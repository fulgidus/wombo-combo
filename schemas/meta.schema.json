{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/fulgidus/wombo/schemas/meta.schema.json",
  "title": "wombo-combo Task Store Metadata",
  "description": "Schema for _meta.yml files in .wombo-combo/tasks/ and .wombo-combo/archive/",
  "type": "object",
  "required": ["version", "meta"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version (currently \"1.0\")"
    },
    "meta": {
      "type": "object",
      "required": ["created_at", "updated_at", "project", "generator", "maintainer"],
      "additionalProperties": false,
      "properties": {
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp when this store was created"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of last modification"
        },
        "project": {
          "type": "string",
          "description": "Project name"
        },
        "generator": {
          "type": "string",
          "description": "Tool that generated this file (wombo-combo)"
        },
        "maintainer": {
          "type": "string",
          "description": "Primary maintainer or team"
        }
      }
    }
  }
}
