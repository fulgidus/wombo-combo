{"type":"tool_use","timestamp":1773351842417,"sessionID":"ses_31c010c9effeOfeCSqmf0ROAdl","part":{"id":"prt_ce400e9bd002QnCqiDzUP93JxI","sessionID":"ses_31c010c9effeOfeCSqmf0ROAdl","messageID":"msg_ce400dff3001CdkDZHva6ayLwR","type":"tool","callID":"toolu_vrtx_01TPyypiNQE7z3buD1SGKM4W","tool":"write","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-dynamic-agent-types/src/lib/agent-registry.ts","content":"/**\n * agent-registry.ts — Fetch agent definitions from the agency-agents GitHub repo.\n *\n * Responsibilities:\n *   - Fetch the full file tree from msitarzewski/agency-agents via GitHub API\n *   - Parse agent Markdown files (YAML frontmatter + body)\n *   - Cache agent definitions locally to avoid repeated network calls\n *   - Support listing available agents and fetching by name\n *   - Support offline mode using cached agents\n */\n\nimport { existsSync, mkdirSync, readFileSync, writeFileSync, readdirSync, statSync } from \"node:fs\";\nimport { resolve, join, basename } from \"node:path\";\nimport { parse as parseYaml } from \"yaml\";\nimport type { WomboConfig } from \"../config.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\n/** Frontmatter fields from an agency-agents Markdown file */\nexport interface AgencyAgentFrontmatter {\n  name: string;\n  description: string;\n  color?: string;\n  emoji?: string;\n  vibe?: string;\n}\n\n/** A parsed agent definition from the registry */\nexport interface RegistryAgent {\n  /** Unique slug derived from filename (e.g., \"engineering-frontend-developer\") */\n  slug: string;\n  /** Division/category directory (e.g., \"engineering\", \"design\") */\n  division: string;\n  /** Relative path in the repo (e.g., \"engineering/engineering-frontend-developer.md\") */\n  path: string;\n  /** Parsed frontmatter */\n  frontmatter: AgencyAgentFrontmatter;\n  /** Raw Markdown body (everything after the frontmatter) */\n  body: string;\n  /** Full raw content (frontmatter + body) */\n  raw: string;\n}\n\n/** Minimal entry from the GitHub tree API */\ninterface GitTreeEntry {\n  path: string;\n  type: string;\n  sha: string;\n}\n\n/** Cached tree index stored as JSON */\ninterface CachedTreeIndex {\n  fetchedAt: string;\n  repo: string;\n  agents: Array<{\n    slug: string;\n    division: string;\n    path: string;\n  }>;\n}\n\n// ---------------------------------------------------------------------------\n// Constants\n// ---------------------------------------------------------------------------\n\nconst GITHUB_API_BASE = \"https://api.github.com\";\nconst GITHUB_RAW_BASE = \"https://raw.githubusercontent.com\";\nconst TREE_INDEX_FILE = \"_tree-index.json\";\n\n// ---------------------------------------------------------------------------\n// Cache Directory Helpers\n// ---------------------------------------------------------------------------\n\nfunction getCacheDir(projectRoot: string, config: WomboConfig): string {\n  return resolve(projectRoot, config.agentRegistry.cacheDir);\n}\n\nfunction ensureCacheDir(projectRoot: string, config: WomboConfig): string {\n  const dir = getCacheDir(projectRoot, config);\n  if (!existsSync(dir)) {\n    mkdirSync(dir, { recursive: true });\n  }\n  return dir;\n}\n\n// ---------------------------------------------------------------------------\n// Tree Index (list of available agents)\n// ---------------------------------------------------------------------------\n\n/**\n * Fetch the full file tree from the agency-agents GitHub repo.\n * Returns a list of agent entries (Markdown files only, excluding README, etc.)\n */\nasync function fetchRemoteTree(config: WomboConfig): Promise<GitTreeEntry[]> {\n  const url = `${GITHUB_API_BASE}/repos/${config.agentRegistry.repo}/git/trees/main?recursive=1`;\n\n  const response = await fetch(url, {\n    headers: {\n      Accept: \"application/vnd.github.v3+json\",\n      \"User-Agent\": \"wombo-combo\",\n      ...(process.env.GITHUB_TOKEN\n        ? { Authorization: `token ${process.env.GITHUB_TOKEN}` }\n        : {}),\n    },\n  });\n\n  if (!response.ok) {\n    throw new Error(\n      `Failed to fetch agent registry tree: ${response.status} ${response.statusText}`\n    );\n  }\n\n  const data = (await response.json()) as { tree: GitTreeEntry[] };\n  return data.tree;\n}\n\n/**\n * Filter tree entries to only agent Markdown files.\n * Agents are .md files inside division directories (not root-level files like README.md).\n */\nfunction filterAgentEntries(tree: GitTreeEntry[]): Array<{\n  slug: string;\n  division: string;\n  path: string;\n}> {\n  return tree\n    .filter((entry) => {\n      if (entry.type !== \"blob\") return false;\n      if (!entry.path.endsWith(\".md\")) return false;\n      // Must be inside a directory (division/filename.md)\n      const parts = entry.path.split(\"/\");\n      if (parts.length < 2) return false;\n      // Exclude README files\n      const filename = parts[parts.length - 1];\n      if (filename.toLowerCase() === \"readme.md\") return false;\n      return true;\n    })\n    .map((entry) => {\n      const parts = entry.path.split(\"/\");\n      const filename = parts[parts.length - 1];\n      const slug = filename.replace(/\\.md$/, \"\");\n      // Division is everything before the filename\n      const division = parts.slice(0, -1).join(\"/\");\n      return { slug, division, path: entry.path };\n    });\n}\n\n/**\n * Load the cached tree index, or return null if it doesn't exist or is expired.\n */\nfunction loadCachedTreeIndex(\n  projectRoot: string,\n  config: WomboConfig\n): CachedTreeIndex | null {\n  const cacheDir = getCacheDir(projectRoot, config);\n  const indexPath = join(cacheDir, TREE_INDEX_FILE);\n\n  if (!existsSync(indexPath)) return null;\n\n  try {\n    const raw = readFileSync(indexPath, \"utf-8\");\n    const index = JSON.parse(raw) as CachedTreeIndex;\n\n    // Check TTL\n    const fetchedAt = new Date(index.fetchedAt).getTime();\n    const now = Date.now();\n    if (now - fetchedAt > config.agentRegistry.cacheTtlMs) {\n      return null; // Expired\n    }\n\n    return index;\n  } catch {\n    return null;\n  }\n}\n\n/**\n * Save the tree index to the cache directory.\n */\nfunction saveCachedTreeIndex(\n  projectRoot: string,\n  config: WomboConfig,\n  agents: Array<{ slug: string; division: string; path: string }>\n): void {\n  const cacheDir = ensureCacheDir(projectRoot, config);\n  const indexPath = join(cacheDir, TREE_INDEX_FILE);\n\n  const index: CachedTreeIndex = {\n    fetchedAt: new Date().toISOString(),\n    repo: config.agentRegistry.repo,\n    agents,\n  };\n\n  writeFileSync(indexPath, JSON.stringify(index, null, 2), \"utf-8\");\n}\n\n// ---------------------------------------------------------------------------\n// Agent Content Fetching\n// ---------------------------------------------------------------------------\n\n/**\n * Fetch raw content of an agent definition file from GitHub.\n */\nasync function fetchAgentContent(\n  agentPath: string,\n  config: WomboConfig\n): Promise<string> {\n  const url = `${GITHUB_RAW_BASE}/${config.agentRegistry.repo}/main/${agentPath}`;\n\n  const response = await fetch(url, {\n    headers: {\n      \"User-Agent\": \"wombo-combo\",\n      ...(process.env.GITHUB_TOKEN\n        ? { Authorization: `token ${process.env.GITHUB_TOKEN}` }\n        : {}),\n    },\n  });\n\n  if (!response.ok) {\n    throw new Error(\n      `Failed to fetch agent \"${agentPath}\": ${response.status} ${response.statusText}`\n    );\n  }\n\n  return response.text();\n}\n\n/**\n * Parse a raw Markdown file with YAML frontmatter into a RegistryAgent.\n */\nfunction parseAgentMarkdown(\n  raw: string,\n  slug: string,\n  division: string,\n  path: string\n): RegistryAgent {\n  // Extract frontmatter between --- markers\n  const fmMatch = raw.match(/^---\\s*\\n([\\s\\S]*?)\\n---\\s*\\n([\\s\\S]*)$/);\n\n  let frontmatter: AgencyAgentFrontmatter;\n  let body: string;\n\n  if (fmMatch) {\n    try {\n      const parsed = parseYaml(fmMatch[1]) as Record<string, unknown>;\n      frontmatter = {\n        name: (parsed.name as string) || slug,\n        description: (parsed.description as string) || \"\",\n        color: parsed.color as string | undefined,\n        emoji: parsed.emoji as string | undefined,\n        vibe: parsed.vibe as string | undefined,\n      };\n    } catch {\n      frontmatter = { name: slug, description: \"\" };\n    }\n    body = fmMatch[2].trim();\n  } else {\n    // No frontmatter — treat entire content as body\n    frontmatter = { name: slug, description: \"\" };\n    body = raw.trim();\n  }\n\n  return { slug, division, path, frontmatter, body, raw };\n}\n\n/**\n * Get the cached content file path for an agent.\n */\nfunction agentCachePath(\n  projectRoot: string,\n  config: WomboConfig,\n  slug: string\n): string {\n  const cacheDir = getCacheDir(projectRoot, config);\n  return join(cacheDir, `${slug}.md`);\n}\n\n/**\n * Load an agent from the local cache, or return null if not cached.\n */\nfunction loadCachedAgent(\n  projectRoot: string,\n  config: WomboConfig,\n  slug: string,\n  division: string,\n  path: string\n): RegistryAgent | null {\n  const cachePath = agentCachePath(projectRoot, config, slug);\n  if (!existsSync(cachePath)) return null;\n\n  try {\n    const raw = readFileSync(cachePath, \"utf-8\");\n    return parseAgentMarkdown(raw, slug, division, path);\n  } catch {\n    return null;\n  }\n}\n\n/**\n * Save an agent's raw content to the local cache.\n */\nfunction cacheAgent(\n  projectRoot: string,\n  config: WomboConfig,\n  slug: string,\n  raw: string\n): void {\n  const cacheDir = ensureCacheDir(projectRoot, config);\n  const cachePath = join(cacheDir, `${slug}.md`);\n  writeFileSync(cachePath, raw, \"utf-8\");\n}\n\n// ---------------------------------------------------------------------------\n// Public API\n// ---------------------------------------------------------------------------\n\n/**\n * List all available agents from the registry.\n * Uses cached tree index if available and not expired; fetches from GitHub otherwise.\n * Falls back to locally cached agents if offline.\n */\nexport async function listRegistryAgents(\n  projectRoot: string,\n  config: WomboConfig\n): Promise<Array<{ slug: string; division: string; path: string }>> {\n  // Try cached index first\n  const cached = loadCachedTreeIndex(projectRoot, config);\n  if (cached) {\n    return cached.agents;\n  }\n\n  // Try to fetch from GitHub\n  try {\n    const tree = await fetchRemoteTree(config);\n    const agents = filterAgentEntries(tree);\n    saveCachedTreeIndex(projectRoot, config, agents);\n    return agents;\n  } catch (err) {\n    // Offline fallback: return agents from local cache\n    const cacheDir = getCacheDir(projectRoot, config);\n    if (!existsSync(cacheDir)) return [];\n\n    const files = readdirSync(cacheDir).filter(\n      (f) => f.endsWith(\".md\") && f !== TREE_INDEX_FILE\n    );\n\n    return files.map((f) => {\n      const slug = f.replace(/\\.md$/, \"\");\n      return { slug, division: \"cached\", path: `cached/${f}` };\n    });\n  }\n}\n\n/**\n * Get a specific agent by slug from the registry.\n * Uses cache if available, fetches from GitHub otherwise.\n * Falls back to locally cached content if offline.\n *\n * @returns The parsed RegistryAgent, or null if not found.\n */\nexport async function getRegistryAgent(\n  projectRoot: string,\n  config: WomboConfig,\n  slug: string\n): Promise<RegistryAgent | null> {\n  // First, find the agent in the tree index to get its path and division\n  const agents = await listRegistryAgents(projectRoot, config);\n  const entry = agents.find((a) => a.slug === slug);\n\n  if (!entry) {\n    // Check local cache as last resort (might have the content even if not in index)\n    const cachePath = agentCachePath(projectRoot, config, slug);\n    if (existsSync(cachePath)) {\n      const raw = readFileSync(cachePath, \"utf-8\");\n      return parseAgentMarkdown(raw, slug, \"cached\", `cached/${slug}.md`);\n    }\n    return null;\n  }\n\n  // Try loading from cache first\n  const cached = loadCachedAgent(projectRoot, config, slug, entry.division, entry.path);\n  if (cached) {\n    return cached;\n  }\n\n  // Fetch from GitHub\n  try {\n    const raw = await fetchAgentContent(entry.path, config);\n    cacheAgent(projectRoot, config, slug, raw);\n    return parseAgentMarkdown(raw, slug, entry.division, entry.path);\n  } catch {\n    // Last resort: check if we have any cached version\n    const cachePath = agentCachePath(projectRoot, config, slug);\n    if (existsSync(cachePath)) {\n      const raw = readFileSync(cachePath, \"utf-8\");\n      return parseAgentMarkdown(raw, slug, entry.division, entry.path);\n    }\n    return null;\n  }\n}\n\n/**\n * Search for agents matching a query string (searches slug and name).\n */\nexport async function searchRegistryAgents(\n  projectRoot: string,\n  config: WomboConfig,\n  query: string\n): Promise<Array<{ slug: string; division: string; path: string }>> {\n  const agents = await listRegistryAgents(projectRoot, config);\n  const lowerQuery = query.toLowerCase();\n\n  return agents.filter(\n    (a) =>\n      a.slug.toLowerCase().includes(lowerQuery) ||\n      a.division.toLowerCase().includes(lowerQuery)\n  );\n}\n\n/**\n * Check if the registry cache is available (has a tree index or cached agents).\n * Useful for determining if offline mode is possible.\n */\nexport function isRegistryCacheAvailable(\n  projectRoot: string,\n  config: WomboConfig\n): boolean {\n  const cacheDir = getCacheDir(projectRoot, config);\n  if (!existsSync(cacheDir)) return false;\n\n  const indexPath = join(cacheDir, TREE_INDEX_FILE);\n  if (existsSync(indexPath)) return true;\n\n  // Check for any cached .md files\n  const files = readdirSync(cacheDir).filter((f) => f.endsWith(\".md\"));\n  return files.length > 0;\n}\n\n/**\n * Check if a specific agent is cached locally.\n */\nexport function isAgentCached(\n  projectRoot: string,\n  config: WomboConfig,\n  slug: string\n): boolean {\n  return existsSync(agentCachePath(projectRoot, config, slug));\n}\n"},"output":"Wrote file successfully.","title":"src/lib/agent-registry.ts","metadata":{"diagnostics":{"/home/fulgidus/Documents/wombo-dynamic-agent-types/src/lib/templates.ts":[],"/home/fulgidus/Documents/wombo-dynamic-agent-types/src/commands/launch.ts":[{"range":{"start":{"line":49,"character":2},"end":{"line":49,"character":18}},"message":"'retryInteractive' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"}],"/home/fulgidus/Documents/wombo-dynamic-agent-types/src/lib/launcher.ts":[],"/home/fulgidus/Documents/wombo-dynamic-agent-types/src/lib/prompt.ts":[],"/home/fulgidus/Documents/wombo-dynamic-agent-types/src/lib/features.ts":[],"/home/fulgidus/Documents/wombo-dynamic-agent-types/src/config.ts":[],"/home/fulgidus/Documents/wombo-dynamic-agent-types/src/index.ts":[{"range":{"start":{"line":447,"character":8},"end":{"line":447,"character":14}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":543,"character":8},"end":{"line":543,"character":14}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":568,"character":6},"end":{"line":568,"character":12}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":601,"character":8},"end":{"line":601,"character":14}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":627,"character":10},"end":{"line":627,"character":16}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":668,"character":8},"end":{"line":668,"character":1