{"type":"tool_use","timestamp":1773351685747,"sessionID":"ses_31c010c9effeOfeCSqmf0ROAdl","part":{"id":"prt_ce3ff4dc2001OmaqSfsD4UVo1a","sessionID":"ses_31c010c9effeOfeCSqmf0ROAdl","messageID":"msg_ce3ff413e001Br7VDSoZWyMaCQ","type":"tool","callID":"toolu_vrtx_01VroknmB61TfXK1uD5LM4Wn","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-dynamic-agent-types/src/config.ts"},"output":"<path>/home/fulgidus/Documents/wombo-dynamic-agent-types/src/config.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * config.ts — Load wombo.json, merge with defaults, validate, expose typed config.\n3:  *\n4:  * The config file lives at the target project root (the repo being orchestrated).\n5:  * All values have sensible defaults so minimal config works out of the box.\n6:  */\n7: \n8: import { readFileSync, existsSync } from \"node:fs\";\n9: import { resolve } from \"node:path\";\n10: \n11: // ---------------------------------------------------------------------------\n12: // Types\n13: // ---------------------------------------------------------------------------\n14: \n15: export interface WomboConfig {\n16:   /** Path to the features YAML file relative to project root */\n17:   featuresFile: string;\n18:   /** Base branch to create feature branches from */\n19:   baseBranch: string;\n20:   /** Build configuration */\n21:   build: {\n22:     /** Build command to run in worktrees */\n23:     command: string;\n24:     /** Build timeout in milliseconds */\n25:     timeout: number;\n26:     /** Build artifact directory (for quick \"did it build?\" checks) */\n27:     artifactDir: string;\n28:   };\n29:   /** Install configuration */\n30:   install: {\n31:     /** Install command to run in worktrees */\n32:     command: string;\n33:     /** Install timeout in milliseconds */\n34:     timeout: number;\n35:   };\n36:   /** Git configuration */\n37:   git: {\n38:     /** Branch name prefix for feature branches */\n39:     branchPrefix: string;\n40:     /** Worktree directory name prefix */\n41:     worktreePrefix: string;\n42:     /** Git remote name */\n43:     remote: string;\n44:     /** Merge strategy flag */\n45:     mergeStrategy: string;\n46:   };\n47:   /** Agent configuration */\n48:   agent: {\n49:     /** Path to agent binary (null = auto-detect) */\n50:     bin: string | null;\n51:     /** Agent name to pass via --agent flag */\n52:     name: string;\n53:     /** Config files/dirs to copy into worktrees */\n54:     configFiles: string[];\n55:     /** tmux session name prefix */\n56:     tmuxPrefix: string;\n57:   };\n58:   /** Backup configuration for features file */\n59:   backup: {\n60:     /** Maximum number of timestamped backups to keep */\n61:     maxBackups: number;\n62:   };\n63:   /** Default runtime values */\n64:   defaults: {\n65:     /** Max concurrent agents */\n66:     maxConcurrent: number;\n67:     /** Max retries per agent */\n68:     maxRetries: number;\n69:   };\n70: }\n71: \n72: // ---------------------------------------------------------------------------\n73: // Defaults\n74: // ---------------------------------------------------------------------------\n75: \n76: export const DEFAULT_CONFIG: WomboConfig = {\n77:   featuresFile: \".features.yml\",\n78:   baseBranch: \"develop\",\n79:   build: {\n80:     command: \"bun run build\",\n81:     timeout: 300_000,\n82:     artifactDir: \"dist\",\n83:   },\n84:   install: {\n85:     command: \"bun install\",\n86:     timeout: 120_000,\n87:   },\n88:   git: {\n89:     branchPrefix: \"feature/\",\n90:     worktreePrefix: \"wombo-\",\n91:     remote: \"origin\",\n92:     mergeStrategy: \"--no-ff\",\n93:   },\n94:   agent: {\n95:     bin: null,\n96:     name: \"wave-worker\",\n97:     configFiles: [\".opencode/\", \"opencode.json\", \"AGENTS.md\", \"agent/\"],\n98:     tmuxPrefix: \"wombo\",\n99:   },\n100:   backup: {\n101:     maxBackups: 5,\n102:   },\n103:   defaults: {\n104:     maxConcurrent: 6,\n105:     maxRetries: 2,\n106:   },\n107: };\n108: \n109: // ---------------------------------------------------------------------------\n110: // Config File Name\n111: // ---------------------------------------------------------------------------\n112: \n113: export const CONFIG_FILE = \"wombo.json\";\n114: \n115: // ---------------------------------------------------------------------------\n116: // Loader\n117: // ---------------------------------------------------------------------------\n118: \n119: /**\n120:  * Deep-merge source into target. Only merges plain objects, not arrays.\n121:  */\n122: function deepMerge<T extends Record<string, any>>(target: T, source: Partial<T>): T {\n123:   const result = { ...target };\n124:   for (const key of Object.keys(source) as (keyof T)[]) {\n125:     const srcVal = source[key];\n126:     const tgtVal = target[key];\n127:     if (\n128:       srcVal !== undefined &&\n129:       srcVal !== null &&\n130:       typeof srcVal === \"object\" &&\n131:       !Array.isArray(srcVal) &&\n132:       typeof tgtVal === \"object\" &&\n133:       !Array.isArray(tgtVal) &&\n134:       tgtVal !== null\n135:     ) {\n136:       result[key] = deepMerge(tgtVal as any, srcVal as any);\n137:     } else if (srcVal !== undefined) {\n138:       result[key] = srcVal as T[keyof T];\n139:     }\n140:   }\n141:   return result;\n142: }\n143: \n144: /**\n145:  * Load wombo.json from the given project root and merge with defaults.\n146:  * Returns the full config. If no config file exists, returns defaults.\n147:  */\n148: export function loadConfig(projectRoot: string): WomboConfig {\n149:   const configPath = resolve(projectRoot, CONFIG_FILE);\n150: \n151:   if (!existsSync(configPath)) {\n152:     return { ...DEFAULT_CONFIG };\n153:   }\n154: \n155:   try {\n156:     const raw = readFileSync(configPath, \"utf-8\");\n157:     const partial = JSON.parse(raw) as Partial<WomboConfig>;\n158:     return deepMerge(DEFAULT_CONFIG, partial);\n159:   } catch (err: any) {\n160:     throw new Error(`Failed to load ${CONFIG_FILE}: ${err.message}`);\n161:   }\n162: }\n163: \n164: /**\n165:  * Resolve the agent binary path. Priority:\n166:  *   1. config.agent.bin (explicit)\n167:  *   2. OPENCODE_BIN env var\n168:  *   3. ~/.opencode/bin/opencode (default install location)\n169:  */\n170: export function resolveAgentBin(config: WomboConfig): string {\n171:   if (config.agent.bin) return config.agent.bin;\n172:   if (process.env.OPENCODE_BIN) return process.env.OPENCODE_BIN;\n173:   return resolve(process.env.HOME || \"~\", \".opencode/bin/opencode\");\n174: }\n175: \n176: /**\n177:  * Validate the config for obvious issues. Throws on error.\n178:  */\n179: export function validateConfig(config: WomboConfig): void {\n180:   if (!config.featuresFile) {\n181:     throw new Error(\"config.featuresFile must be a non-empty string\");\n182:   }\n183:   if (!config.baseBranch) {\n184:     throw new Error(\"config.baseBranch must be a non-empty string\");\n185:   }\n186:   if (!config.build.command) {\n187:     throw new Error(\"config.build.command must be a non-empty string\");\n188:   }\n189:   if (!config.install.command) {\n190:     throw new Error(\"config.install.command must be a non-empty string\");\n191:   }\n192:   if (!config.git.branchPrefix) {\n193:     throw new Error(\"config.git.branchPrefix must be a non-empty string\");\n194:   }\n195:   if (!config.git.worktreePrefix) {\n196:     throw new Error(\"config.git.worktreePrefix must be a non-empty string\");\n197:   }\n198:   if (config.defaults.maxConcurrent < 1) {\n199:     throw new Error(\"config.defaults.maxConcurrent must be >= 1\");\n200:   }\n201:   if (config.defaults.maxRetries < 0) {\n202:     throw new Error(\"config.defaults.maxRetries must be >= 0\");\n203:   }\n204:   if (config.backup.maxBackups < 0) {\n205:     throw new Error(\"config.backup.maxBackups must be >= 0\");\n206:   }\n207: }\n208: \n209: /**\n210:  * Generate the default wombo.json content string (for `wombo init`).\n211:  */\n212: export function generateDefaultConfig(): string {\n213:   return JSON.stringify(DEFAULT_CONFIG, null, 2) + \"\\n\";\n214: }\n\n(End of file - total 214 lines)\n</content>","title":"src/config.ts","metadata":{"preview":"/**\n * config.ts — Load wombo.json, merge with defaults, validate, expose typed config.\n *\n * The config file lives at the target project root (the repo being orchestrated).\n * All values have sensible defaults so minimal config works out of the box.\n */\n\nimport { readFileSync, existsSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface WomboConfig {\n  /** Path to the features YAML file relative to project root */\n  featuresFile: string;\n  /** Base branch to create feature branches from */\n  baseBranch: string;\n  /** Build configuration */","truncated":false,"loaded":[]},"time":{"start":1773351685743,"end":1773351685746}}}}
{"type":"tool_use","timestamp":1773351686356,"sessionID":"ses_31c010c9effeOfeCSqmf0ROAdl","part":{"id":"prt_ce3ff4e71001zxJ5jW6uvHkqFL","sessionID":"ses_31c010c9effeOfeCSqmf0ROAdl","messageID":"msg_ce3ff413e001Br7VDSoZWyMaCQ","type":"tool","callID":"toolu_vrtx_01LGPEnt3nBWX76XzLJBTRpu","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-dynamic-agent-types/src/templates/wave-worker.md"},"output":"<path>/home/fulgidus/Documents/wombo-dynamic-agent-types/src/templates/wave-worker.md</path>\n<type>file</type>\n<content>1: ---\n2: description: >-\n3:   Autonomous coding agent launched by wombo into isolated git worktrees to\n4:   implement features from .features.yml. Operates headlessly with no human\n5:   interaction. Launched by `wombo launch` when there are backlog/planned\n6:   features ready for implementation.\n7: \n8:   Examples:\n9: \n10:   - user: \"Implement feature cli-bugs from the backlog\"\n11:     assistant: \"I'll read the feature spec from .features.yml and implement all subtasks.\"\n12: \n13:   - user: \"Fix the build errors from the last run\"\n14:     assistant: \"I'll read the build output, identify the failures, and fix them.\"\n15: mode: primary\n16: ---\n17: You are an autonomous coding agent launched by wombo into an isolated git worktree.\n18: You implement features defined in `.features.yml` with zero human interaction.\n19: \n20: ## Your Environment\n21: \n22: - You are in a **git worktree**, not the main repository. Your branch is `feature/<feature-id>`.\n23: - The feature you must implement was passed to you as a prompt. It includes the full spec: description, subtasks, constraints, forbidden items, references, and build command.\n24: - Config files from the main repo (AGENTS.md, opencode config, this agent definition) have been copied into your worktree.\n25: - **Runtime:** Bun (not Node). TypeScript, strict mode, ESM only.\n26: \n27: ## Operational Rules\n28: \n29: **You run headlessly. You MUST:**\n30: - NEVER ask questions or request clarification. Make reasonable decisions from context and code conventions.\n31: - NEVER enter plan mode or propose plans for approval. Execute directly.\n32: - NEVER wait for confirmation. Act decisively.\n33: - If ambiguity exists, examine the codebase for patterns and follow them.\n34: - If you encounter an error, debug and fix it yourself (up to 3 attempts per issue).\n35: \n36: ## Workflow\n37: \n38: 1. **Read the prompt** — it contains the full feature spec from `.features.yml` including subtasks, constraints, and forbidden items.\n39: 2. **Read AGENTS.md** if present — it contains project-specific hard constraints and conventions.\n40: 3. **Explore the codebase** — understand the architecture before writing code. Read key files, follow imports, understand patterns.\n41: 4. **Plan with TodoWrite** — break the work into concrete steps.\n42: 5. **Implement subtasks in order** — commit after each logical unit of work.\n43: 6. **Typecheck** — run `bun run typecheck` (or the project's equivalent).\n44: 7. **Build** — run the build command from the prompt to verify everything compiles.\n45: 8. **Fix any failures** — if typecheck or build fails, fix and re-run until it passes.\n46: \n47: ## Commit Guidelines\n48: \n49: - Use conventional commits: `feat(scope):`, `fix(scope):`, `refactor(scope):`\n50: - Scope should be the feature ID or a relevant module name\n51: - Commit after each logical unit of work (roughly per subtask)\n52: - Do NOT squash everything into one commit\n53: - Do NOT push to remote — the orchestrator handles that\n54: - Do NOT modify `.features.yml` — the orchestrator handles status updates\n55: \n56: ## Constraints\n57: \n58: - **Stay in scope.** Only implement the feature you were assigned. Do not modify unrelated code.\n59: - **Respect the feature's constraints and forbidden lists.** These are non-negotiable.\n60: - **Build must pass.** The orchestrator will verify your build. If it fails, you'll be retried with the error output.\n61: - **No new dependencies** unless the feature spec explicitly requires them.\n62: - **Follow existing code style** — indentation, naming, patterns, module structure.\n63: \n64: ## Error Recovery\n65: \n66: If something fails:\n67: 1. Read error messages carefully and diagnose the root cause.\n68: 2. Check if the error is in your new code or pre-existing.\n69: 3. Attempt up to 3 fix-and-retry iterations per issue.\n70: 4. If truly blocked by an external factor, document the blocker in a commit message, implement what you can, and move on.\n71: 5. Never leave the worktree in a broken state — if you cannot complete a feature, revert partial changes and document why.\n72: \n73: ## What You Must Never Do\n74: \n75: - Never ask for human input or confirmation\n76: - Never enter plan mode\n77: - Never modify files outside the scope of the current feature\n78: - Never commit code that breaks the build\n79: - Never ignore errors without investigation\n80: - Never push to remote\n\n(End of file - total 80 lines)\n</content>","title":"src/templates/wave-worker.md","metadata":{"preview":"---\ndescription: >-\n  Autonomous coding agent launched by wombo into isolated git worktrees to\n  implement features from .features.yml. Operates headlessly with no human\n  interaction. Launched by `wombo launch` when there are backlog/planned\n  features ready for implementation.\n\n  Examples:\n\n  - user: \"Implement feature cli-bugs from the backlog\"\n    assistant: \"I'll read the feature spec from .features.yml and implement all subtasks.\"\n\n  - user: \"Fix the build errors from the last run\"\n    assistant: \"I'll read the build output, identify the failures, and fix them.\"\nmode: primary\n---\nYou are an autonomous coding agent launched by wombo into an isolated git worktree.\nYou implement features defined in `.features.yml` with zero human interaction.\n\n## Your Environment","truncated":false,"loaded":[]},"time":{"start":1773351686354,"end":1773351686356}}}}
{"type":"text","timestamp":1773351686800,"sessionID":"ses_31c010c9effeOfeCSqmf0ROAdl","part":{"id":"prt_ce3ff4a6e001Mq9lezd63PKDG6","sessionID":"ses_31c010c9effeOfeCSqmf0ROAdl","messageID":"msg_ce3ff413e001Br7VDSoZWyMaCQ","type":"text","text":"Now let me read more critical files: the config, index.ts, and the wave-worker template:","time":{"start":1773351686799,"end":1773351686799}}}
{"type":"tool_use","timestamp":1773351686802,"sessionID":"ses_31c010c9effeOfeCSqmf0ROAdl","part":{"id":"prt_ce3ff50d3001Nr3LNx4MRhFsXS","sessionID":"ses_31c010c9effeOfeCSqmf0ROAdl","messageID":"msg_ce3ff413e001Br7VDSoZWyMaCQ","type":"tool","callID":"toolu_vrtx_01JLnWrrAxBExxXYtTbMC28a","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-dynamic-agent-types/src/index.ts"},"output":"<path>/home/fulgidus/Documents/wombo-dynamic-agent-types/src/index.ts</path>\n<type>file</type>\n<content>1: #!/usr/bin/env bun\n2: /**\n3:  * index.ts — CLI entry point for the Wombo agent orchestration system.\n4:  *\n5:  * Usage:\n6:  *   wombo init\n7:  *   wombo launch --top-priority 3\n8:  *   wombo launch --quickest-wins 5\n9:  *   wombo launch --priority high\n10:  *   wombo launch --difficulty easy\n11:  *   wombo launch --features \"feat-a,feat-b\"\n12:  *   wombo launch --all-ready\n13:  *   wombo launch ... --max-concurrent 3 --model \"anthropic/claude-sonnet-4-20250514\"\n14:  *   wombo launch ... --interactive\n15:  *   wombo resume\n16:  *   wombo status\n17:  *   wombo verify [feature-id]\n18:  *   wombo merge [feature-id]\n19:  *   wombo retry <feature-id>\n20:  *   wombo cleanup\n21:  *   wombo features list [--status <s>] [--priority <p>] [--difficulty <d>] [--ready] [--include-archive]\n22:  *   wombo features add <id> <title> [options]\n23:  *   wombo features set-status <feature-id> <status>\n24:  *   wombo features check\n25:  *   wombo features archive [feature-id] [--dry-run]\n26:  *   wombo features show <feature-id>\n27:  *   wombo features graph [--ascii] [--mermaid] [--subtasks] [--status <s>]\n28:  *   wombo help\n29:  *   wombo --version\n30:  */\n31: \n32: import { resolve } from \"node:path\";\n33: import { existsSync, readFileSync } from \"node:fs\";\n34: import { loadConfig, validateConfig } from \"./config.js\";\n35: import { loadState, saveState } from \"./lib/state.js\";\n36: \n37: // ---------------------------------------------------------------------------\n38: // Dev-mode guard: warn if running the global binary inside the wombo repo\n39: // ---------------------------------------------------------------------------\n40: \n41: function checkDevModeGuard(): void {\n42:   const cwd = process.cwd();\n43:   const pkgPath = resolve(cwd, \"package.json\");\n44: \n45:   // Are we inside the wombo repo?\n46:   if (!existsSync(pkgPath)) return;\n47: \n48:   let pkgName: string | undefined;\n49:   try {\n50:     const raw = readFileSync(pkgPath, \"utf-8\");\n51:     pkgName = JSON.parse(raw).name;\n52:   } catch {\n53:     return;\n54:   }\n55:   if (pkgName !== \"wombo\") return;\n56: \n57:   // We're in the wombo repo. Is the source being run from a different location?\n58:   // import.meta.dir = directory of THIS file (index.ts). If it's under cwd,\n59:   // we're running local source (bun dev). If it's elsewhere (e.g. ~/.bun/install),\n60:   // we're running the globally installed binary.\n61:   const sourceDir = resolve(import.meta.dir);\n62:   const projectSrc = resolve(cwd, \"src\");\n63: \n64:   if (!sourceDir.startsWith(projectSrc)) {\n65:     console.warn(\n66:       \"\\x1b[33m[WARNING]\\x1b[0m You are running the globally installed wombo binary \" +\n67:       \"inside the wombo repo.\\n\" +\n68:       \"  Use \\x1b[1mbun dev <command>\\x1b[0m instead to run from local source.\\n\" +\n69:       \"  See AGENTS.md for details.\\n\"\n70:     );\n71:   }\n72: }\n73: \n74: import { cmdInit } from \"./commands/init.js\";\n75: import { cmdLaunch } from \"./commands/launch.js\";\n76: import { cmdResume } from \"./commands/resume.js\";\n77: import { cmdStatus } from \"./commands/status.js\";\n78: import { cmdVerify } from \"./commands/verify.js\";\n79: import { cmdMerge } from \"./commands/merge.js\";\n80: import { cmdRetry } from \"./commands/retry.js\";\n81: import { cmdCleanup } from \"./commands/cleanup.js\";\n82: import { cmdUpgrade } from \"./commands/upgrade.js\";\n83: import { cmdFeaturesList } from \"./commands/features/list.js\";\n84: import { cmdFeaturesAdd } from \"./commands/features/add.js\";\n85: import { cmdFeaturesSetStatus } from \"./commands/features/set-status.js\";\n86: import { cmdFeaturesCheck } from \"./commands/features/check.js\";\n87: import { cmdFeaturesArchive } from \"./commands/features/archive.js\";\n88: import { cmdFeaturesShow } from \"./commands/features/show.js\";\n89: import { cmdFeaturesGraph } from \"./commands/features/graph.js\";\n90: \n91: import { ensureFeaturesFile } from \"./lib/features.js\";\n92: import type { Priority, Difficulty, FeatureStatus } from \"./lib/features.js\";\n93: import { resolveOutputFormat, type OutputFormat } from \"./lib/output.js\";\n94: import { validateId, validateText, validateBranchName, validateDuration, assertValid } from \"./lib/validate.js\";\n95: import { findCommandDef, commandToSchema, allCommandSchemas } from \"./lib/schema.js\";\n96: \n97: // ---------------------------------------------------------------------------\n98: // Types\n99: // ---------------------------------------------------------------------------\n100: \n101: interface CLIArgs {\n102:   command: string;\n103:   subcommand?: string;\n104:   // Selection options (launch)\n105:   topPriority?: number;\n106:   quickestWins?: number;\n107:   priority?: Priority;\n108:   difficulty?: Difficulty;\n109:   features?: string[];\n110:   allReady?: boolean;\n111:   // Launch / runtime options\n112:   maxConcurrent?: number;\n113:   model?: string;\n114:   interactive: boolean;\n115:   dryRun: boolean;\n116:   baseBranch?: string;\n117:   maxRetries?: number;\n118:   noTui: boolean;\n119:   autoPush: boolean;\n120:   // General\n121:   featureId?: string;\n122:   force: boolean;\n123:   // Output format\n124:   outputFmt: OutputFormat;\n125:   // Upgrade options\n126:   checkOnly: boolean;\n127:   version?: string;\n128:   // Features subcommand extras\n129:   status?: string;\n130:   ready?: boolean;\n131:   includeArchive?: boolean;\n132:   title?: string;\n133:   description?: string;\n134:   effort?: string;\n135:   dependsOn?: string[];\n136:   // Compact output\n137:   fields?: string[];\n138:   // Graph options\n139:   ascii?: boolean;\n140:   mermaidRaw?: boolean;\n141:   graphSubtasks?: boolean;\n142: }\n143: \n144: // ---------------------------------------------------------------------------\n145: // Arg Parsing\n146: // ---------------------------------------------------------------------------\n147: \n148: function parseArgs(argv: string[]): CLIArgs {\n149:   const args = argv.slice(2); // skip 'bun' and script path\n150:   const result: CLIArgs = {\n151:     command: args[0] || \"help\",\n152:     interactive: false,\n153:     dryRun: false,\n154:     noTui: false,\n155:     autoPush: false,\n156:     force: false,\n157:     checkOnly: false,\n158:     outputFmt: resolveOutputFormat(undefined), // auto-detect until --output overrides\n159:   };\n160: \n161:   // If the first arg is \"features\", treat the second positional as the subcommand\n162:   let startIdx = 1;\n163:   if (result.command === \"features\") {\n164:     result.subcommand = args[1] || \"list\";\n165:     startIdx = 2;\n166:   }\n167: \n168:   for (let i = startIdx; i < args.length; i++) {\n169:     const arg = args[i];\n170:     switch (arg) {\n171:       // --- Selection options ---\n172:       case \"--top-priority\":\n173:         result.topPriority = parseInt(args[++i], 10);\n174:         break;\n175:       case \"--quickest-wins\":\n176:         result.quickestWins = parseInt(args[++i], 10);\n177:         break;\n178:       case \"--priority\":\n179:         result.priority = args[++i] as Priority;\n180:         break;\n181:       case \"--difficulty\":\n182:         result.difficulty = args[++i] as Difficulty;\n183:         break;\n184:       case \"--features\":\n185:         result.features = args[++i].split(\",\").map((s) => s.trim());\n186:         break;\n187:       case \"--all-ready\":\n188:         result.allReady = true;\n189:         break;\n190: \n191:       // --- Launch / runtime options ---\n192:       case \"--max-concurrent\":\n193:         result.maxConcurrent = parseInt(args[++i], 10);\n194:         break;\n195:       case \"--model\":\n196:       case \"-m\":\n197:         result.model = args[++i];\n198:         break;\n199:       case \"--interactive\":\n200:         result.interactive = true;\n201:         break;\n202:       case \"--dry-run\":\n203:         result.dryRun = true;\n204:         break;\n205:       case \"--no-tui\":\n206:         result.noTui = true;\n207:         break;\n208:       case \"--auto-push\":\n209:         result.autoPush = true;\n210:         break;\n211:       case \"--base-branch\":\n212:         result.baseBranch = args[++i];\n213:         break;\n214:       case \"--max-retries\":\n215:         result.maxRetries = parseInt(args[++i], 10);\n216:         break;\n217: \n218:       // --- General flags ---\n219:       case \"--force\":\n220:         result.force = true;\n221:         break;\n222:       case \"--check\":\n223:         result.checkOnly = true;\n224:         break;\n225:       case \"--version\":\n226:         result.version = args[++i];\n227:         break;\n228:       case \"--output\":\n229:       case \"-o\":\n230:         result.outputFmt = resolveOutputFormat(args[++i]);\n231:         break;\n232: \n233:       // --- Features subcommand options ---\n234:       case \"--status\":\n235:         result.status = args[++i];\n236:         break;\n237:       case \"--ready\":\n238:         result.ready = true;\n239:         break;\n240:       case \"--include-archive\":\n241:         result.includeArchive = true;\n242:         break;\n243:       case \"--title\":\n244:         result.title = args[++i];\n245:         break;\n246:       case \"--description\":\n247:       case \"--desc\":\n248:         result.description = args[++i];\n249:         break;\n250:       case \"--effort\":\n251:         result.effort = args[++i];\n252:         break;\n253:       case \"--depends-on\":\n254:         result.dependsOn = args[++i].split(\",\").map((s) => s.trim());\n255:         break;\n256:       case \"--fields\":\n257:         result.fields = args[++i].split(\",\").map((s) => s.trim());\n258:         break;\n259: \n260:       // --- Graph options ---\n261:       case \"--ascii\":\n262:         result.ascii = true;\n263:         break;\n264:       case \"--mermaid\":\n265:         result.mermaidRaw = true;\n266:         break;\n267:       case \"--subtasks\":\n268:         result.graphSubtasks = true;\n269:         break;\n270: \n271:       // --- Positional (feature-id, title for add, etc.) ---\n272:       default:\n273:         if (!arg.startsWith(\"-\")) {\n274:           if (!result.featureId) {\n275:             result.featureId = arg;\n276:           } else if (!result.title) {\n277:             result.title = arg;\n278:           }\n279:         }\n280:         break;\n281:     }\n282:   }\n283: \n284:   return result;\n285: }\n286: \n287: // ---------------------------------------------------------------------------\n288: // Help\n289: // ---------------------------------------------------------------------------\n290: \n291: function cmdHelp(): void {\n292:   console.log(`\n293: Wombo — AI Agent Orchestration System\n294: \n295:   WOMBO COMBO! Parallel feature development with AI agents.\n296: \n297: Commands:\n298:   init           Generate wombo.json config in the current project\n299:   launch         Launch a wave of agents to implement features\n300:   resume         Resume a previously stopped wave\n301:   status         Show the status of the current wave\n302:   verify         Run build verification on completed agents\n303:   merge          Merge verified branches into the base branch\n304:   retry          Retry a failed agent\n305:   cleanup        Remove all wave worktrees and tmux sessions\n306:   features       Manage .features.yml (see below)\n307:   upgrade        Check for updates and upgrade wombo\n308:   describe       Emit JSON schema of a command (for AI agents)\n309:   help           Show this help\n310: \n311: Features Subcommands:\n312:   features list            List features (--status, --priority, --difficulty, --ready, --include-archive)\n313:   features add <id> <title> [options]\n314:                            Add a new feature (--desc, --priority, --difficulty, --effort, --depends-on)\n315:   features set-status <id> <status>\n316:                            Change a feature's status\n317:   features check           Validate .features.yml (schema, deps, duplicates, cycles)\n318:   features archive [id]    Move done/cancelled to archive (--dry-run)\n319:   features show <id>       Show feature details\n320:   features graph           Visualize dependency graph (--ascii, --mermaid, --subtasks)\n321: \n322: Selection Options (for launch):\n323:   --top-priority N         Select top N features by priority\n324:   --quickest-wins N        Select N features with lowest effort\n325:   --priority <level>       Filter by priority (critical/high/medium/low/wishlist)\n326:   --difficulty <level>     Filter by difficulty (trivial/easy/medium/hard/very_hard)\n327:   --features \"id1,id2\"     Select specific features by ID\n328:   --all-ready              Select all features whose dependencies are met\n329: \n330: Launch Options:\n331:   --max-concurrent N       Max agents running in parallel (default: from config)\n332:   --model <model>          Model to use (e.g., \"anthropic/claude-sonnet-4-20250514\")\n333:   --interactive            Use tmux TUI mode instead of headless\n334:   --no-tui                 Headless mode without neo-blessed TUI (periodic console dashboard)\n335:   --auto-push              Push base branch to remote after all merges complete\n336:   --dry-run                Show what would be launched without launching\n337:   --base-branch <branch>   Base branch (default: from config)\n338:   --max-retries N          Max retries per agent (default: from config)\n339: \n340: General:\n341:   --version, -V            Print version and exit\n342:   --force                  Force overwrite (e.g., for init) / skip prompts (e.g., for upgrade)\n343:   --output <fmt>           Output format: text (default on TTY) or json (default when piped)\n344:   -o <fmt>                 Alias for --output\n345:   --dry-run                Show what would happen without performing the action\n346:   --fields <list>          Comma-separated fields to include (e.g., id,status,priority)\n347: \n348: Upgrade Options:\n349:   --check                  Only check for updates, don't install\n350:   --version <tag>          Install a specific version (e.g., v0.1.0)\n351: \n352: Examples:\n353:   wombo init\n354:   wombo launch --quickest-wins 3\n355:   wombo launch --priority high --interactive\n356:   wombo launch --features \"auth-flow,search-api\" --max-concurrent 2\n357:   wombo resume\n358:   wombo status\n359:   wombo verify\n360:   wombo merge\n361:   wombo retry auth-flow\n362:   wombo cleanup\n363:   wombo features list --status ready --priority high\n364:   wombo features list --fields id,status,priority --output json\n365:   wombo features add my-feature \"My Cool Feature\" --priority high --difficulty easy\n366:   wombo features set-status my-feature in-progress\n367:   wombo features check\n368:   wombo features archive --dry-run\n369:   wombo features show my-feature\n370:   wombo describe                           # list all commands as JSON\n371:   wombo describe launch                    # describe a specific command\n372:   wombo describe features add              # describe a subcommand\n373: `);\n374: }\n375: \n376: // ---------------------------------------------------------------------------\n377: // Main\n378: // ---------------------------------------------------------------------------\n379: \n380: async function main(): Promise<void> {\n381:   checkDevModeGuard();\n382: \n383:   const PROJECT_ROOT = resolve(process.cwd());\n384:   const args = parseArgs(process.argv);\n385: \n386:   // -----------------------------------------------------------------------\n387:   // Input validation at the CLI boundary\n388:   // -----------------------------------------------------------------------\n389:   if (args.featureId) {\n390:     assertValid(validateId(args.featureId, \"feature ID\"));\n391:   }\n392:   if (args.title) {\n393:     assertValid(validateText(args.title, \"title\"));\n394:   }\n395:   if (args.description) {\n396:     assertValid(validateText(args.description, \"description\"));\n397:   }\n398:   if (args.baseBranch) {\n399:     assertValid(validateBranchName(args.baseBranch, \"base branch\"));\n400:   }\n401:   if (args.effort) {\n402:     assertValid(validateDuration(args.effort, \"effort\"));\n403:   }\n404:   if (args.features) {\n405:     for (const fid of args.features) {\n406:       assertValid(validateId(fid, \"feature ID in --features\"));\n407:     }\n408:   }\n409:   if (args.dependsOn) {\n410:     for (const dep of args.dependsOn) {\n411:       assertValid(validateId(dep, \"dependency ID in --depends-on\"));\n412:     }\n413:   }\n414: \n415:   // Commands that don't need config loading\n416:   if (args.command === \"--version\" || args.command === \"-V\") {\n417:     const pkgPath = resolve(import.meta.dir, \"..\", \"package.json\");\n418:     try {\n419:       const raw = readFileSync(pkgPath, \"utf-8\");\n420:       const pkg = JSON.parse(raw);\n421:       console.log(`wombo ${pkg.version}`);\n422:     } catch {\n423:       console.log(\"wombo (unknown version)\");\n424:     }\n425:     return;\n426:   }\n427: \n428:   if (args.command === \"help\" || args.command === \"--help\" || args.command === \"-h\") {\n429:     cmdHelp();\n430:     return;\n431:   }\n432: \n433:   if (args.command === \"describe\") {\n434:     // Schema introspection: `wombo describe [command]`\n435:     if (!args.featureId) {\n436:       // No command specified — list all commands\n437:       console.log(JSON.stringify(allCommandSchemas(), null, 2));\n438:     } else {\n439:       // Describe a specific command. Handle compound names: \"features list\"\n440:       const cmdName = args.title\n441:         ? `${args.featureId} ${args.title}`\n442:         : args.featureId;\n443:       const def = findCommandDef(cmdName);\n444:       if (!def) {\n445:         console.error(`Unknown command: \"${cmdName}\"`);\n446:         console.error(\"Run 'wombo describe' to list all commands.\");\n447:         process.exit(1);\n448:         return;\n449:       }\n450:       console.log(JSON.stringify(commandToSchema(def), null, 2));\n451:     }\n452:     return;\n453:   }\n454: \n455:   if (args.command === \"init\") {\n456:     await cmdInit({ projectRoot: PROJECT_ROOT, force: args.force });\n457:     return;\n458:   }\n459: \n460:   if (args.command === \"upgrade\") {\n461:     await cmdUpgrade({\n462:       force: args.force,\n463:       version: args.version,\n464:       checkOnly: args.checkOnly,\n465:     });\n466:     return;\n467:   }\n468: \n469:   // Everything else requires config\n470:   const config = loadConfig(PROJECT_ROOT);\n471:   validateConfig(config);\n472: \n473:   // Commands that operate on the features file — ensure it exists first\n474:   const needsFeatures = new Set([\"launch\", \"resume\", \"verify\", \"retry\", \"features\"]);\n475:   if (needsFeatures.has(args.command)) {\n476:     await ensureFeaturesFile(PROJECT_ROOT, config);\n477:   }\n478: \n479:   switch (args.command) {\n480:     case \"launch\":\n481:       await cmdLaunch({\n482:         projectRoot: PROJECT_ROOT,\n483:         config,\n484:         topPriority: args.topPriority,\n485:         quickestWins: args.quickestWins,\n486:         priority: args.priority,\n487:         difficulty: args.difficulty,\n488:         features: args.features,\n489:         allReady: args.allReady,\n490:         maxConcurrent: args.maxConcurrent ?? config.defaults.maxConcurrent,\n491:         model: args.model,\n492:         interactive: args.interactive,\n493:         dryRun: args.dryRun,\n494:         baseBranch: args.baseBranch ?? config.baseBranch,\n495:         maxRetries: args.maxRetries ?? config.defaults.maxRetries,\n496:         noTui: args.noTui,\n497:         autoPush: args.autoPush,\n498:         outputFmt: args.outputFmt,\n499:       });\n500:       break;\n501: \n502:     case \"resume\":\n503:       await cmdResume({\n504:         projectRoot: PROJECT_ROOT,\n505:         config,\n506:         maxConcurrent: args.maxConcurrent,\n507:         model: args.model,\n508:         interactive: args.interactive,\n509:         noTui: args.noTui,\n510:         autoPush: args.autoPush,\n511:         baseBranch: args.baseBranch,\n512:         maxRetries: args.maxRetries,\n513:       });\n514:       break;\n515: \n516:     case \"status\":\n517:       await cmdStatus({ projectRoot: PROJECT_ROOT, config });\n518:       break;\n519: \n520:     case \"verify\":\n521:       await cmdVerify({\n522:         projectRoot: PROJECT_ROOT,\n523:         config,\n524:         featureId: args.featureId,\n525:         model: args.model,\n526:         maxRetries: args.maxRetries,\n527:       });\n528:       break;\n529: \n530:     case \"merge\":\n531:       await cmdMerge({\n532:         projectRoot: PROJECT_ROOT,\n533:         config,\n534:         featureId: args.featureId,\n535:         autoPush: args.autoPush,\n536:         dryRun: args.dryRun,\n537:       });\n538:       break;\n539: \n540:     case \"retry\": {\n541:       if (!args.featureId) {\n542:         console.error(\"Usage: wombo retry <feature-id>\");\n543:         process.exit(1);\n544:         return;\n545:       }\n546:       await cmdRetry({\n547:         projectRoot: PROJECT_ROOT,\n548:         config,\n549:         featureId: args.featureId,\n550:         model: args.model,\n551:         interactive: args.interactive,\n552:         dryRun: args.dryRun,\n553:       });\n554:       break;\n555:     }\n556: \n557:     case \"cleanup\":\n558:       await cmdCleanup({ projectRoot: PROJECT_ROOT, config, dryRun: args.dryRun });\n559:       break;\n560: \n561:     case \"features\":\n562:       await handleFeaturesSubcommand(args, PROJECT_ROOT, config);\n563:       break;\n564: \n565:     default:\n566:       console.error(`Unknown command: ${args.command}`);\n567:       cmdHelp();\n568:       process.exit(1);\n569:       return;\n570:   }\n571: }\n572: \n573: // ---------------------------------------------------------------------------\n574: // Features Subcommand Router\n575: // ---------------------------------------------------------------------------\n576: \n577: async function handleFeaturesSubcommand(\n578:   args: CLIArgs,\n579:   projectRoot: string,\n580:   config: import(\"./config.js\").WomboConfig\n581: ): Promise<void> {\n582:   switch (args.subcommand) {\n583:     case \"list\":\n584:     case \"ls\":\n585:       await cmdFeaturesList({\n586:         projectRoot,\n587:         config,\n588:         status: args.status as FeatureStatus | undefined,\n589:         priority: args.priority,\n590:         difficulty: args.difficulty,\n591:         ready: args.ready,\n592:         includeArchive: args.includeArchive,\n593:         outputFmt: args.outputFmt,\n594:         fields: args.fields,\n595:       });\n596:       break;\n597: \n598:     case \"add\": {\n599:       if (!args.featureId || !args.title) {\n600:         console.error(\"Usage: wombo features add <id> <title> [--desc <desc>] [--priority <p>] [--difficulty <d>] [--effort <e>] [--depends-on <ids>]\");\n601:         process.exit(1);\n602:         return;\n603:       }\n604:       await cmdFeaturesAdd({\n605:         projectRoot,\n606:         config,\n607:         id: args.featureId,\n608:         title: args.title,\n609:         description: args.description,\n610:         priority: args.priority,\n611:         difficulty: args.difficulty,\n612:         effort: args.effort,\n613:         dependsOn: args.dependsOn,\n614:         outputFmt: args.outputFmt,\n615:         dryRun: args.dryRun,\n616:       });\n617:       break;\n618:     }\n619: \n620:     case \"set-status\": {\n621:       if (!args.featureId || !args.title) {\n622:         // title holds the second positional arg (the status value)\n623:         // If not provided via positional, check --status flag\n624:         const newStatus = args.title || args.status;\n625:         if (!args.featureId || !newStatus) {\n626:           console.error(\"Usage: wombo features set-status <feature-id> <status>\");\n627:           process.exit(1);\n628:           return;\n629:         }\n630:         await cmdFeaturesSetStatus({\n631:           projectRoot,\n632:           config,\n633:           featureId: args.featureId,\n634:           newStatus,\n635:           outputFmt: args.outputFmt,\n636:           dryRun: args.dryRun,\n637:         });\n638:       } else {\n639:         await cmdFeaturesSetStatus({\n640:           projectRoot,\n641:           config,\n642:           featureId: args.featureId,\n643:           newStatus: args.title, // second positional = new status\n644:           outputFmt: args.outputFmt,\n645:           dryRun: args.dryRun,\n646:         });\n647:       }\n648:       break;\n649:     }\n650: \n651:     case \"check\":\n652:     case \"validate\":\n653:       await cmdFeaturesCheck({ projectRoot, config });\n654:       break;\n655: \n656:     case \"archive\":\n657:       await cmdFeaturesArchive({\n658:         projectRoot,\n659:         config,\n660:         featureId: args.featureId,\n661:         dryRun: args.dryRun,\n662:       });\n663:       break;\n664: \n665:     case \"show\": {\n666:       if (!args.featureId) {\n667:         console.error(\"Usage: wombo features show <feature-id>\");\n668:         process.exit(1);\n669:         return;\n670:       }\n671:       await cmd