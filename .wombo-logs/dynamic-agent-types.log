{"type":"tool_use","timestamp":1773351910555,"sessionID":"ses_31c010c9effeOfeCSqmf0ROAdl","part":{"id":"prt_ce401dd7d002OgO3JzJ18o2VBp","sessionID":"ses_31c010c9effeOfeCSqmf0ROAdl","messageID":"msg_ce401d436001b77z4dsMcxx2hp","type":"tool","callID":"toolu_vrtx_01EUDXGFvrXpXPR6oGh3d3ee","tool":"write","state":{"status":"completed","input":{"content":"/**\n * agent-converter.ts — Convert agency-agents format to woco agent template format.\n *\n * Responsibilities:\n *   - Map agency-agents MD file format (YAML frontmatter + personality body) to\n *     woco's wave-worker.md template format (YAML frontmatter + operational rules)\n *   - Merge the agency-agent personality/instructions with woco's operational\n *     constraints (worktree awareness, headless operation, commit guidelines)\n *   - Generate a ready-to-use agent definition Markdown file\n */\n\nimport { stringify as stringifyYaml } from \"yaml\";\nimport type { RegistryAgent } from \"./agent-registry.js\";\n\n// ---------------------------------------------------------------------------\n// Wave-worker operational sections (appended to every converted agent)\n// ---------------------------------------------------------------------------\n\nconst WOCO_ENVIRONMENT_SECTION = `\n## Your Environment\n\n- You are in a **git worktree**, not the main repository. Your branch is \\`feature/<feature-id>\\`.\n- The feature you must implement was passed to you as a prompt. It includes the full spec: description, subtasks, constraints, forbidden items, references, and build command.\n- Config files from the main repo (AGENTS.md, opencode config, this agent definition) have been copied into your worktree.\n- **Runtime:** Bun (not Node). TypeScript, strict mode, ESM only.\n`;\n\nconst WOCO_OPERATIONAL_RULES = `\n## Operational Rules\n\n**You run headlessly. You MUST:**\n- NEVER ask questions or request clarification. Make reasonable decisions from context and code conventions.\n- NEVER enter plan mode or propose plans for approval. Execute directly.\n- NEVER wait for confirmation. Act decisively.\n- If ambiguity exists, examine the codebase for patterns and follow them.\n- If you encounter an error, debug and fix it yourself (up to 3 attempts per issue).\n`;\n\nconst WOCO_WORKFLOW = `\n## Workflow\n\n1. **Read the prompt** — it contains the full feature spec from \\`.features.yml\\` including subtasks, constraints, and forbidden items.\n2. **Read AGENTS.md** if present — it contains project-specific hard constraints and conventions.\n3. **Explore the codebase** — understand the architecture before writing code. Read key files, follow imports, understand patterns.\n4. **Plan with TodoWrite** — break the work into concrete steps.\n5. **Implement subtasks in order** — commit after each logical unit of work.\n6. **Typecheck** — run \\`bun run typecheck\\` (or the project's equivalent).\n7. **Build** — run the build command from the prompt to verify everything compiles.\n8. **Fix any failures** — if typecheck or build fails, fix and re-run until it passes.\n`;\n\nconst WOCO_COMMIT_GUIDELINES = `\n## Commit Guidelines\n\n- Use conventional commits: \\`feat(scope):\\`, \\`fix(scope):\\`, \\`refactor(scope):\\`\n- Scope should be the feature ID or a relevant module name\n- Commit after each logical unit of work (roughly per subtask)\n- Do NOT squash everything into one commit\n- Do NOT push to remote — the orchestrator handles that\n- Do NOT modify \\`.features.yml\\` — the orchestrator handles status updates\n`;\n\nconst WOCO_CONSTRAINTS = `\n## Constraints\n\n- **Stay in scope.** Only implement the feature you were assigned. Do not modify unrelated code.\n- **Respect the feature's constraints and forbidden lists.** These are non-negotiable.\n- **Build must pass.** The orchestrator will verify your build. If it fails, you'll be retried with the error output.\n- **No new dependencies** unless the feature spec explicitly requires them.\n- **Follow existing code style** — indentation, naming, patterns, module structure.\n`;\n\nconst WOCO_ERROR_RECOVERY = `\n## Error Recovery\n\nIf something fails:\n1. Read error messages carefully and diagnose the root cause.\n2. Check if the error is in your new code or pre-existing.\n3. Attempt up to 3 fix-and-retry iterations per issue.\n4. If truly blocked by an external factor, document the blocker in a commit message, implement what you can, and move on.\n5. Never leave the worktree in a broken state — if you cannot complete a feature, revert partial changes and document why.\n`;\n\nconst WOCO_NEVER_DO = `\n## What You Must Never Do\n\n- Never ask for human input or confirmation\n- Never enter plan mode\n- Never modify files outside the scope of the current feature\n- Never commit code that breaks the build\n- Never ignore errors without investigation\n- Never push to remote\n`;\n\n// ---------------------------------------------------------------------------\n// Conversion\n// ---------------------------------------------------------------------------\n\n/**\n * Convert a RegistryAgent into woco's agent definition Markdown format.\n *\n * The result is a Markdown file with:\n *   - YAML frontmatter compatible with opencode (description, mode)\n *   - The agency-agent's personality/specialization as a \"Specialization\" section\n *   - woco's standard operational rules appended\n *\n * This ensures the agent retains its personality and expertise while\n * operating correctly within woco's autonomous worktree workflow.\n */\nexport function convertAgentToWocoFormat(agent: RegistryAgent): string {\n  const sections: string[] = [];\n\n  // --- YAML Frontmatter ---\n  const emoji = agent.frontmatter.emoji ? `${agent.frontmatter.emoji} ` : \"\";\n  const description = buildDescription(agent);\n\n  const frontmatter: Record<string, unknown> = {\n    description,\n    mode: \"primary\",\n  };\n\n  sections.push(\"---\");\n  sections.push(\n    stringifyYaml(frontmatter, { lineWidth: 120, defaultStringType: \"BLOCK_LITERAL\" }).trim()\n  );\n  sections.push(\"---\");\n\n  // --- Identity introduction ---\n  sections.push(\n    `You are ${emoji}**${agent.frontmatter.name}**, an autonomous coding agent launched by wombo into an isolated git worktree.`\n  );\n  sections.push(\n    `You implement features defined in \\`.features.yml\\` with zero human interaction.`\n  );\n\n  // --- Specialization section (the agency-agent's personality/instructions) ---\n  sections.push(`\\n## Specialization\\n`);\n  sections.push(\n    `You bring specialized expertise as **${agent.frontmatter.name}**` +\n    (agent.frontmatter.description ? `: ${agent.frontmatter.description}` : \".\") \n  );\n  if (agent.frontmatter.vibe) {\n    sections.push(`\\n**Vibe:** ${agent.frontmatter.vibe}`);\n  }\n  sections.push(`\\n### Domain Expertise\\n`);\n  sections.push(cleanBodyForWoco(agent.body));\n\n  // --- woco operational sections ---\n  sections.push(WOCO_ENVIRONMENT_SECTION);\n  sections.push(WOCO_OPERATIONAL_RULES);\n  sections.push(WOCO_WORKFLOW);\n  sections.push(WOCO_COMMIT_GUIDELINES);\n  sections.push(WOCO_CONSTRAINTS);\n  sections.push(WOCO_ERROR_RECOVERY);\n  sections.push(WOCO_NEVER_DO);\n\n  return sections.join(\"\\n\");\n}\n\n/**\n * Build the opencode-compatible description from the agency-agent's metadata.\n */\nfunction buildDescription(agent: RegistryAgent): string {\n  const parts: string[] = [];\n\n  parts.push(\n    `Autonomous coding agent launched by wombo into isolated git worktrees.`\n  );\n  parts.push(\n    `Specialized as: ${agent.frontmatter.name}${agent.frontmatter.description ? ` — ${agent.frontmatter.description}` : \"\"}.`\n  );\n  parts.push(\n    `Operates headlessly with no human interaction.`\n  );\n  parts.push(\n    `Launched by \\`wombo launch\\` when there are backlog/planned features ready for implementation.`\n  );\n  parts.push(\"\");\n  parts.push(\"Examples:\");\n  parts.push(\"\");\n  parts.push('- user: \"Implement feature from the backlog\"');\n  parts.push(\n    `  assistant: \"I'll read the feature spec from .features.yml and implement all subtasks, applying my expertise as ${agent.frontmatter.name}.\"`\n  );\n  parts.push(\"\");\n  parts.push('- user: \"Fix the build errors from the last run\"');\n  parts.push(\n    `  assistant: \"I'll read the build output, identify the failures, and fix them.\"`\n  );\n\n  return parts.join(\"\\n\");\n}\n\n/**\n * Clean the agency-agent's body content for inclusion in a woco template.\n *\n * Adjusts heading levels to nest properly under \"Domain Expertise\" (h3),\n * and removes any sections that would conflict with woco's operational rules\n * (like if the agent body has its own \"Error Recovery\" or similar generic sections).\n */\nfunction cleanBodyForWoco(body: string): string {\n  if (!body) return \"\";\n\n  let cleaned = body;\n\n  // Bump heading levels: # -> ####, ## -> #####, etc.\n  // This nests the agent's content under the ### Domain Expertise heading.\n  cleaned = cleaned.replace(/^(#{1,6})\\s/gm, (match, hashes: string) => {\n    // Add 3 levels of nesting (since Domain Expertise is ###)\n    const newLevel = Math.min(hashes.length + 3, 6);\n    return \"#\".repeat(newLevel) + \" \";\n  });\n\n  return cleaned.trim();\n}\n\n/**\n * Get just the specialization/personality portion that should be injected\n * into the prompt when using a registry agent (for prompt augmentation).\n *\n * This is lighter than the full template — used when the agent definition\n * is already installed and we just want to add context to the prompt.\n */\nexport function getAgentSpecializationContext(agent: RegistryAgent): string {\n  const sections: string[] = [];\n\n  sections.push(`## Agent Specialization: ${agent.frontmatter.name}\\n`);\n\n  if (agent.frontmatter.description) {\n    sections.push(agent.frontmatter.description);\n    sections.push(\"\");\n  }\n\n  if (agent.frontmatter.vibe) {\n    sections.push(`**Approach:** ${agent.frontmatter.vibe}`);\n    sections.push(\"\");\n  }\n\n  // Include a condensed version of the body (first ~50 lines to avoid bloat)\n  const bodyLines = agent.body.split(\"\\n\");\n  const condensed = bodyLines.slice(0, 50).join(\"\\n\");\n  if (condensed.trim()) {\n    sections.push(condensed.trim());\n    if (bodyLines.length > 50) {\n      sections.push(\"\\n*(Additional specialization details available in the agent definition)*\");\n    }\n  }\n\n  return sections.join(\"\\n\");\n}\n","filePath":"/home/fulgidus/Documents/wombo-dynamic-agent-types/src/lib/agent-converter.ts"},"output":"Wrote file successfully.","title":"src/lib/agent-converter.ts","metadata":{"diagnostics":{"/home/fulgidus/Documents/wombo-dynamic-agent-types/src/lib/templates.ts":[],"/home/fulgidus/Documents/wombo-dynamic-agent-types/src/commands/launch.ts":[{"range":{"start":{"line":49,"character":2},"end":{"line":49,"character":18}},"message":"'retryInteractive' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"}],"/home/fulgidus/Documents/wombo-dynamic-agent-types/src/lib/launcher.ts":[],"/home/fulgidus/Documents/wombo-dynamic-agent-types/src/lib/prompt.ts":[],"/home/fulgidus/Documents/wombo-dynamic-agent-types/src/lib/features.ts":[],"/home/fulgidus/Documents/wombo-dynamic-agent-types/src/config.ts":[],"/home/fulgidus/Documents/wombo-dynamic-agent-types/src/index.ts":[{"range":{"start":{"line":447,"character":8},"end":{"line":447,"character":14}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":543,"character":8},"end":{"line":543,"character":14}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":568,"character":6},"end":{"line":568,"character":12}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":601,"character":8},"end":{"line":601,"character":14}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":627,"character":10},"end":{"line":627,"character":16}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":668,"character":8},"end":{"line":668,"character":14}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":702,"character":6},"end":{"line":702,"character":12}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"}],"/home/fulgidus/Documents/wombo-dynamic-agent-types/src/lib/state.ts":[],"/home/fulgidus/Documents/wombo-dynamic-agent-types/src/lib/agent-registry.ts":[{"range":{"start":{"line":11,"character":74},"end":{"line":11,"character":82}},"message":"'statSync' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"},{"range":{"start":{"line":12,"character":24},"end":{"line":12,"character":32}},"message":"'basename' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"}],"/home/fulgidus/Documents/wombo-dynamic-agent-types/src/lib/agent-converter.ts":[{"range":{"start":{"line":207,"character":46},"end":{"line":207,"character":51}},"message":"'match' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"}]},"filepath":"/home/fulgidus/Documents/wombo-dynamic-agent-types/src/lib/agent-converter.ts","exists":false,"truncated":false},"time":{"start":1773351907630,"end":1773351910553}}}}
