{"type":"tool_use","timestamp":1773351961989,"sessionID":"ses_31c010c9effeOfeCSqmf0ROAdl","part":{"id":"prt_ce4033788002sbXwBkaMW68UmU","sessionID":"ses_31c010c9effeOfeCSqmf0ROAdl","messageID":"msg_ce4032ecb001eq4xzTxyHDpnZv","type":"tool","callID":"toolu_vrtx_01RLoAC8mDnjQ7SVfa5xwbH3","tool":"write","state":{"status":"completed","input":{"content":"/**\n * templates.ts — Resolve paths to bundled template files and install helpers.\n *\n * All template paths are resolved relative to the source file location\n * using import.meta.dir (Bun-specific). This ensures templates are found\n * whether running from source (bun dev) or from an installed package.\n *\n * Supports both the default wave-worker agent and dynamic agent types\n * pulled from the agent registry (agency-agents GitHub repo).\n */\n\nimport { join, dirname, resolve } from \"node:path\";\nimport { existsSync, readFileSync, writeFileSync, mkdirSync } from \"node:fs\";\nimport type { WomboConfig } from \"../config.js\";\nimport { getRegistryAgent } from \"./agent-registry.js\";\nimport { convertAgentToWocoFormat } from \"./agent-converter.js\";\n\n// ---------------------------------------------------------------------------\n// Template Paths\n// ---------------------------------------------------------------------------\n\n/**\n * Absolute path to the bundled wave-worker agent definition template.\n * Used by `wombo init` to install the agent definition into the project,\n * and by `wombo launch` to reinstall it if missing.\n */\nexport const AGENT_TEMPLATE_PATH = join(dirname(import.meta.dir), \"templates\", \"wave-worker.md\");\n\n// ---------------------------------------------------------------------------\n// Agent Definition Guard\n// ---------------------------------------------------------------------------\n\n/**\n * Ensure the default agent definition file exists at the expected path.\n * If missing, reinstall from the bundled template and warn the user.\n *\n * Called at the start of `wombo launch` to prevent the failure mode where\n * agents spawn without their agent definition file.\n *\n * @returns true if the file was reinstalled, false if it already existed.\n */\nexport function ensureAgentDefinition(\n  projectRoot: string,\n  config: WomboConfig\n): boolean {\n  const agentDir = resolve(projectRoot, \"agent\");\n  const agentDefPath = resolve(agentDir, `${config.agent.name}.md`);\n\n  if (existsSync(agentDefPath)) {\n    return false;\n  }\n\n  // Agent definition missing — reinstall from bundled template\n  console.warn(\n    `\\x1b[33m[WARNING]\\x1b[0m Agent definition not found: agent/${config.agent.name}.md`\n  );\n  console.warn(`  Reinstalling from bundled template...`);\n\n  try {\n    mkdirSync(agentDir, { recursive: true });\n    const template = readFileSync(AGENT_TEMPLATE_PATH, \"utf-8\");\n    writeFileSync(agentDefPath, template, \"utf-8\");\n    console.warn(`  Restored agent/${config.agent.name}.md\\n`);\n    return true;\n  } catch (err: any) {\n    console.error(\n      `  Failed to restore agent definition: ${err.message}`\n    );\n    console.error(\n      `  Agents may launch without their definition file.\\n`\n    );\n    return false;\n  }\n}\n\n// ---------------------------------------------------------------------------\n// Dynamic Agent Definition\n// ---------------------------------------------------------------------------\n\n/**\n * Ensure a dynamic agent definition file exists at the expected path.\n * If the agent is not the default wave-worker, fetch it from the registry,\n * convert it to woco format, and install it.\n *\n * @param agentSlug - The agent slug (e.g., \"engineering-frontend-developer\").\n *                    If this matches config.agent.name (default \"wave-worker\"),\n *                    falls back to ensureAgentDefinition().\n * @returns true if the file was installed/updated, false if it already existed.\n */\nexport async function ensureDynamicAgentDefinition(\n  projectRoot: string,\n  config: WomboConfig,\n  agentSlug: string\n): Promise<boolean> {\n  // If it's the default agent, use the standard path\n  if (agentSlug === config.agent.name) {\n    return ensureAgentDefinition(projectRoot, config);\n  }\n\n  const agentDir = resolve(projectRoot, \"agent\");\n  const agentDefPath = resolve(agentDir, `${agentSlug}.md`);\n\n  if (existsSync(agentDefPath)) {\n    return false;\n  }\n\n  // Fetch from registry and convert\n  console.log(`Fetching agent definition: ${agentSlug}...`);\n\n  try {\n    const registryAgent = await getRegistryAgent(projectRoot, config, agentSlug);\n\n    if (!registryAgent) {\n      console.error(\n        `\\x1b[33m[WARNING]\\x1b[0m Agent \"${agentSlug}\" not found in registry.`\n      );\n      console.error(\n        `  Falling back to default agent: ${config.agent.name}`\n      );\n      return ensureAgentDefinition(projectRoot, config);\n    }\n\n    // Convert to woco format\n    const wocoContent = convertAgentToWocoFormat(registryAgent);\n\n    // Install to agent/ directory\n    mkdirSync(agentDir, { recursive: true });\n    writeFileSync(agentDefPath, wocoContent, \"utf-8\");\n    console.log(\n      `  Installed agent/${agentSlug}.md (${registryAgent.frontmatter.name} from ${registryAgent.division})`\n    );\n\n    return true;\n  } catch (err: any) {\n    console.error(\n      `\\x1b[33m[WARNING]\\x1b[0m Failed to fetch agent \"${agentSlug}\": ${err.message}`\n    );\n    console.error(\n      `  Falling back to default agent: ${config.agent.name}`\n    );\n    return ensureAgentDefinition(projectRoot, config);\n  }\n}\n\n/**\n * Resolve the effective agent name for a feature.\n * Priority:\n *   1. CLI --agent flag (agentOverride)\n *   2. Feature's agent field\n *   3. Config default (config.agent.name, typically \"wave-worker\")\n */\nexport function resolveAgentName(\n  featureAgent: string | undefined,\n  agentOverride: string | undefined,\n  config: WomboConfig\n): string {\n  if (agentOverride) return agentOverride;\n  if (featureAgent) return featureAgent;\n  return config.agent.name;\n}\n","filePath":"/home/fulgidus/Documents/wombo-dynamic-agent-types/src/lib/templates.ts"},"output":"Wrote file successfully.","title":"src/lib/templates.ts","metadata":{"diagnostics":{"/home/fulgidus/Documents/wombo-dynamic-agent-types/src/lib/templates.ts":[],"/home/fulgidus/Documents/wombo-dynamic-agent-types/src/commands/launch.ts":[{"range":{"start":{"line":49,"character":2},"end":{"line":49,"character":18}},"message":"'retryInteractive' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"}],"/home/fulgidus/Documents/wombo-dynamic-agent-types/src/lib/launcher.ts":[],"/home/fulgidus/Documents/wombo-dynamic-agent-types/src/lib/prompt.ts":[],"/home/fulgidus/Documents/wombo-dynamic-agent-types/src/lib/features.ts":[],"/home/fulgidus/Documents/wombo-dynamic-agent-types/src/config.ts":[],"/home/fulgidus/Documents/wombo-dynamic-agent-types/src/index.ts":[{"range":{"start":{"line":447,"character":8},"end":{"line":447,"character":14}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":543,"character":8},"end":{"line":543,"character":14}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":568,"character":6},"end":{"line":568,"character":12}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":601,"character":8},"end":{"line":601,"character":14}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":627,"character":10},"end":{"line":627,"character":16}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":668,"character":8},"end":{"line":668,"character":14}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start