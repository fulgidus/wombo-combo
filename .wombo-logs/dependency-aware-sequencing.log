          \"type\": \"file\",\n          \"language\": \"typescript\",\n          \"symbol_count\": 6,\n          \"summary\": \"Contains 5 functions: checkDevModeGuard, parseArgs, cmdHelp, ...\"\n        },\n        {\n          \"path\": \"lib/\",\n          \"type\": \"dir\",\n          \"children\": [\n            {\n              \"path\": \"src/lib/features.ts\",\n              \"type\": \"file\",\n              \"language\": \"typescript\",\n              \"symbol_count\": 28,\n              \"summary\": \"Contains 19 functions: parseDurationMinutes, formatDuration, promptYesNo, ...\"\n            },\n            {\n              \"path\": \"src/lib/launcher.ts\",\n              \"type\": \"file\",\n              \"language\": \"typescript\",\n              \"symbol_count\": 16,\n              \"summary\": \"Contains 12 functions: tmuxSessionName, runSilent, launchHeadless, ...\"\n            },\n            {\n              \"path\": \"src/lib/merger.ts\",\n              \"type\": \"file\",\n              \"language\": \"typescript\",\n              \"symbol_count\": 10,\n              \"summary\": \"Contains 9 functions: run, runSafe, parseUntrackedFiles, ...\"\n            },\n            {\n              \"path\": \"src/lib/monitor.ts\",\n              \"type\": \"file\",\n              \"language\": \"typescript\",\n              \"symbol_count\": 25,\n              \"summary\": \"Defines ProcessMonitor class (13 methods). Contains 5 functions: parseEvents, shortPath, shortCmd, ...\"\n            },\n            {\n              \"path\": \"src/lib/output.ts\",\n              \"type\": \"file\",\n              \"language\": \"typescript\",\n              \"symbol_count\": 8,\n              \"summary\": \"Contains 7 functions: resolveOutputFormat, output, outputError, ...\"\n            },\n            {\n              \"path\": \"src/lib/prompt.ts\",\n              \"type\": \"file\",\n              \"language\": \"typescript\",\n              \"symbol_count\": 3,\n              \"summary\": \"Contains 3 functions: generatePrompt, generateConflictResolutionPrompt, formatSubtask\"\n            },\n            {\n              \"path\": \"src/lib/schema.ts\",\n              \"type\": \"file\",\n              \"language\": \"typescript\",\n              \"symbol_count\": 6,\n              \"summary\": \"Contains 3 functions: findCommandDef, commandToSchema, allCommandSchemas\"\n            },\n            {\n              \"path\": \"src/lib/state.ts\",\n              \"type\": \"file\",\n              \"language\": \"typescript\",\n              \"symbol_count\": 15,\n              \"summary\": \"Contains 12 functions: generateWaveId, statePath, loadState, ...\"\n            },\n            {\n              \"path\": \"src/lib/templates.ts\",\n              \"type\": \"file\",\n              \"language\": \"typescript\",\n              \"symbol_count\": 1,\n              \"summary\": \"Contains 1 functions: ensureAgentDefinition\"\n            },\n            {\n              \"path\": \"src/lib/tui.ts\",\n              \"type\": \"file\",\n              \"language\": \"typescript\",\n              \"symbol_count\": 23,\n              \"summary\": \"Defines WomboTUI class (17 methods). Contains 3 functions: escapeBlessedTags, elapsed, progressBar\"\n            },\n            {\n              \"path\": \"src/lib/ui.ts\",\n              \"type\": \"file\",\n              \"language\": \"typescript\",\n              \"symbol_count\": 10,\n              \"summary\": \"Contains 10 functions: colorize, pad, padLeft, ...\"\n            },\n            {\n              \"path\": \"src/lib/validate.ts\",\n              \"type\": \"file\",\n              \"language\": \"typescript\",\n              \"symbol_count\": 9,\n              \"summary\": \"Contains 8 functions: ok, fail, validateId, ...\"\n            },\n            {\n              \"path\": \"src/lib/verifier.ts\",\n              \"type\": \"file\",\n              \"language\": \"typescript\",\n              \"symbol_count\": 5,\n              \"summary\": \"Contains 4 functions: runBuild, extractErrorSummary, truncate, ...\"\n            },\n            {\n              \"path\": \"src/lib/worktree.ts\",\n              \"type\": \"file\",\n              \"language\": \"typescript\",\n              \"symbol_count\": 19,\n              \"summary\": \"Contains 18 functions: ts, log, runAsync, ...\"\n            }\n          ]\n        },\n        {\n          \"path\": \"src/neo-blessed.d.ts\",\n          \"type\": \"file\",\n          \"language\": \"typescript\",\n          \"symbol_count\": 0,\n          \"summary\": \"\"\n        }\n      ]\n    }\n  ],\n  \"_meta\": {\n    \"timing_ms\": 2.3,\n    \"file_count\": 33,\n    \"tokens_saved\": 71720,\n    \"total_tokens_saved\": 566121,\n    \"cost_avoided\": {\n      \"claude_opus_4_6\": 0.3586,\n      \"claude_sonnet_4_6\": 0.2152,\n      \"claude_haiku_4_5\": 0.0717,\n      \"gpt5_latest\": 0.7172\n    },\n    \"total_cost_avoided\": {\n      \"claude_opus_4_6\": 2.8306,\n      \"claude_sonnet_4_6\": 1.6984,\n      \"claude_haiku_4_5\": 0.5661,\n      \"gpt5_latest\": 5.6612\n    },\n    \"powered_by\": \"jcodemunch-mcp by jgravelle \\u00b7 https://github.com/jgravelle/jcodemunch-mcp\"\n  }\n}","title":"","metadata":{"truncated":false},"time":{"start":1773351516153,"end":1773351516160},"attachments":[]}}}
