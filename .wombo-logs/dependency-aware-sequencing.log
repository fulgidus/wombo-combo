es 725-804 of 1061. Use offset=805 to continue.)\n</content>","title":"src/commands/launch.ts","metadata":{"preview":"  const ready = readyToLaunchAgents(state);\n  const tolaunch = ready.slice(0, opts.maxConcurrent);\n  console.log(`Setting up ${tolaunch.length} agent(s) in parallel...\\n`);\n\n  await Promise.all(\n    tolaunch.map((agent) =>\n      launchSingleHeadless(\n        projectRoot,\n        state,\n        agent,\n        featureMap.get(agent.feature_id)!,\n        monitor,\n        config,\n        model\n      )\n    )\n  );\n\n  const launched = state.agents.filter((a) => a.status === \"running\").length;\n","truncated":true,"loaded":[]},"time":{"start":1773351858741,"end":1773351858745}}}}
