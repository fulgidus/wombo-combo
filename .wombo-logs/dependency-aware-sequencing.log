{err.message}`);\n          launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n        });\n    },"},"output":"Edit applied successfully.\n\nLSP errors detected in this file, please fix:\n<diagnostics file=\"/home/fulgidus/Documents/wombo-dependency-aware-sequencing/src/commands/launch.ts\">\nERROR [607:11] Cannot find name 'launchAllReady'.\nERROR [611:11] Cannot find name 'launchAllReady'.\n</diagnostics>","title":"src/commands/launch.ts","metadata":{"diagnostics":{"/home/fulgidus/Documents/wombo-dependency-aware-sequencing/src/lib/state.ts":[],"/home/fulgidus/Documents/wombo-dependency-aware-sequencing/src/commands/launch.ts":[{"range":{"start":{"line":606,"character":10},"end":{"line":606,"character":24}},"message":"Cannot find name 'launchAllReady'.","severity":1,"code":2304,"source":"typescript"},{"range":{"start":{"line":610,"character":10},"end":{"line":610,"character":24}},"message":"Cannot find name 'launchAllReady'.","severity":1,"code":2304,"source":"typescript"},{"range":{"start":{"line":30,"character":2},"end":{"line":30,"character":19}},"message":"'areAgentDepsReady' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"},{"range":{"start":{"line":31,"character":2},"end":{"line":31,"character":18}},"message":"'cancelDownstream' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"},{"range":{"start":{"line":35,"character":7},"end":{"line":35,"character":29}},"message":"'SerializedSchedulePlan' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"},{"range":{"start":{"line":52,"character":2},"end":{"line":52,"character":18}},"message":"'retryInteractive' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"},{"range":{"start":{"line":66,"character":0},"end":{"line":74,"character":36}},"message":"All imports in import declaration are unused.","severity":4,"code":6192,"source":"typescript"}],"/