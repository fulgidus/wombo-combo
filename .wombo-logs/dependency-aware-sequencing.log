{"type":"tool_use","timestamp":1773351684341,"sessionID":"ses_31c036c7affe6dPx3n8MQ9tKUs","part":{"id":"prt_ce3ff4505001LgDf0DIHnIdA3D","sessionID":"ses_31c036c7affe6dPx3n8MQ9tKUs","messageID":"msg_ce3ff35e70010SBtumoDtn3Zm2","type":"tool","callID":"toolu_vrtx_01XCkivKdhSptbwm43dGKGrr","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-dependency-aware-sequencing/src/lib/dependency-graph.ts"},"output":"<path>/home/fulgidus/Documents/wombo-dependency-aware-sequencing/src/lib/dependency-graph.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * dependency-graph.ts — Dependency graph construction, cycle detection, and\n3:  * topological ordering for dependency-aware sequential scheduling.\n4:  *\n5:  * Responsibilities:\n6:  *   - Parse depends_on fields across all features to build a DAG\n7:  *   - Detect circular dependencies and report them before launch\n8:  *   - Compute topological ordering for sequential scheduling\n9:  *   - Identify dependency chains (A -> B -> C) for same-worktree reuse\n10:  *   - Identify diamond dependencies (C depends on both A and B)\n11:  *   - Group features into independent streams for parallel execution\n12:  *\n13:  * IMPORTANT: All dependency resolution is fully programmatic — no LLM calls.\n14:  */\n15: \n16: import type { Feature, FeaturesFile } from \"./features.js\";\n17: \n18: // ---------------------------------------------------------------------------\n19: // Types\n20: // ---------------------------------------------------------------------------\n21: \n22: /**\n23:  * A node in the dependency graph. Wraps a Feature with graph metadata.\n24:  */\n25: export interface DepGraphNode {\n26:   /** Feature ID */\n27:   id: string;\n28:   /** The underlying feature */\n29:   feature: Feature;\n30:   /** IDs this feature depends on (predecessors) */\n31:   dependsOn: string[];\n32:   /** IDs that depend on this feature (successors) */\n33:   dependedOnBy: string[];\n34: }\n35: \n36: /**\n37:  * Result of building the dependency graph.\n38:  */\n39: export interface DepGraph {\n40:   /** All nodes keyed by feature ID */\n41:   nodes: Map<string, DepGraphNode>;\n42:   /** Topological ordering (features sorted so deps come before dependents) */\n43:   topologicalOrder: string[];\n44:   /** Detected cycles (each is a path of IDs forming the cycle) */\n45:   cycles: string[][];\n46:   /** Dangling dependency references (depend on IDs that don't exist in the selected set) */\n47:   danglingDeps: Array<{ featureId: string; missingDep: string }>;\n48:   /** Root nodes (features with no dependencies) */\n49:   roots: string[];\n50:   /** Leaf nodes (features with no dependents) */\n51:   leaves: string[];\n52: }\n53: \n54: /**\n55:  * A chain of features that form a linear dependency sequence.\n56:  * These should be executed sequentially in the same worktree.\n57:  */\n58: export interface DepChain {\n59:   /** Feature IDs in execution order (first has no deps within the chain) */\n60:   featureIds: string[];\n61: }\n62: \n63: /**\n64:  * A scheduling plan that groups features into parallel streams\n65:  * and sequential chains within those streams.\n66:  */\n67: export interface SchedulePlan {\n68:   /**\n69:    * Independent streams that can run in parallel.\n70:    * Each stream is a chain of features to execute sequentially.\n71:    */\n72:   streams: DepChain[];\n73:   /**\n74:    * Features that have diamond dependencies (depend on features from\n75:    * multiple different streams). These must wait until all their\n76:    * dependencies are verified/merged before starting.\n77:    */\n78:   mergeGates: MergeGate[];\n79:   /**\n80:    * Topological order of all features for reference.\n81:    */\n82:   topologicalOrder: string[];\n83: }\n84: \n85: /**\n86:  * A merge gate for diamond dependencies.\n87:  * Feature C depends on A (stream 1) and B (stream 2).\n88:  * C cannot start until both A and B are verified/merged.\n89:  */\n90: export interface MergeGate {\n91:   /** The feature that must wait */\n92:   featureId: string;\n93:   /** The features it depends on (from different streams) */\n94:   waitFor: string[];\n95: }\n96: \n97: // ---------------------------------------------------------------------------\n98: // Graph Construction\n99: // ---------------------------------------------------------------------------\n100: \n101: /**\n102:  * Build a dependency graph from a set of features.\n103:  *\n104:  * @param features - The features to include in the graph (typically selected features)\n105:  * @param allFeatures - All features in the features file (for resolving external deps)\n106:  * @returns The constructed dependency graph with cycle detection results\n107:  */\n108: export function buildDepGraph(\n109:   features: Feature[],\n110:   allFeatures?: Feature[]\n111: ): DepGraph {\n112:   const nodes = new Map<string, DepGraphNode>();\n113:   const selectedIds = new Set(features.map((f) => f.id));\n114:   const allIds = new Set(\n115:     allFeatures ? allFeatures.map((f) => f.id) : features.map((f) => f.id)\n116:   );\n117: \n118:   // Create nodes for all selected features\n119:   for (const feature of features) {\n120:     nodes.set(feature.id, {\n121:       id: feature.id,\n122:       feature,\n123:       dependsOn: [...(feature.depends_on ?? [])],\n124:       dependedOnBy: [],\n125:     });\n126:   }\n127: \n128:   // Build reverse edges (dependedOnBy) and detect dangling deps\n129:   const danglingDeps: Array<{ featureId: string; missingDep: string }> = [];\n130: \n131:   for (const [id, node] of nodes) {\n132:     for (const dep of node.dependsOn) {\n133:       if (nodes.has(dep)) {\n134:         // Both endpoints are in our selected set — add reverse edge\n135:         nodes.get(dep)!.dependedOnBy.push(id);\n136:       } else if (!allIds.has(dep)) {\n137:         // Dependency doesn't exist at all\n138:         danglingDeps.push({ featureId: id, missingDep: dep });\n139:       }\n140:       // If dep exists in allFeatures but not in selected set,\n141:       // it's an external dependency — not dangling, just not in scope\n142:     }\n143:   }\n144: \n145:   // Detect cycles using DFS\n146:   const cycles = detectCycles(nodes);\n147: \n148:   // Compute topological order (only valid if no cycles)\n149:   const topologicalOrder = cycles.length === 0\n150:     ? computeTopologicalOrder(nodes)\n151:     : [];\n152: \n153:   // Find roots and leaves\n154:   const roots: string[] = [];\n155:   const leaves: string[] = [];\n156:   for (const [id, node] of nodes) {\n157:     // A root has no dependencies within the selected set\n158:     const internalDeps = node.dependsOn.filter((d) => selectedIds.has(d));\n159:     if (internalDeps.length === 0) {\n160:       roots.push(id);\n161:     }\n162:     if (node.dependedOnBy.length === 0) {\n163:       leaves.push(id);\n164:     }\n165:   }\n166: \n167:   return {\n168:     nodes,\n169:     topologicalOrder,\n170:     cycles,\n171:     danglingDeps,\n172:     roots,\n173:     leaves,\n174:   };\n175: }\n176: \n177: // ---------------------------------------------------------------------------\n178: // Cycle Detection (DFS-based)\n179: // ---------------------------------------------------------------------------\n180: \n181: /**\n182:  * Detect cycles in the dependency graph using iterative DFS with coloring.\n183:  * Returns arrays of ID paths that form cycles.\n184:  *\n185:  * Uses three-color marking:\n186:  * - WHITE (unvisited)\n187:  * - GRAY (in current DFS stack)\n188:  * - BLACK (fully processed)\n189:  */\n190: function detectCycles(nodes: Map<string, DepGraphNode>): string[][] {\n191:   const WHITE = 0;\n192:   const GRAY = 1;\n193:   const BLACK = 2;\n194: \n195:   const color = new Map<string, number>();\n196:   const parent = new Map<string, string | null>();\n197:   const cycles: string[][] = [];\n198: \n199:   for (const id of nodes.keys()) {\n200:     color.set(id, WHITE);\n201:   }\n202: \n203:   for (const startId of nodes.keys()) {\n204:     if (color.get(startId) !== WHITE) continue;\n205: \n206:     // Iterative DFS\n207:     const stack: Array<{ id: string; depIdx: number }> = [\n208:       { id: startId, depIdx: 0 },\n209:     ];\n210:     color.set(startId, GRAY);\n211:     parent.set(startId, null);\n212: \n213:     while (stack.length > 0) {\n214:       const top = stack[stack.length - 1];\n215:       const node = nodes.get(top.id);\n216: \n217:       if (!node) {\n218:         stack.pop();\n219:         continue;\n220:       }\n221: \n222:       // Only consider dependencies that exist in our graph\n223:       const internalDeps = node.dependsOn.filter((d) => nodes.has(d));\n224: \n225:       if (top.depIdx < internalDeps.length) {\n226:         const dep = internalDeps[top.depIdx];\n227:         top.depIdx++;\n228: \n229:         const depColor = color.get(dep);\n230:         if (depColor === WHITE) {\n231:           color.set(dep, GRAY);\n232:           parent.set(dep, top.id);\n233:           stack.push({ id: dep, depIdx: 0 });\n234:         } else if (depColor === GRAY) {\n235:           // Found a cycle — extract the cycle path\n236:           const cyclePath: string[] = [dep];\n237:           let current = top.id;\n238:           while (current !== dep) {\n239:             cyclePath.push(current);\n240:             current = parent.get(current)!;\n241:           }\n242:           cyclePath.push(dep);\n243:           cyclePath.reverse();\n244:           cycles.push(cyclePath);\n245:         }\n246:         // BLACK nodes are already fully processed — skip\n247:       } else {\n248:         // All deps processed — mark as BLACK\n249:         color.set(top.id, BLACK);\n250:         stack.pop();\n251:       }\n252:     }\n253:   }\n254: \n255:   return cycles;\n256: }\n257: \n258: // ---------------------------------------------------------------------------\n259: // Topological Sort (Kahn's Algorithm)\n260: // ---------------------------------------------------------------------------\n261: \n262: /**\n263:  * Compute topological ordering using Kahn's algorithm (BFS-based).\n264:  * Returns feature IDs in dependency order (deps come first).\n265:  *\n266:  * Precondition: the graph must be acyclic.\n267:  */\n268: function computeTopologicalOrder(nodes: Map<string, DepGraphNode>): string[] {\n269:   // Calculate in-degree for each node (only counting internal deps)\n270:   const inDegree = new Map<string, number>();\n271:   for (const [id, node] of nodes) {\n272:     const internalDeps = node.dependsOn.filter((d) => nodes.has(d));\n273:     inDegree.set(id, internalDeps.length);\n274:   }\n275: \n276:   // Start with nodes that have zero in-degree (roots)\n277:   const queue: string[] = [];\n278:   for (const [id, degree] of inDegree) {\n279:     if (degree === 0) {\n280:       queue.push(id);\n281:     }\n282:   }\n283: \n284:   // Sort queue for deterministic ordering (by feature ID)\n285:   queue.sort();\n286: \n287:   const result: string[] = [];\n288: \n289:   while (queue.length > 0) {\n290:     const id = queue.shift()!;\n291:     result.push(id);\n292: \n293:     const node = nodes.get(id)!;\n294:     for (const dependent of node.dependedOnBy) {\n295:       const currentDegree = inDegree.get(dependent)!;\n296:       inDegree.set(dependent, currentDegree - 1);\n297:       if (currentDegree - 1 === 0) {\n298:         queue.push(dependent);\n299:         // Re-sort to maintain deterministic ordering\n300:         queue.sort();\n301:       }\n302:     }\n303:   }\n304: \n305:   return result;\n306: }\n307: \n308: // ---------------------------------------------------------------------------\n309: // Scheduling Plan Construction\n310: // ---------------------------------------------------------------------------\n311: \n312: /**\n313:  * Build a scheduling plan from a dependency graph.\n314:  *\n315:  * Groups features into:\n316:  * 1. **Streams**: Linear chains of dependent features that execute sequentially\n317:  *    in the same worktree. A -> B -> C becomes one stream.\n318:  * 2. **Merge gates**: Features with diamond dependencies that must wait for\n319:  *    multiple streams to complete. If C depends on A (stream 1) and B (stream 2),\n320:  *    C gets a merge gate.\n321:  *\n322:  * Features with no dependencies and no dependents run as single-feature streams.\n323:  */\n324: export function buildSchedulePlan(graph: DepGraph): SchedulePlan {\n325:   if (graph.cycles.length > 0) {\n326:     throw new Error(\n327:       `Cannot build schedule plan: circular dependencies detected:\\n` +\n328:       graph.cycles.map((c) => `  ${c.join(\" -> \")}`).join(\"\\n\")\n329:     );\n330:   }\n331: \n332:   const selectedIds = new Set(graph.nodes.keys());\n333:   const mergeGates: MergeGate[] = [];\n334:   const assigned = new Set<string>();\n335: \n336:   // Identify diamond dependencies first:\n337:   // A feature has a diamond dep if it depends on features that belong to\n338:   // different independent sub-graphs (or multiple chains).\n339:   // Strategy: walk the topological order and group features into chains.\n340: \n341:   // Step 1: Build chains by following single-dependency paths.\n342:   // A chain is a maximal sequence where each feature has exactly one\n343:   // internal predecessor and that predecessor has exactly one internal successor.\n344:   const chains: DepChain[] = [];\n345: \n346:   // Find chain starts: features that either have no internal deps, or whose\n347:   // internal deps have multiple dependents (branch point), or that have\n348:   // multiple internal deps (merge point / diamond).\n349:   for (const id of graph.topologicalOrder) {\n350:     if (assigned.has(id)) continue;\n351: \n352:     const node = graph.nodes.get(id)!;\n353:     const internalDeps = node.dependsOn.filter((d) => selectedIds.has(d));\n354: \n355:     // Diamond dependency: depends on multiple features\n356:     if (internalDeps.length > 1) {\n357:       mergeGates.push({\n358:         featureId: id,\n359:         waitFor: [...internalDeps],\n360:       });\n361:       // Don't add to any chain yet — it will be its own chain starting\n362:       // after the gate opens. But we need to continue from it.\n363:       // Start a new chain from this node\n364:       const chain = buildChainFrom(id, graph, selectedIds, assigned);\n365:       if (chain.featureIds.length > 0) {\n366:         chains.push(chain);\n367:       }\n368:       continue;\n369:     }\n370: \n371:     // If this feature has no internal deps, start a new chain from it\n372:     if (internalDeps.length === 0) {\n373:       const chain = buildChainFrom(id, graph, selectedIds, assigned);\n374:       if (chain.featureIds.length > 0) {\n375:         chains.push(chain);\n376:       }\n377:       continue;\n378:     }\n379: \n380:     // Single internal dep — check if the dep has already been assigned\n381:     // (meaning we're starting a new branch)\n382:     const depId = internalDeps[0];\n383:     const depNode = graph.nodes.get(depId);\n384:     if (!depNode) continue;\n385: \n386:     // If the dep has multiple internal successors, this is a branch point.\n387:     // This feature starts a new chain.\n388:     const depInternalSuccessors = depNode.dependedOnBy.filter((d) =>\n389:       selectedIds.has(d)\n390:     );\n391:     if (depInternalSuccessors.length > 1 && !assigned.has(id)) {\n392:       const chain = buildChainFrom(id, graph, selectedIds, assigned);\n393:       if (chain.featureIds.length > 0) {\n394:         chains.push(chain);\n395:       }\n396:       continue;\n397:     }\n398: \n399:     // Otherwise, this feature should have been picked up by its chain start\n400:     if (!assigned.has(id)) {\n401:       const chain = buildChainFrom(id, graph, selectedIds, assigned);\n402:       if (chain.featureIds.length > 0) {\n403:         chains.push(chain);\n404:       }\n405:     }\n406:   }\n407: \n408:   return {\n409:     streams: chains,\n410:     mergeGates,\n411:     topologicalOrder: [...graph.topologicalOrder],\n412:   };\n413: }\n414: \n415: /**\n416:  * Build a linear chain starting from a given feature ID.\n417:  * Follows the single-successor path as long as each successor has\n418:  * exactly one internal dependency and the predecessor has exactly one\n419:  * internal successor.\n420:  */\n421: function buildChainFrom(\n422:   startId: string,\n423:   graph: DepGraph,\n424:   selectedIds: Set<string>,\n425:   assigned: Set<string>\n426: ): DepChain {\n427:   const chain: string[] = [];\n428:   let currentId: string | null = startId;\n429: \n430:   while (currentId && !assigned.has(currentId)) {\n431:     assigned.add(currentId);\n432:     chain.push(currentId);\n433: \n434:     const node: DepGraphNode = graph.nodes.get(currentId)!;\n435:     const internalSuccessors: string[] = node.dependedOnBy.filter(\n436:       (d: string) => selectedIds.has(d)\n437:     );\n438: \n439:     if (internalSuccessors.length === 1) {\n440:       const nextId: string = internalSuccessors[0];\n441:       const nextNode: DepGraphNode = graph.nodes.get(nextId)!;\n442:       const nextInternalDeps: string[] = nextNode.dependsOn.filter(\n443:         (d: string) => selectedIds.has(d)\n444:       );\n445: \n446:       // Only continue the chain if the next node has exactly one dep (us)\n447:       if (nextInternalDeps.length === 1 && !assigned.has(nextId)) {\n448:         currentId = nextId;\n449:       } else {\n450:         currentId = null;\n451:       }\n452:     } else {\n453:       // Multiple successors (branch point) or no successors (leaf) — end chain\n454:       currentId = null;\n455:     }\n456:   }\n457: \n458:   return { featureIds: chain };\n459: }\n460: \n461: // ---------------------------------------------------------------------------\n462: // Validation Helpers\n463: // ---------------------------------------------------------------------------\n464: \n465: /**\n466:  * Validate the dependency graph before launching.\n467:  * Throws descriptive errors if there are cycles or dangling deps.\n468:  *\n469:  * @returns The validated DepGraph (for chaining)\n470:  */\n471: export function validateDepGraph(graph: DepGraph): DepGraph {\n472:   const errors: string[] = [];\n473: \n474:   if (graph.cycles.length > 0) {\n475:     errors.push(\"Circular dependencies detected:\");\n476:     for (const cycle of graph.cycles) {\n477:       errors.push(`  ${cycle.join(\" → \")}`);\n478:     }\n479:   }\n480: \n481:   if (graph.danglingDeps.length > 0) {\n482:     errors.push(\"Dangling dependencies (reference non-existent features):\");\n483:     for (const { featureId, missingDep } of graph.danglingDeps) {\n484:       errors.push(`  ${featureId} depends on \"${missingDep}\" which does not exist`);\n485:     }\n486:   }\n487: \n488:   if (errors.length > 0) {\n489:     throw new Error(\n490:       `Dependency graph validation failed:\\n${errors.join(\"\\n\")}`\n491:     );\n492:   }\n493: \n494:   return graph;\n495: }\n496: \n497: /**\n498:  * Format the scheduling plan as a human-readable summary.\n499:  */\n500: export function formatSchedulePlan(plan: SchedulePlan): string {\n501:   const lines: string[] = [];\n502: \n503:   lines.push(`Schedule Plan: ${plan.streams.length} stream(s), ${plan.mergeGates.length} merge gate(s)\\n`);\n504: \n505:   for (let i = 0; i < plan.streams.length; i++) {\n506:     const stream = plan.streams[i];\n507:     if (stream.featureIds.length === 1) {\n508:       lines.push(`  Stream ${i + 1}: ${stream.featureIds[0]}`);\n509:     } else {\n510:       lines.push(\n511:         `  Stream ${i + 1}: ${stream.featureIds.join(\" → \")}`\n512:       );\n513:     }\n514:   }\n515: \n516:   if (plan.mergeGates.length > 0) {\n517:     lines.push(\"\");\n518:     lines.push(\"  Merge Gates:\");\n519:     for (const gate of plan.mergeGates) {\n520:       lines.push(\n521:         `    ${gate.featureId} waits for: ${gate.waitFor.join(\", \")}`\n522:       );\n523:     }\n524:   }\n525: \n526:   return lines.join(\"\\n\");\n527: }\n528: \n529: /**\n530:  * Get the stream index that a feature belongs to.\n531:  * Returns -1 if the feature is not in any stream.\n532:  */\n533: export function getStreamForFeature(\n534:   plan: SchedulePlan,\n535:   featureId: string\n536: ): number {\n537:   for (let i = 0; i < plan.streams.length; i++) {\n538:     if (plan.streams[i].featureIds.includes(featureId)) {\n539:       return i;\n540:     }\n541:   }\n542:   return -1;\n543: }\n544: \n545: /**\n546:  * Check if a feature's dependencies are all satisfied within the scheduling context.\n547:  * A dependency is satisfied if:\n548:  * - It's not in the selected set (external dep, assumed done) OR\n549:  * - It's in the completedIds set (verified/merged)\n550:  *\n551:  * @param featureId - The feature to check\n552:  * @param graph - The dependency graph\n553:  * @param completedIds - Set of feature IDs that have been completed (verified/merged)\n554:  * @returns true if all dependencies are satisfied\n555:  */\n556: export function areDepsReady(\n557:   featureId: string,\n558:   graph: DepGraph,\n559:   completedIds: Set<string>\n560: ): boolean {\n561:   const node = graph.nodes.get(featureId);\n562:   if (!node) return true;\n563: \n564:   const selectedIds = new Set(graph.nodes.keys());\n565: \n566:   for (const dep of node.dependsOn) {\n567:     if (selectedIds.has(dep) && !completedIds.has(dep)) {\n568:       return false;\n569:     }\n570:   }\n571:   return true;\n572: }\n\n(End of file - total 572 lines)\n</content>","title":"src/lib/dependency-graph.ts","metadata":{"preview":"/**\n * dependency-graph.ts — Dependency graph construction, cycle detection, and\n * topological ordering for dependency-aware sequential scheduling.\n *\n * Responsibilities:\n *   - Parse depends_on fields across all features to build a DAG\n *   - Detect circular dependencies and report them before launch\n *   - Compute topological ordering for sequential scheduling\n *   - Identify dependency chains (A -> B -> C) for same-worktree reuse\n *   - Identify diamond dependencies (C depends on both A and B)\n *   - Group features into independent streams for parallel execution\n *\n * IMPORTANT: All dependency resolution is fully programmatic — no LLM calls.\n */\n\nimport type { Feature, FeaturesFile } from \"./features.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------","truncated":false,"loaded":[]},"time":{"start":1773351684335,"end":1773351684340}}}}
{"type":"tool_use","timestamp":1773351684825,"sessionID":"ses_31c036c7affe6dPx3n8MQ9tKUs","part":{"id":"prt_ce3ff48f0001imyRnmDWorAaC4","sessionID":"ses_31c036c7affe6dPx3n8MQ9tKUs","messageID":"msg_ce3ff35e70010SBtumoDtn3Zm2","type":"tool","callID":"toolu_vrtx_01HQQkFJkNNhuyRtpNLgFDG7","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-dependency-aware-sequencing/src/commands/launch.ts"},"output":"<path>/home/fulgidus/Documents/wombo-dependency-aware-sequencing/src/commands/launch.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * launch.ts — Launch a wave of agents.\n3:  *\n4:  * Usage: wombo launch [selection options] [launch options]\n5:  *\n6:  * This is the primary entry point for starting a new wave. It selects features\n7:  * from the features file, creates a wave state, sets up worktrees, and launches\n8:  * agent processes (either headless or interactive via tmux).\n9:  *\n10:  * IMPORTANT: This file also exports shared helper functions that are reused\n11:  * by resume.ts and other commands:\n12:  *   - launchSingleHeadless\n13:  *   - handleBuildVerification\n14:  *   - handleRetry\n15:  *   - launchNextQueued\n16:  */\n17: \n18: import { execSync } from \"node:child_process\";\n19: import type { WomboConfig } from \"../config.js\";\n20: import type { Feature, SelectionOptions, Priority, Difficulty } from \"../lib/features.js\";\n21: import { loadFeatures, selectFeatures, parseDurationMinutes, saveFeatures } from \"../lib/features.js\";\n22: import {\n23:   loadState,\n24:   saveState,\n25:   createWaveState,\n26:   createAgentState,\n27:   updateAgent,\n28:   activeAgents,\n29:   queuedAgents,\n30:   isWaveComplete,\n31:   type WaveState,\n32:   type AgentState,\n33: } from \"../lib/state.js\";\n34: import {\n35:   createWorktree,\n36:   installDeps,\n37:   featureBranchName,\n38:   worktreePath,\n39:   worktreeReady,\n40:   branchHasChanges,\n41:   removeWorktree,\n42:   log as wtLog,\n43: } from \"../lib/worktree.js\";\n44: import { generatePrompt, generateConflictResolutionPrompt } from \"../lib/prompt.js\";\n45: import {\n46:   launchHeadless,\n47:   retryHeadless,\n48:   launchInteractive,\n49:   retryInteractive,\n50:   launchConflictResolver,\n51:   isProcessRunning,\n52: } from \"../lib/launcher.js\";\n53: import { ProcessMonitor } from \"../lib/monitor.js\";\n54: import { runBuild } from \"../lib/verifier.js\";\n55: import { mergeBranch, mergeBaseIntoFeature, pushBaseBranch } from \"../lib/merger.js\";\n56: import {\n57:   printDashboard,\n58:   printFeatureSelection,\n59:   printAgentUpdate,\n60: } from \"../lib/ui.js\";\n61: import { WomboTUI } from \"../lib/tui.js\";\n62: import { ensureAgentDefinition } from \"../lib/templates.js\";\n63: \n64: // ---------------------------------------------------------------------------\n65: // Types\n66: // ---------------------------------------------------------------------------\n67: \n68: export interface LaunchCommandOptions {\n69:   projectRoot: string;\n70:   config: WomboConfig;\n71:   // Selection\n72:   topPriority?: number;\n73:   quickestWins?: number;\n74:   priority?: Priority;\n75:   difficulty?: Difficulty;\n76:   features?: string[];\n77:   allReady?: boolean;\n78:   // Launch\n79:   maxConcurrent: number;\n80:   model?: string;\n81:   interactive: boolean;\n82:   dryRun: boolean;\n83:   baseBranch: string;\n84:   maxRetries: number;\n85:   noTui: boolean;\n86:   autoPush: boolean;\n87: }\n88: \n89: // ---------------------------------------------------------------------------\n90: // Shared Helpers (exported for resume.ts and others)\n91: // ---------------------------------------------------------------------------\n92: \n93: /**\n94:  * Mark a feature as done in the features file after a successful merge.\n95:  * Updates status to \"done\", completion to 100, and sets ended_at.\n96:  *\n97:  * GUARD: Verifies that the feature branch has actually been merged into\n98:  * baseBranch before allowing the status change. This prevents callers\n99:  * from accidentally marking verified-but-unmerged features as done.\n100:  */\n101: export function markFeatureDone(\n102:   projectRoot: string,\n103:   featureId: string,\n104:   config: WomboConfig,\n105:   baseBranch: string\n106: ): void {\n107:   try {\n108:     // Verify the feature branch was actually merged into base\n109:     const branch = featureBranchName(featureId, config);\n110:     try {\n111:       execSync(`git merge-base --is-ancestor \"${branch}\" \"${baseBranch}\"`, {\n112:         cwd: projectRoot,\n113:         stdio: \"pipe\",\n114:       });\n115:     } catch {\n116:       // git merge-base --is-ancestor exits non-zero if NOT an ancestor\n117:       console.error(\n118:         `Warning: ${featureId} branch \"${branch}\" is not merged into \"${baseBranch}\" — refusing to mark as done`\n119:       );\n120:       return;\n121:     }\n122: \n123:     const data = loadFeatures(projectRoot, config);\n124:     const feature = data.features.find((f) => f.id === featureId);\n125:     if (feature && feature.status !== \"done\") {\n126:       feature.status = \"done\";\n127:       feature.completion = 100;\n128:       feature.ended_at = new Date().toISOString();\n129:       saveFeatures(projectRoot, config, data);\n130:     }\n131:   } catch (err: any) {\n132:     // Non-fatal — log but don't crash the wave\n133:     console.error(`Warning: failed to update feature status for ${featureId}: ${err.message}`);\n134:   }\n135: }\n136: \n137: /**\n138:  * Launch a single agent in headless mode.\n139:  * Sets up worktree, installs deps, generates prompt, launches agent process.\n140:  */\n141: export async function launchSingleHeadless(\n142:   projectRoot: string,\n143:   state: WaveState,\n144:   agent: AgentState,\n145:   feature: Feature,\n146:   monitor: ProcessMonitor,\n147:   config: WomboConfig,\n148:   model?: string\n149: ): Promise<void> {\n150:   updateAgent(state, agent.feature_id, {\n151:     status: \"installing\",\n152:     started_at: new Date().toISOString(),\n153:     activity: \"setting up worktree...\",\n154:   });\n155:   saveState(projectRoot, state);\n156: \n157:   try {\n158:     // Skip worktree setup if already ready (resume case)\n159:     if (worktreeReady(agent.worktree)) {\n160:       wtLog(agent.feature_id, \"worktree already exists, skipping setup\");\n161:     } else {\n162:       // Create worktree (async — doesn't block other agents)\n163:       await createWorktree(projectRoot, feature.id, state.base_branch, config);\n164: \n165:       // Install dependencies (async)\n166:       updateAgent(state, agent.feature_id, { activity: \"installing deps...\" });\n167:       await installDeps(agent.worktree, feature.id, config);\n168:     }\n169: \n170:     // Generate prompt\n171:     const prompt = generatePrompt(feature, state.base_branch, config);\n172: \n173:     // Launch agent\n174:     wtLog(agent.feature_id, \"launching agent...\");\n175:     const result = launchHeadless({\n176:       worktreePath: agent.worktree,\n177:       featureId: feature.id,\n178:       prompt,\n179:       model,\n180:       config,\n181:     });\n182: \n183:     updateAgent(state, agent.feature_id, {\n184:       status: \"running\",\n185:       pid: result.pid,\n186:       activity: \"starting...\",\n187:     });\n188:     saveState(projectRoot, state);\n189: \n190:     monitor.addProcess(feature.id, result.process);\n191:     wtLog(agent.feature_id, `running (PID: ${result.pid})`);\n192:   } catch (err: any) {\n193:     updateAgent(state, agent.feature_id, {\n194:       status: \"failed\",\n195:       error: err.message,\n196:       activity: null,\n197:       completed_at: new Date().toISOString(),\n198:     });\n199:     saveState(projectRoot, state);\n200:     wtLog(agent.feature_id, `SETUP FAILED: ${err.message.split(\"\\n\")[0]}`);\n201:   }\n202: }\n203: \n204: /**\n205:  * Handle build verification after agent completion.\n206:  * Runs build, auto-merges on pass, retries on failure if retries remain.\n207:  *\n208:  * ASYNC — runs build and merge without blocking the event loop.\n209:  */\n210: export async function handleBuildVerification(\n211:   projectRoot: string,\n212:   state: WaveState,\n213:   agent: AgentState,\n214:   feature: Feature,\n215:   config: WomboConfig,\n216:   model?: string,\n217:   monitor?: ProcessMonitor\n218: ): Promise<void> {\n219:   try {\n220:     printAgentUpdate(agent, \"verifying build...\");\n221: \n222:     const buildResult = await runBuild(agent.worktree, config);\n223: \n224:     if (buildResult.passed) {\n225:       updateAgent(state, agent.feature_id, {\n226:         status: \"verified\",\n227:         build_passed: true,\n228:         build_output: null,\n229:       });\n230:       saveState(projectRoot, state);\n231:       printAgentUpdate(agent, `BUILD PASSED (${Math.round(buildResult.durationMs / 1000)}s)`);\n232: \n233:       // Auto-merge: attempt merge + conflict resolution\n234:       await attemptMerge(projectRoot, state, agent, feature, config, model);\n235:     } else {\n236:       if (agent.retries < agent.max_retries) {\n237:         updateAgent(state, agent.feature_id, {\n238:           status: \"retry\",\n239:           retries: agent.retries + 1,\n240:           build_passed: false,\n241:           build_output: buildResult.errorSummary,\n242:         });\n243:         saveState(projectRoot, state);\n244:         printAgentUpdate(\n245:           agent,\n246:           `BUILD FAILED — retrying (${agent.retries}/${agent.max_retries})`\n247:         );\n248: \n249:         // Retry with build errors\n250:         if (agent.session_id) {\n251:           const retryResult = retryHeadless({\n252:             worktreePath: agent.worktree,\n253:             featureId: agent.feature_id,\n254:             sessionId: agent.session_id,\n255:             buildErrors: buildResult.errorSummary,\n256:             model,\n257:             config,\n258:           });\n259: \n260:           updateAgent(state, agent.feature_id, {\n261:             status: \"running\",\n262:             pid: retryResult.pid,\n263:           });\n264:           saveState(projectRoot, state);\n265: \n266:           // Add retry process to monitor so events are tracked\n267:           if (monitor) {\n268:             monitor.addProcess(agent.feature_id, retryResult.process);\n269:           }\n270:         }\n271:       } else {\n272:         updateAgent(state, agent.feature_id, {\n273:           status: \"failed\",\n274:           build_passed: false,\n275:           build_output: buildResult.errorSummary,\n276:           error: `Build failed after ${agent.max_retries} retries`,\n277:           completed_at: new Date().toISOString(),\n278:         });\n279:         saveState(projectRoot, state);\n280:         printAgentUpdate(agent, \"BUILD FAILED — max retries reached\");\n281:       }\n282:     }\n283:   } catch (err: any) {\n284:     // Catch-all — never let build verification crash the process\n285:     printAgentUpdate(agent, `VERIFY ERROR: ${err.message?.slice(0, 100)}`);\n286:     updateAgent(state, agent.feature_id, {\n287:       status: \"failed\",\n288:       error: `Build verification error: ${err.message}`,\n289:       completed_at: new Date().toISOString(),\n290:     });\n291:     saveState(projectRoot, state);\n292:   }\n293: }\n294: \n295: /**\n296:  * Attempt to merge a verified agent's branch into the base branch.\n297:  *\n298:  * Handles conflict detection, base-into-feature merge, and resolver agent\n299:  * launch. Extracted from handleBuildVerification so it can be called\n300:  * independently (e.g., from resume's sequential merge phase).\n301:  */\n302: export async function attemptMerge(\n303:   projectRoot: string,\n304:   state: WaveState,\n305:   agent: AgentState,\n306:   feature: Feature,\n307:   config: WomboConfig,\n308:   model?: string,\n309: ): Promise<void> {\n310:   printAgentUpdate(agent, \"auto-merging...\");\n311:   try {\n312:     const mergeResult = await mergeBranch(projectRoot, agent.branch, state.base_branch, config);\n313: \n314:     if (mergeResult.success) {\n315:       updateAgent(state, agent.feature_id, {\n316:         status: \"merged\",\n317:         completed_at: new Date().toISOString(),\n318:       });\n319:       saveState(projectRoot, state);\n320:       printAgentUpdate(agent, `MERGED (${mergeResult.commitHash?.slice(0, 7)})`);\n321: \n322:       // Mark feature as done in .features.yml so it won't be re-selected\n323:       markFeatureDone(projectRoot, agent.feature_id, config, state.base_branch);\n324: \n325:       // Clean up worktree after successful merge\n326:       try {\n327:         removeWorktree(projectRoot, agent.worktree, true);\n328:         printAgentUpdate(agent, \"worktree and branch removed\");\n329:       } catch {\n330:         // Not critical — worktree cleanup is best-effort\n331:       }\n332:     } else {\n333:       // Merge failed — attempt automatic conflict resolution\n334:       const mergeError = mergeResult.error ?? \"Unknown merge error\";\n335:       printAgentUpdate(agent, `MERGE CONFLICT — attempting resolution...`);\n336: \n337:       try {\n338:         // Merge base INTO the feature worktree to create conflict markers\n339:         const conflictResult = await mergeBaseIntoFeature(\n340:           agent.worktree,\n341:           state.base_branch,\n342:           config\n343:         );\n344: \n345:         if (conflictResult.error && !conflictResult.conflicting) {\n346:           printAgentUpdate(agent, `CONFLICT SETUP FAILED: ${conflictResult.error.slice(0, 100)}`);\n347:           return; // Leave as \"verified\" for manual resolution\n348:         }\n349: \n350:         if (!conflictResult.conflicting) {\n351:           // Base merged cleanly into feature — retry merge into base.\n352:           printAgentUpdate(agent, \"base merged cleanly into feature — retrying merge...\");\n353:           const retryMerge = await mergeBranch(projectRoot, agent.branch, state.base_branch, config);\n354:           if (retryMerge.success) {\n355:             updateAgent(state, agent.feature_id, {\n356:               status: \"merged\",\n357:               completed_at: new Date().toISOString(),\n358:             });\n359:             saveState(projectRoot, state);\n360:             printAgentUpdate(agent, `MERGED after rebase (${retryMerge.commitHash?.slice(0, 7)})`);\n361:             markFeatureDone(projectRoot, agent.feature_id, config, state.base_branch);\n362:             try {\n363:               removeWorktree(projectRoot, agent.worktree, true);\n364:             } catch {}\n365:             return;\n366:           }\n367: \n368:           // Retry still failed — launch resolver agent\n369:           printAgentUpdate(agent, `retry merge still failed — launching resolver agent...`);\n370: \n371:           const secondConflict = await mergeBaseIntoFeature(\n372:             agent.worktree,\n373:             state.base_branch,\n374:             config\n375:           );\n376: \n377:           const conflictFiles = secondConflict.conflicting\n378:             ? secondConflict.files\n379:             : [\"(unknown — merge direction mismatch)\"];\n380:           const resolverMergeError = retryMerge.error ?? mergeError;\n381: \n382:           await launchResolverAndRetryMerge(\n383:             projectRoot, state, agent, feature, config, model,\n384:             resolverMergeError, conflictFiles\n385:           );\n386:           return;\n387:         }\n388: \n389:         // There are real conflicts — launch a resolver agent\n390:         printAgentUpdate(\n391:           agent,\n392:           `${conflictResult.files.length} conflicting file(s): ${conflictResult.files.join(\", \")}`\n393:         );\n394: \n395:         await launchResolverAndRetryMerge(\n396:           projectRoot, state, agent, feature, config, model,\n397:           mergeError, conflictResult.files\n398:         );\n399:       } catch (conflictErr: any) {\n400:         printAgentUpdate(agent, `CONFLICT RESOLUTION ERROR: ${conflictErr.message?.slice(0, 100)}`);\n401:         // Leave as \"verified\" for manual resolution\n402:       }\n403:     }\n404:   } catch (mergeErr: any) {\n405:     printAgentUpdate(agent, `AUTO-MERGE ERROR: ${mergeErr.message?.slice(0, 100)}`);\n406:   }\n407: }\n408: \n409: /**\n410:  * Launch a conflict resolver agent, wait for it to finish, re-verify build,\n411:  * and retry the merge. Extracted to avoid duplicating the resolver flow.\n412:  */\n413: async function launchResolverAndRetryMerge(\n414:   projectRoot: string,\n415:   state: WaveState,\n416:   agent: AgentState,\n417:   feature: Feature,\n418:   config: WomboConfig,\n419:   model: string | undefined,\n420:   mergeError: string,\n421:   conflictFiles: string[]\n422: ): Promise<void> {\n423:   const conflictPrompt = generateConflictResolutionPrompt(\n424:     feature,\n425:     state.base_branch,\n426:     mergeError,\n427:     config\n428:   );\n429: \n430:   updateAgent(state, agent.feature_id, {\n431:     status: \"resolving_conflict\",\n432:     activity: `resolving ${conflictFiles.length} conflict(s)...`,\n433:   });\n434:   saveState(projectRoot, state);\n435: \n436:   const resolverResult = launchConflictResolver({\n437:     worktreePath: agent.worktree,\n438:     featureId: agent.feature_id,\n439:     prompt: conflictPrompt,\n440:     model,\n441:     config,\n442:   });\n443: \n444:   updateAgent(state, agent.feature_id, {\n445:     pid: resolverResult.pid,\n446:   });\n447:   saveState(projectRoot, state);\n448: \n449:   // Wait for the resolver process to complete, then re-verify and retry merge.\n450:   // We intentionally do NOT add the resolver to the ProcessMonitor because\n451:   // the monitor's onComplete callback would trigger handleBuildVerification\n452:   // again, causing infinite recursion. Instead we await the process directly.\n453:   const resolverExitCode = await new Promise<number | null>((resolve) => {\n454:     resolverResult.process.on(\"exit\", (code) => resolve(code));\n455:     resolverResult.process.on(\"error\", () => resolve(null));\n456:   });\n457: \n458:   printAgentUpdate(agent, `conflict resolver exited (code ${resolverExitCode}) — re-verifying build...`);\n459: \n460:   // Re-verify build after conflict resolution\n461:   const rebuildResult = await runBuild(agent.worktree, config);\n462: \n463:   if (!rebuildResult.passed) {\n464:     printAgentUpdate(agent, `POST-CONFLICT BUILD FAILED`);\n465:     updateAgent(state, agent.feature_id, {\n466:       status: \"failed\",\n467:       build_passed: false,\n468:       build_output: rebuildResult.errorSummary,\n469:       error: \"Build failed after conflict resolution\",\n470:       completed_at: new Date().toISOString(),\n471:     });\n472:     saveState(projectRoot, state);\n473:     return;\n474:   }\n475: \n476:   printAgentUpdate(agent, \"post-conflict build passed — retrying merge...\");\n477: \n478:   const retryMerge = await mergeBranch(\n479:     projectRoot,\n480:     agent.branch,\n481:     state.base_branch,\n482:     config\n483:   );\n484: \n485:   if (retryMerge.success) {\n486:     updateAgent(state, agent.feature_id, {\n487:       status: \"merged\",\n488:       build_passed: true,\n489:       completed_at: new Date().toISOString(),\n490:     });\n491:     saveState(projectRoot, state);\n492:     printAgentUpdate(agent, `MERGED after conflict resolution (${retryMerge.commitHash?.slice(0, 7)})`);\n493:     markFeatureDone(projectRoot, agent.feature_id, config, state.base_branch);\n494:     try {\n495:       removeWorktree(projectRoot, agent.worktree, true);\n496:     } catch {}\n497:   } else {\n498:     printAgentUpdate(agent, `POST-CONFLICT MERGE FAILED: ${retryMerge.error}`);\n499:     updateAgent(state, agent.feature_id, {\n500:       status: \"failed\",\n501:       error: `Merge still failed after conflict resolution: ${retryMerge.error}`,\n502:       completed_at: new Date().toISOString(),\n503:     });\n504:     saveState(projectRoot, state);\n505:   }\n506: }\n507: \n508: /**\n509:  * Handle retry of a failed agent (error-based, not build-based).\n510:  */\n511: export function handleRetry(\n512:   projectRoot: string,\n513:   state: WaveState,\n514:   agent: AgentState,\n515:   monitor: ProcessMonitor,\n516:   config: WomboConfig,\n517:   model?: string\n518: ): void {\n519:   if (!agent.session_id || !agent.error) return;\n520: \n521:   const retryResult = retryHeadless({\n522:     worktreePath: agent.worktree,\n523:     featureId: agent.feature_id,\n524:     sessionId: agent.session_id,\n525:     buildErrors: agent.error,\n526:     model,\n527:     config,\n528:   });\n529: \n530:   updateAgent(state, agent.feature_id, {\n531:     status: \"running\",\n532:     pid: retryResult.pid,\n533:   });\n534:   saveState(projectRoot, state);\n535: \n536:   monitor.addProcess(agent.feature_id, retryResult.process);\n537: }\n538: \n539: /**\n540:  * Launch the next queued agent if capacity allows.\n541:  */\n542: export function launchNextQueued(\n543:   projectRoot: string,\n544:   state: WaveState,\n545:   featureMap: Map<string, Feature>,\n546:   monitor: ProcessMonitor,\n547:   config: WomboConfig,\n548:   model?: string\n549: ): void {\n550:   const active = activeAgents(state);\n551:   const queued = queuedAgents(state);\n552: \n553:   if (active.length < state.max_concurrent && queued.length > 0) {\n554:     const next = queued[0];\n555:     const feature = featureMap.get(next.feature_id);\n556:     if (feature) {\n557:       launchSingleHeadless(projectRoot, state, next, feature, monitor, config, model);\n558:     }\n559:   }\n560: }\n561: \n562: // ---------------------------------------------------------------------------\n563: // Headless Wave Launch\n564: // ---------------------------------------------------------------------------\n565: \n566: async function launchWaveHeadless(\n567:   projectRoot: string,\n568:   state: WaveState,\n569:   features: Feature[],\n570:   opts: LaunchCommandOptions\n571: ): Promise<void> {\n572:   const { config, model } = opts;\n573:   const featureMap = new Map(features.map((f) => [f.id, f]));\n574: \n575:   const monitor = new ProcessMonitor(projectRoot, {\n576:     onSessionId: (featureId, sessionId) => {\n577:       updateAgent(state, featureId, { session_id: sessionId });\n578:       saveState(projectRoot, state);\n579:     },\n580:     onComplete: (featureId) => {\n581:       updateAgent(state, featureId, {\n582:         status: \"completed\",\n583:         completed_at: new Date().toISOString(),\n584:       });\n585:       saveState(projectRoot, state);\n586: \n587:       // Run build verification — fire-and-forget\n588:       const agent = state.agents.find((a) => a.feature_id === featureId)!;\n589:       handleBuildVerification(projectRoot, state, agent, featureMap.get(featureId)!, config, model, monitor)\n590:         .then(() => launchNextQueued(projectRoot, state, featureMap, monitor, config, model))\n591:         .catch((err) => {\n592:           wtLog(featureId, `BUILD VERIFICATION UNHANDLED ERROR: ${err.message}`);\n593:           launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n594:         });\n595:     },\n596:     onError: (featureId, error) => {\n597:       const agent = state.agents.find((a) => a.feature_id === featureId)!;\n598:       if (agent.retries < agent.max_retries) {\n599:         updateAgent(state, featureId, {\n600:           status: \"retry\",\n601:           retries: agent.retries + 1,\n602:           error,\n603:         });\n604:         saveState(projectRoot, state);\n605: \n606:         // Retry\n607:         handleRetry(projectRoot, state, agent, monitor, config, model);\n608:       } else {\n609:         updateAgent(state, featureId, {\n610:           status: \"failed\",\n611:           error,\n612:           completed_at: new Date().toISOString(),\n613:         });\n614:         saveState(projectRoot, state);\n615:       }\n616: \n617:       // Try to launch next queued agent\n618:       launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n619:     },\n620:     onOutput: (_featureId, _data) => {\n621:       // Raw output — logged to file by ProcessMonitor\n622:     },\n623:     onActivity: (featureId, activity) => {\n624:       updateAgent(state, featureId, {\n625:         activity,\n626:         activity_updated_at: new Date().toISOString(),\n627:       });\n628:       // Don't save to disk on every activity — too frequent.\n629:     },\n630:   });\n631: \n632:   // Create the TUI — it will auto-refresh and show activity from the monitor\n633:   const tuiRef = { current: null as WomboTUI | null };\n634:   const startTUI = () => {\n635:     tuiRef.current = new WomboTUI({\n636:       state,\n637:       monitor,\n638:       projectRoot,\n639:       interactive: false,\n640:       config,\n641:       onQuit: () => {\n642:         // Same as SIGINT — save state and exit\n643:         for (const agent of state.agents) {\n644:           if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n645:             updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n646:           }\n647:         }\n648:         monitor.killAll();\n649:         saveState(projectRoot, state);\n650:         console.log(\"State saved. Use 'wombo resume' to continue.\");\n651:         process.exit(0);\n652:       },\n653:     });\n654:     tuiRef.current.start();\n655:   };\n656: \n657:   // Handle graceful shutdown\n658:   process.on(\"SIGINT\", () => {\n659:     if (tuiRef.current) tuiRef.current.stop();\n660:     for (const agent of state.agents) {\n661:       if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n662:         updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n663:       }\n664:     }\n665:     monitor.killAll();\n666:     saveState(projectRoot, state);\n667:     console.log(\"\\nState saved. Use 'wombo resume' to continue.\");\n668:     process.exit(0);\n669:   });\n670: \n671:   // Launch initial batch — set up worktrees in parallel\n672:   const tolaunch = queuedAgents(state).slice(0, opts.maxConcurrent);\n673:   console.log(`Setting up ${tolaunch.length} agent(s) in parallel...\\n`);\n674: \n675:   await Promise.all(\n676:     tolaunch.map((agent) =>\n677:       launchSingleHeadless(\n678:         projectRoot,\n679:         state,\n680:         agent,\n681:         featureMap.get(agent.feature_id)!,\n682:         monitor,\n683:         config,\n684:         model\n685:       )\n686:     )\n687:   );\n688: \n689:   const launched = state.agents.filter((a) => a.status === \"running\").length;\n690: \n691:   // Start the TUI dashboard (or skip if --no-tui)\n692:   if (opts.noTui) {\n693:     console.log(`${launched} agent(s) running. (--no-tui mode, dashboard prints every 15s)\\n`);\n694:     printDashboard(state);\n695:   } else {\n696:     console.log(`${launched} agent(s) running. Launching TUI...\\n`);\n697:     startTUI();\n698:   }\n699: \n700:   // Background monitoring loop — checks for dead processes and launches queued\n701:   const POLL_INTERVAL = 5000;\n702:   let dashboardCounter = 0;\n703:   while (!isWaveComplete(state)) {\n704:     await new Promise((r) => setTimeout(r, POLL_INTERVAL));\n705: \n706:     // Check for completed processes that weren't caught by event handlers\n707:     for (const agent of state.agents) {\n708:       if (\n709:         (agent.status === \"running\" || agent.status === \"resolving_conflict\") &&\n710:         agent.pid &&\n711:         !isProcessRunning(agent.pid) &&\n712:         !monitor.isRunning(agent.feature_id)\n713:       ) {\n714:         if (agent.status === \"resolving_conflict\") {\n715:           // Conflict resolver died — the await in handleBuildVerification\n716:           // will resolve via the 'exit' event, so nothing to do here\n717:           continue;\n718:         }\n719:         // Process exited but we didn't get a callback\n720:         // Check if the agent actually made any commits\n721:         if (!branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n722:           // Agent died without producing any code — mark as failed, not completed\n723:           updateAgent(state, agent.feature_id, {\n724:             status: \"failed\",\n725:             error: \"Agent process exited without making any commits\",\n726:             activity: null,\n727:             completed_at: new Date().toISOString(),\n728:           });\n729:           saveState(projectRoot, state);\n730:           wtLog(agent.feature_id, \"process died with no code changes — marked failed\");\n731:         } else {\n732:           updateAgent(state, agent.feature_id, {\n733:             status: \"completed\",\n734:             completed_at: new Date().toISOString(),\n735:             activity: \"done\",\n736:           });\n737:           saveState(projectRoot, state);\n738:           try {\n739:             await handleBuildVerification(projectRoot, state, agent, featureMap.get(agent.feature_id)!, config, model, monitor);\n740:           } catch (err: any) {\n741:             wtLog(agent.feature_id, `POLL VERIFY ERROR: ${err.message}`);\n742:           }\n743:         }\n744:         launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n745:       }\n746:     }\n747: \n748:     // Persist state periodically\n749:     saveState(projectRoot, state);\n750: \n751:     // Update TUI state reference (or print dashboard in --no-tui mode)\n752:     if (tuiRef.current) {\n753:       tuiRef.current.updateState(state);\n754:     } else if (opts.noTui) {\n755:       dashboardCounter++;\n756:       if (dashboardCounter % 3 === 0) {\n757:         printDashboard(state);\n758: \n759:         // Auto-push base branch if requested\n760:         if (opts.autoPush) {\n761:           const anyMerged = state.agents.some((a) => a.status === \"merged\");\n762:           if (anyMerged) {\n763:             await pushBaseBranch(projectRoot, state.base_branch, config);\n764:           } else {\n765:             console.log(\"No branches were merged — skipping push.\");\n766:           }\n767:         }\n768:       }\n769:     }\n770:   }\n771: \n772:   // Wave complete — tear down TUI and show final summary\n773:   if (tuiRef.current) tuiRef.current.stop();\n774:   printDashboard(state);\n775: \n776:   // Auto-push base branch if requested\n777:   if (opts.autoPush) {\n778:     await pushBaseBranch(projectRoot, state.base_branch, config);\n779:   }\n780: \n781:   console.log(\"Wave complete.\");\n782: }\n783: \n784: // ---------------------------------------------------------------------------\n785: // Interactive Wave Launch\n786: // ---------------------------------------------------------------------------\n787: \n788: async function launchWaveInteractive(\n789:   projectRoot: string,\n790:   state: WaveState,\n791:   features: Feature[],\n792:   opts: LaunchCommandOptions\n793: ): Promise<void> {\n794:   const { config, model } = opts;\n795:   const featureMap = new Map(features.map((f) => [f.id, f]));\n796: \n797:   // Show dashboard immediately\n798:   printDashboard(state);\n799: \n800:   // Launch initial batch in tmux — parallelize setup\n801:   const tolaunch = queuedAgents(state).slice(0, opts.maxConcurrent);\n802:   console.log(`Setting up ${tolaunch.length} agent(s) in parallel...\\n`);\n803: \n804:   await Promise.all(\n805:     tolaunch.map(async (agent) => {\n806:       updateAgent(state, agent.feature_id, {\n807:         status: \"installing\",\n808:         started_at: new Date().toISOString(),\n809:         activity: \"setting up worktree...\",\n810:       });\n811:       saveState(projectRoot, state);\n812: \n813:       try {\n814:         if (worktreeReady(agent.worktree)) {\n815:           wtLog(agent.feature_id, \"worktree already exists, skipping setup\");\n816:         } else {\n817:           await createWorktree(projectRoot, agent.feature_id, state.base_branch, config);\n818:           updateAgent(state, agent.feature_id, { activity: \"installing deps...\" });\n819:           await installDeps(agent.worktree, agent.feature_id, config);\n820:         }\n821: \n822:         const prompt = generatePrompt(\n823:           featureMap.get(agent.feature_id)!,\n824:           state.base_branch,\n825:           config\n826:         );\n827: \n828:         wtLog(agent.feature_id, \"launching tmux session...\");\n829:         const result = launchInteractive({\n830:           worktreePath: agent.worktree,\n831:           featureId: agent.feature_id,\n832:           prompt,\n833:           model,\n834:           interactive: true,\n835:           config,\n836:         });\n837: \n838:         updateAgent(state, agent.feature_id, {\n839:           status: \"running\",\n840:           pid: result.pid,\n841:           activity: \"tmux session active\",\n842:         });\n843:         saveState(projectRoot, state);\n844:         wtLog(agent.feature_id, `tmux session: ${config.agent.tmuxPrefix}-${agent.feature_id}`);\n845:       } catch (err: any) {\n846:         updateAgent(state, agent.feature_id, {\n847:           status: \"failed\",\n848:           error: err.message,\n849:           activity: null,\n850:           completed_at: new Date().toISOString(),\n851:         });\n852:         saveState(projectRoot, state);\n853:         wtLog(agent.feature_id, `SETUP FAILED: ${err.message.split(\"\\n\")[0]}`);\n854:       }\n855:     })\n856:   );\n857: \n858:   console.log(\"\\nInteractive sessions launched. Use these commands:\");\n859:   console.log(`  tmux attach -t ${config.agent.tmuxPrefix}-<feature-id>   # attach to a session`);\n860:   console.log(\"  tmux ls                                                  # list sessions\");\n861:   console.log(\"  wombo status                                             # check status\");\n862:   console.log(\"  wombo verify                                             # verify builds\");\n863:   console.log(\"  wombo merge                                              # merge verified\");\n864:   console.log(\"  wombo cleanup                                            # remove worktrees\");\n865: \n866:   printDashboard(state);\n867: }\n868: \n869: // ---------------------------------------------------------------------------\n870: // Main Command\n871: // ---------------------------------------------------------------------------\n872: \n873: export async function cmdLaunch(opts: LaunchCommandOptions): Promise<void> {\n874:   const { projectRoot, config } = opts;\n875: \n876:   console.log(\"\\n--- Wombo: Launch ---\\n\");\n877: \n878:   // Ensure agent definition exists — reinstall from template if missing\n879:   ensureAgentDefinition(projectRoot, config);\n880: \n881:   // -------------------------------------------------------------------------\n882:   // Check for existing wave state — don't overwrite work in progress\n883:   // -------------------------------------------------------------------------\n884:   const existingState = loadState(projectRoot);\n885:   if (existingState) {\n886:     const merged = existingState.agents.filter((a) => a.status === \"merged\");\n887:     const verified = existingState.agents.filter((a) => a.status === \"verified\");\n888:     const completed = existingState.agents.filter((a) => a.status === \"completed\");\n889:     const running = existingState.agents.filter((a) => a.status === \"running\");\n890:     const queued = existingState.agents.filter((a) => a.status === \"queued\");\n891:     const failed = existingState.agents.filter((a) => a.status === \"failed\");\n892: \n893:     const hasWork = merged.length > 0 || verified.length > 0 || completed.length > 0 || running.length > 0;\n894: \n895:     if (hasWork) {\n896:       console.log(`Existing wave found: ${existingState.wave_id}`);\n897:       console.log(`  ${merged.length} merged, ${verified.length} verified, ${completed.length} completed, ${running.length} running, ${queued.length} queued, ${failed.length} failed`);\n898: \n899:       // Finalize any merged agents by marking their features as done\n900:       if (merged.length > 0) {\n901:         console.log(\"\\nFinalizing merged features in .features.yml...\");\n902:         for (const agent of merged) {\n903:           markFeatureDone(projectRoot, agent.feature_id, config, existingState.base_branch);\n904:           // Clean up worktree and branch (already merged, safe to delete)\n905:           try {\n906:             removeWorktree(projectRoot, agent.worktree, true);\n907:             console.log(`  ${agent.feature_id}: marked done, worktree removed`);\n908:           } catch {\n909:             console.log(`  ${agent.feature_id}: marked done (worktree already cleaned)`);\n910:           }\n911:         }\n912:       }\n913: \n914:       // Verified agents: build passed but NOT merged — do NOT mark done.\n915:       // Leave them for 'wombo resume' to attempt the merge.\n916:       if (verified.length > 0) {\n917:         for (const agent of verified) {\n918:           console.log(`  ${agent.feature_id}: verified (not yet merged) — use 'wombo resume' to merge`);\n919:         }\n920:       }\n921: \n922:       const activeCount = running.length + completed.length + queued.length;\n923:       if (activeCount > 0) {\n924:         console.error(`\\nWave ${existingState.wave_id} has ${activeCount} unfinished agent(s).`);\n925:         console.error(\"Use 'wombo resume' to continue the existing wave,\");\n926:         console.error(\"or 'wombo cleanup' to clear it before starting a new one.\");\n927:         process.exit(1);\n928:       }\n929: \n930:       // All agents are in terminal states (merged/verified/failed) — safe to start fresh\n931:       console.log(\"\\nAll agents in previous wave are finished. Starting fresh wave.\\n\");\n932:     }\n933:   }\n934: \n935:   // Load features\n936:   const data = loadFeatures(projectRoot, config);\n937: \n938:   // Build selection options\n939:   const selOpts: SelectionOptions = {};\n940:   if (opts.topPriority) selOpts.topPriority = opts.topPriority;\n941:   if (opts.quickestWins) selOpts.quickestWins = opts.quickestWins;\n942:   if (opts.priority) selOpts.priority = opts.priority;\n943:   if (opts.difficulty) selOpts.difficulty = opts.difficulty;\n944:   if (opts.features) selOpts.featureIds = opts.features;\n945:   if (opts.allReady) selOpts.allReady = true;\n946: \n947:   // Select features\n948:   const selected = selectFeatures(data, selOpts);\n949: \n950:   if (selected.length === 0) {\n951:     if (opts.allReady) {\n952:       console.error(\n953:         \"No launchable features found. All features may be done, cancelled, or have unmet dependencies.\"\n954:       );\n955:     } else {\n956:       console.error(\n957:         \"No features matched the selection criteria. Use --all-ready to see all available.\"\n958:       );\n959:     }\n960:     process.exit(1);\n961:   }\n962: \n963:   // Show selection\n964:   printFeatureSelection(\n965:     selected.map((f) => ({\n966:       id: f.id,\n967:       title: f.title,\n968:       priority: f.priority,\n969:       difficulty: f.difficulty,\n970:       effort: f.effort,\n971:     }))\n972:   );\n973: \n974:   if (opts.dryRun) {\n975:     console.log(\"Dry run — not launching agents.\");\n976:     return;\n977:   }\n978: \n979:   // Create wave state\n980:   const state = createWaveState({\n981:     baseBranch: opts.baseBranch,\n982:     maxConcurrent: opts.maxConcurrent,\n983:     model: opts.model ?? null,\n984:     interactive: opts.interactive,\n985:   });\n986: \n987:   // Create agent entries for all selected features\n988:   for (const feature of selected) {\n989:     const branch = featureBranchName(feature.id, config);\n990:     const wtPath = worktreePath(projectRoot, feature.id, config);\n991:     const agent = createAgentState(feature.id, branch, wtPath, opts.maxRetries);\n992:     // Set effort estimate from feature spec\n993:     const effortMinutes = parseDurationMinutes(feature.effort);\n994:     agent.effort_estimate_ms = effortMinutes === Infinity ? null : effortMinutes * 60 * 1000;\n995:     state.agents.push(agent);\n996:   }\n997: \n998:   saveState(projectRoot, state);\n999:   console.log(`Wave ${state.wave_id} created with ${selected.length} agents.`);\n1000: \n1001:   // Launch agents up to max_concurrent\n1002:   if (opts.interactive) {\n1003:     await launchWaveInteractive(projectRoot, state, selected, opts);\n1004:   } else {\n1005:     await launchWaveHeadless(projectRoot, state, selected, opts);\n1006:   }\n1007: }\n\n(End of file - total 1007 lines)\n</content>","title":"src/commands/launch.ts","metadata":{"preview":"/**\n * launch.ts — Launch a wave of agents.\n *\n * Usage: wombo launch [selection options] [launch options]\n *\n * This is the primary entry point for starting a new wave. It selects features\n * from the features file, creates a wave state, sets up worktrees, and launches\n * agent processes (either headless or interactive via tmux).\n *\n * IMPORTANT: This file also exports shared helper functions that are reused\n * by resume.ts and other commands:\n *   - launchSingleHeadless\n *   - handleBuildVerification\n *   - handleRetry\n *   - launchNextQueued\n */\n\nimport { execSync } from \"node:child_process\";\nimport type { WomboConfig } from \"../config.js\";\nimport type { Feature, SelectionOptions, Priority, Difficulty } from \"../lib/features.js\";","truncated":false,"loaded":[]},"time":{"start":1773351684820,"end":1773351684824}}}}
{"type":"text","timestamp":1773351685200,"sessionID":"ses_31c036c7affe6dPx3n8MQ9tKUs","part":{"id":"prt_ce3ff4099001pc5hvo5Uy2wb65","sessionID":"ses_31c036c7affe6dPx3n8MQ9tKUs","messageID":"msg_ce3ff35e70010SBtumoDtn3Zm2","type":"text","text":"Good. I'm on `feature/dependency-aware-sequencing` with the new `src/lib/dependency-graph.ts` file created but not yet committed. Let me read it and verify it, then proceed with the remaining subtasks.","time":{"start":1773351685199,"end":1773351685199}}}
{"type":"tool_use","timestamp":1773351685202,"sessionID":"ses_31c036c7affe6dPx3n8MQ9tKUs","part":{"id":"prt_ce3ff4ad5001IXhaLfTm0Rl8AV","sessionID":"ses_31c036c7affe6dPx3n8MQ9tKUs","messageID":"msg_ce3ff35e70010SBtumoDtn3Zm2","type":"tool","callID":"toolu_vrtx_01AVxMVZJycYDu6vyDwB1PGK","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-dependency-aware-sequencing/src/lib/state.ts"},"output":"<path>/home/fulgidus/Documents/wombo-dependency-aware-sequencing/src/lib/state.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * state.ts — Persistent wave state management.\n3:  *\n4:  * Responsibilities:\n5:  *   - Define the shape of .wombo-state.json\n6:  *   - Read/write state atomically\n7:  *   - Generate wave IDs\n8:  *   - Update individual agent state within a wave\n9:  */\n10: \n11: import { readFileSync, writeFileSync, existsSync, renameSync } from \"node:fs\";\n12: import { resolve } from \"node:path\";\n13: \n14: // ---------------------------------------------------------------------------\n15: // Types\n16: // ---------------------------------------------------------------------------\n17: \n18: export type AgentStatus =\n19:   | \"queued\"\n20:   | \"installing\"\n21:   | \"running\"\n22:   | \"completed\"\n23:   | \"verified\"\n24:   | \"failed\"\n25:   | \"merged\"\n26:   | \"retry\"\n27:   | \"resolving_conflict\";\n28: \n29: export interface AgentState {\n30:   feature_id: string;\n31:   branch: string;\n32:   worktree: string;\n33:   session_id: string | null;\n34:   pid: number | null;\n35:   status: AgentStatus;\n36:   activity: string | null;\n37:   activity_updated_at: string | null;\n38:   retries: number;\n39:   max_retries: number;\n40:   started_at: string | null;\n41:   completed_at: string | null;\n42:   build_passed: boolean | null;\n43:   build_output: string | null;\n44:   error: string | null;\n45:   /** Estimated effort in milliseconds (from feature's ISO 8601 duration) */\n46:   effort_estimate_ms: number | null;\n47: }\n48: \n49: export interface WaveState {\n50:   wave_id: string;\n51:   base_branch: string;\n52:   started_at: string;\n53:   updated_at: string;\n54:   max_concurrent: number;\n55:   model: string | null;\n56:   interactive: boolean;\n57:   agents: AgentState[];\n58: }\n59: \n60: // ---------------------------------------------------------------------------\n61: // Constants\n62: // ---------------------------------------------------------------------------\n63: \n64: const STATE_FILE = \".wombo-state.json\";\n65: \n66: // ---------------------------------------------------------------------------\n67: // Wave ID Generation\n68: // ---------------------------------------------------------------------------\n69: \n70: /**\n71:  * Generate a unique wave ID based on current timestamp.\n72:  * Format: wave-YYYY-MM-DD-NNN\n73:  */\n74: export function generateWaveId(): string {\n75:   const now = new Date();\n76:   const date = now.toISOString().slice(0, 10);\n77:   const seq = String(now.getHours() * 60 + now.getMinutes()).padStart(3, \"0\");\n78:   return `wave-${date}-${seq}`;\n79: }\n80: \n81: // ---------------------------------------------------------------------------\n82: // State Path\n83: // ---------------------------------------------------------------------------\n84: \n85: function statePath(projectRoot: string): string {\n86:   return resolve(projectRoot, STATE_FILE);\n87: }\n88: \n89: // ---------------------------------------------------------------------------\n90: // Read State\n91: // ---------------------------------------------------------------------------\n92: \n93: /**\n94:  * Load the current wave state from disk. Returns null if no state file exists.\n95:  */\n96: export function loadState(projectRoot: string): WaveState | null {\n97:   const p = statePath(projectRoot);\n98:   if (!existsSync(p)) return null;\n99:   try {\n100:     const raw = readFileSync(p, \"utf-8\");\n101:     return JSON.parse(raw) as WaveState;\n102:   } catch {\n103:     return null;\n104:   }\n105: }\n106: \n107: // ---------------------------------------------------------------------------\n108: // Write State\n109: // ---------------------------------------------------------------------------\n110: \n111: /**\n112:  * Save wave state to disk atomically (write to tmp then rename).\n113:  */\n114: export function saveState(projectRoot: string, state: WaveState): void {\n115:   state.updated_at = new Date().toISOString();\n116:   const p = statePath(projectRoot);\n117:   const tmp = p + \".tmp\";\n118:   writeFileSync(tmp, JSON.stringify(state, null, 2) + \"\\n\", \"utf-8\");\n119:   renameSync(tmp, p);\n120: }\n121: \n122: // ---------------------------------------------------------------------------\n123: // State Mutations\n124: // ---------------------------------------------------------------------------\n125: \n126: /**\n127:  * Create a fresh wave state.\n128:  */\n129: export function createWaveState(opts: {\n130:   baseBranch: string;\n131:   maxConcurrent: number;\n132:   model: string | null;\n133:   interactive: boolean;\n134: }): WaveState {\n135:   return {\n136:     wave_id: generateWaveId(),\n137:     base_branch: opts.baseBranch,\n138:     started_at: new Date().toISOString(),\n139:     updated_at: new Date().toISOString(),\n140:     max_concurrent: opts.maxConcurrent,\n141:     model: opts.model,\n142:     interactive: opts.interactive,\n143:     agents: [],\n144:   };\n145: }\n146: \n147: /**\n148:  * Create an initial agent state for a feature.\n149:  */\n150: export function createAgentState(\n151:   featureId: string,\n152:   branch: string,\n153:   worktreePath: string,\n154:   maxRetries: number = 2\n155: ): AgentState {\n156:   return {\n157:     feature_id: featureId,\n158:     branch,\n159:     worktree: worktreePath,\n160:     session_id: null,\n161:     pid: null,\n162:     status: \"queued\",\n163:     activity: null,\n164:     activity_updated_at: null,\n165:     retries: 0,\n166:     max_retries: maxRetries,\n167:     started_at: null,\n168:     completed_at: null,\n169:     build_passed: null,\n170:     build_output: null,\n171:     error: null,\n172:     effort_estimate_ms: null,\n173:   };\n174: }\n175: \n176: /**\n177:  * Find an agent state by feature ID.\n178:  */\n179: export function getAgent(\n180:   state: WaveState,\n181:   featureId: string\n182: ): AgentState | undefined {\n183:   return state.agents.find((a) => a.feature_id === featureId);\n184: }\n185: \n186: /**\n187:  * Update an agent's state fields.\n188:  */\n189: export function updateAgent(\n190:   state: WaveState,\n191:   featureId: string,\n192:   updates: Partial<AgentState>\n193: ): void {\n194:   const agent = state.agents.find((a) => a.feature_id === featureId);\n195:   if (!agent) throw new Error(`Agent not found for feature: ${featureId}`);\n196:   Object.assign(agent, updates);\n197: }\n198: \n199: /**\n200:  * Get counts of agents by status.\n201:  */\n202: export function agentCounts(state: WaveState): Record<AgentStatus, number> {\n203:   const counts: Record<AgentStatus, number> = {\n204:     queued: 0,\n205:     installing: 0,\n206:     running: 0,\n207:     completed: 0,\n208:     verified: 0,\n209:     failed: 0,\n210:     merged: 0,\n211:     retry: 0,\n212:     resolving_conflict: 0,\n213:   };\n214:   for (const a of state.agents) {\n215:     counts[a.status]++;\n216:   }\n217:   return counts;\n218: }\n219: \n220: /**\n221:  * Get agents that are currently running or installing.\n222:  */\n223: export function activeAgents(state: WaveState): AgentState[] {\n224:   return state.agents.filter(\n225:     (a) => a.status === \"running\" || a.status === \"installing\" || a.status === \"resolving_conflict\"\n226:   );\n227: }\n228: \n229: /**\n230:  * Get agents that are queued and ready to be launched.\n231:  */\n232: export function queuedAgents(state: WaveState): AgentState[] {\n233:   return state.agents.filter((a) => a.status === \"queued\");\n234: }\n235: \n236: /**\n237:  * Check if the wave is fully complete (no queued, installing, running, or retry agents).\n238:  */\n239: export function isWaveComplete(state: WaveState): boolean {\n240:   return state.agents.every(\n241:     (a) =>\n242:       a.status === \"completed\" ||\n243:       a.status === \"verified\" ||\n244:       a.status === \"failed\" ||\n245:       a.status === \"merged\"\n246:   );\n247: }\n\n(End of file - total 247 lines)\n</content>","title":"src/lib/state.ts","metadata":{"preview":"/**\n * state.ts — Persistent wave state management.\n *\n * Responsibilities:\n *   - Define the shape of .wombo-state.json\n *   - Read/write state atomically\n *   - Generate wave IDs\n *   - Update individual agent state within a wave\n */\n\nimport { readFileSync, writeFileSync, existsSync, renameSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type AgentStatus =\n  | \"queued\"\n  | \"installing\"","truncated":false,"loaded":[]},"time":{"start":1773351685197,"end":1773351685201}}}}
