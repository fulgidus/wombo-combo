{"type":"tool_use","timestamp":1773351519351,"sessionID":"ses_31c036c7affe6dPx3n8MQ9tKUs","part":{"id":"prt_ce3fcc08b001VMrMPpbNmcBe7P","sessionID":"ses_31c036c7affe6dPx3n8MQ9tKUs","messageID":"msg_ce3fcb817001DlyAdg5mV5FZLE","type":"tool","callID":"toolu_vrtx_01HSoXdXdbjvTuTny9qZWcMs","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-dependency-aware-sequencing/src/lib/features.ts"},"output":"<path>/home/fulgidus/Documents/wombo-dependency-aware-sequencing/src/lib/features.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * features.ts — Parse features YAML and provide feature selection/filtering.\n3:  *\n4:  * Responsibilities:\n5:  *   - Load and parse the features file with full type safety\n6:  *   - Parse ISO 8601 durations into comparable minutes\n7:  *   - Filter features by status, priority, difficulty, dependency readiness\n8:  *   - Select features by various strategies (top-priority, quickest-wins, etc.)\n9:  *   - Resolve dependency graphs to determine which features are ready to start\n10:  *   - Write-back capability for feature management commands\n11:  */\n12: \n13: import { readFileSync, writeFileSync, existsSync } from \"node:fs\";\n14: import { resolve, dirname, join } from \"node:path\";\n15: import { parse as parseYaml, stringify as stringifyYaml } from \"yaml\";\n16: import { createInterface } from \"node:readline\";\n17: import type { WomboConfig } from \"../config.js\";\n18: \n19: // ---------------------------------------------------------------------------\n20: // Template path (resolved relative to this source file)\n21: // ---------------------------------------------------------------------------\n22: \n23: export const FEATURES_TEMPLATE_PATH = join(dirname(import.meta.dir), \"templates\", \".features.yml\");\n24: \n25: // ---------------------------------------------------------------------------\n26: // Types\n27: // ---------------------------------------------------------------------------\n28: \n29: export type FeatureStatus =\n30:   | \"backlog\"\n31:   | \"planned\"\n32:   | \"in_progress\"\n33:   | \"blocked\"\n34:   | \"in_review\"\n35:   | \"done\"\n36:   | \"cancelled\";\n37: \n38: export type Priority = \"critical\" | \"high\" | \"medium\" | \"low\" | \"wishlist\";\n39: \n40: export type Difficulty = \"trivial\" | \"easy\" | \"medium\" | \"hard\" | \"very_hard\";\n41: \n42: export interface Subtask {\n43:   id: string;\n44:   title: string;\n45:   description: string;\n46:   status: FeatureStatus;\n47:   completion: number;\n48:   difficulty: Difficulty;\n49:   priority: Priority;\n50:   depends_on: string[];\n51:   effort: string;\n52:   started_at: string | null;\n53:   ended_at: string | null;\n54:   constraints: string[];\n55:   forbidden: string[];\n56:   references: string[];\n57:   notes: string[];\n58:   subtasks: Subtask[];\n59: }\n60: \n61: export interface Feature {\n62:   id: string;\n63:   title: string;\n64:   description: string;\n65:   status: FeatureStatus;\n66:   completion: number;\n67:   difficulty: Difficulty;\n68:   priority: Priority;\n69:   depends_on: string[];\n70:   effort: string;\n71:   started_at: string | null;\n72:   ended_at: string | null;\n73:   constraints: string[];\n74:   forbidden: string[];\n75:   references: string[];\n76:   notes: string[];\n77:   subtasks: Subtask[];\n78: }\n79: \n80: export interface FeaturesFile {\n81:   version: string;\n82:   meta: {\n83:     created_at: string;\n84:     updated_at: string;\n85:     project: string;\n86:     generator: string;\n87:     maintainer: string;\n88:   };\n89:   features: Feature[];\n90:   archive: Feature[];\n91: }\n92: \n93: // Priority ordering (lower = more important)\n94: const PRIORITY_ORDER: Record<Priority, number> = {\n95:   critical: 0,\n96:   high: 1,\n97:   medium: 2,\n98:   low: 3,\n99:   wishlist: 4,\n100: };\n101: \n102: // Difficulty ordering (lower = easier)\n103: const DIFFICULTY_ORDER: Record<Difficulty, number> = {\n104:   trivial: 0,\n105:   easy: 1,\n106:   medium: 2,\n107:   hard: 3,\n108:   very_hard: 4,\n109: };\n110: \n111: // ---------------------------------------------------------------------------\n112: // ISO 8601 Duration Parser\n113: // ---------------------------------------------------------------------------\n114: \n115: /**\n116:  * Parse an ISO 8601 duration string into total minutes.\n117:  * Supports: P[nD][T[nH][nM][nS]]\n118:  * Examples: PT1H -> 60, PT30M -> 30, P1D -> 1440, P2DT4H -> 3360, PT1H30M -> 90\n119:  */\n120: export function parseDurationMinutes(iso: string): number {\n121:   const match = iso.match(\n122:     /^P(?:(\\d+)D)?(?:T(?:(\\d+)H)?(?:(\\d+)M)?(?:(\\d+)S)?)?$/\n123:   );\n124:   if (!match) return Infinity; // unparseable -> sort to end\n125:   const days = parseInt(match[1] || \"0\", 10);\n126:   const hours = parseInt(match[2] || \"0\", 10);\n127:   const minutes = parseInt(match[3] || \"0\", 10);\n128:   const seconds = parseInt(match[4] || \"0\", 10);\n129:   return days * 24 * 60 + hours * 60 + minutes + Math.ceil(seconds / 60);\n130: }\n131: \n132: /**\n133:  * Format minutes into a human-readable string.\n134:  */\n135: export function formatDuration(minutes: number): string {\n136:   if (minutes === Infinity) return \"unknown\";\n137:   if (minutes < 60) return `${minutes}m`;\n138:   const h = Math.floor(minutes / 60);\n139:   const m = minutes % 60;\n140:   if (h >= 24) {\n141:     const d = Math.floor(h / 24);\n142:     const rh = h % 24;\n143:     if (rh === 0 && m === 0) return `${d}d`;\n144:     if (m === 0) return `${d}d ${rh}h`;\n145:     return `${d}d ${rh}h ${m}m`;\n146:   }\n147:   return m === 0 ? `${h}h` : `${h}h ${m}m`;\n148: }\n149: \n150: // ---------------------------------------------------------------------------\n151: // Features File Existence Guard\n152: // ---------------------------------------------------------------------------\n153: \n154: /**\n155:  * Prompt the user with a yes/no question via stdin.\n156:  */\n157: function promptYesNo(question: string): Promise<boolean> {\n158:   const rl = createInterface({ input: process.stdin, output: process.stdout });\n159:   return new Promise((resolve) => {\n160:     rl.question(question, (answer) => {\n161:       rl.close();\n162:       resolve(answer.trim().toLowerCase().startsWith(\"y\"));\n163:     });\n164:   });\n165: }\n166: \n167: /**\n168:  * Ensure the features file exists before any command that needs it.\n169:  * If the file is missing, prompt the user to generate one from the template.\n170:  */\n171: export async function ensureFeaturesFile(\n172:   projectRoot: string,\n173:   config: WomboConfig\n174: ): Promise<void> {\n175:   const filePath = resolve(projectRoot, config.featuresFile);\n176: \n177:   if (existsSync(filePath)) return;\n178: \n179:   console.log(`\\nFeatures file not found: ${config.featuresFile}`);\n180: \n181:   const generate = await promptYesNo(\n182:     \"Generate a new features file from template? (y/N): \"\n183:   );\n184: \n185:   if (!generate) {\n186:     console.error(\n187:       `Cannot proceed without a features file. Create one manually or run again and accept the prompt.`\n188:     );\n189:     process.exit(1);\n190:   }\n191: \n192:   // Read template, update timestamps, write to project root\n193:   const template = readFileSync(FEATURES_TEMPLATE_PATH, \"utf-8\");\n194:   const now = new Date().toISOString();\n195:   const content = template\n196:     .replace(/created_at:\\s*\".*?\"/, `created_at: \"${now}\"`)\n197:     .replace(/updated_at:\\s*\".*?\"/, `updated_at: \"${now}\"`);\n198: \n199:   writeFileSync(filePath, content, \"utf-8\");\n200:   console.log(`Created ${config.featuresFile} from template.\\n`);\n201: }\n202: \n203: // ---------------------------------------------------------------------------\n204: // Loader\n205: // ---------------------------------------------------------------------------\n206: \n207: /**\n208:  * Load and parse the features YAML file from the project root.\n209:  * Uses config.featuresFile for the file path.\n210:  */\n211: export function loadFeatures(\n212:   projectRoot: string,\n213:   config: WomboConfig\n214: ): FeaturesFile {\n215:   const filePath = resolve(projectRoot, config.featuresFile);\n216:   const raw = readFileSync(filePath, \"utf-8\");\n217:   const parsed = parseYaml(raw) as FeaturesFile;\n218: \n219:   // Normalize: ensure top-level arrays are never null/undefined (YAML parses\n220:   // empty keys as null).\n221:   parsed.features = parsed.features ?? [];\n222:   parsed.archive = parsed.archive ?? [];\n223: \n224:   for (const f of [...parsed.features, ...parsed.archive]) {\n225:     normalizeFeature(f);\n226:   }\n227: \n228:   return parsed;\n229: }\n230: \n231: /**\n232:  * Save the features file back to disk (for management commands).\n233:  */\n234: export function saveFeatures(\n235:   projectRoot: string,\n236:   config: WomboConfig,\n237:   data: FeaturesFile\n238: ): void {\n239:   const filePath = resolve(projectRoot, config.featuresFile);\n240:   data.meta.updated_at = new Date().toISOString();\n241:   const yaml = stringifyYaml(data, {\n242:     lineWidth: 120,\n243:     defaultKeyType: \"PLAIN\",\n244:     defaultStringType: \"PLAIN\",\n245:   });\n246:   writeFileSync(filePath, yaml, \"utf-8\");\n247: }\n248: \n249: function normalizeFeature(f: Feature | Subtask): void {\n250:   f.depends_on = f.depends_on ?? [];\n251:   f.constraints = f.constraints ?? [];\n252:   f.forbidden = f.forbidden ?? [];\n253:   f.references = f.references ?? [];\n254:   f.notes = f.notes ?? [];\n255:   f.subtasks = f.subtasks ?? [];\n256:   for (const s of f.subtasks) {\n257:     normalizeFeature(s);\n258:   }\n259: }\n260: \n261: // ---------------------------------------------------------------------------\n262: // Dependency Resolution\n263: // ---------------------------------------------------------------------------\n264: \n265: /**\n266:  * Get all feature IDs that are done (status === \"done\" or completion === 100).\n267:  */\n268: function getDoneIds(features: Feature[], archive: Feature[]): Set<string> {\n269:   const done = new Set<string>();\n270:   const collectDone = (items: (Feature | Subtask)[]) => {\n271:     for (const item of items) {\n272:       if (item.status === \"done\" || item.completion === 100) {\n273:         done.add(item.id);\n274:       }\n275:       if (item.subtasks?.length) {\n276:         collectDone(item.subtasks);\n277:       }\n278:     }\n279:   };\n280:   collectDone(features);\n281:   collectDone(archive);\n282:   return done;\n283: }\n284: \n285: /**\n286:  * Check if a feature's dependencies are all satisfied.\n287:  */\n288: export function areDependenciesMet(\n289:   feature: Feature,\n290:   doneIds: Set<string>\n291: ): boolean {\n292:   return feature.depends_on.every((dep) => doneIds.has(dep));\n293: }\n294: \n295: /**\n296:  * Get all features that are ready to start (backlog + deps met).\n297:  */\n298: export function getReadyFeatures(data: FeaturesFile): Feature[] {\n299:   const doneIds = getDoneIds(data.features, data.archive);\n300:   return data.features.filter(\n301:     (f) =>\n302:       f.status === \"backlog\" &&\n303:       f.completion === 0 &&\n304:       areDependenciesMet(f, doneIds)\n305:   );\n306: }\n307: \n308: /**\n309:  * Get done IDs (exported for use in selection error messages).\n310:  */\n311: export function getDoneFeatureIds(data: FeaturesFile): Set<string> {\n312:   return getDoneIds(data.features, data.archive);\n313: }\n314: \n315: // ---------------------------------------------------------------------------\n316: // Selection Strategies\n317: // ---------------------------------------------------------------------------\n318: \n319: export interface SelectionOptions {\n320:   /** Select top N by priority (highest priority first, then lowest effort) */\n321:   topPriority?: number;\n322:   /** Select N quickest wins (lowest effort first) */\n323:   quickestWins?: number;\n324:   /** Select all features matching this priority level */\n325:   priority?: Priority;\n326:   /** Select all features matching this difficulty level */\n327:   difficulty?: Difficulty;\n328:   /** Select specific feature IDs (comma-separated) */\n329:   featureIds?: string[];\n330:   /** Select all ready features */\n331:   allReady?: boolean;\n332: }\n333: \n334: /**\n335:  * Select features based on the given strategy.\n336:  * Always filters to only ready features (backlog + deps met) first.\n337:  */\n338: export function selectFeatures(\n339:   data: FeaturesFile,\n340:   options: SelectionOptions\n341: ): Feature[] {\n342:   const ready = getReadyFeatures(data);\n343: \n344:   if (options.allReady) {\n345:     return sortByPriorityThenEffort(ready);\n346:   }\n347: \n348:   if (options.featureIds?.length) {\n349:     const idSet = new Set(options.featureIds);\n350:     const selected = ready.filter((f) => idSet.has(f.id));\n351:     const missing = options.featureIds.filter(\n352:       (id) => !selected.find((f) => f.id === id)\n353:     );\n354:     if (missing.length) {\n355:       const allIds = data.features.map((f) => f.id);\n356:       const doneIds = getDoneIds(data.features, data.archive);\n357:       for (const m of missing) {\n358:         if (!allIds.includes(m)) {\n359:           console.error(`  Feature \"${m}\" does not exist in the features file`);\n360:         } else {\n361:           const feat = data.features.find((f) => f.id === m)!;\n362:           console.error(\n363:             `  Feature \"${m}\" is not ready (status: ${feat.status}, deps met: ${areDependenciesMet(feat, doneIds)})`\n364:           );\n365:         }\n366:       }\n367:     }\n368:     return sortByPriorityThenEffort(selected);\n369:   }\n370: \n371:   if (options.priority) {\n372:     return sortByPriorityThenEffort(\n373:       ready.filter((f) => f.priority === options.priority)\n374:     );\n375:   }\n376: \n377:   if (options.difficulty) {\n378:     return sortByEffort(ready.filter((f) => f.difficulty === options.difficulty));\n379:   }\n380: \n381:   if (options.topPriority) {\n382:     return sortByPriorityThenEffort(ready).slice(0, options.topPriority);\n383:   }\n384: \n385:   if (options.quickestWins) {\n386:     return sortByEffort(ready).slice(0, options.quickestWins);\n387:   }\n388: \n389:   // Default: return all ready, sorted by priority\n390:   return sortByPriorityThenEffort(ready);\n391: }\n392: \n393: // ---------------------------------------------------------------------------\n394: // Sorting Helpers\n395: // ---------------------------------------------------------------------------\n396: \n397: function sortByPriorityThenEffort(features: Feature[]): Feature[] {\n398:   return [...features].sort((a, b) => {\n399:     const pDiff = PRIORITY_ORDER[a.priority] - PRIORITY_ORDER[b.priority];\n400:     if (pDiff !== 0) return pDiff;\n401:     return parseDurationMinutes(a.effort) - parseDurationMinutes(b.effort);\n402:   });\n403: }\n404: \n405: function sortByEffort(features: Feature[]): Feature[] {\n406:   return [...features].sort(\n407:     (a, b) => parseDurationMinutes(a.effort) - parseDurationMinutes(b.effort)\n408:   );\n409: }\n410: \n411: // ---------------------------------------------------------------------------\n412: // Utility Exports\n413: // ---------------------------------------------------------------------------\n414: \n415: export { PRIORITY_ORDER, DIFFICULTY_ORDER };\n416: \n417: /**\n418:  * Get a compact summary of a feature for display.\n419:  */\n420: export function featureSummary(f: Feature): string {\n421:   const effort = formatDuration(parseDurationMinutes(f.effort));\n422:   return `[${f.priority}/${f.difficulty}] ${f.id} -- ${f.title} (${effort})`;\n423: }\n424: \n425: /**\n426:  * Recursively search a list of features (and their subtasks) for a matching ID.\n427:  */\n428: function findInList(features: Feature[], id: string): Feature | undefined {\n429:   for (const f of features) {\n430:     if (f.id === id) return f;\n431:     if (f.subtasks?.length) {\n432:       const found = findInList(f.subtasks, id);\n433:       if (found) return found;\n434:     }\n435:   }\n436:   return undefined;\n437: }\n438: \n439: /**\n440:  * Find a feature or subtask by ID across active features, their subtasks\n441:  * (recursively), and the archive list.\n442:  */\n443: export function findFeatureById(\n444:   data: FeaturesFile,\n445:   id: string\n446: ): Feature | undefined {\n447:   return (\n448:     findInList(data.features, id) ??\n449:     (data.archive ? findInList(data.archive, id) : undefined)\n450:   );\n451: }\n452: \n453: /**\n454:  * Create a blank feature with all required fields initialized.\n455:  */\n456: export function createBlankFeature(\n457:   id: string,\n458:   title: string,\n459:   description: string = \"\",\n460:   opts?: {\n461:     priority?: Priority;\n462:     difficulty?: Difficulty;\n463:     effort?: string;\n464:   }\n465: ): Feature {\n466:   return {\n467:     id,\n468:     title,\n469:     description,\n470:     status: \"backlog\",\n471:     completion: 0,\n472:     difficulty: opts?.difficulty ?? \"medium\",\n473:     priority: opts?.priority ?? \"medium\",\n474:     depends_on: [],\n475:     effort: opts?.effort ?? \"PT1H\",\n476:     started_at: null,\n477:     ended_at: null,\n478:     constraints: [],\n479:     forbidden: [],\n480:     references: [],\n481:     notes: [],\n482:     subtasks: [],\n483:   };\n484: }\n485: \n486: /**\n487:  * Get all feature IDs (active + archive), useful for validation.\n488:  */\n489: export function allFeatureIds(data: FeaturesFile): string[] {\n490:   const ids: string[] = [];\n491:   const collect = (items: (Feature | Subtask)[]) => {\n492:     for (const item of items) {\n493:       ids.push(item.id);\n494:       if (item.subtasks?.length) collect(item.subtasks);\n495:     }\n496:   };\n497:   collect(data.features);\n498:   collect(data.archive ?? []);\n499:   return ids;\n500: }\n\n(End of file - total 500 lines)\n</content>","title":"src/lib/features.ts","metadata":{"preview":"/**\n * features.ts — Parse features YAML and provide feature selection/filtering.\n *\n * Responsibilities:\n *   - Load and parse the features file with full type safety\n *   - Parse ISO 8601 durations into comparable minutes\n *   - Filter features by status, priority, difficulty, dependency readiness\n *   - Select features by various strategies (top-priority, quickest-wins, etc.)\n *   - Resolve dependency graphs to determine which features are ready to start\n *   - Write-back capability for feature management commands\n */\n\nimport { readFileSync, writeFileSync, existsSync } from \"node:fs\";\nimport { resolve, dirname, join } from \"node:path\";\nimport { parse as parseYaml, stringify as stringifyYaml } from \"yaml\";\nimport { createInterface } from \"node:readline\";\nimport type { WomboConfig } from \"../config.js\";\n\n// ---------------------------------------------------------------------------\n// Template path (resolved relative to this source file)","truncated":false,"loaded":[]},"time":{"start":1773351519342,"end":1773351519349}}}}
{"type":"tool_use","timestamp":1773351519753,"sessionID":"ses_31c036c7affe6dPx3n8MQ9tKUs","part":{"id":"prt_ce3fcc4700017aOm2arNd9pukw","sessionID":"ses_31c036c7affe6dPx3n8MQ9tKUs","messageID":"msg_ce3fcb817001DlyAdg5mV5FZLE","type":"tool","callID":"toolu_vrtx_01NjdKscofpLQw6QvMn2JRMc","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-dependency-aware-sequencing/src/lib/launcher.ts"},"output":"<path>/home/fulgidus/Documents/wombo-dependency-aware-sequencing/src/lib/launcher.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * launcher.ts — Process spawning and tmux session management.\n3:  *\n4:  * Responsibilities:\n5:  *   - Launch agent in headless mode (agent run --format json)\n6:  *   - Launch agent in interactive mode (tmux session with TUI)\n7:  *   - Resume sessions for auto-retry\n8:  *   - Manage tmux sessions (create, list, kill)\n9:  */\n10: \n11: import { spawn, execSync, type ChildProcess } from \"node:child_process\";\n12: import { writeFileSync, unlinkSync } from \"node:fs\";\n13: import type { WomboConfig } from \"../config.js\";\n14: import { resolveAgentBin } from \"../config.js\";\n15: \n16: // ---------------------------------------------------------------------------\n17: // Types\n18: // ---------------------------------------------------------------------------\n19: \n20: export interface LaunchResult {\n21:   pid: number;\n22:   process: ChildProcess;\n23:   sessionId?: string;\n24: }\n25: \n26: export interface LaunchOptions {\n27:   worktreePath: string;\n28:   featureId: string;\n29:   prompt: string;\n30:   model?: string;\n31:   interactive?: boolean;\n32:   config: WomboConfig;\n33: }\n34: \n35: export interface RetryOptions {\n36:   worktreePath: string;\n37:   featureId: string;\n38:   sessionId: string;\n39:   buildErrors: string;\n40:   model?: string;\n41:   interactive?: boolean;\n42:   config: WomboConfig;\n43: }\n44: \n45: // ---------------------------------------------------------------------------\n46: // Helpers\n47: // ---------------------------------------------------------------------------\n48: \n49: function tmuxSessionName(featureId: string, config: WomboConfig): string {\n50:   return `${config.agent.tmuxPrefix}-${featureId}`;\n51: }\n52: \n53: function runSilent(cmd: string): string {\n54:   try {\n55:     return execSync(cmd, { encoding: \"utf-8\", stdio: \"pipe\" }).trim();\n56:   } catch {\n57:     return \"\";\n58:   }\n59: }\n60: \n61: // ---------------------------------------------------------------------------\n62: // Headless Launch\n63: // ---------------------------------------------------------------------------\n64: \n65: /**\n66:  * Launch agent in headless mode with JSON output.\n67:  */\n68: export function launchHeadless(opts: LaunchOptions): LaunchResult {\n69:   const agentBin = resolveAgentBin(opts.config);\n70: \n71:   const args = [\n72:     \"run\",\n73:     \"--format\", \"json\",\n74:     \"--agent\", opts.config.agent.name,\n75:     \"--dir\", opts.worktreePath,\n76:     \"--title\", `wombo: ${opts.featureId}`,\n77:   ];\n78: \n79:   if (opts.model) {\n80:     args.push(\"--model\", opts.model);\n81:   }\n82: \n83:   args.push(opts.prompt);\n84: \n85:   const child = spawn(agentBin, args, {\n86:     stdio: [\"pipe\", \"pipe\", \"pipe\"],\n87:     detached: false,\n88:     env: {\n89:       ...process.env,\n90:       OPENCODE_DIR: opts.worktreePath,\n91:     },\n92:   });\n93: \n94:   // Close stdin so agent starts processing immediately\n95:   child.stdin?.end();\n96: \n97:   return {\n98:     pid: child.pid!,\n99:     process: child,\n100:   };\n101: }\n102: \n103: /**\n104:  * Resume a headless session with a retry message (build errors).\n105:  */\n106: export function retryHeadless(opts: RetryOptions): LaunchResult {\n107:   const agentBin = resolveAgentBin(opts.config);\n108: \n109:   const retryMessage = `The build failed. Please fix the following errors and run \\`${opts.config.build.command}\\` again:\\n\\n\\`\\`\\`\\n${opts.buildErrors}\\n\\`\\`\\`\\n\\nFix all errors, then verify the build passes.`;\n110: \n111:   const args = [\n112:     \"run\",\n113:     \"--format\", \"json\",\n114:     \"--session\", opts.sessionId,\n115:     \"--continue\",\n116:     \"--dir\", opts.worktreePath,\n117:   ];\n118: \n119:   if (opts.model) {\n120:     args.push(\"--model\", opts.model);\n121:   }\n122: \n123:   args.push(retryMessage);\n124: \n125:   const child = spawn(agentBin, args, {\n126:     stdio: [\"pipe\", \"pipe\", \"pipe\"],\n127:     detached: false,\n128:     env: {\n129:       ...process.env,\n130:       OPENCODE_DIR: opts.worktreePath,\n131:     },\n132:   });\n133: \n134:   child.stdin?.end();\n135: \n136:   return {\n137:     pid: child.pid!,\n138:     process: child,\n139:   };\n140: }\n141: \n142: // ---------------------------------------------------------------------------\n143: // Conflict Resolution Launch\n144: // ---------------------------------------------------------------------------\n145: \n146: export interface ConflictResolverOptions {\n147:   worktreePath: string;\n148:   featureId: string;\n149:   prompt: string;\n150:   model?: string;\n151:   config: WomboConfig;\n152: }\n153: \n154: /**\n155:  * Launch a headless agent to resolve merge conflicts.\n156:  *\n157:  * This is similar to `launchHeadless`, but the prompt is a conflict-resolution\n158:  * prompt generated by `generateConflictResolutionPrompt()`. The agent runs in\n159:  * the feature worktree where `git merge <baseBranch>` has already been run,\n160:  * leaving conflict markers in the working tree.\n161:  */\n162: export function launchConflictResolver(opts: ConflictResolverOptions): LaunchResult {\n163:   const agentBin = resolveAgentBin(opts.config);\n164: \n165:   const args = [\n166:     \"run\",\n167:     \"--format\", \"json\",\n168:     \"--agent\", opts.config.agent.name,\n169:     \"--dir\", opts.worktreePath,\n170:     \"--title\", `wombo: conflict-resolve ${opts.featureId}`,\n171:   ];\n172: \n173:   if (opts.model) {\n174:     args.push(\"--model\", opts.model);\n175:   }\n176: \n177:   args.push(opts.prompt);\n178: \n179:   const child = spawn(agentBin, args, {\n180:     stdio: [\"pipe\", \"pipe\", \"pipe\"],\n181:     detached: false,\n182:     env: {\n183:       ...process.env,\n184:       OPENCODE_DIR: opts.worktreePath,\n185:     },\n186:   });\n187: \n188:   child.stdin?.end();\n189: \n190:   return {\n191:     pid: child.pid!,\n192:     process: child,\n193:   };\n194: }\n195: \n196: // ---------------------------------------------------------------------------\n197: // Interactive (tmux) Launch\n198: // ---------------------------------------------------------------------------\n199: \n200: /**\n201:  * Launch agent in a tmux session for interactive use.\n202:  */\n203: export function launchInteractive(opts: LaunchOptions): LaunchResult {\n204:   const agentBin = resolveAgentBin(opts.config);\n205:   const sessionName = tmuxSessionName(opts.featureId, opts.config);\n206: \n207:   // Kill existing session if any\n208:   killTmuxSession(opts.featureId, opts.config);\n209: \n210:   // Build the agent command to run inside tmux\n211:   const ocArgs = [\n212:     agentBin,\n213:     \"--dir\", JSON.stringify(opts.worktreePath),\n214:   ];\n215: \n216:   if (opts.model) {\n217:     ocArgs.push(\"--model\", JSON.stringify(opts.model));\n218:   }\n219: \n220:   const tmuxCmd = ocArgs.join(\" \");\n221: \n222:   // Create a detached tmux session running the agent\n223:   execSync(\n224:     `tmux new-session -d -s \"${sessionName}\" -c \"${opts.worktreePath}\" \"${tmuxCmd}\"`,\n225:     { stdio: \"pipe\" }\n226:   );\n227: \n228:   // Send the prompt as initial message after a brief delay\n229:   setTimeout(() => {\n230:     try {\n231:       const tmpFile = `/tmp/wombo-prompt-${opts.featureId}.txt`;\n232:       writeFileSync(tmpFile, opts.prompt);\n233:       execSync(`tmux load-buffer \"${tmpFile}\"`, { stdio: \"pipe\" });\n234:       execSync(`tmux paste-buffer -t \"${sessionName}\"`, { stdio: \"pipe\" });\n235:       execSync(`tmux send-keys -t \"${sessionName}\" Enter`, { stdio: \"pipe\" });\n236:       try { unlinkSync(tmpFile); } catch {}\n237:     } catch {\n238:       // If prompt sending fails, user can type manually\n239:     }\n240:   }, 3000);\n241: \n242:   // Get the PID of the tmux server pane process\n243:   const panePid = runSilent(\n244:     `tmux list-panes -t \"${sessionName}\" -F \"#{pane_pid}\"`\n245:   );\n246: \n247:   return {\n248:     pid: parseInt(panePid) || 0,\n249:     process: null as any, // No direct process handle in tmux mode\n250:   };\n251: }\n252: \n253: /**\n254:  * Resume an interactive session with retry message.\n255:  */\n256: export function retryInteractive(opts: RetryOptions): LaunchResult {\n257:   const sessionName = tmuxSessionName(opts.featureId, opts.config);\n258: \n259:   const exists = tmuxSessionExists(opts.featureId, opts.config);\n260: \n261:   if (exists) {\n262:     const retryMsg = `The build failed. Fix these errors:\\n${opts.buildErrors}`;\n263:     const tmpFile = `/tmp/wombo-retry-${opts.featureId}.txt`;\n264:     writeFileSync(tmpFile, retryMsg);\n265:     execSync(`tmux load-buffer \"${tmpFile}\"`, { stdio: \"pipe\" });\n266:     execSync(`tmux paste-buffer -t \"${sessionName}\"`, { stdio: \"pipe\" });\n267:     execSync(`tmux send-keys -t \"${sessionName}\" Enter`, { stdio: \"pipe\" });\n268:     try { unlinkSync(tmpFile); } catch {}\n269: \n270:     const panePid = runSilent(\n271:       `tmux list-panes -t \"${sessionName}\" -F \"#{pane_pid}\"`\n272:     );\n273: \n274:     return {\n275:       pid: parseInt(panePid) || 0,\n276:       process: null as any,\n277:     };\n278:   }\n279: \n280:   // Session doesn't exist — launch a new interactive session\n281:   return launchInteractive({\n282:     worktreePath: opts.worktreePath,\n283:     featureId: opts.featureId,\n284:     prompt: `Continue from session ${opts.sessionId}. The build failed:\\n${opts.buildErrors}\\n\\nFix all errors and verify the build passes.`,\n285:     model: opts.model,\n286:     interactive: true,\n287:     config: opts.config,\n288:   });\n289: }\n290: \n291: // ---------------------------------------------------------------------------\n292: // tmux Session Management\n293: // ---------------------------------------------------------------------------\n294: \n295: /**\n296:  * Check if a tmux session exists for a feature.\n297:  */\n298: export function tmuxSessionExists(\n299:   featureId: string,\n300:   config: WomboConfig\n301: ): boolean {\n302:   const sessionName = tmuxSessionName(featureId, config);\n303:   return runSilent(`tmux has-session -t \"${sessionName}\" 2>/dev/null && echo yes`) === \"yes\";\n304: }\n305: \n306: /**\n307:  * Kill a tmux session for a feature.\n308:  */\n309: export function killTmuxSession(\n310:   featureId: string,\n311:   config: WomboConfig\n312: ): void {\n313:   const sessionName = tmuxSessionName(featureId, config);\n314:   runSilent(`tmux kill-session -t \"${sessionName}\" 2>/dev/null`);\n315: }\n316: \n317: /**\n318:  * List all wombo-related tmux sessions.\n319:  */\n320: export function listTmuxSessions(config: WomboConfig): string[] {\n321:   const output = runSilent(\n322:     `tmux list-sessions -F \"#{session_name}\" 2>/dev/null`\n323:   );\n324:   if (!output) return [];\n325:   return output\n326:     .split(\"\\n\")\n327:     .filter((s) => s.startsWith(config.agent.tmuxPrefix + \"-\"));\n328: }\n329: \n330: /**\n331:  * Kill all wombo-related tmux sessions.\n332:  */\n333: export function killAllTmuxSessions(config: WomboConfig): number {\n334:   const sessions = listTmuxSessions(config);\n335:   for (const s of sessions) {\n336:     runSilent(`tmux kill-session -t \"${s}\" 2>/dev/null`);\n337:   }\n338:   return sessions.length;\n339: }\n340: \n341: /**\n342:  * Check if a process is still running by PID.\n343:  */\n344: export function isProcessRunning(pid: number): boolean {\n345:   if (!pid || pid <= 0) return false;\n346:   try {\n347:     process.kill(pid, 0);\n348:     return true;\n349:   } catch {\n350:     return false;\n351:   }\n352: }\n\n(End of file - total 352 lines)\n</content>","title":"src/lib/launcher.ts","metadata":{"preview":"/**\n * launcher.ts — Process spawning and tmux session management.\n *\n * Responsibilities:\n *   - Launch agent in headless mode (agent run --format json)\n *   - Launch agent in interactive mode (tmux session with TUI)\n *   - Resume sessions for auto-retry\n *   - Manage tmux sessions (create, list, kill)\n */\n\nimport { spawn, execSync, type ChildProcess } from \"node:child_process\";\nimport { writeFileSync, unlinkSync } from \"node:fs\";\nimport type { WomboConfig } from \"../config.js\";\nimport { resolveAgentBin } from \"../config.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface LaunchResult {","truncated":false,"loaded":[]},"time":{"start":1773351519748,"end":1773351519752}}}}
{"type":"tool_use","timestamp":1773351520374,"sessionID":"ses_31c036c7affe6dPx3n8MQ9tKUs","part":{"id":"prt_ce3fcc66e001sTECQ3vx1DWNNh","sessionID":"ses_31c036c7affe6dPx3n8MQ9tKUs","messageID":"msg_ce3fcb817001DlyAdg5mV5FZLE","type":"tool","callID":"toolu_vrtx_011LfsuUgxB7qZ6N22KrHVZt","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-dependency-aware-sequencing/src/commands/launch.ts"},"output":"<path>/home/fulgidus/Documents/wombo-dependency-aware-sequencing/src/commands/launch.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * launch.ts — Launch a wave of agents.\n3:  *\n4:  * Usage: wombo launch [selection options] [launch options]\n5:  *\n6:  * This is the primary entry point for starting a new wave. It selects features\n7:  * from the features file, creates a wave state, sets up worktrees, and launches\n8:  * agent processes (either headless or interactive via tmux).\n9:  *\n10:  * IMPORTANT: This file also exports shared helper functions that are reused\n11:  * by resume.ts and other commands:\n12:  *   - launchSingleHeadless\n13:  *   - handleBuildVerification\n14:  *   - handleRetry\n15:  *   - launchNextQueued\n16:  */\n17: \n18: import { execSync } from \"node:child_process\";\n19: import type { WomboConfig } from \"../config.js\";\n20: import type { Feature, SelectionOptions, Priority, Difficulty } from \"../lib/features.js\";\n21: import { loadFeatures, selectFeatures, parseDurationMinutes, saveFeatures } from \"../lib/features.js\";\n22: import {\n23:   loadState,\n24:   saveState,\n25:   createWaveState,\n26:   createAgentState,\n27:   updateAgent,\n28:   activeAgents,\n29:   queuedAgents,\n30:   isWaveComplete,\n31:   type WaveState,\n32:   type AgentState,\n33: } from \"../lib/state.js\";\n34: import {\n35:   createWorktree,\n36:   installDeps,\n37:   featureBranchName,\n38:   worktreePath,\n39:   worktreeReady,\n40:   branchHasChanges,\n41:   removeWorktree,\n42:   log as wtLog,\n43: } from \"../lib/worktree.js\";\n44: import { generatePrompt, generateConflictResolutionPrompt } from \"../lib/prompt.js\";\n45: import {\n46:   launchHeadless,\n47:   retryHeadless,\n48:   launchInteractive,\n49:   retryInteractive,\n50:   launchConflictResolver,\n51:   isProcessRunning,\n52: } from \"../lib/launcher.js\";\n53: import { ProcessMonitor } from \"../lib/monitor.js\";\n54: import { runBuild } from \"../lib/verifier.js\";\n55: import { mergeBranch, mergeBaseIntoFeature, pushBaseBranch } from \"../lib/merger.js\";\n56: import {\n57:   printDashboard,\n58:   printFeatureSelection,\n59:   printAgentUpdate,\n60: } from \"../lib/ui.js\";\n61: import { WomboTUI } from \"../lib/tui.js\";\n62: import { ensureAgentDefinition } from \"../lib/templates.js\";\n63: \n64: // ---------------------------------------------------------------------------\n65: // Types\n66: // ---------------------------------------------------------------------------\n67: \n68: export interface LaunchCommandOptions {\n69:   projectRoot: string;\n70:   config: WomboConfig;\n71:   // Selection\n72:   topPriority?: number;\n73:   quickestWins?: number;\n74:   priority?: Priority;\n75:   difficulty?: Difficulty;\n76:   features?: string[];\n77:   allReady?: boolean;\n78:   // Launch\n79:   maxConcurrent: number;\n80:   model?: string;\n81:   interactive: boolean;\n82:   dryRun: boolean;\n83:   baseBranch: string;\n84:   maxRetries: number;\n85:   noTui: boolean;\n86:   autoPush: boolean;\n87: }\n88: \n89: // ---------------------------------------------------------------------------\n90: // Shared Helpers (exported for resume.ts and others)\n91: // ---------------------------------------------------------------------------\n92: \n93: /**\n94:  * Mark a feature as done in the features file after a successful merge.\n95:  * Updates status to \"done\", completion to 100, and sets ended_at.\n96:  *\n97:  * GUARD: Verifies that the feature branch has actually been merged into\n98:  * baseBranch before allowing the status change. This prevents callers\n99:  * from accidentally marking verified-but-unmerged features as done.\n100:  */\n101: export function markFeatureDone(\n102:   projectRoot: string,\n103:   featureId: string,\n104:   config: WomboConfig,\n105:   baseBranch: string\n106: ): void {\n107:   try {\n108:     // Verify the feature branch was actually merged into base\n109:     const branch = featureBranchName(featureId, config);\n110:     try {\n111:       execSync(`git merge-base --is-ancestor \"${branch}\" \"${baseBranch}\"`, {\n112:         cwd: projectRoot,\n113:         stdio: \"pipe\",\n114:       });\n115:     } catch {\n116:       // git merge-base --is-ancestor exits non-zero if NOT an ancestor\n117:       console.error(\n118:         `Warning: ${featureId} branch \"${branch}\" is not merged into \"${baseBranch}\" — refusing to mark as done`\n119:       );\n120:       return;\n121:     }\n122: \n123:     const data = loadFeatures(projectRoot, config);\n124:     const feature = data.features.find((f) => f.id === featureId);\n125:     if (feature && feature.status !== \"done\") {\n126:       feature.status = \"done\";\n127:       feature.completion = 100;\n128:       feature.ended_at = new Date().toISOString();\n129:       saveFeatures(projectRoot, config, data);\n130:     }\n131:   } catch (err: any) {\n132:     // Non-fatal — log but don't crash the wave\n133:     console.error(`Warning: failed to update feature status for ${featureId}: ${err.message}`);\n134:   }\n135: }\n136: \n137: /**\n138:  * Launch a single agent in headless mode.\n139:  * Sets up worktree, installs deps, generates prompt, launches agent process.\n140:  */\n141: export async function launchSingleHeadless(\n142:   projectRoot: string,\n143:   state: WaveState,\n144:   agent: AgentState,\n145:   feature: Feature,\n146:   monitor: ProcessMonitor,\n147:   config: WomboConfig,\n148:   model?: string\n149: ): Promise<void> {\n150:   updateAgent(state, agent.feature_id, {\n151:     status: \"installing\",\n152:     started_at: new Date().toISOString(),\n153:     activity: \"setting up worktree...\",\n154:   });\n155:   saveState(projectRoot, state);\n156: \n157:   try {\n158:     // Skip worktree setup if already ready (resume case)\n159:     if (worktreeReady(agent.worktree)) {\n160:       wtLog(agent.feature_id, \"worktree already exists, skipping setup\");\n161:     } else {\n162:       // Create worktree (async — doesn't block other agents)\n163:       await createWorktree(projectRoot, feature.id, state.base_branch, config);\n164: \n165:       // Install dependencies (async)\n166:       updateAgent(state, agent.feature_id, { activity: \"installing deps...\" });\n167:       await installDeps(agent.worktree, feature.id, config);\n168:     }\n169: \n170:     // Generate prompt\n171:     const prompt = generatePrompt(feature, state.base_branch, config);\n172: \n173:     // Launch agent\n174:     wtLog(agent.feature_id, \"launching agent...\");\n175:     const result = launchHeadless({\n176:       worktreePath: agent.worktree,\n177:       featureId: feature.id,\n178:       prompt,\n179:       model,\n180:       config,\n181:     });\n182: \n183:     updateAgent(state, agent.feature_id, {\n184:       status: \"running\",\n185:       pid: result.pid,\n186:       activity: \"starting...\",\n187:     });\n188:     saveState(projectRoot, state);\n189: \n190:     monitor.addProcess(feature.id, result.process);\n191:     wtLog(agent.feature_id, `running (PID: ${result.pid})`);\n192:   } catch (err: any) {\n193:     updateAgent(state, agent.feature_id, {\n194:       status: \"failed\",\n195:       error: err.message,\n196:       activity: null,\n197:       completed_at: new Date().toISOString(),\n198:     });\n199:     saveState(projectRoot, state);\n200:     wtLog(agent.feature_id, `SETUP FAILED: ${err.message.split(\"\\n\")[0]}`);\n201:   }\n202: }\n203: \n204: /**\n205:  * Handle build verification after agent completion.\n206:  * Runs build, auto-merges on pass, retries on failure if retries remain.\n207:  *\n208:  * ASYNC — runs build and merge without blocking the event loop.\n209:  */\n210: export async function handleBuildVerification(\n211:   projectRoot: string,\n212:   state: WaveState,\n213:   agent: AgentState,\n214:   feature: Feature,\n215:   config: WomboConfig,\n216:   model?: string,\n217:   monitor?: ProcessMonitor\n218: ): Promise<void> {\n219:   try {\n220:     printAgentUpdate(agent, \"verifying build...\");\n221: \n222:     const buildResult = await runBuild(agent.worktree, config);\n223: \n224:     if (buildResult.passed) {\n225:       updateAgent(state, agent.feature_id, {\n226:         status: \"verified\",\n227:         build_passed: true,\n228:         build_output: null,\n229:       });\n230:       saveState(projectRoot, state);\n231:       printAgentUpdate(agent, `BUILD PASSED (${Math.round(buildResult.durationMs / 1000)}s)`);\n232: \n233:       // Auto-merge: attempt merge + conflict resolution\n234:       await attemptMerge(projectRoot, state, agent, feature, config, model);\n235:     } else {\n236:       if (agent.retries < agent.max_retries) {\n237:         updateAgent(state, agent.feature_id, {\n238:           status: \"retry\",\n239:           retries: agent.retries + 1,\n240:           build_passed: false,\n241:           build_output: buildResult.errorSummary,\n242:         });\n243:         saveState(projectRoot, state);\n244:         printAgentUpdate(\n245:           agent,\n246:           `BUILD FAILED — retrying (${agent.retries}/${agent.max_retries})`\n247:         );\n248: \n249:         // Retry with build errors\n250:         if (agent.session_id) {\n251:           const retryResult = retryHeadless({\n252:             worktreePath: agent.worktree,\n253:             featureId: agent.feature_id,\n254:             sessionId: agent.session_id,\n255:             buildErrors: buildResult.errorSummary,\n256:             model,\n257:             config,\n258:           });\n259: \n260:           updateAgent(state, agent.feature_id, {\n261:             status: \"running\",\n262:             pid: retryResult.pid,\n263:           });\n264:           saveState(projectRoot, state);\n265: \n266:           // Add retry process to monitor so events are tracked\n267:           if (monitor) {\n268:             monitor.addProcess(agent.feature_id, retryResult.process);\n269:           }\n270:         }\n271:       } else {\n272:         updateAgent(state, agent.feature_id, {\n273:           status: \"failed\",\n274:           build_passed: false,\n275:           build_output: buildResult.errorSummary,\n276:           error: `Build failed after ${agent.max_retries} retries`,\n277:           completed_at: new Date().toISOString(),\n278:         });\n279:         saveState(projectRoot, state);\n280:         printAgentUpdate(agent, \"BUILD FAILED — max retries reached\");\n281:       }\n282:     }\n283:   } catch (err: any) {\n284:     // Catch-all — never let build verification crash the process\n285:     printAgentUpdate(agent, `VERIFY ERROR: ${err.message?.slice(0, 100)}`);\n286:     updateAgent(state, agent.feature_id, {\n287:       status: \"failed\",\n288:       error: `Build verification error: ${err.message}`,\n289:       completed_at: new Date().toISOString(),\n290:     });\n291:     saveState(projectRoot, state);\n292:   }\n293: }\n294: \n295: /**\n296:  * Attempt to merge a verified agent's branch into the base branch.\n297:  *\n298:  * Handles conflict detection, base-into-feature merge, and resolver agent\n299:  * launch. Extracted from handleBuildVerification so it can be called\n300:  * independently (e.g., from resume's sequential merge phase).\n301:  */\n302: export async function attemptMerge(\n303:   projectRoot: string,\n304:   state: WaveState,\n305:   agent: AgentState,\n306:   feature: Feature,\n307:   config: WomboConfig,\n308:   model?: string,\n309: ): Promise<void> {\n310:   printAgentUpdate(agent, \"auto-merging...\");\n311:   try {\n312:     const mergeResult = await mergeBranch(projectRoot, agent.branch, state.base_branch, config);\n313: \n314:     if (mergeResult.success) {\n315:       updateAgent(state, agent.feature_id, {\n316:         status: \"merged\",\n317:         completed_at: new Date().toISOString(),\n318:       });\n319:       saveState(projectRoot, state);\n320:       printAgentUpdate(agent, `MERGED (${mergeResult.commitHash?.slice(0, 7)})`);\n321: \n322:       // Mark feature as done in .features.yml so it won't be re-selected\n323:       markFeatureDone(projectRoot, agent.feature_id, config, state.base_branch);\n324: \n325:       // Clean up worktree after successful merge\n326:       try {\n327:         removeWorktree(projectRoot, agent.worktree, true);\n328:         printAgentUpdate(agent, \"worktree and branch removed\");\n329:       } catch {\n330:         // Not critical — worktree cleanup is best-effort\n331:       }\n332:     } else {\n333:       // Merge failed — attempt automatic conflict resolution\n334:       const mergeError = mergeResult.error ?? \"Unknown merge error\";\n335:       printAgentUpdate(agent, `MERGE CONFLICT — attempting resolution...`);\n336: \n337:       try {\n338:         // Merge base INTO the feature worktree to create conflict markers\n339:         const conflictResult = await mergeBaseIntoFeature(\n340:           agent.worktree,\n341:           state.base_branch,\n342:           config\n343:         );\n344: \n345:         if (conflictResult.error && !conflictResult.conflicting) {\n346:           printAgentUpdate(agent, `CONFLICT SETUP FAILED: ${conflictResult.error.slice(0, 100)}`);\n347:           return; // Leave as \"verified\" for manual resolution\n348:         }\n349: \n350:         if (!conflictResult.conflicting) {\n351:           // Base merged cleanly into feature — retry merge into base.\n352:           printAgentUpdate(agent, \"base merged cleanly into feature — retrying merge...\");\n353:           const retryMerge = await mergeBranch(projectRoot, agent.branch, state.base_branch, config);\n354:           if (retryMerge.success) {\n355:             updateAgent(state, agent.feature_id, {\n356:               status: \"merged\",\n357:               completed_at: new Date().toISOString(),\n358:             });\n359:             saveState(projectRoot, state);\n360:             printAgentUpdate(agent, `MERGED after rebase (${retryMerge.commitHash?.slice(0, 7)})`);\n361:             markFeatureDone(projectRoot, agent.feature_id, config, state.base_branch);\n362:             try {\n363:               removeWorktree(projectRoot, agent.worktree, true);\n364:             } catch {}\n365:             return;\n366:           }\n367: \n368:           // Retry still failed — launch resolver agent\n369:           printAgentUpdate(agent, `retry merge still failed — launching resolver agent...`);\n370: \n371:           const secondConflict = await mergeBaseIntoFeature(\n372:             agent.worktree,\n373:             state.base_branch,\n374:             config\n375:           );\n376: \n377:           const conflictFiles = secondConflict.conflicting\n378:             ? secondConflict.files\n379:             : [\"(unknown — merge direction mismatch)\"];\n380:           const resolverMergeError = retryMerge.error ?? mergeError;\n381: \n382:           await launchResolverAndRetryMerge(\n383:             projectRoot, state, agent, feature, config, model,\n384:             resolverMergeError, conflictFiles\n385:           );\n386:           return;\n387:         }\n388: \n389:         // There are real conflicts — launch a resolver agent\n390:         printAgentUpdate(\n391:           agent,\n392:           `${conflictResult.files.length} conflicting file(s): ${conflictResult.files.join(\", \")}`\n393:         );\n394: \n395:         await launchResolverAndRetryMerge(\n396:           projectRoot, state, agent, feature, config, model,\n397:           mergeError, conflictResult.files\n398:         );\n399:       } catch (conflictErr: any) {\n400:         printAgentUpdate(agent, `CONFLICT RESOLUTION ERROR: ${conflictErr.message?.slice(0, 100)}`);\n401:         // Leave as \"verified\" for manual resolution\n402:       }\n403:     }\n404:   } catch (mergeErr: any) {\n405:     printAgentUpdate(agent, `AUTO-MERGE ERROR: ${mergeErr.message?.slice(0, 100)}`);\n406:   }\n407: }\n408: \n409: /**\n410:  * Launch a conflict resolver agent, wait for it to finish, re-verify build,\n411:  * and retry the merge. Extracted to avoid duplicating the resolver flow.\n412:  */\n413: async function launchResolverAndRetryMerge(\n414:   projectRoot: string,\n415:   state: WaveState,\n416:   agent: AgentState,\n417:   feature: Feature,\n418:   config: WomboConfig,\n419:   model: string | undefined,\n420:   mergeError: string,\n421:   conflictFiles: string[]\n422: ): Promise<void> {\n423:   const conflictPrompt = generateConflictResolutionPrompt(\n424:     feature,\n425:     state.base_branch,\n426:     mergeError,\n427:     config\n428:   );\n429: \n430:   updateAgent(state, agent.feature_id, {\n431:     status: \"resolving_conflict\",\n432:     activity: `resolving ${conflictFiles.length} conflict(s)...`,\n433:   });\n434:   saveState(projectRoot, state);\n435: \n436:   const resolverResult = launchConflictResolver({\n437:     worktreePath: agent.worktree,\n438:     featureId: agent.feature_id,\n439:     prompt: conflictPrompt,\n440:     model,\n441:     config,\n442:   });\n443: \n444:   updateAgent(state, agent.feature_id, {\n445:     pid: resolverResult.pid,\n446:   });\n447:   saveState(projectRoot, state);\n448: \n449:   // Wait for the resolver process to complete, then re-verify and retry merge.\n450:   // We intentionally do NOT add the resolver to the ProcessMonitor because\n451:   // the monitor's onComplete callback would trigger handleBuildVerification\n452:   // again, causing infinite recursion. Instead we await the process directly.\n453:   const resolverExitCode = await new Promise<number | null>((resolve) => {\n454:     resolverResult.process.on(\"exit\", (code) => resolve(code));\n455:     resolverResult.process.on(\"error\", () => resolve(null));\n456:   });\n457: \n458:   printAgentUpdate(agent, `conflict resolver exited (code ${resolverExitCode}) — re-verifying build...`);\n459: \n460:   // Re-verify build after conflict resolution\n461:   const rebuildResult = await runBuild(agent.worktree, config);\n462: \n463:   if (!rebuildResult.passed) {\n464:     printAgentUpdate(agent, `POST-CONFLICT BUILD FAILED`);\n465:     updateAgent(state, agent.feature_id, {\n466:       status: \"failed\",\n467:       build_passed: false,\n468:       build_output: rebuildResult.errorSummary,\n469:       error: \"Build failed after conflict resolution\",\n470:       completed_at: new Date().toISOString(),\n471:     });\n472:     saveState(projectRoot, state);\n473:     return;\n474:   }\n475: \n476:   printAgentUpdate(agent, \"post-conflict build passed — retrying merge...\");\n477: \n478:   const retryMerge = await mergeBranch(\n479:     projectRoot,\n480:     agent.branch,\n481:     state.base_branch,\n482:     config\n483:   );\n484: \n485:   if (retryMerge.success) {\n486:     updateAgent(state, agent.feature_id, {\n487:       status: \"merged\",\n488:       build_passed: true,\n489:       completed_at: new Date().toISOString(),\n490:     });\n491:     saveState(projectRoot, state);\n492:     printAgentUpdate(agent, `MERGED after conflict resolution (${retryMerge.commitHash?.slice(0, 7)})`);\n493:     markFeatureDone(projectRoot, agent.feature_id, config, state.base_branch);\n494:     try {\n495:       removeWorktree(projectRoot, agent.worktree, true);\n496:     } catch {}\n497:   } else {\n498:     printAgentUpdate(agent, `POST-CONFLICT MERGE FAILED: ${retryMerge.error}`);\n499:     updateAgent(state, agent.feature_id, {\n500:       status: \"failed\",\n501:       error: `Merge still failed after conflict resolution: ${retryMerge.error}`,\n502:       completed_at: new Date().toISOString(),\n503:     });\n504:     saveState(projectRoot, state);\n505:   }\n506: }\n507: \n508: /**\n509:  * Handle retry of a failed agent (error-based, not build-based).\n510:  */\n511: export function handleRetry(\n512:   projectRoot: string,\n513:   state: WaveState,\n514:   agent: AgentState,\n515:   monitor: ProcessMonitor,\n516:   config: WomboConfig,\n517:   model?: string\n518: ): void {\n519:   if (!agent.session_id || !agent.error) return;\n520: \n521:   const retryResult = retryHeadless({\n522:     worktreePath: agent.worktree,\n523:     featureId: agent.feature_id,\n524:     sessionId: agent.session_id,\n525:     buildErrors: agent.error,\n526:     model,\n527:     config,\n528:   });\n529: \n530:   updateAgent(state, agent.feature_id, {\n531:     status: \"running\",\n532:     pid: retryResult.pid,\n533:   });\n534:   saveState(projectRoot, state);\n535: \n536:   monitor.addProcess(agent.feature_id, retryResult.process);\n537: }\n538: \n539: /**\n540:  * Launch the next queued agent if capacity allows.\n541:  */\n542: export function launchNextQueued(\n543:   projectRoot: string,\n544:   state: WaveState,\n545:   featureMap: Map<string, Feature>,\n546:   monitor: ProcessMonitor,\n547:   config: WomboConfig,\n548:   model?: string\n549: ): void {\n550:   const active = activeAgents(state);\n551:   const queued = queuedAgents(state);\n552: \n553:   if (active.length < state.max_concurrent && queued.length > 0) {\n554:     const next = queued[0];\n555:     const feature = featureMap.get(next.feature_id);\n556:     if (feature) {\n557:       launchSingleHeadless(projectRoot, state, next, feature, monitor, config, model);\n558:     }\n559:   }\n560: }\n561: \n562: // ---------------------------------------------------------------------------\n563: // Headless Wave Launch\n564: // ---------------------------------------------------------------------------\n565: \n566: async function launchWaveHeadless(\n567:   projectRoot: string,\n568:   state: WaveState,\n569:   features: Feature[],\n570:   opts: LaunchCommandOptions\n571: ): Promise<void> {\n572:   const { config, model } = opts;\n573:   const featureMap = new Map(features.map((f) => [f.id, f]));\n574: \n575:   const monitor = new ProcessMonitor(projectRoot, {\n576:     onSessionId: (featureId, sessionId) => {\n577:       updateAgent(state, featureId, { session_id: sessionId });\n578:       saveState(projectRoot, state);\n579:     },\n580:     onComplete: (featureId) => {\n581:       updateAgent(state, featureId, {\n582:         status: \"completed\",\n583:         completed_at: new Date().toISOString(),\n584:       });\n585:       saveState(projectRoot, state);\n586: \n587:       // Run build verification — fire-and-forget\n588:       const agent = state.agents.find((a) => a.feature_id === featureId)!;\n589:       handleBuildVerification(projectRoot, state, agent, featureMap.get(featureId)!, config, model, monitor)\n590:         .then(() => launchNextQueued(projectRoot, state, featureMap, monitor, config, model))\n591:         .catch((err) => {\n592:           wtLog(featureId, `BUILD VERIFICATION UNHANDLED ERROR: ${err.message}`);\n593:           launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n594:         });\n595:     },\n596:     onError: (featureId, error) => {\n597:       const agent = state.agents.find((a) => a.feature_id === featureId)!;\n598:       if (agent.retries < agent.max_retries) {\n599:         updateAgent(state, featureId, {\n600:           status: \"retry\",\n601:           retries: agent.retries + 1,\n602:           error,\n603:         });\n604:         saveState(projectRoot, state);\n605: \n606:         // Retry\n607:         handleRetry(projectRoot, state, agent, monitor, config, model);\n608:       } else {\n609:         updateAgent(state, featureId, {\n610:           status: \"failed\",\n611:           error,\n612:           completed_at: new Date().toISOString(),\n613:         });\n614:         saveState(projectRoot, state);\n615:       }\n616: \n617:       // Try to launch next queued agent\n618:       launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n619:     },\n620:     onOutput: (_featureId, _data) => {\n621:       // Raw output — logged to file by ProcessMonitor\n622:     },\n623:     onActivity: (featureId, activity) => {\n624:       updateAgent(state, featureId, {\n625:         activity,\n626:         activity_updated_at: new Date().toISOString(),\n627:       });\n628:       // Don't save to disk on every activity — too frequent.\n629:     },\n630:   });\n631: \n632:   // Create the TUI — it will auto-refresh and show activity from the monitor\n633:   const tuiRef = { current: null as WomboTUI | null };\n634:   const startTUI = () => {\n635:     tuiRef.current = new WomboTUI({\n636:       state,\n637:       monitor,\n638:       projectRoot,\n639:       interactive: false,\n640:       config,\n641:       onQuit: () => {\n642:         // Same as SIGINT — save state and exit\n643:         for (const agent of state.agents) {\n644:           if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n645:             updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n646:           }\n647:         }\n648:         monitor.killAll();\n649:         saveState(projectRoot, state);\n650:         console.log(\"State saved. Use 'wombo resume' to continue.\");\n651:         process.exit(0);\n652:       },\n653:     });\n654:     tuiRef.current.start();\n655:   };\n656: \n657:   // Handle graceful shutdown\n658:   process.on(\"SIGINT\", () => {\n659:     if (tuiRef.current) tuiRef.current.stop();\n660:     for (const agent of state.agents) {\n661:       if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n662:         updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n663:       }\n664:     }\n665:     monitor.killAll();\n666:     saveState(projectRoot, state);\n667:     console.log(\"\\nState saved. Use 'wombo resume' to continue.\");\n668:     process.exit(0);\n669:   });\n670: \n671:   // Launch initial batch — set up worktrees in parallel\n672:   const tolaunch = queuedAgents(state).slice(0, opts.maxConcurrent);\n673:   console.log(`Setting up ${tolaunch.length} agent(s) in parallel...\\n`);\n674: \n675:   await Promise.all(\n676:     tolaunch.map((agent) =>\n677:       launchSingleHeadless(\n678:         projectRoot,\n679:         state,\n680:         agent,\n681:         featureMap.get(agent.feature_id)!,\n682:         monitor,\n683:         config,\n684:         model\n685:       )\n686:     )\n687:   );\n688: \n689:   const launched = state.agents.filter((a) => a.status === \"running\").length;\n690: \n691:   // Start the TUI dashboard (or skip if --no-tui)\n692:   if (opts.noTui) {\n693:     console.log(`${launched} agent(s) running. (--no-tui mode, dashboard prints every 15s)\\n`);\n694:     printDashboard(state);\n695:   } else {\n696:     console.log(`${launched} agent(s) running. Launching TUI...\\n`);\n697:     startTUI();\n698:   }\n699: \n700:   // Background monitoring loop — checks for dead processes and launches queued\n701:   const POLL_INTERVAL = 5000;\n702:   let dashboardCounter = 0;\n703:   while (!isWaveComplete(state)) {\n704:     await new Promise((r) => setTimeout(r, POLL_INTERVAL));\n705: \n706:     // Check for completed processes that weren't caught by event handlers\n707:     for (const agent of state.agents) {\n708:       if (\n709:         (agent.status === \"running\" || agent.status === \"resolving_conflict\") &&\n710:         agent.pid &&\n711:         !isProcessRunning(agent.pid) &&\n712:         !monitor.isRunning(agent.feature_id)\n713:       ) {\n714:         if (agent.status === \"resolving_conflict\") {\n715:           // Conflict resolver died — the await in handleBuildVerification\n716:           // will resolve via the 'exit' event, so nothing to do here\n717:           continue;\n718:         }\n719:         // Process exited but we didn't get a callback\n720:         // Check if the agent actually made any commits\n721:         if (!branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n722:           // Agent died without producing any code — mark as failed, not completed\n723:           updateAgent(state, agent.feature_id, {\n724:             status: \"failed\",\n725:             error: \"Agent process exited without making any commits\",\n726:             activity: null,\n727:             completed_at: new Date().toISOString(),\n728:           });\n729:           saveState(projectRoot, state);\n730:           wtLog(agent.feature_id, \"process died with no code changes — marked failed\");\n731:         } else {\n732:           updateAgent(state, agent.feature_id, {\n733:             status: \"completed\",\n734:             completed_at: new Date().toISOString(),\n735:             activity: \"done\",\n736:           });\n737:           saveState(projectRoot, state);\n738:           try {\n739:             await handleBuildVerification(projectRoot, state, agent, featureMap.get(agent.feature_id)!, config, model, monitor);\n740:           } catch (err: any) {\n741:             wtLog(agent.feature_id, `POLL VERIFY ERROR: ${err.message}`);\n742:           }\n743:         }\n744:         launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n745:       }\n746:     }\n747: \n748:     // Persist state periodically\n749:     saveState(projectRoot, state);\n750: \n751:     // Update TUI state reference (or print dashboard in --no-tui mode)\n752:     if (tuiRef.current) {\n753:       tuiRef.current.updateState(state);\n754:     } else if (opts.noTui) {\n755:       dashboardCounter++;\n756:       if (dashboardCounter % 3 === 0) {\n757:         printDashboard(state);\n758: \n759:         // Auto-push base branch if requested\n760:         if (opts.autoPush) {\n761:           const anyMerged = state.agents.some((a) => a.status === \"merged\");\n762:           if (anyMerged) {\n763:             await pushBaseBranch(projectRoot, state.base_branch, config);\n764:           } else {\n765:             console.log(\"No branches were merged — skipping push.\");\n766:           }\n767:         }\n768:       }\n769:     }\n770:   }\n771: \n772:   // Wave complete — tear down TUI and show final summary\n773:   if (tuiRef.current) tuiRef.current.stop();\n774:   printDashboard(state);\n775: \n776:   // Auto-push base branch if requested\n777:   if (opts.autoPush) {\n778:     await pushBaseBranch(projectRoot, state.base_branch, config);\n779:   }\n780: \n781:   console.log(\"Wave complete.\");\n782: }\n783: \n784: // ---------------------------------------------------------------------------\n785: // Interactive Wave Launch\n786: // ---------------------------------------------------------------------------\n787: \n788: async function launchWaveInteractive(\n789:   projectRoot: string,\n790:   state: WaveState,\n791:   features: Feature[],\n792:   opts: LaunchCommandOptions\n793: ): Promise<void> {\n794:   const { config, model } = opts;\n795:   const featureMap = new Map(features.map((f) => [f.id, f]));\n796: \n797:   // Show dashboard immediately\n798:   printDashboard(state);\n799: \n800:   // Launch initial batch in tmux — parallelize setup\n801:   const tolaunch = queuedAgents(state).slice(0, opts.maxConcurrent);\n802:   console.log(`Setting up ${tolaunch.length} agent(s) in parallel...\\n`);\n803: \n804:   await Promise.all(\n805:     tolaunch.map(async (agent) => {\n806:       updateAgent(state, agent.feature_id, {\n807:         status: \"installing\",\n808:         started_at: new Date().toISOString(),\n809:         activity: \"setting up worktree...\",\n810:       });\n811:       saveState(projectRoot, state);\n812: \n813:       try {\n814:         if (worktreeReady(agent.worktree)) {\n815:           wtLog(agent.feature_id, \"worktree already exists, skipping setup\");\n816:         } else {\n817:           await createWorktree(projectRoot, agent.feature_id, state.base_branch, config);\n818:           updateAgent(state, agent.feature_id, { activity: \"installing deps...\" });\n819:           await installDeps(agent.worktree, agent.feature_id, config);\n820:         }\n821: \n822:         const prompt = generatePrompt(\n823:           featureMap.get(agent.feature_id)!,\n824:           state.base_branch,\n825:           config\n826:         );\n827: \n828:         wtLog(agent.feature_id, \"launching tmux session...\");\n829:         const result = launchInteractive({\n830:           worktreePath: agent.worktree,\n831:           featureId: agent.feature_id,\n832:           prompt,\n833:           model,\n834:           interactive: true,\n835:           config,\n836:         });\n837: \n838:         updateAgent(state, agent.feature_id, {\n839:           status: \"running\",\n840:           pid: result.pid,\n841:           activity: \"tmux session active\",\n842:         });\n843:         saveState(projectRoot, state);\n844:         wtLog(agent.feature_id, `tmux session: ${config.agent.tmuxPrefix}-${agent.feature_id}`);\n845:       } catch (err: any) {\n846:         updateAgent(state, agent.feature_id, {\n847:           status: \"failed\",\n848:           error: err.message,\n849:           activity: null,\n850:           completed_at: new Date().toISOString(),\n851:         });\n852:         saveState(projectRoot, state);\n853:         wtLog(agent.feature_id, `SETUP FAILED: ${err.message.split(\"\\n\")[0]}`);\n854:       }\n855:     })\n856:   );\n857: \n858:   console.log(\"\\nInteractive sessions launched. Use these commands:\");\n859:   console.log(`  tmux attach -t ${config.agent.tmuxPrefix}-<feature-id>   # attach to a session`);\n860:   console.log(\"  tmux ls                                                  # list sessions\");\n861:   console.log(\"  wombo status                                             # check status\");\n862:   console.log(\"  wombo verify                                             # verify builds\");\n863:   console.log(\"  wombo merge                                              # merge verified\");\n864:   console.log(\"  wombo cleanup                                            # remove worktrees\");\n865: \n866:   printDashboard(state);\n867: }\n868: \n869: // ---------------------------------------------------------------------------\n870: // Main Command\n871: // ---------------------------------------------------------------------------\n872: \n873: export async function cmdLaunch(opts: LaunchCommandOptions): Promise<void> {\n874:   const { projectRoot, config } = opts;\n875: \n876:   console.log(\"\\n--- Wombo: Launch ---\\n\");\n877: \n878:   // Ensure agent definition exists — reinstall from template if missing\n879:   ensureAgentDefinition(projectRoot, config);\n880: \n881:   // -------------------------------------------------------------------------\n882:   // Check for existing wave state — don't overwrite work in progress\n883:   // -------------------------------------------------------------------------\n884:   const existingState = loadState(projectRoot);\n885:   if (existingState) {\n886:     const merged = existingState.agents.filter((a) => a.status === \"merged\");\n887:     const verified = existingState.agents.filter((a) => a.status === \"verified\");\n888:     const completed = existingState.agents.filter((a) => a.status === \"completed\");\n889:     const running = existingState.agents.filter((a) => a.status === \"running\");\n890:     const queued = existingState.agents.filter((a) => a.status === \"queued\");\n891:     const failed = existingState.agents.filter((a) => a.status === \"failed\");\n892: \n893:     const hasWork = merged.length > 0 || verified.length > 0 || completed.length > 0 || running.length > 0;\n894: \n895:     if (hasWork) {\n896:       console.log(`Existing wave found: ${existingState.wave_id}`);\n897:       console.log(`  ${merged.length} merged, ${verified.length} verified, ${completed.length} completed, ${running.length} running, ${queued.length} queued, ${failed.length} failed`);\n898: \n899:       // Finalize any merged agents by marking their features as done\n900:       if (merged.length > 0) {\n901:         console.log(\"\\nFinalizing merged features in .features.yml...\");\n902:         for (const agent of merged) {\n903:           markFeatureDone(projectRoot, agent.feature_id, config, existingState.base_branch);\n904:           // Clean up worktree and branch (already merged, safe to delete)\n905:           try {\n906:             removeWorktree(projectRoot, agent.worktree, true);\n907:             console.log(`  ${agent.feature_id}: marked done, worktree removed`);\n908:           } catch {\n909:             console.log(`  ${agent.feature_id}: marked done (worktree already cleaned)`);\n910:           }\n911:         }\n912:       }\n913: \n914:       // Verified agents: build passed but NOT merged — do NOT mark done.\n915:       // Leave them for 'wombo resume' to attempt the merge.\n916:       if (verified.length > 0) {\n917:         for (const agent of verified) {\n918:           console.log(`  ${agent.feature_id}: verified (not yet merged) — use 'wombo resume' to merge`);\n919:         }\n920:       }\n921: \n922:       const activeCount = running.length + completed.length + queued.length;\n923:       if (activeCount > 0) {\n924:         console.error(`\\nWave ${existingState.wave_id} has ${activeCount} unfinished agent(s).`);\n925:         console.error(\"Use 'wombo resume' to continue the existing wave,\");\n926:         console.error(\"or 'wombo cleanup' to clear it before starting a new one.\");\n927:         process.exit(1);\n928:       }\n929: \n930:       // All agents are in terminal states (merged/verified/failed) — safe to start fresh\n931:       console.log(\"\\nAll agents in previous wave are finished. Starting fresh wave.\\n\");\n932:     }\n933:   }\n934: \n935:   // Load features\n936:   const data = loadFeatures(projectRoot, config);\n937: \n938:   // Build selection options\n939:   const selOpts: SelectionOptions = {};\n940:   if (opts.topPriority) selOpts.topPriority = opts.topPriority;\n941:   if (opts.quickestWins) selOpts.quickestWins = opts.quickestWins;\n942:   if (opts.priority) selOpts.priority = opts.priority;\n943:   if (opts.difficulty) selOpts.difficulty = opts.difficulty;\n944:   if (opts.features) selOpts.featureIds = opts.features;\n945:   if (opts.allReady) selOpts.allReady = true;\n946: \n947:   // Select features\n948:   const selected = selectFeatures(data, selOpts);\n949: \n950:   if (selected.length === 0) {\n951:     if (opts.allReady) {\n952:       console.error(\n953:         \"No launchable features found. All features may be done, cancelled, or have unmet dependencies.\"\n954:       );\n955:     } else {\n956:       console.error(\n957:         \"No features matched the selection criteria. Use --all-ready to see all available.\"\n958:       );\n959:     }\n960:     process.exit(1);\n961:   }\n962: \n963:   // Show selection\n964:   printFeatureSelection(\n965:     selected.map((f) => ({\n966:       id: f.id,\n967:       title: f.title,\n968:       priority: f.priority,\n969:       difficulty: f.difficulty,\n970:       effort: f.effort,\n971:     }))\n972:   );\n973: \n974:   if (opts.dryRun) {\n975:     console.log(\"Dry run — not launching agents.\");\n976:     return;\n977:   }\n978: \n979:   // Create wave state\n980:   const state = createWaveState({\n981:     baseBranch: opts.baseBranch,\n982:     maxConcurrent: opts.maxConcurrent,\n983:     model: opts.model ?? null,\n984:     interactive: opts.interactive,\n985:   });\n986: \n987:   // Create agent entries for all selected features\n988:   for (const feature of selected) {\n989:     const branch = featureBranchName(feature.id, config);\n990:     const wtPath = worktreePath(projectRoot, feature.id, config);\n991:     const agent = createAgentState(feature.id, branch, wtPath, opts.maxRetries);\n992:     // Set effort estimate from feature spec\n993:     const effortMinutes = parseDurationMinutes(feature.effort);\n994:     agent.effort_estimate_ms = effortMinutes === Infinity ? null : effortMinutes * 60 * 1000;\n995:     state.agents.push(agent);\n996:   }\n997: \n998:   saveState(projectRoot, state);\n999:   console.log(`Wave ${state.wave_id} created with ${selected.length} agents.`);\n1000: \n1001:   // Launch agents up to max_concurrent\n1002:   if (opts.interactive) {\n1003:     await launchWaveInteractive(projectRoot, state, selected, opts);\n1004:   } else {\n1005:     await launchWaveHeadless(projectRoot, state, selected, opts);\n1006:   }\n1007: }\n\n(End of file - total 1007 lines)\n</content>","title":"src/commands/launch.ts","metadata":{"preview":"/**\n * launch.ts — Launch a wave of agents.\n *\n * Usage: wombo launch [selection options] [launch options]\n *\n * This is the primary entry point for starting a new wave. It selects features\n * from the features file, creates a wave state, sets up worktrees, and launches\n * agent processes (either headless or interactive via tmux).\n *\n * IMPORTANT: This file also exports shared helper functions that are reused\n * by resume.ts and other commands:\n *   - launchSingleHeadless\n *   - handleBuildVerification\n *   - handleRetry\n *   - launchNextQueued\n */\n\nimport { execSync } from \"node:child_process\";\nimport type { WomboConfig } from \"../config.js\";\nimport type { Feature, SelectionOptions, Priority, Difficulty } from \"../lib/features.js\";","truncated":false,"loaded":[]},"time":{"start":1773351520348,"end":1773351520371}}}}
