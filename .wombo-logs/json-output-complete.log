{"type":"tool_use","timestamp":1773351791930,"sessionID":"ses_31c036d66ffeb3gOzUVP7hTP5i","part":{"id":"prt_ce400a4a7001gGkZwzr3dF332N","sessionID":"ses_31c036d66ffeb3gOzUVP7hTP5i","messageID":"msg_ce4009a1d001ygyp6854JwlzvM","type":"tool","callID":"toolu_vrtx_01PtoX7nW8HhoD8Ht9YWh5Hh","tool":"write","state":{"status":"completed","input":{"content":"/**\n * retry.ts — Retry a specific failed agent.\n *\n * Usage: wombo retry <feature-id> [--interactive] [--model <model>]\n *\n * Resets the agent's retry count and re-launches it. Can launch in either\n * headless mode (default) or interactive (tmux) mode.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport { loadFeatures, type Feature } from \"../lib/features.js\";\nimport {\n  loadState,\n  saveState,\n  updateAgent,\n} from \"../lib/state.js\";\nimport { worktreeReady } from \"../lib/worktree.js\";\nimport { generatePrompt } from \"../lib/prompt.js\";\nimport { launchInteractive } from \"../lib/launcher.js\";\nimport { ProcessMonitor } from \"../lib/monitor.js\";\nimport { launchSingleHeadless } from \"./launch.js\";\nimport { output, outputError, outputMessage, type OutputFormat } from \"../lib/output.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface RetryCommandOptions {\n  projectRoot: string;\n  config: WomboConfig;\n  featureId: string;\n  model?: string;\n  interactive: boolean;\n  dryRun?: boolean;\n  outputFmt?: OutputFormat;\n}\n\n// ---------------------------------------------------------------------------\n// Command\n// ---------------------------------------------------------------------------\n\nexport async function cmdRetry(opts: RetryCommandOptions): Promise<void> {\n  const { projectRoot, config } = opts;\n  const fmt = opts.outputFmt ?? \"text\";\n\n  if (!opts.featureId) {\n    outputError(fmt, \"Usage: wombo retry <feature-id>\");\n    return; // unreachable — helps TypeScript narrow\n  }\n\n  const state = loadState(projectRoot);\n  if (!state) {\n    outputMessage(fmt, \"No active wave.\", { wave: null });\n    return;\n  }\n\n  const agent = state.agents.find((a) => a.feature_id === opts.featureId);\n  if (!agent) {\n    outputError(fmt, `Agent not found for feature: ${opts.featureId}`);\n    return; // unreachable — helps TypeScript narrow\n  }\n\n  if (agent.status !== \"failed\") {\n    outputError(\n      fmt,\n      `Agent ${opts.featureId} is not in failed state (current: ${agent.status})`\n    );\n    return; // unreachable — helps TypeScript narrow\n  }\n\n  // Dry-run: show what would be retried without doing it\n  if (opts.dryRun) {\n    output(\n      fmt,\n      {\n        dry_run: true,\n        feature_id: opts.featureId,\n        current_status: agent.status,\n        retries: agent.retries,\n        worktree: agent.worktree,\n        mode: opts.interactive ? \"interactive\" : \"headless\",\n        model: opts.model ?? null,\n      },\n      () => {\n        console.log(`\\n[dry-run] Would retry agent: ${opts.featureId}`);\n        console.log(`  Current status: ${agent.status}`);\n        console.log(`  Retries so far: ${agent.retries}`);\n        console.log(`  Worktree: ${agent.worktree}`);\n        console.log(`  Mode: ${opts.interactive ? \"interactive (tmux)\" : \"headless\"}`);\n        if (opts.model) console.log(`  Model: ${opts.model}`);\n      }\n    );\n    return;\n  }\n\n  // Reset retry count and re-run\n  updateAgent(state, agent.feature_id, {\n    status: \"queued\",\n    retries: 0,\n    error: null,\n    build_passed: null,\n    build_output: null,\n    completed_at: null,\n  });\n  saveState(projectRoot, state);\n\n  const data = loadFeatures(projectRoot, config);\n  const feature = data.features.find((f) => f.id === opts.featureId);\n  if (!feature) {\n    outputError(fmt, `Feature ${opts.featureId} not found in ${config.featuresFile}`);\n    return; // unreachable — helps TypeScript narrow\n  }\n\n  if (opts.interactive) {\n    const prompt = generatePrompt(feature, state.base_branch, config);\n    launchInteractive({\n      worktreePath: agent.worktree,\n      featureId: feature.id,\n      prompt,\n      model: opts.model,\n      interactive: true,\n      config,\n    });\n\n    updateAgent(state, agent.feature_id, {\n      status: \"running\",\n      started_at: new Date().toISOString(),\n    });\n    saveState(projectRoot, state);\n\n    outputMessage(fmt, `Retrying ${opts.featureId} in tmux session ${config.agent.tmuxPrefix}-${opts.featureId}`, {\n      feature_id: opts.featureId,\n      mode: \"interactive\",\n      status: \"running\",\n    });\n  } else {\n    const monitor = new ProcessMonitor(projectRoot);\n    await launchSingleHeadless(projectRoot, state, agent, feature, monitor, config, opts.model);\n\n    outputMessage(fmt, `Retrying ${opts.featureId} in headless mode`, {\n      feature_id: opts.featureId,\n      mode: \"headless\",\n      status: \"running\",\n    });\n  }\n}\n","filePath":"/home/fulgidus/Documents/wombo-json-output-complete/src/commands/retry.ts"},"output":"Wrote file successfully.","title":"src/commands/retry.ts","metadata":{"diagnostics":{"/home/fulgidus/Documents/wombo-json-output-complete/src/commands/features/show.ts":[{"range":{"start":{"line":15,"character":7},"end":{"line":15,"character":14}},"message":"'Feature' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"},{"range":{"start":{"line":41,"character":6},"end":{"line":41,"character":12}},"message":"'YELLOW' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"},{"range":{"start":{"line":84,"character":4},"end":{"line":84,"character":10}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":92,"character":4},"end":{"line":92,"character":10}},"message":"Unreachable code detected.","severity":4,