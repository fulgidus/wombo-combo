{"type":"tool_use","timestamp":1773351605954,"sessionID":"ses_31c036d66ffeb3gOzUVP7hTP5i","part":{"id":"prt_ce3fde1d1001TE0wZEvRYB2Cll","sessionID":"ses_31c036d66ffeb3gOzUVP7hTP5i","messageID":"msg_ce3fdd439001Psr3spJPvQ4asX","type":"tool","callID":"toolu_vrtx_016u7rqbWSBba6vMbn5AMu8A","tool":"write","state":{"status":"completed","input":{"content":"/**\n * features/archive.ts — Move done/cancelled features to the archive section.\n *\n * Usage:\n *   wombo features archive              # archive all done + cancelled\n *   wombo features archive <feature-id> # archive a specific feature\n *   wombo features archive --dry-run    # show what would be archived\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  saveFeatures,\n  findFeatureById,\n  type Feature,\n} from \"../../lib/features.js\";\nimport { output, outputError, outputMessage, type OutputFormat } from \"../../lib/output.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface FeaturesArchiveOptions {\n  projectRoot: string;\n  config: WomboConfig;\n  featureId?: string;\n  dryRun?: boolean;\n  outputFmt?: OutputFormat;\n}\n\n// ---------------------------------------------------------------------------\n// Command\n// ---------------------------------------------------------------------------\n\nexport async function cmdFeaturesArchive(opts: FeaturesArchiveOptions): Promise<void> {\n  const { projectRoot, config } = opts;\n  const fmt = opts.outputFmt ?? \"text\";\n\n  const data = loadFeatures(projectRoot, config);\n\n  // Ensure archive array exists\n  if (!data.archive) {\n    data.archive = [];\n  }\n\n  let toArchive: Feature[];\n\n  if (opts.featureId) {\n    // Archive a specific feature\n    const idx = data.features.findIndex((f) => f.id === opts.featureId);\n    if (idx === -1) {\n      // Check if already in archive\n      if (data.archive.find((f) => f.id === opts.featureId)) {\n        outputMessage(fmt, `Feature \"${opts.featureId}\" is already in the archive.`, {\n          id: opts.featureId,\n          already_archived: true,\n        });\n        return;\n      }\n      outputError(fmt, `Feature \"${opts.featureId}\" not found.`);\n      return;\n    }\n    toArchive = [data.features[idx]];\n  } else {\n    // Archive all done + cancelled features\n    toArchive = data.features.filter(\n      (f) => f.status === \"done\" || f.status === \"cancelled\"\n    );\n  }\n\n  if (toArchive.length === 0) {\n    outputMessage(fmt, \"No features to archive.\", { archived: [], count: 0 });\n    return;\n  }\n\n  const archivedSummary = toArchive.map((f) => ({\n    id: f.id,\n    title: f.title,\n    status: f.status,\n  }));\n\n  if (opts.dryRun) {\n    output(\n      fmt,\n      { dry_run: true, archived: archivedSummary, count: toArchive.length },\n      () => {\n        console.log(`\\nWould archive ${toArchive.length} feature(s):\\n`);\n        for (const f of toArchive) {\n          console.log(`  ${f.id} — ${f.title} (${f.status})`);\n        }\n      }\n    );\n    return;\n  }\n\n  // Move features from active to archive\n  const archiveIds = new Set(toArchive.map((f) => f.id));\n  data.features = data.features.filter((f) => !archiveIds.has(f.id));\n  data.archive.push(...toArchive);\n\n  saveFeatures(projectRoot, config, data);\n\n  output(\n    fmt,\n    { archived: archivedSummary, count: toArchive.length },\n    () => {\n      console.log(`\\nArchived ${toArchive.length} feature(s):`);\n      for (const f of toArchive) {\n        console.log(`  ${f.id} — ${f.title} (${f.status})`);\n      }\n    }\n  );\n}\n","filePath":"/home/fulgidus/Documents/wombo-json-output-complete/src/commands/features/archive.ts"},"output":"Wrote file successfully.","title":"src/commands/features/archive.ts","metadata":{"diagnostics":{"/home/fulgidus/Documents/wombo-json-output-complete/src/comm