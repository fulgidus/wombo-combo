{"type":"tool_use","timestamp":1773351746896,"sessionID":"ses_31c036d66ffeb3gOzUVP7hTP5i","part":{"id":"prt_ce3ffffe1002fmvc7PYcCF3nBX","sessionID":"ses_31c036d66ffeb3gOzUVP7hTP5i","messageID":"msg_ce3fff793001fNI2oWKMbzNqCM","type":"tool","callID":"toolu_vrtx_01UkQDnHS3SDfxwoU6jYJCtX","tool":"write","state":{"status":"completed","input":{"content":"/**\n * merge.ts — Merge verified branches into the base branch.\n *\n * Usage: wombo merge [feature-id]\n *\n * Merges all verified agents (or a specific one) into the base branch.\n * After merging, cleans up the worktree as best-effort.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport {\n  loadState,\n  saveState,\n  updateAgent,\n} from \"../lib/state.js\";\nimport { mergeBranch, pushBaseBranch } from \"../lib/merger.js\";\nimport { removeWorktree } from \"../lib/worktree.js\";\nimport { printDashboard, printAgentUpdate } from \"../lib/ui.js\";\nimport { output, outputMessage, type OutputFormat } from \"../lib/output.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface MergeCommandOptions {\n  projectRoot: string;\n  config: WomboConfig;\n  featureId?: string;\n  autoPush?: boolean;\n  dryRun?: boolean;\n  outputFmt?: OutputFormat;\n}\n\n// ---------------------------------------------------------------------------\n// Command\n// ---------------------------------------------------------------------------\n\nexport async function cmdMerge(opts: MergeCommandOptions): Promise<void> {\n  const { projectRoot, config } = opts;\n  const fmt = opts.outputFmt ?? \"text\";\n\n  const state = loadState(projectRoot);\n  if (!state) {\n    outputMessage(fmt, \"No active wave.\", { wave: null });\n    return;\n  }\n\n  const toMerge = opts.featureId\n    ? state.agents.filter(\n        (a) => a.feature_id === opts.featureId && a.status === \"verified\"\n      )\n    : state.agents.filter((a) => a.status === \"verified\");\n\n  if (toMerge.length === 0) {\n    outputMessage(fmt, \"No verified agents to merge.\", {\n      wave_id: state.wave_id,\n      merged: [],\n      count: 0,\n    });\n    return;\n  }\n\n  // Dry-run: show what would be merged without merging\n  if (opts.dryRun) {\n    const dryRunData = toMerge.map((a) => ({\n      feature_id: a.feature_id,\n      branch: a.branch,\n    }));\n\n    output(\n      fmt,\n      {\n        dry_run: true,\n        would_merge: dryRunData,\n        count: toMerge.length,\n        auto_push: opts.autoPush ?? false,\n        base_branch: state.base_branch,\n      },\n      () => {\n        console.log(`\\n[dry-run] Would merge ${toMerge.length} branch(es):\\n`);\n        for (const agent of toMerge) {\n          console.log(`  ${agent.feature_id} — branch: ${agent.branch}`);\n        }\n        if (opts.autoPush) {\n          console.log(`\\n  Would push ${state.base_branch} to remote after merge.`);\n        }\n      }\n    );\n    return;\n  }\n\n  if (fmt !== \"json\") {\n    console.log(`\\nMerging ${toMerge.length} branch(es)...\\n`);\n  }\n\n  const mergeResults: Array<{\n    feature_id: string;\n    branch: string;\n    success: boolean;\n    commit_hash?: string;\n    error?: string;\n  }> = [];\n\n  for (const agent of toMerge) {\n    if (fmt !== \"json\") printAgentUpdate(agent, \"merging...\");\n    const result = await mergeBranch(projectRoot, agent.branch, state.base_branch, config);\n\n    if (result.success) {\n      updateAgent(state, agent.feature_id, {\n        status: \"merged\",\n      });\n      saveState(projectRoot, state);\n      if (fmt !== \"json\") printAgentUpdate(agent, `MERGED (${result.commitHash?.slice(0, 7)})`);\n\n      mergeResults.push({\n        feature_id: agent.feature_id,\n        branch: agent.branch,\n        success: true,\n        commit_hash: result.commitHash,\n      });\n\n      // Clean up worktree\n      try {\n        removeWorktree(projectRoot, agent.worktree, false);\n        if (fmt !== \"json\") printAgentUpdate(agent, \"worktree removed\");\n      } catch {\n        // Not critical\n      }\n    } else {\n      if (fmt !== \"json\") printAgentUpdate(agent, `MERGE FAILED: ${result.error}`);\n      mergeResults.push({\n        feature_id: agent.feature_id,\n        branch: agent.branch,\n        success: false,\n        error: result.error,\n      });\n    }\n  }\n\n  // Auto-push if requested\n  let pushed = false;\n  if (opts.autoPush) {\n    const anyMerged = state.agents.some((a) => a.status === \"merged\");\n    if (anyMerged) {\n      await pushBaseBranch(projectRoot, state.base_branch, config);\n      pushed = true;\n    }\n  }\n\n  output(\n    fmt,\n    {\n      wave_id: state.wave_id,\n      merged: mergeResults,\n      count: mergeResults.length,\n      pushed,\n    },\n    () => {\n      printDashboard(state);\n    }\n  );\n}\n","filePath":"/home/fulgidus/Documents/wombo-json-output-complete/src/commands/merge.ts"},"output":"Wrote file successfully.\n\nLSP errors detected in this file, please fix:\n<diagnostics file=\"/home/fulgidus/Documents/wombo-json-output-complete/src/commands/merge.ts\">\nERROR [119:9] Type 'string | null' is not assignable to type 'string | undefined'.\n  Type 'null' is not assignable to type 'string | undefined'.\nERROR [135:9] Type 'string | null' is not assignable to type 'string | undefined'.\n  Type 'null' is not assignable to type 'string | undefined'.\n</diagnostics>","title":"src/commands/merge.ts","metadata":{"diagnostics":{"/home/fulgidus/Documents/wombo-json-output-complete/src/commands/features/show.ts":[{"range":{"start":{"line":15,"character":7},"end":{"line":15,"character":14}},"message":"'Feature' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"},{"range":{"start":{"line":41,"character":6},"end":{"line":41,"character":12}},"message":"'YELLOW' is declared but its value is never read.","severity":4,"code