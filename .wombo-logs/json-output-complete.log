{"type":"tool_use","timestamp":1773351874130,"sessionID":"ses_31c036d66ffeb3gOzUVP7hTP5i","part":{"id":"prt_ce4022c1d0013KQ8PzW15112Q1","sessionID":"ses_31c036d66ffeb3gOzUVP7hTP5i","messageID":"msg_ce4021d10001boYRn5H8KP8Zw8","type":"tool","callID":"toolu_vrtx_01XX3NUz2GYnJjVQofpP1hgu","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-json-output-complete/src/index.ts"},"output":"<path>/home/fulgidus/Documents/wombo-json-output-complete/src/index.ts</path>\n<type>file</type>\n<content>1: #!/usr/bin/env bun\n2: /**\n3:  * index.ts — CLI entry point for the Wombo agent orchestration system.\n4:  *\n5:  * Usage:\n6:  *   wombo init\n7:  *   wombo launch --top-priority 3\n8:  *   wombo launch --quickest-wins 5\n9:  *   wombo launch --priority high\n10:  *   wombo launch --difficulty easy\n11:  *   wombo launch --features \"feat-a,feat-b\"\n12:  *   wombo launch --all-ready\n13:  *   wombo launch ... --max-concurrent 3 --model \"anthropic/claude-sonnet-4-20250514\"\n14:  *   wombo launch ... --interactive\n15:  *   wombo resume\n16:  *   wombo status\n17:  *   wombo verify [feature-id]\n18:  *   wombo merge [feature-id]\n19:  *   wombo retry <feature-id>\n20:  *   wombo cleanup\n21:  *   wombo features list [--status <s>] [--priority <p>] [--difficulty <d>] [--ready] [--include-archive]\n22:  *   wombo features add <id> <title> [options]\n23:  *   wombo features set-status <feature-id> <status>\n24:  *   wombo features check\n25:  *   wombo features archive [feature-id] [--dry-run]\n26:  *   wombo features show <feature-id>\n27:  *   wombo features graph [--ascii] [--mermaid] [--subtasks] [--status <s>]\n28:  *   wombo help\n29:  *   wombo --version\n30:  */\n31: \n32: import { resolve } from \"node:path\";\n33: import { existsSync, readFileSync } from \"node:fs\";\n34: import { loadConfig, validateConfig } from \"./config.js\";\n35: import { loadState, saveState } from \"./lib/state.js\";\n36: \n37: // ---------------------------------------------------------------------------\n38: // Dev-mode guard: warn if running the global binary inside the wombo repo\n39: // ---------------------------------------------------------------------------\n40: \n41: function checkDevModeGuard(): void {\n42:   const cwd = process.cwd();\n43:   const pkgPath = resolve(cwd, \"package.json\");\n44: \n45:   // Are we inside the wombo repo?\n46:   if (!existsSync(pkgPath)) return;\n47: \n48:   let pkgName: string | undefined;\n49:   try {\n50:     const raw = readFileSync(pkgPath, \"utf-8\");\n51:     pkgName = JSON.parse(raw).name;\n52:   } catch {\n53:     return;\n54:   }\n55:   if (pkgName !== \"wombo\") return;\n56: \n57:   // We're in the wombo repo. Is the source being run from a different location?\n58:   // import.meta.dir = directory of THIS file (index.ts). If it's under cwd,\n59:   // we're running local source (bun dev). If it's elsewhere (e.g. ~/.bun/install),\n60:   // we're running the globally installed binary.\n61:   const sourceDir = resolve(import.meta.dir);\n62:   const projectSrc = resolve(cwd, \"src\");\n63: \n64:   if (!sourceDir.startsWith(projectSrc)) {\n65:     console.warn(\n66:       \"\\x1b[33m[WARNING]\\x1b[0m You are running the globally installed wombo binary \" +\n67:       \"inside the wombo repo.\\n\" +\n68:       \"  Use \\x1b[1mbun dev <command>\\x1b[0m instead to run from local source.\\n\" +\n69:       \"  See AGENTS.md for details.\\n\"\n70:     );\n71:   }\n72: }\n73: \n74: import { cmdInit } from \"./commands/init.js\";\n75: import { cmdLaunch } from \"./commands/launch.js\";\n76: import { cmdResume } from \"./commands/resume.js\";\n77: import { cmdStatus } from \"./commands/status.js\";\n78: import { cmdVerify } from \"./commands/verify.js\";\n79: import { cmdMerge } from \"./commands/merge.js\";\n80: import { cmdRetry } from \"./commands/retry.js\";\n81: import { cmdCleanup } from \"./commands/cleanup.js\";\n82: import { cmdUpgrade } from \"./commands/upgrade.js\";\n83: import { cmdFeaturesList } from \"./commands/features/list.js\";\n84: import { cmdFeaturesAdd } from \"./commands/features/add.js\";\n85: import { cmdFeaturesSetStatus } from \"./commands/features/set-status.js\";\n86: import { cmdFeaturesCheck } from \"./commands/features/check.js\";\n87: import { cmdFeaturesArchive } from \"./commands/features/archive.js\";\n88: import { cmdFeaturesShow } from \"./commands/features/show.js\";\n89: import { cmdFeaturesGraph } from \"./commands/features/graph.js\";\n90: \n91: import { ensureFeaturesFile } from \"./lib/features.js\";\n92: import type { Priority, Difficulty, FeatureStatus } from \"./lib/features.js\";\n93: import { resolveOutputFormat, type OutputFormat } from \"./lib/output.js\";\n94: import { validateId, validateText, validateBranchName, validateDuration, assertValid } from \"./lib/validate.js\";\n95: import { findCommandDef, commandToSchema, allCommandSchemas } from \"./lib/schema.js\";\n96: \n97: // ---------------------------------------------------------------------------\n98: // Types\n99: // ---------------------------------------------------------------------------\n100: \n101: interface CLIArgs {\n102:   command: string;\n103:   subcommand?: string;\n104:   // Selection options (launch)\n105:   topPriority?: number;\n106:   quickestWins?: number;\n107:   priority?: Priority;\n108:   difficulty?: Difficulty;\n109:   features?: string[];\n110:   allReady?: boolean;\n111:   // Launch / runtime options\n112:   maxConcurrent?: number;\n113:   model?: string;\n114:   interactive: boolean;\n115:   dryRun: boolean;\n116:   baseBranch?: string;\n117:   maxRetries?: number;\n118:   noTui: boolean;\n119:   autoPush: boolean;\n120:   // General\n121:   featureId?: string;\n122:   force: boolean;\n123:   // Output format\n124:   outputFmt: OutputFormat;\n125:   // Upgrade options\n126:   checkOnly: boolean;\n127:   version?: string;\n128:   // Features subcommand extras\n129:   status?: string;\n130:   ready?: boolean;\n131:   includeArchive?: boolean;\n132:   title?: string;\n133:   description?: string;\n134:   effort?: string;\n135:   dependsOn?: string[];\n136:   // Compact output\n137:   fields?: string[];\n138:   // Graph options\n139:   ascii?: boolean;\n140:   mermaidRaw?: boolean;\n141:   graphSubtasks?: boolean;\n142: }\n143: \n144: // ---------------------------------------------------------------------------\n145: // Arg Parsing\n146: // ---------------------------------------------------------------------------\n147: \n148: function parseArgs(argv: string[]): CLIArgs {\n149:   const args = argv.slice(2); // skip 'bun' and script path\n150:   const result: CLIArgs = {\n151:     command: args[0] || \"help\",\n152:     interactive: false,\n153:     dryRun: false,\n154:     noTui: false,\n155:     autoPush: false,\n156:     force: false,\n157:     checkOnly: false,\n158:     outputFmt: resolveOutputFormat(undefined), // auto-detect until --output overrides\n159:   };\n160: \n161:   // If the first arg is \"features\", treat the second positional as the subcommand\n162:   let startIdx = 1;\n163:   if (result.command === \"features\") {\n164:     result.subcommand = args[1] || \"list\";\n165:     startIdx = 2;\n166:   }\n167: \n168:   for (let i = startIdx; i < args.length; i++) {\n169:     const arg = args[i];\n170:     switch (arg) {\n171:       // --- Selection options ---\n172:       case \"--top-priority\":\n173:         result.topPriority = parseInt(args[++i], 10);\n174:         break;\n175:       case \"--quickest-wins\":\n176:         result.quickestWins = parseInt(args[++i], 10);\n177:         break;\n178:       case \"--priority\":\n179:         result.priority = args[++i] as Priority;\n180:         break;\n181:       case \"--difficulty\":\n182:         result.difficulty = args[++i] as Difficulty;\n183:         break;\n184:       case \"--features\":\n185:         result.features = args[++i].split(\",\").map((s) => s.trim());\n186:         break;\n187:       case \"--all-ready\":\n188:         result.allReady = true;\n189:         break;\n190: \n191:       // --- Launch / runtime options ---\n192:       case \"--max-concurrent\":\n193:         result.maxConcurrent = parseInt(args[++i], 10);\n194:         break;\n195:       case \"--model\":\n196:       case \"-m\":\n197:         result.model = args[++i];\n198:         break;\n199:       case \"--interactive\":\n200:         result.interactive = true;\n201:         break;\n202:       case \"--dry-run\":\n203:         result.dryRun = true;\n204:         break;\n205:       case \"--no-tui\":\n206:         result.noTui = true;\n207:         break;\n208:       case \"--auto-push\":\n209:         result.autoPush = true;\n210:         break;\n211:       case \"--base-branch\":\n212:         result.baseBranch = args[++i];\n213:         break;\n214:       case \"--max-retries\":\n215:         result.maxRetries = parseInt(args[++i], 10);\n216:         break;\n217: \n218:       // --- General flags ---\n219:       case \"--force\":\n220:         result.force = true;\n221:         break;\n222:       case \"--check\":\n223:         result.checkOnly = true;\n224:         break;\n225:       case \"--version\":\n226:         result.version = args[++i];\n227:         break;\n228:       case \"--output\":\n229:       case \"-o\":\n230:         result.outputFmt = resolveOutputFormat(args[++i]);\n231:         break;\n232: \n233:       // --- Features subcommand options ---\n234:       case \"--status\":\n235:         result.status = args[++i];\n236:         break;\n237:       case \"--ready\":\n238:         result.ready = true;\n239:         break;\n240:       case \"--include-archive\":\n241:         result.includeArchive = true;\n242:         break;\n243:       case \"--title\":\n244:         result.title = args[++i];\n245:         break;\n246:       case \"--description\":\n247:       case \"--desc\":\n248:         result.description = args[++i];\n249:         break;\n250:       case \"--effort\":\n251:         result.effort = args[++i];\n252:         break;\n253:       case \"--depends-on\":\n254:         result.dependsOn = args[++i].split(\",\").map((s) => s.trim());\n255:         break;\n256:       case \"--fields\":\n257:         result.fields = args[++i].split(\",\").map((s) => s.trim());\n258:         break;\n259: \n260:       // --- Graph options ---\n261:       case \"--ascii\":\n262:         result.ascii = true;\n263:         break;\n264:       case \"--mermaid\":\n265:         result.mermaidRaw = true;\n266:         break;\n267:       case \"--subtasks\":\n268:         result.graphSubtasks = true;\n269:         break;\n270: \n271:       // --- Positional (feature-id, title for add, etc.) ---\n272:       default:\n273:         if (!arg.startsWith(\"-\")) {\n274:           if (!result.featureId) {\n275:             result.featureId = arg;\n276:           } else if (!result.title) {\n277:             result.title = arg;\n278:           }\n279:         }\n280:         break;\n281:     }\n282:   }\n283: \n284:   return result;\n285: }\n286: \n287: // ---------------------------------------------------------------------------\n288: // Help\n289: // ---------------------------------------------------------------------------\n290: \n291: function cmdHelp(): void {\n292:   console.log(`\n293: Wombo — AI Agent Orchestration System\n294: \n295:   WOMBO COMBO! Parallel feature development with AI agents.\n296: \n297: Commands:\n298:   init           Generate wombo.json config in the current project\n299:   launch         Launch a wave of agents to implement features\n300:   resume         Resume a previously stopped wave\n301:   status         Show the status of the current wave\n302:   verify         Run build verification on completed agents\n303:   merge          Merge verified branches into the base branch\n304:   retry          Retry a failed agent\n305:   cleanup        Remove all wave worktrees and tmux sessions\n306:   features       Manage .features.yml (see below)\n307:   upgrade        Check for updates and upgrade wombo\n308:   describe       Emit JSON schema of a command (for AI agents)\n309:   help           Show this help\n310: \n311: Features Subcommands:\n312:   features list            List features (--status, --priority, --difficulty, --ready, --include-archive)\n313:   features add <id> <title> [options]\n314:                            Add a new feature (--desc, --priority, --difficulty, --effort, --depends-on)\n315:   features set-status <id> <status>\n316:                            Change a feature's status\n317:   features check           Validate .features.yml (schema, deps, duplicates, cycles)\n318:   features archive [id]    Move done/cancelled to archive (--dry-run)\n319:   features show <id>       Show feature details\n320:   features graph           Visualize dependency graph (--ascii, --mermaid, --subtasks)\n321: \n322: Selection Options (for launch):\n323:   --top-priority N         Select top N features by priority\n324:   --quickest-wins N        Select N features with lowest effort\n325:   --priority <level>       Filter by priority (critical/high/medium/low/wishlist)\n326:   --difficulty <level>     Filter by difficulty (trivial/easy/medium/hard/very_hard)\n327:   --features \"id1,id2\"     Select specific features by ID\n328:   --all-ready              Select all features whose dependencies are met\n329: \n330: Launch Options:\n331:   --max-concurrent N       Max agents running in parallel (default: from config)\n332:   --model <model>          Model to use (e.g., \"anthropic/claude-sonnet-4-20250514\")\n333:   --interactive            Use tmux TUI mode instead of headless\n334:   --no-tui                 Headless mode without neo-blessed TUI (periodic console dashboard)\n335:   --auto-push              Push base branch to remote after all merges complete\n336:   --dry-run                Show what would be launched without launching\n337:   --base-branch <branch>   Base branch (default: from config)\n338:   --max-retries N          Max retries per agent (default: from config)\n339: \n340: General:\n341:   --version, -V            Print version and exit\n342:   --force                  Force overwrite (e.g., for init) / skip prompts (e.g., for upgrade)\n343:   --output <fmt>           Output format: text (default on TTY) or json (default when piped)\n344:   -o <fmt>                 Alias for --output\n345:   --dry-run                Show what would happen without performing the action\n346:   --fields <list>          Comma-separated fields to include (e.g., id,status,priority)\n347: \n348: Upgrade Options:\n349:   --check                  Only check for updates, don't install\n350:   --version <tag>          Install a specific version (e.g., v0.1.0)\n351: \n352: Examples:\n353:   wombo init\n354:   wombo launch --quickest-wins 3\n355:   wombo launch --priority high --interactive\n356:   wombo launch --features \"auth-flow,search-api\" --max-concurrent 2\n357:   wombo resume\n358:   wombo status\n359:   wombo verify\n360:   wombo merge\n361:   wombo retry auth-flow\n362:   wombo cleanup\n363:   wombo features list --status ready --priority high\n364:   wombo features list --fields id,status,priority --output json\n365:   wombo features add my-feature \"My Cool Feature\" --priority high --difficulty easy\n366:   wombo features set-status my-feature in-progress\n367:   wombo features check\n368:   wombo features archive --dry-run\n369:   wombo features show my-feature\n370:   wombo describe                           # list all commands as JSON\n371:   wombo describe launch                    # describe a specific command\n372:   wombo describe features add              # describe a subcommand\n373: `);\n374: }\n375: \n376: // ---------------------------------------------------------------------------\n377: // Main\n378: // ---------------------------------------------------------------------------\n379: \n380: async function main(): Promise<void> {\n381:   checkDevModeGuard();\n382: \n383:   const PROJECT_ROOT = resolve(process.cwd());\n384:   const args = parseArgs(process.argv);\n385: \n386:   // -----------------------------------------------------------------------\n387:   // Input validation at the CLI boundary\n388:   // -----------------------------------------------------------------------\n389:   if (args.featureId) {\n390:     assertValid(validateId(args.featureId, \"feature ID\"));\n391:   }\n392:   if (args.title) {\n393:     assertValid(validateText(args.title, \"title\"));\n394:   }\n395:   if (args.description) {\n396:     assertValid(validateText(args.description, \"description\"));\n397:   }\n398:   if (args.baseBranch) {\n399:     assertValid(validateBranchName(args.baseBranch, \"base branch\"));\n400:   }\n401:   if (args.effort) {\n402:     assertValid(validateDuration(args.effort, \"effort\"));\n403:   }\n404:   if (args.features) {\n405:     for (const fid of args.features) {\n406:       assertValid(validateId(fid, \"feature ID in --features\"));\n407:     }\n408:   }\n409:   if (args.dependsOn) {\n410:     for (const dep of args.dependsOn) {\n411:       assertValid(validateId(dep, \"dependency ID in --depends-on\"));\n412:     }\n413:   }\n414: \n415:   // Commands that don't need config loading\n416:   if (args.command === \"--version\" || args.command === \"-V\") {\n417:     const pkgPath = resolve(import.meta.dir, \"..\", \"package.json\");\n418:     try {\n419:       const raw = readFileSync(pkgPath, \"utf-8\");\n420:       const pkg = JSON.parse(raw);\n421:       console.log(`wombo ${pkg.version}`);\n422:     } catch {\n423:       console.log(\"wombo (unknown version)\");\n424:     }\n425:     return;\n426:   }\n427: \n428:   if (args.command === \"help\" || args.command === \"--help\" || args.command === \"-h\") {\n429:     cmdHelp();\n430:     return;\n431:   }\n432: \n433:   if (args.command === \"describe\") {\n434:     // Schema introspection: `wombo describe [command]`\n435:     if (!args.featureId) {\n436:       // No command specified — list all commands\n437:       console.log(JSON.stringify(allCommandSchemas(), null, 2));\n438:     } else {\n439:       // Describe a specific command. Handle compound names: \"features list\"\n440:       const cmdName = args.title\n441:         ? `${args.featureId} ${args.title}`\n442:         : args.featureId;\n443:       const def = findCommandDef(cmdName);\n444:       if (!def) {\n445:         console.error(`Unknown command: \"${cmdName}\"`);\n446:         console.error(\"Run 'wombo describe' to list all commands.\");\n447:         process.exit(1);\n448:         return;\n449:       }\n450:       console.log(JSON.stringify(commandToSchema(def), null, 2));\n451:     }\n452:     return;\n453:   }\n454: \n455:   if (args.command === \"init\") {\n456:     await cmdInit({ projectRoot: PROJECT_ROOT, force: args.force });\n457:     return;\n458:   }\n459: \n460:   if (args.command === \"upgrade\") {\n461:     await cmdUpgrade({\n462:       force: args.force,\n463:       version: args.version,\n464:       checkOnly: args.checkOnly,\n465:       outputFmt: args.outputFmt,\n466:     });\n467:     return;\n468:   }\n469: \n470:   // Everything else requires config\n471:   const config = loadConfig(PROJECT_ROOT);\n472:   validateConfig(config);\n473: \n474:   // Commands that operate on the features file — ensure it exists first\n475:   const needsFeatures = new Set([\"launch\", \"resume\", \"verify\", \"retry\", \"features\"]);\n476:   if (needsFeatures.has(args.command)) {\n477:     await ensureFeaturesFile(PROJECT_ROOT, config);\n478:   }\n479: \n480:   switch (args.command) {\n481:     case \"launch\":\n482:       await cmdLaunch({\n483:         projectRoot: PROJECT_ROOT,\n484:         config,\n485:         topPriority: args.topPriority,\n486:         quickestWins: args.quickestWins,\n487:         priority: args.priority,\n488:         difficulty: args.difficulty,\n489:         features: args.features,\n490:         allReady: args.allReady,\n491:         maxConcurrent: args.maxConcurrent ?? config.defaults.maxConcurrent,\n492:         model: args.model,\n493:         interactive: args.interactive,\n494:         dryRun: args.dryRun,\n495:         baseBranch: args.baseBranch ?? config.baseBranch,\n496:         maxRetries: args.maxRetries ?? config.defaults.maxRetries,\n497:         noTui: args.noTui,\n498:         autoPush: args.autoPush,\n499:       });\n500:       break;\n501: \n502:     case \"resume\":\n503:       await cmdResume({\n504:         projectRoot: PROJECT_ROOT,\n505:         config,\n506:         maxConcurrent: args.maxConcurrent,\n507:         model: args.model,\n508:         interactive: args.interactive,\n509:         noTui: args.noTui,\n510:         autoPush: args.autoPush,\n511:         baseBranch: args.baseBranch,\n512:         maxRetries: args.maxRetries,\n513:       });\n514:       break;\n515: \n516:     case \"status\":\n517:       await cmdStatus({ projectRoot: PROJECT_ROOT, config });\n518:       break;\n519: \n520:     case \"verify\":\n521:       await cmdVerify({\n522:         projectRoot: PROJECT_ROOT,\n523:         config,\n524:         featureId: args.featureId,\n525:         model: args.model,\n526:         maxRetries: args.maxRetries,\n527:       });\n528:       break;\n529: \n530:     case \"merge\":\n531:       await cmdMerge({\n532:         projectRoot: PROJECT_ROOT,\n533:         config,\n534:         featureId: args.featureId,\n535:         autoPush: args.autoPush,\n536:         dryRun: args.dryRun,\n537:       });\n538:       break;\n539: \n540:     case \"retry\": {\n541:       if (!args.featureId) {\n542:         console.error(\"Usage: wombo retry <feature-id>\");\n543:         process.exit(1);\n544:         return;\n545:       }\n546:       await cmdRetry({\n547:         projectRoot: PROJECT_ROOT,\n548:         config,\n549:         featureId: args.featureId,\n550:         model: args.model,\n551:         interactive: args.interactive,\n552:         dryRun: args.dryRun,\n553:       });\n554:       break;\n555:     }\n556: \n557:     case \"cleanup\":\n558:       await cmdCleanup({ projectRoot: PROJECT_ROOT, config, dryRun: args.dryRun });\n559:       break;\n560: \n561:     case \"features\":\n562:       await handleFeaturesSubcommand(args, PROJECT_ROOT, config);\n563:       break;\n564: \n565:     default:\n566:       console.error(`Unknown command: ${args.command}`);\n567:       cmdHelp();\n568:       process.exit(1);\n569:       return;\n570:   }\n571: }\n572: \n573: // ---------------------------------------------------------------------------\n574: // Features Subcommand Router\n575: // ---------------------------------------------------------------------------\n576: \n577: async function handleFeaturesSubcommand(\n578:   args: CLIArgs,\n579:   projectRoot: string,\n580:   config: import(\"./config.js\").WomboConfig\n581: ): Promise<void> {\n582:   switch (args.subcommand) {\n583:     case \"list\":\n584:     case \"ls\":\n585:       await cmdFeaturesList({\n586:         projectRoot,\n587:         config,\n588:         status: args.status as FeatureStatus | undefined,\n589:         priority: args.priority,\n590:         difficulty: args.difficulty,\n591:         ready: args.ready,\n592:         includeArchive: args.includeArchive,\n593:         outputFmt: args.outputFmt,\n594:         fields: args.fields,\n595:       });\n596:       break;\n597: \n598:     case \"add\": {\n599:       if (!args.featureId || !args.title) {\n600:         console.error(\"Usage: wombo features add <id> <title> [--desc <desc>] [--priority <p>] [--difficulty <d>] [--effort <e>] [--depends-on <ids>]\");\n601:         process.exit(1);\n602:         return;\n603:       }\n604:       await cmdFeaturesAdd({\n605:         projectRoot,\n606:         config,\n607:         id: args.featureId,\n608:         title: args.title,\n609:         description: args.description,\n610:         priority: args.priority,\n611:         difficulty: args.difficulty,\n612:         effort: args.effort,\n613:         dependsOn: args.dependsOn,\n614:         outputFmt: args.outputFmt,\n615:         dryRun: args.dryRun,\n616:       });\n617:       break;\n618:     }\n619: \n620:     case \"set-status\": {\n621:       if (!args.featureId || !args.title) {\n622:         // title holds the second positional arg (the status value)\n623:         // If not provided via positional, check --status flag\n624:         const newStatus = args.title || args.status;\n625:         if (!args.featureId || !newStatus) {\n626:           console.error(\"Usage: wombo features set-status <feature-id> <status>\");\n627:           process.exit(1);\n628:           return;\n629:         }\n630:         await cmdFeaturesSetStatus({\n631:           projectRoot,\n632:           config,\n633:           featureId: args.featureId,\n634:           newStatus,\n635:           outputFmt: args.outputFmt,\n636:           dryRun: args.dryRun,\n637:         });\n638:       } else {\n639:         await cmdFeaturesSetStatus({\n640:           projectRoot,\n641:           config,\n642:           featureId: args.featureId,\n643:           newStatus: args.title, // second positional = new status\n644:           outputFmt: args.outputFmt,\n645:           dryRun: args.dryRun,\n646:         });\n647:       }\n648:       break;\n649:     }\n650: \n651:     case \"check\":\n652:     case \"validate\":\n653:       await cmdFeaturesCheck({ projectRoot, config, outputFmt: args.outputFmt });\n654:       break;\n655: \n656:     case \"archive\":\n657:       await cmdFeaturesArchive({\n658:         projectRoot,\n659:         config,\n660:         featureId: args.featureId,\n661:         dryRun: args.dryRun,\n662:         outputFmt: args.outputFmt,\n663:       });\n664:       break;\n665: \n666:     case \"show\": {\n667:       if (!args.featureId) {\n668:         console.error(\"Usage: wombo features show <feature-id>\");\n669:         process.exit(1);\n670:         return;\n671:       }\n672:       await cmdFeaturesShow({\n673:         projectRoot,\n674:         config,\n675:         featureId: args.featureId,\n676:         outputFmt: args.outputFmt,\n677:         fields: args.fields,\n678:       });\n679:       break;\n680:     }\n681: \n682:     case \"graph\":\n683:       await cmdFeaturesGraph({\n684:         projectRoot,\n685:         config,\n686:         status: args.status as FeatureStatus | undefined,\n687:         ascii: args.ascii,\n688:         mermaid: args.mermaidRaw,\n689:         subtasks: args.graphSubtasks,\n690:         outputFmt: args.outputFmt,\n691:       });\n692:       break;\n693: \n694:     case \"help\":\n695:     case \"--help\":\n696:     case \"-h\":\n697:       cmdHelp();\n698:       break;\n699: \n700:     default:\n701:       console.error(`Unknown features subcommand: ${args.subcommand}`);\n702:       console.error(\"Run 'wombo features help' or 'wombo help' for usage.\");\n703:       process.exit(1);\n704:       return;\n705:   }\n706: }\n707: \n708: // ---------------------------------------------------------------------------\n709: // Error Handlers & Entry\n710: // ---------------------------------------------------------------------------\n711: \n712: // Global error handlers — prevent silent crashes\n713: process.on(\"uncaughtException\", (err) => {\n714:   console.error(`\\n[FATAL] Uncaught exception: ${err.message}`);\n715:   console.error(err.stack);\n716:   try {\n717:     const state = loadState(process.cwd());\n718:     if (state) saveState(process.cwd(), state);\n719:   } catch {}\n720:   process.exit(1);\n721: });\n722: \n723: process.on(\"unhandledRejection\", (reason: any) => {\n724:   console.error(`\\n[FATAL] Unhandled rejection: ${reason?.message || reason}`);\n725:   if (reason?.stack) console.error(reason.stack);\n726:   try {\n727:     const state = loadState(process.cwd());\n728:     if (state) saveState(process.cwd(), state);\n729:   } catch {}\n730:   process.exit(1);\n731: });\n732: \n733: main().catch((err) => {\n734:   console.error(\"Fatal error:\", err.message);\n735:   process.exit(1);\n736: });\n\n(End of file - total 736 lines)\n</content>","title":"src/index.ts","metadata":{"preview":"#!/usr/bin/env bun\n/**\n * index.ts — CLI entry point for the Wombo agent orchestration system.\n *\n * Usage:\n *   wombo init\n *   wombo launch --top-priority 3\n *   wombo launch --quickest-wins 5\n *   wombo launch --priority high\n *   wombo launch --difficulty easy\n *   wombo launch --features \"feat-a,feat-b\"\n *   wombo launch --all-ready\n *   wombo launch ... --max-concurrent 3 --model \"anthropic/claude-sonnet-4-20250514\"\n *   wombo launch ... --interactive\n *   wombo resume\n *   wombo status\n *   wombo verify [feature-id]\n *   wombo merge [feature-id]\n *   wombo retry <feature-id>\n *   wombo cleanup","truncated":false,"loaded":[]},"time":{"start":1773351874125,"end":1773351874129}}}}
{"type":"tool_use","timestamp":1773351874552,"sessionID":"ses_31c036d66ffeb3gOzUVP7hTP5i","part":{"id":"prt_ce4022eb9001Z3W06BHE20pTGb","sessionID":"ses_31c036d66ffeb3gOzUVP7hTP5i","messageID":"msg_ce4021d10001boYRn5H8KP8Zw8","type":"tool","callID":"toolu_vrtx_01FZVvKuuaNjo4vWfdexVxTq","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-json-output-complete/src/commands/resume.ts"},"output":"<path>/home/fulgidus/Documents/wombo-json-output-complete/src/commands/resume.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * resume.ts — Resume a previously stopped wave.\n3:  *\n4:  * Usage: wombo resume [options]\n5:  *\n6:  * Restores from .wombo-state.json:\n7:  *   - Agents in \"running\"/\"installing\" whose PID is dead → re-check or re-launch\n8:  *   - Agents in \"queued\" → launch them\n9:  *   - Agents in terminal states (verified/failed/merged) → leave alone\n10:  */\n11: \n12: import type { WomboConfig } from \"../config.js\";\n13: import type { Feature } from \"../lib/features.js\";\n14: import { loadFeatures } from \"../lib/features.js\";\n15: import {\n16:   loadState,\n17:   saveState,\n18:   updateAgent,\n19:   queuedAgents,\n20:   isWaveComplete,\n21:   type WaveState,\n22:   type AgentState,\n23: } from \"../lib/state.js\";\n24: import {\n25:   createWorktree,\n26:   installDeps,\n27:   worktreeReady,\n28:   worktreeExists,\n29:   branchHasChanges,\n30:   removeWorktree,\n31:   log as wtLog,\n32: } from \"../lib/worktree.js\";\n33: import { generatePrompt } from \"../lib/prompt.js\";\n34: import {\n35:   launchInteractive,\n36:   isProcessRunning,\n37: } from \"../lib/launcher.js\";\n38: import { ProcessMonitor } from \"../lib/monitor.js\";\n39: import { pushBaseBranch } from \"../lib/merger.js\";\n40: import { runBuild } from \"../lib/verifier.js\";\n41: import { printDashboard, printAgentUpdate } from \"../lib/ui.js\";\n42: import { WomboTUI } from \"../lib/tui.js\";\n43: import {\n44:   launchSingleHeadless,\n45:   handleBuildVerification,\n46:   handleRetry,\n47:   launchNextQueued,\n48:   markFeatureDone,\n49:   attemptMerge,\n50: } from \"./launch.js\";\n51: \n52: import { outputError, outputMessage, type OutputFormat } from \"../lib/output.js\";\n53: \n54: // ---------------------------------------------------------------------------\n55: // Types\n56: // ---------------------------------------------------------------------------\n57: \n58: export interface ResumeCommandOptions {\n59:   projectRoot: string;\n60:   config: WomboConfig;\n61:   maxConcurrent?: number;\n62:   model?: string;\n63:   interactive: boolean;\n64:   noTui: boolean;\n65:   autoPush: boolean;\n66:   baseBranch?: string;\n67:   maxRetries?: number;\n68:   outputFmt?: OutputFormat;\n69: }\n70: \n71: // ---------------------------------------------------------------------------\n72: // Command\n73: // ---------------------------------------------------------------------------\n74: \n75: export async function cmdResume(opts: ResumeCommandOptions): Promise<void> {\n76:   const { projectRoot, config } = opts;\n77:   const fmt = opts.outputFmt ?? \"text\";\n78: \n79:   const state = loadState(projectRoot);\n80:   if (!state) {\n81:     outputError(fmt, \"No wave state found. Use 'wombo launch' to start a new wave.\");\n82:     return; // unreachable — helps TypeScript narrow\n83:   }\n84: \n85:   if (fmt !== \"json\") {\n86:     console.log(`\\n--- Wombo: Resume ${state.wave_id} ---\\n`);\n87:   }\n88: \n89:   // Load feature data for prompt generation\n90:   const data = loadFeatures(projectRoot, config);\n91:   const featureMap = new Map(data.features.map((f) => [f.id, f]));\n92: \n93:   // Triage agents by current state\n94:   let toRelaunch: AgentState[] = [];\n95:   let toVerify: AgentState[] = [];\n96: \n97:   for (const agent of state.agents) {\n98:     switch (agent.status) {\n99:       case \"running\":\n100:       case \"installing\":\n101:       case \"retry\":\n102:       case \"resolving_conflict\":\n103:         // Was in-flight when we stopped — check if PID is still alive\n104:         if (agent.pid && isProcessRunning(agent.pid)) {\n105:           console.log(`  ${agent.feature_id}: still running (PID ${agent.pid}), leaving alone`);\n106:         } else {\n107:           // Process is dead — check if worktree exists with meaningful changes.\n108:           // Use worktreeExists (not worktreeReady) because node_modules may be\n109:           // missing — the worktree still has code that should be verified.\n110:           if (worktreeExists(agent.worktree) && branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n111:             // Worktree exists AND branch has commits — try build verification\n112:             console.log(`  ${agent.feature_id}: process dead, worktree has changes — will verify build`);\n113:             toVerify.push(agent);\n114:           } else {\n115:             // No worktree, or worktree exists but branch has no commits (agent did nothing)\n116:             const reason = worktreeExists(agent.worktree)\n117:               ? \"worktree exists but no code changes\"\n118:               : \"no worktree\";\n119:             console.log(`  ${agent.feature_id}: process dead, ${reason} — will re-launch`);\n120:             updateAgent(state, agent.feature_id, {\n121:               status: \"queued\",\n122:               pid: null,\n123:               activity: null,\n124:               session_id: null,\n125:             });\n126:             toRelaunch.push(agent);\n127:           }\n128:         }\n129:         break;\n130: \n131:       case \"queued\":\n132:         console.log(`  ${agent.feature_id}: queued — will launch`);\n133:         toRelaunch.push(agent);\n134:         break;\n135: \n136:       case \"completed\":\n137:         // Completed but not verified — verify\n138:         console.log(`  ${agent.feature_id}: completed — will verify build`);\n139:         toVerify.push(agent);\n140:         break;\n141: \n142:       case \"verified\":\n143:         // Build passed but NOT yet merged — need to attempt merge (+ conflict resolution)\n144:         console.log(`  ${agent.feature_id}: verified — will attempt merge`);\n145:         toVerify.push(agent);\n146:         break;\n147: \n148:       case \"merged\":\n149:         console.log(`  ${agent.feature_id}: merged — marking feature as done`);\n150:         markFeatureDone(projectRoot, agent.feature_id, config, state.base_branch);\n151:         try {\n152:           removeWorktree(projectRoot, agent.worktree, true);\n153:           console.log(`  ${agent.feature_id}: worktree and branch removed`);\n154:         } catch {\n155:           // Already cleaned — not critical\n156:         }\n157:         break;\n158: \n159:       case \"failed\":\n160:         // If the worktree exists with code changes and retries remain,\n161:         // attempt build verification rather than discarding the work.\n162:         if (agent.retries < agent.max_retries &&\n163:             worktreeExists(agent.worktree) &&\n164:             branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n165:           console.log(`  ${agent.feature_id}: failed but has work (retry ${agent.retries}/${agent.max_retries}) — will verify build`);\n166:           // Clear stale error and mark as completed so handleBuildVerification\n167:           // processes it correctly (it expects a non-failed agent)\n168:           updateAgent(state, agent.feature_id, {\n169:             status: \"completed\",\n170:             error: null,\n171:             build_passed: null,\n172:             build_output: null,\n173:             completed_at: new Date().toISOString(),\n174:           });\n175:           toVerify.push(agent);\n176:         } else if (agent.retries < agent.max_retries) {\n177:           // No worktree or no changes — re-launch from scratch\n178:           console.log(`  ${agent.feature_id}: failed, no salvageable work (retry ${agent.retries}/${agent.max_retries}) — will re-launch`);\n179:           updateAgent(state, agent.feature_id, {\n180:             status: \"queued\",\n181:             pid: null,\n182:             error: null,\n183:             build_passed: null,\n184:             build_output: null,\n185:             activity: null,\n186:             session_id: null,\n187:             completed_at: null,\n188:           });\n189:           toRelaunch.push(agent);\n190:         } else {\n191:           console.log(`  ${agent.feature_id}: failed — max retries reached (use 'wombo retry' to reset)`);\n192:         }\n193:         break;\n194:     }\n195:   }\n196: \n197:   saveState(projectRoot, state);\n198: \n199:   // ---------------------------------------------------------------------------\n200:   // Phase 1: Parallel build verification\n201:   // Each agent's worktree is independent, so dep install + build can run\n202:   // concurrently. Merges must remain sequential (they mutate the project root).\n203:   // ---------------------------------------------------------------------------\n204:   if (toVerify.length > 0) {\n205:     console.log(`\\nVerifying ${toVerify.length} agent(s) in parallel...\\n`);\n206: \n207:     const verifyResults = await Promise.all(\n208:       toVerify.map(async (agent): Promise<{ agent: AgentState; needsMerge: boolean }> => {\n209:         const feature = featureMap.get(agent.feature_id);\n210:         if (!feature) return { agent, needsMerge: false };\n211: \n212:         // Already verified — skip build, go straight to merge\n213:         if (agent.status === \"verified\") {\n214:           printAgentUpdate(agent, \"already verified — queued for merge\");\n215:           return { agent, needsMerge: true };\n216:         }\n217: \n218:         printAgentUpdate(agent, \"verifying build...\");\n219: \n220:         // Ensure deps are installed — worktree may exist without node_modules\n221:         // (e.g., failed agents whose setup was interrupted)\n222:         if (!worktreeReady(agent.worktree) && worktreeExists(agent.worktree)) {\n223:           try {\n224:             printAgentUpdate(agent, \"installing deps...\");\n225:             await installDeps(agent.worktree, agent.feature_id, config);\n226:           } catch (depErr: any) {\n227:             printAgentUpdate(agent, `dep install failed: ${depErr.message}`);\n228:             updateAgent(state, agent.feature_id, {\n229:               status: \"failed\",\n230:               error: `Dependency install failed: ${depErr.message}`,\n231:               retries: agent.retries + 1,\n232:               completed_at: new Date().toISOString(),\n233:             });\n234:             saveState(projectRoot, state);\n235:             return { agent, needsMerge: false };\n236:           }\n237:         }\n238: \n239:         try {\n240:           const buildResult = await runBuild(agent.worktree, config);\n241:           if (buildResult.passed) {\n242:             updateAgent(state, agent.feature_id, {\n243:               status: \"verified\",\n244:               build_passed: true,\n245:               build_output: null,\n246:             });\n247:             saveState(projectRoot, state);\n248:             printAgentUpdate(agent, `BUILD PASSED (${Math.round(buildResult.durationMs / 1000)}s)`);\n249:             return { agent, needsMerge: true };\n250:           } else {\n251:             // Build failed\n252:             if (agent.retries < agent.max_retries) {\n253:               updateAgent(state, agent.feature_id, {\n254:                 status: \"retry\",\n255:                 retries: agent.retries + 1,\n256:                 build_passed: false,\n257:                 build_output: buildResult.errorSummary,\n258:               });\n259:               saveState(projectRoot, state);\n260:               printAgentUpdate(agent, `BUILD FAILED — will retry (${agent.retries + 1}/${agent.max_retries})`);\n261:             } else {\n262:               updateAgent(state, agent.feature_id, {\n263:                 status: \"failed\",\n264:                 build_passed: false,\n265:                 build_output: buildResult.errorSummary,\n266:                 error: `Build failed after ${agent.max_retries} retries`,\n267:                 completed_at: new Date().toISOString(),\n268:               });\n269:               saveState(projectRoot, state);\n270:               printAgentUpdate(agent, \"BUILD FAILED — max retries reached\");\n271:             }\n272:             return { agent, needsMerge: false };\n273:           }\n274:         } catch (err: any) {\n275:           printAgentUpdate(agent, `verify error: ${err.message}`);\n276:           updateAgent(state, agent.feature_id, {\n277:             status: \"failed\",\n278:             error: `Build verification error: ${err.message}`,\n279:             completed_at: new Date().toISOString(),\n280:           });\n281:           saveState(projectRoot, state);\n282:           return { agent, needsMerge: false };\n283:         }\n284:       })\n285:     );\n286: \n287:     saveState(projectRoot, state);\n288: \n289:     // -------------------------------------------------------------------------\n290:     // Phase 2: Sequential merge for verified agents\n291:     // Merges must be sequential because they operate on the project root.\n292:     // -------------------------------------------------------------------------\n293:     const toMerge = verifyResults.filter((r) => r.needsMerge);\n294:     if (toMerge.length > 0) {\n295:       console.log(`\\nMerging ${toMerge.length} verified agent(s)...\\n`);\n296:       for (const { agent } of toMerge) {\n297:         const feature = featureMap.get(agent.feature_id);\n298:         if (!feature) continue;\n299:         try {\n300:           await attemptMerge(projectRoot, state, agent, feature, config, opts.model);\n301:         } catch (err: any) {\n302:           printAgentUpdate(agent, `merge error: ${err.message}`);\n303:         }\n304:       }\n305:     }\n306: \n307:     // Collect agents that need re-launching from verify results\n308:     for (const { agent } of verifyResults) {\n309:       if (agent.status === \"retry\" || agent.status === \"running\") {\n310:         toRelaunch.push(agent);\n311:       }\n312:     }\n313:   }\n314: \n315:   // Re-launch agents\n316:   const maxConcurrent = opts.maxConcurrent ?? state.max_concurrent;\n317:   const toLaunchNow = toRelaunch.slice(0, maxConcurrent);\n318:   if (toLaunchNow.length === 0) {\n319:     console.log(\"\\nNo agents need (re)launching.\");\n320:     printDashboard(state);\n321:     return;\n322:   }\n323: \n324:   console.log(`\\nRe-launching ${toLaunchNow.length} agent(s)...\\n`);\n325:   printDashboard(state);\n326: \n327:   const model = opts.model ?? state.model ?? undefined;\n328: \n329:   if (opts.interactive) {\n330:     // Interactive resume\n331:     await Promise.all(\n332:       toLaunchNow.map(async (agent) => {\n333:         const feature = featureMap.get(agent.feature_id);\n334:         if (!feature) return;\n335: \n336:         updateAgent(state, agent.feature_id, {\n337:           status: \"installing\",\n338:           started_at: new Date().toISOString(),\n339:           activity: \"resuming...\",\n340:         });\n341:         saveState(projectRoot, state);\n342: \n343:         try {\n344:           if (!worktreeReady(agent.worktree)) {\n345:             await createWorktree(projectRoot, agent.feature_id, state.base_branch, config);\n346:             await installDeps(agent.worktree, agent.feature_id, config);\n347:           }\n348: \n349:           const prompt = generatePrompt(feature, state.base_branch, config);\n350:           const result = launchInteractive({\n351:             worktreePath: agent.worktree,\n352:             featureId: feature.id,\n353:             prompt,\n354:             model,\n355:             interactive: true,\n356:             config,\n357:           });\n358: \n359:           updateAgent(state, agent.feature_id, {\n360:             status: \"running\",\n361:             pid: result.pid,\n362:             activity: \"tmux session active\",\n363:           });\n364:           saveState(projectRoot, state);\n365:         } catch (err: any) {\n366:           updateAgent(state, agent.feature_id, {\n367:             status: \"failed\",\n368:             error: err.message,\n369:             activity: null,\n370:             completed_at: new Date().toISOString(),\n371:           });\n372:           saveState(projectRoot, state);\n373:         }\n374:       })\n375:     );\n376: \n377:     printDashboard(state);\n378:     console.log(`\\nResume complete. Use 'tmux attach -t ${config.agent.tmuxPrefix}-<id>' to check sessions.`);\n379:   } else {\n380:     // Headless resume — re-enter monitoring loop\n381:     const monitor = new ProcessMonitor(projectRoot, {\n382:       onSessionId: (featureId, sessionId) => {\n383:         updateAgent(state, featureId, { session_id: sessionId });\n384:         saveState(projectRoot, state);\n385:       },\n386:       onComplete: (featureId) => {\n387:         updateAgent(state, featureId, {\n388:           status: \"completed\",\n389:           completed_at: new Date().toISOString(),\n390:           activity: \"done\",\n391:         });\n392:         saveState(projectRoot, state);\n393:         wtLog(featureId, \"agent completed — verifying build...\");\n394: \n395:         const agent = state.agents.find((a) => a.feature_id === featureId)!;\n396:         const feature = featureMap.get(featureId)!;\n397:         handleBuildVerification(projectRoot, state, agent, feature, config, model, monitor)\n398:           .then(() => launchNextQueued(projectRoot, state, featureMap, monitor, config, model))\n399:           .catch((err) => {\n400:             wtLog(featureId, `BUILD VERIFICATION UNHANDLED ERROR: ${err.message}`);\n401:             launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n402:           });\n403:       },\n404:       onError: (featureId, error) => {\n405:         const agent = state.agents.find((a) => a.feature_id === featureId)!;\n406:         if (agent.retries < agent.max_retries) {\n407:           updateAgent(state, featureId, {\n408:             status: \"retry\",\n409:             retries: agent.retries + 1,\n410:             error,\n411:             activity: \"retrying...\",\n412:           });\n413:           saveState(projectRoot, state);\n414:           handleRetry(projectRoot, state, agent, monitor, config, model);\n415:         } else {\n416:           updateAgent(state, featureId, {\n417:             status: \"failed\",\n418:             error,\n419:             activity: null,\n420:             completed_at: new Date().toISOString(),\n421:           });\n422:           saveState(projectRoot, state);\n423:         }\n424:         launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n425:       },\n426:       onActivity: (featureId, activity) => {\n427:         updateAgent(state, featureId, {\n428:           activity,\n429:           activity_updated_at: new Date().toISOString(),\n430:         });\n431:       },\n432:     });\n433: \n434:     // Handle graceful shutdown\n435:     const tuiRef = { current: null as WomboTUI | null };\n436:     process.on(\"SIGINT\", () => {\n437:       if (tuiRef.current) tuiRef.current.stop();\n438:       for (const agent of state.agents) {\n439:         if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n440:           updateAgent(state, agent.feature_id, {\n441:             activity: \"interrupted\",\n442:           });\n443:         }\n444:       }\n445:       monitor.killAll();\n446:       saveState(projectRoot, state);\n447:       console.log(\"\\nState saved. Use 'wombo resume' to continue.\");\n448:       process.exit(0);\n449:     });\n450: \n451:     await Promise.all(\n452:       toLaunchNow.map((agent) => {\n453:         const feature = featureMap.get(agent.feature_id);\n454:         if (!feature) return Promise.resolve();\n455:         return launchSingleHeadless(projectRoot, state, agent, feature, monitor, config, model);\n456:       })\n457:     );\n458: \n459:     // Start TUI dashboard (or skip if --no-tui)\n460:     if (!opts.noTui) {\n461:       tuiRef.current = new WomboTUI({\n462:         state,\n463:         monitor,\n464:         projectRoot,\n465:         interactive: false,\n466:         config,\n467:         onQuit: () => {\n468:           for (const agent of state.agents) {\n469:             if (agent.status === \"running\") {\n470:               updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n471:             }\n472:           }\n473:           monitor.killAll();\n474:           saveState(projectRoot, state);\n475:           console.log(\"State saved. Use 'wombo resume' to continue.\");\n476:           process.exit(0);\n477:         },\n478:       });\n479:       tuiRef.current.start();\n480:     } else {\n481:       console.log(\"(--no-tui mode, dashboard prints every 15s)\\n\");\n482:       printDashboard(state);\n483:     }\n484: \n485:     // Monitoring loop\n486:     const POLL_INTERVAL = 5000;\n487:     let dashboardCounter = 0;\n488:     while (!isWaveComplete(state)) {\n489:       await new Promise((r) => setTimeout(r, POLL_INTERVAL));\n490: \n491:       for (const agent of state.agents) {\n492:         if (\n493:           (agent.status === \"running\" || agent.status === \"resolving_conflict\") &&\n494:           agent.pid &&\n495:           !isProcessRunning(agent.pid) &&\n496:           !monitor.isRunning(agent.feature_id)\n497:         ) {\n498:           if (agent.status === \"resolving_conflict\") {\n499:             // Conflict resolver died unexpectedly — mark as failed\n500:             updateAgent(state, agent.feature_id, {\n501:               status: \"failed\",\n502:               error: \"Conflict resolver process died unexpectedly\",\n503:               activity: null,\n504:               completed_at: new Date().toISOString(),\n505:             });\n506:             saveState(projectRoot, state);\n507:             wtLog(agent.feature_id, \"conflict resolver died — marked failed\");\n508:             launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n509:             continue;\n510:           }\n511:           // Check if the agent actually made any commits\n512:           if (!branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n513:             // Agent died without producing any code — mark as failed\n514:             updateAgent(state, agent.feature_id, {\n515:               status: \"failed\",\n516:               error: \"Agent process exited without making any commits\",\n517:               activity: null,\n518:               completed_at: new Date().toISOString(),\n519:             });\n520:             saveState(projectRoot, state);\n521:             wtLog(agent.feature_id, \"process died with no code changes — marked failed\");\n522:           } else {\n523:             updateAgent(state, agent.feature_id, {\n524:               status: \"completed\",\n525:               completed_at: new Date().toISOString(),\n526:               activity: \"done\",\n527:             });\n528:             saveState(projectRoot, state);\n529:             const feature = featureMap.get(agent.feature_id)!;\n530:             try {\n531:               await handleBuildVerification(projectRoot, state, agent, feature, config, model, monitor);\n532:             } catch (err: any) {\n533:               wtLog(agent.feature_id, `POLL VERIFY ERROR: ${err.message}`);\n534:             }\n535:           }\n536:           launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n537:         }\n538:       }\n539: \n540:       saveState(projectRoot, state);\n541:       if (tuiRef.current) {\n542:         tuiRef.current.updateState(state);\n543:       } else if (opts.noTui) {\n544:         dashboardCounter++;\n545:         if (dashboardCounter % 3 === 0) {\n546:           printDashboard(state);\n547:         }\n548:       }\n549:     }\n550: \n551:     if (tuiRef.current) tuiRef.current.stop();\n552:     printDashboard(state);\n553: \n554:     // Auto-push base branch if requested\n555:     if (opts.autoPush) {\n556:       await pushBaseBranch(projectRoot, state.base_branch, config);\n557:     }\n558: \n559:     console.log(\"Wave complete.\");\n560:   }\n561: }\n\n(End of file - total 561 lines)\n</content>","title":"src/commands/resume.ts","metadata":{"preview":"/**\n * resume.ts — Resume a previously stopped wave.\n *\n * Usage: wombo resume [options]\n *\n * Restores from .wombo-state.json:\n *   - Agents in \"running\"/\"installing\" whose PID is dead → re-check or re-launch\n *   - Agents in \"queued\" → launch them\n *   - Agents in terminal states (verified/failed/merged) → leave alone\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport type { Feature } from \"../lib/features.js\";\nimport { loadFeatures } from \"../lib/features.js\";\nimport {\n  loadState,\n  saveState,\n  updateAgent,\n  queuedAgents,\n  isWaveComplete,","truncated":false,"loaded":[]},"time":{"start":1773351874545,"end":1773351874551}}}}
{"type":"tool_use","timestamp":1773351875058,"sessionID":"ses_31c036d66ffeb3gOzUVP7hTP5i","part":{"id":"prt_ce402305d001jzPubl32sTUaN9","sessionID":"ses_31c036d66ffeb3gOzUVP7hTP5i","messageID":"msg_ce4021d10001boYRn5H8KP8Zw8","type":"tool","callID":"toolu_vrtx_01PHE9ZaBpcRtFCitYmF9epU","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-json-output-complete/src/commands/launch.ts"},"output":"<path>/home/fulgidus/Documents/wombo-json-output-complete/src/commands/launch.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * launch.ts — Launch a wave of agents.\n3:  *\n4:  * Usage: wombo launch [selection options] [launch options]\n5:  *\n6:  * This is the primary entry point for starting a new wave. It selects features\n7:  * from the features file, creates a wave state, sets up worktrees, and launches\n8:  * agent processes (either headless or interactive via tmux).\n9:  *\n10:  * IMPORTANT: This file also exports shared helper functions that are reused\n11:  * by resume.ts and other commands:\n12:  *   - launchSingleHeadless\n13:  *   - handleBuildVerification\n14:  *   - handleRetry\n15:  *   - launchNextQueued\n16:  */\n17: \n18: import { execSync } from \"node:child_process\";\n19: import type { WomboConfig } from \"../config.js\";\n20: import type { Feature, SelectionOptions, Priority, Difficulty } from \"../lib/features.js\";\n21: import { loadFeatures, selectFeatures, parseDurationMinutes, saveFeatures } from \"../lib/features.js\";\n22: import {\n23:   loadState,\n24:   saveState,\n25:   createWaveState,\n26:   createAgentState,\n27:   updateAgent,\n28:   activeAgents,\n29:   queuedAgents,\n30:   isWaveComplete,\n31:   type WaveState,\n32:   type AgentState,\n33: } from \"../lib/state.js\";\n34: import {\n35:   createWorktree,\n36:   installDeps,\n37:   featureBranchName,\n38:   worktreePath,\n39:   worktreeReady,\n40:   branchHasChanges,\n41:   removeWorktree,\n42:   log as wtLog,\n43: } from \"../lib/worktree.js\";\n44: import { generatePrompt, generateConflictResolutionPrompt } from \"../lib/prompt.js\";\n45: import {\n46:   launchHeadless,\n47:   retryHeadless,\n48:   launchInteractive,\n49:   retryInteractive,\n50:   launchConflictResolver,\n51:   isProcessRunning,\n52: } from \"../lib/launcher.js\";\n53: import { ProcessMonitor } from \"../lib/monitor.js\";\n54: import { runBuild } from \"../lib/verifier.js\";\n55: import { mergeBranch, mergeBaseIntoFeature, pushBaseBranch } from \"../lib/merger.js\";\n56: import {\n57:   printDashboard,\n58:   printFeatureSelection,\n59:   printAgentUpdate,\n60: } from \"../lib/ui.js\";\n61: import { WomboTUI } from \"../lib/tui.js\";\n62: import { ensureAgentDefinition } from \"../lib/templates.js\";\n63: \n64: // ---------------------------------------------------------------------------\n65: // Types\n66: // ---------------------------------------------------------------------------\n67: \n68: import { output, outputError, type OutputFormat } from \"../lib/output.js\";\n69: \n70: export interface LaunchCommandOptions {\n71:   projectRoot: string;\n72:   config: WomboConfig;\n73:   // Selection\n74:   topPriority?: number;\n75:   quickestWins?: number;\n76:   priority?: Priority;\n77:   difficulty?: Difficulty;\n78:   features?: string[];\n79:   allReady?: boolean;\n80:   // Launch\n81:   maxConcurrent: number;\n82:   model?: string;\n83:   interactive: boolean;\n84:   dryRun: boolean;\n85:   baseBranch: string;\n86:   maxRetries: number;\n87:   noTui: boolean;\n88:   autoPush: boolean;\n89:   outputFmt?: OutputFormat;\n90: }\n91: \n92: // ---------------------------------------------------------------------------\n93: // Shared Helpers (exported for resume.ts and others)\n94: // ---------------------------------------------------------------------------\n95: \n96: /**\n97:  * Mark a feature as done in the features file after a successful merge.\n98:  * Updates status to \"done\", completion to 100, and sets ended_at.\n99:  *\n100:  * GUARD: Verifies that the feature branch has actually been merged into\n101:  * baseBranch before allowing the status change. This prevents callers\n102:  * from accidentally marking verified-but-unmerged features as done.\n103:  */\n104: export function markFeatureDone(\n105:   projectRoot: string,\n106:   featureId: string,\n107:   config: WomboConfig,\n108:   baseBranch: string\n109: ): void {\n110:   try {\n111:     // Verify the feature branch was actually merged into base\n112:     const branch = featureBranchName(featureId, config);\n113:     try {\n114:       execSync(`git merge-base --is-ancestor \"${branch}\" \"${baseBranch}\"`, {\n115:         cwd: projectRoot,\n116:         stdio: \"pipe\",\n117:       });\n118:     } catch {\n119:       // git merge-base --is-ancestor exits non-zero if NOT an ancestor\n120:       console.error(\n121:         `Warning: ${featureId} branch \"${branch}\" is not merged into \"${baseBranch}\" — refusing to mark as done`\n122:       );\n123:       return;\n124:     }\n125: \n126:     const data = loadFeatures(projectRoot, config);\n127:     const feature = data.features.find((f) => f.id === featureId);\n128:     if (feature && feature.status !== \"done\") {\n129:       feature.status = \"done\";\n130:       feature.completion = 100;\n131:       feature.ended_at = new Date().toISOString();\n132:       saveFeatures(projectRoot, config, data);\n133:     }\n134:   } catch (err: any) {\n135:     // Non-fatal — log but don't crash the wave\n136:     console.error(`Warning: failed to update feature status for ${featureId}: ${err.message}`);\n137:   }\n138: }\n139: \n140: /**\n141:  * Launch a single agent in headless mode.\n142:  * Sets up worktree, installs deps, generates prompt, launches agent process.\n143:  */\n144: export async function launchSingleHeadless(\n145:   projectRoot: string,\n146:   state: WaveState,\n147:   agent: AgentState,\n148:   feature: Feature,\n149:   monitor: ProcessMonitor,\n150:   config: WomboConfig,\n151:   model?: string\n152: ): Promise<void> {\n153:   updateAgent(state, agent.feature_id, {\n154:     status: \"installing\",\n155:     started_at: new Date().toISOString(),\n156:     activity: \"setting up worktree...\",\n157:   });\n158:   saveState(projectRoot, state);\n159: \n160:   try {\n161:     // Skip worktree setup if already ready (resume case)\n162:     if (worktreeReady(agent.worktree)) {\n163:       wtLog(agent.feature_id, \"worktree already exists, skipping setup\");\n164:     } else {\n165:       // Create worktree (async — doesn't block other agents)\n166:       await createWorktree(projectRoot, feature.id, state.base_branch, config);\n167: \n168:       // Install dependencies (async)\n169:       updateAgent(state, agent.feature_id, { activity: \"installing deps...\" });\n170:       await installDeps(agent.worktree, feature.id, config);\n171:     }\n172: \n173:     // Generate prompt\n174:     const prompt = generatePrompt(feature, state.base_branch, config);\n175: \n176:     // Launch agent\n177:     wtLog(agent.feature_id, \"launching agent...\");\n178:     const result = launchHeadless({\n179:       worktreePath: agent.worktree,\n180:       featureId: feature.id,\n181:       prompt,\n182:       model,\n183:       config,\n184:     });\n185: \n186:     updateAgent(state, agent.feature_id, {\n187:       status: \"running\",\n188:       pid: result.pid,\n189:       activity: \"starting...\",\n190:     });\n191:     saveState(projectRoot, state);\n192: \n193:     monitor.addProcess(feature.id, result.process);\n194:     wtLog(agent.feature_id, `running (PID: ${result.pid})`);\n195:   } catch (err: any) {\n196:     updateAgent(state, agent.feature_id, {\n197:       status: \"failed\",\n198:       error: err.message,\n199:       activity: null,\n200:       completed_at: new Date().toISOString(),\n201:     });\n202:     saveState(projectRoot, state);\n203:     wtLog(agent.feature_id, `SETUP FAILED: ${err.message.split(\"\\n\")[0]}`);\n204:   }\n205: }\n206: \n207: /**\n208:  * Handle build verification after agent completion.\n209:  * Runs build, auto-merges on pass, retries on failure if retries remain.\n210:  *\n211:  * ASYNC — runs build and merge without blocking the event loop.\n212:  */\n213: export async function handleBuildVerification(\n214:   projectRoot: string,\n215:   state: WaveState,\n216:   agent: AgentState,\n217:   feature: Feature,\n218:   config: WomboConfig,\n219:   model?: string,\n220:   monitor?: ProcessMonitor\n221: ): Promise<void> {\n222:   try {\n223:     printAgentUpdate(agent, \"verifying build...\");\n224: \n225:     const buildResult = await runBuild(agent.worktree, config);\n226: \n227:     if (buildResult.passed) {\n228:       updateAgent(state, agent.feature_id, {\n229:         status: \"verified\",\n230:         build_passed: true,\n231:         build_output: null,\n232:       });\n233:       saveState(projectRoot, state);\n234:       printAgentUpdate(agent, `BUILD PASSED (${Math.round(buildResult.durationMs / 1000)}s)`);\n235: \n236:       // Auto-merge: attempt merge + conflict resolution\n237:       await attemptMerge(projectRoot, state, agent, feature, config, model);\n238:     } else {\n239:       if (agent.retries < agent.max_retries) {\n240:         updateAgent(state, agent.feature_id, {\n241:           status: \"retry\",\n242:           retries: agent.retries + 1,\n243:           build_passed: false,\n244:           build_output: buildResult.errorSummary,\n245:         });\n246:         saveState(projectRoot, state);\n247:         printAgentUpdate(\n248:           agent,\n249:           `BUILD FAILED — retrying (${agent.retries}/${agent.max_retries})`\n250:         );\n251: \n252:         // Retry with build errors\n253:         if (agent.session_id) {\n254:           const retryResult = retryHeadless({\n255:             worktreePath: agent.worktree,\n256:             featureId: agent.feature_id,\n257:             sessionId: agent.session_id,\n258:             buildErrors: buildResult.errorSummary,\n259:             model,\n260:             config,\n261:           });\n262: \n263:           updateAgent(state, agent.feature_id, {\n264:             status: \"running\",\n265:             pid: retryResult.pid,\n266:           });\n267:           saveState(projectRoot, state);\n268: \n269:           // Add retry process to monitor so events are tracked\n270:           if (monitor) {\n271:             monitor.addProcess(agent.feature_id, retryResult.process);\n272:           }\n273:         }\n274:       } else {\n275:         updateAgent(state, agent.feature_id, {\n276:           status: \"failed\",\n277:           build_passed: false,\n278:           build_output: buildResult.errorSummary,\n279:           error: `Build failed after ${agent.max_retries} retries`,\n280:           completed_at: new Date().toISOString(),\n281:         });\n282:         saveState(projectRoot, state);\n283:         printAgentUpdate(agent, \"BUILD FAILED — max retries reached\");\n284:       }\n285:     }\n286:   } catch (err: any) {\n287:     // Catch-all — never let build verification crash the process\n288:     printAgentUpdate(agent, `VERIFY ERROR: ${err.message?.slice(0, 100)}`);\n289:     updateAgent(state, agent.feature_id, {\n290:       status: \"failed\",\n291:       error: `Build verification error: ${err.message}`,\n292:       completed_at: new Date().toISOString(),\n293:     });\n294:     saveState(projectRoot, state);\n295:   }\n296: }\n297: \n298: /**\n299:  * Attempt to merge a verified agent's branch into the base branch.\n300:  *\n301:  * Handles conflict detection, base-into-feature merge, and resolver agent\n302:  * launch. Extracted from handleBuildVerification so it can be called\n303:  * independently (e.g., from resume's sequential merge phase).\n304:  */\n305: export async function attemptMerge(\n306:   projectRoot: string,\n307:   state: WaveState,\n308:   agent: AgentState,\n309:   feature: Feature,\n310:   config: WomboConfig,\n311:   model?: string,\n312: ): Promise<void> {\n313:   printAgentUpdate(agent, \"auto-merging...\");\n314:   try {\n315:     const mergeResult = await mergeBranch(projectRoot, agent.branch, state.base_branch, config);\n316: \n317:     if (mergeResult.success) {\n318:       updateAgent(state, agent.feature_id, {\n319:         status: \"merged\",\n320:         completed_at: new Date().toISOString(),\n321:       });\n322:       saveState(projectRoot, state);\n323:       printAgentUpdate(agent, `MERGED (${mergeResult.commitHash?.slice(0, 7)})`);\n324: \n325:       // Mark feature as done in .features.yml so it won't be re-selected\n326:       markFeatureDone(projectRoot, agent.feature_id, config, state.base_branch);\n327: \n328:       // Clean up worktree after successful merge\n329:       try {\n330:         removeWorktree(projectRoot, agent.worktree, true);\n331:         printAgentUpdate(agent, \"worktree and branch removed\");\n332:       } catch {\n333:         // Not critical — worktree cleanup is best-effort\n334:       }\n335:     } else {\n336:       // Merge failed — attempt automatic conflict resolution\n337:       const mergeError = mergeResult.error ?? \"Unknown merge error\";\n338:       printAgentUpdate(agent, `MERGE CONFLICT — attempting resolution...`);\n339: \n340:       try {\n341:         // Merge base INTO the feature worktree to create conflict markers\n342:         const conflictResult = await mergeBaseIntoFeature(\n343:           agent.worktree,\n344:           state.base_branch,\n345:           config\n346:         );\n347: \n348:         if (conflictResult.error && !conflictResult.conflicting) {\n349:           printAgentUpdate(agent, `CONFLICT SETUP FAILED: ${conflictResult.error.slice(0, 100)}`);\n350:           return; // Leave as \"verified\" for manual resolution\n351:         }\n352: \n353:         if (!conflictResult.conflicting) {\n354:           // Base merged cleanly into feature — retry merge into base.\n355:           printAgentUpdate(agent, \"base merged cleanly into feature — retrying merge...\");\n356:           const retryMerge = await mergeBranch(projectRoot, agent.branch, state.base_branch, config);\n357:           if (retryMerge.success) {\n358:             updateAgent(state, agent.feature_id, {\n359:               status: \"merged\",\n360:               completed_at: new Date().toISOString(),\n361:             });\n362:             saveState(projectRoot, state);\n363:             printAgentUpdate(agent, `MERGED after rebase (${retryMerge.commitHash?.slice(0, 7)})`);\n364:             markFeatureDone(projectRoot, agent.feature_id, config, state.base_branch);\n365:             try {\n366:               removeWorktree(projectRoot, agent.worktree, true);\n367:             } catch {}\n368:             return;\n369:           }\n370: \n371:           // Retry still failed — launch resolver agent\n372:           printAgentUpdate(agent, `retry merge still failed — launching resolver agent...`);\n373: \n374:           const secondConflict = await mergeBaseIntoFeature(\n375:             agent.worktree,\n376:             state.base_branch,\n377:             config\n378:           );\n379: \n380:           const conflictFiles = secondConflict.conflicting\n381:             ? secondConflict.files\n382:             : [\"(unknown — merge direction mismatch)\"];\n383:           const resolverMergeError = retryMerge.error ?? mergeError;\n384: \n385:           await launchResolverAndRetryMerge(\n386:             projectRoot, state, agent, feature, config, model,\n387:             resolverMergeError, conflictFiles\n388:           );\n389:           return;\n390:         }\n391: \n392:         // There are real conflicts — launch a resolver agent\n393:         printAgentUpdate(\n394:           agent,\n395:           `${conflictResult.files.length} conflicting file(s): ${conflictResult.files.join(\", \")}`\n396:         );\n397: \n398:         await launchResolverAndRetryMerge(\n399:           projectRoot, state, agent, feature, config, model,\n400:           mergeError, conflictResult.files\n401:         );\n402:       } catch (conflictErr: any) {\n403:         printAgentUpdate(agent, `CONFLICT RESOLUTION ERROR: ${conflictErr.message?.slice(0, 100)}`);\n404:         // Leave as \"verified\" for manual resolution\n405:       }\n406:     }\n407:   } catch (mergeErr: any) {\n408:     printAgentUpdate(agent, `AUTO-MERGE ERROR: ${mergeErr.message?.slice(0, 100)}`);\n409:   }\n410: }\n411: \n412: /**\n413:  * Launch a conflict resolver agent, wait for it to finish, re-verify build,\n414:  * and retry the merge. Extracted to avoid duplicating the resolver flow.\n415:  */\n416: async function launchResolverAndRetryMerge(\n417:   projectRoot: string,\n418:   state: WaveState,\n419:   agent: AgentState,\n420:   feature: Feature,\n421:   config: WomboConfig,\n422:   model: string | undefined,\n423:   mergeError: string,\n424:   conflictFiles: string[]\n425: ): Promise<void> {\n426:   const conflictPrompt = generateConflictResolutionPrompt(\n427:     feature,\n428:     state.base_branch,\n429:     mergeError,\n430:     config\n431:   );\n432: \n433:   updateAgent(state, agent.feature_id, {\n434:     status: \"resolving_conflict\",\n435:     activity: `resolving ${conflictFiles.length} conflict(s)...`,\n436:   });\n437:   saveState(projectRoot, state);\n438: \n439:   const resolverResult = launchConflictResolver({\n440:     worktreePath: agent.worktree,\n441:     featureId: agent.feature_id,\n442:     prompt: conflictPrompt,\n443:     model,\n444:     config,\n445:   });\n446: \n447:   updateAgent(state, agent.feature_id, {\n448:     pid: resolverResult.pid,\n449:   });\n450:   saveState(projectRoot, state);\n451: \n452:   // Wait for the resolver process to complete, then re-verify and retry merge.\n453:   // We intentionally do NOT add the resolver to the ProcessMonitor because\n454:   // the monitor's onComplete callback would trigger handleBuildVerification\n455:   // again, causing infinite recursion. Instead we await the process directly.\n456:   const resolverExitCode = await new Promise<number | null>((resolve) => {\n457:     resolverResult.process.on(\"exit\", (code) => resolve(code));\n458:     resolverResult.process.on(\"error\", () => resolve(null));\n459:   });\n460: \n461:   printAgentUpdate(agent, `conflict resolver exited (code ${resolverExitCode}) — re-verifying build...`);\n462: \n463:   // Re-verify build after conflict resolution\n464:   const rebuildResult = await runBuild(agent.worktree, config);\n465: \n466:   if (!rebuildResult.passed) {\n467:     printAgentUpdate(agent, `POST-CONFLICT BUILD FAILED`);\n468:     updateAgent(state, agent.feature_id, {\n469:       status: \"failed\",\n470:       build_passed: false,\n471:       build_output: rebuildResult.errorSummary,\n472:       error: \"Build failed after conflict resolution\",\n473:       completed_at: new Date().toISOString(),\n474:     });\n475:     saveState(projectRoot, state);\n476:     return;\n477:   }\n478: \n479:   printAgentUpdate(agent, \"post-conflict build passed — retrying merge...\");\n480: \n481:   const retryMerge = await mergeBranch(\n482:     projectRoot,\n483:     agent.branch,\n484:     state.base_branch,\n485:     config\n486:   );\n487: \n488:   if (retryMerge.success) {\n489:     updateAgent(state, agent.feature_id, {\n490:       status: \"merged\",\n491:       build_passed: true,\n492:       completed_at: new Date().toISOString(),\n493:     });\n494:     saveState(projectRoot, state);\n495:     printAgentUpdate(agent, `MERGED after conflict resolution (${retryMerge.commitHash?.slice(0, 7)})`);\n496:     markFeatureDone(projectRoot, agent.feature_id, config, state.base_branch);\n497:     try {\n498:       removeWorktree(projectRoot, agent.worktree, true);\n499:     } catch {}\n500:   } else {\n501:     printAgentUpdate(agent, `POST-CONFLICT MERGE FAILED: ${retryMerge.error}`);\n502:     updateAgent(state, agent.feature_id, {\n503:       status: \"failed\",\n504:       error: `Merge still failed after conflict resolution: ${retryMerge.error}`,\n505:       completed_at: new Date().toISOString(),\n506:     });\n507:     saveState(projectRoot, state);\n508:   }\n509: }\n510: \n511: /**\n512:  * Handle retry of a failed agent (error-based, not build-based).\n513:  */\n514: export function handleRetry(\n515:   projectRoot: string,\n516:   state: WaveState,\n517:   agent: AgentState,\n518:   monitor: ProcessMonitor,\n519:   config: WomboConfig,\n520:   model?: string\n521: ): void {\n522:   if (!agent.session_id || !agent.error) return;\n523: \n524:   const retryResult = retryHeadless({\n525:     worktreePath: agent.worktree,\n526:     featureId: agent.feature_id,\n527:     sessionId: agent.session_id,\n528:     buildErrors: agent.error,\n529:     model,\n530:     config,\n531:   });\n532: \n533:   updateAgent(state, agent.feature_id, {\n534:     status: \"running\",\n535:     pid: retryResult.pid,\n536:   });\n537:   saveState(projectRoot, state);\n538: \n539:   monitor.addProcess(agent.feature_id, retryResult.process);\n540: }\n541: \n542: /**\n543:  * Launch the next queued agent if capacity allows.\n544:  */\n545: export function launchNextQueued(\n546:   projectRoot: string,\n547:   state: WaveState,\n548:   featureMap: Map<string, Feature>,\n549:   monitor: ProcessMonitor,\n550:   config: WomboConfig,\n551:   model?: string\n552: ): void {\n553:   const active = activeAgents(state);\n554:   const queued = queuedAgents(state);\n555: \n556:   if (active.length < state.max_concurrent && queued.length > 0) {\n557:     const next = queued[0];\n558:     const feature = featureMap.get(next.feature_id);\n559:     if (feature) {\n560:       launchSingleHeadless(projectRoot, state, next, feature, monitor, config, model);\n561:     }\n562:   }\n563: }\n564: \n565: // ---------------------------------------------------------------------------\n566: // Headless Wave Launch\n567: // ---------------------------------------------------------------------------\n568: \n569: async function launchWaveHeadless(\n570:   projectRoot: string,\n571:   state: WaveState,\n572:   features: Feature[],\n573:   opts: LaunchCommandOptions\n574: ): Promise<void> {\n575:   const { config, model } = opts;\n576:   const featureMap = new Map(features.map((f) => [f.id, f]));\n577: \n578:   const monitor = new ProcessMonitor(projectRoot, {\n579:     onSessionId: (featureId, sessionId) => {\n580:       updateAgent(state, featureId, { session_id: sessionId });\n581:       saveState(projectRoot, state);\n582:     },\n583:     onComplete: (featureId) => {\n584:       updateAgent(state, featureId, {\n585:         status: \"completed\",\n586:         completed_at: new Date().toISOString(),\n587:       });\n588:       saveState(projectRoot, state);\n589: \n590:       // Run build verification — fire-and-forget\n591:       const agent = state.agents.find((a) => a.feature_id === featureId)!;\n592:       handleBuildVerification(projectRoot, state, agent, featureMap.get(featureId)!, config, model, monitor)\n593:         .then(() => launchNextQueued(projectRoot, state, featureMap, monitor, config, model))\n594:         .catch((err) => {\n595:           wtLog(featureId, `BUILD VERIFICATION UNHANDLED ERROR: ${err.message}`);\n596:           launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n597:         });\n598:     },\n599:     onError: (featureId, error) => {\n600:       const agent = state.agents.find((a) => a.feature_id === featureId)!;\n601:       if (agent.retries < agent.max_retries) {\n602:         updateAgent(state, featureId, {\n603:           status: \"retry\",\n604:           retries: agent.retries + 1,\n605:           error,\n606:         });\n607:         saveState(projectRoot, state);\n608: \n609:         // Retry\n610:         handleRetry(projectRoot, state, agent, monitor, config, model);\n611:       } else {\n612:         updateAgent(state, featureId, {\n613:           status: \"failed\",\n614:           error,\n615:           completed_at: new Date().toISOString(),\n616:         });\n617:         saveState(projectRoot, state);\n618:       }\n619: \n620:       // Try to launch next queued agent\n621:       launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n622:     },\n623:     onOutput: (_featureId, _data) => {\n624:       // Raw output — logged to file by ProcessMonitor\n625:     },\n626:     onActivity: (featureId, activity) => {\n627:       updateAgent(state, featureId, {\n628:         activity,\n629:         activity_updated_at: new Date().toISOString(),\n630:       });\n631:       // Don't save to disk on every activity — too frequent.\n632:     },\n633:   });\n634: \n635:   // Create the TUI — it will auto-refresh and show activity from the monitor\n636:   const tuiRef = { current: null as WomboTUI | null };\n637:   const startTUI = () => {\n638:     tuiRef.current = new WomboTUI({\n639:       state,\n640:       monitor,\n641:       projectRoot,\n642:       interactive: false,\n643:       config,\n644:       onQuit: () => {\n645:         // Same as SIGINT — save state and exit\n646:         for (const agent of state.agents) {\n647:           if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n648:             updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n649:           }\n650:         }\n651:         monitor.killAll();\n652:         saveState(projectRoot, state);\n653:         console.log(\"State saved. Use 'wombo resume' to continue.\");\n654:         process.exit(0);\n655:       },\n656:     });\n657:     tuiRef.current.start();\n658:   };\n659: \n660:   // Handle graceful shutdown\n661:   process.on(\"SIGINT\", () => {\n662:     if (tuiRef.current) tuiRef.current.stop();\n663:     for (const agent of state.agents) {\n664:       if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n665:         updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n666:       }\n667:     }\n668:     monitor.killAll();\n669:     saveState(projectRoot, state);\n670:     console.log(\"\\nState saved. Use 'wombo resume' to continue.\");\n671:     process.exit(0);\n672:   });\n673: \n674:   // Launch initial batch — set up worktrees in parallel\n675:   const tolaunch = queuedAgents(state).slice(0, opts.maxConcurrent);\n676:   console.log(`Setting up ${tolaunch.length} agent(s) in parallel...\\n`);\n677: \n678:   await Promise.all(\n679:     tolaunch.map((agent) =>\n680:       launchSingleHeadless(\n681:         projectRoot,\n682:         state,\n683:         agent,\n684:         featureMap.get(agent.feature_id)!,\n685:         monitor,\n686:         config,\n687:         model\n688:       )\n689:     )\n690:   );\n691: \n692:   const launched = state.agents.filter((a) => a.status === \"running\").length;\n693: \n694:   // Start the TUI dashboard (or skip if --no-tui)\n695:   if (opts.noTui) {\n696:     console.log(`${launched} agent(s) running. (--no-tui mode, dashboard prints every 15s)\\n`);\n697:     printDashboard(state);\n698:   } else {\n699:     console.log(`${launched} agent(s) running. Launching TUI...\\n`);\n700:     startTUI();\n701:   }\n702: \n703:   // Background monitoring loop — checks for dead processes and launches queued\n704:   const POLL_INTERVAL = 5000;\n705:   let dashboardCounter = 0;\n706:   while (!isWaveComplete(state)) {\n707:     await new Promise((r) => setTimeout(r, POLL_INTERVAL));\n708: \n709:     // Check for completed processes that weren't caught by event handlers\n710:     for (const agent of state.agents) {\n711:       if (\n712:         (agent.status === \"running\" || agent.status === \"resolving_conflict\") &&\n713:         agent.pid &&\n714:         !isProcessRunning(agent.pid) &&\n715:         !monitor.isRunning(agent.feature_id)\n716:       ) {\n717:         if (agent.status === \"resolving_conflict\") {\n718:           // Conflict resolver died — the await in handleBuildVerification\n719:           // will resolve via the 'exit' event, so nothing to do here\n720:           continue;\n721:         }\n722:         // Process exited but we didn't get a callback\n723:         // Check if the agent actually made any commits\n724:         if (!branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n725:           // Agent died without producing any code — mark as failed, not completed\n726:           updateAgent(state, agent.feature_id, {\n727:             status: \"failed\",\n728:             error: \"Agent process exited without making any commits\",\n729:             activity: null,\n730:             completed_at: new Date().toISOString(),\n731:           });\n732:           saveState(projectRoot, state);\n733:           wtLog(agent.feature_id, \"process died with no code changes — marked failed\");\n734:         } else {\n735:           updateAgent(state, agent.feature_id, {\n736:             status: \"completed\",\n737:             completed_at: new Date().toISOString(),\n738:             activity: \"done\",\n739:           });\n740:           saveState(projectRoot, state);\n741:           try {\n742:             await handleBuildVerification(projectRoot, state, agent, featureMap.get(agent.feature_id)!, config, model, monitor);\n743:           } catch (err: any) {\n744:             wtLog(agent.feature_id, `POLL VERIFY ERROR: ${err.message}`);\n745:           }\n746:         }\n747:         launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n748:       }\n749:     }\n750: \n751:     // Persist state periodically\n752:     saveState(projectRoot, state);\n753: \n754:     // Update TUI state reference (or print dashboard in --no-tui mode)\n755:     if (tuiRef.current) {\n756:       tuiRef.current.updateState(state);\n757:     } else if (opts.noTui) {\n758:       dashboardCounter++;\n759:       if (dashboardCounter % 3 === 0) {\n760:         printDashboard(state);\n761: \n762:         // Auto-push base branch if requested\n763:         if (opts.autoPush) {\n764:           const anyMerged = state.agents.some((a) => a.status === \"merged\");\n765:           if (anyMerged) {\n766:             await pushBaseBranch(projectRoot, state.base_branch, config);\n767:           } else {\n768:             console.log(\"No branches were merged — skipping push.\");\n769:           }\n770:         }\n771:       }\n772:     }\n773:   }\n774: \n775:   // Wave complete — tear down TUI and show final summary\n776:   if (tuiRef.current) tuiRef.current.stop();\n777:   printDashboard(state);\n778: \n779:   // Auto-push base branch if requested\n780:   if (opts.autoPush) {\n781:     await pushBaseBranch(projectRoot, state.base_branch, config);\n782:   }\n783: \n784:   console.log(\"Wave complete.\");\n785: }\n786: \n787: // ---------------------------------------------------------------------------\n788: // Interactive Wave Launch\n789: // ---------------------------------------------------------------------------\n790: \n791: async function launchWaveInteractive(\n792:   projectRoot: string,\n793:   state: WaveState,\n794:   features: Feature[],\n795:   opts: LaunchCommandOptions\n796: ): Promise<void> {\n797:   const { config, model } = opts;\n798:   const featureMap = new Map(features.map((f) => [f.id, f]));\n799: \n800:   // Show dashboard immediately\n801:   printDashboard(state);\n802: \n803:   // Launch initial batch in tmux — parallelize setup\n804:   const tolaunch = queuedAgents(state).slice(0, opts.maxConcurrent);\n805:   console.log(`Setting up ${tolaunch.length} agent(s) in parallel...\\n`);\n806: \n807:   await Promise.all(\n808:     tolaunch.map(async (agent) => {\n809:       updateAgent(state, agent.feature_id, {\n810:         status: \"installing\",\n811:         started_at: new Date().toISOString(),\n812:         activity: \"setting up worktree...\",\n813:       });\n814:       saveState(projectRoot, state);\n815: \n816:       try {\n817:         if (worktreeReady(agent.worktree)) {\n818:           wtLog(agent.feature_id, \"worktree already exists, skipping setup\");\n819:         } else {\n820:           await createWorktree(projectRoot, agent.feature_id, state.base_branch, config);\n821:           updateAgent(state, agent.feature_id, { activity: \"installing deps...\" });\n822:           await installDeps(agent.worktree, agent.feature_id, config);\n823:         }\n824: \n825:         const prompt = generatePrompt(\n826:           featureMap.get(agent.feature_id)!,\n827:           state.base_branch,\n828:           config\n829:         );\n830: \n831:         wtLog(agent.feature_id, \"launching tmux session...\");\n832:         const result = launchInteractive({\n833:           worktreePath: agent.worktree,\n834:           featureId: agent.feature_id,\n835:           prompt,\n836:           model,\n837:           interactive: true,\n838:           config,\n839:         });\n840: \n841:         updateAgent(state, agent.feature_id, {\n842:           status: \"running\",\n843:           pid: result.pid,\n844:           activity: \"tmux session active\",\n845:         });\n846:         saveState(projectRoot, state);\n847:         wtLog(agent.feature_id, `tmux session: ${config.agent.tmuxPrefix}-${agent.feature_id}`);\n848:       } catch (err: any) {\n849:         updateAgent(state, agent.feature_id, {\n850:           status: \"failed\",\n851:           error: err.message,\n852:           activity: null,\n853:           completed_at: new Date().toISOString(),\n854:         });\n855:         saveState(projectRoot, state);\n856:         wtLog(agent.feature_id, `SETUP FAILED: ${err.message.split(\"\\n\")[0]}`);\n857:       }\n858:     })\n859:   );\n860: \n861:   console.log(\"\\nInteractive sessions launched. Use these commands:\");\n862:   console.log(`  tmux attach -t ${config.agent.tmuxPrefix}-<feature-id>   # attach to a session`);\n863:   console.log(\"  tmux ls                                                  # list sessions\");\n864:   console.log(\"  wombo status                                             # check status\");\n865:   console.log(\"  wombo verify                                             # verify builds\");\n866:   console.log(\"  wombo merge                                              # merge verified\");\n867:   console.log(\"  wombo cleanup                                            # remove worktrees\");\n868: \n869:   printDashboard(state);\n870: }\n871: \n872: // ---------------------------------------------------------------------------\n873: // Main Command\n874: // ---------------------------------------------------------------------------\n875: \n876: export async function cmdLaunch(opts: LaunchCommandOptions): Promise<void> {\n877:   const { projectRoot, config } = opts;\n878:   const fmt = opts.outputFmt ?? \"text\";\n879: \n880:   if (fmt !== \"json\") {\n881:     console.log(\"\\n--- Wombo: Launch ---\\n\");\n882:   }\n883: \n884:   // Ensure agent definition exists — reinstall from template if missing\n885:   ensureAgentDefinition(projectRoot, config);\n886: \n887:   // -------------------------------------------------------------------------\n888:   // Check for existing wave state — don't overwrite work in progress\n889:   // -------------------------------------------------------------------------\n890:   const existingState = loadState(projectRoot);\n891:   if (existingState) {\n892:     const merged = existingState.agents.filter((a) => a.status === \"merged\");\n893:     const verified = existingState.agents.filter((a) => a.status === \"verified\");\n894:     const completed = existingState.agents.filter((a) => a.status === \"completed\");\n895:     const running = existingState.agents.filter((a) => a.status === \"running\");\n896:     const queued = existingState.agents.filter((a) => a.status === \"queued\");\n897:     const failed = existingState.agents.filter((a) => a.status === \"failed\");\n898: \n899:     const hasWork = merged.length > 0 || verified.length > 0 || completed.length > 0 || running.length > 0;\n900: \n901:     if (hasWork) {\n902:       if (fmt !== \"json\") {\n903:         console.log(`Existing wave found: ${existingState.wave_id}`);\n904:         console.log(`  ${merged.length} merged, ${verified.length} verified, ${completed.length} completed, ${running.length} running, ${queued.length} queued, ${failed.length} failed`);\n905:       }\n906: \n907:       // Finalize any merged agents by marking their features as done\n908:       if (merged.length > 0) {\n909:         if (fmt !== \"json\") console.log(\"\\nFinalizing merged features in .features.yml...\");\n910:         for (const agent of merged) {\n911:           markFeatureDone(projectRoot, agent.feature_id, config, existingState.base_branch);\n912:           // Clean up worktree and branch (already merged, safe to delete)\n913:           try {\n914:             removeWorktree(projectRoot, agent.worktree, true);\n915:             if (fmt !== \"json\") console.log(`  ${agent.feature_id}: marked done, worktree removed`);\n916:           } catch {\n917:             if (fmt !== \"json\") console.log(`  ${agent.feature_id}: marked done (worktree already cleaned)`);\n918:           }\n919:         }\n920:       }\n921: \n922:       // Verified agents: build passed but NOT merged — do NOT mark done.\n923:       // Leave them for 'wombo resume' to attempt the merge.\n924:       if (verified.length > 0) {\n925:         for (const agent of verified) {\n926:           if (fmt !== \"json\") console.log(`  ${agent.feature_id}: verified (not yet merged) — use 'wombo resume' to merge`);\n927:         }\n928:       }\n929: \n930:       const activeCount = running.length + completed.length + queued.length;\n931:       if (activeCount > 0) {\n932:         outputError(\n933:           fmt,\n934:           `Wave ${existingState.wave_id} has ${activeCount} unfinished agent(s). Use 'wombo resume' to continue or 'wombo cleanup' to clear.`\n935:         );\n936:       }\n937: \n938:       // All agents are in terminal states (merged/verified/failed) — safe to start fresh\n939:       if (fmt !== \"json\") console.log(\"\\nAll agents in previous wave are finished. Starting fresh wave.\\n\");\n940:     }\n941:   }\n942: \n943:   // Load features\n944:   const data = loadFeatures(projectRoot, config);\n945: \n946:   // Build selection options\n947:   const selOpts: SelectionOptions = {};\n948:   if (opts.topPriority) selOpts.topPriority = opts.topPriority;\n949:   if (opts.quickestWins) selOpts.quickestWins = opts.quickestWins;\n950:   if (opts.priority) selOpts.priority = opts.priority;\n951:   if (opts.difficulty) selOpts.difficulty = opts.difficulty;\n952:   if (opts.features) selOpts.featureIds = opts.features;\n953:   if (opts.allReady) selOpts.allReady = true;\n954: \n955:   // Select features\n956:   const selected = selectFeatures(data, selOpts);\n957: \n958:   if (selected.length === 0) {\n959:     const msg = opts.allReady\n960:       ? \"No launchable features found. All features may be done, cancelled, or have unmet dependencies.\"\n961:       : \"No features matched the selection criteria. Use --all-ready to see all available.\";\n962:     outputError(fmt, msg);\n963:   }\n964: \n965:   const selectedData = selected.map((f) => ({\n966:     id: f.id,\n967:     title: f.title,\n968:     priority: f.priority,\n969:     difficulty: f.difficulty,\n970:     effort: f.effort,\n971:   }));\n972: \n973:   if (opts.dryRun) {\n974:     output(\n975:       fmt,\n976:       {\n977:         dry_run: true,\n978:         selected: selectedData,\n979:         count: selected.length,\n980:         base_branch: opts.baseBranch,\n981:         max_concurrent: opts.maxConcurrent,\n982:         model: opts.model ?? null,\n983:         interactive: opts.interactive,\n984:       },\n985:       () => {\n986:         // Show selection\n987:         printFeatureSelection(selectedData);\n988:         console.log(\"Dry run — not launching agents.\");\n989:       }\n990:     );\n991:     return;\n992:   }\n993: \n994:   // Show selection (text only — JSON mode doesn't need this for non-dry-run)\n995:   if (fmt !== \"json\") {\n996:     printFeatureSelection(selectedData);\n997:   }\n998: \n999:   // Create wave state\n1000:   const state = createWaveState({\n1001:     baseBranch: opts.baseBranch,\n1002:     maxConcurrent: opts.maxConcurrent,\n1003:     model: opts.model ?? null,\n1004:     interactive: opts.interactive,\n1005:   });\n1006: \n1007:   // Create agent entries for all selected features\n1008:   for (const feature of selected) {\n1009:     const branch = featureBranchName(feature.id, config);\n1010:     const wtPath = worktreePath(projectRoot, feature.id, config);\n1011:     const agent = createAgentState(feature.id, branch, wtPath, opts.maxRetries);\n1012:     // Set effort estimate from feature spec\n1013:     const effortMinutes = parseDurationMinutes(feature.effort);\n1014:     agent.effort_estimate_ms = effortMinutes === Infinity ? null : effortMinutes * 60 * 1000;\n1015:     state.agents.push(agent);\n1016:   }\n1017: \n1018:   saveState(projectRoot, state);\n1019:   console.log(`Wave ${state.wave_id} created with ${selected.length} agents.`);\n1020: \n1021:   // Launch agents up to max_concurrent\n1022:   if (opts.interactive) {\n1023:     await launchWaveInteractive(projectRoot, state, selected, opts);\n1024:   } else {\n1025:     await launchWaveHeadless(projectRoot, state, selected, opts);\n1026:   }\n1027: }\n\n(End of file - total 1027 lines)\n</content>","title":"src/commands/launch.ts","metadata":{"preview":"/**\n * launch.ts — Launch a wave of agents.\n *\n * Usage: wombo launch [selection options] [launch options]\n *\n * This is the primary entry point for starting a new wave. It selects features\n * from the features file, creates a wave state, sets up worktrees, and launches\n * agent processes (either headless or interactive via tmux).\n *\n * IMPORTANT: This file also exports shared helper functions that are reused\n * by resume.ts and other commands:\n *   - launchSingleHeadless\n *   - handleBuildVerification\n *   - handleRetry\n *   - launchNextQueued\n */\n\nimport { execSync } from \"node:child_process\";\nimport type { WomboConfig } from \"../config.js\";\nimport type { Feature, SelectionOptions, Priority, Difficulty } from \"../lib/features.js\";","truncated":false,"loaded":[]},"time":{"start":1773351875050,"end":1773351875056}}}}
