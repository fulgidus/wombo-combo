{"type":"tool_use","timestamp":1773351715652,"sessionID":"ses_31c036d66ffeb3gOzUVP7hTP5i","part":{"id":"prt_ce3ff6ca3001LpP1XvwSrJ6rPd","sessionID":"ses_31c036d66ffeb3gOzUVP7hTP5i","messageID":"msg_ce3ff621d001pWnj7tBiQTk3R6","type":"tool","callID":"toolu_vrtx_01Wa5rXF7thpJXsvfz2XTJSR","tool":"write","state":{"status":"completed","input":{"content":"/**\n * cleanup.ts — Remove all wave-related resources.\n *\n * Usage: wombo cleanup\n *\n * Kills tmux sessions, removes worktrees, removes state and log files.\n */\n\nimport { existsSync, unlinkSync, rmSync } from \"node:fs\";\nimport { execSync } from \"node:child_process\";\nimport { resolve } from \"node:path\";\nimport type { WomboConfig } from \"../config.js\";\nimport { killAllTmuxSessions } from \"../lib/launcher.js\";\nimport { cleanupAllWorktrees } from \"../lib/worktree.js\";\nimport { output, type OutputFormat } from \"../lib/output.js\";\n\nexport interface CleanupOptions {\n  projectRoot: string;\n  config: WomboConfig;\n  dryRun?: boolean;\n  outputFmt?: OutputFormat;\n}\n\nexport async function cmdCleanup(opts: CleanupOptions): Promise<void> {\n  const { projectRoot, config } = opts;\n  const fmt = opts.outputFmt ?? \"text\";\n\n  // Dry-run: show what would be cleaned up without doing it\n  if (opts.dryRun) {\n    let tmuxSessions: string[] = [];\n    try {\n      const sessions = execSync(\"tmux list-sessions -F '#{session_name}'\", {\n        encoding: \"utf-8\",\n      }).trim();\n      const prefix = config.agent.tmuxPrefix;\n      tmuxSessions = sessions\n        .split(\"\\n\")\n        .filter((s) => s.startsWith(prefix));\n    } catch {\n      // no tmux server running\n    }\n\n    let worktrees: string[] = [];\n    try {\n      const worktreeOutput = execSync(\"git worktree list --porcelain\", {\n        cwd: projectRoot,\n        encoding: \"utf-8\",\n      }).trim();\n      const prefix = config.git.worktreePrefix;\n      worktrees = worktreeOutput\n        .split(\"\\n\")\n        .filter((line) => line.startsWith(\"worktree \") && line.includes(prefix))\n        .map((line) => line.replace(\"worktree \", \"\"));\n    } catch {\n      // no worktrees\n    }\n\n    const statePath = resolve(projectRoot, \".wombo-state.json\");\n    const logDir = resolve(projectRoot, \".wombo-logs\");\n    const stateExists = existsSync(statePath);\n    const logsExist = existsSync(logDir);\n\n    output(\n      fmt,\n      {\n        dry_run: true,\n        tmux_sessions: tmuxSessions,\n        tmux_sessions_count: tmuxSessions.length,\n        worktrees,\n        worktrees_count: worktrees.length,\n        state_file: stateExists,\n        log_dir: logsExist,\n      },\n      () => {\n        console.log(\"\\n[dry-run] Would perform the following cleanup:\\n\");\n        console.log(`  tmux sessions to kill: ${tmuxSessions.length}`);\n        for (const s of tmuxSessions) {\n          console.log(`    ${s}`);\n        }\n        console.log(`  worktrees to remove: ${worktrees.length}`);\n        for (const w of worktrees) {\n          console.log(`    ${w}`);\n        }\n        if (stateExists) console.log(\"  Would remove: .wombo-state.json\");\n        if (logsExist) console.log(\"  Would remove: .wombo-logs/\");\n      }\n    );\n    return;\n  }\n\n  if (fmt !== \"json\") {\n    console.log(\"\\n--- Wombo: Cleanup ---\\n\");\n  }\n\n  // Kill tmux sessions\n  const killed = killAllTmuxSessions(config);\n  if (fmt !== \"json\") console.log(`Killed ${killed} tmux session(s)`);\n\n  // Remove worktrees\n  const removed = cleanupAllWorktrees(projectRoot, config);\n  if (fmt !== \"json\") console.log(`Removed ${removed} worktree(s)`);\n\n  // List remaining feature branches\n  let remainingBranches: string[] = [];\n  try {\n    const branchPattern = `\"${config.git.branchPrefix}*\"`;\n    const branches = execSync(`git branch --list ${branchPattern}`, {\n      cwd: projectRoot,\n      encoding: \"utf-8\",\n    }).trim();\n    if (branches) {\n      remainingBranches = branches.split(\"\\n\").map((b) => b.trim());\n      if (fmt !== \"json\") {\n        console.log(`\\nRemaining feature branches:\\n${branches}`);\n        console.log('Use \"git branch -D <branch>\" to remove manually.');\n      }\n    }\n  } catch {}\n\n  // Remove state file\n  const statePath = resolve(projectRoot, \".wombo-state.json\");\n  const stateRemoved = existsSync(statePath);\n  if (stateRemoved) {\n    unlinkSync(statePath);\n    if (fmt !== \"json\") console.log(\"Removed .wombo-state.json\");\n  }\n\n  // Remove log directory\n  const logDir = resolve(projectRoot, \".wombo-logs\");\n  const logsRemoved = existsSync(logDir);\n  if (logsRemoved) {\n    rmSync(logDir, { recursive: true, force: true });\n    if (fmt !== \"json\") console.log(\"Removed .wombo-logs/\");\n  }\n\n  output(\n    fmt,\n    {\n      tmux_sessions_killed: killed,\n      worktrees_removed: removed,\n      state_file_removed: stateRemoved,\n      log_dir_removed: logsRemoved,\n      remaining_branches: remainingBranches,\n    },\n    () => {\n      console.log(\"\\nCleanup complete.\");\n    }\n  );\n}\n","filePath":"/home/fulgidus/Documents/wombo-json-output-complete/src/commands/cleanup.ts"},"output":"Wrote file successfully.","title":"src/commands/cleanup.ts","metadata":{"diagnostics":{"/home/fulgidus/Documents/wombo-json-output-complete/src/commands/features/show.ts":[{"range":{"start":{"line":15,"character":7},"end":{"line":15,"character":14}},"message":"'Feature' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"},{"range":{"start":{"line":41,"character":6},"end":{"line":41,"character":12}},"message":"'YELLOW' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"},{"range":{"start":{"line":84,"character":4},"end":{"line":84,"character":10}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":92,"character":4},"end":{"line":92,"character":10