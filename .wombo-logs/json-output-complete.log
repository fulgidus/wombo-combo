{"type":"tool_use","timestamp":1773351729022,"sessionID":"ses_31c036d66ffeb3gOzUVP7hTP5i","part":{"id":"prt_ce3ffcd9c001ZezGLJD35oga2W","sessionID":"ses_31c036d66ffeb3gOzUVP7hTP5i","messageID":"msg_ce3ffc357001Uka3QRYNE4xNZx","type":"tool","callID":"toolu_vrtx_01MtV9VjyRC3ZohAh2DhfHk7","tool":"write","state":{"status":"completed","input":{"content":"/**\n * verify.ts — Run build verification on completed agents.\n *\n * Usage: wombo verify [feature-id]\n *\n * Runs the build command in each completed agent's worktree. If a specific\n * feature-id is given, verifies only that agent. Otherwise verifies all\n * agents with status \"completed\".\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport { loadFeatures } from \"../lib/features.js\";\nimport { loadState, saveState } from \"../lib/state.js\";\nimport { printDashboard } from \"../lib/ui.js\";\nimport { handleBuildVerification } from \"./launch.js\";\nimport { output, outputMessage, type OutputFormat } from \"../lib/output.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface VerifyCommandOptions {\n  projectRoot: string;\n  config: WomboConfig;\n  featureId?: string;\n  model?: string;\n  maxRetries?: number;\n  outputFmt?: OutputFormat;\n}\n\n// ---------------------------------------------------------------------------\n// Command\n// ---------------------------------------------------------------------------\n\nexport async function cmdVerify(opts: VerifyCommandOptions): Promise<void> {\n  const { projectRoot, config } = opts;\n  const fmt = opts.outputFmt ?? \"text\";\n\n  const state = loadState(projectRoot);\n  if (!state) {\n    outputMessage(fmt, \"No active wave.\", { wave: null });\n    return;\n  }\n\n  const toVerify = opts.featureId\n    ? state.agents.filter((a) => a.feature_id === opts.featureId)\n    : state.agents.filter((a) => a.status === \"completed\");\n\n  if (toVerify.length === 0) {\n    outputMessage(fmt, \"No agents to verify.\", {\n      wave_id: state.wave_id,\n      verified: [],\n      count: 0,\n    });\n    return;\n  }\n\n  if (fmt !== \"json\") {\n    console.log(`\\nVerifying ${toVerify.length} agent(s)...\\n`);\n  }\n\n  const data = loadFeatures(projectRoot, config);\n\n  for (const agent of toVerify) {\n    const feature = data.features.find((f) => f.id === agent.feature_id);\n    if (!feature) continue;\n\n    await handleBuildVerification(projectRoot, state, agent, feature, config, opts.model);\n  }\n\n  const results = toVerify.map((a) => ({\n    feature_id: a.feature_id,\n    status: a.status,\n    build_passed: a.build_passed,\n    error: a.error,\n  }));\n\n  output(\n    fmt,\n    {\n      wave_id: state.wave_id,\n      verified: results,\n      count: toVerify.length,\n    },\n    () => {\n      printDashboard(state);\n    }\n  );\n}\n","filePath":"/home/fulgidus/Documents/wombo-json-output-complete/src/commands/verify.ts"},"output":"Wrote file successfully.","title":"src/commands/verify.ts","metadata":{"diagnostics":{"/home/fulgidus/Documents/wombo-json-output-complete/src/commands/features/show.ts":[{"range":{"start":{"line":15,"character":7},"end":{"line":15,"character":14}},"message":"'Feature' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"},{"range":{"start":{"line":41,"character":6},"end":{"line":41,"character":12}},"message":"'YELLOW' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"},{"range":{"start":{"line":84,"character":4},"end":{"line":84,"character":10}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":92,"character":4},"end":{"line":92,"character":10}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"}],"/home/fulgidus/Documents/wombo-json-output-complete/src/commands/features/list