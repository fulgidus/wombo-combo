{"type":"tool_use","timestamp":1773351887622,"sessionID":"ses_31c036d66ffeb3gOzUVP7hTP5i","part":{"id":"prt_ce40261c3002XdFu1peSr6CSNE","sessionID":"ses_31c036d66ffeb3gOzUVP7hTP5i","messageID":"msg_ce40259c7001ygmGSqvQ62yxZJ","type":"tool","callID":"toolu_vrtx_013URhHwVhk4EGYuhoFqZUjH","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-json-output-complete/src/commands/merge.ts"},"output":"<path>/home/fulgidus/Documents/wombo-json-output-complete/src/commands/merge.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * merge.ts — Merge verified branches into the base branch.\n3:  *\n4:  * Usage: wombo merge [feature-id]\n5:  *\n6:  * Merges all verified agents (or a specific one) into the base branch.\n7:  * After merging, cleans up the worktree as best-effort.\n8:  */\n9: \n10: import type { WomboConfig } from \"../config.js\";\n11: import {\n12:   loadState,\n13:   saveState,\n14:   updateAgent,\n15: } from \"../lib/state.js\";\n16: import { mergeBranch, pushBaseBranch } from \"../lib/merger.js\";\n17: import { removeWorktree } from \"../lib/worktree.js\";\n18: import { printDashboard, printAgentUpdate } from \"../lib/ui.js\";\n19: import { output, outputMessage, type OutputFormat } from \"../lib/output.js\";\n20: \n21: // ---------------------------------------------------------------------------\n22: // Types\n23: // ---------------------------------------------------------------------------\n24: \n25: export interface MergeCommandOptions {\n26:   projectRoot: string;\n27:   config: WomboConfig;\n28:   featureId?: string;\n29:   autoPush?: boolean;\n30:   dryRun?: boolean;\n31:   outputFmt?: OutputFormat;\n32: }\n33: \n34: // ---------------------------------------------------------------------------\n35: // Command\n36: // ---------------------------------------------------------------------------\n37: \n38: export async function cmdMerge(opts: MergeCommandOptions): Promise<void> {\n39:   const { projectRoot, config } = opts;\n40:   const fmt = opts.outputFmt ?? \"text\";\n41: \n42:   const state = loadState(projectRoot);\n43:   if (!state) {\n44:     outputMessage(fmt, \"No active wave.\", { wave: null });\n45:     return;\n46:   }\n47: \n48:   const toMerge = opts.featureId\n49:     ? state.agents.filter(\n50:         (a) => a.feature_id === opts.featureId && a.status === \"verified\"\n51:       )\n52:     : state.agents.filter((a) => a.status === \"verified\");\n53: \n54:   if (toMerge.length === 0) {\n55:     outputMessage(fmt, \"No verified agents to merge.\", {\n56:       wave_id: state.wave_id,\n57:       merged: [],\n58:       count: 0,\n59:     });\n60:     return;\n61:   }\n62: \n63:   // Dry-run: show what would be merged without merging\n64:   if (opts.dryRun) {\n65:     const dryRunData = toMerge.map((a) => ({\n66:       feature_id: a.feature_id,\n67:       branch: a.branch,\n68:     }));\n69: \n70:     output(\n71:       fmt,\n72:       {\n73:         dry_run: true,\n74:         would_merge: dryRunData,\n75:         count: toMerge.length,\n76:         auto_push: opts.autoPush ?? false,\n77:         base_branch: state.base_branch,\n78:       },\n79:       () => {\n80:         console.log(`\\n[dry-run] Would merge ${toMerge.length} branch(es):\\n`);\n81:         for (const agent of toMerge) {\n82:           console.log(`  ${agent.feature_id} — branch: ${agent.branch}`);\n83:         }\n84:         if (opts.autoPush) {\n85:           console.log(`\\n  Would push ${state.base_branch} to remote after merge.`);\n86:         }\n87:       }\n88:     );\n89:     return;\n90:   }\n91: \n92:   if (fmt !== \"json\") {\n93:     console.log(`\\nMerging ${toMerge.length} branch(es)...\\n`);\n94:   }\n95: \n96:   const mergeResults: Array<{\n97:     feature_id: string;\n98:     branch: string;\n99:     success: boolean;\n100:     commit_hash?: string;\n101:     error?: string;\n102:   }> = [];\n103: \n104:   for (const agent of toMerge) {\n105:     if (fmt !== \"json\") printAgentUpdate(agent, \"merging...\");\n106:     const result = await mergeBranch(projectRoot, agent.branch, state.base_branch, config);\n107: \n108:     if (result.success) {\n109:       updateAgent(state, agent.feature_id, {\n110:         status: \"merged\",\n111:       });\n112:       saveState(projectRoot, state);\n113:       if (fmt !== \"json\") printAgentUpdate(agent, `MERGED (${result.commitHash?.slice(0, 7)})`);\n114: \n115:       mergeResults.push({\n116:         feature_id: agent.feature_id,\n117:         branch: agent.branch,\n118:         success: true,\n119:         commit_hash: result.commitHash ?? undefined,\n120:       });\n121: \n122:       // Clean up worktree\n123:       try {\n124:         removeWorktree(projectRoot, agent.worktree, false);\n125:         if (fmt !== \"json\") printAgentUpdate(agent, \"worktree removed\");\n126:       } catch {\n127:         // Not critical\n128:       }\n129:     } else {\n130:       if (fmt !== \"json\") printAgentUpdate(agent, `MERGE FAILED: ${result.error}`);\n131:       mergeResults.push({\n132:         feature_id: agent.feature_id,\n133:         branch: agent.branch,\n134:         success: false,\n135:         error: result.error ?? undefined,\n136:       });\n137:     }\n138:   }\n139: \n140:   // Auto-push if requested\n141:   let pushed = false;\n142:   if (opts.autoPush) {\n143:     const anyMerged = state.agents.some((a) => a.status === \"merged\");\n144:     if (anyMerged) {\n145:       await pushBaseBranch(projectRoot, state.base_branch, config);\n146:       pushed = true;\n147:     }\n148:   }\n149: \n150:   output(\n151:     fmt,\n152:     {\n153:       wave_id: state.wave_id,\n154:       merged: mergeResults,\n155:       count: mergeResults.length,\n156:       pushed,\n157:     },\n158:     () => {\n159:       printDashboard(state);\n160:     }\n161:   );\n162: }\n\n(End of file - total 162 lines)\n</content>","title":"src/commands/merge.ts","metadata":{"preview":"/**\n * merge.ts — Merge verified branches into the base branch.\n *\n * Usage: wombo merge [feature-id]\n *\n * Merges all verified agents (or a specific one) into the base branch.\n * After merging, cleans up the worktree as best-effort.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport {\n  loadState,\n  saveState,\n  updateAgent,\n} from \"../lib/state.js\";\nimport { mergeBranch, pushBaseBranch } from \"../lib/merger.js\";\nimport { removeWorktree } from \"../lib/worktree.js\";\nimport { printDashboard, printAgentUpdate } from \"../lib/ui.js\";\nimport { output, outputMessage, type OutputFormat } from \"../lib/output.js\";\n","truncated":false,"loaded":[]},"time":{"start":1773351887620,"end":1773351887621}}}}
{"type":"tool_use","timestamp":1773351887966,"sessionID":"ses_31c036d66ffeb3gOzUVP7hTP5i","part":{"id":"prt_ce4026304001Nb45HMnvm97EYP","sessionID":"ses_31c036d66ffeb3gOzUVP7hTP5i","messageID":"msg_ce40259c7001ygmGSqvQ62yxZJ","type":"tool","callID":"toolu_vrtx_018G8HxYsJM2JeXZ545JAWvc","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-json-output-complete/src/commands/retry.ts"},"output":"<path>/home/fulgidus/Documents/wombo-json-output-complete/src/commands/retry.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * retry.ts — Retry a specific failed agent.\n3:  *\n4:  * Usage: wombo retry <feature-id> [--interactive] [--model <model>]\n5:  *\n6:  * Resets the agent's retry count and re-launches it. Can launch in either\n7:  * headless mode (default) or interactive (tmux) mode.\n8:  */\n9: \n10: import type { WomboConfig } from \"../config.js\";\n11: import { loadFeatures, type Feature } from \"../lib/features.js\";\n12: import {\n13:   loadState,\n14:   saveState,\n15:   updateAgent,\n16: } from \"../lib/state.js\";\n17: import { worktreeReady } from \"../lib/worktree.js\";\n18: import { generatePrompt } from \"../lib/prompt.js\";\n19: import { launchInteractive } from \"../lib/launcher.js\";\n20: import { ProcessMonitor } from \"../lib/monitor.js\";\n21: import { launchSingleHeadless } from \"./launch.js\";\n22: import { output, outputError, outputMessage, type OutputFormat } from \"../lib/output.js\";\n23: \n24: // ---------------------------------------------------------------------------\n25: // Types\n26: // ---------------------------------------------------------------------------\n27: \n28: export interface RetryCommandOptions {\n29:   projectRoot: string;\n30:   config: WomboConfig;\n31:   featureId: string;\n32:   model?: string;\n33:   interactive: boolean;\n34:   dryRun?: boolean;\n35:   outputFmt?: OutputFormat;\n36: }\n37: \n38: // ---------------------------------------------------------------------------\n39: // Command\n40: // ---------------------------------------------------------------------------\n41: \n42: export async function cmdRetry(opts: RetryCommandOptions): Promise<void> {\n43:   const { projectRoot, config } = opts;\n44:   const fmt = opts.outputFmt ?? \"text\";\n45: \n46:   if (!opts.featureId) {\n47:     outputError(fmt, \"Usage: wombo retry <feature-id>\");\n48:     return; // unreachable — helps TypeScript narrow\n49:   }\n50: \n51:   const state = loadState(projectRoot);\n52:   if (!state) {\n53:     outputMessage(fmt, \"No active wave.\", { wave: null });\n54:     return;\n55:   }\n56: \n57:   const agent = state.agents.find((a) => a.feature_id === opts.featureId);\n58:   if (!agent) {\n59:     outputError(fmt, `Agent not found for feature: ${opts.featureId}`);\n60:     return; // unreachable — helps TypeScript narrow\n61:   }\n62: \n63:   if (agent.status !== \"failed\") {\n64:     outputError(\n65:       fmt,\n66:       `Agent ${opts.featureId} is not in failed state (current: ${agent.status})`\n67:     );\n68:     return; // unreachable — helps TypeScript narrow\n69:   }\n70: \n71:   // Dry-run: show what would be retried without doing it\n72:   if (opts.dryRun) {\n73:     output(\n74:       fmt,\n75:       {\n76:         dry_run: true,\n77:         feature_id: opts.featureId,\n78:         current_status: agent.status,\n79:         retries: agent.retries,\n80:         worktree: agent.worktree,\n81:         mode: opts.interactive ? \"interactive\" : \"headless\",\n82:         model: opts.model ?? null,\n83:       },\n84:       () => {\n85:         console.log(`\\n[dry-run] Would retry agent: ${opts.featureId}`);\n86:         console.log(`  Current status: ${agent.status}`);\n87:         console.log(`  Retries so far: ${agent.retries}`);\n88:         console.log(`  Worktree: ${agent.worktree}`);\n89:         console.log(`  Mode: ${opts.interactive ? \"interactive (tmux)\" : \"headless\"}`);\n90:         if (opts.model) console.log(`  Model: ${opts.model}`);\n91:       }\n92:     );\n93:     return;\n94:   }\n95: \n96:   // Reset retry count and re-run\n97:   updateAgent(state, agent.feature_id, {\n98:     status: \"queued\",\n99:     retries: 0,\n100:     error: null,\n101:     build_passed: null,\n102:     build_output: null,\n103:     completed_at: null,\n104:   });\n105:   saveState(projectRoot, state);\n106: \n107:   const data = loadFeatures(projectRoot, config);\n108:   const feature = data.features.find((f) => f.id === opts.featureId);\n109:   if (!feature) {\n110:     outputError(fmt, `Feature ${opts.featureId} not found in ${config.featuresFile}`);\n111:     return; // unreachable — helps TypeScript narrow\n112:   }\n113: \n114:   if (opts.interactive) {\n115:     const prompt = generatePrompt(feature, state.base_branch, config);\n116:     launchInteractive({\n117:       worktreePath: agent.worktree,\n118:       featureId: feature.id,\n119:       prompt,\n120:       model: opts.model,\n121:       interactive: true,\n122:       config,\n123:     });\n124: \n125:     updateAgent(state, agent.feature_id, {\n126:       status: \"running\",\n127:       started_at: new Date().toISOString(),\n128:     });\n129:     saveState(projectRoot, state);\n130: \n131:     outputMessage(fmt, `Retrying ${opts.featureId} in tmux session ${config.agent.tmuxPrefix}-${opts.featureId}`, {\n132:       feature_id: opts.featureId,\n133:       mode: \"interactive\",\n134:       status: \"running\",\n135:     });\n136:   } else {\n137:     const monitor = new ProcessMonitor(projectRoot);\n138:     await launchSingleHeadless(projectRoot, state, agent, feature, monitor, config, opts.model);\n139: \n140:     outputMessage(fmt, `Retrying ${opts.featureId} in headless mode`, {\n141:       feature_id: opts.featureId,\n142:       mode: \"headless\",\n143:       status: \"running\",\n144:     });\n145:   }\n146: }\n\n(End of file - total 146 lines)\n</content>","title":"src/commands/retry.ts","metadata":{"preview":"/**\n * retry.ts — Retry a specific failed agent.\n *\n * Usage: wombo retry <feature-id> [--interactive] [--model <model>]\n *\n * Resets the agent's retry count and re-launches it. Can launch in either\n * headless mode (default) or interactive (tmux) mode.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport { loadFeatures, type Feature } from \"../lib/features.js\";\nimport {\n  loadState,\n  saveState,\n  updateAgent,\n} from \"../lib/state.js\";\nimport { worktreeReady } from \"../lib/worktree.js\";\nimport { generatePrompt } from \"../lib/prompt.js\";\nimport { launchInteractive } from \"../lib/launcher.js\";\nimport { ProcessMonitor } from \"../lib/monitor.js\";","truncated":false,"loaded":[]},"time":{"start":1773351887964,"end":1773351887966}}}}
{"type":"tool_use","timestamp":1773351888424,"sessionID":"ses_31c036d66ffeb3gOzUVP7hTP5i","part":{"id":"prt_ce40264c4001P7JdTBd5rr4ljO","sessionID":"ses_31c036d66ffeb3gOzUVP7hTP5i","messageID":"msg_ce40259c7001ygmGSqvQ62yxZJ","type":"tool","callID":"toolu_vrtx_01U1tQKVc4GJCSUysz74yfQL","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-json-output-complete/src/commands/upgrade.ts"},"output":"<path>/home/fulgidus/Documents/wombo-json-output-complete/src/commands/upgrade.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * upgrade.ts — Self-upgrade wombo from GitHub.\n3:  *\n4:  * Usage:\n5:  *   wombo upgrade              # Check for updates and prompt to install\n6:  *   wombo upgrade --force      # Skip confirmation prompt\n7:  *   wombo upgrade --version v0.1.0  # Install a specific version\n8:  *   wombo upgrade --check      # Only check, don't install\n9:  */\n10: \n11: import { readFileSync } from \"node:fs\";\n12: import { resolve } from \"node:path\";\n13: import { createInterface } from \"node:readline\";\n14: import { output, outputError, outputMessage, type OutputFormat } from \"../lib/output.js\";\n15: \n16: // ---------------------------------------------------------------------------\n17: // Types\n18: // ---------------------------------------------------------------------------\n19: \n20: export interface UpgradeOptions {\n21:   force: boolean;\n22:   version?: string;\n23:   checkOnly: boolean;\n24:   outputFmt?: OutputFormat;\n25: }\n26: \n27: // ---------------------------------------------------------------------------\n28: // Helpers\n29: // ---------------------------------------------------------------------------\n30: \n31: const REPO = \"fulgidus/wombo\";\n32: \n33: /**\n34:  * Get the locally installed version from package.json.\n35:  * Uses import.meta to find the package.json relative to this source file,\n36:  * which works whether running from local source or global install.\n37:  */\n38: function getLocalVersion(): string {\n39:   const pkgPath = resolve(import.meta.dir, \"../../package.json\");\n40:   const raw = readFileSync(pkgPath, \"utf-8\");\n41:   return JSON.parse(raw).version as string;\n42: }\n43: \n44: /**\n45:  * Fetch all v* tags from the remote GitHub repo using git ls-remote.\n46:  * Returns tags sorted by semver descending (latest first).\n47:  */\n48: async function fetchRemoteTags(): Promise<string[]> {\n49:   const proc = Bun.spawn([\"git\", \"ls-remote\", \"--tags\", `https://github.com/${REPO}.git`], {\n50:     stdout: \"pipe\",\n51:     stderr: \"pipe\",\n52:   });\n53: \n54:   const stdout = await new Response(proc.stdout).text();\n55:   const exitCode = await proc.exited;\n56: \n57:   if (exitCode !== 0) {\n58:     const stderr = await new Response(proc.stderr).text();\n59:     throw new Error(`Failed to fetch remote tags: ${stderr.trim()}`);\n60:   }\n61: \n62:   // Parse lines like: \"abc123\\trefs/tags/v0.0.1\"\n63:   const tags: string[] = [];\n64:   for (const line of stdout.split(\"\\n\")) {\n65:     const match = line.match(/refs\\/tags\\/(v\\d+\\.\\d+\\.\\d+)$/);\n66:     if (match) {\n67:       tags.push(match[1]);\n68:     }\n69:   }\n70: \n71:   // Sort descending by semver\n72:   tags.sort((a, b) => {\n73:     const pa = a.slice(1).split(\".\").map(Number);\n74:     const pb = b.slice(1).split(\".\").map(Number);\n75:     for (let i = 0; i < 3; i++) {\n76:       if (pa[i] !== pb[i]) return pb[i] - pa[i];\n77:     }\n78:     return 0;\n79:   });\n80: \n81:   return tags;\n82: }\n83: \n84: /**\n85:  * Compare two semver strings. Returns:\n86:  *   -1 if a < b\n87:  *    0 if a === b\n88:  *    1 if a > b\n89:  */\n90: function compareSemver(a: string, b: string): number {\n91:   const pa = a.replace(/^v/, \"\").split(\".\").map(Number);\n92:   const pb = b.replace(/^v/, \"\").split(\".\").map(Number);\n93:   for (let i = 0; i < 3; i++) {\n94:     if (pa[i] < pb[i]) return -1;\n95:     if (pa[i] > pb[i]) return 1;\n96:   }\n97:   return 0;\n98: }\n99: \n100: /**\n101:  * Prompt the user for yes/no confirmation.\n102:  */\n103: async function confirm(message: string): Promise<boolean> {\n104:   if (!process.stdin.isTTY) return false;\n105: \n106:   const rl = createInterface({ input: process.stdin, output: process.stdout });\n107:   return new Promise<boolean>((resolve) => {\n108:     rl.question(`${message} [y/N] `, (answer) => {\n109:       rl.close();\n110:       resolve(answer.trim().toLowerCase() === \"y\");\n111:     });\n112:   });\n113: }\n114: \n115: // ---------------------------------------------------------------------------\n116: // Command\n117: // ---------------------------------------------------------------------------\n118: \n119: export async function cmdUpgrade(opts: UpgradeOptions): Promise<void> {\n120:   const fmt = opts.outputFmt ?? \"text\";\n121:   const localVersion = getLocalVersion();\n122: \n123:   if (fmt !== \"json\") {\n124:     console.log(`Current version: v${localVersion}`);\n125:   }\n126: \n127:   // If a specific version is requested, skip the check\n128:   if (opts.version) {\n129:     const targetTag = opts.version.startsWith(\"v\") ? opts.version : `v${opts.version}`;\n130: \n131:     if (compareSemver(localVersion, targetTag) === 0) {\n132:       outputMessage(fmt, \"Already at the requested version.\", {\n133:         current_version: `v${localVersion}`,\n134:         requested_version: targetTag,\n135:         up_to_date: true,\n136:       });\n137:       return;\n138:     }\n139: \n140:     if (fmt !== \"json\") {\n141:       console.log(`Requested version: ${targetTag}`);\n142:     }\n143: \n144:     if (!opts.force && fmt !== \"json\") {\n145:       const ok = await confirm(`Install ${targetTag}?`);\n146:       if (!ok) {\n147:         outputMessage(fmt, \"Upgrade cancelled.\", {\n148:           current_version: `v${localVersion}`,\n149:           requested_version: targetTag,\n150:           cancelled: true,\n151:         });\n152:         return;\n153:       }\n154:     }\n155: \n156:     await installVersion(targetTag, fmt);\n157:     return;\n158:   }\n159: \n160:   // Fetch latest from GitHub\n161:   if (fmt !== \"json\") {\n162:     console.log(`Checking for updates from github.com/${REPO}...`);\n163:   }\n164: \n165:   let tags: string[];\n166:   try {\n167:     tags = await fetchRemoteTags();\n168:   } catch (err: any) {\n169:     outputError(fmt, `Failed to check for updates: ${err.message}`);\n170:     return;\n171:   }\n172: \n173:   if (tags.length === 0) {\n174:     outputError(fmt, \"No release tags found on the remote repository.\");\n175:     return;\n176:   }\n177: \n178:   const latestTag = tags[0];\n179:   const latestVersion = latestTag.slice(1); // strip 'v'\n180: \n181:   if (fmt !== \"json\") {\n182:     console.log(`Latest version:  ${latestTag}`);\n183:   }\n184: \n185:   const cmp = compareSemver(localVersion, latestVersion);\n186:   if (cmp >= 0) {\n187:     outputMessage(fmt, \"You are already up to date.\", {\n188:       current_version: `v${localVersion}`,\n189:       latest_version: latestTag,\n190:       up_to_date: true,\n191:     });\n192:     return;\n193:   }\n194: \n195:   if (opts.checkOnly) {\n196:     output(\n197:       fmt,\n198:       {\n199:         current_version: `v${localVersion}`,\n200:         latest_version: latestTag,\n201:         update_available: true,\n202:         up_to_date: false,\n203:       },\n204:       () => {\n205:         console.log(`\\nUpdate available: v${localVersion} → ${latestTag}`);\n206:         console.log(`Run 'wombo upgrade' to install.`);\n207:       }\n208:     );\n209:     return;\n210:   }\n211: \n212:   if (fmt !== \"json\") {\n213:     console.log(`\\nUpdate available: v${localVersion} → ${latestTag}`);\n214:   }\n215: \n216:   if (!opts.force && fmt !== \"json\") {\n217:     const ok = await confirm(`Upgrade to ${latestTag}?`);\n218:     if (!ok) {\n219:       outputMessage(fmt, \"Upgrade cancelled.\", {\n220:         current_version: `v${localVersion}`,\n221:         latest_version: latestTag,\n222:         cancelled: true,\n223:       });\n224:       return;\n225:     }\n226:   }\n227: \n228:   await installVersion(latestTag, fmt);\n229: }\n230: \n231: async function installVersion(tag: string, fmt: OutputFormat = \"text\"): Promise<void> {\n232:   if (fmt !== \"json\") {\n233:     console.log(`\\nInstalling wombo@${tag}...`);\n234:   }\n235: \n236:   const proc = Bun.spawn(\n237:     [\"bun\", \"install\", \"-g\", `github:${REPO}#${tag}`],\n238:     {\n239:       stdout: fmt === \"json\" ? \"pipe\" : \"inherit\",\n240:       stderr: fmt === \"json\" ? \"pipe\" : \"inherit\",\n241:     }\n242:   );\n243: \n244:   const exitCode = await proc.exited;\n245: \n246:   if (exitCode !== 0) {\n247:     outputError(fmt, `Installation failed (exit code ${exitCode}).`);\n248:     return;\n249:   }\n250: \n251:   outputMessage(fmt, `Successfully upgraded to ${tag}.`, {\n252:     version: tag,\n253:     success: true,\n254:   });\n255: }\n\n(End of file - total 255 lines)\n</content>","title":"src/commands/upgrade.ts","metadata":{"preview":"/**\n * upgrade.ts — Self-upgrade wombo from GitHub.\n *\n * Usage:\n *   wombo upgrade              # Check for updates and prompt to install\n *   wombo upgrade --force      # Skip confirmation prompt\n *   wombo upgrade --version v0.1.0  # Install a specific version\n *   wombo upgrade --check      # Only check, don't install\n */\n\nimport { readFileSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\nimport { createInterface } from \"node:readline\";\nimport { output, outputError, outputMessage, type OutputFormat } from \"../lib/output.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface UpgradeOptions {","truncated":false,"loaded":[]},"time":{"start":1773351888420,"end":1773351888424}}}}
