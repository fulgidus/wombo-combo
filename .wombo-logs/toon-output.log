{"type":"tool_use","timestamp":1773351657697,"sessionID":"ses_31c0172a9ffeekk99N9QZhhvnC","part":{"id":"prt_ce3fedde10016W1fXGoFElYnqC","sessionID":"ses_31c0172a9ffeekk99N9QZhhvnC","messageID":"msg_ce3fecc25001TQ58Z9hSHfdkwT","type":"tool","callID":"toolu_vrtx_012RKS6gJYqTGKFGrnJ6EhUS","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-toon-output/src/commands/features/archive.ts"},"output":"<path>/home/fulgidus/Documents/wombo-toon-output/src/commands/features/archive.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * features/archive.ts — Move done/cancelled features to the archive section.\n3:  *\n4:  * Usage:\n5:  *   wombo features archive              # archive all done + cancelled\n6:  *   wombo features archive <feature-id> # archive a specific feature\n7:  *   wombo features archive --dry-run    # show what would be archived\n8:  */\n9: \n10: import type { WomboConfig } from \"../../config.js\";\n11: import {\n12:   loadFeatures,\n13:   saveFeatures,\n14:   findFeatureById,\n15:   type Feature,\n16: } from \"../../lib/features.js\";\n17: \n18: // ---------------------------------------------------------------------------\n19: // Types\n20: // ---------------------------------------------------------------------------\n21: \n22: export interface FeaturesArchiveOptions {\n23:   projectRoot: string;\n24:   config: WomboConfig;\n25:   featureId?: string;\n26:   dryRun?: boolean;\n27: }\n28: \n29: // ---------------------------------------------------------------------------\n30: // Command\n31: // ---------------------------------------------------------------------------\n32: \n33: export async function cmdFeaturesArchive(opts: FeaturesArchiveOptions): Promise<void> {\n34:   const { projectRoot, config } = opts;\n35: \n36:   const data = loadFeatures(projectRoot, config);\n37: \n38:   // Ensure archive array exists\n39:   if (!data.archive) {\n40:     data.archive = [];\n41:   }\n42: \n43:   let toArchive: Feature[];\n44: \n45:   if (opts.featureId) {\n46:     // Archive a specific feature\n47:     const idx = data.features.findIndex((f) => f.id === opts.featureId);\n48:     if (idx === -1) {\n49:       // Check if already in archive\n50:       if (data.archive.find((f) => f.id === opts.featureId)) {\n51:         console.log(`Feature \"${opts.featureId}\" is already in the archive.`);\n52:         return;\n53:       }\n54:       console.error(`Feature \"${opts.featureId}\" not found.`);\n55:       process.exit(1);\n56:       return;\n57:     }\n58:     toArchive = [data.features[idx]];\n59:   } else {\n60:     // Archive all done + cancelled features\n61:     toArchive = data.features.filter(\n62:       (f) => f.status === \"done\" || f.status === \"cancelled\"\n63:     );\n64:   }\n65: \n66:   if (toArchive.length === 0) {\n67:     console.log(\"No features to archive.\");\n68:     return;\n69:   }\n70: \n71:   if (opts.dryRun) {\n72:     console.log(`\\nWould archive ${toArchive.length} feature(s):\\n`);\n73:     for (const f of toArchive) {\n74:       console.log(`  ${f.id} — ${f.title} (${f.status})`);\n75:     }\n76:     return;\n77:   }\n78: \n79:   // Move features from active to archive\n80:   const archiveIds = new Set(toArchive.map((f) => f.id));\n81:   data.features = data.features.filter((f) => !archiveIds.has(f.id));\n82:   data.archive.push(...toArchive);\n83: \n84:   saveFeatures(projectRoot, config, data);\n85: \n86:   console.log(`\\nArchived ${toArchive.length} feature(s):`);\n87:   for (const f of toArchive) {\n88:     console.log(`  ${f.id} — ${f.title} (${f.status})`);\n89:   }\n90: }\n\n(End of file - total 90 lines)\n</content>","title":"src/commands/features/archive.ts","metadata":{"preview":"/**\n * features/archive.ts — Move done/cancelled features to the archive section.\n *\n * Usage:\n *   wombo features archive              # archive all done + cancelled\n *   wombo features archive <feature-id> # archive a specific feature\n *   wombo features archive --dry-run    # show what would be archived\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  saveFeatures,\n  findFeatureById,\n  type Feature,\n} from \"../../lib/features.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------","truncated":false,"loaded":[]},"time":{"start":1773351657693,"end":1773351657696}}}}
