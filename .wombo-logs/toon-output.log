{"type":"tool_use","timestamp":1773351756719,"sessionID":"ses_31c0172a9ffeekk99N9QZhhvnC","part":{"id":"prt_ce3ff415f001yu02Ipxy6NjOrd","sessionID":"ses_31c0172a9ffeekk99N9QZhhvnC","messageID":"msg_ce3ff354f001tSATIo8v72QJk6","type":"tool","callID":"toolu_vrtx_013Y9fWxnV9YL7PfrBDXx1Fx","tool":"write","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-toon-output/src/lib/toon.ts","content":"/**\n * toon.ts — Token-Optimized Output Notation (TOON) formatter.\n *\n * TOON is an ultra-compact output format designed for LLM agent consumption.\n * It minimizes token count by using:\n *   - Pipe-delimited fields (no quotes, no braces, no repeated keys)\n *   - Single/two-char status codes (BL, IP, DN, etc.)\n *   - Single-char priority codes (C, H, M, L, W)\n *   - Single-char difficulty codes (T, E, M, H, V)\n *   - No whitespace padding or decorative elements\n *   - Newline-separated records\n *\n * Format is self-describing via the legend (emitted by `woco describe --output toon`).\n *\n * Field ordering per record type:\n *   feature-row:  id|status|priority|difficulty|effort|completion|title[|deps]\n *   feature-show: id|status|priority|difficulty|effort|completion|deps_met|title\n *   status-msg:   MSG|message\n *   error-msg:    ERR|message\n *   subtask-row:  >id|status|priority|difficulty|effort|completion|title\n *   set-status:   SET|id|old_status|new_status|changed\n *   add-result:   ADD|id|priority|difficulty|effort|title\n *   graph-info:   GRAPH|nodes|edges|orphans\n */\n\nimport type { FeatureStatus, Priority, Difficulty, Feature, Subtask } from \"./features.js\";\nimport type { AgentStatus } from \"./state.js\";\n\n// ---------------------------------------------------------------------------\n// Encoding Maps\n// ---------------------------------------------------------------------------\n\n/** Status codes: 2 chars, unambiguous abbreviations */\nexport const STATUS_CODE: Record<FeatureStatus, string> = {\n  backlog: \"BL\",\n  planned: \"PL\",\n  in_progress: \"IP\",\n  blocked: \"BK\",\n  in_review: \"IR\",\n  done: \"DN\",\n  cancelled: \"XX\",\n};\n\n/** Reverse lookup: code -> status */\nexport const STATUS_DECODE: Record<string, FeatureStatus> = Object.fromEntries(\n  Object.entries(STATUS_CODE).map(([k, v]) => [v, k as FeatureStatus])\n) as Record<string, FeatureStatus>;\n\n/** Priority codes: single char */\nexport const PRIORITY_CODE: Record<Priority, string> = {\n  critical: \"C\",\n  high: \"H\",\n  medium: \"M\",\n  low: \"L\",\n  wishlist: \"W\",\n};\n\n/** Reverse lookup: code -> priority */\nexport const PRIORITY_DECODE: Record<string, Priority> = Object.fromEntries(\n  Object.entries(PRIORITY_CODE).map(([k, v]) => [v, k as Priority])\n) as Record<string, Priority>;\n\n/** Difficulty codes: single char */\nexport const DIFFICULTY_CODE: Record<Difficulty, string> = {\n  trivial: \"T\",\n  easy: \"E\",\n  medium: \"M\",\n  hard: \"H\",\n  very_hard: \"V\",\n};\n\n/** Reverse lookup: code -> difficulty */\nexport const DIFFICULTY_DECODE: Record<string, Difficulty> = Object.fromEntries(\n  Object.entries(DIFFICULTY_CODE).map(([k, v]) => [v, k as Difficulty])\n) as Record<string, Difficulty>;\n\n/** Agent status codes: 2 chars */\nexport const AGENT_STATUS_CODE: Record<AgentStatus, string> = {\n  queued: \"QU\",\n  installing: \"IN\",\n  running: \"RU\",\n  completed: \"CO\",\n  verified: \"VF\",\n  failed: \"FA\",\n  merged: \"MG\",\n  retry: \"RT\",\n  resolving_conflict: \"RC\",\n};\n\n// ---------------------------------------------------------------------------\n// Delimiter\n// ---------------------------------------------------------------------------\n\n/** Field delimiter */\nconst D = \"|\";\n\n/** List delimiter (for arrays within a field, e.g., deps) */\nconst LD = \",\";\n\n// ---------------------------------------------------------------------------\n// Encoding Helpers\n// ---------------------------------------------------------------------------\n\n/** Encode a status value to its TOON code */\nexport function encStatus(s: FeatureStatus): string {\n  return STATUS_CODE[s] ?? s;\n}\n\n/** Encode a priority value to its TOON code */\nexport function encPriority(p: Priority): string {\n  return PRIORITY_CODE[p] ?? p;\n}\n\n/** Encode a difficulty value to its TOON code */\nexport function encDifficulty(d: Difficulty): string {\n  return DIFFICULTY_CODE[d] ?? d;\n}\n\n/** Encode an agent status to its TOON code */\nexport function encAgentStatus(s: AgentStatus): string {\n  return AGENT_STATUS_CODE[s] ?? s;\n}\n\n/** Encode a boolean to 1/0 */\nfunction encBool(b: boolean | null | undefined): string {\n  if (b === null || b === undefined) return \"-\";\n  return b ? \"1\" : \"0\";\n}\n\n/** Encode a deps array to comma-separated string or \"-\" if empty */\nfunction encDeps(deps: string[]): string {\n  return deps.length > 0 ? deps.join(LD) : \"-\";\n}\n\n/** Sanitize a string field: replace pipes with dashes to prevent field corruption */\nfunction sanitize(s: string): string {\n  return s.replace(/\\|/g, \"-\").replace(/\\n/g, \" \");\n}\n\n// ---------------------------------------------------------------------------\n// Feature Encoding\n// ---------------------------------------------------------------------------\n\n/**\n * Encode a single feature as a TOON row.\n * Format: id|status|priority|difficulty|effort|completion|title[|deps]\n */\nexport function toonFeatureRow(f: {\n  id: string;\n  status: FeatureStatus;\n  priority: Priority;\n  difficulty: Difficulty;\n  effort: string;\n  completion: number;\n  title: string;\n  depends_on: string[];\n}): string {\n  const parts = [\n    f.id,\n    encStatus(f.status),\n    encPriority(f.priority),\n    encDifficulty(f.difficulty),\n    f.effort,\n    String(f.completion),\n    sanitize(f.title),\n  ];\n  if (f.depends_on.length > 0) {\n    parts.push(encDeps(f.depends_on));\n  }\n  return parts.join(D);\n}\n\n/**\n * Encode a subtask as a TOON row (prefixed with > for nesting).\n * Format: >id|status|priority|difficulty|effort|completion|title\n */\nexport function toonSubtaskRow(st: Subtask, depth: number = 1): string {\n  const prefix = \">\".repeat(depth);\n  const parts = [\n    prefix + st.id,\n    encStatus(st.status),\n    encPriority(st.priority),\n    encDifficulty(st.difficulty),\n    st.effort,\n    String(st.completion),\n    sanitize(st.title),\n  ];\n  if (st.depends_on.length > 0) {\n    parts.push(encDeps(st.depends_on));\n  }\n  return parts.join(D);\n}\n\n/**\n * Encode a full feature list as TOON output.\n * Header line: #FL|total|effort\n * Then one row per feature.\n */\nexport function toonFeatureList(\n  features: {\n    id: string;\n    status: FeatureStatus;\n    priority: Priority;\n    difficulty: Difficulty;\n    effort: string;\n    completion: number;\n    title: string;\n    depends_on: string[];\n  }[],\n  totalEffort: string\n): string {\n  const lines: string[] = [];\n  lines.push(`#FL${D}${features.length}${D}${totalEffort}`);\n  for (const f of features) {\n    lines.push(toonFeatureRow(f));\n  }\n  return lines.join(\"\\n\");\n}\n\n/**\n * Encode a feature show (detail view) as TOON output.\n * Header: #FS\n * Main row: id|status|priority|difficulty|effort|completion|deps_met|title\n * Description line (if any): #DESC|description\n * Deps lines: #DEP|dep_id|met\n * Constraint lines: #CON|constraint_text\n * Forbidden lines: #FBD|forbidden_text\n * Reference lines: #REF|reference_text\n * Note lines: #NOTE|note_text\n * Subtask lines: >subtask rows\n */\nexport function toonFeatureShow(\n  f: Feature,\n  depsMet: boolean\n): string {\n  const lines: string[] = [];\n  lines.push(\"#FS\");\n  lines.push(\n    [\n      f.id,\n      encStatus(f.status),\n      encPriority(f.priority),\n      encDifficulty(f.difficulty),\n      f.effort,\n      String(f.completion),\n      encBool(depsMet),\n      sanitize(f.title),\n    ].join(D)\n  );\n\n  if (f.description) {\n    lines.push(`#DESC${D}${sanitize(f.description)}`);\n  }\n\n  if (f.started_at) {\n    lines.push(`#START${D}${f.started_at}`);\n  }\n  if (f.ended_at) {\n    lines.push(`#END${D}${f.ended_at}`);\n  }\n\n  for (const dep of f.depends_on) {\n    lines.push(`#DEP${D}${dep}`);\n  }\n\n  for (const c of f.constraints) {\n    lines.push(`#CON${D}${sanitize(c)}`);\n  }\n\n  for (const fb of f.forbidden) {\n    lines.push(`#FBD${D}${sanitize(fb)}`);\n  }\n\n  for (const r of f.references) {\n    lines.push(`#REF${D}${sanitize(r)}`);\n  }\n\n  for (const n of f.notes) {\n    lines.push(`#NOTE${D}${sanitize(n)}`);\n  }\n\n  if (f.subtasks.length > 0) {\n    appendSubtasks(f.subtasks, lines, 1);\n  }\n\n  return lines.join(\"\\n\");\n}\n\n/**\n * Recursively append subtask rows to lines.\n */\nfunction appendSubtasks(subtasks: Subtask[], lines: string[], depth: number): void {\n  for (const st of subtasks) {\n    lines.push(toonSubtaskRow(st, depth));\n    if (st.subtasks.length > 0) {\n      appendSubtasks(st.subtasks, lines, depth + 1);\n    }\n  }\n}\n\n/**\n * Encode an add-feature result as TOON.\n * Format: ADD|id|priority|difficulty|effort|title\n */\nexport function toonAddResult(\n  id: string,\n  title: string,\n  priority: Priority,\n  difficulty: Difficulty,\n  effort: string,\n  dryRun: boolean = false\n): string {\n  const prefix = dryRun ? \"DRYADD\" : \"ADD\";\n  return [prefix, id, encPriority(priority), encDifficulty(difficulty), effort, sanitize(title)].join(D);\n}\n\n/**\n * Encode a set-status result as TOON.\n * Format: SET|id|old_status|new_status|changed\n */\nexport function toonSetStatusResult(\n  id: string,\n  oldStatus: FeatureStatus,\n  newStatus: FeatureStatus,\n  changed: boolean,\n  dryRun: boolean = false\n): string {\n  const prefix = dryRun ? \"DRYSET\" : \"SET\";\n  return [prefix, id, encStatus(oldStatus), encStatus(newStatus), encBool(changed)].join(D);\n}\n\n/**\n * Encode a graph result as TOON.\n * Format: GRAPH|nodes|edges|orphans\n * Then mermaid source lines prefixed with ~\n */\nexport function toonGraphResult(\n  nodes: number,\n  edges: number,\n  orphans: number,\n  mermaidSource?: string\n): string {\n  const lines: string[] = [];\n  lines.push(`GRAPH${D}${nodes}${D}${edges}${D}${orphans}`);\n  if (mermaidSource) {\n    for (const line of mermaidSource.split(\"\\n\")) {\n      lines.push(`~${line}`);\n    }\n  }\n  return lines.join(\"\\n\");\n}\n\n/**\n * Encode an error message in TOON.\n * Format: ERR|message\n */\nexport function toonError(message: string): string {\n  return `ERR${D}${sanitize(message)}`;\n}\n\n/**\n * Encode an info/success message in TOON.\n * Format: MSG|message\n */\nexport function toonMessage(message: string, extra?: Record<string, unknown>): string {\n  const parts = [`MSG${D}${sanitize(message)}`];\n  if (extra) {\n    for (const [k, v] of Object.entries(extra)) {\n      if (v !== undefined && v !== null) {\n        const val = Array.isArray(v) ? v.join(LD) : String(v);\n        parts.push(`${k}=${sanitize(val)}`);\n      }\n    }\n  }\n  return parts.join(D);\n}\n\n/**\n * Encode the wave status dashboard in TOON.\n * Header: #WS|wave_id|base_branch|total_agents\n * Agent rows: agent_feature_id|agent_status|retries|build_passed\n */\nexport function toonWaveStatus(state: {\n  wave_id: string;\n  base_branch: string;\n  agents: {\n    feature_id: string;\n    status: AgentStatus;\n    retries: number;\n    build_passed: boolean | null;\n  }[];\n}): string {\n  const lines: string[] = [];\n  lines.push(`#WS${D}${state.wave_id}${D}${state.base_branch}${D}${state.agents.length}`);\n  for (const a of state.agents) {\n    lines.push(\n      [a.feature_id, encAgentStatus(a.status), String(a.retries), encBool(a.build_passed)].join(D)\n    );\n  }\n  return lines.join(\"\\n\");\n}\n\n// ---------------------------------------------------------------------------\n// Legend / Schema Description\n// ---------------------------------------------------------------------------\n\n/**\n * Generate the TOON legend — a self-describing schema that agents can\n * request once at session start to understand the format.\n *\n * Emitted by `woco describe --output toon`.\n */\nexport function toonLegend(): string {\n  const lines: string[] = [];\n\n  lines.push(\"#TOON v1\");\n  lines.push(\"#LEGEND\");\n  lines.push(\"\");\n\n  // Delimiter\n  lines.push(\"#DELIM|pipe(|)field,comma(,)list\");\n  lines.push(\"\");\n\n  // Status codes\n  lines.push(\"#STATUS\");\n  for (const [status, code] of Object.entries(STATUS_CODE)) {\n    lines.push(`${code}=${status}`);\n  }\n  lines.push(\"\");\n\n  // Priority codes\n  lines.push(\"#PRIORITY\");\n  for (const [priority, code] of Object.entries(PRIORITY_CODE)) {\n    lines.push(`${code}=${priority}`);\n  }\n  lines.push(\"\");\n\n  // Difficulty codes\n  lines.push(\"#DIFFICULTY\");\n  for (const [difficulty, code] of Object.entries(DIFFICULTY_CODE)) {\n    lines.push(`${code}=${difficulty}`);\n  }\n  lines.push(\"\");\n\n  // Agent status codes\n  lines.push(\"#AGENT_STATUS\");\n  for (const [status, code] of Object.entries(AGENT_STATUS_CODE)) {\n    lines.push(`${code}=${status}`);\n  }\n  lines.push(\"\");\n\n  // Boolean encoding\n  lines.push(\"#BOOL\");\n  lines.push(\"1=true,0=false,-=null\");\n  lines.push(\"\");\n\n  // Record formats\n  lines.push(\"#FORMATS\");\n  lines.push(\"feature-row: id|status|priority|difficulty|effort|completion|title[|deps]\");\n  lines.push(\"feature-show: #FS then id|status|priority|difficulty|effort|completion|deps_met|title\");\n  lines.push(\"feature-list: #FL|count|total_effort then feature-rows\");\n  lines.push(\"subtask: >id|status|priority|difficulty|effort|completion|title[|deps]\");\n  lines.push(\"set-status: SET|id|old|new|changed\");\n  lines.push(\"add: ADD|id|priority|difficulty|effort|title\");\n  lines.push(\"graph: GRAPH|nodes|edges|orphans then ~mermaid-lines\");\n  lines.push(\"wave-status: #WS|wave_id|base_branch|count then agent-rows\");\n  lines.push(\"agent-row: feature_id|agent_status|retries|build_passed\");\n  lines.push(\"message: MSG|text[|key=val...]\");\n  lines.push(\"error: ERR|text\");\n  lines.push(\"dry-run: prefix DRY (DRYADD, DRYSET)\");\n  lines.push(\"desc-line: #DESC|text, #DEP|id, #CON|text, #FBD|text, #REF|text, #NOTE|text\");\n  lines.push(\"timestamps: #START|iso, #END|iso\");\n\n  return lines.join(\"\\n\");\n}\n\n/**\n * Encode a command schema in TOON format (for describe command).\n * Format: #CMD|name|summary|mutating|dry_run\n * Positionals: #POS|name|required|description\n * Flags: #FLG|name|type|default|description[|enum_values]\n */\nexport function toonCommandSchema(cmd: {\n  command: string;\n  summary: string;\n  mutating: boolean;\n  supports_dry_run: boolean;\n  description?: string;\n  positionals?: { name: string; description: string; required: boolean }[];\n  flags?: {\n    name: string;\n    type: string;\n    description: string;\n    alias?: string;\n    default?: unknown;\n    enum?: readonly string[];\n    required?: boolean;\n  }[];\n  subcommands?: string[];\n}): string {\n  const lines: string[] = [];\n  lines.push(\n    [`#CMD`, cmd.command, sanitize(cmd.summary), encBool(cmd.mutating), encBool(cmd.supports_dry_run)].join(D)\n  );\n\n  if (cmd.positionals) {\n    for (const p of cmd.positionals) {\n      lines.push([`#POS`, p.name, encBool(p.required), sanitize(p.description)].join(D));\n    }\n  }\n\n  if (cmd.flags) {\n    for (const f of cmd.flags) {\n      const parts = [\n        `#FLG`,\n        f.name,\n        f.type,\n        f.default !== undefined ? String(f.default) : \"-\",\n        sanitize(f.description),\n      ];\n      if (f.enum) {\n        parts.push(f.enum.join(LD));\n      }\n      lines.push(parts.join(D));\n    }\n  }\n\n  if (cmd.subcommands?.length) {\n    lines.push(`#SUB${D}${cmd.subcommands.join(LD)}`);\n  }\n\n  return lines.join(\"\\n\");\n}\n\n/**\n * Encode a list of all command schemas in TOON format.\n */\nexport function toonAllCommandSchemas(schemas: {\n  tool: string;\n  version: string;\n  commands: {\n    name: string;\n    summary: string;\n    mutating: boolean;\n    supports_dry_run: boolean;\n    subcommands?: { name: string; summary: string; mutating: boolean; supports_dry_run: boolean }[];\n  }[];\n}): string {\n  const lines: string[] = [];\n  lines.push(`#TOOL${D}${schemas.tool}${D}${schemas.version}`);\n\n  for (const cmd of schemas.commands) {\n    lines.push(\n      [`#CMD`, cmd.name, sanitize(cmd.summary), encBool(cmd.mutating), encBool(cmd.supports_dry_run)].join(D)\n    );\n    if (cmd.subcommands) {\n      for (const sc of cmd.subcommands) {\n        lines.push(\n          [`#SCMD`, sc.name, sanitize(sc.summary), encBool(sc.mutating), encBool(sc.supports_dry_run)].join(D)\n        );\n      }\n    }\n  }\n\n  return lines.join(\"\\n\");\n}\n\n/**\n * Encode verification results in TOON format.\n * Format: #VFY|feature_id|passed|message\n */\nexport function toonVerifyResult(\n  featureId: string,\n  passed: boolean,\n  message?: string\n): string {\n  return [`#VFY`, featureId, encBool(passed), message ? sanitize(message) : \"-\"].join(D);\n}\n\n/**\n * Encode check results in TOON format.\n * Header: #CHK|total_items|errors|warnings\n * Error lines: #CERR|message\n * Warning lines: #CWRN|message\n */\nexport function toonCheckResult(\n  totalItems: number,\n  errors: string[],\n  warnings: string[]\n): string {\n  const lines: string[] = [];\n  lines.push(`#CHK${D}${totalItems}${D}${errors.length}${D}${warnings.length}`);\n  for (const e of errors) {\n    lines.push(`#CERR${D}${sanitize(e)}`);\n  }\n  for (const w of warnings) {\n    lines.push(`#CWRN${D}${sanitize(w)}`);\n  }\n  return lines.join(\"\\n\");\n}\n\n/**\n * Encode archive results in TOON format.\n * Format: #ARC|count then feature_id|title|status per archived feature\n */\nexport function toonArchiveResult(\n  archived: { id: string; title: string; status: FeatureStatus }[],\n  dryRun: boolean = false\n): string {\n  const lines: string[] = [];\n  const prefix = dryRun ? \"#DRYARC\" : \"#ARC\";\n  lines.push(`${prefix}${D}${archived.length}`);\n  for (const f of archived) {\n    lines.push([f.id, sanitize(f.title), encStatus(f.status)].join(D));\n  }\n  return lines.join(\"\\n\");\n}\n"},"output":"Wrote file successfully.","title":"src/lib/toon.ts","metadata":{"diagnostics":{"/home/fulgidus/Documents/wombo-toon-output/src/index.ts":[{"range":{"start":{"line":447,"character":8},"end":{"line":447,"character":14}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":542,"character":8},"end":{"line":542,"character":14}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":567,"character":6},"end":{"line":567,"character":12}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":600,"character":8},"end":{"line":600,"character":14}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":626,"character":10},"end":{"line":626,"character":16}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":667,"character":8},"end":{"line":667,"character":14}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":701,"character":6},"end":{"line":701,"character":12}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"}],"/home/fulgidus/Documents/wombo-toon-output/src/lib/output.ts":[],"/home/fulgidus/Documents/wombo-toon-output/src/lib/features.ts":[],"/home/fulgidus/Documents/wombo-toon-output/src/lib/schema.ts":[],"/home/fulgidus/Documents/wombo-toon-output/src/commands/features/list.ts":[{"range":{"start":{"line":15,"character":2},"end":{"line":15,"character":16}},"message":"'featureSummary' is declared but its value is n