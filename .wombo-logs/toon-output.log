"},{"range":{"start":{"line":71,"character":8},"end":{"line":71,"character":14}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"}],"/home/fulgidus/Documents/wombo-toon-output/src/commands/features/set-status.ts":[{"range":{"start":{"line":52,"character":4},"end":{"line":52,"character":10}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":58,"character":4},"end":{"line":58,"character":10}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":66,"character":4},"end":{"line":66,"character":10}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"}],"/home/fulgidus/Documents/wombo-toon-output/src/commands/features/graph.ts":[{"range":{"start":{"line":24,"character":0},"end":{"line":24,"character":52}},"message":"'toonGraphResult' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"},{"range":{"start":{"line":28,"character":35},"end":{"line":28,"character":47}},"message":"Could not find a declaration file for module 'mermaidtui'. '/home/fulgidus/Documents/wombo-toon-output/node_modules/mermaidtui/dist/src/index.js' implicitly has an 'any' type.\n  Try `npm i --save-dev @types/mermaidtui` if it exists or add a new declaration (.d.ts) file containing `declare module 'mermaidtui';`","severity":4,"code":7016,"source":"typescript"},{"range":{"start":{"line":220,"character":6},"end":{"line":220,"character":11}},"message":"'GREEN' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"}],"/home/fulgidus/Documents/wombo-toon-output/src/commands/status.ts":[],"/home/fulgidus/Documents/wombo-toon-output/src/lib/state.ts":[],"/home/fulgidus/Documents/wombo-toon-output/src/commands/features/check.ts":[{"range":{"start":{"line":19,"character":2},"end":{"line":19,"character":15}},"message":"'allFeatureIds' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"}],"/home/fulgidus/Documents/wombo-toon-output/src/commands/features/archive.ts":[{"range":{"start":{"line":13,"character":2},"end":{"line":13,"character":17}},"message":"'findFeatureById' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"},{"range":{"start":{"line":55,"character":6},"end":{"line":55,"character":12}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"}],"/home/fulgidus/Documents/wombo-toon-output/src/lib/toon.ts":[]},"diff":"Index: /home/fulgidus/Documents/wombo-toon-output/src/commands/features/graph.ts\n===================================================================\n--- /home/fulgidus/Documents/wombo-toon-output/src/commands/features/graph.ts\n+++ /home/fulgidus/Documents/wombo-toon-output/src/commands/features/graph.ts\n@@ -21,8 +21,9 @@\n   type FeatureStatus,\n   type FeaturesFile,\n } from \"../../lib/features.js\";\n import { output, type OutputFormat } from \"../../lib/output.js\";\n+import { toonGraphResult } from \"../../lib/toon.js\";\n \n // mermaidtui has no type declarations — import the JS module directly\n // @ts-ignore — no .d.ts published\n import { renderMermaidToTui } from \"mermaidtui\";\n","filediff":{"file":"/home/fulgidus/Documents/wombo-toon-output/src/commands/features/graph.ts","before":"/**\n * features/graph.ts — Visualize the feature dependency graph.\n *\n * Usage:\n *   wombo features graph                     # show full dependency graph\n *   wombo features graph --status backlog    # filter by status\n *   wombo features graph --ascii             # ASCII-only rendering\n *   wombo features graph --output json       # emit mermaid source as JSON\n *   wombo features graph --mermaid           # emit raw mermaid source text\n *   wombo features graph --subtasks          # include subtask-level nodes\n *\n * Builds a Mermaid flowchart from the features dependency graph and renders\n * it as a Unicode box diagram in the terminal using mermaidtui.\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  type Feature,\n  type Subtask,\n  type FeatureStatus,\n  type FeaturesFile,\n} from \"../../lib/features.js\";\nimport { output, type OutputFormat } from \"../../lib/output.js\";\n\n// mermaidtui has no type declarations — import the JS module directly\n// @ts-ignore — no .d.ts published\nimport { renderMermaidToTui } from \"mermaidtui\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface FeaturesGraphOptions {\n  projectRoot: string;\n  config: WomboConfig;\n  status?: FeatureStatus;\n  ascii?: boolean;\n  mermaid?: boolean;\n  subtasks?: boolean;\n  outputFmt?: OutputFormat;\n}\n\n// ---------------------------------------------------------------------------\n// Status styling for Mermaid classDef\n// ---------------------------------------------------------------------------\n\n// Short status badge for node labels\nconst STATUS_BADGE: Record<FeatureStatus, string> = {\n  backlog: \"BL\",\n  planned: \"PL\",\n  in_progress: \"IP\",\n  blocked: \"BK\",\n  in_review: \"IR\",\n  done: \"DN\",\n  cancelled: \"XX\",\n};\n\n// ---------------------------------------------------------------------------\n// Mermaid generation\n// ---------------------------------------------------------------------------\n\n/**\n * Sanitize a string for use inside Mermaid labels.\n * Mermaid uses square brackets for labels — we need to escape them.\n */\nfunction sanitizeLabel(s: string): string {\n  return s\n    .replace(/\"/g, \"'\")\n    .replace(/\\[/g, \"(\")\n    .replace(/\\]/g, \")\")\n    .replace(/\\n/g, \" \")\n    .slice(0, 40); // keep labels short for terminal rendering\n}\n\n/**\n * Generate a safe Mermaid node ID from a feature/subtask ID.\n * Mermaid IDs can't start with numbers and some chars are reserved.\n */\nfunction nodeId(id: string): string {\n  return `n_${id.replace(/-/g, \"_\")}`;\n}\n\n/**\n * Collect all node IDs that exist in the graph (for filtering dangling deps).\n */\nfunction collectAllIds(\n  features: Feature[],\n  includeSubtasks: boolean\n): Set<string> {\n  const ids = new Set<string>();\n  for (const f of features) {\n    ids.add(f.id);\n    if (includeSubtasks) {\n      collectSubtaskIds(f.subtasks, ids);\n    }\n  }\n  return ids;\n}\n\nfunction collectSubtaskIds(subtasks: Subtask[], ids: Set<string>): void {\n  for (const st of subtasks) {\n    ids.add(st.id);\n    collectSubtaskIds(st.subtasks, ids);\n  }\n}\n\n/**\n * Build the Mermaid flowchart source from the features file.\n */\nfunction buildMermaidSource(\n  data: FeaturesFile,\n  opts: { status?: FeatureStatus; subtasks?: boolean }\n): { source: string; nodeCount: number; edgeCount: number; orphanCount: number } {\n  let features = [...data.features];\n\n  // Filter by status if requested\n  if (opts.status) {\n    features = features.filter((f) => f.status === opts.status);\n  }\n\n  if (features.length === 0) {\n    return { source: \"\", nodeCount: 0, edgeCount: 0, orphanCount: 0 };\n  }\n\n  const allIds = collectAllIds(features, !!opts.subtasks);\n  const lines: string[] = [\"flowchart LR\"];\n  let nodeCount = 0;\n  let edgeCount = 0;\n  let orphanCount = 0;\n\n  // Process each feature\n  for (const f of features) {\n    const nid = nodeId(f.id);\n    const badge = STATUS_BADGE[f.status];\n    const label = `${badge} ${sanitizeLabel(f.title)}`;\n    lines.push(`    ${nid}[${label}]`);\n    nodeCount++;\n\n    let hasDeps = false;\n\n    // Add dependency edges\n    for (const dep of f.depends_on) {\n      if (allIds.has(dep)) {\n        lines.push(`    ${nodeId(dep)} --> ${nid}`);\n        edgeCount++;\n        hasDeps = true;\n      }\n    }\n\n    // Process subtasks if requested\n    if (opts.subtasks && f.subtasks.length > 0) {\n      const result = processSubtasks(f.subtasks, nid, allIds, lines);\n      nodeCount += result.nodeCount;\n      edgeCount += result.edgeCount;\n      if (result.nodeCount > 0) hasDeps = true;\n    }\n\n    if (!hasDeps && f.depends_on.length === 0 && (!opts.subtasks || f.subtasks.length === 0)) {\n      orphanCount++;\n    }\n  }\n\n  return {\n    source: lines.join(\"\\n\"),\n    nodeCount,\n    edgeCount,\n    orphanCount,\n  };\n}\n\nfunction processSubtasks(\n  subtasks: Subtask[],\n  parentNodeId: string,\n  allIds: Set<string>,\n  lines: string[]\n): { nodeCount: number; edgeCount: number } {\n  let nodeCount = 0;\n  let edgeCount = 0;\n\n  for (const st of subtasks) {\n    const nid = nodeId(st.id);\n    const badge = STATUS_BADGE[st.status];\n    const label = `${badge} ${sanitizeLabel(st.title)}`;\n    lines.push(`    ${nid}[${label}]`);\n    nodeCount++;\n\n    // Link parent to subtask\n    lines.push(`    ${parentNodeId} --> ${nid}`);\n    edgeCount++;\n\n    // Subtask's own dependencies\n    for (const dep of st.depends_on) {\n      if (allIds.has(dep)) {\n        lines.push(`    ${nodeId(dep)} --> ${nid}`);\n        edgeCount++;\n      }\n    }\n\n    // Recurse into nested subtasks\n    if (st.subtasks.length > 0) {\n      const result = processSubtasks(st.subtasks, nid, allIds, lines);\n      nodeCount += result.nodeCount;\n      edgeCount += result.edgeCount;\n    }\n  }\n\n  return { nodeCount, edgeCount };\n}\n\n// ---------------------------------------------------------------------------\n// Text rendering helpers\n// ---------------------------------------------------------------------------\n\nconst RESET = \"\\x1b[0m\";\nconst BOLD = \"\\x1b[1m\";\nconst DIM = \"\\x1b[2m\";\nconst RED = \"\\x1b[31m\";\nconst YELLOW = \"\\x1b[33m\";\nconst GREEN = \"\\x1b[32m\";\nconst CYAN = \"\\x1b[36m\";\n\n/**\n * Print a legend explaining the status badges used in the graph.\n */\nfunction printLegend(features: Feature[]): void {\n  const statuses = new Set<FeatureStatus>();\n  for (const f of features) {\n    statuses.add(f.status);\n  }\n\n  console.log(`\\n${BOLD}Legend:${RESET}`);\n  const legendItems: string[] = [];\n  for (const [status, badge] of Object.entries(STATUS_BADGE)) {\n    if (statuses.has(status as FeatureStatus)) {\n      legendItems.push(`  ${badge} = ${status}`);\n    }\n  }\n  console.log(legendItems.join(\"  |\"));\n}\n\n/**\n * Detect potential issues in the dependency graph and print warnings.\n */\nfunction printDiagnostics(data: FeaturesFile, includeSubtasks: boolean): void {\n  const allIds = collectAllIds(data.features, includeSubtasks);\n  const issues: string[] = [];\n\n  // Check for dangling dependencies (pointing to non-existent IDs)\n  for (const f of data.features) {\n    for (const dep of f.depends_on) {\n      if (!allIds.has(dep)) {\n        issues.push(`${YELLOW}WARNING${RESET}: ${f.id} depends on \"${dep}\" which does not exist`);\n      }\n    }\n    if (includeSubtasks) {\n      checkSubtaskDeps(f.subtasks, allIds, issues);\n    }\n  }\n\n  // Check for circular dependencies (simple DFS)\n  const circularPaths = detectCycles(data.features, includeSubtasks);\n  for (const cycle of circularPaths) {\n    issues.push(`${RED}CYCLE${RESET}: ${cycle.join(\" -> \")}`);\n  }\n\n  // Check for blocked features whose blockers are done\n  for (const f of data.features) {\n    if (f.status === \"blocked\") {\n      const allDepsDone = f.depends_on.every((dep) => {\n        const depFeature = data.features.find((ff) => ff.id === dep);\n        return depFeature?.status === \"done\";\n      });\n      if (allDepsDone && f.depends_on.length > 0) {\n        issues.push(\n          `${CYAN}INFO${RESET}: ${f.id} is marked \"blocked\" but all its dependencies are done`\n        );\n      }\n    }\n  }\n\n  if (issues.length > 0) {\n    console.log(`\\n${BOLD}Diagnostics (${issues.length} issue${issues.length > 1 ? \"s\" : \"\"}):${RESET}`);\n    for (const issue of issues) {\n      console.log(`  ${issue}`);\n    }\n  }\n}\n\nfunction checkSubtaskDeps(\n  subtasks: Subtask[],\n  allIds: Set<string>,\n  issues: string[]\n): void {\n  for (const st of subtasks) {\n    for (const dep of st.depends_on) {\n      if (!allIds.has(dep)) {\n        issues.push(\n          `${YELLOW}WARNING${RESET}: subtask ${st.id} depends on \"${dep}\" which does not exist`\n        );\n      }\n    }\n    checkSubtaskDeps(st.subtasks, allIds, issues);\n  }\n}\n\n/**\n * Detect circular dependencies using DFS.\n * Returns arrays of ID paths that form cycles.\n */\nfunction detectCycles(\n  features: Feature[],\n  includeSubtasks: boolean\n): string[][] {\n  // Build adjacency list: dep -> [dependents]\n  const adj = new Map<string, string[]>();\n  const allItems = new Map<string, { depends_on: string[] }>();\n\n  for (const f of features) {\n    allItems.set(f.id, f);\n    if (includeSubtasks) {\n      collectSubtaskItems(f.subtasks, allItems);\n    }\n  }\n\n  for (const [id, item] of allItems) {\n    for (const dep of item.depends_on) {\n      if (!adj.has(id)) adj.set(id, []);\n      adj.get(id)!.push(dep);\n    }\n  }\n\n  const visited = new Set<string>();\n  const inStack = new Set<string>();\n  const cycles: string[][] = [];\n\n  function dfs(node: string, path: string[]): void {\n    if (inStack.has(node)) {\n      // Found a cycle — extract it\n      const cycleStart = path.indexOf(node);\n      cycles.push([...path.slice(cycleStart), node]);\n      return;\n    }\n    if (visited.has(node)) return;\n\n    visited.add(node);\n    inStack.add(node);\n    path.push(node);\n\n    for (const neighbor of adj.get(node) ?? []) {\n      dfs(neighbor, path);\n    }\n\n    path.pop();\n    inStack.delete(node);\n  }\n\n  for (const id of allItems.keys()) {\n    if (!visited.has(id)) {\n      dfs(id, []);\n    }\n  }\n\n  return cycles;\n}\n\nfunction collectSubtaskItems(\n  subtasks: Subtask[],\n  map: Map<string, { depends_on: string[] }>\n): void {\n  for (const st of subtasks) {\n    map.set(st.id, st);\n    collectSubtaskItems(st.subtasks, map);\n  }\n}\n\n// ---------------------------------------------------------------------------\n// Command\n// ---------------------------------------------------------------------------\n\nexport async function cmdFeaturesGraph(opts: FeaturesGraphOptions): Promise<void> {\n  const { projectRoot, config } = opts;\n  const data = loadFeatures(projectRoot, config);\n  const fmt = opts.outputFmt ?? \"text\";\n\n  const { source, nodeCount, edgeCount, orphanCount } = buildMermaidSource(data, {\n    status: opts.status,\n    subtasks: opts.subtasks,\n  });\n\n  if (nodeCount === 0) {\n    output(fmt, { graph: null, nodes: 0, edges: 0, message: \"No features to graph\" }, () => {\n      console.log(\"No features to graph.\");\n    });\n    return;\n  }\n\n  // --mermaid: emit raw mermaid source\n  if (opts.mermaid) {\n    output(fmt, { mermaid: source, nodes: nodeCount, edges: edgeCount }, () => {\n      console.log(source);\n    });\n    return;\n  }\n\n  // --output json: emit structured data\n  if (fmt === \"json\") {\n    const rendered = renderMermaidToTui(source, { ascii: true }) as string;\n    console.log(\n      JSON.stringify({\n        mermaid: source,\n        rendered,\n        nodes: nodeCount,\n        edges: edgeCount,\n        orphans: orphanCount,\n      })\n    );\n    return;\n  }\n\n  // Default: render the graph in the terminal\n  const rendered = renderMermaidToTui(source, { ascii: !!opts.ascii }) as string;\n\n  console.log(`\\n${BOLD}Feature Dependency Graph${RESET}`);\n  console.log(`${DIM}${nodeCount} nodes, ${edgeCount} edges, ${orphanCount} orphans (no deps/dependents)${RESET}\\n`);\n  console.log(rendered);\n\n  // Print legend and diagnostics\n  printLegend(data.features);\n  printDiagnostics(data, !!opts.subtasks);\n  console.log(\"\");\n}\n","after":"/**\n * features/graph.ts — Visualize the feature dependency graph.\n *\n * Usage:\n *   wombo features graph                     # show full dependency graph\n *   wombo features graph --status backlog    # filter by status\n *   wombo features graph --ascii             # ASCII-only rendering\n *   wombo features graph --output json       # emit mermaid source as JSON\n *   wombo features graph --mermaid           # emit raw mermaid source text\n *   wombo features graph --subtasks          # include subtask-level nodes\n *\n * Builds a Mermaid flowchart from the features dependency graph and renders\n * it as a Unicode box diagram in the terminal using mermaidtui.\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  type Feature,\n  type Subtask,\n  type FeatureStatus,\n  type FeaturesFile,\n} from \"../../lib/features.js\";\nimport { output, type OutputFormat } from \"../../lib/output.js\";\nimport { toonGraphResult } from \"../../lib/toon.js\";\n\n// mermaidtui has no type declarations — import the JS module directly\n// @ts-ignore — no .d.ts published\nimport { renderMermaidToTui } from \"mermaidtui\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface FeaturesGraphOptions {\n  projectRoot: string;\n  config: WomboConfig;\n  status?: FeatureStatus;\n  ascii?: boolean;\n  mermaid?: boolean;\n  subtasks?: boolean;\n  outputFmt?: OutputFormat;\n}\n\n// ---------------------------------------------------------------------------\n// Status styling for Mermaid classDef\n// ---------------------------------------------------------------------------\n\n// Short status badge for node labels\nconst STATUS_BADGE: Record<FeatureStatus, string> = {\n  backlog: \"BL\",\n  planned: \"PL\",\n  in_progress: \"IP\",\n  blocked: \"BK\",\n  in_review: \"IR\",\n  done: \"DN\",\n  cancelled: \"XX\",\n};\n\n// ---------------------------------------------------------------------------\n// Mermaid generation\n// ---------------------------------------------------------------------------\n\n/**\n * Sanitize a string for use inside Mermaid labels.\n * Mermaid uses square brackets for labels — we need to escape them.\n */\nfunction sanitizeLabel(s: string): string {\n  return s\n    .replace(/\"/g, \"'\")\n    .replace(/\\[/g, \"(\")\n    .replace(/\\]/g, \")\")\n    .replace(/\\n/g, \" \")\n    .slice(0, 40); // keep labels short for terminal rendering\n}\n\n/**\n * Generate a safe Mermaid node ID from a feature/subtask ID.\n * Mermaid IDs can't start with numbers and some chars are reserved.\n */\nfunction nodeId(id: string): string {\n  return `n_${id.replace(/-/g, \"_\")}`;\n}\n\n/**\n * Collect all node IDs that exist in the graph (for filtering dangling deps).\n */\nfunction collectAllIds(\n  features: Feature[],\n  includeSubtasks: boolean\n): Set<string> {\n  const ids = new Set<string>();\n  for (const f of features) {\n    ids.add(f.id);\n    if (includeSubtasks) {\n      collectSubtaskIds(f.subtasks, ids);\n    }\n  }\n  return ids;\n}\n\nfunction collectSubtaskIds(subtasks: Subtask[], ids: Set<string>): void {\n  for (const st of subtasks) {\n    ids.add(st.id);\n    collectSubtaskIds(st.subtasks, ids);\n  }\n}\n\n/**\n * Build the Mermaid flowchart source from the features file.\n */\nfunction buildMermaidSource(\n  data: FeaturesFile,\n  opts: { status?: FeatureStatus; subtasks?: boolean }\n): { source: string; nodeCount: number; edgeCount: number; orphanCount: number } {\n  let features = [...data.features];\n\n  // Filter by status if requested\n  if (opts.status) {\n    features = features.filter((f) => f.status === opts.status);\n  }\n\n  if (features.length === 0) {\n    return { source: \"\", nodeCount: 0, edgeCount: 0, orphanCount: 0 };\n  }\n\n  const allIds = collectAllIds(features, !!opts.subtasks);\n  const lines: string[] = [\"flowchart LR\"];\n  let nodeCount = 0;\n  let edgeCount = 0;\n  let orphanCount = 0;\n\n  // Process each feature\n  for (const f of features) {\n    const nid = nodeId(f.id);\n    const badge = STATUS_BADGE[f.status];\n    const label = `${badge} ${sanitizeLabel(f.title)}`;\n    lines.push(`    ${nid}[${label}]`);\n    nodeCount++;\n\n    let hasDeps = false;\n\n    // Add dependency edges\n    for (const dep of f.depends_on) {\n      if (allIds.has(dep)) {\n        lines.push(`    ${nodeId(dep)} --> ${nid}`);\n        edgeCount++;\n        hasDeps = true;\n      }\n    }\n\n    // Process subtasks if requested\n    if (opts.subtasks && f.subtasks.length > 0) {\n      const result = processSubtasks(f.subtasks, nid, allIds, lines);\n      nodeCount += result.nodeCount;\n      edgeCount += result.edgeCount;\n      if (result.nodeCount > 0) hasDeps = true;\n    }\n\n    if (!hasDeps && f.depends_on.length === 0 && (!opts.subtasks || f.subtasks.length === 0)) {\n      orphanCount++;\n    }\n  }\n\n  return {\n    source: lines.join(\"\\n\"),\n    nodeCount,\n    edgeCount,\n    orphanCount,\n  };\n}\n\nfunction processSubtasks(\n  subtasks: Subtask[],\n  parentNodeId: string,\n  allIds: Set<string>,\n  lines: string[]\n): { nodeCount: number; edgeCount: number } {\n  let nodeCount = 0;\n  let edgeCount = 0;\n\n  for (const st of subtasks) {\n    const nid = nodeId(st.id);\n    const badge = STATUS_BADGE[st.status];\n    const label = `${badge} ${sanitizeLabel(st.title)}`;\n    lines.push(`    ${nid}[${label}]`);\n    nodeCount++;\n\n    // Link parent to subtask\n    lines.push(`    ${parentNodeId} --> ${nid}`);\n    edgeCount++;\n\n    // Subtask's own dependencies\n    for (const dep of st.depends_on) {\n      if (allIds.has(dep)) {\n        lines.push(`    ${nodeId(dep)} --> ${nid}`);\n        edgeCount++;\n      }\n    }\n\n    // Recurse into nested subtasks\n    if (st.subtasks.length > 0) {\n      const result = processSubtasks(st.subtasks, nid, allIds, lines);\n      nodeCount += result.nodeCount;\n      edgeCount += result.edgeCount;\n    }\n  }\n\n  return { nodeCount, edgeCount };\n}\n\n// ---------------------------------------------------------------------------\n// Text rendering helpers\n// ---------------------------------------------------------------------------\n\nconst RESET = \"\\x1b[0m\";\nconst BOLD = \"\\x1b[1m\";\nconst DIM = \"\\x1b[2m\";\nconst RED = \"\\x1b[31m\";\nconst YELLOW = \"\\x1b[33m\";\nconst GREEN = \"\\x1b[32m\";\nconst CYAN = \"\\x1b[36m\";\n\n/**\n * Print a legend explaining the status badges used in the graph.\n */\nfunction printLegend(features: Feature[]): void {\n  const statuses = new Set<FeatureStatus>();\n  for (const f of features) {\n    statuses.add(f.status);\n  }\n\n  console.log(`\\n${BOLD}Legend:${RESET}`);\n  const legendItems: string[] = [];\n  for (const [status, badge] of Object.entries(STATUS_BADGE)) {\n    if (statuses.has(status as FeatureStatus)) {\n      legendItems.push(`  ${badge} = ${status}`);\n    }\n  }\n  console.log(legendItems.join(\"  |\"));\n}\n\n/**\n * Detect potential issues in the dependency graph and print warnings.\n */\nfunction printDiagnostics(data: FeaturesFile, includeSubtasks: boolean): void {\n  const allIds = collectAllIds(data.features, includeSubtasks);\n  const issues: string[] = [];\n\n  // Check for dangling dependencies (pointing to non-existent IDs)\n  for (const f of data.features) {\n    for (const dep of f.depends_on) {\n      if (!allIds.has(dep)) {\n        issues.push(`${YELLOW}WARNING${RESET}: ${f.id} depends on \"${dep}\" which does not exist`);\n      }\n    }\n    if (includeSubtasks) {\n      checkSubtaskDeps(f.subtasks, allIds, issues);\n    }\n  }\n\n  // Check for circular dependencies (simple DFS)\n  const circularPaths = detectCycles(data.features, includeSubtasks);\n  for (const cycle of circularPaths) {\n    issues.push(`${RED}CYCLE${RESET}: ${cycle.join(\" -> \")}`);\n  }\n\n  // Check for blocked features whose blockers are done\n  for (const f of data.features) {\n    if (f.status === \"blocked\") {\n      const allDepsDone = f.depends_on.every((dep) => {\n        const depFeature = data.features.find((ff) => ff.id === dep);\n        return depFeature?.status === \"done\";\n      });\n      if (allDepsDone && f.depends_on.length > 0) {\n        issues.push(\n          `${CYAN}INFO${RESET}: ${f.id} is marked \"blocked\" but all its dependencies are done`\n        );\n      }\n    }\n  }\n\n  if (issues.length > 0) {\n    console.log(`\\n${BOLD}Diagnostics (${issues.length} issue${issues.length > 1 ? \"s\" : \"\"}):${RESET}`);\n    for (const issue of issues) {\n      console.log(`  ${issue}`);\n    }\n  }\n}\n\nfunction checkSubtaskDeps(\n  subtasks: Subtask[],\n  allIds: Set<string>,\n  issues: string[]\n): void {\n  for (const st of subtasks) {\n    for (const dep of st.depends_on) {\n      if (!allIds.has(dep)) {\n        issues.push(\n          `${YELLOW}WARNING${RESET}: subtask ${st.id} depends on \"${dep}\" which does not exist`\n        );\n      }\n    }\n    checkSubtaskDeps(st.subtasks, allIds, issues);\n  }\n}\n\n/**\n * Detect circular dependencies using DFS.\n * Returns arrays of ID paths that form cycles.\n */\nfunction detectCycles(\n  features: Feature[],\n  includeSubtasks: boolean\n): string[][] {\n  // Build adjacency list: dep -> [dependents]\n  const adj = new Map<string, string[]>();\n  const allItems = new Map<string, { depends_on: string[] }>();\n\n  for (const f of features) {\n    allItems.set(f.id, f);\n    if (includeSubtasks) {\n      collectSubtaskItems(f.subtasks, allItems);\n    }\n  }\n\n  for (const [id, item] of allItems) {\n    for (const dep of item.depends_on) {\n      if (!adj.has(id)) adj.set(id, []);\n      adj.get(id)!.push(dep);\n    }\n  }\n\n  const visited = new Set<string>();\n  const inStack = new Set<string>();\n  const cycles: string[][] = [];\n\n  function dfs(node: string, path: string[]): void {\n    if (inStack.has(node)) {\n      // Found a cycle — extract it\n      const cycleStart = path.indexOf(node);\n      cycles.push([...path.slice(cycleStart), node]);\n      return;\n    }\n    if (visited.has(node)) return;\n\n    visited.add(node);\n    inStack.add(node);\n    path.push(node);\n\n    for (const neighbor of adj.get(node) ?? []) {\n      dfs(neighbor, path);\n    }\n\n    path.pop();\n    inStack.delete(node);\n  }\n\n  for (const id of allItems.keys()) {\n    if (!visited.has(id)) {\n      dfs(id, []);\n    }\n  }\n\n  return cycles;\n}\n\nfunction collectSubtaskItems(\n  subtasks: Subtask[],\n  map: Map<string, { depends_on: string[] }>\n): void {\n  for (const st of subtasks) {\n    map.set(st.id, st);\n    collectSubtaskItems(st.subtasks, map);\n  }\n}\n\n// ---------------------------------------------------------------------------\n// Command\n// ---------------------------------------------------------------------------\n\nexport async function cmdFeaturesGraph(opts: FeaturesGraphOptions): Promise<void> {\n  const { projectRoot, config } = opts;\n  const data = loadFeatures(projectRoot, config);\n  const fmt = opts.outputFmt ?? \"text\";\n\n  const { source, nodeCount, edgeCount, orphanCount } = buildMermaidSource(data, {\n    status: opts.status,\n    subtasks: opts.subtasks,\n  });\n\n  if (nodeCount === 0) {\n    output(fmt, { graph: null, nodes: 0, edges: 0, message: \"No features to graph\" }, () => {\n      console.log(\"No features to graph.\");\n    });\n    return;\n  }\n\n  // --mermaid: emit raw mermaid source\n  if (opts.mermaid) {\n    output(fmt, { mermaid: source, nodes: nodeCount, edges: edgeCount }, () => {\n      console.log(source);\n    });\n    return;\n  }\n\n  // --output json: emit structured data\n  if (fmt === \"json\") {\n    const rendered = renderMermaidToTui(source, { ascii: true }) as string;\n    console.log(\n      JSON.stringify({\n        mermaid: source,\n        rendered,\n        nodes: nodeCount,\n        edges: edgeCount,\n        orphans: orphanCount,\n      })\n    );\n    return;\n  }\n\n  // Default: render the graph in the terminal\n  const rendered = renderMermaidToTui(source, { ascii: !!opts.ascii }) as string;\n\n  console.log(`\\n${BOLD}Feature Dependency Graph${RESET}`);\n  console.log(`${DIM}${nodeCount} nodes, ${edgeCount} edges, ${orphanCount} orphans (no deps/dependents)${RESET}\\n`);\n  console.log(rendered);\n\n  // Print legend and diagnostics\n  printLegend(data.features);\n  printDiagnostics(data, !!opts.subtasks);\n  console.log(\"\");\n}\n","additions":1,"deletions":0},"truncated":false},"time":{"start":1773351924267,"end":1773351924804}}}}
