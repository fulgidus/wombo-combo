{"type":"tool_use","timestamp":1773351645797,"sessionID":"ses_31c0172a9ffeekk99N9QZhhvnC","part":{"id":"prt_ce3feb0f2001tkE1NHSiLq5uyx","sessionID":"ses_31c0172a9ffeekk99N9QZhhvnC","messageID":"msg_ce3fea085001bCCJXIfOhY5MdD","type":"tool","callID":"toolu_vrtx_01X27MSddxkNRaTVEq64DXaE","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-toon-output/src/lib/schema.ts"},"output":"<path>/home/fulgidus/Documents/wombo-toon-output/src/lib/schema.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * schema.ts — Declarative command/flag registry for schema introspection.\n3:  *\n4:  * Every command and flag is described in a single registry. This registry is\n5:  * the source of truth for:\n6:  *   1. `wombo describe <command>` — emits a JSON schema of accepted args\n7:  *   2. Future help text generation\n8:  *\n9:  * The registry is NOT used for actual arg parsing (that's still the hand-rolled\n10:  * switch in index.ts), but the two must stay in sync. If they drift, `wombo\n11:  * features check` should eventually catch it.\n12:  */\n13: \n14: // ---------------------------------------------------------------------------\n15: // Types\n16: // ---------------------------------------------------------------------------\n17: \n18: export interface FlagDef {\n19:   /** Primary flag name, e.g. \"--dry-run\" */\n20:   name: string;\n21:   /** Short alias, e.g. \"-o\" */\n22:   alias?: string;\n23:   /** Description shown in help / schema */\n24:   description: string;\n25:   /** Type of the value: \"boolean\" flags take no value, others consume next arg */\n26:   type: \"string\" | \"number\" | \"boolean\" | \"string[]\";\n27:   /** Default value (undefined = required or absent) */\n28:   default?: unknown;\n29:   /** For enum-like flags, the set of allowed values */\n30:   enum?: readonly string[];\n31:   /** If true, this flag is required */\n32:   required?: boolean;\n33: }\n34: \n35: export interface PositionalDef {\n36:   /** Name used in usage strings, e.g. \"feature-id\" */\n37:   name: string;\n38:   description: string;\n39:   required?: boolean;\n40: }\n41: \n42: export interface CommandDef {\n43:   /** Command name as typed by the user, e.g. \"launch\" or \"features list\" */\n44:   name: string;\n45:   /** One-line summary */\n46:   summary: string;\n47:   /** Longer description */\n48:   description?: string;\n49:   /** Positional arguments */\n50:   positionals: PositionalDef[];\n51:   /** Named flags */\n52:   flags: FlagDef[];\n53:   /** Whether this command mutates state (used for dry-run indication) */\n54:   mutating: boolean;\n55:   /** Whether this command supports --dry-run */\n56:   supportsDryRun: boolean;\n57:   /** Subcommands (for \"features\" parent) */\n58:   subcommands?: CommandDef[];\n59: }\n60: \n61: // ---------------------------------------------------------------------------\n62: // Global flags (available on every command)\n63: // ---------------------------------------------------------------------------\n64: \n65: const GLOBAL_FLAGS: FlagDef[] = [\n66:   {\n67:     name: \"--output\",\n68:     alias: \"-o\",\n69:     description: \"Output format: text (default) or json\",\n70:     type: \"string\",\n71:     default: \"text\",\n72:     enum: [\"text\", \"json\"],\n73:   },\n74:   {\n75:     name: \"--force\",\n76:     description: \"Force overwrite / skip safety prompts\",\n77:     type: \"boolean\",\n78:     default: false,\n79:   },\n80: ];\n81: \n82: // ---------------------------------------------------------------------------\n83: // Command Registry\n84: // ---------------------------------------------------------------------------\n85: \n86: export const COMMAND_REGISTRY: CommandDef[] = [\n87:   // --- init ---------------------------------------------------------------\n88:   {\n89:     name: \"init\",\n90:     summary: \"Generate wombo.json config in the current project\",\n91:     description:\n92:       \"Interactive guided setup that walks through every config section. \" +\n93:       \"Creates wombo.json and .features.yml from template.\",\n94:     positionals: [],\n95:     flags: [\n96:       {\n97:         name: \"--force\",\n98:         description: \"Overwrite existing config files\",\n99:         type: \"boolean\",\n100:         default: false,\n101:       },\n102:       {\n103:         name: \"--dry-run\",\n104:         description: \"Show what would be created without writing files\",\n105:         type: \"boolean\",\n106:         default: false,\n107:       },\n108:     ],\n109:     mutating: true,\n110:     supportsDryRun: true,\n111:   },\n112: \n113:   // --- launch -------------------------------------------------------------\n114:   {\n115:     name: \"launch\",\n116:     summary: \"Launch a wave of agents to implement features\",\n117:     description:\n118:       \"Select features from .features.yml, create worktrees, and spawn agents. \" +\n119:       \"Supports multiple selection strategies.\",\n120:     positionals: [],\n121:     flags: [\n122:       { name: \"--top-priority\", description: \"Select top N features by priority\", type: \"number\" },\n123:       { name: \"--quickest-wins\", description: \"Select N features with lowest effort\", type: \"number\" },\n124:       { name: \"--priority\", description: \"Filter by priority level\", type: \"string\", enum: [\"critical\", \"high\", \"medium\", \"low\", \"wishlist\"] },\n125:       { name: \"--difficulty\", description: \"Filter by difficulty level\", type: \"string\", enum: [\"trivial\", \"easy\", \"medium\", \"hard\", \"very_hard\"] },\n126:       { name: \"--features\", description: \"Select specific features by comma-separated IDs\", type: \"string\" },\n127:       { name: \"--all-ready\", description: \"Select all features whose dependencies are met\", type: \"boolean\", default: false },\n128:       { name: \"--max-concurrent\", description: \"Max agents running in parallel\", type: \"number\" },\n129:       { name: \"--model\", alias: \"-m\", description: \"Model to use (e.g., anthropic/claude-sonnet-4-20250514)\", type: \"string\" },\n130:       { name: \"--interactive\", description: \"Use tmux TUI mode instead of headless\", type: \"boolean\", default: false },\n131:       { name: \"--no-tui\", description: \"Headless mode without neo-blessed TUI\", type: \"boolean\", default: false },\n132:       { name: \"--auto-push\", description: \"Push base branch to remote after all merges\", type: \"boolean\", default: false },\n133:       { name: \"--dry-run\", description: \"Show what would be launched without launching\", type: \"boolean\", default: false },\n134:       { name: \"--base-branch\", description: \"Base branch (default: from config)\", type: \"string\" },\n135:       { name: \"--max-retries\", description: \"Max retries per agent\", type: \"number\" },\n136:     ],\n137:     mutating: true,\n138:     supportsDryRun: true,\n139:   },\n140: \n141:   // --- resume -------------------------------------------------------------\n142:   {\n143:     name: \"resume\",\n144:     summary: \"Resume a previously stopped wave\",\n145:     positionals: [],\n146:     flags: [\n147:       { name: \"--max-concurrent\", description: \"Max agents running in parallel\", type: \"number\" },\n148:       { name: \"--model\", alias: \"-m\", description: \"Model to use\", type: \"string\" },\n149:       { name: \"--interactive\", description: \"Use tmux TUI mode\", type: \"boolean\", default: false },\n150:       { name: \"--no-tui\", description: \"Headless mode without neo-blessed TUI\", type: \"boolean\", default: false },\n151:       { name: \"--auto-push\", description: \"Push base branch to remote after merges\", type: \"boolean\", default: false },\n152:       { name: \"--base-branch\", description: \"Base branch override\", type: \"string\" },\n153:       { name: \"--max-retries\", description: \"Max retries per agent\", type: \"number\" },\n154:     ],\n155:     mutating: true,\n156:     supportsDryRun: false,\n157:   },\n158: \n159:   // --- status -------------------------------------------------------------\n160:   {\n161:     name: \"status\",\n162:     summary: \"Show the status of the current wave\",\n163:     positionals: [],\n164:     flags: [],\n165:     mutating: false,\n166:     supportsDryRun: false,\n167:   },\n168: \n169:   // --- verify -------------------------------------------------------------\n170:   {\n171:     name: \"verify\",\n172:     summary: \"Run build verification on completed agents\",\n173:     positionals: [\n174:       { name: \"feature-id\", description: \"Specific feature to verify (optional)\", required: false },\n175:     ],\n176:     flags: [\n177:       { name: \"--model\", alias: \"-m\", description: \"Model to use for verification\", type: \"string\" },\n178:       { name: \"--max-retries\", description: \"Max retries\", type: \"number\" },\n179:     ],\n180:     mutating: true,\n181:     supportsDryRun: false,\n182:   },\n183: \n184:   // --- merge --------------------------------------------------------------\n185:   {\n186:     name: \"merge\",\n187:     summary: \"Merge verified branches into the base branch\",\n188:     positionals: [\n189:       { name: \"feature-id\", description: \"Specific feature to merge (optional)\", required: false },\n190:     ],\n191:     flags: [\n192:       { name: \"--auto-push\", description: \"Push base branch to remote after merge\", type: \"boolean\", default: false },\n193:       { name: \"--dry-run\", description: \"Show what would be merged without merging\", type: \"boolean\", default: false },\n194:     ],\n195:     mutating: true,\n196:     supportsDryRun: true,\n197:   },\n198: \n199:   // --- retry --------------------------------------------------------------\n200:   {\n201:     name: \"retry\",\n202:     summary: \"Retry a failed agent\",\n203:     positionals: [\n204:       { name: \"feature-id\", description: \"Feature ID of the failed agent\", required: true },\n205:     ],\n206:     flags: [\n207:       { name: \"--model\", alias: \"-m\", description: \"Model to use\", type: \"string\" },\n208:       { name: \"--interactive\", description: \"Use tmux TUI mode\", type: \"boolean\", default: false },\n209:       { name: \"--dry-run\", description: \"Show what would be retried without retrying\", type: \"boolean\", default: false },\n210:     ],\n211:     mutating: true,\n212:     supportsDryRun: true,\n213:   },\n214: \n215:   // --- cleanup ------------------------------------------------------------\n216:   {\n217:     name: \"cleanup\",\n218:     summary: \"Remove all wave worktrees and tmux sessions\",\n219:     description: \"Kills tmux sessions, removes worktrees, removes state and log files.\",\n220:     positionals: [],\n221:     flags: [\n222:       { name: \"--dry-run\", description: \"Show what would be cleaned up without removing\", type: \"boolean\", default: false },\n223:     ],\n224:     mutating: true,\n225:     supportsDryRun: true,\n226:   },\n227: \n228:   // --- upgrade ------------------------------------------------------------\n229:   {\n230:     name: \"upgrade\",\n231:     summary: \"Check for updates and upgrade wombo\",\n232:     positionals: [],\n233:     flags: [\n234:       { name: \"--check\", description: \"Only check for updates, don't install\", type: \"boolean\", default: false },\n235:       { name: \"--version\", description: \"Install a specific version (e.g., v0.1.0)\", type: \"string\" },\n236:       { name: \"--force\", description: \"Force reinstall even if up to date\", type: \"boolean\", default: false },\n237:     ],\n238:     mutating: true,\n239:     supportsDryRun: false,\n240:   },\n241: \n242:   // --- features (parent with subcommands) ---------------------------------\n243:   {\n244:     name: \"features\",\n245:     summary: \"Manage .features.yml\",\n246:     positionals: [],\n247:     flags: [],\n248:     mutating: false,\n249:     supportsDryRun: false,\n250:     subcommands: [\n251:       {\n252:         name: \"features list\",\n253:         summary: \"List features with optional filtering\",\n254:         positionals: [],\n255:         flags: [\n256:           { name: \"--status\", description: \"Filter by status\", type: \"string\", enum: [\"backlog\", \"planned\", \"in_progress\", \"blocked\", \"in_review\", \"done\", \"cancelled\"] },\n257:           { name: \"--priority\", description: \"Filter by priority\", type: \"string\", enum: [\"critical\", \"high\", \"medium\", \"low\", \"wishlist\"] },\n258:           { name: \"--difficulty\", description: \"Filter by difficulty\", type: \"string\", enum: [\"trivial\", \"easy\", \"medium\", \"hard\", \"very_hard\"] },\n259:           { name: \"--ready\", description: \"Show only ready features (backlog + deps met)\", type: \"boolean\", default: false },\n260:           { name: \"--include-archive\", description: \"Include archived features\", type: \"boolean\", default: false },\n261:           { name: \"--fields\", description: \"Comma-separated list of fields to include in output\", type: \"string\" },\n262:         ],\n263:         mutating: false,\n264:         supportsDryRun: false,\n265:       },\n266:       {\n267:         name: \"features add\",\n268:         summary: \"Add a new feature\",\n269:         positionals: [\n270:           { name: \"id\", description: \"Feature ID (kebab-case)\", required: true },\n271:           { name: \"title\", description: \"Feature title\", required: true },\n272:         ],\n273:         flags: [\n274:           { name: \"--description\", alias: \"--desc\", description: \"Feature description\", type: \"string\" },\n275:           { name: \"--priority\", description: \"Priority level\", type: \"string\", default: \"medium\", enum: [\"critical\", \"high\", \"medium\", \"low\", \"wishlist\"] },\n276:           { name: \"--difficulty\", description: \"Difficulty level\", type: \"string\", default: \"medium\", enum: [\"trivial\", \"easy\", \"medium\", \"hard\", \"very_hard\"] },\n277:           { name: \"--effort\", description: \"Effort estimate (ISO 8601 duration, e.g. PT2H)\", type: \"string\", default: \"PT1H\" },\n278:           { name: \"--depends-on\", description: \"Comma-separated dependency IDs\", type: \"string\" },\n279:           { name: \"--dry-run\", description: \"Show what would be added without writing\", type: \"boolean\", default: false },\n280:         ],\n281:         mutating: true,\n282:         supportsDryRun: true,\n283:       },\n284:       {\n285:         name: \"features set-status\",\n286:         summary: \"Change a feature's status\",\n287:         positionals: [\n288:           { name: \"feature-id\", description: \"Feature ID to update\", required: true },\n289:           { name: \"status\", description: \"New status value\", required: true },\n290:         ],\n291:         flags: [\n292:           { name: \"--dry-run\", description: \"Show what would change without writing\", type: \"boolean\", default: false },\n293:         ],\n294:         mutating: true,\n295:         supportsDryRun: true,\n296:       },\n297:       {\n298:         name: \"features check\",\n299:         summary: \"Validate .features.yml (schema, deps, duplicates, cycles)\",\n300:         positionals: [],\n301:         flags: [],\n302:         mutating: false,\n303:         supportsDryRun: false,\n304:       },\n305:       {\n306:         name: \"features archive\",\n307:         summary: \"Move done/cancelled features to archive section\",\n308:         positionals: [\n309:           { name: \"feature-id\", description: \"Specific feature to archive (optional)\", required: false },\n310:         ],\n311:         flags: [\n312:           { name: \"--dry-run\", description: \"Show what would be archived without moving\", type: \"boolean\", default: false },\n313:         ],\n314:         mutating: true,\n315:         supportsDryRun: true,\n316:       },\n317:       {\n318:         name: \"features show\",\n319:         summary: \"Show detailed information about a specific feature\",\n320:         positionals: [\n321:           { name: \"feature-id\", description: \"Feature ID to display\", required: true },\n322:         ],\n323:         flags: [\n324:           { name: \"--fields\", description: \"Comma-separated list of fields to include in output\", type: \"string\" },\n325:         ],\n326:         mutating: false,\n327:         supportsDryRun: false,\n328:       },\n329:       {\n330:         name: \"features graph\",\n331:         summary: \"Visualize the feature dependency graph as a terminal diagram\",\n332:         description:\n333:           \"Builds a Mermaid flowchart from the features dependency graph and renders \" +\n334:           \"it as a Unicode box diagram. Shows dependency edges, status badges, orphan \" +\n335:           \"detection, dangling dependency warnings, and cycle detection.\",\n336:         positionals: [],\n337:         flags: [\n338:           { name: \"--status\", description: \"Filter graph to features with this status\", type: \"string\", enum: [\"backlog\", \"planned\", \"in_progress\", \"blocked\", \"in_review\", \"done\", \"cancelled\"] },\n339:           { name: \"--ascii\", description: \"Use ASCII-only rendering (no Unicode box chars)\", type: \"boolean\", default: false },\n340:           { name: \"--mermaid\", description: \"Emit raw Mermaid source instead of rendered graph\", type: \"boolean\", default: false },\n341:           { name: \"--subtasks\", description: \"Include subtask-level nodes in the graph\", type: \"boolean\", default: false },\n342:         ],\n343:         mutating: false,\n344:         supportsDryRun: false,\n345:       },\n346:     ],\n347:   },\n348: \n349:   // --- help ---------------------------------------------------------------\n350:   {\n351:     name: \"help\",\n352:     summary: \"Show help text\",\n353:     positionals: [],\n354:     flags: [],\n355:     mutating: false,\n356:     supportsDryRun: false,\n357:   },\n358: \n359:   // --- describe -----------------------------------------------------------\n360:   {\n361:     name: \"describe\",\n362:     summary: \"Emit JSON schema of a command's arguments and flags\",\n363:     description:\n364:       \"Machine-readable introspection for AI agents. Outputs the accepted \" +\n365:       \"positionals, flags, types, defaults, and constraints for a command.\",\n366:     positionals: [\n367:       { name: \"command\", description: \"Command to describe (e.g. 'launch', 'features add')\", required: false },\n368:     ],\n369:     flags: [],\n370:     mutating: false,\n371:     supportsDryRun: false,\n372:   },\n373: ];\n374: \n375: // ---------------------------------------------------------------------------\n376: // Lookup helpers\n377: // ---------------------------------------------------------------------------\n378: \n379: /**\n380:  * Find a command definition by name. Supports compound names like \"features list\".\n381:  */\n382: export function findCommandDef(name: string): CommandDef | undefined {\n383:   // Try direct match first\n384:   const direct = COMMAND_REGISTRY.find((c) => c.name === name);\n385:   if (direct) return direct;\n386: \n387:   // Try compound: \"features list\" -> look in features subcommands\n388:   const parts = name.split(/\\s+/);\n389:   if (parts.length === 2) {\n390:     const parent = COMMAND_REGISTRY.find((c) => c.name === parts[0]);\n391:     if (parent?.subcommands) {\n392:       return parent.subcommands.find((sc) => sc.name === name || sc.name === parts[1]);\n393:     }\n394:   }\n395: \n396:   return undefined;\n397: }\n398: \n399: /**\n400:  * Produce the JSON schema object for a command, suitable for agent consumption.\n401:  */\n402: export function commandToSchema(cmd: CommandDef): Record<string, unknown> {\n403:   const schema: Record<string, unknown> = {\n404:     command: cmd.name,\n405:     summary: cmd.summary,\n406:     mutating: cmd.mutating,\n407:     supports_dry_run: cmd.supportsDryRun,\n408:   };\n409: \n410:   if (cmd.description) {\n411:     schema.description = cmd.description;\n412:   }\n413: \n414:   if (cmd.positionals.length > 0) {\n415:     schema.positionals = cmd.positionals.map((p) => ({\n416:       name: p.name,\n417:       description: p.description,\n418:       required: p.required ?? false,\n419:     }));\n420:   }\n421: \n422:   const allFlags = [...cmd.flags, ...GLOBAL_FLAGS];\n423:   schema.flags = allFlags.map((f) => {\n424:     const entry: Record<string, unknown> = {\n425:       name: f.name,\n426:       type: f.type,\n427:       description: f.description,\n428:     };\n429:     if (f.alias) entry.alias = f.alias;\n430:     if (f.default !== undefined) entry.default = f.default;\n431:     if (f.enum) entry.enum = f.enum;\n432:     if (f.required) entry.required = true;\n433:     return entry;\n434:   });\n435: \n436:   if (cmd.subcommands?.length) {\n437:     schema.subcommands = cmd.subcommands.map((sc) => sc.name);\n438:   }\n439: \n440:   return schema;\n441: }\n442: \n443: /**\n444:  * Produce a listing of all commands (for `wombo describe` with no args).\n445:  */\n446: export function allCommandSchemas(): Record<string, unknown> {\n447:   const commands: Record<string, unknown>[] = [];\n448: \n449:   for (const cmd of COMMAND_REGISTRY) {\n450:     const entry: Record<string, unknown> = {\n451:       name: cmd.name,\n452:       summary: cmd.summary,\n453:       mutating: cmd.mutating,\n454:       supports_dry_run: cmd.supportsDryRun,\n455:     };\n456:     if (cmd.subcommands) {\n457:       entry.subcommands = cmd.subcommands.map((sc) => ({\n458:         name: sc.name,\n459:         summary: sc.summary,\n460:         mutating: sc.mutating,\n461:         supports_dry_run: sc.supportsDryRun,\n462:       }));\n463:     }\n464:     commands.push(entry);\n465:   }\n466: \n467:   return {\n468:     tool: \"wombo\",\n469:     version: \"0.0.2\",\n470:     global_flags: GLOBAL_FLAGS.map((f) => ({\n471:       name: f.name,\n472:       alias: f.alias,\n473:       type: f.type,\n474:       description: f.description,\n475:       default: f.default,\n476:     })),\n477:     commands,\n478:   };\n479: }\n\n(End of file - total 479 lines)\n</content>","title":"src/lib/schema.ts","metadata":{"preview":"/**\n * schema.ts — Declarative command/flag registry for schema introspection.\n *\n * Every command and flag is described in a single registry. This registry is\n * the source of truth for:\n *   1. `wombo describe <command>` — emits a JSON schema of accepted args\n *   2. Future help text generation\n *\n * The registry is NOT used for actual arg parsing (that's still the hand-rolled\n * switch in index.ts), but the two must stay in sync. If they drift, `wombo\n * features check` should eventually catch it.\n */\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface FlagDef {\n  /** Primary flag name, e.g. \"--dry-run\" */\n  name: string;","truncated":false,"loaded":[]},"time":{"start":1773351645793,"end":1773351645796}}}}
