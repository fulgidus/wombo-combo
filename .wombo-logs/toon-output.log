{"type":"tool_use","timestamp":1773351655804,"sessionID":"ses_31c0172a9ffeekk99N9QZhhvnC","part":{"id":"prt_ce3fed6a0001XrEmxeXpGmfF7c","sessionID":"ses_31c0172a9ffeekk99N9QZhhvnC","messageID":"msg_ce3fecc25001TQ58Z9hSHfdkwT","type":"tool","callID":"toolu_vrtx_01KuTzMEHX9EtSN9QBJ6FvGs","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-toon-output/src/commands/status.ts"},"output":"<path>/home/fulgidus/Documents/wombo-toon-output/src/commands/status.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * status.ts — Show the status of the current wave.\n3:  *\n4:  * Usage: wombo status\n5:  *\n6:  * Loads the wave state, checks for dead processes, and prints a dashboard.\n7:  */\n8: \n9: import type { WomboConfig } from \"../config.js\";\n10: import { loadState, saveState, updateAgent } from \"../lib/state.js\";\n11: import { isProcessRunning } from \"../lib/launcher.js\";\n12: import { printDashboard } from \"../lib/ui.js\";\n13: \n14: export interface StatusOptions {\n15:   projectRoot: string;\n16:   config: WomboConfig;\n17: }\n18: \n19: export async function cmdStatus(opts: StatusOptions): Promise<void> {\n20:   const state = loadState(opts.projectRoot);\n21:   if (!state) {\n22:     console.log(\"No active wave. Use 'wombo launch' to start one.\");\n23:     return;\n24:   }\n25: \n26:   // Update running agent status from process state\n27:   for (const agent of state.agents) {\n28:     if (agent.status === \"running\" && agent.pid) {\n29:       if (!isProcessRunning(agent.pid)) {\n30:         updateAgent(state, agent.feature_id, {\n31:           status: \"completed\",\n32:           completed_at: new Date().toISOString(),\n33:         });\n34:       }\n35:     }\n36:   }\n37:   saveState(opts.projectRoot, state);\n38: \n39:   printDashboard(state);\n40: }\n\n(End of file - total 40 lines)\n</content>","title":"src/commands/status.ts","metadata":{"preview":"/**\n * status.ts — Show the status of the current wave.\n *\n * Usage: wombo status\n *\n * Loads the wave state, checks for dead processes, and prints a dashboard.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport { loadState, saveState, updateAgent } from \"../lib/state.js\";\nimport { isProcessRunning } from \"../lib/launcher.js\";\nimport { printDashboard } from \"../lib/ui.js\";\n\nexport interface StatusOptions {\n  projectRoot: string;\n  config: WomboConfig;\n}\n\nexport async function cmdStatus(opts: StatusOptions): Promise<void> {\n  const state = loadState(opts.projectRoot);","truncated":false,"loaded":[]},"time":{"start":1773351655802,"end":1773351655804}}}}
{"type":"tool_use","timestamp":1773351656335,"sessionID":"ses_31c0172a9ffeekk99N9QZhhvnC","part":{"id":"prt_ce3fed9e8001WmMXDkr3bAgJc1","sessionID":"ses_31c0172a9ffeekk99N9QZhhvnC","messageID":"msg_ce3fecc25001TQ58Z9hSHfdkwT","type":"tool","callID":"toolu_vrtx_0157XnGKEg1PZQeqEGmw7CKu","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-toon-output/src/lib/state.ts"},"output":"<path>/home/fulgidus/Documents/wombo-toon-output/src/lib/state.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * state.ts — Persistent wave state management.\n3:  *\n4:  * Responsibilities:\n5:  *   - Define the shape of .wombo-state.json\n6:  *   - Read/write state atomically\n7:  *   - Generate wave IDs\n8:  *   - Update individual agent state within a wave\n9:  */\n10: \n11: import { readFileSync, writeFileSync, existsSync, renameSync } from \"node:fs\";\n12: import { resolve } from \"node:path\";\n13: \n14: // ---------------------------------------------------------------------------\n15: // Types\n16: // ---------------------------------------------------------------------------\n17: \n18: export type AgentStatus =\n19:   | \"queued\"\n20:   | \"installing\"\n21:   | \"running\"\n22:   | \"completed\"\n23:   | \"verified\"\n24:   | \"failed\"\n25:   | \"merged\"\n26:   | \"retry\"\n27:   | \"resolving_conflict\";\n28: \n29: export interface AgentState {\n30:   feature_id: string;\n31:   branch: string;\n32:   worktree: string;\n33:   session_id: string | null;\n34:   pid: number | null;\n35:   status: AgentStatus;\n36:   activity: string | null;\n37:   activity_updated_at: string | null;\n38:   retries: number;\n39:   max_retries: number;\n40:   started_at: string | null;\n41:   completed_at: string | null;\n42:   build_passed: boolean | null;\n43:   build_output: string | null;\n44:   error: string | null;\n45:   /** Estimated effort in milliseconds (from feature's ISO 8601 duration) */\n46:   effort_estimate_ms: number | null;\n47: }\n48: \n49: export interface WaveState {\n50:   wave_id: string;\n51:   base_branch: string;\n52:   started_at: string;\n53:   updated_at: string;\n54:   max_concurrent: number;\n55:   model: string | null;\n56:   interactive: boolean;\n57:   agents: AgentState[];\n58: }\n59: \n60: // ---------------------------------------------------------------------------\n61: // Constants\n62: // ---------------------------------------------------------------------------\n63: \n64: const STATE_FILE = \".wombo-state.json\";\n65: \n66: // ---------------------------------------------------------------------------\n67: // Wave ID Generation\n68: // ---------------------------------------------------------------------------\n69: \n70: /**\n71:  * Generate a unique wave ID based on current timestamp.\n72:  * Format: wave-YYYY-MM-DD-NNN\n73:  */\n74: export function generateWaveId(): string {\n75:   const now = new Date();\n76:   const date = now.toISOString().slice(0, 10);\n77:   const seq = String(now.getHours() * 60 + now.getMinutes()).padStart(3, \"0\");\n78:   return `wave-${date}-${seq}`;\n79: }\n80: \n81: // ---------------------------------------------------------------------------\n82: // State Path\n83: // ---------------------------------------------------------------------------\n84: \n85: function statePath(projectRoot: string): string {\n86:   return resolve(projectRoot, STATE_FILE);\n87: }\n88: \n89: // ---------------------------------------------------------------------------\n90: // Read State\n91: // ---------------------------------------------------------------------------\n92: \n93: /**\n94:  * Load the current wave state from disk. Returns null if no state file exists.\n95:  */\n96: export function loadState(projectRoot: string): WaveState | null {\n97:   const p = statePath(projectRoot);\n98:   if (!existsSync(p)) return null;\n99:   try {\n100:     const raw = readFileSync(p, \"utf-8\");\n101:     return JSON.parse(raw) as WaveState;\n102:   } catch {\n103:     return null;\n104:   }\n105: }\n106: \n107: // ---------------------------------------------------------------------------\n108: // Write State\n109: // ---------------------------------------------------------------------------\n110: \n111: /**\n112:  * Save wave state to disk atomically (write to tmp then rename).\n113:  */\n114: export function saveState(projectRoot: string, state: WaveState): void {\n115:   state.updated_at = new Date().toISOString();\n116:   const p = statePath(projectRoot);\n117:   const tmp = p + \".tmp\";\n118:   writeFileSync(tmp, JSON.stringify(state, null, 2) + \"\\n\", \"utf-8\");\n119:   renameSync(tmp, p);\n120: }\n121: \n122: // ---------------------------------------------------------------------------\n123: // State Mutations\n124: // ---------------------------------------------------------------------------\n125: \n126: /**\n127:  * Create a fresh wave state.\n128:  */\n129: export function createWaveState(opts: {\n130:   baseBranch: string;\n131:   maxConcurrent: number;\n132:   model: string | null;\n133:   interactive: boolean;\n134: }): WaveState {\n135:   return {\n136:     wave_id: generateWaveId(),\n137:     base_branch: opts.baseBranch,\n138:     started_at: new Date().toISOString(),\n139:     updated_at: new Date().toISOString(),\n140:     max_concurrent: opts.maxConcurrent,\n141:     model: opts.model,\n142:     interactive: opts.interactive,\n143:     agents: [],\n144:   };\n145: }\n146: \n147: /**\n148:  * Create an initial agent state for a feature.\n149:  */\n150: export function createAgentState(\n151:   featureId: string,\n152:   branch: string,\n153:   worktreePath: string,\n154:   maxRetries: number = 2\n155: ): AgentState {\n156:   return {\n157:     feature_id: featureId,\n158:     branch,\n159:     worktree: worktreePath,\n160:     session_id: null,\n161:     pid: null,\n162:     status: \"queued\",\n163:     activity: null,\n164:     activity_updated_at: null,\n165:     retries: 0,\n166:     max_retries: maxRetries,\n167:     started_at: null,\n168:     completed_at: null,\n169:     build_passed: null,\n170:     build_output: null,\n171:     error: null,\n172:     effort_estimate_ms: null,\n173:   };\n174: }\n175: \n176: /**\n177:  * Find an agent state by feature ID.\n178:  */\n179: export function getAgent(\n180:   state: WaveState,\n181:   featureId: string\n182: ): AgentState | undefined {\n183:   return state.agents.find((a) => a.feature_id === featureId);\n184: }\n185: \n186: /**\n187:  * Update an agent's state fields.\n188:  */\n189: export function updateAgent(\n190:   state: WaveState,\n191:   featureId: string,\n192:   updates: Partial<AgentState>\n193: ): void {\n194:   const agent = state.agents.find((a) => a.feature_id === featureId);\n195:   if (!agent) throw new Error(`Agent not found for feature: ${featureId}`);\n196:   Object.assign(agent, updates);\n197: }\n198: \n199: /**\n200:  * Get counts of agents by status.\n201:  */\n202: export function agentCounts(state: WaveState): Record<AgentStatus, number> {\n203:   const counts: Record<AgentStatus, number> = {\n204:     queued: 0,\n205:     installing: 0,\n206:     running: 0,\n207:     completed: 0,\n208:     verified: 0,\n209:     failed: 0,\n210:     merged: 0,\n211:     retry: 0,\n212:     resolving_conflict: 0,\n213:   };\n214:   for (const a of state.agents) {\n215:     counts[a.status]++;\n216:   }\n217:   return counts;\n218: }\n219: \n220: /**\n221:  * Get agents that are currently running or installing.\n222:  */\n223: export function activeAgents(state: WaveState): AgentState[] {\n224:   return state.agents.filter(\n225:     (a) => a.status === \"running\" || a.status === \"installing\" || a.status === \"resolving_conflict\"\n226:   );\n227: }\n228: \n229: /**\n230:  * Get agents that are queued and ready to be launched.\n231:  */\n232: export function queuedAgents(state: WaveState): AgentState[] {\n233:   return state.agents.filter((a) => a.status === \"queued\");\n234: }\n235: \n236: /**\n237:  * Check if the wave is fully complete (no queued, installing, running, or retry agents).\n238:  */\n239: export function isWaveComplete(state: WaveState): boolean {\n240:   return state.agents.every(\n241:     (a) =>\n242:       a.status === \"completed\" ||\n243:       a.status === \"verified\" ||\n244:       a.status === \"failed\" ||\n245:       a.status === \"merged\"\n246:   );\n247: }\n\n(End of file - total 247 lines)\n</content>","title":"src/lib/state.ts","metadata":{"preview":"/**\n * state.ts — Persistent wave state management.\n *\n * Responsibilities:\n *   - Define the shape of .wombo-state.json\n *   - Read/write state atomically\n *   - Generate wave IDs\n *   - Update individual agent state within a wave\n */\n\nimport { readFileSync, writeFileSync, existsSync, renameSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type AgentStatus =\n  | \"queued\"\n  | \"installing\"","truncated":false,"loaded":[]},"time":{"start":1773351656333,"end":1773351656335}}}}
{"type":"tool_use","timestamp":1773351656931,"sessionID":"ses_31c0172a9ffeekk99N9QZhhvnC","part":{"id":"prt_ce3fedbde001EalnhIyXD57jy4","sessionID":"ses_31c0172a9ffeekk99N9QZhhvnC","messageID":"msg_ce3fecc25001TQ58Z9hSHfdkwT","type":"tool","callID":"toolu_vrtx_01RiPX6sCo8i6oNbELYbvYrg","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-toon-output/src/commands/features/check.ts"},"output":"<path>/home/fulgidus/Documents/wombo-toon-output/src/commands/features/check.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * features/check.ts — Validate the features file for schema issues, broken deps, and orphans.\n3:  *\n4:  * Usage:\n5:  *   wombo features check\n6:  *\n7:  * Checks:\n8:  *   - Required fields present on every feature\n9:  *   - No duplicate IDs\n10:  *   - All depends_on references point to existing features\n11:  *   - No circular dependencies\n12:  *   - No orphaned subtasks (subtask IDs unique)\n13:  *   - Priority/difficulty values are valid enums\n14:  *   - Effort strings are parseable ISO 8601 durations\n15:  */\n16: \n17: import type { WomboConfig } from \"../../config.js\";\n18: import {\n19:   loadFeatures,\n20:   allFeatureIds,\n21:   parseDurationMinutes,\n22:   type Feature,\n23:   type Subtask,\n24:   type FeaturesFile,\n25:   type Priority,\n26:   type Difficulty,\n27:   type FeatureStatus,\n28: } from \"../../lib/features.js\";\n29: \n30: // ---------------------------------------------------------------------------\n31: // Types\n32: // ---------------------------------------------------------------------------\n33: \n34: export interface FeaturesCheckOptions {\n35:   projectRoot: string;\n36:   config: WomboConfig;\n37: }\n38: \n39: interface CheckResult {\n40:   errors: string[];\n41:   warnings: string[];\n42: }\n43: \n44: // ---------------------------------------------------------------------------\n45: // Validation\n46: // ---------------------------------------------------------------------------\n47: \n48: const VALID_STATUSES: FeatureStatus[] = [\n49:   \"backlog\", \"planned\", \"in_progress\", \"blocked\", \"in_review\", \"done\", \"cancelled\",\n50: ];\n51: \n52: const VALID_PRIORITIES: Priority[] = [\"critical\", \"high\", \"medium\", \"low\", \"wishlist\"];\n53: \n54: const VALID_DIFFICULTIES: Difficulty[] = [\"trivial\", \"easy\", \"medium\", \"hard\", \"very_hard\"];\n55: \n56: function collectAllItems(data: FeaturesFile): (Feature | Subtask)[] {\n57:   const items: (Feature | Subtask)[] = [];\n58:   const collect = (list: (Feature | Subtask)[]) => {\n59:     for (const item of list) {\n60:       items.push(item);\n61:       if (item.subtasks?.length) collect(item.subtasks);\n62:     }\n63:   };\n64:   collect(data.features ?? []);\n65:   collect(data.archive ?? []);\n66:   return items;\n67: }\n68: \n69: function checkFeatures(data: FeaturesFile): CheckResult {\n70:   const errors: string[] = [];\n71:   const warnings: string[] = [];\n72:   const allItems = collectAllItems(data);\n73:   const allIds = allItems.map((i) => i.id);\n74:   const idSet = new Set<string>();\n75: \n76:   // Check for duplicates\n77:   for (const id of allIds) {\n78:     if (idSet.has(id)) {\n79:       errors.push(`Duplicate ID: \"${id}\"`);\n80:     }\n81:     idSet.add(id);\n82:   }\n83: \n84:   // Check each item\n85:   for (const item of allItems) {\n86:     const prefix = `[${item.id}]`;\n87: \n88:     // Required fields\n89:     if (!item.id) errors.push(`${prefix} Missing required field: id`);\n90:     if (!item.title) errors.push(`${prefix} Missing required field: title`);\n91:     if (!item.status) errors.push(`${prefix} Missing required field: status`);\n92: \n93:     // Validate enum values\n94:     if (item.status && !VALID_STATUSES.includes(item.status)) {\n95:       errors.push(`${prefix} Invalid status: \"${item.status}\"`);\n96:     }\n97:     if (item.priority && !VALID_PRIORITIES.includes(item.priority)) {\n98:       errors.push(`${prefix} Invalid priority: \"${item.priority}\"`);\n99:     }\n100:     if (item.difficulty && !VALID_DIFFICULTIES.includes(item.difficulty)) {\n101:       errors.push(`${prefix} Invalid difficulty: \"${item.difficulty}\"`);\n102:     }\n103: \n104:     // Validate effort\n105:     if (item.effort) {\n106:       const minutes = parseDurationMinutes(item.effort);\n107:       if (minutes === Infinity) {\n108:         warnings.push(`${prefix} Unparseable effort duration: \"${item.effort}\"`);\n109:       }\n110:     }\n111: \n112:     // Check depends_on references\n113:     if (item.depends_on?.length) {\n114:       for (const dep of item.depends_on) {\n115:         if (!idSet.has(dep)) {\n116:           errors.push(`${prefix} Broken dependency: \"${dep}\" does not exist`);\n117:         }\n118:       }\n119:     }\n120:   }\n121: \n122:   // Check for circular dependencies (simple DFS)\n123:   const visited = new Set<string>();\n124:   const visiting = new Set<string>();\n125:   const depMap = new Map<string, string[]>();\n126:   for (const item of allItems) {\n127:     depMap.set(item.id, item.depends_on ?? []);\n128:   }\n129: \n130:   function hasCycle(id: string): boolean {\n131:     if (visiting.has(id)) return true;\n132:     if (visited.has(id)) return false;\n133:     visiting.add(id);\n134:     for (const dep of depMap.get(id) ?? []) {\n135:       if (hasCycle(dep)) {\n136:         errors.push(`Circular dependency detected involving: \"${id}\" → \"${dep}\"`);\n137:         return true;\n138:       }\n139:     }\n140:     visiting.delete(id);\n141:     visited.add(id);\n142:     return false;\n143:   }\n144: \n145:   for (const id of idSet) {\n146:     hasCycle(id);\n147:   }\n148: \n149:   // Warn about features with no effort estimate\n150:   for (const item of allItems) {\n151:     if (!item.effort || item.effort === \"PT0S\") {\n152:       warnings.push(`[${item.id}] No effort estimate`);\n153:     }\n154:   }\n155: \n156:   return { errors, warnings };\n157: }\n158: \n159: // ---------------------------------------------------------------------------\n160: // Command\n161: // ---------------------------------------------------------------------------\n162: \n163: export async function cmdFeaturesCheck(opts: FeaturesCheckOptions): Promise<void> {\n164:   const { projectRoot, config } = opts;\n165: \n166:   const data = loadFeatures(projectRoot, config);\n167:   const result = checkFeatures(data);\n168: \n169:   const allItems = collectAllItems(data);\n170:   console.log(`\\nChecking ${config.featuresFile} (${allItems.length} items)...\\n`);\n171: \n172:   if (result.errors.length === 0 && result.warnings.length === 0) {\n173:     console.log(\"  All checks passed. No issues found.\");\n174:     return;\n175:   }\n176: \n177:   if (result.errors.length > 0) {\n178:     console.log(`  ERRORS (${result.errors.length}):`);\n179:     for (const e of result.errors) {\n180:       console.log(`    \\x1b[31m✗\\x1b[0m ${e}`);\n181:     }\n182:     console.log(\"\");\n183:   }\n184: \n185:   if (result.warnings.length > 0) {\n186:     console.log(`  WARNINGS (${result.warnings.length}):`);\n187:     for (const w of result.warnings) {\n188:       console.log(`    \\x1b[33m⚠\\x1b[0m ${w}`);\n189:     }\n190:     console.log(\"\");\n191:   }\n192: \n193:   if (result.errors.length > 0) {\n194:     process.exit(1);\n195:   }\n196: }\n\n(End of file - total 196 lines)\n</content>","title":"src/commands/features/check.ts","metadata":{"preview":"/**\n * features/check.ts — Validate the features file for schema issues, broken deps, and orphans.\n *\n * Usage:\n *   wombo features check\n *\n * Checks:\n *   - Required fields present on every feature\n *   - No duplicate IDs\n *   - All depends_on references point to existing features\n *   - No circular dependencies\n *   - No orphaned subtasks (subtask IDs unique)\n *   - Priority/difficulty values are valid enums\n *   - Effort strings are parseable ISO 8601 durations\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  allFeatureIds,","truncated":false,"loaded":[]},"time":{"start":1773351656928,"end":1773351656931}}}}
