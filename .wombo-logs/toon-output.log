{"type":"tool_use","timestamp":1773351802196,"sessionID":"ses_31c0172a9ffeekk99N9QZhhvnC","part":{"id":"prt_ce400a8e4001N74ojwmbWoabK2","sessionID":"ses_31c0172a9ffeekk99N9QZhhvnC","messageID":"msg_ce4009ae4001SoKruk8kMFuCm6","type":"tool","callID":"toolu_vrtx_01JyT71PHQHZFaKGC2y43gxM","tool":"write","state":{"status":"completed","input":{"content":"/**\n * output.ts — Shared output helpers for agent-ready CLI.\n *\n * Provides a centralized way for commands to emit structured data that\n * renders as human-readable text on TTY, as JSON when --output json\n * is specified, or as TOON (Token-Optimized Output Notation) when\n * --output toon is specified.\n *\n * Usage in commands:\n *   import { output, OutputFormat } from \"../lib/output.js\";\n *\n *   // At the end of a command:\n *   output(format, data, textRenderer, toonRenderer);\n *   outputError(format, message);\n *   outputMessage(format, message, extra);\n */\n\nimport { toonError, toonMessage } from \"./toon.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type OutputFormat = \"text\" | \"json\" | \"toon\";\n\n// ---------------------------------------------------------------------------\n// Auto-detection heuristic\n// ---------------------------------------------------------------------------\n\n/**\n * Detect if the caller is likely an AI agent, using heuristics:\n *   1. WOMBO_OUTPUT env var is set to \"toon\"\n *   2. WOMBO_AGENT env var is truthy (explicit agent indicator)\n *   3. TERM_PROGRAM suggests a non-interactive context common with agents\n *\n * This is used when no explicit --output flag is given.\n */\nfunction detectAgentContext(): boolean {\n  if (process.env.WOMBO_AGENT === \"1\" || process.env.WOMBO_AGENT === \"true\") return true;\n  if (process.env.WOMBO_OUTPUT === \"toon\") return true;\n  return false;\n}\n\n// ---------------------------------------------------------------------------\n// Helpers\n// ---------------------------------------------------------------------------\n\n/**\n * Determine the output format. Priority:\n *   1. Explicit --output flag value\n *   2. WOMBO_OUTPUT env var (for agent pipelines — supports \"json\" and \"toon\")\n *   3. Auto-detect agent context → \"toon\" if WOMBO_AGENT=1\n *   4. Default to \"text\"\n *\n * Note: We intentionally do NOT auto-detect based on TTY. Many legitimate\n * use cases (bun dev, piped to less/grep, CI) have non-TTY stdout but still\n * want human output. Agents should explicitly pass --output json/toon or set\n * WOMBO_OUTPUT=json/toon or WOMBO_AGENT=1.\n */\nexport function resolveOutputFormat(explicit?: string): OutputFormat {\n  if (explicit === \"json\") return \"json\";\n  if (explicit === \"text\") return \"text\";\n  if (explicit === \"toon\") return \"toon\";\n  // Check env var for agent pipelines\n  const env = process.env.WOMBO_OUTPUT;\n  if (env === \"json\") return \"json\";\n  if (env === \"toon\") return \"toon\";\n  // Auto-detect agent context\n  if (detectAgentContext()) return \"toon\";\n  return \"text\";\n}\n\n/**\n * Emit structured data. In JSON mode, outputs a single JSON line to stdout.\n * In TOON mode, calls the toonRenderer callback (or falls back to JSON).\n * In text mode, calls the provided textRenderer callback.\n */\nexport function output(\n  format: OutputFormat,\n  data: unknown,\n  textRenderer: () => void,\n  toonRenderer?: () => string\n): void {\n  if (format === \"json\") {\n    console.log(JSON.stringify(data));\n  } else if (format === \"toon\") {\n    if (toonRenderer) {\n      console.log(toonRenderer());\n    } else {\n      // Fallback: emit JSON if no TOON renderer provided\n      console.log(JSON.stringify(data));\n    }\n  } else {\n    textRenderer();\n  }\n}\n\n/**\n * Emit an error. In JSON mode, outputs {\"error\": message} to stderr.\n * In TOON mode, outputs ERR|message to stderr.\n * In text mode, outputs the message to stderr normally.\n */\nexport function outputError(format: OutputFormat, message: string, exitCode: number = 1): never {\n  if (format === \"json\") {\n    console.error(JSON.stringify({ error: message }));\n  } else if (format === \"toon\") {\n    console.error(toonError(message));\n  } else {\n    console.error(message);\n  }\n  process.exit(exitCode);\n}\n\n/**\n * Emit a success/info message. In JSON mode, outputs {\"message\": msg, ...extra}.\n * In TOON mode, outputs MSG|msg[|key=val...].\n * In text mode, outputs the message to stdout normally.\n */\nexport function outputMessage(\n  format: OutputFormat,\n  message: string,\n  extra?: Record<string, unknown>\n): void {\n  if (format === \"json\") {\n    console.log(JSON.stringify({ message, ...extra }));\n  } else if (format === \"toon\") {\n    console.log(toonMessage(message, extra));\n  } else {\n    console.log(message);\n  }\n}\n\n// ---------------------------------------------------------------------------\n// Field filtering for compact output (--fields)\n// ---------------------------------------------------------------------------\n\n/**\n * Filter an object to only include the specified fields.\n * If fields is undefined/empty, returns the object unchanged.\n */\nexport function filterFields<T extends Record<string, unknown>>(\n  obj: T,\n  fields?: string[]\n): Partial<T> {\n  if (!fields || fields.length === 0) return obj;\n  const result: Partial<T> = {};\n  for (const field of fields) {\n    if (field in obj) {\n      (result as any)[field] = (obj as any)[field];\n    }\n  }\n  return result;\n}\n\n/**\n * Filter an array of objects to only include specified fields per object.\n * If fields is undefined/empty, returns the array unchanged.\n */\nexport function filterFieldsArray<T extends Record<string, unknown>>(\n  arr: T[],\n  fields?: string[]\n): Partial<T>[] {\n  if (!fields || fields.length === 0) return arr;\n  return arr.map((obj) => filterFields(obj, fields));\n}\n\n/**\n * Render a compact text table from an array of objects with selected fields.\n * Used for text-mode --fields output.\n */\nexport function renderCompactTable(\n  items: Record<string, unknown>[],\n  fields: string[]\n): void {\n  if (items.length === 0) return;\n\n  // Calculate column widths\n  const widths: Record<string, number> = {};\n  for (const field of fields) {\n    widths[field] = field.length;\n    for (const item of items) {\n      const val = String(item[field] ?? \"\");\n      widths[field] = Math.max(widths[field], val.length);\n    }\n  }\n\n  // Header\n  const header = fields.map((f) => f.padEnd(widths[f])).join(\"  \");\n  console.log(header);\n  console.log(fields.map((f) => \"─\".repeat(widths[f])).join(\"  \"));\n\n  // Rows\n  for (const item of items) {\n    const row = fields.map((f) => String(item[f] ?? \"\").padEnd(widths[f])).join(\"  \");\n    console.log(row);\n  }\n}\n","filePath":"/home/fulgidus/Documents/wombo-toon-output/src/lib/output.ts"},"output":"Wrote file successfully.","title":"src/lib/output.ts","metadata":{"diagnostics":{"/home/fulgidus/Documents/wombo-toon-output/src/index.ts":[{"range":{"start":{"line":447,"character":8},"end":{"line":447,"character":14}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":542,"character":8},"end":{"line":542,"character":14}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":567,"character":6},"end":{"line":567,"character":12}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":600,"character":8},"end":{"line":600,"character":14}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":626,"character":10},"end":{"line":626,"character":16}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"ra