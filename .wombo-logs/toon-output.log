{"type":"tool_use","timestamp":1773351650579,"sessionID":"ses_31c0172a9ffeekk99N9QZhhvnC","part":{"id":"prt_ce3fec19f001wwZ05b5kuBwxij","sessionID":"ses_31c0172a9ffeekk99N9QZhhvnC","messageID":"msg_ce3feb279001LHYB9Kt2qOwj6d","type":"tool","callID":"toolu_vrtx_01Ft218BEgHTtHAMDhpktwCK","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-toon-output/src/commands/features/list.ts"},"output":"<path>/home/fulgidus/Documents/wombo-toon-output/src/commands/features/list.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * features/list.ts — List and filter features from the features file.\n3:  *\n4:  * Usage:\n5:  *   wombo features list                     # list all features\n6:  *   wombo features list --status backlog    # filter by status\n7:  *   wombo features list --priority high     # filter by priority\n8:  *   wombo features list --ready             # show only ready features\n9:  *   wombo features list --archive           # include archived features\n10:  */\n11: \n12: import type { WomboConfig } from \"../../config.js\";\n13: import {\n14:   loadFeatures,\n15:   getReadyFeatures,\n16:   featureSummary,\n17:   formatDuration,\n18:   parseDurationMinutes,\n19:   type Feature,\n20:   type FeatureStatus,\n21:   type Priority,\n22:   type Difficulty,\n23:   type FeaturesFile,\n24: } from \"../../lib/features.js\";\n25: import { output, filterFieldsArray, renderCompactTable, type OutputFormat } from \"../../lib/output.js\";\n26: \n27: // ---------------------------------------------------------------------------\n28: // Types\n29: // ---------------------------------------------------------------------------\n30: \n31: export interface FeaturesListOptions {\n32:   projectRoot: string;\n33:   config: WomboConfig;\n34:   status?: FeatureStatus;\n35:   priority?: Priority;\n36:   difficulty?: Difficulty;\n37:   ready?: boolean;\n38:   includeArchive?: boolean;\n39:   outputFmt?: OutputFormat;\n40:   fields?: string[];\n41: }\n42: \n43: // ---------------------------------------------------------------------------\n44: // ANSI Helpers\n45: // ---------------------------------------------------------------------------\n46: \n47: const RESET = \"\\x1b[0m\";\n48: const BOLD = \"\\x1b[1m\";\n49: const DIM = \"\\x1b[2m\";\n50: \n51: const STATUS_COLOR: Record<FeatureStatus, string> = {\n52:   backlog: \"\\x1b[37m\",     // white\n53:   planned: \"\\x1b[36m\",     // cyan\n54:   in_progress: \"\\x1b[34m\", // blue\n55:   blocked: \"\\x1b[31m\",     // red\n56:   in_review: \"\\x1b[33m\",   // yellow\n57:   done: \"\\x1b[32m\",        // green\n58:   cancelled: \"\\x1b[90m\",   // gray\n59: };\n60: \n61: // ---------------------------------------------------------------------------\n62: // Command\n63: // ---------------------------------------------------------------------------\n64: \n65: export async function cmdFeaturesList(opts: FeaturesListOptions): Promise<void> {\n66:   const { projectRoot, config } = opts;\n67:   const data = loadFeatures(projectRoot, config);\n68: \n69:   let features: Feature[] = [...data.features];\n70: \n71:   // Include archive if requested\n72:   if (opts.includeArchive && data.archive?.length) {\n73:     features = [...features, ...data.archive];\n74:   }\n75: \n76:   // Filter by status\n77:   if (opts.status) {\n78:     features = features.filter((f) => f.status === opts.status);\n79:   }\n80: \n81:   // Filter by priority\n82:   if (opts.priority) {\n83:     features = features.filter((f) => f.priority === opts.priority);\n84:   }\n85: \n86:   // Filter by difficulty\n87:   if (opts.difficulty) {\n88:     features = features.filter((f) => f.difficulty === opts.difficulty);\n89:   }\n90: \n91:   // Filter to ready-only\n92:   if (opts.ready) {\n93:     const readyFeatures = getReadyFeatures(data);\n94:     const readyIds = new Set(readyFeatures.map((f) => f.id));\n95:     features = features.filter((f) => readyIds.has(f.id));\n96:   }\n97: \n98:   if (features.length === 0) {\n99:     output(opts.outputFmt ?? \"text\", { features: [], total: 0, effort: \"0m\" }, () => {\n100:       console.log(\"No features match the given filters.\");\n101:     });\n102:     return;\n103:   }\n104: \n105:   // Group by status for display\n106:   const byStatus = new Map<FeatureStatus, Feature[]>();\n107:   for (const f of features) {\n108:     const list = byStatus.get(f.status) ?? [];\n109:     list.push(f);\n110:     byStatus.set(f.status, list);\n111:   }\n112: \n113:   // Display\n114:   const totalEffort = features.reduce(\n115:     (sum, f) => sum + parseDurationMinutes(f.effort),\n116:     0\n117:   );\n118: \n119:   const fmt = opts.outputFmt ?? \"text\";\n120: \n121:   // Build the structured data for each feature\n122:   const featureData = features.map((f) => ({\n123:     id: f.id,\n124:     title: f.title,\n125:     status: f.status,\n126:     priority: f.priority,\n127:     difficulty: f.difficulty,\n128:     effort: f.effort,\n129:     completion: f.completion,\n130:     depends_on: f.depends_on,\n131:   }));\n132: \n133:   // If --fields is specified, use compact output mode\n134:   if (opts.fields?.length) {\n135:     const filtered = filterFieldsArray(featureData, opts.fields);\n136:     output(\n137:       fmt,\n138:       { features: filtered, total: features.length, effort: formatDuration(totalEffort) },\n139:       () => {\n140:         renderCompactTable(\n141:           featureData as Record<string, unknown>[],\n142:           opts.fields!\n143:         );\n144:       }\n145:     );\n146:     return;\n147:   }\n148: \n149:   output(\n150:     fmt,\n151:     {\n152:       features: featureData,\n153:       total: features.length,\n154:       effort: formatDuration(totalEffort),\n155:     },\n156:     () => {\n157:       console.log(`\\n${BOLD}Features (${features.length} total, ~${formatDuration(totalEffort)} effort)${RESET}\\n`);\n158: \n159:       const statusOrder: FeatureStatus[] = [\n160:         \"in_progress\",\n161:         \"planned\",\n162:         \"backlog\",\n163:         \"blocked\",\n164:         \"in_review\",\n165:         \"done\",\n166:         \"cancelled\",\n167:       ];\n168: \n169:       for (const status of statusOrder) {\n170:         const group = byStatus.get(status);\n171:         if (!group?.length) continue;\n172: \n173:         const color = STATUS_COLOR[status] ?? \"\";\n174:         console.log(`  ${color}${BOLD}${status.toUpperCase()}${RESET} (${group.length})`);\n175: \n176:         for (const f of group) {\n177:           const effort = formatDuration(parseDurationMinutes(f.effort));\n178:           const deps = f.depends_on.length > 0 ? ` ${DIM}deps: ${f.depends_on.join(\", \")}${RESET}` : \"\";\n179:           const completion = f.completion > 0 ? ` ${DIM}${f.completion}%${RESET}` : \"\";\n180:           console.log(\n181:             `    ${color}${f.id}${RESET} — ${f.title} [${f.priority}/${f.difficulty}] (${effort})${completion}${deps}`\n182:           );\n183:         }\n184:         console.log(\"\");\n185:       }\n186:     }\n187:   );\n188: }\n\n(End of file - total 188 lines)\n</content>","title":"src/commands/features/list.ts","metadata":{"preview":"/**\n * features/list.ts — List and filter features from the features file.\n *\n * Usage:\n *   wombo features list                     # list all features\n *   wombo features list --status backlog    # filter by status\n *   wombo features list --priority high     # filter by priority\n *   wombo features list --ready             # show only ready features\n *   wombo features list --archive           # include archived features\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  getReadyFeatures,\n  featureSummary,\n  formatDuration,\n  parseDurationMinutes,\n  type Feature,\n  type FeatureStatus,","truncated":false,"loaded":[]},"time":{"start":1773351650576,"end":1773351650578}}}}
{"type":"tool_use","timestamp":1773351650885,"sessionID":"ses_31c0172a9ffeekk99N9QZhhvnC","part":{"id":"prt_ce3fec569001odJnOaUJkQTwQ1","sessionID":"ses_31c0172a9ffeekk99N9QZhhvnC","messageID":"msg_ce3feb279001LHYB9Kt2qOwj6d","type":"tool","callID":"toolu_vrtx_01R1bN3yH1Jj1pA9hxsqfj6N","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-toon-output/src/commands/features/show.ts"},"output":"<path>/home/fulgidus/Documents/wombo-toon-output/src/commands/features/show.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * features/show.ts — Show detailed information about a specific feature.\n3:  *\n4:  * Usage:\n5:  *   wombo features show <feature-id>\n6:  */\n7: \n8: import type { WomboConfig } from \"../../config.js\";\n9: import {\n10:   loadFeatures,\n11:   findFeatureById,\n12:   formatDuration,\n13:   parseDurationMinutes,\n14:   areDependenciesMet,\n15:   getDoneFeatureIds,\n16:   type Feature,\n17:   type Subtask,\n18: } from \"../../lib/features.js\";\n19: import { output, outputError, filterFields, type OutputFormat } from \"../../lib/output.js\";\n20: \n21: // ---------------------------------------------------------------------------\n22: // Types\n23: // ---------------------------------------------------------------------------\n24: \n25: export interface FeaturesShowOptions {\n26:   projectRoot: string;\n27:   config: WomboConfig;\n28:   featureId: string;\n29:   outputFmt?: OutputFormat;\n30:   fields?: string[];\n31: }\n32: \n33: // ---------------------------------------------------------------------------\n34: // ANSI Helpers\n35: // ---------------------------------------------------------------------------\n36: \n37: const RESET = \"\\x1b[0m\";\n38: const BOLD = \"\\x1b[1m\";\n39: const DIM = \"\\x1b[2m\";\n40: const GREEN = \"\\x1b[32m\";\n41: const RED = \"\\x1b[31m\";\n42: const YELLOW = \"\\x1b[33m\";\n43: const CYAN = \"\\x1b[36m\";\n44: \n45: // ---------------------------------------------------------------------------\n46: // Display Helpers\n47: // ---------------------------------------------------------------------------\n48: \n49: function statusColor(status: string): string {\n50:   switch (status) {\n51:     case \"done\": return GREEN;\n52:     case \"in_progress\": return CYAN;\n53:     case \"blocked\":\n54:     case \"failed\": return RED;\n55:     case \"cancelled\": return DIM;\n56:     default: return \"\";\n57:   }\n58: }\n59: \n60: function renderSubtask(st: Subtask, indent: number): void {\n61:   const pad = \"  \".repeat(indent);\n62:   const color = statusColor(st.status);\n63:   const effort = formatDuration(parseDurationMinutes(st.effort));\n64:   const completionStr = st.completion > 0 ? ` (${st.completion}%)` : \"\";\n65:   console.log(\n66:     `${pad}${color}[${st.status}]${RESET} ${st.id} — ${st.title} [${st.priority}/${st.difficulty}] (${effort})${completionStr}`\n67:   );\n68:   if (st.subtasks?.length) {\n69:     for (const sub of st.subtasks) {\n70:       renderSubtask(sub, indent + 1);\n71:     }\n72:   }\n73: }\n74: \n75: // ---------------------------------------------------------------------------\n76: // Command\n77: // ---------------------------------------------------------------------------\n78: \n79: export async function cmdFeaturesShow(opts: FeaturesShowOptions): Promise<void> {\n80:   const { projectRoot, config } = opts;\n81:   const fmt = opts.outputFmt ?? \"text\";\n82: \n83:   if (!opts.featureId) {\n84:     outputError(fmt, \"Usage: wombo features show <feature-id>\");\n85:     return;\n86:   }\n87: \n88:   const data = loadFeatures(projectRoot, config);\n89:   const feature = findFeatureById(data, opts.featureId);\n90: \n91:   if (!feature) {\n92:     outputError(fmt, `Feature \"${opts.featureId}\" not found.`);\n93:     return;\n94:   }\n95: \n96:   const doneIds = getDoneFeatureIds(data);\n97:   const depsMet = areDependenciesMet(feature, doneIds);\n98:   const effort = formatDuration(parseDurationMinutes(feature.effort));\n99: \n100:   const fullData = {\n101:     ...feature,\n102:     deps_met: depsMet,\n103:     effort_formatted: effort,\n104:   };\n105: \n106:   // If --fields is specified, emit only those fields\n107:   if (opts.fields?.length) {\n108:     const filtered = filterFields(fullData as Record<string, unknown>, opts.fields);\n109:     output(fmt, filtered, () => {\n110:       for (const [key, val] of Object.entries(filtered)) {\n111:         const display = Array.isArray(val) ? val.join(\", \") : String(val ?? \"\");\n112:         console.log(`${key}: ${display}`);\n113:       }\n114:     });\n115:     return;\n116:   }\n117: \n118:   output(\n119:     fmt,\n120:     fullData,\n121:     () => {\n122:       console.log(`\\n${BOLD}Feature: ${feature.title}${RESET}`);\n123:       console.log(`  ID:          ${feature.id}`);\n124:       console.log(`  Status:      ${statusColor(feature.status)}${feature.status}${RESET}`);\n125:       console.log(`  Priority:    ${feature.priority}`);\n126:       console.log(`  Difficulty:  ${feature.difficulty}`);\n127:       console.log(`  Effort:      ${effort}`);\n128:       console.log(`  Completion:  ${feature.completion}%`);\n129:       console.log(`  Deps met:    ${depsMet ? `${GREEN}yes${RESET}` : `${RED}no${RESET}`}`);\n130: \n131:       if (feature.started_at) {\n132:         console.log(`  Started:     ${feature.started_at}`);\n133:       }\n134:       if (feature.ended_at) {\n135:         console.log(`  Ended:       ${feature.ended_at}`);\n136:       }\n137: \n138:       if (feature.description) {\n139:         console.log(`\\n  ${BOLD}Description:${RESET}`);\n140:         for (const line of feature.description.split(\"\\n\")) {\n141:           console.log(`    ${line}`);\n142:         }\n143:       }\n144: \n145:       if (feature.depends_on.length > 0) {\n146:         console.log(`\\n  ${BOLD}Dependencies:${RESET}`);\n147:         for (const dep of feature.depends_on) {\n148:           const met = doneIds.has(dep);\n149:           const icon = met ? `${GREEN}✓${RESET}` : `${RED}✗${RESET}`;\n150:           console.log(`    ${icon} ${dep}`);\n151:         }\n152:       }\n153: \n154:       if (feature.constraints.length > 0) {\n155:         console.log(`\\n  ${BOLD}Constraints:${RESET}`);\n156:         for (const c of feature.constraints) {\n157:           console.log(`    - ${c}`);\n158:         }\n159:       }\n160: \n161:       if (feature.forbidden.length > 0) {\n162:         console.log(`\\n  ${BOLD}Forbidden:${RESET}`);\n163:         for (const f of feature.forbidden) {\n164:           console.log(`    - ${RED}${f}${RESET}`);\n165:         }\n166:       }\n167: \n168:       if (feature.references.length > 0) {\n169:         console.log(`\\n  ${BOLD}References:${RESET}`);\n170:         for (const r of feature.references) {\n171:           console.log(`    - ${DIM}${r}${RESET}`);\n172:         }\n173:       }\n174: \n175:       if (feature.notes.length > 0) {\n176:         console.log(`\\n  ${BOLD}Notes:${RESET}`);\n177:         for (const n of feature.notes) {\n178:           console.log(`    - ${n}`);\n179:         }\n180:       }\n181: \n182:       if (feature.subtasks.length > 0) {\n183:         console.log(`\\n  ${BOLD}Subtasks (${feature.subtasks.length}):${RESET}`);\n184:         for (const st of feature.subtasks) {\n185:           renderSubtask(st, 2);\n186:         }\n187:       }\n188: \n189:       console.log(\"\");\n190:     }\n191:   );\n192: }\n\n(End of file - total 192 lines)\n</content>","title":"src/commands/features/show.ts","metadata":{"preview":"/**\n * features/show.ts — Show detailed information about a specific feature.\n *\n * Usage:\n *   wombo features show <feature-id>\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  findFeatureById,\n  formatDuration,\n  parseDurationMinutes,\n  areDependenciesMet,\n  getDoneFeatureIds,\n  type Feature,\n  type Subtask,\n} from \"../../lib/features.js\";\nimport { output, outputError, filterFields, type OutputFormat } from \"../../lib/output.js\";\n","truncated":false,"loaded":[]},"time":{"start":1773351650882,"end":1773351650884}}}}
{"type":"tool_use","timestamp":1773351651414,"sessionID":"ses_31c0172a9ffeekk99N9QZhhvnC","part":{"id":"prt_ce3fec683001xvsEY0GNz2S1KC","sessionID":"ses_31c0172a9ffeekk99N9QZhhvnC","messageID":"msg_ce3feb279001LHYB9Kt2qOwj6d","type":"tool","callID":"toolu_vrtx_01Jw9b2UxSKRf7zpxAJSjdD7","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-toon-output/src/commands/features/add.ts"},"output":"<path>/home/fulgidus/Documents/wombo-toon-output/src/commands/features/add.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * features/add.ts — Add a new feature to the features file.\n3:  *\n4:  * Usage:\n5:  *   wombo features add <id> --title \"Feature Title\" [--description \"...\"]\n6:  *                      [--priority medium] [--difficulty easy] [--effort PT2H]\n7:  *                      [--depends-on \"feat1,feat2\"]\n8:  */\n9: \n10: import type { WomboConfig } from \"../../config.js\";\n11: import {\n12:   loadFeatures,\n13:   saveFeatures,\n14:   createBlankFeature,\n15:   allFeatureIds,\n16:   type Priority,\n17:   type Difficulty,\n18: } from \"../../lib/features.js\";\n19: import { outputError, outputMessage, type OutputFormat } from \"../../lib/output.js\";\n20: \n21: // ---------------------------------------------------------------------------\n22: // Types\n23: // ---------------------------------------------------------------------------\n24: \n25: export interface FeaturesAddOptions {\n26:   projectRoot: string;\n27:   config: WomboConfig;\n28:   id: string;\n29:   title: string;\n30:   description?: string;\n31:   priority?: Priority;\n32:   difficulty?: Difficulty;\n33:   effort?: string;\n34:   dependsOn?: string[];\n35:   outputFmt?: OutputFormat;\n36:   dryRun?: boolean;\n37: }\n38: \n39: // ---------------------------------------------------------------------------\n40: // Command\n41: // ---------------------------------------------------------------------------\n42: \n43: export async function cmdFeaturesAdd(opts: FeaturesAddOptions): Promise<void> {\n44:   const { projectRoot, config } = opts;\n45:   const fmt = opts.outputFmt ?? \"text\";\n46: \n47:   if (!opts.id) {\n48:     outputError(fmt, \"Usage: wombo features add <id> --title \\\"Feature Title\\\"\");\n49:     return;\n50:   }\n51: \n52:   if (!opts.title) {\n53:     outputError(fmt, \"--title is required when adding a feature.\");\n54:     return;\n55:   }\n56: \n57:   const data = loadFeatures(projectRoot, config);\n58: \n59:   // Check for duplicate ID\n60:   const existingIds = allFeatureIds(data);\n61:   if (existingIds.includes(opts.id)) {\n62:     outputError(fmt, `Feature ID \"${opts.id}\" already exists.`);\n63:     return;\n64:   }\n65: \n66:   // Validate depends_on references\n67:   if (opts.dependsOn?.length) {\n68:     for (const dep of opts.dependsOn) {\n69:       if (!existingIds.includes(dep)) {\n70:         outputError(fmt, `Dependency \"${dep}\" does not exist in the features file.`);\n71:         return;\n72:       }\n73:     }\n74:   }\n75: \n76:   // Create the feature\n77:   const feature = createBlankFeature(opts.id, opts.title, opts.description ?? \"\", {\n78:     priority: opts.priority,\n79:     difficulty: opts.difficulty,\n80:     effort: opts.effort,\n81:   });\n82: \n83:   // Set dependencies\n84:   if (opts.dependsOn?.length) {\n85:     feature.depends_on = opts.dependsOn;\n86:   }\n87: \n88:   // Dry-run: show what would be added without writing\n89:   if (opts.dryRun) {\n90:     outputMessage(fmt, `[dry-run] Would add feature: ${opts.id} — ${opts.title}`, {\n91:       dry_run: true,\n92:       id: feature.id,\n93:       title: feature.title,\n94:       priority: feature.priority,\n95:       difficulty: feature.difficulty,\n96:       effort: feature.effort,\n97:       depends_on: feature.depends_on,\n98:     });\n99:     return;\n100:   }\n101: \n102:   // Append to features list\n103:   data.features.push(feature);\n104:   saveFeatures(projectRoot, config, data);\n105: \n106:   outputMessage(fmt, `Added feature: ${opts.id} — ${opts.title}`, {\n107:     id: feature.id,\n108:     title: feature.title,\n109:     priority: feature.priority,\n110:     difficulty: feature.difficulty,\n111:     effort: feature.effort,\n112:     depends_on: feature.depends_on,\n113:   });\n114: \n115:   if (fmt === \"text\") {\n116:     console.log(`  priority: ${feature.priority}, difficulty: ${feature.difficulty}, effort: ${feature.effort}`);\n117:     if (feature.depends_on.length > 0) {\n118:       console.log(`  depends on: ${feature.depends_on.join(\", \")}`);\n119:     }\n120:   }\n121: }\n\n(End of file - total 121 lines)\n</content>","title":"src/commands/features/add.ts","metadata":{"preview":"/**\n * features/add.ts — Add a new feature to the features file.\n *\n * Usage:\n *   wombo features add <id> --title \"Feature Title\" [--description \"...\"]\n *                      [--priority medium] [--difficulty easy] [--effort PT2H]\n *                      [--depends-on \"feat1,feat2\"]\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  saveFeatures,\n  createBlankFeature,\n  allFeatureIds,\n  type Priority,\n  type Difficulty,\n} from \"../../lib/features.js\";\nimport { outputError, outputMessage, type OutputFormat } from \"../../lib/output.js\";\n","truncated":false,"loaded":[]},"time":{"start":1773351651410,"end":1773351651413}}}}
{"type":"tool_use","timestamp":1773351652016,"sessionID":"ses_31c0172a9ffeekk99N9QZhhvnC","part":{"id":"prt_ce3fec853001sUjvfP2ui4On0P","sessionID":"ses_31c0172a9ffeekk99N9QZhhvnC","messageID":"msg_ce3feb279001LHYB9Kt2qOwj6d","type":"tool","callID":"toolu_vrtx_01UmCxYoXtUpkifdizKarfDe","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-toon-output/src/commands/features/set-status.ts"},"output":"<path>/home/fulgidus/Documents/wombo-toon-output/src/commands/features/set-status.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * features/set-status.ts — Change a feature's status.\n3:  *\n4:  * Usage:\n5:  *   wombo features set-status <feature-id> <new-status>\n6:  *\n7:  * Valid statuses: backlog, planned, in_progress, blocked, in_review, done, cancelled\n8:  */\n9: \n10: import type { WomboConfig } from \"../../config.js\";\n11: import {\n12:   loadFeatures,\n13:   saveFeatures,\n14:   findFeatureById,\n15:   type FeatureStatus,\n16: } from \"../../lib/features.js\";\n17: import { outputError, outputMessage, type OutputFormat } from \"../../lib/output.js\";\n18: \n19: // ---------------------------------------------------------------------------\n20: // Types\n21: // ---------------------------------------------------------------------------\n22: \n23: const VALID_STATUSES: FeatureStatus[] = [\n24:   \"backlog\",\n25:   \"planned\",\n26:   \"in_progress\",\n27:   \"blocked\",\n28:   \"in_review\",\n29:   \"done\",\n30:   \"cancelled\",\n31: ];\n32: \n33: export interface FeaturesSetStatusOptions {\n34:   projectRoot: string;\n35:   config: WomboConfig;\n36:   featureId: string;\n37:   newStatus: string;\n38:   outputFmt?: OutputFormat;\n39:   dryRun?: boolean;\n40: }\n41: \n42: // ---------------------------------------------------------------------------\n43: // Command\n44: // ---------------------------------------------------------------------------\n45: \n46: export async function cmdFeaturesSetStatus(opts: FeaturesSetStatusOptions): Promise<void> {\n47:   const { projectRoot, config } = opts;\n48:   const fmt = opts.outputFmt ?? \"text\";\n49: \n50:   if (!opts.featureId || !opts.newStatus) {\n51:     outputError(fmt, `Usage: wombo features set-status <feature-id> <new-status>\\nValid statuses: ${VALID_STATUSES.join(\", \")}`);\n52:     return;\n53:   }\n54: \n55:   // Validate status\n56:   if (!VALID_STATUSES.includes(opts.newStatus as FeatureStatus)) {\n57:     outputError(fmt, `Invalid status: \"${opts.newStatus}\"\\nValid statuses: ${VALID_STATUSES.join(\", \")}`);\n58:     return;\n59:   }\n60: \n61:   const data = loadFeatures(projectRoot, config);\n62:   const feature = findFeatureById(data, opts.featureId);\n63: \n64:   if (!feature) {\n65:     outputError(fmt, `Feature \"${opts.featureId}\" not found.`);\n66:     return;\n67:   }\n68: \n69:   const oldStatus = feature.status;\n70:   const newStatus = opts.newStatus as FeatureStatus;\n71: \n72:   if (oldStatus === newStatus) {\n73:     outputMessage(fmt, `Feature \"${opts.featureId}\" is already in status \"${newStatus}\".`, {\n74:       id: opts.featureId,\n75:       status: newStatus,\n76:       changed: false,\n77:     });\n78:     return;\n79:   }\n80: \n81:   // Dry-run: show what would change without writing\n82:   if (opts.dryRun) {\n83:     outputMessage(fmt, `[dry-run] Would change \"${opts.featureId}\": ${oldStatus} → ${newStatus}`, {\n84:       dry_run: true,\n85:       id: opts.featureId,\n86:       old_status: oldStatus,\n87:       new_status: newStatus,\n88:       changed: false,\n89:     });\n90:     return;\n91:   }\n92: \n93:   // Apply status change\n94:   feature.status = newStatus;\n95: \n96:   // Set timestamps\n97:   if (newStatus === \"in_progress\" && !feature.started_at) {\n98:     feature.started_at = new Date().toISOString();\n99:   }\n100:   if (newStatus === \"done\" || newStatus === \"cancelled\") {\n101:     feature.ended_at = new Date().toISOString();\n102:     if (newStatus === \"done\") {\n103:       feature.completion = 100;\n104:     }\n105:   }\n106: \n107:   saveFeatures(projectRoot, config, data);\n108: \n109:   outputMessage(fmt, `Feature \"${opts.featureId}\": ${oldStatus} → ${newStatus}`, {\n110:     id: opts.featureId,\n111:     old_status: oldStatus,\n112:     new_status: newStatus,\n113:     changed: true,\n114:   });\n115: }\n\n(End of file - total 115 lines)\n</content>","title":"src/commands/features/set-status.ts","metadata":{"preview":"/**\n * features/set-status.ts — Change a feature's status.\n *\n * Usage:\n *   wombo features set-status <feature-id> <new-status>\n *\n * Valid statuses: backlog, planned, in_progress, blocked, in_review, done, cancelled\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  saveFeatures,\n  findFeatureById,\n  type FeatureStatus,\n} from \"../../lib/features.js\";\nimport { outputError, outputMessage, type OutputFormat } from \"../../lib/output.js\";\n\n// ---------------------------------------------------------------------------\n// Types","truncated":false,"loaded":[]},"time":{"start":1773351652013,"end":1773351652015}}}}
{"type":"text","timestamp":1773351652357,"sessionID":"ses_31c0172a9ffeekk99N9QZhhvnC","part":{"id":"prt_ce3febeb9002373d2PzobkvCnC","sessionID":"ses_31c0172a9ffeekk99N9QZhhvnC","messageID":"msg_ce3feb279001LHYB9Kt2qOwj6d","type":"text","text":"Now let me look at the commands that use output format to understand the patterns:","time":{"start":1773351652357,"end":1773351652357}}}
{"type":"tool_use","timestamp":1773351652359,"sessionID":"ses_31c0172a9ffeekk99N9QZhhvnC","part":{"id":"prt_ce3fecaae0017dB33G5ByOyr5O","sessionID":"ses_31c0172a9ffeekk99N9QZhhvnC","messageID":"msg_ce3feb279001LHYB9Kt2qOwj6d","type":"tool","callID":"toolu_vrtx_01KE4DkFS6kLfxB5pZC76quh","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-toon-output/src/commands/features/graph.ts"},"output":"<path>/home/fulgidus/Documents/wombo-toon-output/src/commands/features/graph.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * features/graph.ts — Visualize the feature dependency graph.\n3:  *\n4:  * Usage:\n5:  *   wombo features graph                     # show full dependency graph\n6:  *   wombo features graph --status backlog    # filter by status\n7:  *   wombo features graph --ascii             # ASCII-only rendering\n8:  *   wombo features graph --output json       # emit mermaid source as JSON\n9:  *   wombo features graph --mermaid           # emit raw mermaid source text\n10:  *   wombo features graph --subtasks          # include subtask-level nodes\n11:  *\n12:  * Builds a Mermaid flowchart from the features dependency graph and renders\n13:  * it as a Unicode box diagram in the terminal using mermaidtui.\n14:  */\n15: \n16: import type { WomboConfig } from \"../../config.js\";\n17: import {\n18:   loadFeatures,\n19:   type Feature,\n20:   type Subtask,\n21:   type FeatureStatus,\n22:   type FeaturesFile,\n23: } from \"../../lib/features.js\";\n24: import { output, type OutputFormat } from \"../../lib/output.js\";\n25: \n26: // mermaidtui has no type declarations — import the JS module directly\n27: // @ts-ignore — no .d.ts published\n28: import { renderMermaidToTui } from \"mermaidtui\";\n29: \n30: // ---------------------------------------------------------------------------\n31: // Types\n32: // ---------------------------------------------------------------------------\n33: \n34: export interface FeaturesGraphOptions {\n35:   projectRoot: string;\n36:   config: WomboConfig;\n37:   status?: FeatureStatus;\n38:   ascii?: boolean;\n39:   mermaid?: boolean;\n40:   subtasks?: boolean;\n41:   outputFmt?: OutputFormat;\n42: }\n43: \n44: // ---------------------------------------------------------------------------\n45: // Status styling for Mermaid classDef\n46: // ---------------------------------------------------------------------------\n47: \n48: // Short status badge for node labels\n49: const STATUS_BADGE: Record<FeatureStatus, string> = {\n50:   backlog: \"BL\",\n51:   planned: \"PL\",\n52:   in_progress: \"IP\",\n53:   blocked: \"BK\",\n54:   in_review: \"IR\",\n55:   done: \"DN\",\n56:   cancelled: \"XX\",\n57: };\n58: \n59: // ---------------------------------------------------------------------------\n60: // Mermaid generation\n61: // ---------------------------------------------------------------------------\n62: \n63: /**\n64:  * Sanitize a string for use inside Mermaid labels.\n65:  * Mermaid uses square brackets for labels — we need to escape them.\n66:  */\n67: function sanitizeLabel(s: string): string {\n68:   return s\n69:     .replace(/\"/g, \"'\")\n70:     .replace(/\\[/g, \"(\")\n71:     .replace(/\\]/g, \")\")\n72:     .replace(/\\n/g, \" \")\n73:     .slice(0, 40); // keep labels short for terminal rendering\n74: }\n75: \n76: /**\n77:  * Generate a safe Mermaid node ID from a feature/subtask ID.\n78:  * Mermaid IDs can't start with numbers and some chars are reserved.\n79:  */\n80: function nodeId(id: string): string {\n81:   return `n_${id.replace(/-/g, \"_\")}`;\n82: }\n83: \n84: /**\n85:  * Collect all node IDs that exist in the graph (for filtering dangling deps).\n86:  */\n87: function collectAllIds(\n88:   features: Feature[],\n89:   includeSubtasks: boolean\n90: ): Set<string> {\n91:   const ids = new Set<string>();\n92:   for (const f of features) {\n93:     ids.add(f.id);\n94:     if (includeSubtasks) {\n95:       collectSubtaskIds(f.subtasks, ids);\n96:     }\n97:   }\n98:   return ids;\n99: }\n100: \n101: function collectSubtaskIds(subtasks: Subtask[], ids: Set<string>): void {\n102:   for (const st of subtasks) {\n103:     ids.add(st.id);\n104:     collectSubtaskIds(st.subtasks, ids);\n105:   }\n106: }\n107: \n108: /**\n109:  * Build the Mermaid flowchart source from the features file.\n110:  */\n111: function buildMermaidSource(\n112:   data: FeaturesFile,\n113:   opts: { status?: FeatureStatus; subtasks?: boolean }\n114: ): { source: string; nodeCount: number; edgeCount: number; orphanCount: number } {\n115:   let features = [...data.features];\n116: \n117:   // Filter by status if requested\n118:   if (opts.status) {\n119:     features = features.filter((f) => f.status === opts.status);\n120:   }\n121: \n122:   if (features.length === 0) {\n123:     return { source: \"\", nodeCount: 0, edgeCount: 0, orphanCount: 0 };\n124:   }\n125: \n126:   const allIds = collectAllIds(features, !!opts.subtasks);\n127:   const lines: string[] = [\"flowchart LR\"];\n128:   let nodeCount = 0;\n129:   let edgeCount = 0;\n130:   let orphanCount = 0;\n131: \n132:   // Process each feature\n133:   for (const f of features) {\n134:     const nid = nodeId(f.id);\n135:     const badge = STATUS_BADGE[f.status];\n136:     const label = `${badge} ${sanitizeLabel(f.title)}`;\n137:     lines.push(`    ${nid}[${label}]`);\n138:     nodeCount++;\n139: \n140:     let hasDeps = false;\n141: \n142:     // Add dependency edges\n143:     for (const dep of f.depends_on) {\n144:       if (allIds.has(dep)) {\n145:         lines.push(`    ${nodeId(dep)} --> ${nid}`);\n146:         edgeCount++;\n147:         hasDeps = true;\n148:       }\n149:     }\n150: \n151:     // Process subtasks if requested\n152:     if (opts.subtasks && f.subtasks.length > 0) {\n153:       const result = processSubtasks(f.subtasks, nid, allIds, lines);\n154:       nodeCount += result.nodeCount;\n155:       edgeCount += result.edgeCount;\n156:       if (result.nodeCount > 0) hasDeps = true;\n157:     }\n158: \n159:     if (!hasDeps && f.depends_on.length === 0 && (!opts.subtasks || f.subtasks.length === 0)) {\n160:       orphanCount++;\n161:     }\n162:   }\n163: \n164:   return {\n165:     source: lines.join(\"\\n\"),\n166:     nodeCount,\n167:     edgeCount,\n168:     orphanCount,\n169:   };\n170: }\n171: \n172: function processSubtasks(\n173:   subtasks: Subtask[],\n174:   parentNodeId: string,\n175:   allIds: Set<string>,\n176:   lines: string[]\n177: ): { nodeCount: number; edgeCount: number } {\n178:   let nodeCount = 0;\n179:   let edgeCount = 0;\n180: \n181:   for (const st of subtasks) {\n182:     const nid = nodeId(st.id);\n183:     const badge = STATUS_BADGE[st.status];\n184:     const label = `${badge} ${sanitizeLabel(st.title)}`;\n185:     lines.push(`    ${nid}[${label}]`);\n186:     nodeCount++;\n187: \n188:     // Link parent to subtask\n189:     lines.push(`    ${parentNodeId} --> ${nid}`);\n190:     edgeCount++;\n191: \n192:     // Subtask's own dependencies\n193:     for (const dep of st.depends_on) {\n194:       if (allIds.has(dep)) {\n195:         lines.push(`    ${nodeId(dep)} --> ${nid}`);\n196:         edgeCount++;\n197:       }\n198:     }\n199: \n200:     // Recurse into nested subtasks\n201:     if (st.subtasks.length > 0) {\n202:       const result = processSubtasks(st.subtasks, nid, allIds, lines);\n203:       nodeCount += result.nodeCount;\n204:       edgeCount += result.edgeCount;\n205:     }\n206:   }\n207: \n208:   return { nodeCount, edgeCount };\n209: }\n210: \n211: // ---------------------------------------------------------------------------\n212: // Text rendering helpers\n213: // ---------------------------------------------------------------------------\n214: \n215: const RESET = \"\\x1b[0m\";\n216: const BOLD = \"\\x1b[1m\";\n217: const DIM = \"\\x1b[2m\";\n218: const RED = \"\\x1b[31m\";\n219: const YELLOW = \"\\x1b[33m\";\n220: const GREEN = \"\\x1b[32m\";\n221: const CYAN = \"\\x1b[36m\";\n222: \n223: /**\n224:  * Print a legend explaining the status badges used in the graph.\n225:  */\n226: function printLegend(features: Feature[]): void {\n227:   const statuses = new Set<FeatureStatus>();\n228:   for (const f of features) {\n229:     statuses.add(f.status);\n230:   }\n231: \n232:   console.log(`\\n${BOLD}Legend:${RESET}`);\n233:   const legendItems: string[] = [];\n234:   for (const [status, badge] of Object.entries(STATUS_BADGE)) {\n235:     if (statuses.has(status as FeatureStatus)) {\n236:       legendItems.push(`  ${badge} = ${status}`);\n237:     }\n238:   }\n239:   console.log(legendItems.join(\"  |\"));\n240: }\n241: \n242: /**\n243:  * Detect potential issues in the dependency graph and print warnings.\n244:  */\n245: function printDiagnostics(data: FeaturesFile, includeSubtasks: boolean): void {\n246:   const allIds = collectAllIds(data.features, includeSubtasks);\n247:   const issues: string[] = [];\n248: \n249:   // Check for dangling dependencies (pointing to non-existent IDs)\n250:   for (const f of data.features) {\n251:     for (const dep of f.depends_on) {\n252:       if (!allIds.has(dep)) {\n253:         issues.push(`${YELLOW}WARNING${RESET}: ${f.id} depends on \"${dep}\" which does not exist`);\n254:       }\n255:     }\n256:     if (includeSubtasks) {\n257:       checkSubtaskDeps(f.subtasks, allIds, issues);\n258:     }\n259:   }\n260: \n261:   // Check for circular dependencies (simple DFS)\n262:   const circularPaths = detectCycles(data.features, includeSubtasks);\n263:   for (const cycle of circularPaths) {\n264:     issues.push(`${RED}CYCLE${RESET}: ${cycle.join(\" -> \")}`);\n265:   }\n266: \n267:   // Check for blocked features whose blockers are done\n268:   for (const f of data.features) {\n269:     if (f.status === \"blocked\") {\n270:       const allDepsDone = f.depends_on.every((dep) => {\n271:         const depFeature = data.features.find((ff) => ff.id === dep);\n272:         return depFeature?.status === \"done\";\n273:       });\n274:       if (allDepsDone && f.depends_on.length > 0) {\n275:         issues.push(\n276:           `${CYAN}INFO${RESET}: ${f.id} is marked \"blocked\" but all its dependencies are done`\n277:         );\n278:       }\n279:     }\n280:   }\n281: \n282:   if (issues.length > 0) {\n283:     console.log(`\\n${BOLD}Diagnostics (${issues.length} issue${issues.length > 1 ? \"s\" : \"\"}):${RESET}`);\n284:     for (const issue of issues) {\n285:       console.log(`  ${issue}`);\n286:     }\n287:   }\n288: }\n289: \n290: function checkSubtaskDeps(\n291:   subtasks: Subtask[],\n292:   allIds: Set<string>,\n293:   issues: string[]\n294: ): void {\n295:   for (const st of subtasks) {\n296:     for (const dep of st.depends_on) {\n297:       if (!allIds.has(dep)) {\n298:         issues.push(\n299:           `${YELLOW}WARNING${RESET}: subtask ${st.id} depends on \"${dep}\" which does not exist`\n300:         );\n301:       }\n302:     }\n303:     checkSubtaskDeps(st.subtasks, allIds, issues);\n304:   }\n305: }\n306: \n307: /**\n308:  * Detect circular dependencies using DFS.\n309:  * Returns arrays of ID paths that form cycles.\n310:  */\n311: function detectCycles(\n312:   features: Feature[],\n313:   includeSubtasks: boolean\n314: ): string[][] {\n315:   // Build adjacency list: dep -> [dependents]\n316:   const adj = new Map<string, string[]>();\n317:   const allItems = new Map<string, { depends_on: string[] }>();\n318: \n319:   for (const f of features) {\n320:     allItems.set(f.id, f);\n321:     if (includeSubtasks) {\n322:       collectSubtaskItems(f.subtasks, allItems);\n323:     }\n324:   }\n325: \n326:   for (const [id, item] of allItems) {\n327:     for (const dep of item.depends_on) {\n328:       if (!adj.has(id)) adj.set(id, []);\n329:       adj.get(id)!.push(dep);\n330:     }\n331:   }\n332: \n333:   const visited = new Set<string>();\n334:   const inStack = new Set<string>();\n335:   const cycles: string[][] = [];\n336: \n337:   function dfs(node: string, path: string[]): void {\n338:     if (inStack.has(node)) {\n339:       // Found a cycle — extract it\n340:       const cycleStart = path.indexOf(node);\n341:       cycles.push([...path.slice(cycleStart), node]);\n342:       return;\n343:     }\n344:     if (visited.has(node)) return;\n345: \n346:     visited.add(node);\n347:     inStack.add(node);\n348:     path.push(node);\n349: \n350:     for (const neighbor of adj.get(node) ?? []) {\n351:       dfs(neighbor, path);\n352:     }\n353: \n354:     path.pop();\n355:     inStack.delete(node);\n356:   }\n357: \n358:   for (const id of allItems.keys()) {\n359:     if (!visited.has(id)) {\n360:       dfs(id, []);\n361:     }\n362:   }\n363: \n364:   return cycles;\n365: }\n366: \n367: function collectSubtaskItems(\n368:   subtasks: Subtask[],\n369:   map: Map<string, { depends_on: string[] }>\n370: ): void {\n371:   for (const st of subtasks) {\n372:     map.set(st.id, st);\n373:     collectSubtaskItems(st.subtasks, map);\n374:   }\n375: }\n376: \n377: // ---------------------------------------------------------------------------\n378: // Command\n379: // ---------------------------------------------------------------------------\n380: \n381: export async function cmdFeaturesGraph(opts: FeaturesGraphOptions): Promise<void> {\n382:   const { projectRoot, config } = opts;\n383:   const data = loadFeatures(projectRoot, config);\n384:   const fmt = opts.outputFmt ?? \"text\";\n385: \n386:   const { source, nodeCount, edgeCount, orphanCount } = buildMermaidSource(data, {\n387:     status: opts.status,\n388:     subtasks: opts.subtasks,\n389:   });\n390: \n391:   if (nodeCount === 0) {\n392:     output(fmt, { graph: null, nodes: 0, edges: 0, message: \"No features to graph\" }, () => {\n393:       console.log(\"No features to graph.\");\n394:     });\n395:     return;\n396:   }\n397: \n398:   // --mermaid: emit raw mermaid source\n399:   if (opts.mermaid) {\n400:     output(fmt, { mermaid: source, nodes: nodeCount, edges: edgeCount }, () => {\n401:       console.log(source);\n402:     });\n403:     return;\n404:   }\n405: \n406:   // --output json: emit structured data\n407:   if (fmt === \"json\") {\n408:     const rendered = renderMermaidToTui(source, { ascii: true }) as string;\n409:     console.log(\n410:       JSON.stringify({\n411:         mermaid: source,\n412:         rendered,\n413:         nodes: nodeCount,\n414:         edges: edgeCount,\n415:         orphans: orphanCount,\n416:       })\n417:     );\n418:     return;\n419:   }\n420: \n421:   // Default: render the graph in the terminal\n422:   const rendered = renderMermaidToTui(source, { ascii: !!opts.ascii }) as string;\n423: \n424:   console.log(`\\n${BOLD}Feature Dependency Graph${RESET}`);\n425:   console.log(`${DIM}${nodeCount} nodes, ${edgeCount} edges, ${orphanCount} orphans (no deps/dependents)${RESET}\\n`);\n426:   console.log(rendered);\n427: \n428:   // Print legend and diagnostics\n429:   printLegend(data.features);\n430:   printDiagnostics(data, !!opts.subtasks);\n431:   console.log(\"\");\n432: }\n\n(End of file - total 432 lines)\n</content>","title":"src/commands/features/graph.ts","metadata":{"preview":"/**\n * features/graph.ts — Visualize the feature dependency graph.\n *\n * Usage:\n *   wombo features graph                     # show full dependency graph\n *   wombo features graph --status backlog    # filter by status\n *   wombo features graph --ascii             # ASCII-only rendering\n *   wombo features graph --output json       # emit mermaid source as JSON\n *   wombo features graph --mermaid           # emit raw mermaid source text\n *   wombo features graph --subtasks          # include subtask-level nodes\n *\n * Builds a Mermaid flowchart from the features dependency graph and renders\n * it as a Unicode box diagram in the terminal using mermaidtui.\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  type Feature,\n  type Subtask,","truncated":false,"loaded":[]},"time":{"start":1773351652356,"end":1773351652358}}}}
