{"type":"tool_use","timestamp":1773351979375,"sessionID":"ses_31bfcf566ffeX54k1gNGv0ej46","part":{"id":"prt_ce403c76a001vS3jrfyAACDrfl","sessionID":"ses_31bfcf566ffeX54k1gNGv0ej46","messageID":"msg_ce403bc8c001pid3r8AusWjRLU","type":"tool","callID":"toolu_vrtx_01HbfnG2ajgnji6i4s1gpygh","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-agent-browser-integration/src/lib/templates.ts"},"output":"<path>/home/fulgidus/Documents/wombo-agent-browser-integration/src/lib/templates.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * templates.ts — Resolve paths to bundled template files and install helpers.\n3:  *\n4:  * All template paths are resolved relative to the source file location\n5:  * using import.meta.dir (Bun-specific). This ensures templates are found\n6:  * whether running from source (bun dev) or from an installed package.\n7:  */\n8: \n9: import { join, dirname, resolve } from \"node:path\";\n10: import { existsSync, readFileSync, writeFileSync, mkdirSync } from \"node:fs\";\n11: import type { WomboConfig } from \"../config.js\";\n12: \n13: // ---------------------------------------------------------------------------\n14: // Template Paths\n15: // ---------------------------------------------------------------------------\n16: \n17: /**\n18:  * Absolute path to the bundled wave-worker agent definition template.\n19:  * Used by `wombo init` to install the agent definition into the project,\n20:  * and by `wombo launch` to reinstall it if missing.\n21:  */\n22: export const AGENT_TEMPLATE_PATH = join(dirname(import.meta.dir), \"templates\", \"wave-worker.md\");\n23: \n24: // ---------------------------------------------------------------------------\n25: // Template Rendering\n26: // ---------------------------------------------------------------------------\n27: \n28: /**\n29:  * Default runtime description used when no project-specific value is available.\n30:  */\n31: const DEFAULT_RUNTIME = \"Bun (not Node). TypeScript, strict mode, ESM only.\";\n32: \n33: /**\n34:  * Render the agent template by replacing {{placeholders}} with config values.\n35:  *\n36:  * Supported placeholders:\n37:  *   - {{featuresFile}}  — path to the features YAML file (e.g. \".features.yml\")\n38:  *   - {{branchPrefix}}  — git branch prefix (e.g. \"feature/\")\n39:  *   - {{buildCommand}}  — build command (e.g. \"bun run build\")\n40:  *   - {{runtime}}       — project runtime description\n41:  *   - {{project}}       — project directory name\n42:  */\n43: export function renderAgentTemplate(\n44:   config: WomboConfig,\n45:   projectRoot: string\n46: ): string {\n47:   const raw = readFileSync(AGENT_TEMPLATE_PATH, \"utf-8\");\n48:   const projectName = projectRoot.split(\"/\").pop() ?? \"project\";\n49: \n50:   return raw\n51:     .replace(/\\{\\{featuresFile\\}\\}/g, config.featuresFile)\n52:     .replace(/\\{\\{branchPrefix\\}\\}/g, config.git.branchPrefix)\n53:     .replace(/\\{\\{buildCommand\\}\\}/g, config.build.command)\n54:     .replace(/\\{\\{runtime\\}\\}/g, DEFAULT_RUNTIME)\n55:     .replace(/\\{\\{project\\}\\}/g, projectName);\n56: }\n57: \n58: // ---------------------------------------------------------------------------\n59: // Agent Definition Guard\n60: // ---------------------------------------------------------------------------\n61: \n62: /**\n63:  * Ensure the agent definition file exists at the expected path.\n64:  * If missing, reinstall from the bundled template and warn the user.\n65:  *\n66:  * Called at the start of `wombo launch` to prevent the failure mode where\n67:  * agents spawn without their agent definition file.\n68:  *\n69:  * @returns true if the file was reinstalled, false if it already existed.\n70:  */\n71: export function ensureAgentDefinition(\n72:   projectRoot: string,\n73:   config: WomboConfig\n74: ): boolean {\n75:   const agentDir = resolve(projectRoot, \"agent\");\n76:   const agentDefPath = resolve(agentDir, `${config.agent.name}.md`);\n77: \n78:   if (existsSync(agentDefPath)) {\n79:     return false;\n80:   }\n81: \n82:   // Agent definition missing — reinstall from bundled template\n83:   console.warn(\n84:     `\\x1b[33m[WARNING]\\x1b[0m Agent definition not found: agent/${config.agent.name}.md`\n85:   );\n86:   console.warn(`  Reinstalling from bundled template...`);\n87: \n88:   try {\n89:     mkdirSync(agentDir, { recursive: true });\n90:     const content = renderAgentTemplate(config, projectRoot);\n91:     writeFileSync(agentDefPath, content, \"utf-8\");\n92:     console.warn(`  Restored agent/${config.agent.name}.md\\n`);\n93:     return true;\n94:   } catch (err: any) {\n95:     console.error(\n96:       `  Failed to restore agent definition: ${err.message}`\n97:     );\n98:     console.error(\n99:       `  Agents may launch without their definition file.\\n`\n100:     );\n101:     return false;\n102:   }\n103: }\n\n(End of file - total 103 lines)\n</content>","title":"src/lib/templates.ts","metadata":{"preview":"/**\n * templates.ts — Resolve paths to bundled template files and install helpers.\n *\n * All template paths are resolved relative to the source file location\n * using import.meta.dir (Bun-specific). This ensures templates are found\n * whether running from source (bun dev) or from an installed package.\n */\n\nimport { join, dirname, resolve } from \"node:path\";\nimport { existsSync, readFileSync, writeFileSync, mkdirSync } from \"node:fs\";\nimport type { WomboConfig } from \"../config.js\";\n\n// ---------------------------------------------------------------------------\n// Template Paths\n// ---------------------------------------------------------------------------\n\n/**\n * Absolute path to the bundled wave-worker agent definition template.\n * Used by `wombo init` to install the agent definition into the project,\n * and by `wombo launch` to reinstall it if missing.","truncated":false,"loaded":[]},"time":{"start":1773351979372,"end":1773351979374}}}}
