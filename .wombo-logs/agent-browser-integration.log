{"type":"tool_use","timestamp":1773352298992,"sessionID":"ses_31bfcf566ffeX54k1gNGv0ej46","part":{"id":"prt_ce408a6b9001uzcDBiNBL7boiN","sessionID":"ses_31bfcf566ffeX54k1gNGv0ej46","messageID":"msg_ce4089a9f0010zrBlHjrGK140x","type":"tool","callID":"toolu_vrtx_01V3BUWa4ZwU5f6JhLQUPQNa","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-agent-browser-integration/src/commands/verify.ts"},"output":"<path>/home/fulgidus/Documents/wombo-agent-browser-integration/src/commands/verify.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * verify.ts — Run build verification on completed agents.\n3:  *\n4:  * Usage: wombo verify [feature-id] [--browser]\n5:  *\n6:  * Runs the build command in each completed agent's worktree. If a specific\n7:  * feature-id is given, verifies only that agent. Otherwise verifies all\n8:  * agents with status \"completed\".\n9:  *\n10:  * When --browser is passed (or browser.enabled is true in config), also\n11:  * runs browser-based verification after the build passes.\n12:  */\n13: \n14: import type { WomboConfig } from \"../config.js\";\n15: import { loadFeatures } from \"../lib/features.js\";\n16: import { loadState, saveState } from \"../lib/state.js\";\n17: import { printDashboard } from \"../lib/ui.js\";\n18: import { handleBuildVerification } from \"./launch.js\";\n19: \n20: // ---------------------------------------------------------------------------\n21: // Types\n22: // ---------------------------------------------------------------------------\n23: \n24: export interface VerifyCommandOptions {\n25:   projectRoot: string;\n26:   config: WomboConfig;\n27:   featureId?: string;\n28:   model?: string;\n29:   maxRetries?: number;\n30:   /** Enable browser verification (overrides config.browser.enabled) */\n31:   browserVerify?: boolean;\n32: }\n33: \n34: // ---------------------------------------------------------------------------\n35: // Command\n36: // ---------------------------------------------------------------------------\n37: \n38: export async function cmdVerify(opts: VerifyCommandOptions): Promise<void> {\n39:   const { projectRoot, config } = opts;\n40: \n41:   // Apply browser verification override if --browser flag was passed\n42:   if (opts.browserVerify !== undefined) {\n43:     config.browser.enabled = opts.browserVerify;\n44:   }\n45: \n46:   const state = loadState(projectRoot);\n47:   if (!state) {\n48:     console.log(\"No active wave.\");\n49:     return;\n50:   }\n51: \n52:   const toVerify = opts.featureId\n53:     ? state.agents.filter((a) => a.feature_id === opts.featureId)\n54:     : state.agents.filter((a) => a.status === \"completed\");\n55: \n56:   if (toVerify.length === 0) {\n57:     console.log(\"No agents to verify.\");\n58:     return;\n59:   }\n60: \n61:   console.log(`\\nVerifying ${toVerify.length} agent(s)...\\n`);\n62: \n63:   const data = loadFeatures(projectRoot, config);\n64: \n65:   for (const agent of toVerify) {\n66:     const feature = data.features.find((f) => f.id === agent.feature_id);\n67:     if (!feature) continue;\n68: \n69:     await handleBuildVerification(projectRoot, state, agent, feature, config, opts.model);\n70:   }\n71: \n72:   printDashboard(state);\n73: }\n\n(End of file - total 73 lines)\n</content>","title":"src/commands/verify.ts","metadata":{"preview":"/**\n * verify.ts — Run build verification on completed agents.\n *\n * Usage: wombo verify [feature-id] [--browser]\n *\n * Runs the build command in each completed agent's worktree. If a specific\n * feature-id is given, verifies only that agent. Otherwise verifies all\n * agents with status \"completed\".\n *\n * When --browser is passed (or browser.enabled is true in config), also\n * runs browser-based verification after the build passes.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport { loadFeatures } from \"../lib/features.js\";\nimport { loadState, saveState } from \"../lib/state.js\";\nimport { printDashboard } from \"../lib/ui.js\";\nimport { handleBuildVerification } from \"./launch.js\";\n\n// ---------------------------------------------------------------------------","truncated":false,"loaded":[]},"time":{"start":1773352298988,"end":1773352298991}}}}
