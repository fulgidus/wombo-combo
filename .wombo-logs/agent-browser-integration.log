lty>\");\n764:           process.exit(1);\n765:           return;\n766:         }\n767:         await cmdFeaturesSetDifficulty({\n768:           projectRoot,\n769:           config,\n770:           featureId: args.featureId,\n771:           newDifficulty,\n772:           outputFmt: args.outputFmt,\n773:           dryRun: args.dryRun,\n774:         });\n775:       } else {\n776:         await cmdFeaturesSetDifficulty({\n777:           projectRoot,\n778:           config,\n779:           featureId: args.featureId,\n780:           newDifficulty: args.title, // second positional = new difficulty\n781:           outputFmt: args.outputFmt,\n782:           dryRun: args.dryRun,\n783:         });\n784:       }\n785:       break;\n786:     }\n787: \n788:     case \"check\":\n789:     case \"validate\":\n790:       await cmdFeaturesCheck({ projectRoot, config });\n791:       break;\n792: \n793:     case \"archive\":\n794:       await cmdFeaturesArchive({\n795:         projectRoot,\n796:         config,\n797:         featureId: args.featureId,\n798:         dryRun: args.dryRun,\n799:       });\n800:       break;\n801: \n802:     case \"show\": {\n803:       if (!args.featureId) {\n804:         console.error(\"Usage: wombo features show <feature-id>\");\n805:         process.exit(1);\n806:         return;\n807:       }\n808:       await cmdFeaturesShow({\n809:         projectRoot,\n810:         config,\n811:         featureId: args.featureId,\n812:         outputFmt: args.outputFmt,\n813:         fields: args.fields,\n814:       });\n815:       break;\n816:     }\n817: \n818:     case \"graph\":\n819:       await cmdFeaturesGraph({\n820:         projectRoot,\n821:         config,\n822:         status: args.status as FeatureStatus | undefined,\n823:         ascii: args.ascii,\n824:         mermaid: args.mermaidRaw,\n825:         subtasks: args.graphSubtasks,\n826:         outputFmt: args.outputFmt,\n827:       });\n828:       break;\n829: \n830:     case \"help\":\n831:     case 