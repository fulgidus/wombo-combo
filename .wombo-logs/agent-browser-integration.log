{"type":"tool_use","timestamp":1773352294719,"sessionID":"ses_31bfcf566ffeX54k1gNGv0ej46","part":{"id":"prt_ce408952a001Gc0yHImX4DTscA","sessionID":"ses_31bfcf566ffeX54k1gNGv0ej46","messageID":"msg_ce4088ac0001XWOSu8vKbz1VwI","type":"tool","callID":"toolu_vrtx_016mN2mpr4tzXf4wzY9r1UUj","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-agent-browser-integration/src/index.ts"},"output":"<path>/home/fulgidus/Documents/wombo-agent-browser-integration/src/index.ts</path>\n<type>file</type>\n<content>1: #!/usr/bin/env bun\n2: /**\n3:  * index.ts — CLI entry point for the Wombo agent orchestration system.\n4:  *\n5:  * Usage:\n6:  *   wombo init\n7:  *   wombo launch --top-priority 3\n8:  *   wombo launch --quickest-wins 5\n9:  *   wombo launch --priority high\n10:  *   wombo launch --difficulty easy\n11:  *   wombo launch --features \"feat-a,feat-b\"\n12:  *   wombo launch --all-ready\n13:  *   wombo launch ... --max-concurrent 3 --model \"anthropic/claude-sonnet-4-20250514\"\n14:  *   wombo launch ... --interactive\n15:  *   wombo resume\n16:  *   wombo status\n17:  *   wombo verify [feature-id]\n18:  *   wombo merge [feature-id]\n19:  *   wombo retry <feature-id>\n20:  *   wombo abort <feature-id> [--requeue] [--output json]\n21:  *   wombo logs <feature-id> [--tail N] [--follow] [--output json]\n22:  *   wombo cleanup\n23:  *   wombo features list [--status <s>] [--priority <p>] [--difficulty <d>] [--ready] [--include-archive]\n24:  *   wombo features add <id> <title> [options]\n25:  *   wombo features set-status <feature-id> <status>\n26:  *   wombo features set-priority <feature-id> <priority>\n27:  *   wombo features set-difficulty <feature-id> <difficulty>\n28:  *   wombo features check\n29:  *   wombo features archive [feature-id] [--dry-run]\n30:  *   wombo features show <feature-id>\n31:  *   wombo features graph [--ascii] [--mermaid] [--subtasks] [--status <s>]\n32:  *   wombo help\n33:  *   wombo --version\n34:  */\n35: \n36: import { resolve } from \"node:path\";\n37: import { existsSync, readFileSync } from \"node:fs\";\n38: import { loadConfig, validateConfig } from \"./config.js\";\n39: import { loadState, saveState } from \"./lib/state.js\";\n40: \n41: // ---------------------------------------------------------------------------\n42: // Dev-mode guard: warn if running the global binary inside the wombo repo\n43: // ---------------------------------------------------------------------------\n44: \n45: function checkDevModeGuard(): void {\n46:   const cwd = process.cwd();\n47:   const pkgPath = resolve(cwd, \"package.json\");\n48: \n49:   // Are we inside the wombo repo?\n50:   if (!existsSync(pkgPath)) return;\n51: \n52:   let pkgName: string | undefined;\n53:   try {\n54:     const raw = readFileSync(pkgPath, \"utf-8\");\n55:     pkgName = JSON.parse(raw).name;\n56:   } catch {\n57:     return;\n58:   }\n59:   if (pkgName !== \"wombo\") return;\n60: \n61:   // We're in the wombo repo. Is the source being run from a different location?\n62:   // import.meta.dir = directory of THIS file (index.ts). If it's under cwd,\n63:   // we're running local source (bun dev). If it's elsewhere (e.g. ~/.bun/install),\n64:   // we're running the globally installed binary.\n65:   const sourceDir = resolve(import.meta.dir);\n66:   const projectSrc = resolve(cwd, \"src\");\n67: \n68:   if (!sourceDir.startsWith(projectSrc)) {\n69:     console.warn(\n70:       \"\\x1b[33m[WARNING]\\x1b[0m You are running the globally installed wombo binary \" +\n71:       \"inside the wombo repo.\\n\" +\n72:       \"  Use \\x1b[1mbun dev <command>\\x1b[0m instead to run from local source.\\n\" +\n73:       \"  See AGENTS.md for details.\\n\"\n74:     );\n75:   }\n76: }\n77: \n78: import { cmdInit } from \"./commands/init.js\";\n79: import { cmdLaunch } from \"./commands/launch.js\";\n80: import { cmdResume } from \"./commands/resume.js\";\n81: import { cmdStatus } from \"./commands/status.js\";\n82: import { cmdVerify } from \"./commands/verify.js\";\n83: import { cmdMerge } from \"./commands/merge.js\";\n84: import { cmdRetry } from \"./commands/retry.js\";\n85: import { cmdCleanup } from \"./commands/cleanup.js\";\n86: import { cmdAbort } from \"./commands/abort.js\";\n87: import { cmdLogs } from \"./commands/logs.js\";\n88: import { cmdUpgrade } from \"./commands/upgrade.js\";\n89: import { cmdFeaturesList } from \"./commands/features/list.js\";\n90: import { cmdFeaturesAdd } from \"./commands/features/add.js\";\n91: import { cmdFeaturesSetStatus } from \"./commands/features/set-status.js\";\n92: import { cmdFeaturesSetPriority } from \"./commands/features/set-priority.js\";\n93: import { cmdFeaturesSetDifficulty } from \"./commands/features/set-difficulty.js\";\n94: import { cmdFeaturesCheck } from \"./commands/features/check.js\";\n95: import { cmdFeaturesArchive } from \"./commands/features/archive.js\";\n96: import { cmdFeaturesShow } from \"./commands/features/show.js\";\n97: import { cmdFeaturesGraph } from \"./commands/features/graph.js\";\n98: \n99: import { ensureFeaturesFile } from \"./lib/features.js\";\n100: import type { Priority, Difficulty, FeatureStatus } from \"./lib/features.js\";\n101: import { resolveOutputFormat, type OutputFormat } from \"./lib/output.js\";\n102: import { validateId, validateText, validateBranchName, validateDuration, assertValid } from \"./lib/validate.js\";\n103: import { findCommandDef, commandToSchema, allCommandSchemas } from \"./lib/schema.js\";\n104: \n105: // ---------------------------------------------------------------------------\n106: // Types\n107: // ---------------------------------------------------------------------------\n108: \n109: interface CLIArgs {\n110:   command: string;\n111:   subcommand?: string;\n112:   // Selection options (launch)\n113:   topPriority?: number;\n114:   quickestWins?: number;\n115:   priority?: Priority;\n116:   difficulty?: Difficulty;\n117:   features?: string[];\n118:   allReady?: boolean;\n119:   // Launch / runtime options\n120:   maxConcurrent?: number;\n121:   model?: string;\n122:   interactive: boolean;\n123:   dryRun: boolean;\n124:   baseBranch?: string;\n125:   maxRetries?: number;\n126:   noTui: boolean;\n127:   autoPush: boolean;\n128:   // Abort options\n129:   requeue: boolean;\n130:   // General\n131:   featureId?: string;\n132:   force: boolean;\n133:   // Output format\n134:   outputFmt: OutputFormat;\n135:   // Upgrade options\n136:   checkOnly: boolean;\n137:   version?: string;\n138:   // Features subcommand extras\n139:   status?: string;\n140:   ready?: boolean;\n141:   includeArchive?: boolean;\n142:   title?: string;\n143:   description?: string;\n144:   effort?: string;\n145:   dependsOn?: string[];\n146:   // Logs options\n147:   tail?: number;\n148:   follow?: boolean;\n149:   // Compact output\n150:   fields?: string[];\n151:   // Graph options\n152:   ascii?: boolean;\n153:   mermaidRaw?: boolean;\n154:   graphSubtasks?: boolean;\n155: }\n156: \n157: // ---------------------------------------------------------------------------\n158: // Arg Parsing\n159: // ---------------------------------------------------------------------------\n160: \n161: function parseArgs(argv: string[]): CLIArgs {\n162:   const args = argv.slice(2); // skip 'bun' and script path\n163:   const result: CLIArgs = {\n164:     command: args[0] || \"help\",\n165:     interactive: false,\n166:     dryRun: false,\n167:     noTui: false,\n168:     autoPush: false,\n169:     requeue: false,\n170:     force: false,\n171:     checkOnly: false,\n172:     outputFmt: resolveOutputFormat(undefined), // auto-detect until --output overrides\n173:   };\n174: \n175:   // If the first arg is \"features\", treat the second positional as the subcommand\n176:   let startIdx = 1;\n177:   if (result.command === \"features\") {\n178:     result.subcommand = args[1] || \"list\";\n179:     startIdx = 2;\n180:   }\n181: \n182:   for (let i = startIdx; i < args.length; i++) {\n183:     const arg = args[i];\n184:     switch (arg) {\n185:       // --- Selection options ---\n186:       case \"--top-priority\":\n187:         result.topPriority = parseInt(args[++i], 10);\n188:         break;\n189:       case \"--quickest-wins\":\n190:         result.quickestWins = parseInt(args[++i], 10);\n191:         break;\n192:       case \"--priority\":\n193:         result.priority = args[++i] as Priority;\n194:         break;\n195:       case \"--difficulty\":\n196:         result.difficulty = args[++i] as Difficulty;\n197:         break;\n198:       case \"--features\":\n199:         result.features = args[++i].split(\",\").map((s) => s.trim());\n200:         break;\n201:       case \"--all-ready\":\n202:         result.allReady = true;\n203:         break;\n204: \n205:       // --- Launch / runtime options ---\n206:       case \"--max-concurrent\":\n207:         result.maxConcurrent = parseInt(args[++i], 10);\n208:         break;\n209:       case \"--model\":\n210:       case \"-m\":\n211:         result.model = args[++i];\n212:         break;\n213:       case \"--interactive\":\n214:         result.interactive = true;\n215:         break;\n216:       case \"--dry-run\":\n217:         result.dryRun = true;\n218:         break;\n219:       case \"--no-tui\":\n220:         result.noTui = true;\n221:         break;\n222:       case \"--auto-push\":\n223:         result.autoPush = true;\n224:         break;\n225:       case \"--requeue\":\n226:         result.requeue = true;\n227:         break;\n228:       case \"--base-branch\":\n229:         result.baseBranch = args[++i];\n230:         break;\n231:       case \"--max-retries\":\n232:         result.maxRetries = parseInt(args[++i], 10);\n233:         break;\n234: \n235:       // --- General flags ---\n236:       case \"--force\":\n237:         result.force = true;\n238:         break;\n239:       case \"--check\":\n240:         result.checkOnly = true;\n241:         break;\n242:       case \"--version\":\n243:         result.version = args[++i];\n244:         break;\n245:       case \"--output\":\n246:       case \"-o\":\n247:         result.outputFmt = resolveOutputFormat(args[++i]);\n248:         break;\n249: \n250:       // --- Features subcommand options ---\n251:       case \"--status\":\n252:         result.status = args[++i];\n253:         break;\n254:       case \"--ready\":\n255:         result.ready = true;\n256:         break;\n257:       case \"--include-archive\":\n258:         result.includeArchive = true;\n259:         break;\n260:       case \"--title\":\n261:         result.title = args[++i];\n262:         break;\n263:       case \"--description\":\n264:       case \"--desc\":\n265:         result.description = args[++i];\n266:         break;\n267:       case \"--effort\":\n268:         result.effort = args[++i];\n269:         break;\n270:       case \"--depends-on\":\n271:         result.dependsOn = args[++i].split(\",\").map((s) => s.trim());\n272:         break;\n273:       case \"--fields\":\n274:         result.fields = args[++i].split(\",\").map((s) => s.trim());\n275:         break;\n276: \n277:       // --- Graph options ---\n278:       case \"--ascii\":\n279:         result.ascii = true;\n280:         break;\n281:       case \"--mermaid\":\n282:         result.mermaidRaw = true;\n283:         break;\n284:       case \"--subtasks\":\n285:         result.graphSubtasks = true;\n286:         break;\n287: \n288:       // --- Logs options ---\n289:       case \"--tail\":\n290:         result.tail = parseInt(args[++i], 10);\n291:         break;\n292:       case \"--follow\":\n293:       case \"-f\":\n294:         result.follow = true;\n295:         break;\n296: \n297:       // --- Positional (feature-id, title for add, etc.) ---\n298:       default:\n299:         if (!arg.startsWith(\"-\")) {\n300:           if (!result.featureId) {\n301:             result.featureId = arg;\n302:           } else if (!result.title) {\n303:             result.title = arg;\n304:           }\n305:         }\n306:         break;\n307:     }\n308:   }\n309: \n310:   return result;\n311: }\n312: \n313: // ---------------------------------------------------------------------------\n314: // Help\n315: // ---------------------------------------------------------------------------\n316: \n317: function cmdHelp(): void {\n318:   console.log(`\n319: Wombo — AI Agent Orchestration System\n320: \n321:   WOMBO COMBO! Parallel feature development with AI agents.\n322: \n323: Commands:\n324:   init           Generate wombo.json config in the current project\n325:   launch         Launch a wave of agents to implement features\n326:   resume         Resume a previously stopped wave\n327:   status         Show the status of the current wave\n328:   verify         Run build verification on completed agents\n329:   merge          Merge verified branches into the base branch\n330:   retry          Retry a failed agent\n331:   abort          Kill a single running agent (--requeue to return to queue)\n332:   logs           Pretty-print agent logs for a feature\n333:   cleanup        Remove all wave worktrees and tmux sessions\n334:   features       Manage .features.yml (see below)\n335:   upgrade        Check for updates and upgrade wombo\n336:   describe       Emit JSON schema of a command (for AI agents)\n337:   help           Show this help\n338: \n339: Features Subcommands:\n340:   features list            List features (--status, --priority, --difficulty, --ready, --include-archive)\n341:   features add <id> <title> [options]\n342:                            Add a new feature (--desc, --priority, --difficulty, --effort, --depends-on)\n343:   features set-status <id> <status>\n344:                             Change a feature's status\n345:   features set-priority <id> <priority>\n346:                             Change a feature's priority (critical/high/medium/low/wishlist)\n347:   features set-difficulty <id> <difficulty>\n348:                             Change a feature's difficulty (trivial/easy/medium/hard/very_hard)\n349:   features check           Validate .features.yml (schema, deps, duplicates, cycles)\n350:   features archive [id]    Move done/cancelled to archive (--dry-run)\n351:   features show <id>       Show feature details\n352:   features graph           Visualize dependency graph (--ascii, --mermaid, --subtasks)\n353: \n354: Selection Options (for launch):\n355:   --top-priority N         Select top N features by priority\n356:   --quickest-wins N        Select N features with lowest effort\n357:   --priority <level>       Filter by priority (critical/high/medium/low/wishlist)\n358:   --difficulty <level>     Filter by difficulty (trivial/easy/medium/hard/very_hard)\n359:   --features \"id1,id2\"     Select specific features by ID\n360:   --all-ready              Select all features whose dependencies are met\n361: \n362: Launch Options:\n363:   --max-concurrent N       Max agents running in parallel (default: from config)\n364:   --model <model>          Model to use (e.g., \"anthropic/claude-sonnet-4-20250514\")\n365:   --interactive            Use tmux TUI mode instead of headless\n366:   --no-tui                 Headless mode without neo-blessed TUI (periodic console dashboard)\n367:   --auto-push              Push base branch to remote after all merges complete\n368:   --dry-run                Show what would be launched without launching\n369:   --base-branch <branch>   Base branch (default: from config)\n370:   --max-retries N          Max retries per agent (default: from config)\n371: \n372: General:\n373:   --version, -V            Print version and exit\n374:   --force                  Force overwrite (e.g., for init) / skip prompts (e.g., for upgrade)\n375:   --output <fmt>           Output format: text (default on TTY) or json (default when piped)\n376:   -o <fmt>                 Alias for --output\n377:   --dry-run                Show what would happen without performing the action\n378:   --fields <list>          Comma-separated fields to include (e.g., id,status,priority)\n379: \n380: Upgrade Options:\n381:   --check                  Only check for updates, don't install\n382:   --version <tag>          Install a specific version (e.g., v0.1.0)\n383: \n384: Logs Options:\n385:   --tail N                 Show only the last N lines\n386:   --follow, -f             Stream new output as it arrives (like tail -f)\n387: \n388: Examples:\n389:   wombo init\n390:   wombo launch --quickest-wins 3\n391:   wombo launch --priority high --interactive\n392:   wombo launch --features \"auth-flow,search-api\" --max-concurrent 2\n393:   wombo resume\n394:   wombo status\n395:   wombo verify\n396:   wombo merge\n397:   wombo retry auth-flow\n398:   wombo abort auth-flow\n399:   wombo abort auth-flow --requeue\n400:   wombo abort auth-flow --output json\n401:   wombo logs auth-flow\n402:   wombo logs auth-flow --tail 50\n403:   wombo logs auth-flow --follow\n404:   wombo logs auth-flow --output json\n405:   wombo cleanup\n406:   wombo features list --status ready --priority high\n407:   wombo features list --fields id,status,priority --output json\n408:   wombo features add my-feature \"My Cool Feature\" --priority high --difficulty easy\n409:   wombo features set-status my-feature in-progress\n410:   wombo features check\n411:   wombo features archive --dry-run\n412:   wombo features show my-feature\n413:   wombo describe                           # list all commands as JSON\n414:   wombo describe launch                    # describe a specific command\n415:   wombo describe features add              # describe a subcommand\n416: `);\n417: }\n418: \n419: // ---------------------------------------------------------------------------\n420: // Main\n421: // ---------------------------------------------------------------------------\n422: \n423: async function main(): Promise<void> {\n424:   checkDevModeGuard();\n425: \n426:   const PROJECT_ROOT = resolve(process.cwd());\n427:   const args = parseArgs(process.argv);\n428: \n429:   // -----------------------------------------------------------------------\n430:   // Input validation at the CLI boundary\n431:   // -----------------------------------------------------------------------\n432:   if (args.featureId) {\n433:     assertValid(validateId(args.featureId, \"feature ID\"));\n434:   }\n435:   if (args.title) {\n436:     assertValid(validateText(args.title, \"title\"));\n437:   }\n438:   if (args.description) {\n439:     assertValid(validateText(args.description, \"description\"));\n440:   }\n441:   if (args.baseBranch) {\n442:     assertValid(validateBranchName(args.baseBranch, \"base branch\"));\n443:   }\n444:   if (args.effort) {\n445:     assertValid(validateDuration(args.effort, \"effort\"));\n446:   }\n447:   if (args.features) {\n448:     for (const fid of args.features) {\n449:       assertValid(validateId(fid, \"feature ID in --features\"));\n450:     }\n451:   }\n452:   if (args.dependsOn) {\n453:     for (const dep of args.dependsOn) {\n454:       assertValid(validateId(dep, \"dependency ID in --depends-on\"));\n455:     }\n456:   }\n457: \n458:   // Commands that don't need config loading\n459:   if (args.command === \"--version\" || args.command === \"-V\") {\n460:     const pkgPath = resolve(import.meta.dir, \"..\", \"package.json\");\n461:     const pkgFile = Bun.file(pkgPath);\n462:     try {\n463:       const pkg = await pkgFile.json();\n464:       console.log(`wombo ${pkg.version ?? \"(unknown version)\"}`);\n465:     } catch {\n466:       console.log(\"wombo (unknown version)\");\n467:     }\n468:     return;\n469:   }\n470: \n471:   if (args.command === \"help\" || args.command === \"--help\" || args.command === \"-h\") {\n472:     cmdHelp();\n473:     return;\n474:   }\n475: \n476:   if (args.command === \"describe\") {\n477:     // Schema introspection: `wombo describe [command]`\n478:     if (!args.featureId) {\n479:       // No command specified — list all commands\n480:       console.log(JSON.stringify(allCommandSchemas(), null, 2));\n481:     } else {\n482:       // Describe a specific command. Handle compound names: \"features list\"\n483:       const cmdName = args.title\n484:         ? `${args.featureId} ${args.title}`\n485:         : args.featureId;\n486:       const def = findCommandDef(cmdName);\n487:       if (!def) {\n488:         console.error(`Unknown command: \"${cmdName}\"`);\n489:         console.error(\"Run 'wombo describe' to list all commands.\");\n490:         process.exit(1);\n491:         return;\n492:       }\n493:       console.log(JSON.stringify(commandToSchema(def), null, 2));\n494:     }\n495:     return;\n496:   }\n497: \n498:   if (args.command === \"init\") {\n499:     await cmdInit({ projectRoot: PROJECT_ROOT, force: args.force });\n500:     return;\n501:   }\n502: \n503:   if (args.command === \"upgrade\") {\n504:     await cmdUpgrade({\n505:       force: args.force,\n506:       version: args.version,\n507:       checkOnly: args.checkOnly,\n508:     });\n509:     return;\n510:   }\n511: \n512:   if (args.command === \"logs\") {\n513:     if (!args.featureId) {\n514:       console.error(\"Usage: wombo logs <feature-id> [--tail N] [--follow] [--output json]\");\n515:       process.exit(1);\n516:       return;\n517:     }\n518:     await cmdLogs({\n519:       projectRoot: PROJECT_ROOT,\n520:       featureId: args.featureId,\n521:       tail: args.tail,\n522:       follow: args.follow,\n523:       outputFmt: args.outputFmt,\n524:     });\n525:     return;\n526:   }\n527: \n528:   // Everything else requires config\n529:   const config = loadConfig(PROJECT_ROOT);\n530:   validateConfig(config);\n531: \n532:   // Commands that operate on the features file — ensure it exists first\n533:   const needsFeatures = new Set([\"launch\", \"resume\", \"verify\", \"retry\", \"features\"]);\n534:   if (needsFeatures.has(args.command)) {\n535:     await ensureFeaturesFile(PROJECT_ROOT, config);\n536:   }\n537: \n538:   switch (args.command) {\n539:     case \"launch\":\n540:       await cmdLaunch({\n541:         projectRoot: PROJECT_ROOT,\n542:         config,\n543:         topPriority: args.topPriority,\n544:         quickestWins: args.quickestWins,\n545:         priority: args.priority,\n546:         difficulty: args.difficulty,\n547:         features: args.features,\n548:         allReady: args.allReady,\n549:         maxConcurrent: args.maxConcurrent ?? config.defaults.maxConcurrent,\n550:         model: args.model,\n551:         interactive: args.interactive,\n552:         dryRun: args.dryRun,\n553:         baseBranch: args.baseBranch ?? config.baseBranch,\n554:         maxRetries: args.maxRetries ?? config.defaults.maxRetries,\n555:         noTui: args.noTui,\n556:         autoPush: args.autoPush,\n557:         outputFmt: args.outputFmt,\n558:       });\n559:       break;\n560: \n561:     case \"resume\":\n562:       await cmdResume({\n563:         projectRoot: PROJECT_ROOT,\n564:         config,\n565:         maxConcurrent: args.maxConcurrent,\n566:         model: args.model,\n567:         interactive: args.interactive,\n568:         noTui: args.noTui,\n569:         autoPush: args.autoPush,\n570:         baseBranch: args.baseBranch,\n571:         maxRetries: args.maxRetries,\n572:       });\n573:       break;\n574: \n575:     case \"status\":\n576:       await cmdStatus({ projectRoot: PROJECT_ROOT, config });\n577:       break;\n578: \n579:     case \"verify\":\n580:       await cmdVerify({\n581:         projectRoot: PROJECT_ROOT,\n582:         config,\n583:         featureId: args.featureId,\n584:         model: args.model,\n585:         maxRetries: args.maxRetries,\n586:       });\n587:       break;\n588: \n589:     case \"merge\":\n590:       await cmdMerge({\n591:         projectRoot: PROJECT_ROOT,\n592:         config,\n593:         featureId: args.featureId,\n594:         autoPush: args.autoPush,\n595:         dryRun: args.dryRun,\n596:       });\n597:       break;\n598: \n599:     case \"retry\": {\n600:       if (!args.featureId) {\n601:         console.error(\"Usage: wombo retry <feature-id>\");\n602:         process.exit(1);\n603:         return;\n604:       }\n605:       await cmdRetry({\n606:         projectRoot: PROJECT_ROOT,\n607:         config,\n608:         featureId: args.featureId,\n609:         model: args.model,\n610:         interactive: args.interactive,\n611:         dryRun: args.dryRun,\n612:       });\n613:       break;\n614:     }\n615: \n616:     case \"cleanup\":\n617:       await cmdCleanup({ projectRoot: PROJECT_ROOT, config, dryRun: args.dryRun });\n618:       break;\n619: \n620:     case \"abort\": {\n621:       if (!args.featureId) {\n622:         console.error(\"Usage: wombo abort <feature-id> [--requeue] [--output json]\");\n623:         process.exit(1);\n624:         return;\n625:       }\n626:       await cmdAbort({\n627:         projectRoot: PROJECT_ROOT,\n628:         config,\n629:         featureId: args.featureId,\n630:         requeue: args.requeue,\n631:         outputFmt: args.outputFmt,\n632:       });\n633:       break;\n634:     }\n635: \n636:     case \"features\":\n637:       await handleFeaturesSubcommand(args, PROJECT_ROOT, config);\n638:       break;\n639: \n640:     default:\n641:       console.error(`Unknown command: ${args.command}`);\n642:       cmdHelp();\n643:       process.exit(1);\n644:       return;\n645:   }\n646: }\n647: \n648: // ---------------------------------------------------------------------------\n649: // Features Subcommand Router\n650: // ---------------------------------------------------------------------------\n651: \n652: async function handleFeaturesSubcommand(\n653:   args: CLIArgs,\n654:   projectRoot: string,\n655:   config: import(\"./config.js\").WomboConfig\n656: ): Promise<void> {\n657:   switch (args.subcommand) {\n658:     case \"list\":\n659:     case \"ls\":\n660:       await cmdFeaturesList({\n661:         projectRoot,\n662:         config,\n663:         status: args.status as FeatureStatus | undefined,\n664:         priority: args.priority,\n665:         difficulty: args.difficulty,\n666:         ready: args.ready,\n667:         includeArchive: args.includeArchive,\n668:         outputFmt: args.outputFmt,\n669:         fields: args.fields,\n670:       });\n671:       break;\n672: \n673:     case \"add\": {\n674:       if (!args.featureId || !args.title) {\n675:         console.error(\"Usage: wombo features add <id> <title> [--desc <desc>] [--priority <p>] [--difficulty <d>] [--effort <e>] [--depends-on <ids>]\");\n676:         process.exit(1);\n677:         return;\n678:       }\n679:       await cmdFeaturesAdd({\n680:         projectRoot,\n681:         config,\n682:         id: args.featureId,\n683:         title: args.title,\n684:         description: args.description,\n685:         priority: args.priority,\n686:         difficulty: args.difficulty,\n687:         effort: args.effort,\n688:         dependsOn: args.dependsOn,\n689:         outputFmt: args.outputFmt,\n690:         dryRun: args.dryRun,\n691:       });\n692:       break;\n693:     }\n694: \n695:     case \"set-status\": {\n696:       if (!args.featureId || !args.title) {\n697:         // title holds the second positional arg (the status value)\n698:         // If not provided via positional, check --status flag\n699:         const newStatus = args.title || args.status;\n700:         if (!args.featureId || !newStatus) {\n701:           console.error(\"Usage: wombo features set-status <feature-id> <status>\");\n702:           process.exit(1);\n703:           return;\n704:         }\n705:         await cmdFeaturesSetStatus({\n706:           projectRoot,\n707:           config,\n708:           featureId: args.featureId,\n709:           newStatus,\n710:           outputFmt: args.outputFmt,\n711:           dryRun: args.dryRun,\n712:         });\n713:       } else {\n714:         await cmdFeaturesSetStatus({\n715:           projectRoot,\n716:           config,\n717:           featureId: args.featureId,\n718:           newStatus: args.title, // second positional = new status\n719:           outputFmt: args.outputFmt,\n720:           dryRun: args.dryRun,\n721:         });\n722:       }\n723:       break;\n724:     }\n725: \n726:     case \"set-priority\": {\n727:       if (!args.featureId || !args.title) {\n728:         // title holds the second positional arg (the priority value)\n729:         // If not provided via positional, check --priority flag\n730:         const newPriority = args.title || (args.priority as string | undefined);\n731:         if (!args.featureId || !newPriority) {\n732:           console.error(\"Usage: wombo features set-priority <feature-id> <priority>\");\n733:           process.exit(1);\n734:           return;\n735:         }\n736:         await cmdFeaturesSetPriority({\n737:           projectRoot,\n738:           config,\n739:           featureId: args.featureId,\n740:           newPriority,\n741:           outputFmt: args.outputFmt,\n742:           dryRun: args.dryRun,\n743:         });\n744:       } else {\n745:         await cmdFeaturesSetPriority({\n746:           projectRoot,\n747:           config,\n748:           featureId: args.featureId,\n749:           newPriority: args.title, // second positional = new priority\n750:           outputFmt: args.outputFmt,\n751:           dryRun: args.dryRun,\n752:         });\n753:       }\n754:       break;\n755:     }\n756: \n757:     case \"set-difficulty\": {\n758:       if (!args.featureId || !args.title) {\n759:         // title holds the second positional arg (the difficulty value)\n760:         // If not provided via positional, check --difficulty flag\n761:         const newDifficulty = args.title || (args.difficulty as string | undefined);\n762:         if (!args.featureId || !newDifficulty) {\n763:           console.error(\"Usage: wombo features set-difficulty <feature-id> <difficulty>\");\n764:           process.exit(1);\n765:           return;\n766:         }\n767:         await cmdFeaturesSetDifficulty({\n768:           projectRoot,\n769:           config,\n770:           featureId: args.featureId,\n771:           newDifficulty,\n772:           outputFmt: args.outputFmt,\n773:           dryRun: args.dryRun,\n774:         });\n775:       } else {\n776:         await cmdFeaturesSetDifficulty({\n777:           projectRoot,\n778:           config,\n779:           featureId: args.featureId,\n780:           newDifficulty: args.title, // second positional = new difficulty\n781:           outputFmt: args.outputFmt,\n782:           dryRun: args.dryRun,\n783:         });\n784:       }\n785:       break;\n786:     }\n787: \n788:     case \"check\":\n789:     case \"validate\":\n790:       await cmdFeaturesCheck({ projectRoot, config });\n791:       break;\n792: \n793:     case \"archive\":\n794:       await cmdFeaturesArchive({\n795:         projectRoot,\n796:         config,\n797:         featureId: args.featureId,\n798:         dryRun: args.dryRun,\n799:       });\n800:       break;\n801: \n802:     case \"show\": {\n803:       if (!args.featureId) {\n804:         console.error(\"Usage: wombo features show <feature-id>\");\n805:         process.exit(1);\n806:         return;\n807:       }\n808:       await cmdFeaturesShow({\n809:         projectRoot,\n810:         config,\n811:         featureId: args.featureId,\n812:         outputFmt: args.outputFmt,\n813:         fields: args.fields,\n814:       });\n815:       break;\n816:     }\n817: \n818:     case \"graph\":\n819:       await cmdFeaturesGraph({\n820:         projectRoot,\n821:         config,\n822:         status: args.status as FeatureStatus | undefined,\n823:         ascii: args.ascii,\n824:         mermaid: args.mermaidRaw,\n825:         subtasks: args.graphSubtasks,\n826:         outputFmt: args.outputFmt,\n827:       });\n828:       break;\n829: \n830:     case \"help\":\n831:     case \"--help\":\n832:     case \"-h\":\n833:       cmdHelp();\n834:       break;\n835: \n836:     default:\n837:       console.error(`Unknown features subcommand: ${args.subcommand}`);\n838:       console.error(\"Run 'wombo features help' or 'wombo help' for usage.\");\n839:       process.exit(1);\n840:       return;\n841:   }\n842: }\n843: \n844: // ---------------------------------------------------------------------------\n845: // Error Handlers & Entry\n846: // ---------------------------------------------------------------------------\n847: \n848: // Global error handlers — prevent silent crashes\n849: process.on(\"uncaughtException\", (err) => {\n850:   console.error(`\\n[FATAL] Uncaught exception: ${err.message}`);\n851:   console.error(err.stack);\n852:   try {\n853:     const state = loadState(process.cwd());\n854:     if (state) saveState(process.cwd(), state);\n855:   } catch {}\n856:   process.exit(1);\n857: });\n858: \n859: process.on(\"unhandledRejection\", (reason: any) => {\n860:   console.error(`\\n[FATAL] Unhandled rejection: ${reason?.message || reason}`);\n861:   if (reason?.stack) console.error(reason.stack);\n862:   try {\n863:     const state = loadState(process.cwd());\n864:     if (state) saveState(process.cwd(), state);\n865:   } catch {}\n866:   process.exit(1);\n867: });\n868: \n869: main().catch((err) => {\n870:   console.error(\"Fatal error:\", err.message);\n871:   process.exit(1);\n872: });\n\n(End of file - total 872 lines)\n</content>","title":"src/index.ts","metadata":{"preview":"#!/usr/bin/env bun\n/**\n * index.ts — CLI entry point for the Wombo agent orchestration system.\n *\n * Usage:\n *   wombo init\n *   wombo launch --top-priority 3\n *   wombo launch --quickest-wins 5\n *   wombo launch --priority high\n *   wombo launch --difficulty easy\n *   wombo launch --features \"feat-a,feat-b\"\n *   wombo launch --all-ready\n *   wombo launch ... --max-concurrent 3 --model \"anthropic/claude-sonnet-4-20250514\"\n *   wombo launch ... --interactive\n *   wombo resume\n *   wombo status\n *   wombo verify [feature-id]\n *   wombo merge [feature-id]\n *   wombo retry <feature-id>\n *   wombo abort <feature-id> [--requeue] [--output json]","truncated":false,"loaded":[]},"time":{"start":1773352294715,"end":1773352294718}}}}
{"type":"tool_use","timestamp":1773352295039,"sessionID":"ses_31bfcf566ffeX54k1gNGv0ej46","part":{"id":"prt_ce408993c001vyDd5RdlMW95I7","sessionID":"ses_31bfcf566ffeX54k1gNGv0ej46","messageID":"msg_ce4088ac0001XWOSu8vKbz1VwI","type":"tool","callID":"toolu_vrtx_01VsGyJHuHoNpsi7VpsA3eBa","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-agent-browser-integration/src/lib/schema.ts"},"output":"<path>/home/fulgidus/Documents/wombo-agent-browser-integration/src/lib/schema.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * schema.ts — Declarative command/flag registry for schema introspection.\n3:  *\n4:  * Every command and flag is described in a single registry. This registry is\n5:  * the source of truth for:\n6:  *   1. `wombo describe <command>` — emits a JSON schema of accepted args\n7:  *   2. Future help text generation\n8:  *\n9:  * The registry is NOT used for actual arg parsing (that's still the hand-rolled\n10:  * switch in index.ts), but the two must stay in sync. If they drift, `wombo\n11:  * features check` should eventually catch it.\n12:  */\n13: \n14: // ---------------------------------------------------------------------------\n15: // Types\n16: // ---------------------------------------------------------------------------\n17: \n18: export interface FlagDef {\n19:   /** Primary flag name, e.g. \"--dry-run\" */\n20:   name: string;\n21:   /** Short alias, e.g. \"-o\" */\n22:   alias?: string;\n23:   /** Description shown in help / schema */\n24:   description: string;\n25:   /** Type of the value: \"boolean\" flags take no value, others consume next arg */\n26:   type: \"string\" | \"number\" | \"boolean\" | \"string[]\";\n27:   /** Default value (undefined = required or absent) */\n28:   default?: unknown;\n29:   /** For enum-like flags, the set of allowed values */\n30:   enum?: readonly string[];\n31:   /** If true, this flag is required */\n32:   required?: boolean;\n33: }\n34: \n35: export interface PositionalDef {\n36:   /** Name used in usage strings, e.g. \"feature-id\" */\n37:   name: string;\n38:   description: string;\n39:   required?: boolean;\n40: }\n41: \n42: export interface CommandDef {\n43:   /** Command name as typed by the user, e.g. \"launch\" or \"features list\" */\n44:   name: string;\n45:   /** One-line summary */\n46:   summary: string;\n47:   /** Longer description */\n48:   description?: string;\n49:   /** Positional arguments */\n50:   positionals: PositionalDef[];\n51:   /** Named flags */\n52:   flags: FlagDef[];\n53:   /** Whether this command mutates state (used for dry-run indication) */\n54:   mutating: boolean;\n55:   /** Whether this command supports --dry-run */\n56:   supportsDryRun: boolean;\n57:   /** Subcommands (for \"features\" parent) */\n58:   subcommands?: CommandDef[];\n59: }\n60: \n61: // ---------------------------------------------------------------------------\n62: // Global flags (available on every command)\n63: // ---------------------------------------------------------------------------\n64: \n65: const GLOBAL_FLAGS: FlagDef[] = [\n66:   {\n67:     name: \"--output\",\n68:     alias: \"-o\",\n69:     description: \"Output format: text (default) or json\",\n70:     type: \"string\",\n71:     default: \"text\",\n72:     enum: [\"text\", \"json\"],\n73:   },\n74:   {\n75:     name: \"--force\",\n76:     description: \"Force overwrite / skip safety prompts\",\n77:     type: \"boolean\",\n78:     default: false,\n79:   },\n80: ];\n81: \n82: // ---------------------------------------------------------------------------\n83: // Command Registry\n84: // ---------------------------------------------------------------------------\n85: \n86: export const COMMAND_REGISTRY: CommandDef[] = [\n87:   // --- init ---------------------------------------------------------------\n88:   {\n89:     name: \"init\",\n90:     summary: \"Generate wombo.json config in the current project\",\n91:     description:\n92:       \"Interactive guided setup that walks through every config section. \" +\n93:       \"Creates wombo.json and .features.yml from template.\",\n94:     positionals: [],\n95:     flags: [\n96:       {\n97:         name: \"--force\",\n98:         description: \"Overwrite existing config files\",\n99:         type: \"boolean\",\n100:         default: false,\n101:       },\n102:       {\n103:         name: \"--dry-run\",\n104:         description: \"Show what would be created without writing files\",\n105:         type: \"boolean\",\n106:         default: false,\n107:       },\n108:     ],\n109:     mutating: true,\n110:     supportsDryRun: true,\n111:   },\n112: \n113:   // --- launch -------------------------------------------------------------\n114:   {\n115:     name: \"launch\",\n116:     summary: \"Launch a wave of agents to implement features\",\n117:     description:\n118:       \"Select features from .features.yml, create worktrees, and spawn agents. \" +\n119:       \"Supports multiple selection strategies.\",\n120:     positionals: [],\n121:     flags: [\n122:       { name: \"--top-priority\", description: \"Select top N features by priority\", type: \"number\" },\n123:       { name: \"--quickest-wins\", description: \"Select N features with lowest effort\", type: \"number\" },\n124:       { name: \"--priority\", description: \"Filter by priority level\", type: \"string\", enum: [\"critical\", \"high\", \"medium\", \"low\", \"wishlist\"] },\n125:       { name: \"--difficulty\", description: \"Filter by difficulty level\", type: \"string\", enum: [\"trivial\", \"easy\", \"medium\", \"hard\", \"very_hard\"] },\n126:       { name: \"--features\", description: \"Select specific features by comma-separated IDs\", type: \"string\" },\n127:       { name: \"--all-ready\", description: \"Select all features whose dependencies are met\", type: \"boolean\", default: false },\n128:       { name: \"--max-concurrent\", description: \"Max agents running in parallel\", type: \"number\" },\n129:       { name: \"--model\", alias: \"-m\", description: \"Model to use (e.g., anthropic/claude-sonnet-4-20250514)\", type: \"string\" },\n130:       { name: \"--interactive\", description: \"Use tmux TUI mode instead of headless\", type: \"boolean\", default: false },\n131:       { name: \"--no-tui\", description: \"Headless mode without neo-blessed TUI\", type: \"boolean\", default: false },\n132:       { name: \"--auto-push\", description: \"Push base branch to remote after all merges\", type: \"boolean\", default: false },\n133:       { name: \"--dry-run\", description: \"Show what would be launched without launching\", type: \"boolean\", default: false },\n134:       { name: \"--base-branch\", description: \"Base branch (default: from config)\", type: \"string\" },\n135:       { name: \"--max-retries\", description: \"Max retries per agent\", type: \"number\" },\n136:     ],\n137:     mutating: true,\n138:     supportsDryRun: true,\n139:   },\n140: \n141:   // --- resume -------------------------------------------------------------\n142:   {\n143:     name: \"resume\",\n144:     summary: \"Resume a previously stopped wave\",\n145:     positionals: [],\n146:     flags: [\n147:       { name: \"--max-concurrent\", description: \"Max agents running in parallel\", type: \"number\" },\n148:       { name: \"--model\", alias: \"-m\", description: \"Model to use\", type: \"string\" },\n149:       { name: \"--interactive\", description: \"Use tmux TUI mode\", type: \"boolean\", default: false },\n150:       { name: \"--no-tui\", description: \"Headless mode without neo-blessed TUI\", type: \"boolean\", default: false },\n151:       { name: \"--auto-push\", description: \"Push base branch to remote after merges\", type: \"boolean\", default: false },\n152:       { name: \"--base-branch\", description: \"Base branch override\", type: \"string\" },\n153:       { name: \"--max-retries\", description: \"Max retries per agent\", type: \"number\" },\n154:     ],\n155:     mutating: true,\n156:     supportsDryRun: false,\n157:   },\n158: \n159:   // --- status -------------------------------------------------------------\n160:   {\n161:     name: \"status\",\n162:     summary: \"Show the status of the current wave\",\n163:     positionals: [],\n164:     flags: [],\n165:     mutating: false,\n166:     supportsDryRun: false,\n167:   },\n168: \n169:   // --- verify -------------------------------------------------------------\n170:   {\n171:     name: \"verify\",\n172:     summary: \"Run build verification on completed agents\",\n173:     positionals: [\n174:       { name: \"feature-id\", description: \"Specific feature to verify (optional)\", required: false },\n175:     ],\n176:     flags: [\n177:       { name: \"--model\", alias: \"-m\", description: \"Model to use for verification\", type: \"string\" },\n178:       { name: \"--max-retries\", description: \"Max retries\", type: \"number\" },\n179:     ],\n180:     mutating: true,\n181:     supportsDryRun: false,\n182:   },\n183: \n184:   // --- merge --------------------------------------------------------------\n185:   {\n186:     name: \"merge\",\n187:     summary: \"Merge verified branches into the base branch\",\n188:     positionals: [\n189:       { name: \"feature-id\", description: \"Specific feature to merge (optional)\", required: false },\n190:     ],\n191:     flags: [\n192:       { name: \"--auto-push\", description: \"Push base branch to remote after merge\", type: \"boolean\", default: false },\n193:       { name: \"--dry-run\", description: \"Show what would be merged without merging\", type: \"boolean\", default: false },\n194:     ],\n195:     mutating: true,\n196:     supportsDryRun: true,\n197:   },\n198: \n199:   // --- retry --------------------------------------------------------------\n200:   {\n201:     name: \"retry\",\n202:     summary: \"Retry a failed agent\",\n203:     positionals: [\n204:       { name: \"feature-id\", description: \"Feature ID of the failed agent\", required: true },\n205:     ],\n206:     flags: [\n207:       { name: \"--model\", alias: \"-m\", description: \"Model to use\", type: \"string\" },\n208:       { name: \"--interactive\", description: \"Use tmux TUI mode\", type: \"boolean\", default: false },\n209:       { name: \"--dry-run\", description: \"Show what would be retried without retrying\", type: \"boolean\", default: false },\n210:     ],\n211:     mutating: true,\n212:     supportsDryRun: true,\n213:   },\n214: \n215:   // --- cleanup ------------------------------------------------------------\n216:   {\n217:     name: \"cleanup\",\n218:     summary: \"Remove all wave worktrees and tmux sessions\",\n219:     description: \"Kills tmux sessions, removes worktrees, removes state and log files.\",\n220:     positionals: [],\n221:     flags: [\n222:       { name: \"--dry-run\", description: \"Show what would be cleaned up without removing\", type: \"boolean\", default: false },\n223:     ],\n224:     mutating: true,\n225:     supportsDryRun: true,\n226:   },\n227: \n228:   // --- abort --------------------------------------------------------------\n229:   {\n230:     name: \"abort\",\n231:     summary: \"Kill a single running agent without affecting the rest of the wave\",\n232:     description:\n233:       \"Kills the tmux session and agent process for a specific feature, then \" +\n234:       \"marks the agent as failed. Use --requeue to return the feature to the \" +\n235:       \"queue instead of marking it failed.\",\n236:     positionals: [\n237:       { name: \"feature-id\", description: \"Feature ID of the agent to abort\", required: true },\n238:     ],\n239:     flags: [\n240:       { name: \"--requeue\", description: \"Return the feature to queued instead of marking it failed\", type: \"boolean\", default: false },\n241:     ],\n242:     mutating: true,\n243:     supportsDryRun: false,\n244:   },\n245: \n246:   // --- upgrade ------------------------------------------------------------\n247:   {\n248:     name: \"upgrade\",\n249:     summary: \"Check for updates and upgrade wombo\",\n250:     positionals: [],\n251:     flags: [\n252:       { name: \"--check\", description: \"Only check for updates, don't install\", type: \"boolean\", default: false },\n253:       { name: \"--version\", description: \"Install a specific version (e.g., v0.1.0)\", type: \"string\" },\n254:       { name: \"--force\", description: \"Force reinstall even if up to date\", type: \"boolean\", default: false },\n255:     ],\n256:     mutating: true,\n257:     supportsDryRun: false,\n258:   },\n259: \n260:   // --- logs ---------------------------------------------------------------\n261:   {\n262:     name: \"logs\",\n263:     summary: \"Pretty-print agent logs from .wombo-logs/<feature-id>.log\",\n264:     description:\n265:       \"Reads log files written by agents during headless runs and displays \" +\n266:       \"them with colorized output. Supports tailing and following.\",\n267:     positionals: [\n268:       { name: \"feature-id\", description: \"Feature ID whose logs to display\", required: true },\n269:     ],\n270:     flags: [\n271:       { name: \"--tail\", description: \"Show only the last N lines\", type: \"number\" },\n272:       { name: \"--follow\", alias: \"-f\", description: \"Stream new output as it arrives (like tail -f)\", type: \"boolean\", default: false },\n273:     ],\n274:     mutating: false,\n275:     supportsDryRun: false,\n276:   },\n277: \n278:   // --- features (parent with subcommands) ---------------------------------\n279:   {\n280:     name: \"features\",\n281:     summary: \"Manage .features.yml\",\n282:     positionals: [],\n283:     flags: [],\n284:     mutating: false,\n285:     supportsDryRun: false,\n286:     subcommands: [\n287:       {\n288:         name: \"features list\",\n289:         summary: \"List features with optional filtering\",\n290:         positionals: [],\n291:         flags: [\n292:           { name: \"--status\", description: \"Filter by status\", type: \"string\", enum: [\"backlog\", \"planned\", \"in_progress\", \"blocked\", \"in_review\", \"done\", \"cancelled\"] },\n293:           { name: \"--priority\", description: \"Filter by priority\", type: \"string\", enum: [\"critical\", \"high\", \"medium\", \"low\", \"wishlist\"] },\n294:           { name: \"--difficulty\", description: \"Filter by difficulty\", type: \"string\", enum: [\"trivial\", \"easy\", \"medium\", \"hard\", \"very_hard\"] },\n295:           { name: \"--ready\", description: \"Show only ready features (backlog + deps met)\", type: \"boolean\", default: false },\n296:           { name: \"--include-archive\", description: \"Include archived features\", type: \"boolean\", default: false },\n297:           { name: \"--fields\", description: \"Comma-separated list of fields to include in output\", type: \"string\" },\n298:         ],\n299:         mutating: false,\n300:         supportsDryRun: false,\n301:       },\n302:       {\n303:         name: \"features add\",\n304:         summary: \"Add a new feature\",\n305:         positionals: [\n306:           { name: \"id\", description: \"Feature ID (kebab-case)\", required: true },\n307:           { name: \"title\", description: \"Feature title\", required: true },\n308:         ],\n309:         flags: [\n310:           { name: \"--description\", alias: \"--desc\", description: \"Feature description\", type: \"string\" },\n311:           { name: \"--priority\", description: \"Priority level\", type: \"string\", default: \"medium\", enum: [\"critical\", \"high\", \"medium\", \"low\", \"wishlist\"] },\n312:           { name: \"--difficulty\", description: \"Difficulty level\", type: \"string\", default: \"medium\", enum: [\"trivial\", \"easy\", \"medium\", \"hard\", \"very_hard\"] },\n313:           { name: \"--effort\", description: \"Effort estimate (ISO 8601 duration, e.g. PT2H)\", type: \"string\", default: \"PT1H\" },\n314:           { name: \"--depends-on\", description: \"Comma-separated dependency IDs\", type: \"string\" },\n315:           { name: \"--dry-run\", description: \"Show what would be added without writing\", type: \"boolean\", default: false },\n316:         ],\n317:         mutating: true,\n318:         supportsDryRun: true,\n319:       },\n320:       {\n321:         name: \"features set-status\",\n322:         summary: \"Change a feature's status\",\n323:         positionals: [\n324:           { name: \"feature-id\", description: \"Feature ID to update\", required: true },\n325:           { name: \"status\", description: \"New status value\", required: true },\n326:         ],\n327:         flags: [\n328:           { name: \"--dry-run\", description: \"Show what would change without writing\", type: \"boolean\", default: false },\n329:         ],\n330:         mutating: true,\n331:         supportsDryRun: true,\n332:       },\n333:       {\n334:         name: \"features set-priority\",\n335:         summary: \"Change a feature's priority\",\n336:         positionals: [\n337:           { name: \"feature-id\", description: \"Feature ID to update\", required: true },\n338:           { name: \"priority\", description: \"New priority value\", required: true },\n339:         ],\n340:         flags: [\n341:           { name: \"--dry-run\", description: \"Show what would change without writing\", type: \"boolean\", default: false },\n342:         ],\n343:         mutating: true,\n344:         supportsDryRun: true,\n345:       },\n346:       {\n347:         name: \"features set-difficulty\",\n348:         summary: \"Change a feature's difficulty\",\n349:         positionals: [\n350:           { name: \"feature-id\", description: \"Feature ID to update\", required: true },\n351:           { name: \"difficulty\", description: \"New difficulty value\", required: true },\n352:         ],\n353:         flags: [\n354:           { name: \"--dry-run\", description: \"Show what would change without writing\", type: \"boolean\", default: false },\n355:         ],\n356:         mutating: true,\n357:         supportsDryRun: true,\n358:       },\n359:       {\n360:         name: \"features check\",\n361:         summary: \"Validate .features.yml (schema, deps, duplicates, cycles)\",\n362:         positionals: [],\n363:         flags: [],\n364:         mutating: false,\n365:         supportsDryRun: false,\n366:       },\n367:       {\n368:         name: \"features archive\",\n369:         summary: \"Move done/cancelled features to archive section\",\n370:         positionals: [\n371:           { name: \"feature-id\", description: \"Specific feature to archive (optional)\", required: false },\n372:         ],\n373:         flags: [\n374:           { name: \"--dry-run\", description: \"Show what would be archived without moving\", type: \"boolean\", default: false },\n375:         ],\n376:         mutating: true,\n377:         supportsDryRun: true,\n378:       },\n379:       {\n380:         name: \"features show\",\n381:         summary: \"Show detailed information about a specific feature\",\n382:         positionals: [\n383:           { name: \"feature-id\", description: \"Feature ID to display\", required: true },\n384:         ],\n385:         flags: [\n386:           { name: \"--fields\", description: \"Comma-separated list of fields to include in output\", type: \"string\" },\n387:         ],\n388:         mutating: false,\n389:         supportsDryRun: false,\n390:       },\n391:       {\n392:         name: \"features graph\",\n393:         summary: \"Visualize the feature dependency graph as a terminal diagram\",\n394:         description:\n395:           \"Builds a Mermaid flowchart from the features dependency graph and renders \" +\n396:           \"it as a Unicode box diagram. Shows dependency edges, status badges, orphan \" +\n397:           \"detection, dangling dependency warnings, and cycle detection.\",\n398:         positionals: [],\n399:         flags: [\n400:           { name: \"--status\", description: \"Filter graph to features with this status\", type: \"string\", enum: [\"backlog\", \"planned\", \"in_progress\", \"blocked\", \"in_review\", \"done\", \"cancelled\"] },\n401:           { name: \"--ascii\", description: \"Use ASCII-only rendering (no Unicode box chars)\", type: \"boolean\", default: false },\n402:           { name: \"--mermaid\", description: \"Emit raw Mermaid source instead of rendered graph\", type: \"boolean\", default: false },\n403:           { name: \"--subtasks\", description: \"Include subtask-level nodes in the graph\", type: \"boolean\", default: false },\n404:         ],\n405:         mutating: false,\n406:         supportsDryRun: false,\n407:       },\n408:     ],\n409:   },\n410: \n411:   // --- help ---------------------------------------------------------------\n412:   {\n413:     name: \"help\",\n414:     summary: \"Show help text\",\n415:     positionals: [],\n416:     flags: [],\n417:     mutating: false,\n418:     supportsDryRun: false,\n419:   },\n420: \n421:   // --- describe -----------------------------------------------------------\n422:   {\n423:     name: \"describe\",\n424:     summary: \"Emit JSON schema of a command's arguments and flags\",\n425:     description:\n426:       \"Machine-readable introspection for AI agents. Outputs the accepted \" +\n427:       \"positionals, flags, types, defaults, and constraints for a command.\",\n428:     positionals: [\n429:       { name: \"command\", description: \"Command to describe (e.g. 'launch', 'features add')\", required: false },\n430:     ],\n431:     flags: [],\n432:     mutating: false,\n433:     supportsDryRun: false,\n434:   },\n435: ];\n436: \n437: // ---------------------------------------------------------------------------\n438: // Lookup helpers\n439: // ---------------------------------------------------------------------------\n440: \n441: /**\n442:  * Find a command definition by name. Supports compound names like \"features list\".\n443:  */\n444: export function findCommandDef(name: string): CommandDef | undefined {\n445:   // Try direct match first\n446:   const direct = COMMAND_REGISTRY.find((c) => c.name === name);\n447:   if (direct) return direct;\n448: \n449:   // Try compound: \"features list\" -> look in features subcommands\n450:   const parts = name.split(/\\s+/);\n451:   if (parts.length === 2) {\n452:     const parent = COMMAND_REGISTRY.find((c) => c.name === parts[0]);\n453:     if (parent?.subcommands) {\n454:       return parent.subcommands.find((sc) => sc.name === name || sc.name === parts[1]);\n455:     }\n456:   }\n457: \n458:   return undefined;\n459: }\n460: \n461: /**\n462:  * Produce the JSON schema object for a command, suitable for agent consumption.\n463:  */\n464: export function commandToSchema(cmd: CommandDef): Record<string, unknown> {\n465:   const schema: Record<string, unknown> = {\n466:     command: cmd.name,\n467:     summary: cmd.summary,\n468:     mutating: cmd.mutating,\n469:     supports_dry_run: cmd.supportsDryRun,\n470:   };\n471: \n472:   if (cmd.description) {\n473:     schema.description = cmd.description;\n474:   }\n475: \n476:   if (cmd.positionals.length > 0) {\n477:     schema.positionals = cmd.positionals.map((p) => ({\n478:       name: p.name,\n479:       description: p.description,\n480:       required: p.required ?? false,\n481:     }));\n482:   }\n483: \n484:   const allFlags = [...cmd.flags, ...GLOBAL_FLAGS];\n485:   schema.flags = allFlags.map((f) => {\n486:     const entry: Record<string, unknown> = {\n487:       name: f.name,\n488:       type: f.type,\n489:       description: f.description,\n490:     };\n491:     if (f.alias) entry.alias = f.alias;\n492:     if (f.default !== undefined) entry.default = f.default;\n493:     if (f.enum) entry.enum = f.enum;\n494:     if (f.required) entry.required = true;\n495:     return entry;\n496:   });\n497: \n498:   if (cmd.subcommands?.length) {\n499:     schema.subcommands = cmd.subcommands.map((sc) => sc.name);\n500:   }\n501: \n502:   return schema;\n503: }\n504: \n505: /**\n506:  * Produce a listing of all commands (for `wombo describe` with no args).\n507:  */\n508: export function allCommandSchemas(): Record<string, unknown> {\n509:   const commands: Record<string, unknown>[] = [];\n510: \n511:   for (const cmd of COMMAND_REGISTRY) {\n512:     const entry: Record<string, unknown> = {\n513:       name: cmd.name,\n514:       summary: cmd.summary,\n515:       mutating: cmd.mutating,\n516:       supports_dry_run: cmd.supportsDryRun,\n517:     };\n518:     if (cmd.subcommands) {\n519:       entry.subcommands = cmd.subcommands.map((sc) => ({\n520:         name: sc.name,\n521:         summary: sc.summary,\n522:         mutating: sc.mutating,\n523:         supports_dry_run: sc.supportsDryRun,\n524:       }));\n525:     }\n526:     commands.push(entry);\n527:   }\n528: \n529:   return {\n530:     tool: \"wombo\",\n531:     version: \"0.0.2\",\n532:     global_flags: GLOBAL_FLAGS.map((f) => ({\n533:       name: f.name,\n534:       alias: f.alias,\n535:       type: f.type,\n536:       description: f.description,\n537:       default: f.default,\n538:     })),\n539:     commands,\n540:   };\n541: }\n\n(End of file - total 541 lines)\n</content>","title":"src/lib/schema.ts","metadata":{"preview":"/**\n * schema.ts — Declarative command/flag registry for schema introspection.\n *\n * Every command and flag is described in a single registry. This registry is\n * the source of truth for:\n *   1. `wombo describe <command>` — emits a JSON schema of accepted args\n *   2. Future help text generation\n *\n * The registry is NOT used for actual arg parsing (that's still the hand-rolled\n * switch in index.ts), but the two must stay in sync. If they drift, `wombo\n * features check` should eventually catch it.\n */\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface FlagDef {\n  /** Primary flag name, e.g. \"--dry-run\" */\n  name: string;","truncated":false,"loaded":[]},"time":{"start":1773352295035,"end":1773352295038}}}}
