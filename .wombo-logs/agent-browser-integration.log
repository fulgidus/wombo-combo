rgs.dryRun,\n596:       });\n597:       break;\n598: \n599:     case \"retry\": {\n600:       if (!args.featureId) {\n601:         console.error(\"Usage: wombo retry <feature-id>\");\n602:         process.exit(1);\n603:         return;\n604:       }\n605:       await cmdRetry({\n606:         projectRoot: PROJECT_ROOT,\n607:         config,\n608:         featureId: args.featureId,\n609:         model: args.model,\n610:         interactive: args.interactive,\n611:         dryRun: args.dryRun,\n612:       });\n613:       break;\n614:     }\n615: \n616:     case \"cleanup\":\n617:       await cmdCleanup({ projectRoot: PROJECT_ROOT, config, dryRun: args.dryRun });\n618:       break;\n619: \n620:     case \"abort\": {\n621:       if (!args.featureId) {\n622:         console.error(\"Usage: wombo abort <feature-id> [--requeue] [--output json]\");\n623:         process.exit(1);\n624:         return;\n625:       }\n626:       await cmdAbort({\n627:         projectRoot: PROJECT_ROOT,\n628:         config,\n629:         featureId: args.featureId,\n630:         requeue: args.requeue,\n631:         outputFmt: args.outputFmt,\n632:       });\n633:       break;\n634:     }\n635: \n636:     case \"features\":\n637:       await handleFeaturesSubcommand(args, PROJECT_ROOT, config);\n638:       break;\n639: \n640:     default:\n641:       console.error(`Unknown command: ${args.command}`);\n642:       cmdHelp();\n643:       process.exit(1);\n644:       return;\n645:   }\n646: }\n647: \n648: // ---------------------------------------------------------------------------\n649: // Features Subcommand Router\n650: // ---------------------------------------------------------------------------\n651: \n652: async function handleFeaturesSubcommand(\n653:   args: CLIArgs,\n654:   projectRoot: string,\n655:   config: import(\"./config.js\").WomboConfig\n656: ): Promise<void> {\n657:   switch (args.subcommand) {\n658:     case \"list\":\n659:     case \"ls\":\n660:       await cmdFeaturesList({\n661:         projectRoot,\n662:         config,\n663:         status: args.status as FeatureStatus | undefined,\n664:         priority: args.priority,\n665:         difficulty: args.difficulty,\n666:         ready: args.ready,\n667:         includeArchive: args.includeArchive,\n668:         outputFmt: args.outputFmt,\n669:         fields: args.fields,\n670:       });\n671:       break;\n672: \n673:     case \"add\": {\n674:       if (!args.featureId || !args.title) {\n675:         console.error(\"Usage: wombo features add <id> <title> [--desc <desc>] [--priority <p>] [--difficulty <d>] [--effort <e>] [--depends-on <ids>]\");\n676:         process.exit(1);\n677:         return;\n678:       }\n679:       await cmdFeaturesAdd({\n680:         projectRoot,\n681:         config,\n682:         id: args.featureId,\n683:         title: args.title,\n684:         description: args.description,\n685:         priority: args.priority,\n686:         difficulty: args.difficulty,\n687:         effort: args.effort,\n688:         dependsOn: args.dependsOn,\n689:         outputFmt: args.outputFmt,\n690:         dryRun: args.dryRun,\n691:       });\n692:       break;\n693:     }\n694: \n695:     case \"set-status\": {\n696:       if (!args.featureId || !args.title) {\n697:         // title holds the second positional arg (the status value)\n698:         // If not provided via positional, check --status flag\n699:         const newStatus = args.title || args.status;\n700:         if (!args.featureId || !newStatus) {\n701:           console.error(\"Usage: wombo features set-status <feature-id> <status>\");\n702:           process.exit(1);\n703:           return;\n704:         }\n705:         await cmdFeaturesSetStatus({\n706:           projectRoot,\n707:           config,\n708:           featureId: args.featureId,\n709:           newStatus,\n710:           outputFmt: args.outputFmt,\n711:           dryRun: args.dryRun,\n712:         });\n713:       } else {\n714:         await cmdFeaturesSe