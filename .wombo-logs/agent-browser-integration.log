{"type":"tool_use","timestamp":1773351957381,"sessionID":"ses_31bfcf566ffeX54k1gNGv0ej46","part":{"id":"prt_ce403720a001ZamsIvq7Pb5iNk","sessionID":"ses_31bfcf566ffeX54k1gNGv0ej46","messageID":"msg_ce40363fe001yxeSfJhzNGr7rt","type":"tool","callID":"toolu_vrtx_01YGoDearasSvTChMeonQLqA","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-agent-browser-integration/src/lib/worktree.ts"},"output":"<path>/home/fulgidus/Documents/wombo-agent-browser-integration/src/lib/worktree.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * worktree.ts — Git worktree lifecycle management.\n3:  *\n4:  * Responsibilities:\n5:  *   - Create feature branches from a base branch\n6:  *   - Create git worktrees for each feature branch\n7:  *   - Run install command in worktrees\n8:  *   - List and remove worktrees\n9:  *   - Copy agent config files into worktrees\n10:  *\n11:  * IMPORTANT: Heavy operations (createWorktree, installDeps) are async\n12:  * to allow true parallelism with Promise.all.\n13:  */\n14: \n15: import { exec, execSync } from \"node:child_process\";\n16: import { existsSync, cpSync, statSync } from \"node:fs\";\n17: import { resolve, dirname, basename } from \"node:path\";\n18: import type { WomboConfig } from \"../config.js\";\n19: \n20: // ---------------------------------------------------------------------------\n21: // Types\n22: // ---------------------------------------------------------------------------\n23: \n24: export interface WorktreeInfo {\n25:   path: string;\n26:   branch: string;\n27:   head: string;\n28:   bare: boolean;\n29: }\n30: \n31: // ---------------------------------------------------------------------------\n32: // Diagnostic Logger\n33: // ---------------------------------------------------------------------------\n34: \n35: function ts(): string {\n36:   return new Date().toISOString().slice(11, 19); // HH:MM:SS\n37: }\n38: \n39: export function log(featureId: string, msg: string): void {\n40:   console.log(`  [${ts()}] ${featureId}: ${msg}`);\n41: }\n42: \n43: // ---------------------------------------------------------------------------\n44: // Async Command Runner\n45: // ---------------------------------------------------------------------------\n46: \n47: /**\n48:  * Run a command asynchronously. Returns stdout on success, throws on failure.\n49:  */\n50: function runAsync(\n51:   cmd: string,\n52:   opts?: { cwd?: string; timeoutMs?: number }\n53: ): Promise<string> {\n54:   return new Promise((resolve, reject) => {\n55:     exec(\n56:       cmd,\n57:       {\n58:         cwd: opts?.cwd,\n59:         encoding: \"utf-8\",\n60:         timeout: opts?.timeoutMs ?? 0,\n61:         maxBuffer: 10 * 1024 * 1024,\n62:       },\n63:       (error, stdout, stderr) => {\n64:         if (error) {\n65:           const errMsg = stderr?.trim() || stdout?.trim() || error.message;\n66:           reject(new Error(`Command failed: ${cmd}\\n${errMsg}`));\n67:         } else {\n68:           resolve((stdout ?? \"\").trim());\n69:         }\n70:       }\n71:     );\n72:   });\n73: }\n74: \n75: /**\n76:  * Synchronous run — only for quick, non-blocking operations.\n77:  */\n78: function runSync(\n79:   cmd: string,\n80:   opts?: { cwd?: string; silent?: boolean; timeoutMs?: number }\n81: ): string {\n82:   try {\n83:     return execSync(cmd, {\n84:       cwd: opts?.cwd,\n85:       encoding: \"utf-8\",\n86:       stdio: opts?.silent ? \"pipe\" : [\"pipe\", \"pipe\", \"pipe\"],\n87:       timeout: opts?.timeoutMs,\n88:       maxBuffer: 10 * 1024 * 1024,\n89:     }).trim();\n90:   } catch (err: any) {\n91:     const stderr = err.stderr?.toString().trim() || \"\";\n92:     const stdout = err.stdout?.toString().trim() || \"\";\n93:     throw new Error(\n94:       `Command failed: ${cmd}\\n${stderr || stdout || err.message}`\n95:     );\n96:   }\n97: }\n98: \n99: // ---------------------------------------------------------------------------\n100: // Branch Management\n101: // ---------------------------------------------------------------------------\n102: \n103: /**\n104:  * Create a feature branch from the base branch.\n105:  * If it already exists and is NOT checked out in a worktree, reset it.\n106:  * If it's checked out in a worktree, leave it alone (resume case).\n107:  */\n108: async function createBranch(\n109:   projectRoot: string,\n110:   branchName: string,\n111:   baseBranch: string\n112: ): Promise<void> {\n113:   const existing = await runAsync(\n114:     `git branch --list \"${branchName}\"`,\n115:     { cwd: projectRoot }\n116:   );\n117:   if (existing.trim()) {\n118:     // Branch exists — try to delete and recreate.\n119:     // If deletion fails (e.g. checked out in worktree), that's fine —\n120:     // we'll reuse the existing branch with its work intact.\n121:     try {\n122:       await runAsync(`git branch -D \"${branchName}\"`, { cwd: projectRoot });\n123:     } catch {\n124:       // Branch is checked out in a worktree — reuse as-is\n125:       return;\n126:     }\n127:   }\n128:   await runAsync(`git branch \"${branchName}\" \"${baseBranch}\"`, {\n129:     cwd: projectRoot,\n130:   });\n131: }\n132: \n133: /**\n134:  * Generate the branch name for a feature using config prefix.\n135:  */\n136: export function featureBranchName(\n137:   featureId: string,\n138:   config: WomboConfig\n139: ): string {\n140:   return `${config.git.branchPrefix}${featureId}`;\n141: }\n142: \n143: /**\n144:  * Generate the worktree path for a feature (sibling directory to project root).\n145:  */\n146: export function worktreePath(\n147:   projectRoot: string,\n148:   featureId: string,\n149:   config: WomboConfig\n150: ): string {\n151:   const parentDir = dirname(projectRoot);\n152:   return resolve(parentDir, `${config.git.worktreePrefix}${featureId}`);\n153: }\n154: \n155: // ---------------------------------------------------------------------------\n156: // Worktree Lifecycle (async)\n157: // ---------------------------------------------------------------------------\n158: \n159: /**\n160:  * Create a git worktree for a feature branch.\n161:  * Returns the absolute path to the worktree.\n162:  *\n163:  * If a valid worktree already exists at the expected path (has .git file),\n164:  * reuses it — this is essential for the resume case where worktrees have\n165:  * real work but may be missing node_modules.\n166:  */\n167: export async function createWorktree(\n168:   projectRoot: string,\n169:   featureId: string,\n170:   baseBranch: string,\n171:   config: WomboConfig\n172: ): Promise<string> {\n173:   const branch = featureBranchName(featureId, config);\n174:   const wtPath = worktreePath(projectRoot, featureId, config);\n175: \n176:   // If a valid worktree already exists, reuse it (resume case).\n177:   // A git worktree has a .git *file* (not directory) pointing to the main repo.\n178:   if (existsSync(wtPath) && existsSync(resolve(wtPath, \".git\"))) {\n179:     log(featureId, \"reusing existing worktree (has work)\");\n180:     // Still copy config files in case they're missing\n181:     copyConfigFiles(projectRoot, wtPath, featureId, config);\n182:     return wtPath;\n183:   }\n184: \n185:   // Create the branch if it doesn't exist\n186:   log(featureId, \"creating branch...\");\n187:   await createBranch(projectRoot, branch, baseBranch);\n188: \n189:   // Remove existing worktree directory if present but invalid\n190:   if (existsSync(wtPath)) {\n191:     log(featureId, \"removing old worktree...\");\n192:     try {\n193:       await runAsync(`git worktree remove --force \"${wtPath}\"`, {\n194:         cwd: projectRoot,\n195:       });\n196:     } catch {\n197:       await runAsync(`rm -rf \"${wtPath}\"`);\n198:       await runAsync(`git worktree prune`, { cwd: projectRoot });\n199:     }\n200:   }\n201: \n202:   // Create the worktree\n203:   log(featureId, \"creating worktree...\");\n204:   await runAsync(`git worktree add \"${wtPath}\" \"${branch}\"`, {\n205:     cwd: projectRoot,\n206:   });\n207: \n208:   // Copy agent config files into worktree\n209:   copyConfigFiles(projectRoot, wtPath, featureId, config);\n210: \n211:   log(featureId, \"worktree ready\");\n212:   return wtPath;\n213: }\n214: \n215: /**\n216:  * Copy agent config files from project root into a worktree.\n217:  * Best-effort — logs warnings but doesn't throw.\n218:  */\n219: function copyConfigFiles(\n220:   projectRoot: string,\n221:   wtPath: string,\n222:   featureId: string,\n223:   config: WomboConfig\n224: ): void {\n225:   for (const configFile of config.agent.configFiles) {\n226:     const srcPath = resolve(projectRoot, configFile);\n227:     if (!existsSync(srcPath)) continue;\n228: \n229:     const destPath = resolve(wtPath, configFile);\n230:     try {\n231:       const stat = statSync(srcPath);\n232:       if (stat.isDirectory()) {\n233:         cpSync(srcPath, destPath, { recursive: true });\n234:       } else {\n235:         cpSync(srcPath, destPath);\n236:       }\n237:     } catch {\n238:       // Non-critical — best effort\n239:     }\n240:   }\n241: \n242:   // Verify all config files were copied successfully\n243:   verifyConfigFiles(projectRoot, wtPath, featureId, config);\n244: }\n245: \n246: // ---------------------------------------------------------------------------\n247: // Config File Verification\n248: // ---------------------------------------------------------------------------\n249: \n250: /**\n251:  * Verify that all expected config files were copied into the worktree.\n252:  * Logs a warning for any that are missing. This is a safety net on top\n253:  * of the best-effort cpSync logic in createWorktree.\n254:  */\n255: function verifyConfigFiles(\n256:   projectRoot: string,\n257:   wtPath: string,\n258:   featureId: string,\n259:   config: WomboConfig\n260: ): void {\n261:   const missing: string[] = [];\n262: \n263:   for (const configFile of config.agent.configFiles) {\n264:     const srcPath = resolve(projectRoot, configFile);\n265:     const destPath = resolve(wtPath, configFile);\n266: \n267:     // Only check files/dirs that exist in the source project\n268:     if (!existsSync(srcPath)) continue;\n269: \n270:     if (!existsSync(destPath)) {\n271:       missing.push(configFile);\n272:     }\n273:   }\n274: \n275:   if (missing.length > 0) {\n276:     log(\n277:       featureId,\n278:       `\\x1b[33mWARNING\\x1b[0m: config files missing in worktree: ${missing.join(\", \")}`\n279:     );\n280:   }\n281: }\n282: \n283: /**\n284:  * Install dependencies in a worktree.\n285:  */\n286: export async function installDeps(\n287:   wtPath: string,\n288:   featureId: string,\n289:   config: WomboConfig\n290: ): Promise<void> {\n291:   log(featureId, `running ${config.install.command}...`);\n292:   const start = Date.now();\n293:   await runAsync(config.install.command, {\n294:     cwd: wtPath,\n295:     timeoutMs: config.install.timeout,\n296:   });\n297:   const elapsed = ((Date.now() - start) / 1000).toFixed(1);\n298:   log(featureId, `install done (${elapsed}s)`);\n299: }\n300: \n301: /**\n302:  * Check if a worktree already exists and has node_modules (fully ready).\n303:  */\n304: export function worktreeReady(wtPath: string): boolean {\n305:   return (\n306:     existsSync(wtPath) &&\n307:     existsSync(resolve(wtPath, \"node_modules\"))\n308:   );\n309: }\n310: \n311: /**\n312:  * Check if a valid git worktree exists at the path (may lack node_modules).\n313:  * A git worktree has a .git *file* (not directory) pointing to the main repo.\n314:  */\n315: export function worktreeExists(wtPath: string): boolean {\n316:   return existsSync(wtPath) && existsSync(resolve(wtPath, \".git\"));\n317: }\n318: \n319: /**\n320:  * Check if a local branch exists in the repository.\n321:  * Uses `git rev-parse --verify` which is the canonical way to check branch existence.\n322:  */\n323: export function branchExists(projectRoot: string, branchName: string): boolean {\n324:   try {\n325:     runSync(`git rev-parse --verify \"refs/heads/${branchName}\"`, {\n326:       cwd: projectRoot,\n327:       silent: true,\n328:     });\n329:     return true;\n330:   } catch {\n331:     return false;\n332:   }\n333: }\n334: \n335: // ---------------------------------------------------------------------------\n336: // Worktree Listing / Cleanup (sync)\n337: // ---------------------------------------------------------------------------\n338: \n339: /**\n340:  * List all git worktrees.\n341:  */\n342: export function listWorktrees(projectRoot: string): WorktreeInfo[] {\n343:   const output = runSync(\"git worktree list --porcelain\", {\n344:     cwd: projectRoot,\n345:     silent: true,\n346:   });\n347:   if (!output) return [];\n348: \n349:   const worktrees: WorktreeInfo[] = [];\n350:   let current: Partial<WorktreeInfo> = {};\n351: \n352:   for (const line of output.split(\"\\n\")) {\n353:     if (line.startsWith(\"worktree \")) {\n354:       if (current.path) worktrees.push(current as WorktreeInfo);\n355:       current = { path: line.slice(9), bare: false };\n356:     } else if (line.startsWith(\"HEAD \")) {\n357:       current.head = line.slice(5);\n358:     } else if (line.startsWith(\"branch \")) {\n359:       current.branch = line.slice(7).replace(\"refs/heads/\", \"\");\n360:     } else if (line === \"bare\") {\n361:       current.bare = true;\n362:     } else if (line === \"\" && current.path) {\n363:       worktrees.push(current as WorktreeInfo);\n364:       current = {};\n365:     }\n366:   }\n367:   if (current.path) worktrees.push(current as WorktreeInfo);\n368: \n369:   return worktrees;\n370: }\n371: \n372: /**\n373:  * List only wombo-related worktrees.\n374:  *\n375:  * SAFETY: Filters by checking that the *basename* of the worktree path\n376:  * starts with the worktreePrefix. A naive `.includes()` on the full path\n377:  * would match the main repo itself if its directory name contained the\n378:  * prefix (e.g. \"wombo-combo\" contains \"wombo-\"), causing cleanup to\n379:  * destroy the project root.\n380:  *\n381:  * Additionally, the main repo worktree (projectRoot) is always excluded\n382:  * as a defensive guard.\n383:  */\n384: export function listWomboWorktrees(\n385:   projectRoot: string,\n386:   config: WomboConfig\n387: ): WorktreeInfo[] {\n388:   const resolvedRoot = resolve(projectRoot);\n389:   return listWorktrees(projectRoot).filter((wt) => {\n390:     // Never include the main project root\n391:     if (resolve(wt.path) === resolvedRoot) return false;\n392:     // Match only worktrees whose directory name starts with the prefix\n393:     return basename(wt.path).startsWith(config.git.worktreePrefix);\n394:   });\n395: }\n396: \n397: /**\n398:  * Remove a worktree and optionally delete its branch.\n399:  *\n400:  * SAFETY: Refuses to remove the project root itself. This is a hard guard\n401:  * against bugs in worktree filtering that could otherwise destroy the main repo.\n402:  */\n403: export function removeWorktree(\n404:   projectRoot: string,\n405:   wtPath: string,\n406:   deleteBranchToo: boolean = true\n407: ): void {\n408:   // Hard safety check: never remove the main project root\n409:   if (resolve(wtPath) === resolve(projectRoot)) {\n410:     throw new Error(\n411:       `SAFETY: refusing to remove project root as worktree: ${wtPath}`\n412:     );\n413:   }\n414: \n415:   const worktrees = listWorktrees(projectRoot);\n416:   const wt = worktrees.find((w) => w.path === wtPath);\n417: \n418:   try {\n419:     runSync(`git worktree remove --force \"${wtPath}\"`, { cwd: projectRoot });\n420:   } catch {\n421:     if (existsSync(wtPath)) {\n422:       runSync(`rm -rf \"${wtPath}\"`);\n423:     }\n424:     runSync(\"git worktree prune\", { cwd: projectRoot });\n425:   }\n426: \n427:   if (deleteBranchToo && wt?.branch) {\n428:     try {\n429:       runSync(`git branch -D \"${wt.branch}\"`, {\n430:         cwd: projectRoot,\n431:         silent: true,\n432:       });\n433:     } catch {\n434:       // Branch may have been merged or already deleted\n435:     }\n436:   }\n437: }\n438: \n439: /**\n440:  * Check if a feature branch has any commits beyond the base branch.\n441:  * Returns true if the branch has diverged (i.e., the agent made commits).\n442:  */\n443: export function branchHasChanges(\n444:   projectRoot: string,\n445:   branch: string,\n446:   baseBranch: string\n447: ): boolean {\n448:   try {\n449:     const count = runSync(\n450:       `git rev-list --count \"${baseBranch}..${branch}\"`,\n451:       { cwd: projectRoot, silent: true }\n452:     );\n453:     return parseInt(count, 10) > 0;\n454:   } catch {\n455:     // If the branch doesn't exist or git fails, assume no changes\n456:     return false;\n457:   }\n458: }\n459: \n460: /**\n461:  * Remove all wombo-related worktrees and prune.\n462:  */\n463: export function cleanupAllWorktrees(\n464:   projectRoot: string,\n465:   config: WomboConfig\n466: ): number {\n467:   const womboWorktrees = listWomboWorktrees(projectRoot, config);\n468:   let removed = 0;\n469:   for (const wt of womboWorktrees) {\n470:     try {\n471:       removeWorktree(projectRoot, wt.path, false);\n472:       removed++;\n473:     } catch (err: any) {\n474:       console.error(`Failed to remove worktree ${wt.path}: ${err.message}`);\n475:     }\n476:   }\n477:   try {\n478:     runSync(\"git worktree prune\", { cwd: projectRoot });\n479:   } catch {\n480:     // Prune is best-effort — may fail if repo state is already clean\n481:   }\n482:   return removed;\n483: }\n\n(End of file - total 483 lines)\n</content>","title":"src/lib/worktree.ts","metadata":{"preview":"/**\n * worktree.ts — Git worktree lifecycle management.\n *\n * Responsibilities:\n *   - Create feature branches from a base branch\n *   - Create git worktrees for each feature branch\n *   - Run install command in worktrees\n *   - List and remove worktrees\n *   - Copy agent config files into worktrees\n *\n * IMPORTANT: Heavy operations (createWorktree, installDeps) are async\n * to allow true parallelism with Promise.all.\n */\n\nimport { exec, execSync } from \"node:child_process\";\nimport { existsSync, cpSync, statSync } from \"node:fs\";\nimport { resolve, dirname, basename } from \"node:path\";\nimport type { WomboConfig } from \"../config.js\";\n\n// ---------------------------------------------------------------------------","truncated":false,"loaded":[]},"time":{"start":1773351957378,"end":1773351957380}}}}
