{"type":"tool_use","timestamp":1773351947874,"sessionID":"ses_31bfcf566ffeX54k1gNGv0ej46","part":{"id":"prt_ce4034b10001OEWs74gJnmU3YD","sessionID":"ses_31bfcf566ffeX54k1gNGv0ej46","messageID":"msg_ce4034194001jYBsVlhwpZEOHX","type":"tool","callID":"toolu_vrtx_01EWAMyqpG1MvKJ9pZGQT8WD","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-agent-browser-integration/src/lib/verifier.ts"},"output":"<path>/home/fulgidus/Documents/wombo-agent-browser-integration/src/lib/verifier.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * verifier.ts — Build verification in worktrees.\n3:  *\n4:  * Responsibilities:\n5:  *   - Run the project build command in a worktree\n6:  *   - Capture and parse build output\n7:  *   - Determine pass/fail\n8:  *   - Extract error messages for retry prompts\n9:  *\n10:  * IMPORTANT: runBuild is ASYNC — does not block the event loop.\n11:  */\n12: \n13: import { exec } from \"node:child_process\";\n14: import { existsSync } from \"node:fs\";\n15: import { resolve } from \"node:path\";\n16: import type { WomboConfig } from \"../config.js\";\n17: \n18: // ---------------------------------------------------------------------------\n19: // Types\n20: // ---------------------------------------------------------------------------\n21: \n22: export interface BuildResult {\n23:   passed: boolean;\n24:   exitCode: number;\n25:   stdout: string;\n26:   stderr: string;\n27:   /** Combined output, truncated for use in retry prompts */\n28:   errorSummary: string;\n29:   /** Duration in milliseconds */\n30:   durationMs: number;\n31: }\n32: \n33: // ---------------------------------------------------------------------------\n34: // Build Verification\n35: // ---------------------------------------------------------------------------\n36: \n37: /**\n38:  * Run the build command in a worktree directory.\n39:  * Uses config for the build command and timeout.\n40:  */\n41: export function runBuild(\n42:   worktreePath: string,\n43:   config: WomboConfig\n44: ): Promise<BuildResult> {\n45:   return new Promise((resolvePromise) => {\n46:     const start = Date.now();\n47: \n48:     exec(\n49:       config.build.command,\n50:       {\n51:         cwd: worktreePath,\n52:         encoding: \"utf-8\",\n53:         timeout: config.build.timeout,\n54:         maxBuffer: 10 * 1024 * 1024,\n55:       },\n56:       (error, stdout, stderr) => {\n57:         const durationMs = Date.now() - start;\n58:         const exitCode = error ? (error as any).code ?? 1 : 0;\n59:         const passed = !error;\n60: \n61:         let errorSummary = \"\";\n62:         if (!passed) {\n63:           errorSummary = extractErrorSummary(stdout ?? \"\", stderr ?? \"\");\n64:         }\n65: \n66:         resolvePromise({\n67:           passed,\n68:           exitCode,\n69:           stdout: stdout ?? \"\",\n70:           stderr: stderr ?? \"\",\n71:           errorSummary,\n72:           durationMs,\n73:         });\n74:       }\n75:     );\n76:   });\n77: }\n78: \n79: // ---------------------------------------------------------------------------\n80: // Error Extraction\n81: // ---------------------------------------------------------------------------\n82: \n83: /**\n84:  * Extract a concise error summary from build output.\n85:  */\n86: function extractErrorSummary(stdout: string, stderr: string): string {\n87:   const combined = stdout + \"\\n\" + stderr;\n88:   const lines = combined.split(\"\\n\");\n89: \n90:   const errorLines: string[] = [];\n91:   let capturing = false;\n92:   let contextLines = 0;\n93: \n94:   for (const line of lines) {\n95:     const isError =\n96:       /error/i.test(line) &&\n97:       !/warning/i.test(line) &&\n98:       !/^info/i.test(line);\n99:     const isTypeError = /TS\\d+/.test(line);\n100: \n101:     if (isError || isTypeError) {\n102:       capturing = true;\n103:       contextLines = 0;\n104:       errorLines.push(line);\n105:     } else if (capturing) {\n106:       contextLines++;\n107:       if (contextLines <= 3) {\n108:         errorLines.push(line);\n109:       } else {\n110:         capturing = false;\n111:       }\n112:     }\n113:   }\n114: \n115:   if (errorLines.length === 0) {\n116:     const tail = lines.slice(-50).join(\"\\n\");\n117:     return truncate(tail, 4000);\n118:   }\n119: \n120:   return truncate(errorLines.join(\"\\n\"), 4000);\n121: }\n122: \n123: /**\n124:  * Truncate a string to maxLen characters.\n125:  */\n126: function truncate(s: string, maxLen: number): string {\n127:   if (s.length <= maxLen) return s;\n128:   return s.slice(0, maxLen) + \"\\n\\n[... truncated, showing first 4000 chars]\";\n129: }\n130: \n131: // ---------------------------------------------------------------------------\n132: // Quick Check\n133: // ---------------------------------------------------------------------------\n134: \n135: /**\n136:  * Quick check if the build artifacts exist.\n137:  */\n138: export function hasBuildArtifacts(\n139:   worktreePath: string,\n140:   config: WomboConfig\n141: ): boolean {\n142:   try {\n143:     return existsSync(resolve(worktreePath, config.build.artifactDir));\n144:   } catch {\n145:     return false;\n146:   }\n147: }\n\n(End of file - total 147 lines)\n</content>","title":"src/lib/verifier.ts","metadata":{"preview":"/**\n * verifier.ts — Build verification in worktrees.\n *\n * Responsibilities:\n *   - Run the project build command in a worktree\n *   - Capture and parse build output\n *   - Determine pass/fail\n *   - Extract error messages for retry prompts\n *\n * IMPORTANT: runBuild is ASYNC — does not block the event loop.\n */\n\nimport { exec } from \"node:child_process\";\nimport { existsSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\nimport type { WomboConfig } from \"../config.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------","truncated":false,"loaded":[]},"time":{"start":1773351947872,"end":1773351947873}}}}
{"type":"tool_use","timestamp":1773351948309,"sessionID":"ses_31bfcf566ffeX54k1gNGv0ej46","part":{"id":"prt_ce4034ecc001R0ffce2grFheBG","sessionID":"ses_31bfcf566ffeX54k1gNGv0ej46","messageID":"msg_ce4034194001jYBsVlhwpZEOHX","type":"tool","callID":"toolu_vrtx_01BS4CGS1KxZTSynAYW6we18","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-agent-browser-integration/src/lib/launcher.ts"},"output":"<path>/home/fulgidus/Documents/wombo-agent-browser-integration/src/lib/launcher.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * launcher.ts — Process spawning and tmux session management.\n3:  *\n4:  * Responsibilities:\n5:  *   - Launch agent in headless mode (agent run --format json)\n6:  *   - Launch agent in interactive mode (tmux session with TUI)\n7:  *   - Resume sessions for auto-retry\n8:  *   - Manage tmux sessions (create, list, kill)\n9:  */\n10: \n11: import { spawn, execSync, type ChildProcess } from \"node:child_process\";\n12: import { writeFileSync, unlinkSync } from \"node:fs\";\n13: import type { WomboConfig } from \"../config.js\";\n14: import { resolveAgentBin } from \"../config.js\";\n15: \n16: // ---------------------------------------------------------------------------\n17: // Types\n18: // ---------------------------------------------------------------------------\n19: \n20: export interface LaunchResult {\n21:   pid: number;\n22:   process: ChildProcess;\n23:   sessionId?: string;\n24: }\n25: \n26: export interface LaunchOptions {\n27:   worktreePath: string;\n28:   featureId: string;\n29:   prompt: string;\n30:   model?: string;\n31:   interactive?: boolean;\n32:   config: WomboConfig;\n33: }\n34: \n35: export interface RetryOptions {\n36:   worktreePath: string;\n37:   featureId: string;\n38:   sessionId: string;\n39:   buildErrors: string;\n40:   model?: string;\n41:   interactive?: boolean;\n42:   config: WomboConfig;\n43: }\n44: \n45: // ---------------------------------------------------------------------------\n46: // Helpers\n47: // ---------------------------------------------------------------------------\n48: \n49: function tmuxSessionName(featureId: string, config: WomboConfig): string {\n50:   return `${config.agent.tmuxPrefix}-${featureId}`;\n51: }\n52: \n53: function runSilent(cmd: string): string {\n54:   try {\n55:     return execSync(cmd, { encoding: \"utf-8\", stdio: \"pipe\" }).trim();\n56:   } catch {\n57:     return \"\";\n58:   }\n59: }\n60: \n61: // ---------------------------------------------------------------------------\n62: // Headless Launch\n63: // ---------------------------------------------------------------------------\n64: \n65: /**\n66:  * Launch agent in headless mode with JSON output.\n67:  */\n68: export function launchHeadless(opts: LaunchOptions): LaunchResult {\n69:   const agentBin = resolveAgentBin(opts.config);\n70: \n71:   const args = [\n72:     \"run\",\n73:     \"--format\", \"json\",\n74:     \"--agent\", opts.config.agent.name,\n75:     \"--dir\", opts.worktreePath,\n76:     \"--title\", `wombo: ${opts.featureId}`,\n77:   ];\n78: \n79:   if (opts.model) {\n80:     args.push(\"--model\", opts.model);\n81:   }\n82: \n83:   args.push(opts.prompt);\n84: \n85:   const child = spawn(agentBin, args, {\n86:     stdio: [\"pipe\", \"pipe\", \"pipe\"],\n87:     detached: false,\n88:     env: {\n89:       ...process.env,\n90:       OPENCODE_DIR: opts.worktreePath,\n91:     },\n92:   });\n93: \n94:   // Close stdin so agent starts processing immediately\n95:   child.stdin?.end();\n96: \n97:   return {\n98:     pid: child.pid!,\n99:     process: child,\n100:   };\n101: }\n102: \n103: /**\n104:  * Resume a headless session with a retry message (build errors).\n105:  */\n106: export function retryHeadless(opts: RetryOptions): LaunchResult {\n107:   const agentBin = resolveAgentBin(opts.config);\n108: \n109:   const retryMessage = `The build failed. Please fix the following errors and run \\`${opts.config.build.command}\\` again:\\n\\n\\`\\`\\`\\n${opts.buildErrors}\\n\\`\\`\\`\\n\\nFix all errors, then verify the build passes.`;\n110: \n111:   const args = [\n112:     \"run\",\n113:     \"--format\", \"json\",\n114:     \"--session\", opts.sessionId,\n115:     \"--continue\",\n116:     \"--dir\", opts.worktreePath,\n117:   ];\n118: \n119:   if (opts.model) {\n120:     args.push(\"--model\", opts.model);\n121:   }\n122: \n123:   args.push(retryMessage);\n124: \n125:   const child = spawn(agentBin, args, {\n126:     stdio: [\"pipe\", \"pipe\", \"pipe\"],\n127:     detached: false,\n128:     env: {\n129:       ...process.env,\n130:       OPENCODE_DIR: opts.worktreePath,\n131:     },\n132:   });\n133: \n134:   child.stdin?.end();\n135: \n136:   return {\n137:     pid: child.pid!,\n138:     process: child,\n139:   };\n140: }\n141: \n142: // ---------------------------------------------------------------------------\n143: // Conflict Resolution Launch\n144: // ---------------------------------------------------------------------------\n145: \n146: export interface ConflictResolverOptions {\n147:   worktreePath: string;\n148:   featureId: string;\n149:   prompt: string;\n150:   model?: string;\n151:   config: WomboConfig;\n152: }\n153: \n154: /**\n155:  * Launch a headless agent to resolve merge conflicts.\n156:  *\n157:  * This is similar to `launchHeadless`, but the prompt is a conflict-resolution\n158:  * prompt generated by `generateConflictResolutionPrompt()`. The agent runs in\n159:  * the feature worktree where `git merge <baseBranch>` has already been run,\n160:  * leaving conflict markers in the working tree.\n161:  */\n162: export function launchConflictResolver(opts: ConflictResolverOptions): LaunchResult {\n163:   const agentBin = resolveAgentBin(opts.config);\n164: \n165:   const args = [\n166:     \"run\",\n167:     \"--format\", \"json\",\n168:     \"--agent\", opts.config.agent.name,\n169:     \"--dir\", opts.worktreePath,\n170:     \"--title\", `wombo: conflict-resolve ${opts.featureId}`,\n171:   ];\n172: \n173:   if (opts.model) {\n174:     args.push(\"--model\", opts.model);\n175:   }\n176: \n177:   args.push(opts.prompt);\n178: \n179:   const child = spawn(agentBin, args, {\n180:     stdio: [\"pipe\", \"pipe\", \"pipe\"],\n181:     detached: false,\n182:     env: {\n183:       ...process.env,\n184:       OPENCODE_DIR: opts.worktreePath,\n185:     },\n186:   });\n187: \n188:   child.stdin?.end();\n189: \n190:   return {\n191:     pid: child.pid!,\n192:     process: child,\n193:   };\n194: }\n195: \n196: // ---------------------------------------------------------------------------\n197: // Interactive (tmux) Launch\n198: // ---------------------------------------------------------------------------\n199: \n200: /**\n201:  * Launch agent in a tmux session for interactive use.\n202:  */\n203: export function launchInteractive(opts: LaunchOptions): LaunchResult {\n204:   const agentBin = resolveAgentBin(opts.config);\n205:   const sessionName = tmuxSessionName(opts.featureId, opts.config);\n206: \n207:   // Kill existing session if any\n208:   killTmuxSession(opts.featureId, opts.config);\n209: \n210:   // Build the agent command to run inside tmux\n211:   const ocArgs = [\n212:     agentBin,\n213:     \"--dir\", JSON.stringify(opts.worktreePath),\n214:   ];\n215: \n216:   if (opts.model) {\n217:     ocArgs.push(\"--model\", JSON.stringify(opts.model));\n218:   }\n219: \n220:   const tmuxCmd = ocArgs.join(\" \");\n221: \n222:   // Create a detached tmux session running the agent\n223:   execSync(\n224:     `tmux new-session -d -s \"${sessionName}\" -c \"${opts.worktreePath}\" \"${tmuxCmd}\"`,\n225:     { stdio: \"pipe\" }\n226:   );\n227: \n228:   // Send the prompt as initial message after a brief delay\n229:   setTimeout(() => {\n230:     try {\n231:       const tmpFile = `/tmp/wombo-prompt-${opts.featureId}.txt`;\n232:       writeFileSync(tmpFile, opts.prompt);\n233:       execSync(`tmux load-buffer \"${tmpFile}\"`, { stdio: \"pipe\" });\n234:       execSync(`tmux paste-buffer -t \"${sessionName}\"`, { stdio: \"pipe\" });\n235:       execSync(`tmux send-keys -t \"${sessionName}\" Enter`, { stdio: \"pipe\" });\n236:       try { unlinkSync(tmpFile); } catch {}\n237:     } catch {\n238:       // If prompt sending fails, user can type manually\n239:     }\n240:   }, 3000);\n241: \n242:   // Get the PID of the tmux server pane process\n243:   const panePid = runSilent(\n244:     `tmux list-panes -t \"${sessionName}\" -F \"#{pane_pid}\"`\n245:   );\n246: \n247:   return {\n248:     pid: parseInt(panePid) || 0,\n249:     process: null as any, // No direct process handle in tmux mode\n250:   };\n251: }\n252: \n253: /**\n254:  * Resume an interactive session with retry message.\n255:  */\n256: export function retryInteractive(opts: RetryOptions): LaunchResult {\n257:   const sessionName = tmuxSessionName(opts.featureId, opts.config);\n258: \n259:   const exists = tmuxSessionExists(opts.featureId, opts.config);\n260: \n261:   if (exists) {\n262:     const retryMsg = `The build failed. Fix these errors:\\n${opts.buildErrors}`;\n263:     const tmpFile = `/tmp/wombo-retry-${opts.featureId}.txt`;\n264:     writeFileSync(tmpFile, retryMsg);\n265:     execSync(`tmux load-buffer \"${tmpFile}\"`, { stdio: \"pipe\" });\n266:     execSync(`tmux paste-buffer -t \"${sessionName}\"`, { stdio: \"pipe\" });\n267:     execSync(`tmux send-keys -t \"${sessionName}\" Enter`, { stdio: \"pipe\" });\n268:     try { unlinkSync(tmpFile); } catch {}\n269: \n270:     const panePid = runSilent(\n271:       `tmux list-panes -t \"${sessionName}\" -F \"#{pane_pid}\"`\n272:     );\n273: \n274:     return {\n275:       pid: parseInt(panePid) || 0,\n276:       process: null as any,\n277:     };\n278:   }\n279: \n280:   // Session doesn't exist — launch a new interactive session\n281:   return launchInteractive({\n282:     worktreePath: opts.worktreePath,\n283:     featureId: opts.featureId,\n284:     prompt: `Continue from session ${opts.sessionId}. The build failed:\\n${opts.buildErrors}\\n\\nFix all errors and verify the build passes.`,\n285:     model: opts.model,\n286:     interactive: true,\n287:     config: opts.config,\n288:   });\n289: }\n290: \n291: // ---------------------------------------------------------------------------\n292: // tmux Session Management\n293: // ---------------------------------------------------------------------------\n294: \n295: /**\n296:  * Check if a tmux session exists for a feature.\n297:  */\n298: export function tmuxSessionExists(\n299:   featureId: string,\n300:   config: WomboConfig\n301: ): boolean {\n302:   const sessionName = tmuxSessionName(featureId, config);\n303:   return runSilent(`tmux has-session -t \"${sessionName}\" 2>/dev/null && echo yes`) === \"yes\";\n304: }\n305: \n306: /**\n307:  * Kill a tmux session for a feature.\n308:  */\n309: export function killTmuxSession(\n310:   featureId: string,\n311:   config: WomboConfig\n312: ): void {\n313:   const sessionName = tmuxSessionName(featureId, config);\n314:   runSilent(`tmux kill-session -t \"${sessionName}\" 2>/dev/null`);\n315: }\n316: \n317: /**\n318:  * List all wombo-related tmux sessions.\n319:  */\n320: export function listTmuxSessions(config: WomboConfig): string[] {\n321:   const output = runSilent(\n322:     `tmux list-sessions -F \"#{session_name}\" 2>/dev/null`\n323:   );\n324:   if (!output) return [];\n325:   return output\n326:     .split(\"\\n\")\n327:     .filter((s) => s.startsWith(config.agent.tmuxPrefix + \"-\"));\n328: }\n329: \n330: /**\n331:  * Kill all wombo-related tmux sessions.\n332:  */\n333: export function killAllTmuxSessions(config: WomboConfig): number {\n334:   const sessions = listTmuxSessions(config);\n335:   for (const s of sessions) {\n336:     runSilent(`tmux kill-session -t \"${s}\" 2>/dev/null`);\n337:   }\n338:   return sessions.length;\n339: }\n340: \n341: /**\n342:  * Check if a process is still running by PID.\n343:  */\n344: export function isProcessRunning(pid: number): boolean {\n345:   if (!pid || pid <= 0) return false;\n346:   try {\n347:     process.kill(pid, 0);\n348:     return true;\n349:   } catch {\n350:     return false;\n351:   }\n352: }\n\n(End of file - total 352 lines)\n</content>","title":"src/lib/launcher.ts","metadata":{"preview":"/**\n * launcher.ts — Process spawning and tmux session management.\n *\n * Responsibilities:\n *   - Launch agent in headless mode (agent run --format json)\n *   - Launch agent in interactive mode (tmux session with TUI)\n *   - Resume sessions for auto-retry\n *   - Manage tmux sessions (create, list, kill)\n */\n\nimport { spawn, execSync, type ChildProcess } from \"node:child_process\";\nimport { writeFileSync, unlinkSync } from \"node:fs\";\nimport type { WomboConfig } from \"../config.js\";\nimport { resolveAgentBin } from \"../config.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface LaunchResult {","truncated":false,"loaded":[]},"time":{"start":1773351948307,"end":1773351948308}}}}
{"type":"tool_use","timestamp":1773351948892,"sessionID":"ses_31bfcf566ffeX54k1gNGv0ej46","part":{"id":"prt_ce40350ad001Cq5OdL8TWW1hRY","sessionID":"ses_31bfcf566ffeX54k1gNGv0ej46","messageID":"msg_ce4034194001jYBsVlhwpZEOHX","type":"tool","callID":"toolu_vrtx_01Wnxjs8G1GSuMhtGvSVaTSS","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-agent-browser-integration/src/lib/prompt.ts"},"output":"<path>/home/fulgidus/Documents/wombo-agent-browser-integration/src/lib/prompt.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * prompt.ts — Generate agent prompts from feature specs.\n3:  *\n4:  * Responsibilities:\n5:  *   - Transform a Feature into a structured prompt for the agent\n6:  *   - Include feature spec, subtasks, constraints, forbidden items, references\n7:  *   - Generate the build command and success criteria\n8:  *   - All project-specific values come from config (no hardcoded Astro references)\n9:  */\n10: \n11: import type { Feature, Subtask } from \"./features.js\";\n12: import { formatDuration, parseDurationMinutes } from \"./features.js\";\n13: import type { WomboConfig } from \"../config.js\";\n14: \n15: // ---------------------------------------------------------------------------\n16: // Prompt Generation\n17: // ---------------------------------------------------------------------------\n18: \n19: /**\n20:  * Generate the full prompt for an autonomous agent working on a feature.\n21:  */\n22: export function generatePrompt(\n23:   feature: Feature,\n24:   baseBranch: string,\n25:   config: WomboConfig\n26: ): string {\n27:   const sections: string[] = [];\n28: \n29:   // Header\n30:   sections.push(`# Feature Implementation: ${feature.title}`);\n31:   sections.push(`**Feature ID:** \\`${feature.id}\\``);\n32:   sections.push(`**Branch:** \\`${config.git.branchPrefix}${feature.id}\\``);\n33:   sections.push(`**Base:** \\`${baseBranch}\\``);\n34:   sections.push(\n35:     `**Estimated Effort:** ${formatDuration(parseDurationMinutes(feature.effort))}`\n36:   );\n37:   sections.push(\n38:     `**Difficulty:** ${feature.difficulty} | **Priority:** ${feature.priority}`\n39:   );\n40: \n41:   // Description\n42:   sections.push(`\\n## Description\\n`);\n43:   sections.push(feature.description.trim());\n44: \n45:   // Subtasks\n46:   if (feature.subtasks.length > 0) {\n47:     sections.push(`\\n## Subtasks\\n`);\n48:     sections.push(\n49:       \"Complete these in order. Mark each done with a commit when finished.\\n\"\n50:     );\n51:     for (let i = 0; i < feature.subtasks.length; i++) {\n52:       sections.push(formatSubtask(feature.subtasks[i], i + 1, 0));\n53:     }\n54:   }\n55: \n56:   // Constraints\n57:   if (feature.constraints.length > 0) {\n58:     sections.push(`\\n## Constraints\\n`);\n59:     sections.push(\n60:       \"You MUST follow these constraints. Violating any is a failure.\\n\"\n61:     );\n62:     for (const c of feature.constraints) {\n63:       sections.push(`- ${c}`);\n64:     }\n65:   }\n66: \n67:   // Forbidden\n68:   if (feature.forbidden.length > 0) {\n69:     sections.push(`\\n## Forbidden\\n`);\n70:     sections.push(\n71:       \"You MUST NOT do any of the following. Violating any is a failure.\\n\"\n72:     );\n73:     for (const f of feature.forbidden) {\n74:       sections.push(`- ${f}`);\n75:     }\n76:   }\n77: \n78:   // References (files to explore)\n79:   if (feature.references.length > 0) {\n80:     sections.push(`\\n## Key Files to Explore\\n`);\n81:     sections.push(\n82:       \"Start by reading these files to understand the current state:\\n\"\n83:     );\n84:     for (const r of feature.references) {\n85:       sections.push(`- \\`${r}\\``);\n86:     }\n87:   }\n88: \n89:   // Notes\n90:   if (feature.notes.length > 0) {\n91:     sections.push(`\\n## Planning Notes\\n`);\n92:     for (const n of feature.notes) {\n93:       sections.push(`- ${n}`);\n94:     }\n95:   }\n96: \n97:   // Build verification — uses config, no hardcoded Astro command\n98:   sections.push(`\\n## Build Verification\\n`);\n99:   sections.push(\n100:     \"After completing all changes, run the build to verify everything works:\\n\"\n101:   );\n102:   sections.push(\"```bash\");\n103:   sections.push(config.build.command);\n104:   sections.push(\"```\\n\");\n105:   sections.push(\n106:     \"If the build fails, fix the errors before considering the task complete.\"\n107:   );\n108: \n109:   // Commit guidelines\n110:   sections.push(`\\n## Commit Guidelines\\n`);\n111:   sections.push(\"- Use conventional commits: `feat(scope):`, `fix(scope):`, `refactor(scope):`, `docs(scope):`\");\n112:   sections.push(`- Scope should be: \\`${feature.id}\\` or a relevant module name`);\n113:   sections.push(\"- Commit after each logical unit of work (roughly per subtask)\");\n114:   sections.push(\"- Do NOT squash all changes into one commit\");\n115:   sections.push(\"- Do NOT push to remote -- the orchestrator handles that\");\n116:   sections.push(`- Do NOT modify \\`${config.featuresFile}\\` -- the orchestrator handles that`);\n117: \n118:   // Final instruction\n119:   sections.push(`\\n## Execution\\n`);\n120:   sections.push(\"1. Read the key files listed above to understand the codebase\");\n121:   sections.push(\"2. Create a plan (use the TodoWrite tool)\");\n122:   sections.push(\"3. Implement each subtask, committing as you go\");\n123:   sections.push(`4. Run \\`${config.build.command}\\` to verify`);\n124:   sections.push(\"5. If the build passes, you are done\");\n125:   sections.push(\"6. If the build fails, fix the errors and re-run until it passes\");\n126: \n127:   return sections.join(\"\\n\");\n128: }\n129: \n130: // ---------------------------------------------------------------------------\n131: // Subtask Formatting\n132: // ---------------------------------------------------------------------------\n133: \n134: // ---------------------------------------------------------------------------\n135: // Conflict Resolution Prompt\n136: // ---------------------------------------------------------------------------\n137: \n138: /**\n139:  * Generate a prompt for an agent that resolves merge conflicts.\n140:  *\n141:  * The agent is launched in the feature worktree AFTER `git merge <baseBranch>`\n142:  * has been run there, leaving conflict markers in the working tree.\n143:  */\n144: export function generateConflictResolutionPrompt(\n145:   feature: Feature,\n146:   baseBranch: string,\n147:   mergeError: string,\n148:   config: WomboConfig\n149: ): string {\n150:   const sections: string[] = [];\n151: \n152:   sections.push(`# Merge Conflict Resolution: ${feature.title}`);\n153:   sections.push(`**Feature ID:** \\`${feature.id}\\``);\n154:   sections.push(`**Feature Branch:** \\`${config.git.branchPrefix}${feature.id}\\``);\n155:   sections.push(`**Base Branch:** \\`${baseBranch}\\``);\n156: \n157:   sections.push(`\\n## Situation\\n`);\n158:   sections.push(\n159:     `The feature branch \\`${config.git.branchPrefix}${feature.id}\\` has been completed and build-verified, ` +\n160:     `but merging it into \\`${baseBranch}\\` produced conflicts. The base branch (\\`${baseBranch}\\`) has been ` +\n161:     `merged INTO this feature branch's worktree, so the conflict markers are present in the working tree right now.`\n162:   );\n163: \n164:   sections.push(`\\n## Merge Error Output\\n`);\n165:   sections.push(\"```\");\n166:   sections.push(mergeError);\n167:   sections.push(\"```\");\n168: \n169:   sections.push(`\\n## Feature Description\\n`);\n170:   sections.push(feature.description.trim());\n171: \n172:   sections.push(`\\n## Your Task\\n`);\n173:   sections.push(\"1. Find all files with conflict markers (`<<<<<<<`, `=======`, `>>>>>>>`)\");\n174:   sections.push(\"2. Resolve each conflict by combining both sides intelligently:\");\n175:   sections.push(`   - The \\`HEAD\\` side is the feature's work (keep this intent)`);\n176:   sections.push(`   - The \\`${baseBranch}\\` side is upstream changes (integrate these)`);\n177:   sections.push(\"3. Remove ALL conflict markers — no `<<<<<<<`, `=======`, or `>>>>>>>` should remain\");\n178:   sections.push(\"4. Run the build to verify everything compiles:\");\n179:   sections.push(\"   ```bash\");\n180:   sections.push(`   ${config.build.command}`);\n181:   sections.push(\"   ```\");\n182:   sections.push(\"5. If the build fails, fix the errors\");\n183:   sections.push(\"6. Stage all resolved files and commit the merge:\");\n184:   sections.push(\"   ```bash\");\n185:   sections.push(\"   git add -A\");\n186:   sections.push('   git commit --no-edit');\n187:   sections.push(\"   ```\");\n188: \n189:   sections.push(`\\n## Rules\\n`);\n190:   sections.push(\"- Do NOT abort the merge (`git merge --abort`)\");\n191:   sections.push(\"- Do NOT create new branches or rebase\");\n192:   sections.push(\"- Do NOT push to remote\");\n193:   sections.push(`- Do NOT modify \\`${config.featuresFile}\\``);\n194:   sections.push(\"- Keep BOTH the feature's changes and the upstream changes where possible\");\n195:   sections.push(\"- If in doubt, prefer the feature's implementation but ensure upstream additions are not lost\");\n196: \n197:   return sections.join(\"\\n\");\n198: }\n199: \n200: // ---------------------------------------------------------------------------\n201: // Subtask Formatting\n202: // ---------------------------------------------------------------------------\n203: \n204: function formatSubtask(\n205:   subtask: Subtask,\n206:   index: number,\n207:   depth: number\n208: ): string {\n209:   const indent = \"  \".repeat(depth);\n210:   const lines: string[] = [];\n211: \n212:   lines.push(\n213:     `${indent}${index}. **${subtask.title}** (\\`${subtask.id}\\`, ${formatDuration(parseDurationMinutes(subtask.effort))})`\n214:   );\n215:   lines.push(`${indent}   ${subtask.description.trim()}`);\n216: \n217:   if (subtask.constraints.length > 0) {\n218:     for (const c of subtask.constraints) {\n219:       lines.push(`${indent}   - Constraint: ${c}`);\n220:     }\n221:   }\n222:   if (subtask.forbidden.length > 0) {\n223:     for (const f of subtask.forbidden) {\n224:       lines.push(`${indent}   - Forbidden: ${f}`);\n225:     }\n226:   }\n227:   if (subtask.references.length > 0) {\n228:     lines.push(\n229:       `${indent}   - Files: ${subtask.references.map((r) => `\\`${r}\\``).join(\", \")}`\n230:     );\n231:   }\n232:   if (subtask.depends_on.length > 0) {\n233:     lines.push(\n234:       `${indent}   - Depends on: ${subtask.depends_on.map((d) => `\\`${d}\\``).join(\", \")}`\n235:     );\n236:   }\n237: \n238:   // Nested subtasks\n239:   if (subtask.subtasks.length > 0) {\n240:     for (let i = 0; i < subtask.subtasks.length; i++) {\n241:       lines.push(formatSubtask(subtask.subtasks[i], i + 1, depth + 1));\n242:     }\n243:   }\n244: \n245:   return lines.join(\"\\n\");\n246: }\n\n(End of file - total 246 lines)\n</content>","title":"src/lib/prompt.ts","metadata":{"preview":"/**\n * prompt.ts — Generate agent prompts from feature specs.\n *\n * Responsibilities:\n *   - Transform a Feature into a structured prompt for the agent\n *   - Include feature spec, subtasks, constraints, forbidden items, references\n *   - Generate the build command and success criteria\n *   - All project-specific values come from config (no hardcoded Astro references)\n */\n\nimport type { Feature, Subtask } from \"./features.js\";\nimport { formatDuration, parseDurationMinutes } from \"./features.js\";\nimport type { WomboConfig } from \"../config.js\";\n\n// ---------------------------------------------------------------------------\n// Prompt Generation\n// ---------------------------------------------------------------------------\n\n/**\n * Generate the full prompt for an autonomous agent working on a feature.","truncated":false,"loaded":[]},"time":{"start":1773351948879,"end":1773351948881}}}}
