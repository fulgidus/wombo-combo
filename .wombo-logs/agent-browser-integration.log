{"type":"tool_use","timestamp":1773351957004,"sessionID":"ses_31bfcf566ffeX54k1gNGv0ej46","part":{"id":"prt_ce4036f0a001MBDZypXR1e2x9O","sessionID":"ses_31bfcf566ffeX54k1gNGv0ej46","messageID":"msg_ce40363fe001yxeSfJhzNGr7rt","type":"tool","callID":"toolu_vrtx_01QbwyQ63gPNxXp6WvwHBPXa","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-agent-browser-integration/src/lib/state.ts"},"output":"<path>/home/fulgidus/Documents/wombo-agent-browser-integration/src/lib/state.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * state.ts — Persistent wave state management.\n3:  *\n4:  * Responsibilities:\n5:  *   - Define the shape of .wombo-state.json\n6:  *   - Read/write state atomically\n7:  *   - Generate wave IDs\n8:  *   - Update individual agent state within a wave\n9:  */\n10: \n11: import { readFileSync, writeFileSync, existsSync, renameSync } from \"node:fs\";\n12: import { resolve } from \"node:path\";\n13: \n14: // ---------------------------------------------------------------------------\n15: // Types\n16: // ---------------------------------------------------------------------------\n17: \n18: export type AgentStatus =\n19:   | \"queued\"\n20:   | \"installing\"\n21:   | \"running\"\n22:   | \"completed\"\n23:   | \"verified\"\n24:   | \"failed\"\n25:   | \"merged\"\n26:   | \"retry\"\n27:   | \"resolving_conflict\";\n28: \n29: export interface AgentState {\n30:   feature_id: string;\n31:   branch: string;\n32:   worktree: string;\n33:   session_id: string | null;\n34:   pid: number | null;\n35:   status: AgentStatus;\n36:   activity: string | null;\n37:   activity_updated_at: string | null;\n38:   retries: number;\n39:   max_retries: number;\n40:   started_at: string | null;\n41:   completed_at: string | null;\n42:   build_passed: boolean | null;\n43:   build_output: string | null;\n44:   error: string | null;\n45:   /** Estimated effort in milliseconds (from feature's ISO 8601 duration) */\n46:   effort_estimate_ms: number | null;\n47: }\n48: \n49: export interface WaveState {\n50:   wave_id: string;\n51:   base_branch: string;\n52:   started_at: string;\n53:   updated_at: string;\n54:   max_concurrent: number;\n55:   model: string | null;\n56:   interactive: boolean;\n57:   agents: AgentState[];\n58: }\n59: \n60: // ---------------------------------------------------------------------------\n61: // Constants\n62: // ---------------------------------------------------------------------------\n63: \n64: const STATE_FILE = \".wombo-state.json\";\n65: \n66: // ---------------------------------------------------------------------------\n67: // Wave ID Generation\n68: // ---------------------------------------------------------------------------\n69: \n70: /**\n71:  * Generate a unique wave ID based on current timestamp.\n72:  * Format: wave-YYYY-MM-DD-NNN\n73:  */\n74: export function generateWaveId(): string {\n75:   const now = new Date();\n76:   const date = now.toISOString().slice(0, 10);\n77:   const seq = String(now.getHours() * 60 + now.getMinutes()).padStart(3, \"0\");\n78:   return `wave-${date}-${seq}`;\n79: }\n80: \n81: // ---------------------------------------------------------------------------\n82: // State Path\n83: // ---------------------------------------------------------------------------\n84: \n85: function statePath(projectRoot: string): string {\n86:   return resolve(projectRoot, STATE_FILE);\n87: }\n88: \n89: // ---------------------------------------------------------------------------\n90: // Read State\n91: // ---------------------------------------------------------------------------\n92: \n93: /**\n94:  * Load the current wave state from disk. Returns null if no state file exists.\n95:  */\n96: export function loadState(projectRoot: string): WaveState | null {\n97:   const p = statePath(projectRoot);\n98:   if (!existsSync(p)) return null;\n99:   try {\n100:     const raw = readFileSync(p, \"utf-8\");\n101:     return JSON.parse(raw) as WaveState;\n102:   } catch {\n103:     return null;\n104:   }\n105: }\n106: \n107: // ---------------------------------------------------------------------------\n108: // Write State\n109: // ---------------------------------------------------------------------------\n110: \n111: /**\n112:  * Save wave state to disk atomically (write to tmp then rename).\n113:  */\n114: export function saveState(projectRoot: string, state: WaveState): void {\n115:   state.updated_at = new Date().toISOString();\n116:   const p = statePath(projectRoot);\n117:   const tmp = p + \".tmp\";\n118:   writeFileSync(tmp, JSON.stringify(state, null, 2) + \"\\n\", \"utf-8\");\n119:   renameSync(tmp, p);\n120: }\n121: \n122: // ---------------------------------------------------------------------------\n123: // State Mutations\n124: // ---------------------------------------------------------------------------\n125: \n126: /**\n127:  * Create a fresh wave state.\n128:  */\n129: export function createWaveState(opts: {\n130:   baseBranch: string;\n131:   maxConcurrent: number;\n132:   model: string | null;\n133:   interactive: boolean;\n134: }): WaveState {\n135:   return {\n136:     wave_id: generateWaveId(),\n137:     base_branch: opts.baseBranch,\n138:     started_at: new Date().toISOString(),\n139:     updated_at: new Date().toISOString(),\n140:     max_concurrent: opts.maxConcurrent,\n141:     model: opts.model,\n142:     interactive: opts.interactive,\n143:     agents: [],\n144:   };\n145: }\n146: \n147: /**\n148:  * Create an initial agent state for a feature.\n149:  */\n150: export function createAgentState(\n151:   featureId: string,\n152:   branch: string,\n153:   worktreePath: string,\n154:   maxRetries: number = 2\n155: ): AgentState {\n156:   return {\n157:     feature_id: featureId,\n158:     branch,\n159:     worktree: worktreePath,\n160:     session_id: null,\n161:     pid: null,\n162:     status: \"queued\",\n163:     activity: null,\n164:     activity_updated_at: null,\n165:     retries: 0,\n166:     max_retries: maxRetries,\n167:     started_at: null,\n168:     completed_at: null,\n169:     build_passed: null,\n170:     build_output: null,\n171:     error: null,\n172:     effort_estimate_ms: null,\n173:   };\n174: }\n175: \n176: /**\n177:  * Find an agent state by feature ID.\n178:  */\n179: export function getAgent(\n180:   state: WaveState,\n181:   featureId: string\n182: ): AgentState | undefined {\n183:   return state.agents.find((a) => a.feature_id === featureId);\n184: }\n185: \n186: /**\n187:  * Update an agent's state fields.\n188:  */\n189: export function updateAgent(\n190:   state: WaveState,\n191:   featureId: string,\n192:   updates: Partial<AgentState>\n193: ): void {\n194:   const agent = state.agents.find((a) => a.feature_id === featureId);\n195:   if (!agent) throw new Error(`Agent not found for feature: ${featureId}`);\n196:   Object.assign(agent, updates);\n197: }\n198: \n199: /**\n200:  * Get counts of agents by status.\n201:  */\n202: export function agentCounts(state: WaveState): Record<AgentStatus, number> {\n203:   const counts: Record<AgentStatus, number> = {\n204:     queued: 0,\n205:     installing: 0,\n206:     running: 0,\n207:     completed: 0,\n208:     verified: 0,\n209:     failed: 0,\n210:     merged: 0,\n211:     retry: 0,\n212:     resolving_conflict: 0,\n213:   };\n214:   for (const a of state.agents) {\n215:     counts[a.status]++;\n216:   }\n217:   return counts;\n218: }\n219: \n220: /**\n221:  * Get agents that are currently running or installing.\n222:  */\n223: export function activeAgents(state: WaveState): AgentState[] {\n224:   return state.agents.filter(\n225:     (a) => a.status === \"running\" || a.status === \"installing\" || a.status === \"resolving_conflict\"\n226:   );\n227: }\n228: \n229: /**\n230:  * Get agents that are queued and ready to be launched.\n231:  */\n232: export function queuedAgents(state: WaveState): AgentState[] {\n233:   return state.agents.filter((a) => a.status === \"queued\");\n234: }\n235: \n236: /**\n237:  * Check if the wave is fully complete (no queued, installing, running, or retry agents).\n238:  */\n239: export function isWaveComplete(state: WaveState): boolean {\n240:   return state.agents.every(\n241:     (a) =>\n242:       a.status === \"completed\" ||\n243:       a.status === \"verified\" ||\n244:       a.status === \"failed\" ||\n245:       a.status === \"merged\"\n246:   );\n247: }\n\n(End of file - total 247 lines)\n</content>","title":"src/lib/state.ts","metadata":{"preview":"/**\n * state.ts — Persistent wave state management.\n *\n * Responsibilities:\n *   - Define the shape of .wombo-state.json\n *   - Read/write state atomically\n *   - Generate wave IDs\n *   - Update individual agent state within a wave\n */\n\nimport { readFileSync, writeFileSync, existsSync, renameSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type AgentStatus =\n  | \"queued\"\n  | \"installing\"","truncated":false,"loaded":[]},"time":{"start":1773351957001,"end":1773351957003}}}}
