{"type":"tool_use","timestamp":1773351904058,"sessionID":"ses_31bfd801cffeMfcGlS1DXqsNs2","part":{"id":"prt_ce4029d9f001YaO0Jc3qkKwfeM","sessionID":"ses_31bfd801cffeMfcGlS1DXqsNs2","messageID":"msg_ce4029502001S7OkWnT9sIu9o3","type":"tool","callID":"toolu_vrtx_01QuH6UFxr2ktzuvioFfz2aB","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-wave-history-export/src/index.ts"},"output":"<path>/home/fulgidus/Documents/wombo-wave-history-export/src/index.ts</path>\n<type>file</type>\n<content>1: #!/usr/bin/env bun\n2: /**\n3:  * index.ts — CLI entry point for the Wombo agent orchestration system.\n4:  *\n5:  * Usage:\n6:  *   wombo init\n7:  *   wombo launch --top-priority 3\n8:  *   wombo launch --quickest-wins 5\n9:  *   wombo launch --priority high\n10:  *   wombo launch --difficulty easy\n11:  *   wombo launch --features \"feat-a,feat-b\"\n12:  *   wombo launch --all-ready\n13:  *   wombo launch ... --max-concurrent 3 --model \"anthropic/claude-sonnet-4-20250514\"\n14:  *   wombo launch ... --interactive\n15:  *   wombo resume\n16:  *   wombo status\n17:  *   wombo verify [feature-id]\n18:  *   wombo merge [feature-id]\n19:  *   wombo retry <feature-id>\n20:  *   wombo abort <feature-id> [--requeue] [--output json]\n21:  *   wombo cleanup\n22:  *   wombo features list [--status <s>] [--priority <p>] [--difficulty <d>] [--ready] [--include-archive]\n23:  *   wombo features add <id> <title> [options]\n24:  *   wombo features set-status <feature-id> <status>\n25:  *   wombo features check\n26:  *   wombo features archive [feature-id] [--dry-run]\n27:  *   wombo features show <feature-id>\n28:  *   wombo features graph [--ascii] [--mermaid] [--subtasks] [--status <s>]\n29:  *   wombo help\n30:  *   wombo --version\n31:  */\n32: \n33: import { resolve } from \"node:path\";\n34: import { existsSync, readFileSync } from \"node:fs\";\n35: import { loadConfig, validateConfig } from \"./config.js\";\n36: import { loadState, saveState } from \"./lib/state.js\";\n37: \n38: // ---------------------------------------------------------------------------\n39: // Dev-mode guard: warn if running the global binary inside the wombo repo\n40: // ---------------------------------------------------------------------------\n41: \n42: function checkDevModeGuard(): void {\n43:   const cwd = process.cwd();\n44:   const pkgPath = resolve(cwd, \"package.json\");\n45: \n46:   // Are we inside the wombo repo?\n47:   if (!existsSync(pkgPath)) return;\n48: \n49:   let pkgName: string | undefined;\n50:   try {\n51:     const raw = readFileSync(pkgPath, \"utf-8\");\n52:     pkgName = JSON.parse(raw).name;\n53:   } catch {\n54:     return;\n55:   }\n56:   if (pkgName !== \"wombo\") return;\n57: \n58:   // We're in the wombo repo. Is the source being run from a different location?\n59:   // import.meta.dir = directory of THIS file (index.ts). If it's under cwd,\n60:   // we're running local source (bun dev). If it's elsewhere (e.g. ~/.bun/install),\n61:   // we're running the globally installed binary.\n62:   const sourceDir = resolve(import.meta.dir);\n63:   const projectSrc = resolve(cwd, \"src\");\n64: \n65:   if (!sourceDir.startsWith(projectSrc)) {\n66:     console.warn(\n67:       \"\\x1b[33m[WARNING]\\x1b[0m You are running the globally installed wombo binary \" +\n68:       \"inside the wombo repo.\\n\" +\n69:       \"  Use \\x1b[1mbun dev <command>\\x1b[0m instead to run from local source.\\n\" +\n70:       \"  See AGENTS.md for details.\\n\"\n71:     );\n72:   }\n73: }\n74: \n75: import { cmdInit } from \"./commands/init.js\";\n76: import { cmdLaunch } from \"./commands/launch.js\";\n77: import { cmdResume } from \"./commands/resume.js\";\n78: import { cmdStatus } from \"./commands/status.js\";\n79: import { cmdVerify } from \"./commands/verify.js\";\n80: import { cmdMerge } from \"./commands/merge.js\";\n81: import { cmdRetry } from \"./commands/retry.js\";\n82: import { cmdCleanup } from \"./commands/cleanup.js\";\n83: import { cmdAbort } from \"./commands/abort.js\";\n84: import { cmdUpgrade } from \"./commands/upgrade.js\";\n85: import { cmdFeaturesList } from \"./commands/features/list.js\";\n86: import { cmdFeaturesAdd } from \"./commands/features/add.js\";\n87: import { cmdFeaturesSetStatus } from \"./commands/features/set-status.js\";\n88: import { cmdFeaturesCheck } from \"./commands/features/check.js\";\n89: import { cmdFeaturesArchive } from \"./commands/features/archive.js\";\n90: import { cmdFeaturesShow } from \"./commands/features/show.js\";\n91: import { cmdFeaturesGraph } from \"./commands/features/graph.js\";\n92: \n93: import { ensureFeaturesFile } from \"./lib/features.js\";\n94: import type { Priority, Difficulty, FeatureStatus } from \"./lib/features.js\";\n95: import { resolveOutputFormat, type OutputFormat } from \"./lib/output.js\";\n96: import { validateId, validateText, validateBranchName, validateDuration, assertValid } from \"./lib/validate.js\";\n97: import { findCommandDef, commandToSchema, allCommandSchemas } from \"./lib/schema.js\";\n98: \n99: // ---------------------------------------------------------------------------\n100: // Types\n101: // ---------------------------------------------------------------------------\n102: \n103: interface CLIArgs {\n104:   command: string;\n105:   subcommand?: string;\n106:   // Selection options (launch)\n107:   topPriority?: number;\n108:   quickestWins?: number;\n109:   priority?: Priority;\n110:   difficulty?: Difficulty;\n111:   features?: string[];\n112:   allReady?: boolean;\n113:   // Launch / runtime options\n114:   maxConcurrent?: number;\n115:   model?: string;\n116:   interactive: boolean;\n117:   dryRun: boolean;\n118:   baseBranch?: string;\n119:   maxRetries?: number;\n120:   noTui: boolean;\n121:   autoPush: boolean;\n122:   // Abort options\n123:   requeue: boolean;\n124:   // General\n125:   featureId?: string;\n126:   force: boolean;\n127:   // Output format\n128:   outputFmt: OutputFormat;\n129:   // Upgrade options\n130:   checkOnly: boolean;\n131:   version?: string;\n132:   // Features subcommand extras\n133:   status?: string;\n134:   ready?: boolean;\n135:   includeArchive?: boolean;\n136:   title?: string;\n137:   description?: string;\n138:   effort?: string;\n139:   dependsOn?: string[];\n140:   // Compact output\n141:   fields?: string[];\n142:   // Graph options\n143:   ascii?: boolean;\n144:   mermaidRaw?: boolean;\n145:   graphSubtasks?: boolean;\n146: }\n147: \n148: // ---------------------------------------------------------------------------\n149: // Arg Parsing\n150: // ---------------------------------------------------------------------------\n151: \n152: function parseArgs(argv: string[]): CLIArgs {\n153:   const args = argv.slice(2); // skip 'bun' and script path\n154:   const result: CLIArgs = {\n155:     command: args[0] || \"help\",\n156:     interactive: false,\n157:     dryRun: false,\n158:     noTui: false,\n159:     autoPush: false,\n160:     requeue: false,\n161:     force: false,\n162:     checkOnly: false,\n163:     outputFmt: resolveOutputFormat(undefined), // auto-detect until --output overrides\n164:   };\n165: \n166:   // If the first arg is \"features\", treat the second positional as the subcommand\n167:   let startIdx = 1;\n168:   if (result.command === \"features\") {\n169:     result.subcommand = args[1] || \"list\";\n170:     startIdx = 2;\n171:   }\n172: \n173:   for (let i = startIdx; i < args.length; i++) {\n174:     const arg = args[i];\n175:     switch (arg) {\n176:       // --- Selection options ---\n177:       case \"--top-priority\":\n178:         result.topPriority = parseInt(args[++i], 10);\n179:         break;\n180:       case \"--quickest-wins\":\n181:         result.quickestWins = parseInt(args[++i], 10);\n182:         break;\n183:       case \"--priority\":\n184:         result.priority = args[++i] as Priority;\n185:         break;\n186:       case \"--difficulty\":\n187:         result.difficulty = args[++i] as Difficulty;\n188:         break;\n189:       case \"--features\":\n190:         result.features = args[++i].split(\",\").map((s) => s.trim());\n191:         break;\n192:       case \"--all-ready\":\n193:         result.allReady = true;\n194:         break;\n195: \n196:       // --- Launch / runtime options ---\n197:       case \"--max-concurrent\":\n198:         result.maxConcurrent = parseInt(args[++i], 10);\n199:         break;\n200:       case \"--model\":\n201:       case \"-m\":\n202:         result.model = args[++i];\n203:         break;\n204:       case \"--interactive\":\n205:         result.interactive = true;\n206:         break;\n207:       case \"--dry-run\":\n208:         result.dryRun = true;\n209:         break;\n210:       case \"--no-tui\":\n211:         result.noTui = true;\n212:         break;\n213:       case \"--auto-push\":\n214:         result.autoPush = true;\n215:         break;\n216:       case \"--requeue\":\n217:         result.requeue = true;\n218:         break;\n219:       case \"--base-branch\":\n220:         result.baseBranch = args[++i];\n221:         break;\n222:       case \"--max-retries\":\n223:         result.maxRetries = parseInt(args[++i], 10);\n224:         break;\n225: \n226:       // --- General flags ---\n227:       case \"--force\":\n228:         result.force = true;\n229:         break;\n230:       case \"--check\":\n231:         result.checkOnly = true;\n232:         break;\n233:       case \"--version\":\n234:         result.version = args[++i];\n235:         break;\n236:       case \"--output\":\n237:       case \"-o\":\n238:         result.outputFmt = resolveOutputFormat(args[++i]);\n239:         break;\n240: \n241:       // --- Features subcommand options ---\n242:       case \"--status\":\n243:         result.status = args[++i];\n244:         break;\n245:       case \"--ready\":\n246:         result.ready = true;\n247:         break;\n248:       case \"--include-archive\":\n249:         result.includeArchive = true;\n250:         break;\n251:       case \"--title\":\n252:         result.title = args[++i];\n253:         break;\n254:       case \"--description\":\n255:       case \"--desc\":\n256:         result.description = args[++i];\n257:         break;\n258:       case \"--effort\":\n259:         result.effort = args[++i];\n260:         break;\n261:       case \"--depends-on\":\n262:         result.dependsOn = args[++i].split(\",\").map((s) => s.trim());\n263:         break;\n264:       case \"--fields\":\n265:         result.fields = args[++i].split(\",\").map((s) => s.trim());\n266:         break;\n267: \n268:       // --- Graph options ---\n269:       case \"--ascii\":\n270:         result.ascii = true;\n271:         break;\n272:       case \"--mermaid\":\n273:         result.mermaidRaw = true;\n274:         break;\n275:       case \"--subtasks\":\n276:         result.graphSubtasks = true;\n277:         break;\n278: \n279:       // --- Positional (feature-id, title for add, etc.) ---\n280:       default:\n281:         if (!arg.startsWith(\"-\")) {\n282:           if (!result.featureId) {\n283:             result.featureId = arg;\n284:           } else if (!result.title) {\n285:             result.title = arg;\n286:           }\n287:         }\n288:         break;\n289:     }\n290:   }\n291: \n292:   return result;\n293: }\n294: \n295: // ---------------------------------------------------------------------------\n296: // Help\n297: // ---------------------------------------------------------------------------\n298: \n299: function cmdHelp(): void {\n300:   console.log(`\n301: Wombo — AI Agent Orchestration System\n302: \n303:   WOMBO COMBO! Parallel feature development with AI agents.\n304: \n305: Commands:\n306:   init           Generate wombo.json config in the current project\n307:   launch         Launch a wave of agents to implement features\n308:   resume         Resume a previously stopped wave\n309:   status         Show the status of the current wave\n310:   verify         Run build verification on completed agents\n311:   merge          Merge verified branches into the base branch\n312:   retry          Retry a failed agent\n313:   abort          Kill a single running agent (--requeue to return to queue)\n314:   cleanup        Remove all wave worktrees and tmux sessions\n315:   features       Manage .features.yml (see below)\n316:   upgrade        Check for updates and upgrade wombo\n317:   describe       Emit JSON schema of a command (for AI agents)\n318:   help           Show this help\n319: \n320: Features Subcommands:\n321:   features list            List features (--status, --priority, --difficulty, --ready, --include-archive)\n322:   features add <id> <title> [options]\n323:                            Add a new feature (--desc, --priority, --difficulty, --effort, --depends-on)\n324:   features set-status <id> <status>\n325:                            Change a feature's status\n326:   features check           Validate .features.yml (schema, deps, duplicates, cycles)\n327:   features archive [id]    Move done/cancelled to archive (--dry-run)\n328:   features show <id>       Show feature details\n329:   features graph           Visualize dependency graph (--ascii, --mermaid, --subtasks)\n330: \n331: Selection Options (for launch):\n332:   --top-priority N         Select top N features by priority\n333:   --quickest-wins N        Select N features with lowest effort\n334:   --priority <level>       Filter by priority (critical/high/medium/low/wishlist)\n335:   --difficulty <level>     Filter by difficulty (trivial/easy/medium/hard/very_hard)\n336:   --features \"id1,id2\"     Select specific features by ID\n337:   --all-ready              Select all features whose dependencies are met\n338: \n339: Launch Options:\n340:   --max-concurrent N       Max agents running in parallel (default: from config)\n341:   --model <model>          Model to use (e.g., \"anthropic/claude-sonnet-4-20250514\")\n342:   --interactive            Use tmux TUI mode instead of headless\n343:   --no-tui                 Headless mode without neo-blessed TUI (periodic console dashboard)\n344:   --auto-push              Push base branch to remote after all merges complete\n345:   --dry-run                Show what would be launched without launching\n346:   --base-branch <branch>   Base branch (default: from config)\n347:   --max-retries N          Max retries per agent (default: from config)\n348: \n349: General:\n350:   --version, -V            Print version and exit\n351:   --force                  Force overwrite (e.g., for init) / skip prompts (e.g., for upgrade)\n352:   --output <fmt>           Output format: text (default on TTY) or json (default when piped)\n353:   -o <fmt>                 Alias for --output\n354:   --dry-run                Show what would happen without performing the action\n355:   --fields <list>          Comma-separated fields to include (e.g., id,status,priority)\n356: \n357: Upgrade Options:\n358:   --check                  Only check for updates, don't install\n359:   --version <tag>          Install a specific version (e.g., v0.1.0)\n360: \n361: Examples:\n362:   wombo init\n363:   wombo launch --quickest-wins 3\n364:   wombo launch --priority high --interactive\n365:   wombo launch --features \"auth-flow,search-api\" --max-concurrent 2\n366:   wombo resume\n367:   wombo status\n368:   wombo verify\n369:   wombo merge\n370:   wombo retry auth-flow\n371:   wombo abort auth-flow\n372:   wombo abort auth-flow --requeue\n373:   wombo abort auth-flow --output json\n374:   wombo cleanup\n375:   wombo features list --status ready --priority high\n376:   wombo features list --fields id,status,priority --output json\n377:   wombo features add my-feature \"My Cool Feature\" --priority high --difficulty easy\n378:   wombo features set-status my-feature in-progress\n379:   wombo features check\n380:   wombo features archive --dry-run\n381:   wombo features show my-feature\n382:   wombo describe                           # list all commands as JSON\n383:   wombo describe launch                    # describe a specific command\n384:   wombo describe features add              # describe a subcommand\n385: `);\n386: }\n387: \n388: // ---------------------------------------------------------------------------\n389: // Main\n390: // ---------------------------------------------------------------------------\n391: \n392: async function main(): Promise<void> {\n393:   checkDevModeGuard();\n394: \n395:   const PROJECT_ROOT = resolve(process.cwd());\n396:   const args = parseArgs(process.argv);\n397: \n398:   // -----------------------------------------------------------------------\n399:   // Input validation at the CLI boundary\n400:   // -----------------------------------------------------------------------\n401:   if (args.featureId) {\n402:     assertValid(validateId(args.featureId, \"feature ID\"));\n403:   }\n404:   if (args.title) {\n405:     assertValid(validateText(args.title, \"title\"));\n406:   }\n407:   if (args.description) {\n408:     assertValid(validateText(args.description, \"description\"));\n409:   }\n410:   if (args.baseBranch) {\n411:     assertValid(validateBranchName(args.baseBranch, \"base branch\"));\n412:   }\n413:   if (args.effort) {\n414:     assertValid(validateDuration(args.effort, \"effort\"));\n415:   }\n416:   if (args.features) {\n417:     for (const fid of args.features) {\n418:       assertValid(validateId(fid, \"feature ID in --features\"));\n419:     }\n420:   }\n421:   if (args.dependsOn) {\n422:     for (const dep of args.dependsOn) {\n423:       assertValid(validateId(dep, \"dependency ID in --depends-on\"));\n424:     }\n425:   }\n426: \n427:   // Commands that don't need config loading\n428:   if (args.command === \"--version\" || args.command === \"-V\") {\n429:     const pkgPath = resolve(import.meta.dir, \"..\", \"package.json\");\n430:     const pkgFile = Bun.file(pkgPath);\n431:     try {\n432:       const pkg = await pkgFile.json();\n433:       console.log(`wombo ${pkg.version ?? \"(unknown version)\"}`);\n434:     } catch {\n435:       console.log(\"wombo (unknown version)\");\n436:     }\n437:     return;\n438:   }\n439: \n440:   if (args.command === \"help\" || args.command === \"--help\" || args.command === \"-h\") {\n441:     cmdHelp();\n442:     return;\n443:   }\n444: \n445:   if (args.command === \"describe\") {\n446:     // Schema introspection: `wombo describe [command]`\n447:     if (!args.featureId) {\n448:       // No command specified — list all commands\n449:       console.log(JSON.stringify(allCommandSchemas(), null, 2));\n450:     } else {\n451:       // Describe a specific command. Handle compound names: \"features list\"\n452:       const cmdName = args.title\n453:         ? `${args.featureId} ${args.title}`\n454:         : args.featureId;\n455:       const def = findCommandDef(cmdName);\n456:       if (!def) {\n457:         console.error(`Unknown command: \"${cmdName}\"`);\n458:         console.error(\"Run 'wombo describe' to list all commands.\");\n459:         process.exit(1);\n460:         return;\n461:       }\n462:       console.log(JSON.stringify(commandToSchema(def), null, 2));\n463:     }\n464:     return;\n465:   }\n466: \n467:   if (args.command === \"init\") {\n468:     await cmdInit({ projectRoot: PROJECT_ROOT, force: args.force });\n469:     return;\n470:   }\n471: \n472:   if (args.command === \"upgrade\") {\n473:     await cmdUpgrade({\n474:       force: args.force,\n475:       version: args.version,\n476:       checkOnly: args.checkOnly,\n477:     });\n478:     return;\n479:   }\n480: \n481:   // Everything else requires config\n482:   const config = loadConfig(PROJECT_ROOT);\n483:   validateConfig(config);\n484: \n485:   // Commands that operate on the features file — ensure it exists first\n486:   const needsFeatures = new Set([\"launch\", \"resume\", \"verify\", \"retry\", \"features\"]);\n487:   if (needsFeatures.has(args.command)) {\n488:     await ensureFeaturesFile(PROJECT_ROOT, config);\n489:   }\n490: \n491:   switch (args.command) {\n492:     case \"launch\":\n493:       await cmdLaunch({\n494:         projectRoot: PROJECT_ROOT,\n495:         config,\n496:         topPriority: args.topPriority,\n497:         quickestWins: args.quickestWins,\n498:         priority: args.priority,\n499:         difficulty: args.difficulty,\n500:         features: args.features,\n501:         allReady: args.allReady,\n502:         maxConcurrent: args.maxConcurrent ?? config.defaults.maxConcurrent,\n503:         model: args.model,\n504:         interactive: args.interactive,\n505:         dryRun: args.dryRun,\n506:         baseBranch: args.baseBranch ?? config.baseBranch,\n507:         maxRetries: args.maxRetries ?? config.defaults.maxRetries,\n508:         noTui: args.noTui,\n509:         autoPush: args.autoPush,\n510:         outputFmt: args.outputFmt,\n511:       });\n512:       break;\n513: \n514:     case \"resume\":\n515:       await cmdResume({\n516:         projectRoot: PROJECT_ROOT,\n517:         config,\n518:         maxConcurrent: args.maxConcurrent,\n519:         model: args.model,\n520:         interactive: args.interactive,\n521:         noTui: args.noTui,\n522:         autoPush: args.autoPush,\n523:         baseBranch: args.baseBranch,\n524:         maxRetries: args.maxRetries,\n525:       });\n526:       break;\n527: \n528:     case \"status\":\n529:       await cmdStatus({ projectRoot: PROJECT_ROOT, config });\n530:       break;\n531: \n532:     case \"verify\":\n533:       await cmdVerify({\n534:         projectRoot: PROJECT_ROOT,\n535:         config,\n536:         featureId: args.featureId,\n537:         model: args.model,\n538:         maxRetries: args.maxRetries,\n539:       });\n540:       break;\n541: \n542:     case \"merge\":\n543:       await cmdMerge({\n544:         projectRoot: PROJECT_ROOT,\n545:         config,\n546:         featureId: args.featureId,\n547:         autoPush: args.autoPush,\n548:         dryRun: args.dryRun,\n549:       });\n550:       break;\n551: \n552:     case \"retry\": {\n553:       if (!args.featureId) {\n554:         console.error(\"Usage: wombo retry <feature-id>\");\n555:         process.exit(1);\n556:         return;\n557:       }\n558:       await cmdRetry({\n559:         projectRoot: PROJECT_ROOT,\n560:         config,\n561:         featureId: args.featureId,\n562:         model: args.model,\n563:         interactive: args.interactive,\n564:         dryRun: args.dryRun,\n565:       });\n566:       break;\n567:     }\n568: \n569:     case \"cleanup\":\n570:       await cmdCleanup({ projectRoot: PROJECT_ROOT, config, dryRun: args.dryRun });\n571:       break;\n572: \n573:     case \"abort\": {\n574:       if (!args.featureId) {\n575:         console.error(\"Usage: wombo abort <feature-id> [--requeue] [--output json]\");\n576:         process.exit(1);\n577:         return;\n578:       }\n579:       await cmdAbort({\n580:         projectRoot: PROJECT_ROOT,\n581:         config,\n582:         featureId: args.featureId,\n583:         requeue: args.requeue,\n584:         outputFmt: args.outputFmt,\n585:       });\n586:       break;\n587:     }\n588: \n589:     case \"features\":\n590:       await handleFeaturesSubcommand(args, PROJECT_ROOT, config);\n591:       break;\n592: \n593:     default:\n594:       console.error(`Unknown command: ${args.command}`);\n595:       cmdHelp();\n596:       process.exit(1);\n597:       return;\n598:   }\n599: }\n600: \n601: // ---------------------------------------------------------------------------\n602: // Features Subcommand Router\n603: // ---------------------------------------------------------------------------\n604: \n605: async function handleFeaturesSubcommand(\n606:   args: CLIArgs,\n607:   projectRoot: string,\n608:   config: import(\"./config.js\").WomboConfig\n609: ): Promise<void> {\n610:   switch (args.subcommand) {\n611:     case \"list\":\n612:     case \"ls\":\n613:       await cmdFeaturesList({\n614:         projectRoot,\n615:         config,\n616:         status: args.status as FeatureStatus | undefined,\n617:         priority: args.priority,\n618:         difficulty: args.difficulty,\n619:         ready: args.ready,\n620:         includeArchive: args.includeArchive,\n621:         outputFmt: args.outputFmt,\n622:         fields: args.fields,\n623:       });\n624:       break;\n625: \n626:     case \"add\": {\n627:       if (!args.featureId || !args.title) {\n628:         console.error(\"Usage: wombo features add <id> <title> [--desc <desc>] [--priority <p>] [--difficulty <d>] [--effort <e>] [--depends-on <ids>]\");\n629:         process.exit(1);\n630:         return;\n631:       }\n632:       await cmdFeaturesAdd({\n633:         projectRoot,\n634:         config,\n635:         id: args.featureId,\n636:         title: args.title,\n637:         description: args.description,\n638:         priority: args.priority,\n639:         difficulty: args.difficulty,\n640:         effort: args.effort,\n641:         dependsOn: args.dependsOn,\n642:         outputFmt: args.outputFmt,\n643:         dryRun: args.dryRun,\n644:       });\n645:       break;\n646:     }\n647: \n648:     case \"set-status\": {\n649:       if (!args.featureId || !args.title) {\n650:         // title holds the second positional arg (the status value)\n651:         // If not provided via positional, check --status flag\n652:         const newStatus = args.title || args.status;\n653:         if (!args.featureId || !newStatus) {\n654:           console.error(\"Usage: wombo features set-status <feature-id> <status>\");\n655:           process.exit(1);\n656:           return;\n657:         }\n658:         await cmdFeaturesSetStatus({\n659:           projectRoot,\n660:           config,\n661:           featureId: args.featureId,\n662:           newStatus,\n663:           outputFmt: args.outputFmt,\n664:           dryRun: args.dryRun,\n665:         });\n666:       } else {\n667:         await cmdFeaturesSetStatus({\n668:           projectRoot,\n669:           config,\n670:           featureId: args.featureId,\n671:           newStatus: args.title, // second positional = new status\n672:           outputFmt: args.outputFmt,\n673:           dryRun: args.dryRun,\n674:         });\n675:       }\n676:       break;\n677:     }\n678: \n679:     case \"check\":\n680:     case \"validate\":\n681:       await cmdFeaturesCheck({ projectRoot, config });\n682:       break;\n683: \n684:     case \"archive\":\n685:       await cmdFeaturesArchive({\n686:         projectRoot,\n687:         config,\n688:         featureId: args.featureId,\n689:         dryRun: args.dryRun,\n690:       });\n691:       break;\n692: \n693:     case \"show\": {\n694:       if (!args.featureId) {\n695:         console.error(\"Usage: wombo features show <feature-id>\");\n696:         process.exit(1);\n697:         return;\n698:       }\n699:       await cmdFeaturesShow({\n700:         projectRoot,\n701:         config,\n702:         featureId: args.featureId,\n703:         outputFmt: args.outputFmt,\n704:         fields: args.fields,\n705:       });\n706:       break;\n707:     }\n708: \n709:     case \"graph\":\n710:       await cmdFeaturesGraph({\n711:         projectRoot,\n712:         config,\n713:         status: args.status as FeatureStatus | undefined,\n714:         ascii: args.ascii,\n715:         mermaid: args.mermaidRaw,\n716:         subtasks: args.graphSubtasks,\n717:         outputFmt: args.outputFmt,\n718:       });\n719:       break;\n720: \n721:     case \"help\":\n722:     case \"--help\":\n723:     case \"-h\":\n724:       cmdHelp();\n725:       break;\n726: \n727:     default:\n728:       console.error(`Unknown features subcommand: ${args.subcommand}`);\n729:       console.error(\"Run 'wombo features help' or 'wombo help' for usage.\");\n730:       process.exit(1);\n731:       return;\n732:   }\n733: }\n734: \n735: // ---------------------------------------------------------------------------\n736: // Error Handlers & Entry\n737: // ---------------------------------------------------------------------------\n738: \n739: // Global error handlers — prevent silent crashes\n740: process.on(\"uncaughtException\", (err) => {\n741:   console.error(`\\n[FATAL] Uncaught exception: ${err.message}`);\n742:   console.error(err.stack);\n743:   try {\n744:     const state = loadState(process.cwd());\n745:     if (state) saveState(process.cwd(), state);\n746:   } catch {}\n747:   process.exit(1);\n748: });\n749: \n750: process.on(\"unhandledRejection\", (reason: any) => {\n751:   console.error(`\\n[FATAL] Unhandled rejection: ${reason?.message || reason}`);\n752:   if (reason?.stack) console.error(reason.stack);\n753:   try {\n754:     const state = loadState(process.cwd());\n755:     if (state) saveState(process.cwd(), state);\n756:   } catch {}\n757:   process.exit(1);\n758: });\n759: \n760: main().catch((err) => {\n761:   console.error(\"Fatal error:\", err.message);\n762:   process.exit(1);\n763: });\n\n(End of file - total 763 lines)\n</content>","title":"src/index.ts","metadata":{"preview":"#!/usr/bin/env bun\n/**\n * index.ts — CLI entry point for the Wombo agent orchestration system.\n *\n * Usage:\n *   wombo init\n *   wombo launch --top-priority 3\n *   wombo launch --quickest-wins 5\n *   wombo launch --priority high\n *   wombo launch --difficulty easy\n *   wombo launch --features \"feat-a,feat-b\"\n *   wombo launch --all-ready\n *   wombo launch ... --max-concurrent 3 --model \"anthropic/claude-sonnet-4-20250514\"\n *   wombo launch ... --interactive\n *   wombo resume\n *   wombo status\n *   wombo verify [feature-id]\n *   wombo merge [feature-id]\n *   wombo retry <feature-id>\n *   wombo abort <feature-id> [--requeue] [--output json]","truncated":false,"loaded":[]},"time":{"start":1773351904053,"end":1773351904057}}}}
{"type":"tool_use","timestamp":1773351904118,"sessionID":"ses_31bfd801cffeMfcGlS1DXqsNs2","part":{"id":"prt_ce402a336001hvTUv7qJYIAxiD","sessionID":"ses_31bfd801cffeMfcGlS1DXqsNs2","messageID":"msg_ce4029502001S7OkWnT9sIu9o3","type":"tool","callID":"toolu_vrtx_01FcnGrrSAq3b3GziZdCZvbn","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-wave-history-export/src/lib/state.ts"},"output":"<path>/home/fulgidus/Documents/wombo-wave-history-export/src/lib/state.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * state.ts — Persistent wave state management.\n3:  *\n4:  * Responsibilities:\n5:  *   - Define the shape of .wombo-state.json\n6:  *   - Read/write state atomically\n7:  *   - Generate wave IDs\n8:  *   - Update individual agent state within a wave\n9:  */\n10: \n11: import { readFileSync, writeFileSync, existsSync, renameSync } from \"node:fs\";\n12: import { resolve } from \"node:path\";\n13: \n14: // ---------------------------------------------------------------------------\n15: // Types\n16: // ---------------------------------------------------------------------------\n17: \n18: export type AgentStatus =\n19:   | \"queued\"\n20:   | \"installing\"\n21:   | \"running\"\n22:   | \"completed\"\n23:   | \"verified\"\n24:   | \"failed\"\n25:   | \"merged\"\n26:   | \"retry\"\n27:   | \"resolving_conflict\";\n28: \n29: export interface AgentState {\n30:   feature_id: string;\n31:   branch: string;\n32:   worktree: string;\n33:   session_id: string | null;\n34:   pid: number | null;\n35:   status: AgentStatus;\n36:   activity: string | null;\n37:   activity_updated_at: string | null;\n38:   retries: number;\n39:   max_retries: number;\n40:   started_at: string | null;\n41:   completed_at: string | null;\n42:   build_passed: boolean | null;\n43:   build_output: string | null;\n44:   error: string | null;\n45:   /** Estimated effort in milliseconds (from feature's ISO 8601 duration) */\n46:   effort_estimate_ms: number | null;\n47: }\n48: \n49: export interface WaveState {\n50:   wave_id: string;\n51:   base_branch: string;\n52:   started_at: string;\n53:   updated_at: string;\n54:   max_concurrent: number;\n55:   model: string | null;\n56:   interactive: boolean;\n57:   agents: AgentState[];\n58: }\n59: \n60: // ---------------------------------------------------------------------------\n61: // Constants\n62: // ---------------------------------------------------------------------------\n63: \n64: const STATE_FILE = \".wombo-state.json\";\n65: \n66: // ---------------------------------------------------------------------------\n67: // Wave ID Generation\n68: // ---------------------------------------------------------------------------\n69: \n70: /**\n71:  * Generate a unique wave ID based on current timestamp.\n72:  * Format: wave-YYYY-MM-DD-NNN\n73:  */\n74: export function generateWaveId(): string {\n75:   const now = new Date();\n76:   const date = now.toISOString().slice(0, 10);\n77:   const seq = String(now.getHours() * 60 + now.getMinutes()).padStart(3, \"0\");\n78:   return `wave-${date}-${seq}`;\n79: }\n80: \n81: // ---------------------------------------------------------------------------\n82: // State Path\n83: // ---------------------------------------------------------------------------\n84: \n85: function statePath(projectRoot: string): string {\n86:   return resolve(projectRoot, STATE_FILE);\n87: }\n88: \n89: // ---------------------------------------------------------------------------\n90: // Read State\n91: // ---------------------------------------------------------------------------\n92: \n93: /**\n94:  * Load the current wave state from disk. Returns null if no state file exists.\n95:  */\n96: export function loadState(projectRoot: string): WaveState | null {\n97:   const p = statePath(projectRoot);\n98:   if (!existsSync(p)) return null;\n99:   try {\n100:     const raw = readFileSync(p, \"utf-8\");\n101:     return JSON.parse(raw) as WaveState;\n102:   } catch {\n103:     return null;\n104:   }\n105: }\n106: \n107: // ---------------------------------------------------------------------------\n108: // Write State\n109: // ---------------------------------------------------------------------------\n110: \n111: /**\n112:  * Save wave state to disk atomically (write to tmp then rename).\n113:  */\n114: export function saveState(projectRoot: string, state: WaveState): void {\n115:   state.updated_at = new Date().toISOString();\n116:   const p = statePath(projectRoot);\n117:   const tmp = p + \".tmp\";\n118:   writeFileSync(tmp, JSON.stringify(state, null, 2) + \"\\n\", \"utf-8\");\n119:   renameSync(tmp, p);\n120: }\n121: \n122: // ---------------------------------------------------------------------------\n123: // State Mutations\n124: // ---------------------------------------------------------------------------\n125: \n126: /**\n127:  * Create a fresh wave state.\n128:  */\n129: export function createWaveState(opts: {\n130:   baseBranch: string;\n131:   maxConcurrent: number;\n132:   model: string | null;\n133:   interactive: boolean;\n134: }): WaveState {\n135:   return {\n136:     wave_id: generateWaveId(),\n137:     base_branch: opts.baseBranch,\n138:     started_at: new Date().toISOString(),\n139:     updated_at: new Date().toISOString(),\n140:     max_concurrent: opts.maxConcurrent,\n141:     model: opts.model,\n142:     interactive: opts.interactive,\n143:     agents: [],\n144:   };\n145: }\n146: \n147: /**\n148:  * Create an initial agent state for a feature.\n149:  */\n150: export function createAgentState(\n151:   featureId: string,\n152:   branch: string,\n153:   worktreePath: string,\n154:   maxRetries: number = 2\n155: ): AgentState {\n156:   return {\n157:     feature_id: featureId,\n158:     branch,\n159:     worktree: worktreePath,\n160:     session_id: null,\n161:     pid: null,\n162:     status: \"queued\",\n163:     activity: null,\n164:     activity_updated_at: null,\n165:     retries: 0,\n166:     max_retries: maxRetries,\n167:     started_at: null,\n168:     completed_at: null,\n169:     build_passed: null,\n170:     build_output: null,\n171:     error: null,\n172:     effort_estimate_ms: null,\n173:   };\n174: }\n175: \n176: /**\n177:  * Find an agent state by feature ID.\n178:  */\n179: export function getAgent(\n180:   state: WaveState,\n181:   featureId: string\n182: ): AgentState | undefined {\n183:   return state.agents.find((a) => a.feature_id === featureId);\n184: }\n185: \n186: /**\n187:  * Update an agent's state fields.\n188:  */\n189: export function updateAgent(\n190:   state: WaveState,\n191:   featureId: string,\n192:   updates: Partial<AgentState>\n193: ): void {\n194:   const agent = state.agents.find((a) => a.feature_id === featureId);\n195:   if (!agent) throw new Error(`Agent not found for feature: ${featureId}`);\n196:   Object.assign(agent, updates);\n197: }\n198: \n199: /**\n200:  * Get counts of agents by status.\n201:  */\n202: export function agentCounts(state: WaveState): Record<AgentStatus, number> {\n203:   const counts: Record<AgentStatus, number> = {\n204:     queued: 0,\n205:     installing: 0,\n206:     running: 0,\n207:     completed: 0,\n208:     verified: 0,\n209:     failed: 0,\n210:     merged: 0,\n211:     retry: 0,\n212:     resolving_conflict: 0,\n213:   };\n214:   for (const a of state.agents) {\n215:     counts[a.status]++;\n216:   }\n217:   return counts;\n218: }\n219: \n220: /**\n221:  * Get agents that are currently running or installing.\n222:  */\n223: export function activeAgents(state: WaveState): AgentState[] {\n224:   return state.agents.filter(\n225:     (a) => a.status === \"running\" || a.status === \"installing\" || a.status === \"resolving_conflict\"\n226:   );\n227: }\n228: \n229: /**\n230:  * Get agents that are queued and ready to be launched.\n231:  */\n232: export function queuedAgents(state: WaveState): AgentState[] {\n233:   return state.agents.filter((a) => a.status === \"queued\");\n234: }\n235: \n236: /**\n237:  * Check if the wave is fully complete (no queued, installing, running, or retry agents).\n238:  */\n239: export function isWaveComplete(state: WaveState): boolean {\n240:   return state.agents.every(\n241:     (a) =>\n242:       a.status === \"completed\" ||\n243:       a.status === \"verified\" ||\n244:       a.status === \"failed\" ||\n245:       a.status === \"merged\"\n246:   );\n247: }\n\n(End of file - total 247 lines)\n</content>","title":"src/lib/state.ts","metadata":{"preview":"/**\n * state.ts — Persistent wave state management.\n *\n * Responsibilities:\n *   - Define the shape of .wombo-state.json\n *   - Read/write state atomically\n *   - Generate wave IDs\n *   - Update individual agent state within a wave\n */\n\nimport { readFileSync, writeFileSync, existsSync, renameSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type AgentStatus =\n  | \"queued\"\n  | \"installing\"","truncated":false,"loaded":[]},"time":{"start":1773351904115,"end":1773351904118}}}}
{"type":"tool_use","timestamp":1773351904337,"sessionID":"ses_31bfd801cffeMfcGlS1DXqsNs2","part":{"id":"prt_ce402a374001ubVnEzsmi9tvVK","sessionID":"ses_31bfd801cffeMfcGlS1DXqsNs2","messageID":"msg_ce4029502001S7OkWnT9sIu9o3","type":"tool","callID":"toolu_vrtx_01UQhk8WR5JvwftQj5CtW8N6","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-wave-history-export/src/config.ts"},"output":"<path>/home/fulgidus/Documents/wombo-wave-history-export/src/config.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * config.ts — Load wombo.json, merge with defaults, validate, expose typed config.\n3:  *\n4:  * The config file lives at the target project root (the repo being orchestrated).\n5:  * All values have sensible defaults so minimal config works out of the box.\n6:  */\n7: \n8: import { readFileSync, existsSync } from \"node:fs\";\n9: import { resolve } from \"node:path\";\n10: \n11: // ---------------------------------------------------------------------------\n12: // Types\n13: // ---------------------------------------------------------------------------\n14: \n15: export interface WomboConfig {\n16:   /** Path to the features YAML file relative to project root */\n17:   featuresFile: string;\n18:   /** Base branch to create feature branches from */\n19:   baseBranch: string;\n20:   /** Build configuration */\n21:   build: {\n22:     /** Build command to run in worktrees */\n23:     command: string;\n24:     /** Build timeout in milliseconds */\n25:     timeout: number;\n26:     /** Build artifact directory (for quick \"did it build?\" checks) */\n27:     artifactDir: string;\n28:   };\n29:   /** Install configuration */\n30:   install: {\n31:     /** Install command to run in worktrees */\n32:     command: string;\n33:     /** Install timeout in milliseconds */\n34:     timeout: number;\n35:   };\n36:   /** Git configuration */\n37:   git: {\n38:     /** Branch name prefix for feature branches */\n39:     branchPrefix: string;\n40:     /** Worktree directory name prefix */\n41:     worktreePrefix: string;\n42:     /** Git remote name */\n43:     remote: string;\n44:     /** Merge strategy flag */\n45:     mergeStrategy: string;\n46:   };\n47:   /** Agent configuration */\n48:   agent: {\n49:     /** Path to agent binary (null = auto-detect) */\n50:     bin: string | null;\n51:     /** Agent name to pass via --agent flag */\n52:     name: string;\n53:     /** Config files/dirs to copy into worktrees */\n54:     configFiles: string[];\n55:     /** tmux session name prefix */\n56:     tmuxPrefix: string;\n57:   };\n58:   /** Backup configuration for features file */\n59:   backup: {\n60:     /** Maximum number of timestamped backups to keep */\n61:     maxBackups: number;\n62:   };\n63:   /** Default runtime values */\n64:   defaults: {\n65:     /** Max concurrent agents */\n66:     maxConcurrent: number;\n67:     /** Max retries per agent */\n68:     maxRetries: number;\n69:   };\n70: }\n71: \n72: // ---------------------------------------------------------------------------\n73: // Defaults\n74: // ---------------------------------------------------------------------------\n75: \n76: export const DEFAULT_CONFIG: WomboConfig = {\n77:   featuresFile: \".features.yml\",\n78:   baseBranch: \"develop\",\n79:   build: {\n80:     command: \"bun run build\",\n81:     timeout: 300_000,\n82:     artifactDir: \"dist\",\n83:   },\n84:   install: {\n85:     command: \"bun install\",\n86:     timeout: 120_000,\n87:   },\n88:   git: {\n89:     branchPrefix: \"feature/\",\n90:     worktreePrefix: \"wombo-\",\n91:     remote: \"origin\",\n92:     mergeStrategy: \"--no-ff\",\n93:   },\n94:   agent: {\n95:     bin: null,\n96:     name: \"wave-worker\",\n97:     configFiles: [\".opencode/\", \"opencode.json\", \"AGENTS.md\", \"agent/\"],\n98:     tmuxPrefix: \"wombo\",\n99:   },\n100:   backup: {\n101:     maxBackups: 5,\n102:   },\n103:   defaults: {\n104:     maxConcurrent: 6,\n105:     maxRetries: 2,\n106:   },\n107: };\n108: \n109: // ---------------------------------------------------------------------------\n110: // Config File Name\n111: // ---------------------------------------------------------------------------\n112: \n113: export const CONFIG_FILE = \"wombo.json\";\n114: \n115: // ---------------------------------------------------------------------------\n116: // Loader\n117: // ---------------------------------------------------------------------------\n118: \n119: /**\n120:  * Deep-merge source into target. Only merges plain objects, not arrays.\n121:  */\n122: function deepMerge<T extends Record<string, any>>(target: T, source: Partial<T>): T {\n123:   const result = { ...target };\n124:   for (const key of Object.keys(source) as (keyof T)[]) {\n125:     const srcVal = source[key];\n126:     const tgtVal = target[key];\n127:     if (\n128:       srcVal !== undefined &&\n129:       srcVal !== null &&\n130:       typeof srcVal === \"object\" &&\n131:       !Array.isArray(srcVal) &&\n132:       typeof tgtVal === \"object\" &&\n133:       !Array.isArray(tgtVal) &&\n134:       tgtVal !== null\n135:     ) {\n136:       result[key] = deepMerge(tgtVal as any, srcVal as any);\n137:     } else if (srcVal !== undefined) {\n138:       result[key] = srcVal as T[keyof T];\n139:     }\n140:   }\n141:   return result;\n142: }\n143: \n144: /**\n145:  * Load wombo.json from the given project root and merge with defaults.\n146:  * Returns the full config. If no config file exists, returns defaults.\n147:  */\n148: export function loadConfig(projectRoot: string): WomboConfig {\n149:   const configPath = resolve(projectRoot, CONFIG_FILE);\n150: \n151:   if (!existsSync(configPath)) {\n152:     return { ...DEFAULT_CONFIG };\n153:   }\n154: \n155:   try {\n156:     const raw = readFileSync(configPath, \"utf-8\");\n157:     const partial = JSON.parse(raw) as Partial<WomboConfig>;\n158:     return deepMerge(DEFAULT_CONFIG, partial);\n159:   } catch (err: any) {\n160:     throw new Error(`Failed to load ${CONFIG_FILE}: ${err.message}`);\n161:   }\n162: }\n163: \n164: /**\n165:  * Resolve the agent binary path. Priority:\n166:  *   1. config.agent.bin (explicit)\n167:  *   2. OPENCODE_BIN env var\n168:  *   3. ~/.opencode/bin/opencode (default install location)\n169:  */\n170: export function resolveAgentBin(config: WomboConfig): string {\n171:   if (config.agent.bin) return config.agent.bin;\n172:   if (process.env.OPENCODE_BIN) return process.env.OPENCODE_BIN;\n173:   return resolve(process.env.HOME || \"~\", \".opencode/bin/opencode\");\n174: }\n175: \n176: /**\n177:  * Validate the config for obvious issues. Throws on error.\n178:  */\n179: export function validateConfig(config: WomboConfig): void {\n180:   if (!config.featuresFile) {\n181:     throw new Error(\"config.featuresFile must be a non-empty string\");\n182:   }\n183:   if (!config.baseBranch) {\n184:     throw new Error(\"config.baseBranch must be a non-empty string\");\n185:   }\n186:   if (!config.build.command) {\n187:     throw new Error(\"config.build.command must be a non-empty string\");\n188:   }\n189:   if (!config.install.command) {\n190:     throw new Error(\"config.install.command must be a non-empty string\");\n191:   }\n192:   if (!config.git.branchPrefix) {\n193:     throw new Error(\"config.git.branchPrefix must be a non-empty string\");\n194:   }\n195:   if (!config.git.worktreePrefix) {\n196:     throw new Error(\"config.git.worktreePrefix must be a non-empty string\");\n197:   }\n198:   if (config.defaults.maxConcurrent < 1) {\n199:     throw new Error(\"config.defaults.maxConcurrent must be >= 1\");\n200:   }\n201:   if (config.defaults.maxRetries < 0) {\n202:     throw new Error(\"config.defaults.maxRetries must be >= 0\");\n203:   }\n204:   if (config.backup.maxBackups < 0) {\n205:     throw new Error(\"config.backup.maxBackups must be >= 0\");\n206:   }\n207: }\n208: \n209: /**\n210:  * Generate the default wombo.json content string (for `wombo init`).\n211:  */\n212: export function generateDefaultConfig(): string {\n213:   return JSON.stringify(DEFAULT_CONFIG, null, 2) + \"\\n\";\n214: }\n\n(End of file - total 214 lines)\n</content>","title":"src/config.ts","metadata":{"preview":"/**\n * config.ts — Load wombo.json, merge with defaults, validate, expose typed config.\n *\n * The config file lives at the target project root (the repo being orchestrated).\n * All values have sensible defaults so minimal config works out of the box.\n */\n\nimport { readFileSync, existsSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface WomboConfig {\n  /** Path to the features YAML file relative to project root */\n  featuresFile: string;\n  /** Base branch to create feature branches from */\n  baseBranch: string;\n  /** Build configuration */","truncated":false,"loaded":[]},"time":{"start":1773351904331,"end":1773351904336}}}}
{"type":"tool_use","timestamp":1773351904858,"sessionID":"ses_31bfd801cffeMfcGlS1DXqsNs2","part":{"id":"prt_ce402a44d001kmyukY4WLB1iUP","sessionID":"ses_31bfd801cffeMfcGlS1DXqsNs2","messageID":"msg_ce4029502001S7OkWnT9sIu9o3","type":"tool","callID":"toolu_vrtx_01Jb93q2dBxLxmNsq4L2QPam","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-wave-history-export/src/commands/cleanup.ts"},"output":"<path>/home/fulgidus/Documents/wombo-wave-history-export/src/commands/cleanup.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * cleanup.ts — Remove all wave-related resources.\n3:  *\n4:  * Usage: wombo cleanup\n5:  *\n6:  * Kills tmux sessions, removes worktrees, removes state and log files.\n7:  */\n8: \n9: import { existsSync, unlinkSync, rmSync } from \"node:fs\";\n10: import { execSync } from \"node:child_process\";\n11: import { resolve } from \"node:path\";\n12: import type { WomboConfig } from \"../config.js\";\n13: import { killAllTmuxSessions } from \"../lib/launcher.js\";\n14: import { cleanupAllWorktrees } from \"../lib/worktree.js\";\n15: \n16: export interface CleanupOptions {\n17:   projectRoot: string;\n18:   config: WomboConfig;\n19:   dryRun?: boolean;\n20: }\n21: \n22: export async function cmdCleanup(opts: CleanupOptions): Promise<void> {\n23:   const { projectRoot, config } = opts;\n24: \n25:   // Dry-run: show what would be cleaned up without doing it\n26:   if (opts.dryRun) {\n27:     console.log(\"\\n[dry-run] Would perform the following cleanup:\\n\");\n28: \n29:     // List tmux sessions that would be killed\n30:     try {\n31:       const sessions = execSync(\"tmux list-sessions -F '#{session_name}'\", {\n32:         encoding: \"utf-8\",\n33:       }).trim();\n34:       const prefix = config.agent.tmuxPrefix;\n35:       const matching = sessions\n36:         .split(\"\\n\")\n37:         .filter((s) => s.startsWith(prefix));\n38:       console.log(`  tmux sessions to kill: ${matching.length}`);\n39:       for (const s of matching) {\n40:         console.log(`    ${s}`);\n41:       }\n42:     } catch {\n43:       console.log(\"  tmux sessions to kill: 0 (no tmux server running)\");\n44:     }\n45: \n46:     // List worktrees that would be removed\n47:     try {\n48:       const worktrees = execSync(\"git worktree list --porcelain\", {\n49:         cwd: projectRoot,\n50:         encoding: \"utf-8\",\n51:       }).trim();\n52:       const prefix = config.git.worktreePrefix;\n53:       const matching = worktrees\n54:         .split(\"\\n\")\n55:         .filter((line) => line.startsWith(\"worktree \") && line.includes(prefix))\n56:         .map((line) => line.replace(\"worktree \", \"\"));\n57:       console.log(`  worktrees to remove: ${matching.length}`);\n58:       for (const w of matching) {\n59:         console.log(`    ${w}`);\n60:       }\n61:     } catch {\n62:       console.log(\"  worktrees to remove: 0\");\n63:     }\n64: \n65:     const statePath = resolve(projectRoot, \".wombo-state.json\");\n66:     const logDir = resolve(projectRoot, \".wombo-logs\");\n67:     if (existsSync(statePath)) console.log(\"  Would remove: .wombo-state.json\");\n68:     if (existsSync(logDir)) console.log(\"  Would remove: .wombo-logs/\");\n69: \n70:     return;\n71:   }\n72: \n73:   console.log(\"\\n--- Wombo: Cleanup ---\\n\");\n74: \n75:   // Kill tmux sessions\n76:   const killed = killAllTmuxSessions(config);\n77:   console.log(`Killed ${killed} tmux session(s)`);\n78: \n79:   // Remove worktrees\n80:   const removed = cleanupAllWorktrees(projectRoot, config);\n81:   console.log(`Removed ${removed} worktree(s)`);\n82: \n83:   // List remaining feature branches\n84:   try {\n85:     const branchPattern = `\"${config.git.branchPrefix}*\"`;\n86:     const branches = execSync(`git branch --list ${branchPattern}`, {\n87:       cwd: projectRoot,\n88:       encoding: \"utf-8\",\n89:     }).trim();\n90:     if (branches) {\n91:       console.log(`\\nRemaining feature branches:\\n${branches}`);\n92:       console.log('Use \"git branch -D <branch>\" to remove manually.');\n93:     }\n94:   } catch {}\n95: \n96:   // Remove state file\n97:   const statePath = resolve(projectRoot, \".wombo-state.json\");\n98:   if (existsSync(statePath)) {\n99:     unlinkSync(statePath);\n100:     console.log(\"Removed .wombo-state.json\");\n101:   }\n102: \n103:   // Remove log directory\n104:   const logDir = resolve(projectRoot, \".wombo-logs\");\n105:   if (existsSync(logDir)) {\n106:     rmSync(logDir, { recursive: true, force: true });\n107:     console.log(\"Removed .wombo-logs/\");\n108:   }\n109: \n110:   console.log(\"\\nCleanup complete.\");\n111: }\n\n(End of file - total 111 lines)\n</content>","title":"src/commands/cleanup.ts","metadata":{"preview":"/**\n * cleanup.ts — Remove all wave-related resources.\n *\n * Usage: wombo cleanup\n *\n * Kills tmux sessions, removes worktrees, removes state and log files.\n */\n\nimport { existsSync, unlinkSync, rmSync } from \"node:fs\";\nimport { execSync } from \"node:child_process\";\nimport { resolve } from \"node:path\";\nimport type { WomboConfig } from \"../config.js\";\nimport { killAllTmuxSessions } from \"../lib/launcher.js\";\nimport { cleanupAllWorktrees } from \"../lib/worktree.js\";\n\nexport interface CleanupOptions {\n  projectRoot: string;\n  config: WomboConfig;\n  dryRun?: boolean;\n}","truncated":false,"loaded":[]},"time":{"start":1773351904853,"end":1773351904857}}}}
{"type":"text","timestamp":1773351905260,"sessionID":"ses_31bfd801cffeMfcGlS1DXqsNs2","part":{"id":"prt_ce4029b2c001ng5y9O38gJWUpv","sessionID":"ses_31bfd801cffeMfcGlS1DXqsNs2","messageID":"msg_ce4029502001S7OkWnT9sIu9o3","type":"text","text":"Now let me read the key source files to understand the codebase patterns:","time":{"start":1773351905259,"end":1773351905259}}}
{"type":"tool_use","timestamp":1773351905281,"sessionID":"ses_31bfd801cffeMfcGlS1DXqsNs2","part":{"id":"prt_ce402a657001paL7hREIFS7Wlb","sessionID":"ses_31bfd801cffeMfcGlS1DXqsNs2","messageID":"msg_ce4029502001S7OkWnT9sIu9o3","type":"tool","callID":"toolu_vrtx_01X1iDtua1PGK2YLiVTaS3Dk","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-wave-history-export/src/commands/launch.ts"},"output":"<path>/home/fulgidus/Documents/wombo-wave-history-export/src/commands/launch.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * launch.ts — Launch a wave of agents.\n3:  *\n4:  * Usage: wombo launch [selection options] [launch options]\n5:  *\n6:  * This is the primary entry point for starting a new wave. It selects features\n7:  * from the features file, creates a wave state, sets up worktrees, and launches\n8:  * agent processes (either headless or interactive via tmux).\n9:  *\n10:  * IMPORTANT: This file also exports shared helper functions that are reused\n11:  * by resume.ts and other commands:\n12:  *   - launchSingleHeadless\n13:  *   - handleBuildVerification\n14:  *   - handleRetry\n15:  *   - launchNextQueued\n16:  */\n17: \n18: import { execSync } from \"node:child_process\";\n19: import type { WomboConfig } from \"../config.js\";\n20: import type { Feature, SelectionOptions, Priority, Difficulty } from \"../lib/features.js\";\n21: import { loadFeatures, selectFeatures, parseDurationMinutes, saveFeatures } from \"../lib/features.js\";\n22: import {\n23:   loadState,\n24:   saveState,\n25:   createWaveState,\n26:   createAgentState,\n27:   updateAgent,\n28:   activeAgents,\n29:   queuedAgents,\n30:   isWaveComplete,\n31:   type WaveState,\n32:   type AgentState,\n33: } from \"../lib/state.js\";\n34: import {\n35:   createWorktree,\n36:   installDeps,\n37:   featureBranchName,\n38:   worktreePath,\n39:   worktreeReady,\n40:   branchHasChanges,\n41:   branchExists,\n42:   removeWorktree,\n43:   log as wtLog,\n44: } from \"../lib/worktree.js\";\n45: import { generatePrompt, generateConflictResolutionPrompt } from \"../lib/prompt.js\";\n46: import {\n47:   launchHeadless,\n48:   retryHeadless,\n49:   launchInteractive,\n50:   retryInteractive,\n51:   launchConflictResolver,\n52:   isProcessRunning,\n53: } from \"../lib/launcher.js\";\n54: import { ProcessMonitor } from \"../lib/monitor.js\";\n55: import { runBuild } from \"../lib/verifier.js\";\n56: import { mergeBranch, mergeBaseIntoFeature, pushBaseBranch } from \"../lib/merger.js\";\n57: import {\n58:   printDashboard,\n59:   printFeatureSelection,\n60:   printAgentUpdate,\n61: } from \"../lib/ui.js\";\n62: import { WomboTUI } from \"../lib/tui.js\";\n63: import { ensureAgentDefinition } from \"../lib/templates.js\";\n64: import { outputError, type OutputFormat } from \"../lib/output.js\";\n65: \n66: // ---------------------------------------------------------------------------\n67: // Types\n68: // ---------------------------------------------------------------------------\n69: \n70: export interface LaunchCommandOptions {\n71:   projectRoot: string;\n72:   config: WomboConfig;\n73:   // Selection\n74:   topPriority?: number;\n75:   quickestWins?: number;\n76:   priority?: Priority;\n77:   difficulty?: Difficulty;\n78:   features?: string[];\n79:   allReady?: boolean;\n80:   // Launch\n81:   maxConcurrent: number;\n82:   model?: string;\n83:   interactive: boolean;\n84:   dryRun: boolean;\n85:   baseBranch: string;\n86:   maxRetries: number;\n87:   noTui: boolean;\n88:   autoPush: boolean;\n89:   // Output\n90:   outputFmt?: OutputFormat;\n91: }\n92: \n93: // ---------------------------------------------------------------------------\n94: // Shared Helpers (exported for resume.ts and others)\n95: // ---------------------------------------------------------------------------\n96: \n97: /**\n98:  * Mark a feature as done in the features file after a successful merge.\n99:  * Updates status to \"done\", completion to 100, and sets ended_at.\n100:  *\n101:  * GUARD: Verifies that the feature branch has actually been merged into\n102:  * baseBranch before allowing the status change. This prevents callers\n103:  * from accidentally marking verified-but-unmerged features as done.\n104:  */\n105: export function markFeatureDone(\n106:   projectRoot: string,\n107:   featureId: string,\n108:   config: WomboConfig,\n109:   baseBranch: string\n110: ): void {\n111:   try {\n112:     // Verify the feature branch was actually merged into base\n113:     const branch = featureBranchName(featureId, config);\n114:     try {\n115:       execSync(`git merge-base --is-ancestor \"${branch}\" \"${baseBranch}\"`, {\n116:         cwd: projectRoot,\n117:         stdio: \"pipe\",\n118:       });\n119:     } catch {\n120:       // git merge-base --is-ancestor exits non-zero if NOT an ancestor\n121:       console.error(\n122:         `Warning: ${featureId} branch \"${branch}\" is not merged into \"${baseBranch}\" — refusing to mark as done`\n123:       );\n124:       return;\n125:     }\n126: \n127:     const data = loadFeatures(projectRoot, config);\n128:     const feature = data.features.find((f) => f.id === featureId);\n129:     if (feature && feature.status !== \"done\") {\n130:       feature.status = \"done\";\n131:       feature.completion = 100;\n132:       feature.ended_at = new Date().toISOString();\n133:       saveFeatures(projectRoot, config, data);\n134:     }\n135:   } catch (err: any) {\n136:     // Non-fatal — log but don't crash the wave\n137:     console.error(`Warning: failed to update feature status for ${featureId}: ${err.message}`);\n138:   }\n139: }\n140: \n141: /**\n142:  * Launch a single agent in headless mode.\n143:  * Sets up worktree, installs deps, generates prompt, launches agent process.\n144:  */\n145: export async function launchSingleHeadless(\n146:   projectRoot: string,\n147:   state: WaveState,\n148:   agent: AgentState,\n149:   feature: Feature,\n150:   monitor: ProcessMonitor,\n151:   config: WomboConfig,\n152:   model?: string\n153: ): Promise<void> {\n154:   updateAgent(state, agent.feature_id, {\n155:     status: \"installing\",\n156:     started_at: new Date().toISOString(),\n157:     activity: \"setting up worktree...\",\n158:   });\n159:   saveState(projectRoot, state);\n160: \n161:   try {\n162:     // Skip worktree setup if already ready (resume case)\n163:     if (worktreeReady(agent.worktree)) {\n164:       wtLog(agent.feature_id, \"worktree already exists, skipping setup\");\n165:     } else {\n166:       // Create worktree (async — doesn't block other agents)\n167:       await createWorktree(projectRoot, feature.id, state.base_branch, config);\n168: \n169:       // Install dependencies (async)\n170:       updateAgent(state, agent.feature_id, { activity: \"installing deps...\" });\n171:       await installDeps(agent.worktree, feature.id, config);\n172:     }\n173: \n174:     // Generate prompt\n175:     const prompt = generatePrompt(feature, state.base_branch, config);\n176: \n177:     // Launch agent\n178:     wtLog(agent.feature_id, \"launching agent...\");\n179:     const result = launchHeadless({\n180:       worktreePath: agent.worktree,\n181:       featureId: feature.id,\n182:       prompt,\n183:       model,\n184:       config,\n185:     });\n186: \n187:     updateAgent(state, agent.feature_id, {\n188:       status: \"running\",\n189:       pid: result.pid,\n190:       activity: \"starting...\",\n191:     });\n192:     saveState(projectRoot, state);\n193: \n194:     monitor.addProcess(feature.id, result.process);\n195:     wtLog(agent.feature_id, `running (PID: ${result.pid})`);\n196:   } catch (err: any) {\n197:     updateAgent(state, agent.feature_id, {\n198:       status: \"failed\",\n199:       error: err.message,\n200:       activity: null,\n201:       completed_at: new Date().toISOString(),\n202:     });\n203:     saveState(projectRoot, state);\n204:     wtLog(agent.feature_id, `SETUP FAILED: ${err.message.split(\"\\n\")[0]}`);\n205:   }\n206: }\n207: \n208: /**\n209:  * Handle build verification after agent completion.\n210:  * Runs build, auto-merges on pass, retries on failure if retries remain.\n211:  *\n212:  * ASYNC — runs build and merge without blocking the event loop.\n213:  */\n214: export async function handleBuildVerification(\n215:   projectRoot: string,\n216:   state: WaveState,\n217:   agent: AgentState,\n218:   feature: Feature,\n219:   config: WomboConfig,\n220:   model?: string,\n221:   monitor?: ProcessMonitor\n222: ): Promise<void> {\n223:   try {\n224:     printAgentUpdate(agent, \"verifying build...\");\n225: \n226:     const buildResult = await runBuild(agent.worktree, config);\n227: \n228:     if (buildResult.passed) {\n229:       updateAgent(state, agent.feature_id, {\n230:         status: \"verified\",\n231:         build_passed: true,\n232:         build_output: null,\n233:       });\n234:       saveState(projectRoot, state);\n235:       printAgentUpdate(agent, `BUILD PASSED (${Math.round(buildResult.durationMs / 1000)}s)`);\n236: \n237:       // Auto-merge: attempt merge + conflict resolution\n238:       await attemptMerge(projectRoot, state, agent, feature, config, model);\n239:     } else {\n240:       if (agent.retries < agent.max_retries) {\n241:         updateAgent(state, agent.feature_id, {\n242:           status: \"retry\",\n243:           retries: agent.retries + 1,\n244:           build_passed: false,\n245:           build_output: buildResult.errorSummary,\n246:         });\n247:         saveState(projectRoot, state);\n248:         printAgentUpdate(\n249:           agent,\n250:           `BUILD FAILED — retrying (${agent.retries}/${agent.max_retries})`\n251:         );\n252: \n253:         // Retry with build errors\n254:         if (agent.session_id) {\n255:           const retryResult = retryHeadless({\n256:             worktreePath: agent.worktree,\n257:             featureId: agent.feature_id,\n258:             sessionId: agent.session_id,\n259:             buildErrors: buildResult.errorSummary,\n260:             model,\n261:             config,\n262:           });\n263: \n264:           updateAgent(state, agent.feature_id, {\n265:             status: \"running\",\n266:             pid: retryResult.pid,\n267:           });\n268:           saveState(projectRoot, state);\n269: \n270:           // Add retry process to monitor so events are tracked\n271:           if (monitor) {\n272:             monitor.addProcess(agent.feature_id, retryResult.process);\n273:           }\n274:         }\n275:       } else {\n276:         updateAgent(state, agent.feature_id, {\n277:           status: \"failed\",\n278:           build_passed: false,\n279:           build_output: buildResult.errorSummary,\n280:           error: `Build failed after ${agent.max_retries} retries`,\n281:           completed_at: new Date().toISOString(),\n282:         });\n283:         saveState(projectRoot, state);\n284:         printAgentUpdate(agent, \"BUILD FAILED — max retries reached\");\n285:       }\n286:     }\n287:   } catch (err: any) {\n288:     // Catch-all — never let build verification crash the process\n289:     printAgentUpdate(agent, `VERIFY ERROR: ${err.message?.slice(0, 100)}`);\n290:     updateAgent(state, agent.feature_id, {\n291:       status: \"failed\",\n292:       error: `Build verification error: ${err.message}`,\n293:       completed_at: new Date().toISOString(),\n294:     });\n295:     saveState(projectRoot, state);\n296:   }\n297: }\n298: \n299: /**\n300:  * Attempt to merge a verified agent's branch into the base branch.\n301:  *\n302:  * Handles conflict detection, base-into-feature merge, and resolver agent\n303:  * launch. Extracted from handleBuildVerification so it can be called\n304:  * independently (e.g., from resume's sequential merge phase).\n305:  */\n306: export async function attemptMerge(\n307:   projectRoot: string,\n308:   state: WaveState,\n309:   agent: AgentState,\n310:   feature: Feature,\n311:   config: WomboConfig,\n312:   model?: string,\n313: ): Promise<void> {\n314:   printAgentUpdate(agent, \"auto-merging...\");\n315:   try {\n316:     const mergeResult = await mergeBranch(projectRoot, agent.branch, state.base_branch, config);\n317: \n318:     if (mergeResult.success) {\n319:       updateAgent(state, agent.feature_id, {\n320:         status: \"merged\",\n321:         completed_at: new Date().toISOString(),\n322:       });\n323:       saveState(projectRoot, state);\n324:       printAgentUpdate(agent, `MERGED (${mergeResult.commitHash?.slice(0, 7)})`);\n325: \n326:       // Mark feature as done in .features.yml so it won't be re-selected\n327:       markFeatureDone(projectRoot, agent.feature_id, config, state.base_branch);\n328: \n329:       // Clean up worktree after successful merge\n330:       try {\n331:         removeWorktree(projectRoot, agent.worktree, true);\n332:         printAgentUpdate(agent, \"worktree and branch removed\");\n333:       } catch {\n334:         // Not critical — worktree cleanup is best-effort\n335:       }\n336:     } else {\n337:       // Merge failed — attempt automatic conflict resolution\n338:       const mergeError = mergeResult.error ?? \"Unknown merge error\";\n339:       printAgentUpdate(agent, `MERGE CONFLICT — attempting resolution...`);\n340: \n341:       try {\n342:         // Merge base INTO the feature worktree to create conflict markers\n343:         const conflictResult = await mergeBaseIntoFeature(\n344:           agent.worktree,\n345:           state.base_branch,\n346:           config\n347:         );\n348: \n349:         if (conflictResult.error && !conflictResult.conflicting) {\n350:           printAgentUpdate(agent, `CONFLICT SETUP FAILED: ${conflictResult.error.slice(0, 100)}`);\n351:           return; // Leave as \"verified\" for manual resolution\n352:         }\n353: \n354:         if (!conflictResult.conflicting) {\n355:           // Base merged cleanly into feature — retry merge into base.\n356:           printAgentUpdate(agent, \"base merged cleanly into feature — retrying merge...\");\n357:           const retryMerge = await mergeBranch(projectRoot, agent.branch, state.base_branch, config);\n358:           if (retryMerge.success) {\n359:             updateAgent(state, agent.feature_id, {\n360:               status: \"merged\",\n361:               completed_at: new Date().toISOString(),\n362:             });\n363:             saveState(projectRoot, state);\n364:             printAgentUpdate(agent, `MERGED after rebase (${retryMerge.commitHash?.slice(0, 7)})`);\n365:             markFeatureDone(projectRoot, agent.feature_id, config, state.base_branch);\n366:             try {\n367:               removeWorktree(projectRoot, agent.worktree, true);\n368:             } catch {}\n369:             return;\n370:           }\n371: \n372:           // Retry still failed — launch resolver agent\n373:           printAgentUpdate(agent, `retry merge still failed — launching resolver agent...`);\n374: \n375:           const secondConflict = await mergeBaseIntoFeature(\n376:             agent.worktree,\n377:             state.base_branch,\n378:             config\n379:           );\n380: \n381:           const conflictFiles = secondConflict.conflicting\n382:             ? secondConflict.files\n383:             : [\"(unknown — merge direction mismatch)\"];\n384:           const resolverMergeError = retryMerge.error ?? mergeError;\n385: \n386:           await launchResolverAndRetryMerge(\n387:             projectRoot, state, agent, feature, config, model,\n388:             resolverMergeError, conflictFiles\n389:           );\n390:           return;\n391:         }\n392: \n393:         // There are real conflicts — launch a resolver agent\n394:         printAgentUpdate(\n395:           agent,\n396:           `${conflictResult.files.length} conflicting file(s): ${conflictResult.files.join(\", \")}`\n397:         );\n398: \n399:         await launchResolverAndRetryMerge(\n400:           projectRoot, state, agent, feature, config, model,\n401:           mergeError, conflictResult.files\n402:         );\n403:       } catch (conflictErr: any) {\n404:         printAgentUpdate(agent, `CONFLICT RESOLUTION ERROR: ${conflictErr.message?.slice(0, 100)}`);\n405:         // Leave as \"verified\" for manual resolution\n406:       }\n407:     }\n408:   } catch (mergeErr: any) {\n409:     printAgentUpdate(agent, `AUTO-MERGE ERROR: ${mergeErr.message?.slice(0, 100)}`);\n410:   }\n411: }\n412: \n413: /**\n414:  * Launch a conflict resolver agent, wait for it to finish, re-verify build,\n415:  * and retry the merge. Extracted to avoid duplicating the resolver flow.\n416:  */\n417: async function launchResolverAndRetryMerge(\n418:   projectRoot: string,\n419:   state: WaveState,\n420:   agent: AgentState,\n421:   feature: Feature,\n422:   config: WomboConfig,\n423:   model: string | undefined,\n424:   mergeError: string,\n425:   conflictFiles: string[]\n426: ): Promise<void> {\n427:   const conflictPrompt = generateConflictResolutionPrompt(\n428:     feature,\n429:     state.base_branch,\n430:     mergeError,\n431:     config\n432:   );\n433: \n434:   updateAgent(state, agent.feature_id, {\n435:     status: \"resolving_conflict\",\n436:     activity: `resolving ${conflictFiles.length} conflict(s)...`,\n437:   });\n438:   saveState(projectRoot, state);\n439: \n440:   const resolverResult = launchConflictResolver({\n441:     worktreePath: agent.worktree,\n442:     featureId: agent.feature_id,\n443:     prompt: conflictPrompt,\n444:     model,\n445:     config,\n446:   });\n447: \n448:   updateAgent(state, agent.feature_id, {\n449:     pid: resolverResult.pid,\n450:   });\n451:   saveState(projectRoot, state);\n452: \n453:   // Wait for the resolver process to complete, then re-verify and retry merge.\n454:   // We intentionally do NOT add the resolver to the ProcessMonitor because\n455:   // the monitor's onComplete callback would trigger handleBuildVerification\n456:   // again, causing infinite recursion. Instead we await the process directly.\n457:   const resolverExitCode = await new Promise<number | null>((resolve) => {\n458:     resolverResult.process.on(\"exit\", (code) => resolve(code));\n459:     resolverResult.process.on(\"error\", () => resolve(null));\n460:   });\n461: \n462:   printAgentUpdate(agent, `conflict resolver exited (code ${resolverExitCode}) — re-verifying build...`);\n463: \n464:   // Re-verify build after conflict resolution\n465:   const rebuildResult = await runBuild(agent.worktree, config);\n466: \n467:   if (!rebuildResult.passed) {\n468:     printAgentUpdate(agent, `POST-CONFLICT BUILD FAILED`);\n469:     updateAgent(state, agent.feature_id, {\n470:       status: \"failed\",\n471:       build_passed: false,\n472:       build_output: rebuildResult.errorSummary,\n473:       error: \"Build failed after conflict resolution\",\n474:       completed_at: new Date().toISOString(),\n475:     });\n476:     saveState(projectRoot, state);\n477:     return;\n478:   }\n479: \n480:   printAgentUpdate(agent, \"post-conflict build passed — retrying merge...\");\n481: \n482:   const retryMerge = await mergeBranch(\n483:     projectRoot,\n484:     agent.branch,\n485:     state.base_branch,\n486:     config\n487:   );\n488: \n489:   if (retryMerge.success) {\n490:     updateAgent(state, agent.feature_id, {\n491:       status: \"merged\",\n492:       build_passed: true,\n493:       completed_at: new Date().toISOString(),\n494:     });\n495:     saveState(projectRoot, state);\n496:     printAgentUpdate(agent, `MERGED after conflict resolution (${retryMerge.commitHash?.slice(0, 7)})`);\n497:     markFeatureDone(projectRoot, agent.feature_id, config, state.base_branch);\n498:     try {\n499:       removeWorktree(projectRoot, agent.worktree, true);\n500:     } catch {}\n501:   } else {\n502:     printAgentUpdate(agent, `POST-CONFLICT MERGE FAILED: ${retryMerge.error}`);\n503:     updateAgent(state, agent.feature_id, {\n504:       status: \"failed\",\n505:       error: `Merge still failed after conflict resolution: ${retryMerge.error}`,\n506:       completed_at: new Date().toISOString(),\n507:     });\n508:     saveState(projectRoot, state);\n509:   }\n510: }\n511: \n512: /**\n513:  * Handle retry of a failed agent (error-based, not build-based).\n514:  */\n515: export function handleRetry(\n516:   projectRoot: string,\n517:   state: WaveState,\n518:   agent: AgentState,\n519:   monitor: ProcessMonitor,\n520:   config: WomboConfig,\n521:   model?: string\n522: ): void {\n523:   if (!agent.session_id || !agent.error) return;\n524: \n525:   const retryResult = retryHeadless({\n526:     worktreePath: agent.worktree,\n527:     featureId: agent.feature_id,\n528:     sessionId: agent.session_id,\n529:     buildErrors: agent.error,\n530:     model,\n531:     config,\n532:   });\n533: \n534:   updateAgent(state, agent.feature_id, {\n535:     status: \"running\",\n536:     pid: retryResult.pid,\n537:   });\n538:   saveState(projectRoot, state);\n539: \n540:   monitor.addProcess(agent.feature_id, retryResult.process);\n541: }\n542: \n543: /**\n544:  * Launch the next queued agent if capacity allows.\n545:  */\n546: export function launchNextQueued(\n547:   projectRoot: string,\n548:   state: WaveState,\n549:   featureMap: Map<string, Feature>,\n550:   monitor: ProcessMonitor,\n551:   config: WomboConfig,\n552:   model?: string\n553: ): void {\n554:   const active = activeAgents(state);\n555:   const queued = queuedAgents(state);\n556: \n557:   if (active.length < state.max_concurrent && queued.length > 0) {\n558:     const next = queued[0];\n559:     const feature = featureMap.get(next.feature_id);\n560:     if (feature) {\n561:       launchSingleHeadless(projectRoot, state, next, feature, monitor, config, model);\n562:     }\n563:   }\n564: }\n565: \n566: // ---------------------------------------------------------------------------\n567: // Headless Wave Launch\n568: // ---------------------------------------------------------------------------\n569: \n570: async function launchWaveHeadless(\n571:   projectRoot: string,\n572:   state: WaveState,\n573:   features: Feature[],\n574:   opts: LaunchCommandOptions\n575: ): Promise<void> {\n576:   const { config, model } = opts;\n577:   const featureMap = new Map(features.map((f) => [f.id, f]));\n578: \n579:   const monitor = new ProcessMonitor(projectRoot, {\n580:     onSessionId: (featureId, sessionId) => {\n581:       updateAgent(state, featureId, { session_id: sessionId });\n582:       saveState(projectRoot, state);\n583:     },\n584:     onComplete: (featureId) => {\n585:       updateAgent(state, featureId, {\n586:         status: \"completed\",\n587:         completed_at: new Date().toISOString(),\n588:       });\n589:       saveState(projectRoot, state);\n590: \n591:       // Run build verification — fire-and-forget\n592:       const agent = state.agents.find((a) => a.feature_id === featureId)!;\n593:       handleBuildVerification(projectRoot, state, agent, featureMap.get(featureId)!, config, model, monitor)\n594:         .then(() => launchNextQueued(projectRoot, state, featureMap, monitor, config, model))\n595:         .catch((err) => {\n596:           wtLog(featureId, `BUILD VERIFICATION UNHANDLED ERROR: ${err.message}`);\n597:           launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n598:         });\n599:     },\n600:     onError: (featureId, error) => {\n601:       const agent = state.agents.find((a) => a.feature_id === featureId)!;\n602:       if (agent.retries < agent.max_retries) {\n603:         updateAgent(state, featureId, {\n604:           status: \"retry\",\n605:           retries: agent.retries + 1,\n606:           error,\n607:         });\n608:         saveState(projectRoot, state);\n609: \n610:         // Retry\n611:         handleRetry(projectRoot, state, agent, monitor, config, model);\n612:       } else {\n613:         updateAgent(state, featureId, {\n614:           status: \"failed\",\n615:           error,\n616:           completed_at: new Date().toISOString(),\n617:         });\n618:         saveState(projectRoot, state);\n619:       }\n620: \n621:       // Try to launch next queued agent\n622:       launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n623:     },\n624:     onOutput: (_featureId, _data) => {\n625:       // Raw output — logged to file by ProcessMonitor\n626:     },\n627:     onActivity: (featureId, activity) => {\n628:       updateAgent(state, featureId, {\n629:         activity,\n630:         activity_updated_at: new Date().toISOString(),\n631:       });\n632:       // Don't save to disk on every activity — too frequent.\n633:     },\n634:   });\n635: \n636:   // Create the TUI — it will auto-refresh and show activity from the monitor\n637:   const tuiRef = { current: null as WomboTUI | null };\n638:   const startTUI = () => {\n639:     tuiRef.current = new WomboTUI({\n640:       state,\n641:       monitor,\n642:       projectRoot,\n643:       interactive: false,\n644:       config,\n645:       onQuit: () => {\n646:         // Same as SIGINT — save state and exit\n647:         for (const agent of state.agents) {\n648:           if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n649:             updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n650:           }\n651:         }\n652:         monitor.killAll();\n653:         saveState(projectRoot, state);\n654:         console.log(\"State saved. Use 'wombo resume' to continue.\");\n655:         process.exit(0);\n656:       },\n657:     });\n658:     tuiRef.current.start();\n659:   };\n660: \n661:   // Handle graceful shutdown\n662:   process.on(\"SIGINT\", () => {\n663:     if (tuiRef.current) tuiRef.current.stop();\n664:     for (const agent of state.agents) {\n665:       if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n666:         updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n667:       }\n668:     }\n669:     monitor.killAll();\n670:     saveState(projectRoot, state);\n671:     console.log(\"\\nState saved. Use 'wombo resume' to continue.\");\n672:     process.exit(0);\n673:   });\n674: \n675:   // Launch initial batch — set up worktrees in parallel\n676:   const tolaunch = queuedAgents(state).slice(0, opts.maxConcurrent);\n677:   console.log(`Setting up ${tolaunch.length} agent(s) in parallel...\\n`);\n678: \n679:   await Promise.all(\n680:     tolaunch.map((agent) =>\n681:       launchSingleHeadless(\n682:         projectRoot,\n683:         state,\n684:         agent,\n685:         featureMap.get(agent.feature_id)!,\n686:         monitor,\n687:         config,\n688:         model\n689:       )\n690:     )\n691:   );\n692: \n693:   const launched = state.agents.filter((a) => a.status === \"running\").length;\n694: \n695:   // Start the TUI dashboard (or skip if --no-tui)\n696:   if (opts.noTui) {\n697:     console.log(`${launched} agent(s) running. (--no-tui mode, dashboard prints every 15s)\\n`);\n698:     printDashboard(state);\n699:   } else {\n700:     console.log(`${launched} agent(s) running. Launching TUI...\\n`);\n701:     startTUI();\n702:   }\n703: \n704:   // Background monitoring loop — checks for dead processes and launches queued\n705:   const POLL_INTERVAL = 5000;\n706:   let dashboardCounter = 0;\n707:   while (!isWaveComplete(state)) {\n708:     await new Promise((r) => setTimeout(r, POLL_INTERVAL));\n709: \n710:     // Check for completed processes that weren't caught by event handlers\n711:     for (const agent of state.agents) {\n712:       if (\n713:         (agent.status === \"running\" || agent.status === \"resolving_conflict\") &&\n714:         agent.pid &&\n715:         !isProcessRunning(agent.pid) &&\n716:         !monitor.isRunning(agent.feature_id)\n717:       ) {\n718:         if (agent.status === \"resolving_conflict\") {\n719:           // Conflict resolver died — the await in handleBuildVerification\n720:           // will resolve via the 'exit' event, so nothing to do here\n721:           continue;\n722:         }\n723:         // Process exited but we didn't get a callback\n724:         // Check if the agent actually made any commits\n725:         if (!branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n726:           // Agent died without producing any code — mark as failed, not completed\n727:           updateAgent(state, agent.feature_id, {\n728:             status: \"failed\",\n729:             error: \"Agent process exited without making any commits\",\n730:             activity: null,\n731:             completed_at: new Date().toISOString(),\n732:           });\n733:           saveState(projectRoot, state);\n734:           wtLog(agent.feature_id, \"process died with no code changes — marked failed\");\n735:         } else {\n736:           updateAgent(state, agent.feature_id, {\n737:             status: \"completed\",\n738:             completed_at: new Date().toISOString(),\n739:             activity: \"done\",\n740:           });\n741:           saveState(projectRoot, state);\n742:           try {\n743:             await handleBuildVerification(projectRoot, state, agent, featureMap.get(agent.feature_id)!, config, model, monitor);\n744:           } catch (err: any) {\n745:             wtLog(agent.feature_id, `POLL VERIFY ERROR: ${err.message}`);\n746:           }\n747:         }\n748:         launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n749:       }\n750:     }\n751: \n752:     // Persist state periodically\n753:     saveState(projectRoot, state);\n754: \n755:     // Update TUI state reference (or print dashboard in --no-tui mode)\n756:     if (tuiRef.current) {\n757:       tuiRef.current.updateState(state);\n758:     } else if (opts.noTui) {\n759:       dashboardCounter++;\n760:       if (dashboardCounter % 3 === 0) {\n761:         printDashboard(state);\n762: \n763:         // Auto-push base branch if requested\n764:         if (opts.autoPush) {\n765:           const anyMerged = state.agents.some((a) => a.status === \"merged\");\n766:           if (anyMerged) {\n767:             await pushBaseBranch(projectRoot, state.base_branch, config);\n768:           } else {\n769:             console.log(\"No branches were merged — skipping push.\");\n770:           }\n771:         }\n772:       }\n773:     }\n774:   }\n775: \n776:   // Wave complete — tear down TUI and show final summary\n777:   if (tuiRef.current) tuiRef.current.stop();\n778:   printDashboard(state);\n779: \n780:   // Auto-push base branch if requested\n781:   if (opts.autoPush) {\n782:     await pushBaseBranch(projectRoot, state.base_branch, config);\n783:   }\n784: \n785:   console.log(\"Wave complete.\");\n786: }\n787: \n788: // ---------------------------------------------------------------------------\n789: // Interactive Wave Launch\n790: // ---------------------------------------------------------------------------\n791: \n792: async function launchWaveInteractive(\n793:   projectRoot: string,\n794:   state: WaveState,\n795:   features: Feature[],\n796:   opts: LaunchCommandOptions\n797: ): Promise<void> {\n798:   const { config, model } = opts;\n799:   const featureMap = new Map(features.map((f) => [f.id, f]));\n800: \n801:   // Show dashboard immediately\n802:   printDashboard(state);\n803: \n804:   // Launch initial batch in tmux — parallelize setup\n805:   const tolaunch = queuedAgents(state).slice(0, opts.maxConcurrent);\n806:   console.log(`Setting up ${tolaunch.length} agent(s) in parallel...\\n`);\n807: \n808:   await Promise.all(\n809:     tolaunch.map(async (agent) => {\n810:       updateAgent(state, agent.feature_id, {\n811:         status: \"installing\",\n812:         started_at: new Date().toISOString(),\n813:         activity: \"setting up worktree...\",\n814:       });\n815:       saveState(projectRoot, state);\n816: \n817:       try {\n818:         if (worktreeReady(agent.worktree)) {\n819:           wtLog(agent.feature_id, \"worktree already exists, skipping setup\");\n820:         } else {\n821:           await createWorktree(projectRoot, agent.feature_id, state.base_branch, config);\n822:           updateAgent(state, agent.feature_id, { activity: \"installing deps...\" });\n823:           await installDeps(agent.worktree, agent.feature_id, config);\n824:         }\n825: \n826:         const prompt = generatePrompt(\n827:           featureMap.get(agent.feature_id)!,\n828:           state.base_branch,\n829:           config\n830:         );\n831: \n832:         wtLog(agent.feature_id, \"launching tmux session...\");\n833:         const result = launchInteractive({\n834:           worktreePath: agent.worktree,\n835:           featureId: agent.feature_id,\n836:           prompt,\n837:           model,\n838:           interactive: true,\n839:           config,\n840:         });\n841: \n842:         updateAgent(state, agent.feature_id, {\n843:           status: \"running\",\n844:           pid: result.pid,\n845:           activity: \"tmux session active\",\n846:         });\n847:         saveState(projectRoot, state);\n848:         wtLog(agent.feature_id, `tmux session: ${config.agent.tmuxPrefix}-${agent.feature_id}`);\n849:       } catch (err: any) {\n850:         updateAgent(state, agent.feature_id, {\n851:           status: \"failed\",\n852:           error: err.message,\n853:           activity: null,\n854:           completed_at: new Date().toISOString(),\n855:         });\n856:         saveState(projectRoot, state);\n857:         wtLog(agent.feature_id, `SETUP FAILED: ${err.message.split(\"\\n\")[0]}`);\n858:       }\n859:     })\n860:   );\n861: \n862:   console.log(\"\\nInteractive sessions launched. Use these commands:\");\n863:   console.log(`  tmux attach -t ${config.agent.tmuxPrefix}-<feature-id>   # attach to a session`);\n864:   console.log(\"  tmux ls                                                  # list sessions\");\n865:   console.log(\"  wombo status                                             # check status\");\n866:   console.log(\"  wombo verify                                             # verify builds\");\n867:   console.log(\"  wombo merge                                              # merge verified\");\n868:   console.log(\"  wombo cleanup                                            # remove worktrees\");\n869: \n870:   printDashboard(state);\n871: }\n872: \n873: // ---------------------------------------------------------------------------\n874: // Main Command\n875: // ---------------------------------------------------------------------------\n876: \n877: export async function cmdLaunch(opts: LaunchCommandOptions): Promise<void> {\n878:   const { projectRoot, config } = opts;\n879: \n880:   console.log(\"\\n--- Wombo: Launch ---\\n\");\n881: \n882:   // Ensure agent definition exists — reinstall from template if missing\n883:   ensureAgentDefinition(projectRoot, config);\n884: \n885:   // -------------------------------------------------------------------------\n886:   // Validate that the configured baseBranch exists as a local branch\n887:   // -------------------------------------------------------------------------\n888:   if (!branchExists(projectRoot, opts.baseBranch)) {\n889:     const fmt = opts.outputFmt ?? \"text\";\n890:     const msg = `Base branch \"${opts.baseBranch}\" does not exist as a local branch. ` +\n891:       `Create it first (e.g. \"git checkout -b ${opts.baseBranch}\") or specify ` +\n892:       `a different branch with --base-branch.`;\n893:     outputError(fmt, msg);\n894:   }\n895: \n896:   // -------------------------------------------------------------------------\n897:   // Check for existing wave state — don't overwrite work in progress\n898:   // -------------------------------------------------------------------------\n899:   const existingState = loadState(projectRoot);\n900:   if (existingState) {\n901:     const merged = existingState.agents.filter((a) => a.status === \"merged\");\n902:     const verified = existingState.agents.filter((a) => a.status === \"verified\");\n903:     const completed = existingState.agents.filter((a) => a.status === \"completed\");\n904:     const running = existingState.agents.filter((a) => a.status === \"running\");\n905:     const queued = existingState.agents.filter((a) => a.status === \"queued\");\n906:     const failed = existingState.agents.filter((a) => a.status === \"failed\");\n907: \n908:     const hasWork = merged.length > 0 || verified.length > 0 || completed.length > 0 || running.length > 0;\n909: \n910:     if (hasWork) {\n911:       console.log(`Existing wave found: ${existingState.wave_id}`);\n912:       console.log(`  ${merged.length} merged, ${verified.length} verified, ${completed.length} completed, ${running.length} running, ${queued.length} queued, ${failed.length} failed`);\n913: \n914:       // Finalize any merged agents by marking their features as done\n915:       if (merged.length > 0) {\n916:         console.log(\"\\nFinalizing merged features in .features.yml...\");\n917:         for (const agent of merged) {\n918:           markFeatureDone(projectRoot, agent.feature_id, config, existingState.base_branch);\n919:           // Clean up worktree and branch (already merged, safe to delete)\n920:           try {\n921:             removeWorktree(projectRoot, agent.worktree, true);\n922:             console.log(`  ${agent.feature_id}: marked done, worktree removed`);\n923:           } catch {\n924:             console.log(`  ${agent.feature_id}: marked done (worktree already cleaned)`);\n925:           }\n926:         }\n927:       }\n928: \n929:       // Verified agents: build passed but NOT merged — do NOT mark done.\n930:       // Leave them for 'wombo resume' to attempt the merge.\n931:       if (verified.length > 0) {\n932:         for (const agent of verified) {\n933:           console.log(`  ${agent.feature_id}: verified (not yet merged) — use 'wombo resume' to merge`);\n934:         }\n935:       }\n936: \n937:       const activeCount = running.length + completed.length + queued.length;\n938:       if (activeCount > 0) {\n939:         console.error(`\\nWave ${existingState.wave_id} has ${activeCount} unfinished agent(s).`);\n940:         console.error(\"Use 'wombo resume' to continue the existing wave,\");\n941:         console.error(\"or 'wombo cleanup' to clear it before starting a new one.\");\n942:         process.exit(1);\n943:       }\n944: \n945:       // All agents are in terminal states (merged/verified/failed) — safe to start fresh\n946:       console.log(\"\\nAll agents in previous wave are finished. Starting fresh wave.\\n\");\n947:     }\n948:   }\n949: \n950:   // Load features\n951:   const data = loadFeatures(projectRoot, config);\n952: \n953:   // Build selection options\n954:   const selOpts: SelectionOptions = {};\n955:   if (opts.topPriority) selOpts.topPriority = opts.topPriority;\n956:   if (opts.quickestWins) selOpts.quickestWins = opts.quickestWins;\n957:   if (opts.priority) selOpts.priority = opts.priority;\n958:   if (opts.difficulty) selOpts.difficulty = opts.difficulty;\n959:   if (opts.features) selOpts.featureIds = opts.features;\n960:   if (opts.allReady) selOpts.allReady = true;\n961: \n962:   // Select features\n963:   const selected = selectFeatures(data, selOpts);\n964: \n965:   if (selected.length === 0) {\n966:     if (opts.allReady) {\n967:       console.error(\n968:         \"No launchable features found (all features are done, cancelled, or have unmet dependencies).\\n\" +\n969:         \"Run 'wombo features list' to review feature statuses.\"\n970:       );\n971:     } else {\n972:       console.error(\n973:         \"No features matched the selection criteria.\\n\" +\n974:         \"Use --all-ready to select all features whose dependencies are met,\\n\" +\n975:         \"or run 'wombo features list --ready' to see available features.\"\n976:       );\n977:     }\n978:     process.exit(1);\n979:   }\n980: \n981:   // Show selection\n982:   printFeatureSelection(\n983:     selected.map((f) => ({\n984:       id: f.id,\n985:       title: f.title,\n986:       priority: f.priority,\n987:       difficulty: f.difficulty,\n988:       effort: f.effort,\n989:     }))\n990:   );\n991: \n992:   if (opts.dryRun) {\n993:     console.log(\"Dry run — not launching agents.\");\n994:     return;\n995:   }\n996: \n997:   // Create wave state\n998:   const state = createWaveState({\n999:     baseBranch: opts.baseBranch,\n1000:     maxConcurrent: opts.maxConcurrent,\n1001:     model: opts.model ?? null,\n1002:     interactive: opts.interactive,\n1003:   });\n1004: \n1005:   // Create agent entries for all selected features\n1006:   for (const feature of selected) {\n1007:     const branch = featureBranchName(feature.id, config);\n1008:     const wtPath = worktreePath(projectRoot, feature.id, config);\n1009:     const agent = createAgentState(feature.id, branch, wtPath, opts.maxRetries);\n1010:     // Set effort estimate from feature spec\n1011:     const effortMinutes = parseDurationMinutes(feature.effort);\n1012:     agent.effort_estimate_ms = effortMinutes === Infinity ? null : effortMinutes * 60 * 1000;\n1013:     state.agents.push(agent);\n1014:   }\n1015: \n1016:   saveState(projectRoot, state);\n1017:   console.log(`Wave ${state.wave_id} created with ${selected.length} agents.`);\n1018: \n1019:   // Launch agents up to max_concurrent\n1020:   if (opts.interactive) {\n1021:     await launchWaveInteractive(projectRoot, state, selected, opts);\n1022:   } else {\n1023:     await launchWaveHeadless(projectRoot, state, selected, opts);\n1024:   }\n1025: }\n\n(End of file - total 1025 lines)\n</content>","title":"src/commands/launch.ts","metadata":{"preview":"/**\n * launch.ts — Launch a wave of agents.\n *\n * Usage: wombo launch [selection options] [launch options]\n *\n * This is the primary entry point for starting a new wave. It selects features\n * from the features file, creates a wave state, sets up worktrees, and launches\n * agent processes (either headless or interactive via tmux).\n *\n * IMPORTANT: This file also exports shared helper functions that are reused\n * by resume.ts and other commands:\n *   - launchSingleHeadless\n *   - handleBuildVerification\n *   - handleRetry\n *   - launchNextQueued\n */\n\nimport { execSync } from \"node:child_process\";\nimport type { WomboConfig } from \"../config.js\";\nimport type { Feature, SelectionOptions, Priority, Difficulty } from \"../lib/features.js\";","truncated":false,"loaded":[]},"time":{"start":1773351905257,"end":1773351905264}}}}
