{"type":"tool_use","timestamp":1773351913463,"sessionID":"ses_31bfd801cffeMfcGlS1DXqsNs2","part":{"id":"prt_ce402c6fa001UY7tfCldLFTqLW","sessionID":"ses_31bfd801cffeMfcGlS1DXqsNs2","messageID":"msg_ce402bc9c001uvrui2d36BDTAB","type":"tool","callID":"toolu_vrtx_01Ky8GCeGTcKFNiRkCf8h9yz","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-wave-history-export/src/lib/schema.ts"},"output":"<path>/home/fulgidus/Documents/wombo-wave-history-export/src/lib/schema.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * schema.ts — Declarative command/flag registry for schema introspection.\n3:  *\n4:  * Every command and flag is described in a single registry. This registry is\n5:  * the source of truth for:\n6:  *   1. `wombo describe <command>` — emits a JSON schema of accepted args\n7:  *   2. Future help text generation\n8:  *\n9:  * The registry is NOT used for actual arg parsing (that's still the hand-rolled\n10:  * switch in index.ts), but the two must stay in sync. If they drift, `wombo\n11:  * features check` should eventually catch it.\n12:  */\n13: \n14: // ---------------------------------------------------------------------------\n15: // Types\n16: // ---------------------------------------------------------------------------\n17: \n18: export interface FlagDef {\n19:   /** Primary flag name, e.g. \"--dry-run\" */\n20:   name: string;\n21:   /** Short alias, e.g. \"-o\" */\n22:   alias?: string;\n23:   /** Description shown in help / schema */\n24:   description: string;\n25:   /** Type of the value: \"boolean\" flags take no value, others consume next arg */\n26:   type: \"string\" | \"number\" | \"boolean\" | \"string[]\";\n27:   /** Default value (undefined = required or absent) */\n28:   default?: unknown;\n29:   /** For enum-like flags, the set of allowed values */\n30:   enum?: readonly string[];\n31:   /** If true, this flag is required */\n32:   required?: boolean;\n33: }\n34: \n35: export interface PositionalDef {\n36:   /** Name used in usage strings, e.g. \"feature-id\" */\n37:   name: string;\n38:   description: string;\n39:   required?: boolean;\n40: }\n41: \n42: export interface CommandDef {\n43:   /** Command name as typed by the user, e.g. \"launch\" or \"features list\" */\n44:   name: string;\n45:   /** One-line summary */\n46:   summary: string;\n47:   /** Longer description */\n48:   description?: string;\n49:   /** Positional arguments */\n50:   positionals: PositionalDef[];\n51:   /** Named flags */\n52:   flags: FlagDef[];\n53:   /** Whether this command mutates state (used for dry-run indication) */\n54:   mutating: boolean;\n55:   /** Whether this command supports --dry-run */\n56:   supportsDryRun: boolean;\n57:   /** Subcommands (for \"features\" parent) */\n58:   subcommands?: CommandDef[];\n59: }\n60: \n61: // ---------------------------------------------------------------------------\n62: // Global flags (available on every command)\n63: // ---------------------------------------------------------------------------\n64: \n65: const GLOBAL_FLAGS: FlagDef[] = [\n66:   {\n67:     name: \"--output\",\n68:     alias: \"-o\",\n69:     description: \"Output format: text (default) or json\",\n70:     type: \"string\",\n71:     default: \"text\",\n72:     enum: [\"text\", \"json\"],\n73:   },\n74:   {\n75:     name: \"--force\",\n76:     description: \"Force overwrite / skip safety prompts\",\n77:     type: \"boolean\",\n78:     default: false,\n79:   },\n80: ];\n81: \n82: // ---------------------------------------------------------------------------\n83: // Command Registry\n84: // ---------------------------------------------------------------------------\n85: \n86: export const COMMAND_REGISTRY: CommandDef[] = [\n87:   // --- init ---------------------------------------------------------------\n88:   {\n89:     name: \"init\",\n90:     summary: \"Generate wombo.json config in the current project\",\n91:     description:\n92:       \"Interactive guided setup that walks through every config section. \" +\n93:       \"Creates wombo.json and .features.yml from template.\",\n94:     positionals: [],\n95:     flags: [\n96:       {\n97:         name: \"--force\",\n98:         description: \"Overwrite existing config files\",\n99:         type: \"boolean\",\n100:         default: false,\n101:       },\n102:       {\n103:         name: \"--dry-run\",\n104:         description: \"Show what would be created without writing files\",\n105:         type: \"boolean\",\n106:         default: false,\n107:       },\n108:     ],\n109:     mutating: true,\n110:     supportsDryRun: true,\n111:   },\n112: \n113:   // --- launch -------------------------------------------------------------\n114:   {\n115:     name: \"launch\",\n116:     summary: \"Launch a wave of agents to implement features\",\n117:     description:\n118:       \"Select features from .features.yml, create worktrees, and spawn agents. \" +\n119:       \"Supports multiple selection strategies.\",\n120:     positionals: [],\n121:     flags: [\n122:       { name: \"--top-priority\", description: \"Select top N features by priority\", type: \"number\" },\n123:       { name: \"--quickest-wins\", description: \"Select N features with lowest effort\", type: \"number\" },\n124:       { name: \"--priority\", description: \"Filter by priority level\", type: \"string\", enum: [\"critical\", \"high\", \"medium\", \"low\", \"wishlist\"] },\n125:       { name: \"--difficulty\", description: \"Filter by difficulty level\", type: \"string\", enum: [\"trivial\", \"easy\", \"medium\", \"hard\", \"very_hard\"] },\n126:       { name: \"--features\", description: \"Select specific features by comma-separated IDs\", type: \"string\" },\n127:       { name: \"--all-ready\", description: \"Select all features whose dependencies are met\", type: \"boolean\", default: false },\n128:       { name: \"--max-concurrent\", description: \"Max agents running in parallel\", type: \"number\" },\n129:       { name: \"--model\", alias: \"-m\", description: \"Model to use (e.g., anthropic/claude-sonnet-4-20250514)\", type: \"string\" },\n130:       { name: \"--interactive\", description: \"Use tmux TUI mode instead of headless\", type: \"boolean\", default: false },\n131:       { name: \"--no-tui\", description: \"Headless mode without neo-blessed TUI\", type: \"boolean\", default: false },\n132:       { name: \"--auto-push\", description: \"Push base branch to remote after all merges\", type: \"boolean\", default: false },\n133:       { name: \"--dry-run\", description: \"Show what would be launched without launching\", type: \"boolean\", default: false },\n134:       { name: \"--base-branch\", description: \"Base branch (default: from config)\", type: \"string\" },\n135:       { name: \"--max-retries\", description: \"Max retries per agent\", type: \"number\" },\n136:     ],\n137:     mutating: true,\n138:     supportsDryRun: true,\n139:   },\n140: \n141:   // --- resume -------------------------------------------------------------\n142:   {\n143:     name: \"resume\",\n144:     summary: \"Resume a previously stopped wave\",\n145:     positionals: [],\n146:     flags: [\n147:       { name: \"--max-concurrent\", description: \"Max agents running in parallel\", type: \"number\" },\n148:       { name: \"--model\", alias: \"-m\", description: \"Model to use\", type: \"string\" },\n149:       { name: \"--interactive\", description: \"Use tmux TUI mode\", type: \"boolean\", default: false },\n150:       { name: \"--no-tui\", description: \"Headless mode without neo-blessed TUI\", type: \"boolean\", default: false },\n151:       { name: \"--auto-push\", description: \"Push base branch to remote after merges\", type: \"boolean\", default: false },\n152:       { name: \"--base-branch\", description: \"Base branch override\", type: \"string\" },\n153:       { name: \"--max-retries\", description: \"Max retries per agent\", type: \"number\" },\n154:     ],\n155:     mutating: true,\n156:     supportsDryRun: false,\n157:   },\n158: \n159:   // --- status -------------------------------------------------------------\n160:   {\n161:     name: \"status\",\n162:     summary: \"Show the status of the current wave\",\n163:     positionals: [],\n164:     flags: [],\n165:     mutating: false,\n166:     supportsDryRun: false,\n167:   },\n168: \n169:   // --- verify -------------------------------------------------------------\n170:   {\n171:     name: \"verify\",\n172:     summary: \"Run build verification on completed agents\",\n173:     positionals: [\n174:       { name: \"feature-id\", description: \"Specific feature to verify (optional)\", required: false },\n175:     ],\n176:     flags: [\n177:       { name: \"--model\", alias: \"-m\", description: \"Model to use for verification\", type: \"string\" },\n178:       { name: \"--max-retries\", description: \"Max retries\", type: \"number\" },\n179:     ],\n180:     mutating: true,\n181:     supportsDryRun: false,\n182:   },\n183: \n184:   // --- merge --------------------------------------------------------------\n185:   {\n186:     name: \"merge\",\n187:     summary: \"Merge verified branches into the base branch\",\n188:     positionals: [\n189:       { name: \"feature-id\", description: \"Specific feature to merge (optional)\", required: false },\n190:     ],\n191:     flags: [\n192:       { name: \"--auto-push\", description: \"Push base branch to remote after merge\", type: \"boolean\", default: false },\n193:       { name: \"--dry-run\", description: \"Show what would be merged without merging\", type: \"boolean\", default: false },\n194:     ],\n195:     mutating: true,\n196:     supportsDryRun: true,\n197:   },\n198: \n199:   // --- retry --------------------------------------------------------------\n200:   {\n201:     name: \"retry\",\n202:     summary: \"Retry a failed agent\",\n203:     positionals: [\n204:       { name: \"feature-id\", description: \"Feature ID of the failed agent\", required: true },\n205:     ],\n206:     flags: [\n207:       { name: \"--model\", alias: \"-m\", description: \"Model to use\", type: \"string\" },\n208:       { name: \"--interactive\", description: \"Use tmux TUI mode\", type: \"boolean\", default: false },\n209:       { name: \"--dry-run\", description: \"Show what would be retried without retrying\", type: \"boolean\", default: false },\n210:     ],\n211:     mutating: true,\n212:     supportsDryRun: true,\n213:   },\n214: \n215:   // --- cleanup ------------------------------------------------------------\n216:   {\n217:     name: \"cleanup\",\n218:     summary: \"Remove all wave worktrees and tmux sessions\",\n219:     description: \"Kills tmux sessions, removes worktrees, removes state and log files.\",\n220:     positionals: [],\n221:     flags: [\n222:       { name: \"--dry-run\", description: \"Show what would be cleaned up without removing\", type: \"boolean\", default: false },\n223:     ],\n224:     mutating: true,\n225:     supportsDryRun: true,\n226:   },\n227: \n228:   // --- abort --------------------------------------------------------------\n229:   {\n230:     name: \"abort\",\n231:     summary: \"Kill a single running agent without affecting the rest of the wave\",\n232:     description:\n233:       \"Kills the tmux session and agent process for a specific feature, then \" +\n234:       \"marks the agent as failed. Use --requeue to return the feature to the \" +\n235:       \"queue instead of marking it failed.\",\n236:     positionals: [\n237:       { name: \"feature-id\", description: \"Feature ID of the agent to abort\", required: true },\n238:     ],\n239:     flags: [\n240:       { name: \"--requeue\", description: \"Return the feature to queued instead of marking it failed\", type: \"boolean\", default: false },\n241:     ],\n242:     mutating: true,\n243:     supportsDryRun: false,\n244:   },\n245: \n246:   // --- upgrade ------------------------------------------------------------\n247:   {\n248:     name: \"upgrade\",\n249:     summary: \"Check for updates and upgrade wombo\",\n250:     positionals: [],\n251:     flags: [\n252:       { name: \"--check\", description: \"Only check for updates, don't install\", type: \"boolean\", default: false },\n253:       { name: \"--version\", description: \"Install a specific version (e.g., v0.1.0)\", type: \"string\" },\n254:       { name: \"--force\", description: \"Force reinstall even if up to date\", type: \"boolean\", default: false },\n255:     ],\n256:     mutating: true,\n257:     supportsDryRun: false,\n258:   },\n259: \n260:   // --- features (parent with subcommands) ---------------------------------\n261:   {\n262:     name: \"features\",\n263:     summary: \"Manage .features.yml\",\n264:     positionals: [],\n265:     flags: [],\n266:     mutating: false,\n267:     supportsDryRun: false,\n268:     subcommands: [\n269:       {\n270:         name: \"features list\",\n271:         summary: \"List features with optional filtering\",\n272:         positionals: [],\n273:         flags: [\n274:           { name: \"--status\", description: \"Filter by status\", type: \"string\", enum: [\"backlog\", \"planned\", \"in_progress\", \"blocked\", \"in_review\", \"done\", \"cancelled\"] },\n275:           { name: \"--priority\", description: \"Filter by priority\", type: \"string\", enum: [\"critical\", \"high\", \"medium\", \"low\", \"wishlist\"] },\n276:           { name: \"--difficulty\", description: \"Filter by difficulty\", type: \"string\", enum: [\"trivial\", \"easy\", \"medium\", \"hard\", \"very_hard\"] },\n277:           { name: \"--ready\", description: \"Show only ready features (backlog + deps met)\", type: \"boolean\", default: false },\n278:           { name: \"--include-archive\", description: \"Include archived features\", type: \"boolean\", default: false },\n279:           { name: \"--fields\", description: \"Comma-separated list of fields to include in output\", type: \"string\" },\n280:         ],\n281:         mutating: false,\n282:         supportsDryRun: false,\n283:       },\n284:       {\n285:         name: \"features add\",\n286:         summary: \"Add a new feature\",\n287:         positionals: [\n288:           { name: \"id\", description: \"Feature ID (kebab-case)\", required: true },\n289:           { name: \"title\", description: \"Feature title\", required: true },\n290:         ],\n291:         flags: [\n292:           { name: \"--description\", alias: \"--desc\", description: \"Feature description\", type: \"string\" },\n293:           { name: \"--priority\", description: \"Priority level\", type: \"string\", default: \"medium\", enum: [\"critical\", \"high\", \"medium\", \"low\", \"wishlist\"] },\n294:           { name: \"--difficulty\", description: \"Difficulty level\", type: \"string\", default: \"medium\", enum: [\"trivial\", \"easy\", \"medium\", \"hard\", \"very_hard\"] },\n295:           { name: \"--effort\", description: \"Effort estimate (ISO 8601 duration, e.g. PT2H)\", type: \"string\", default: \"PT1H\" },\n296:           { name: \"--depends-on\", description: \"Comma-separated dependency IDs\", type: \"string\" },\n297:           { name: \"--dry-run\", description: \"Show what would be added without writing\", type: \"boolean\", default: false },\n298:         ],\n299:         mutating: true,\n300:         supportsDryRun: true,\n301:       },\n302:       {\n303:         name: \"features set-status\",\n304:         summary: \"Change a feature's status\",\n305:         positionals: [\n306:           { name: \"feature-id\", description: \"Feature ID to update\", required: true },\n307:           { name: \"status\", description: \"New status value\", required: true },\n308:         ],\n309:         flags: [\n310:           { name: \"--dry-run\", description: \"Show what would change without writing\", type: \"boolean\", default: false },\n311:         ],\n312:         mutating: true,\n313:         supportsDryRun: true,\n314:       },\n315:       {\n316:         name: \"features check\",\n317:         summary: \"Validate .features.yml (schema, deps, duplicates, cycles)\",\n318:         positionals: [],\n319:         flags: [],\n320:         mutating: false,\n321:         supportsDryRun: false,\n322:       },\n323:       {\n324:         name: \"features archive\",\n325:         summary: \"Move done/cancelled features to archive section\",\n326:         positionals: [\n327:           { name: \"feature-id\", description: \"Specific feature to archive (optional)\", required: false },\n328:         ],\n329:         flags: [\n330:           { name: \"--dry-run\", description: \"Show what would be archived without moving\", type: \"boolean\", default: false },\n331:         ],\n332:         mutating: true,\n333:         supportsDryRun: true,\n334:       },\n335:       {\n336:         name: \"features show\",\n337:         summary: \"Show detailed information about a specific feature\",\n338:         positionals: [\n339:           { name: \"feature-id\", description: \"Feature ID to display\", required: true },\n340:         ],\n341:         flags: [\n342:           { name: \"--fields\", description: \"Comma-separated list of fields to include in output\", type: \"string\" },\n343:         ],\n344:         mutating: false,\n345:         supportsDryRun: false,\n346:       },\n347:       {\n348:         name: \"features graph\",\n349:         summary: \"Visualize the feature dependency graph as a terminal diagram\",\n350:         description:\n351:           \"Builds a Mermaid flowchart from the features dependency graph and renders \" +\n352:           \"it as a Unicode box diagram. Shows dependency edges, status badges, orphan \" +\n353:           \"detection, dangling dependency warnings, and cycle detection.\",\n354:         positionals: [],\n355:         flags: [\n356:           { name: \"--status\", description: \"Filter graph to features with this status\", type: \"string\", enum: [\"backlog\", \"planned\", \"in_progress\", \"blocked\", \"in_review\", \"done\", \"cancelled\"] },\n357:           { name: \"--ascii\", description: \"Use ASCII-only rendering (no Unicode box chars)\", type: \"boolean\", default: false },\n358:           { name: \"--mermaid\", description: \"Emit raw Mermaid source instead of rendered graph\", type: \"boolean\", default: false },\n359:           { name: \"--subtasks\", description: \"Include subtask-level nodes in the graph\", type: \"boolean\", default: false },\n360:         ],\n361:         mutating: false,\n362:         supportsDryRun: false,\n363:       },\n364:     ],\n365:   },\n366: \n367:   // --- help ---------------------------------------------------------------\n368:   {\n369:     name: \"help\",\n370:     summary: \"Show help text\",\n371:     positionals: [],\n372:     flags: [],\n373:     mutating: false,\n374:     supportsDryRun: false,\n375:   },\n376: \n377:   // --- describe -----------------------------------------------------------\n378:   {\n379:     name: \"describe\",\n380:     summary: \"Emit JSON schema of a command's arguments and flags\",\n381:     description:\n382:       \"Machine-readable introspection for AI agents. Outputs the accepted \" +\n383:       \"positionals, flags, types, defaults, and constraints for a command.\",\n384:     positionals: [\n385:       { name: \"command\", description: \"Command to describe (e.g. 'launch', 'features add')\", required: false },\n386:     ],\n387:     flags: [],\n388:     mutating: false,\n389:     supportsDryRun: false,\n390:   },\n391: ];\n392: \n393: // ---------------------------------------------------------------------------\n394: // Lookup helpers\n395: // ---------------------------------------------------------------------------\n396: \n397: /**\n398:  * Find a command definition by name. Supports compound names like \"features list\".\n399:  */\n400: export function findCommandDef(name: string): CommandDef | undefined {\n401:   // Try direct match first\n402:   const direct = COMMAND_REGISTRY.find((c) => c.name === name);\n403:   if (direct) return direct;\n404: \n405:   // Try compound: \"features list\" -> look in features subcommands\n406:   const parts = name.split(/\\s+/);\n407:   if (parts.length === 2) {\n408:     const parent = COMMAND_REGISTRY.find((c) => c.name === parts[0]);\n409:     if (parent?.subcommands) {\n410:       return parent.subcommands.find((sc) => sc.name === name || sc.name === parts[1]);\n411:     }\n412:   }\n413: \n414:   return undefined;\n415: }\n416: \n417: /**\n418:  * Produce the JSON schema object for a command, suitable for agent consumption.\n419:  */\n420: export function commandToSchema(cmd: CommandDef): Record<string, unknown> {\n421:   const schema: Record<string, unknown> = {\n422:     command: cmd.name,\n423:     summary: cmd.summary,\n424:     mutating: cmd.mutating,\n425:     supports_dry_run: cmd.supportsDryRun,\n426:   };\n427: \n428:   if (cmd.description) {\n429:     schema.description = cmd.description;\n430:   }\n431: \n432:   if (cmd.positionals.length > 0) {\n433:     schema.positionals = cmd.positionals.map((p) => ({\n434:       name: p.name,\n435:       description: p.description,\n436:       required: p.required ?? false,\n437:     }));\n438:   }\n439: \n440:   const allFlags = [...cmd.flags, ...GLOBAL_FLAGS];\n441:   schema.flags = allFlags.map((f) => {\n442:     const entry: Record<string, unknown> = {\n443:       name: f.name,\n444:       type: f.type,\n445:       description: f.description,\n446:     };\n447:     if (f.alias) entry.alias = f.alias;\n448:     if (f.default !== undefined) entry.default = f.default;\n449:     if (f.enum) entry.enum = f.enum;\n450:     if (f.required) entry.required = true;\n451:     return entry;\n452:   });\n453: \n454:   if (cmd.subcommands?.length) {\n455:     schema.subcommands = cmd.subcommands.map((sc) => sc.name);\n456:   }\n457: \n458:   return schema;\n459: }\n460: \n461: /**\n462:  * Produce a listing of all commands (for `wombo describe` with no args).\n463:  */\n464: export function allCommandSchemas(): Record<string, unknown> {\n465:   const commands: Record<string, unknown>[] = [];\n466: \n467:   for (const cmd of COMMAND_REGISTRY) {\n468:     const entry: Record<string, unknown> = {\n469:       name: cmd.name,\n470:       summary: cmd.summary,\n471:       mutating: cmd.mutating,\n472:       supports_dry_run: cmd.supportsDryRun,\n473:     };\n474:     if (cmd.subcommands) {\n475:       entry.subcommands = cmd.subcommands.map((sc) => ({\n476:         name: sc.name,\n477:         summary: sc.summary,\n478:         mutating: sc.mutating,\n479:         supports_dry_run: sc.supportsDryRun,\n480:       }));\n481:     }\n482:     commands.push(entry);\n483:   }\n484: \n485:   return {\n486:     tool: \"wombo\",\n487:     version: \"0.0.2\",\n488:     global_flags: GLOBAL_FLAGS.map((f) => ({\n489:       name: f.name,\n490:       alias: f.alias,\n491:       type: f.type,\n492:       description: f.description,\n493:       default: f.default,\n494:     })),\n495:     commands,\n496:   };\n497: }\n\n(End of file - total 497 lines)\n</content>","title":"src/lib/schema.ts","metadata":{"preview":"/**\n * schema.ts — Declarative command/flag registry for schema introspection.\n *\n * Every command and flag is described in a single registry. This registry is\n * the source of truth for:\n *   1. `wombo describe <command>` — emits a JSON schema of accepted args\n *   2. Future help text generation\n *\n * The registry is NOT used for actual arg parsing (that's still the hand-rolled\n * switch in index.ts), but the two must stay in sync. If they drift, `wombo\n * features check` should eventually catch it.\n */\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface FlagDef {\n  /** Primary flag name, e.g. \"--dry-run\" */\n  name: string;","trunca