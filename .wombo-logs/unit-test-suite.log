{"type":"tool_use","timestamp":1773351520493,"sessionID":"ses_31c036cc5ffehJByI1GJ6dwrh0","part":{"id":"prt_ce3fcc826001aYnyeG1Dg4hoIF","sessionID":"ses_31c036cc5ffehJByI1GJ6dwrh0","messageID":"msg_ce3fcb876001c7pE6nZvqiQ77w","type":"tool","callID":"toolu_vrtx_01BTE2qJp4m81qwyJ9uh2zFc","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-unit-test-suite/src/config.ts"},"output":"<path>/home/fulgidus/Documents/wombo-unit-test-suite/src/config.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * config.ts — Load wombo.json, merge with defaults, validate, expose typed config.\n3:  *\n4:  * The config file lives at the target project root (the repo being orchestrated).\n5:  * All values have sensible defaults so minimal config works out of the box.\n6:  */\n7: \n8: import { readFileSync, existsSync } from \"node:fs\";\n9: import { resolve } from \"node:path\";\n10: \n11: // ---------------------------------------------------------------------------\n12: // Types\n13: // ---------------------------------------------------------------------------\n14: \n15: export interface WomboConfig {\n16:   /** Path to the features YAML file relative to project root */\n17:   featuresFile: string;\n18:   /** Base branch to create feature branches from */\n19:   baseBranch: string;\n20:   /** Build configuration */\n21:   build: {\n22:     /** Build command to run in worktrees */\n23:     command: string;\n24:     /** Build timeout in milliseconds */\n25:     timeout: number;\n26:     /** Build artifact directory (for quick \"did it build?\" checks) */\n27:     artifactDir: string;\n28:   };\n29:   /** Install configuration */\n30:   install: {\n31:     /** Install command to run in worktrees */\n32:     command: string;\n33:     /** Install timeout in milliseconds */\n34:     timeout: number;\n35:   };\n36:   /** Git configuration */\n37:   git: {\n38:     /** Branch name prefix for feature branches */\n39:     branchPrefix: string;\n40:     /** Worktree directory name prefix */\n41:     worktreePrefix: string;\n42:     /** Git remote name */\n43:     remote: string;\n44:     /** Merge strategy flag */\n45:     mergeStrategy: string;\n46:   };\n47:   /** Agent configuration */\n48:   agent: {\n49:     /** Path to agent binary (null = auto-detect) */\n50:     bin: string | null;\n51:     /** Agent name to pass via --agent flag */\n52:     name: string;\n53:     /** Config files/dirs to copy into worktrees */\n54:     configFiles: string[];\n55:     /** tmux session name prefix */\n56:     tmuxPrefix: string;\n57:   };\n58:   /** Default runtime values */\n59:   defaults: {\n60:     /** Max concurrent agents */\n61:     maxConcurrent: number;\n62:     /** Max retries per agent */\n63:     maxRetries: number;\n64:   };\n65: }\n66: \n67: // ---------------------------------------------------------------------------\n68: // Defaults\n69: // ---------------------------------------------------------------------------\n70: \n71: export const DEFAULT_CONFIG: WomboConfig = {\n72:   featuresFile: \".features.yml\",\n73:   baseBranch: \"develop\",\n74:   build: {\n75:     command: \"bun run build\",\n76:     timeout: 300_000,\n77:     artifactDir: \"dist\",\n78:   },\n79:   install: {\n80:     command: \"bun install\",\n81:     timeout: 120_000,\n82:   },\n83:   git: {\n84:     branchPrefix: \"feature/\",\n85:     worktreePrefix: \"wombo-\",\n86:     remote: \"origin\",\n87:     mergeStrategy: \"--no-ff\",\n88:   },\n89:   agent: {\n90:     bin: null,\n91:     name: \"wave-worker\",\n92:     configFiles: [\".opencode/\", \"opencode.json\", \"AGENTS.md\", \"agent/\"],\n93:     tmuxPrefix: \"wombo\",\n94:   },\n95:   defaults: {\n96:     maxConcurrent: 6,\n97:     maxRetries: 2,\n98:   },\n99: };\n100: \n101: // ---------------------------------------------------------------------------\n102: // Config File Name\n103: // ---------------------------------------------------------------------------\n104: \n105: export const CONFIG_FILE = \"wombo.json\";\n106: \n107: // ---------------------------------------------------------------------------\n108: // Loader\n109: // ---------------------------------------------------------------------------\n110: \n111: /**\n112:  * Deep-merge source into target. Only merges plain objects, not arrays.\n113:  */\n114: function deepMerge<T extends Record<string, any>>(target: T, source: Partial<T>): T {\n115:   const result = { ...target };\n116:   for (const key of Object.keys(source) as (keyof T)[]) {\n117:     const srcVal = source[key];\n118:     const tgtVal = target[key];\n119:     if (\n120:       srcVal !== undefined &&\n121:       srcVal !== null &&\n122:       typeof srcVal === \"object\" &&\n123:       !Array.isArray(srcVal) &&\n124:       typeof tgtVal === \"object\" &&\n125:       !Array.isArray(tgtVal) &&\n126:       tgtVal !== null\n127:     ) {\n128:       result[key] = deepMerge(tgtVal as any, srcVal as any);\n129:     } else if (srcVal !== undefined) {\n130:       result[key] = srcVal as T[keyof T];\n131:     }\n132:   }\n133:   return result;\n134: }\n135: \n136: /**\n137:  * Load wombo.json from the given project root and merge with defaults.\n138:  * Returns the full config. If no config file exists, returns defaults.\n139:  */\n140: export function loadConfig(projectRoot: string): WomboConfig {\n141:   const configPath = resolve(projectRoot, CONFIG_FILE);\n142: \n143:   if (!existsSync(configPath)) {\n144:     return { ...DEFAULT_CONFIG };\n145:   }\n146: \n147:   try {\n148:     const raw = readFileSync(configPath, \"utf-8\");\n149:     const partial = JSON.parse(raw) as Partial<WomboConfig>;\n150:     return deepMerge(DEFAULT_CONFIG, partial);\n151:   } catch (err: any) {\n152:     throw new Error(`Failed to load ${CONFIG_FILE}: ${err.message}`);\n153:   }\n154: }\n155: \n156: /**\n157:  * Resolve the agent binary path. Priority:\n158:  *   1. config.agent.bin (explicit)\n159:  *   2. OPENCODE_BIN env var\n160:  *   3. ~/.opencode/bin/opencode (default install location)\n161:  */\n162: export function resolveAgentBin(config: WomboConfig): string {\n163:   if (config.agent.bin) return config.agent.bin;\n164:   if (process.env.OPENCODE_BIN) return process.env.OPENCODE_BIN;\n165:   return resolve(process.env.HOME || \"~\", \".opencode/bin/opencode\");\n166: }\n167: \n168: /**\n169:  * Validate the config for obvious issues. Throws on error.\n170:  */\n171: export function validateConfig(config: WomboConfig): void {\n172:   if (!config.featuresFile) {\n173:     throw new Error(\"config.featuresFile must be a non-empty string\");\n174:   }\n175:   if (!config.baseBranch) {\n176:     throw new Error(\"config.baseBranch must be a non-empty string\");\n177:   }\n178:   if (!config.build.command) {\n179:     throw new Error(\"config.build.command must be a non-empty string\");\n180:   }\n181:   if (!config.install.command) {\n182:     throw new Error(\"config.install.command must be a non-empty string\");\n183:   }\n184:   if (!config.git.branchPrefix) {\n185:     throw new Error(\"config.git.branchPrefix must be a non-empty string\");\n186:   }\n187:   if (!config.git.worktreePrefix) {\n188:     throw new Error(\"config.git.worktreePrefix must be a non-empty string\");\n189:   }\n190:   if (config.defaults.maxConcurrent < 1) {\n191:     throw new Error(\"config.defaults.maxConcurrent must be >= 1\");\n192:   }\n193:   if (config.defaults.maxRetries < 0) {\n194:     throw new Error(\"config.defaults.maxRetries must be >= 0\");\n195:   }\n196: }\n197: \n198: /**\n199:  * Generate the default wombo.json content string (for `wombo init`).\n200:  */\n201: export function generateDefaultConfig(): string {\n202:   return JSON.stringify(DEFAULT_CONFIG, null, 2) + \"\\n\";\n203: }\n\n(End of file - total 203 lines)\n</content>","title":"src/config.ts","metadata":{"preview":"/**\n * config.ts — Load wombo.json, merge with defaults, validate, expose typed config.\n *\n * The config file lives at the target project root (the repo being orchestrated).\n * All values have sensible defaults so minimal config works out of the box.\n */\n\nimport { readFileSync, existsSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface WomboConfig {\n  /** Path to the features YAML file relative to project root */\n  featuresFile: string;\n  /** Base branch to create feature branches from */\n  baseBranch: string;\n  /** Build configuration */","truncated":false,"loaded":[]},"time":{"start":1773351520482,"end":1773351520491}}}}
{"type":"tool_use","timestamp":1773351521012,"sessionID":"ses_31c036cc5ffehJByI1GJ6dwrh0","part":{"id":"prt_ce3fcc944001mwwJ6o8I0U3iut","sessionID":"ses_31c036cc5ffehJByI1GJ6dwrh0","messageID":"msg_ce3fcb876001c7pE6nZvqiQ77w","type":"tool","callID":"toolu_vrtx_01FdPu8YznQe4azEXJqNpaa4","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-unit-test-suite/src/lib/output.ts"},"output":"<path>/home/fulgidus/Documents/wombo-unit-test-suite/src/lib/output.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * output.ts — Shared output helpers for agent-ready CLI.\n3:  *\n4:  * Provides a centralized way for commands to emit structured data that\n5:  * renders as human-readable text on TTY or as JSON when --output json\n6:  * is specified (or when stdout is not a TTY).\n7:  *\n8:  * Usage in commands:\n9:  *   import { output, OutputFormat } from \"../lib/output.js\";\n10:  *\n11:  *   // At the end of a command:\n12:  *   output(format, data);           // emits JSON or human text\n13:  *   outputError(format, message);   // emits error in the right format\n14:  */\n15: \n16: // ---------------------------------------------------------------------------\n17: // Types\n18: // ---------------------------------------------------------------------------\n19: \n20: export type OutputFormat = \"text\" | \"json\";\n21: \n22: // ---------------------------------------------------------------------------\n23: // Helpers\n24: // ---------------------------------------------------------------------------\n25: \n26: /**\n27:  * Determine the output format. Priority:\n28:  *   1. Explicit --output flag value\n29:  *   2. WOMBO_OUTPUT env var (for agent pipelines)\n30:  *   3. Default to \"text\"\n31:  *\n32:  * Note: We intentionally do NOT auto-detect based on TTY. Many legitimate\n33:  * use cases (bun dev, piped to less/grep, CI) have non-TTY stdout but still\n34:  * want human output. Agents should explicitly pass --output json or set\n35:  * WOMBO_OUTPUT=json.\n36:  */\n37: export function resolveOutputFormat(explicit?: string): OutputFormat {\n38:   if (explicit === \"json\") return \"json\";\n39:   if (explicit === \"text\") return \"text\";\n40:   // Check env var for agent pipelines\n41:   const env = process.env.WOMBO_OUTPUT;\n42:   if (env === \"json\") return \"json\";\n43:   return \"text\";\n44: }\n45: \n46: /**\n47:  * Emit structured data. In JSON mode, outputs a single JSON line to stdout.\n48:  * In text mode, calls the provided textRenderer callback.\n49:  */\n50: export function output(\n51:   format: OutputFormat,\n52:   data: unknown,\n53:   textRenderer: () => void\n54: ): void {\n55:   if (format === \"json\") {\n56:     console.log(JSON.stringify(data));\n57:   } else {\n58:     textRenderer();\n59:   }\n60: }\n61: \n62: /**\n63:  * Emit an error. In JSON mode, outputs {\"error\": message} to stderr.\n64:  * In text mode, outputs the message to stderr normally.\n65:  */\n66: export function outputError(format: OutputFormat, message: string, exitCode: number = 1): never {\n67:   if (format === \"json\") {\n68:     console.error(JSON.stringify({ error: message }));\n69:   } else {\n70:     console.error(message);\n71:   }\n72:   process.exit(exitCode);\n73: }\n74: \n75: /**\n76:  * Emit a success/info message. In JSON mode, outputs {\"message\": msg, ...extra}.\n77:  * In text mode, outputs the message to stdout normally.\n78:  */\n79: export function outputMessage(\n80:   format: OutputFormat,\n81:   message: string,\n82:   extra?: Record<string, unknown>\n83: ): void {\n84:   if (format === \"json\") {\n85:     console.log(JSON.stringify({ message, ...extra }));\n86:   } else {\n87:     console.log(message);\n88:   }\n89: }\n90: \n91: // ---------------------------------------------------------------------------\n92: // Field filtering for compact output (--fields)\n93: // ---------------------------------------------------------------------------\n94: \n95: /**\n96:  * Filter an object to only include the specified fields.\n97:  * If fields is undefined/empty, returns the object unchanged.\n98:  */\n99: export function filterFields<T extends Record<string, unknown>>(\n100:   obj: T,\n101:   fields?: string[]\n102: ): Partial<T> {\n103:   if (!fields || fields.length === 0) return obj;\n104:   const result: Partial<T> = {};\n105:   for (const field of fields) {\n106:     if (field in obj) {\n107:       (result as any)[field] = (obj as any)[field];\n108:     }\n109:   }\n110:   return result;\n111: }\n112: \n113: /**\n114:  * Filter an array of objects to only include specified fields per object.\n115:  * If fields is undefined/empty, returns the array unchanged.\n116:  */\n117: export function filterFieldsArray<T extends Record<string, unknown>>(\n118:   arr: T[],\n119:   fields?: string[]\n120: ): Partial<T>[] {\n121:   if (!fields || fields.length === 0) return arr;\n122:   return arr.map((obj) => filterFields(obj, fields));\n123: }\n124: \n125: /**\n126:  * Render a compact text table from an array of objects with selected fields.\n127:  * Used for text-mode --fields output.\n128:  */\n129: export function renderCompactTable(\n130:   items: Record<string, unknown>[],\n131:   fields: string[]\n132: ): void {\n133:   if (items.length === 0) return;\n134: \n135:   // Calculate column widths\n136:   const widths: Record<string, number> = {};\n137:   for (const field of fields) {\n138:     widths[field] = field.length;\n139:     for (const item of items) {\n140:       const val = String(item[field] ?? \"\");\n141:       widths[field] = Math.max(widths[field], val.length);\n142:     }\n143:   }\n144: \n145:   // Header\n146:   const header = fields.map((f) => f.padEnd(widths[f])).join(\"  \");\n147:   console.log(header);\n148:   console.log(fields.map((f) => \"─\".repeat(widths[f])).join(\"  \"));\n149: \n150:   // Rows\n151:   for (const item of items) {\n152:     const row = fields.map((f) => String(item[f] ?? \"\").padEnd(widths[f])).join(\"  \");\n153:     console.log(row);\n154:   }\n155: }\n\n(End of file - total 155 lines)\n</content>","title":"src/lib/output.ts","metadata":{"preview":"/**\n * output.ts — Shared output helpers for agent-ready CLI.\n *\n * Provides a centralized way for commands to emit structured data that\n * renders as human-readable text on TTY or as JSON when --output json\n * is specified (or when stdout is not a TTY).\n *\n * Usage in commands:\n *   import { output, OutputFormat } from \"../lib/output.js\";\n *\n *   // At the end of a command:\n *   output(format, data);           // emits JSON or human text\n *   outputError(format, message);   // emits error in the right format\n */\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type OutputFormat = \"text\" | \"json\";","truncated":false,"loaded":[]},"time":{"start":1773351520994,"end":1773351521010}}}}
{"type":"tool_use","timestamp":1773351521468,"sessionID":"ses_31c036cc5ffehJByI1GJ6dwrh0","part":{"id":"prt_ce3fccae50013N34UQUsVGKGY8","sessionID":"ses_31c036cc5ffehJByI1GJ6dwrh0","messageID":"msg_ce3fcb876001c7pE6nZvqiQ77w","type":"tool","callID":"toolu_vrtx_0151pCptPBB7poh71WxPajDv","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-unit-test-suite/src/lib/validate.ts"},"output":"<path>/home/fulgidus/Documents/wombo-unit-test-suite/src/lib/validate.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * validate.ts — Input validation / hardening for agent-ready CLI.\n3:  *\n4:  * All user/agent-supplied inputs pass through these validators at the CLI\n5:  * boundary. This prevents hallucinated inputs from corrupting state.\n6:  *\n7:  * Rules:\n8:  *   - Feature IDs: kebab-case only, no path traversals, no query params\n9:  *   - Branch names: no control chars, no \"..\", no spaces\n10:  *   - Free-text (titles, descriptions): no control chars except \\n \\t\n11:  *   - Effort strings: ISO 8601 duration pattern only\n12:  */\n13: \n14: // ---------------------------------------------------------------------------\n15: // Patterns\n16: // ---------------------------------------------------------------------------\n17: \n18: /** Valid feature/subtask ID: lowercase alphanumeric + hyphens, 1-128 chars */\n19: const ID_PATTERN = /^[a-z0-9][a-z0-9-]{0,127}$/;\n20: \n21: /** Control characters below space, excluding \\t (0x09) and \\n (0x0a) */\n22: const CONTROL_CHARS = /[\\x00-\\x08\\x0b\\x0c\\x0e-\\x1f\\x7f]/;\n23: \n24: /** Path traversal sequences */\n25: const PATH_TRAVERSAL = /\\.\\.\\//;\n26: \n27: /** Embedded query params or fragments */\n28: const QUERY_FRAGMENT = /[?#]/;\n29: \n30: /** Percent-encoded sequences (indicates double-encoding risk) */\n31: const PERCENT_ENCODED = /%[0-9a-fA-F]{2}/;\n32: \n33: /** ISO 8601 duration: P[nY][nM][nD][T[nH][nM][nS]] */\n34: const DURATION_PATTERN = /^P(?:\\d+Y)?(?:\\d+M)?(?:\\d+D)?(?:T(?:\\d+H)?(?:\\d+M)?(?:\\d+S)?)?$/;\n35: \n36: // ---------------------------------------------------------------------------\n37: // Result type\n38: // ---------------------------------------------------------------------------\n39: \n40: export interface ValidationResult {\n41:   valid: boolean;\n42:   error?: string;\n43: }\n44: \n45: function ok(): ValidationResult {\n46:   return { valid: true };\n47: }\n48: \n49: function fail(error: string): ValidationResult {\n50:   return { valid: false, error };\n51: }\n52: \n53: // ---------------------------------------------------------------------------\n54: // Validators\n55: // ---------------------------------------------------------------------------\n56: \n57: /**\n58:  * Validate a feature or subtask ID.\n59:  * Must be kebab-case, no traversals, no query params, no encoded chars.\n60:  */\n61: export function validateId(value: string, label: string = \"ID\"): ValidationResult {\n62:   if (!value || value.length === 0) {\n63:     return fail(`${label} must not be empty.`);\n64:   }\n65: \n66:   if (CONTROL_CHARS.test(value)) {\n67:     return fail(`${label} contains control characters.`);\n68:   }\n69: \n70:   if (PATH_TRAVERSAL.test(value)) {\n71:     return fail(`${label} contains path traversal sequence \"../\".`);\n72:   }\n73: \n74:   if (QUERY_FRAGMENT.test(value)) {\n75:     return fail(`${label} contains query/fragment characters (? or #).`);\n76:   }\n77: \n78:   if (PERCENT_ENCODED.test(value)) {\n79:     return fail(`${label} contains percent-encoded characters — possible double-encoding.`);\n80:   }\n81: \n82:   if (!ID_PATTERN.test(value)) {\n83:     return fail(\n84:       `${label} \"${value}\" is invalid. IDs must be kebab-case ` +\n85:       `(lowercase letters, digits, hyphens), 1–128 characters, starting with a letter or digit.`\n86:     );\n87:   }\n88: \n89:   return ok();\n90: }\n91: \n92: /**\n93:  * Validate free-text input (titles, descriptions, notes).\n94:  * Rejects control chars except \\t and \\n.\n95:  */\n96: export function validateText(value: string, label: string = \"text\"): ValidationResult {\n97:   if (CONTROL_CHARS.test(value)) {\n98:     return fail(`${label} contains control characters (non-printable bytes).`);\n99:   }\n100:   return ok();\n101: }\n102: \n103: /**\n104:  * Validate a branch name.\n105:  * No control chars, no \"..\", no spaces, no ~, ^, :, \\, ?, *, [\n106:  */\n107: export function validateBranchName(value: string, label: string = \"branch name\"): ValidationResult {\n108:   if (!value || value.length === 0) {\n109:     return fail(`${label} must not be empty.`);\n110:   }\n111: \n112:   if (CONTROL_CHARS.test(value)) {\n113:     return fail(`${label} contains control characters.`);\n114:   }\n115: \n116:   if (/\\.\\./.test(value)) {\n117:     return fail(`${label} contains \"..\" which is not allowed in git branch names.`);\n118:   }\n119: \n120:   if (/[ ~^:\\\\?*\\[]/.test(value)) {\n121:     return fail(`${label} contains characters not allowed in git branch names.`);\n122:   }\n123: \n124:   return ok();\n125: }\n126: \n127: /**\n128:  * Validate an ISO 8601 duration string.\n129:  */\n130: export function validateDuration(value: string, label: string = \"effort\"): ValidationResult {\n131:   if (!value || value.length === 0) {\n132:     return fail(`${label} must not be empty.`);\n133:   }\n134: \n135:   if (!DURATION_PATTERN.test(value)) {\n136:     return fail(\n137:       `${label} \"${value}\" is not a valid ISO 8601 duration. ` +\n138:       `Expected format: P[nY][nM][nD][T[nH][nM][nS]] (e.g., \"PT2H\", \"P1D\", \"P1DT4H30M\").`\n139:     );\n140:   }\n141: \n142:   return ok();\n143: }\n144: \n145: /**\n146:  * Validate a status value against the allowed set.\n147:  */\n148: export function validateEnum(\n149:   value: string,\n150:   allowed: readonly string[],\n151:   label: string = \"value\"\n152: ): ValidationResult {\n153:   if (!allowed.includes(value)) {\n154:     return fail(`${label} \"${value}\" is not valid. Allowed values: ${allowed.join(\", \")}`);\n155:   }\n156:   return ok();\n157: }\n158: \n159: // ---------------------------------------------------------------------------\n160: // Convenience: validate and exit on failure\n161: // ---------------------------------------------------------------------------\n162: \n163: /**\n164:  * Run a validation and exit with error message if invalid.\n165:  * For use at the CLI boundary.\n166:  */\n167: export function assertValid(result: ValidationResult): void {\n168:   if (!result.valid) {\n169:     console.error(`Validation error: ${result.error}`);\n170:     process.exit(1);\n171:   }\n172: }\n\n(End of file - total 172 lines)\n</content>","title":"src/lib/validate.ts","metadata":{"preview":"/**\n * validate.ts — Input validation / hardening for agent-ready CLI.\n *\n * All user/agent-supplied inputs pass through these validators at the CLI\n * boundary. This prevents hallucinated inputs from corrupting state.\n *\n * Rules:\n *   - Feature IDs: kebab-case only, no path traversals, no query params\n *   - Branch names: no control chars, no \"..\", no spaces\n *   - Free-text (titles, descriptions): no control chars except \\n \\t\n *   - Effort strings: ISO 8601 duration pattern only\n */\n\n// ---------------------------------------------------------------------------\n// Patterns\n// ---------------------------------------------------------------------------\n\n/** Valid feature/subtask ID: lowercase alphanumeric + hyphens, 1-128 chars */\nconst ID_PATTERN = /^[a-z0-9][a-z0-9-]{0,127}$/;\n","truncated":false,"loaded":[]},"time":{"start":1773351521435,"end":1773351521467}}}}
