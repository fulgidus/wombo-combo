,\n    \"priority\": \"high\",\n    \"status\": \"in_progress\"\n  },\n  {\n    \"content\": \"Subtask 3: Test CLI arg parsing edge cases (parseArgs with trailing flags, missing values, flag collisions, command/subcommand combinations)\",\n    \"priority\": \"high\",\n    \"status\": \"pending\"\n  },\n  {\n    \"content\": \"Subtask 4: Test wave state persistence and concurrent mutations (saveState/loadState atomicity, updateAgent, state file corruption recovery)\",\n    \"priority\": \"high\",\n    \"status\": \"pending\"\n  },\n  {\n    \"content\": \"Run typecheck and build to verify everything passes\",\n    \"priority\": \"high\",\n    \"status\": \"pending\"\n  }\n]","title":"4 todos","metadata":{"todos":[{"content":"Set up test infrastructure: update tsconfig.json to include tests, create test directory structure","priority":"high","status":"completed"},{"content":"Subtask 1: Test worktree listing and filtering (listWomboWorktrees, removeWorktree safety guard, cleanupAllWorktrees, basename bug)","priority":"high","status":"completed"},{"content":"Subtask 2: Test features YAML parsing and validation (loadFeatures, null features, empty arrays, invalid schema, duration parsing, dependency resolution)","priority":"high","status":"in_progress"},{"content":"Subtask 3: Test CLI arg parsing edge cases (parseArgs with trailing flags, missing values, flag collisions, command/subcommand combinations)","priority":"high","status":"pending"},{"content":"Subtask 4: Test wave state persistence and concurrent mutations (saveState/loadState atomicity, updateAgent, state file corruption recovery)","priority":"high","status":"pending"},{"content":"Run typecheck and build to verify everything passes","priority":"high","status":"pending"}],"truncated":false},"time":{"start":1773351648843,"end":1773351648844}}}}
