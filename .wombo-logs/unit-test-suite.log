{"type":"tool_use","timestamp":1773351514404,"sessionID":"ses_31c036cc5ffehJByI1GJ6dwrh0","part":{"id":"prt_ce3fcaf69001O5yX5HSRLRtHnj","sessionID":"ses_31c036cc5ffehJByI1GJ6dwrh0","messageID":"msg_ce3fca642001Ppyjn4N0OF4hZS","type":"tool","callID":"toolu_vrtx_01UbSDNZSExfkhC6Uq3tA33H","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-unit-test-suite/src/lib/worktree.ts"},"output":"<path>/home/fulgidus/Documents/wombo-unit-test-suite/src/lib/worktree.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * worktree.ts — Git worktree lifecycle management.\n3:  *\n4:  * Responsibilities:\n5:  *   - Create feature branches from a base branch\n6:  *   - Create git worktrees for each feature branch\n7:  *   - Run install command in worktrees\n8:  *   - List and remove worktrees\n9:  *   - Copy agent config files into worktrees\n10:  *\n11:  * IMPORTANT: Heavy operations (createWorktree, installDeps) are async\n12:  * to allow true parallelism with Promise.all.\n13:  */\n14: \n15: import { exec, execSync } from \"node:child_process\";\n16: import { existsSync, cpSync, statSync } from \"node:fs\";\n17: import { resolve, dirname, basename } from \"node:path\";\n18: import type { WomboConfig } from \"../config.js\";\n19: \n20: // ---------------------------------------------------------------------------\n21: // Types\n22: // ---------------------------------------------------------------------------\n23: \n24: export interface WorktreeInfo {\n25:   path: string;\n26:   branch: string;\n27:   head: string;\n28:   bare: boolean;\n29: }\n30: \n31: // ---------------------------------------------------------------------------\n32: // Diagnostic Logger\n33: // ---------------------------------------------------------------------------\n34: \n35: function ts(): string {\n36:   return new Date().toISOString().slice(11, 19); // HH:MM:SS\n37: }\n38: \n39: export function log(featureId: string, msg: string): void {\n40:   console.log(`  [${ts()}] ${featureId}: ${msg}`);\n41: }\n42: \n43: // ---------------------------------------------------------------------------\n44: // Async Command Runner\n45: // ---------------------------------------------------------------------------\n46: \n47: /**\n48:  * Run a command asynchronously. Returns stdout on success, throws on failure.\n49:  */\n50: function runAsync(\n51:   cmd: string,\n52:   opts?: { cwd?: string; timeoutMs?: number }\n53: ): Promise<string> {\n54:   return new Promise((resolve, reject) => {\n55:     exec(\n56:       cmd,\n57:       {\n58:         cwd: opts?.cwd,\n59:         encoding: \"utf-8\",\n60:         timeout: opts?.timeoutMs ?? 0,\n61:         maxBuffer: 10 * 1024 * 1024,\n62:       },\n63:       (error, stdout, stderr) => {\n64:         if (error) {\n65:           const errMsg = stderr?.trim() || stdout?.trim() || error.message;\n66:           reject(new Error(`Command failed: ${cmd}\\n${errMsg}`));\n67:         } else {\n68:           resolve((stdout ?? \"\").trim());\n69:         }\n70:       }\n71:     );\n72:   });\n73: }\n74: \n75: /**\n76:  * Synchronous run — only for quick, non-blocking operations.\n77:  */\n78: function runSync(\n79:   cmd: string,\n80:   opts?: { cwd?: string; silent?: boolean; timeoutMs?: number }\n81: ): string {\n82:   try {\n83:     return execSync(cmd, {\n84:       cwd: opts?.cwd,\n85:       encoding: \"utf-8\",\n86:       stdio: opts?.silent ? \"pipe\" : [\"pipe\", \"pipe\", \"pipe\"],\n87:       timeout: opts?.timeoutMs,\n88:       maxBuffer: 10 * 1024 * 1024,\n89:     }).trim();\n90:   } catch (err: any) {\n91:     const stderr = err.stderr?.toString().trim() || \"\";\n92:     const stdout = err.stdout?.toString().trim() || \"\";\n93:     throw new Error(\n94:       `Command failed: ${cmd}\\n${stderr || stdout || err.message}`\n95:     );\n96:   }\n97: }\n98: \n99: // ---------------------------------------------------------------------------\n100: // Branch Management\n101: // ---------------------------------------------------------------------------\n102: \n103: /**\n104:  * Create a feature branch from the base branch.\n105:  * If it already exists and is NOT checked out in a worktree, reset it.\n106:  * If it's checked out in a worktree, leave it alone (resume case).\n107:  */\n108: async function createBranch(\n109:   projectRoot: string,\n110:   branchName: string,\n111:   baseBranch: string\n112: ): Promise<void> {\n113:   const existing = await runAsync(\n114:     `git branch --list \"${branchName}\"`,\n115:     { cwd: projectRoot }\n116:   );\n117:   if (existing.trim()) {\n118:     // Branch exists — try to delete and recreate.\n119:     // If deletion fails (e.g. checked out in worktree), that's fine —\n120:     // we'll reuse the existing branch with its work intact.\n121:     try {\n122:       await runAsync(`git branch -D \"${branchName}\"`, { cwd: projectRoot });\n123:     } catch {\n124:       // Branch is checked out in a worktree — reuse as-is\n125:       return;\n126:     }\n127:   }\n128:   await runAsync(`git branch \"${branchName}\" \"${baseBranch}\"`, {\n129:     cwd: projectRoot,\n130:   });\n131: }\n132: \n133: /**\n134:  * Generate the branch name for a feature using config prefix.\n135:  */\n136: export function featureBranchName(\n137:   featureId: string,\n138:   config: WomboConfig\n139: ): string {\n140:   return `${config.git.branchPrefix}${featureId}`;\n141: }\n142: \n143: /**\n144:  * Generate the worktree path for a feature (sibling directory to project root).\n145:  */\n146: export function worktreePath(\n147:   projectRoot: string,\n148:   featureId: string,\n149:   config: WomboConfig\n150: ): string {\n151:   const parentDir = dirname(projectRoot);\n152:   return resolve(parentDir, `${config.git.worktreePrefix}${featureId}`);\n153: }\n154: \n155: // ---------------------------------------------------------------------------\n156: // Worktree Lifecycle (async)\n157: // ---------------------------------------------------------------------------\n158: \n159: /**\n160:  * Create a git worktree for a feature branch.\n161:  * Returns the absolute path to the worktree.\n162:  *\n163:  * If a valid worktree already exists at the expected path (has .git file),\n164:  * reuses it — this is essential for the resume case where worktrees have\n165:  * real work but may be missing node_modules.\n166:  */\n167: export async function createWorktree(\n168:   projectRoot: string,\n169:   featureId: string,\n170:   baseBranch: string,\n171:   config: WomboConfig\n172: ): Promise<string> {\n173:   const branch = featureBranchName(featureId, config);\n174:   const wtPath = worktreePath(projectRoot, featureId, config);\n175: \n176:   // If a valid worktree already exists, reuse it (resume case).\n177:   // A git worktree has a .git *file* (not directory) pointing to the main repo.\n178:   if (existsSync(wtPath) && existsSync(resolve(wtPath, \".git\"))) {\n179:     log(featureId, \"reusing existing worktree (has work)\");\n180:     // Still copy config files in case they're missing\n181:     copyConfigFiles(projectRoot, wtPath, featureId, config);\n182:     return wtPath;\n183:   }\n184: \n185:   // Create the branch if it doesn't exist\n186:   log(featureId, \"creating branch...\");\n187:   await createBranch(projectRoot, branch, baseBranch);\n188: \n189:   // Remove existing worktree directory if present but invalid\n190:   if (existsSync(wtPath)) {\n191:     log(featureId, \"removing old worktree...\");\n192:     try {\n193:       await runAsync(`git worktree remove --force \"${wtPath}\"`, {\n194:         cwd: projectRoot,\n195:       });\n196:     } catch {\n197:       await runAsync(`rm -rf \"${wtPath}\"`);\n198:       await runAsync(`git worktree prune`, { cwd: projectRoot });\n199:     }\n200:   }\n201: \n202:   // Create the worktree\n203:   log(featureId, \"creating worktree...\");\n204:   await runAsync(`git worktree add \"${wtPath}\" \"${branch}\"`, {\n205:     cwd: projectRoot,\n206:   });\n207: \n208:   // Copy agent config files into worktree\n209:   copyConfigFiles(projectRoot, wtPath, featureId, config);\n210: \n211:   log(featureId, \"worktree ready\");\n212:   return wtPath;\n213: }\n214: \n215: /**\n216:  * Copy agent config files from project root into a worktree.\n217:  * Best-effort — logs warnings but doesn't throw.\n218:  */\n219: function copyConfigFiles(\n220:   projectRoot: string,\n221:   wtPath: string,\n222:   featureId: string,\n223:   config: WomboConfig\n224: ): void {\n225:   for (const configFile of config.agent.configFiles) {\n226:     const srcPath = resolve(projectRoot, configFile);\n227:     if (!existsSync(srcPath)) continue;\n228: \n229:     const destPath = resolve(wtPath, configFile);\n230:     try {\n231:       const stat = statSync(srcPath);\n232:       if (stat.isDirectory()) {\n233:         cpSync(srcPath, destPath, { recursive: true });\n234:       } else {\n235:         cpSync(srcPath, destPath);\n236:       }\n237:     } catch {\n238:       // Non-critical — best effort\n239:     }\n240:   }\n241: \n242:   // Verify all config files were copied successfully\n243:   verifyConfigFiles(projectRoot, wtPath, featureId, config);\n244: }\n245: \n246: // ---------------------------------------------------------------------------\n247: // Config File Verification\n248: // ---------------------------------------------------------------------------\n249: \n250: /**\n251:  * Verify that all expected config files were copied into the worktree.\n252:  * Logs a warning for any that are missing. This is a safety net on top\n253:  * of the best-effort cpSync logic in createWorktree.\n254:  */\n255: function verifyConfigFiles(\n256:   projectRoot: string,\n257:   wtPath: string,\n258:   featureId: string,\n259:   config: WomboConfig\n260: ): void {\n261:   const missing: string[] = [];\n262: \n263:   for (const configFile of config.agent.configFiles) {\n264:     const srcPath = resolve(projectRoot, configFile);\n265:     const destPath = resolve(wtPath, configFile);\n266: \n267:     // Only check files/dirs that exist in the source project\n268:     if (!existsSync(srcPath)) continue;\n269: \n270:     if (!existsSync(destPath)) {\n271:       missing.push(configFile);\n272:     }\n273:   }\n274: \n275:   if (missing.length > 0) {\n276:     log(\n277:       featureId,\n278:       `\\x1b[33mWARNING\\x1b[0m: config files missing in worktree: ${missing.join(\", \")}`\n279:     );\n280:   }\n281: }\n282: \n283: /**\n284:  * Install dependencies in a worktree.\n285:  */\n286: export async function installDeps(\n287:   wtPath: string,\n288:   featureId: string,\n289:   config: WomboConfig\n290: ): Promise<void> {\n291:   log(featureId, `running ${config.install.command}...`);\n292:   const start = Date.now();\n293:   await runAsync(config.install.command, {\n294:     cwd: wtPath,\n295:     timeoutMs: config.install.timeout,\n296:   });\n297:   const elapsed = ((Date.now() - start) / 1000).toFixed(1);\n298:   log(featureId, `install done (${elapsed}s)`);\n299: }\n300: \n301: /**\n302:  * Check if a worktree already exists and has node_modules (fully ready).\n303:  */\n304: export function worktreeReady(wtPath: string): boolean {\n305:   return (\n306:     existsSync(wtPath) &&\n307:     existsSync(resolve(wtPath, \"node_modules\"))\n308:   );\n309: }\n310: \n311: /**\n312:  * Check if a valid git worktree exists at the path (may lack node_modules).\n313:  * A git worktree has a .git *file* (not directory) pointing to the main repo.\n314:  */\n315: export function worktreeExists(wtPath: string): boolean {\n316:   return existsSync(wtPath) && existsSync(resolve(wtPath, \".git\"));\n317: }\n318: \n319: // ---------------------------------------------------------------------------\n320: // Worktree Listing / Cleanup (sync)\n321: // ---------------------------------------------------------------------------\n322: \n323: /**\n324:  * List all git worktrees.\n325:  */\n326: export function listWorktrees(projectRoot: string): WorktreeInfo[] {\n327:   const output = runSync(\"git worktree list --porcelain\", {\n328:     cwd: projectRoot,\n329:     silent: true,\n330:   });\n331:   if (!output) return [];\n332: \n333:   const worktrees: WorktreeInfo[] = [];\n334:   let current: Partial<WorktreeInfo> = {};\n335: \n336:   for (const line of output.split(\"\\n\")) {\n337:     if (line.startsWith(\"worktree \")) {\n338:       if (current.path) worktrees.push(current as WorktreeInfo);\n339:       current = { path: line.slice(9), bare: false };\n340:     } else if (line.startsWith(\"HEAD \")) {\n341:       current.head = line.slice(5);\n342:     } else if (line.startsWith(\"branch \")) {\n343:       current.branch = line.slice(7).replace(\"refs/heads/\", \"\");\n344:     } else if (line === \"bare\") {\n345:       current.bare = true;\n346:     } else if (line === \"\" && current.path) {\n347:       worktrees.push(current as WorktreeInfo);\n348:       current = {};\n349:     }\n350:   }\n351:   if (current.path) worktrees.push(current as WorktreeInfo);\n352: \n353:   return worktrees;\n354: }\n355: \n356: /**\n357:  * List only wombo-related worktrees.\n358:  *\n359:  * SAFETY: Filters by checking that the *basename* of the worktree path\n360:  * starts with the worktreePrefix. A naive `.includes()` on the full path\n361:  * would match the main repo itself if its directory name contained the\n362:  * prefix (e.g. \"wombo-combo\" contains \"wombo-\"), causing cleanup to\n363:  * destroy the project root.\n364:  *\n365:  * Additionally, the main repo worktree (projectRoot) is always excluded\n366:  * as a defensive guard.\n367:  */\n368: export function listWomboWorktrees(\n369:   projectRoot: string,\n370:   config: WomboConfig\n371: ): WorktreeInfo[] {\n372:   const resolvedRoot = resolve(projectRoot);\n373:   return listWorktrees(projectRoot).filter((wt) => {\n374:     // Never include the main project root\n375:     if (resolve(wt.path) === resolvedRoot) return false;\n376:     // Match only worktrees whose directory name starts with the prefix\n377:     return basename(wt.path).startsWith(config.git.worktreePrefix);\n378:   });\n379: }\n380: \n381: /**\n382:  * Remove a worktree and optionally delete its branch.\n383:  *\n384:  * SAFETY: Refuses to remove the project root itself. This is a hard guard\n385:  * against bugs in worktree filtering that could otherwise destroy the main repo.\n386:  */\n387: export function removeWorktree(\n388:   projectRoot: string,\n389:   wtPath: string,\n390:   deleteBranchToo: boolean = true\n391: ): void {\n392:   // Hard safety check: never remove the main project root\n393:   if (resolve(wtPath) === resolve(projectRoot)) {\n394:     throw new Error(\n395:       `SAFETY: refusing to remove project root as worktree: ${wtPath}`\n396:     );\n397:   }\n398: \n399:   const worktrees = listWorktrees(projectRoot);\n400:   const wt = worktrees.find((w) => w.path === wtPath);\n401: \n402:   try {\n403:     runSync(`git worktree remove --force \"${wtPath}\"`, { cwd: projectRoot });\n404:   } catch {\n405:     if (existsSync(wtPath)) {\n406:       runSync(`rm -rf \"${wtPath}\"`);\n407:     }\n408:     runSync(\"git worktree prune\", { cwd: projectRoot });\n409:   }\n410: \n411:   if (deleteBranchToo && wt?.branch) {\n412:     try {\n413:       runSync(`git branch -D \"${wt.branch}\"`, {\n414:         cwd: projectRoot,\n415:         silent: true,\n416:       });\n417:     } catch {\n418:       // Branch may have been merged or already deleted\n419:     }\n420:   }\n421: }\n422: \n423: /**\n424:  * Check if a feature branch has any commits beyond the base branch.\n425:  * Returns true if the branch has diverged (i.e., the agent made commits).\n426:  */\n427: export function branchHasChanges(\n428:   projectRoot: string,\n429:   branch: string,\n430:   baseBranch: string\n431: ): boolean {\n432:   try {\n433:     const count = runSync(\n434:       `git rev-list --count \"${baseBranch}..${branch}\"`,\n435:       { cwd: projectRoot, silent: true }\n436:     );\n437:     return parseInt(count, 10) > 0;\n438:   } catch {\n439:     // If the branch doesn't exist or git fails, assume no changes\n440:     return false;\n441:   }\n442: }\n443: \n444: /**\n445:  * Remove all wombo-related worktrees and prune.\n446:  */\n447: export function cleanupAllWorktrees(\n448:   projectRoot: string,\n449:   config: WomboConfig\n450: ): number {\n451:   const womboWorktrees = listWomboWorktrees(projectRoot, config);\n452:   let removed = 0;\n453:   for (const wt of womboWorktrees) {\n454:     try {\n455:       removeWorktree(projectRoot, wt.path, false);\n456:       removed++;\n457:     } catch (err: any) {\n458:       console.error(`Failed to remove worktree ${wt.path}: ${err.message}`);\n459:     }\n460:   }\n461:   try {\n462:     runSync(\"git worktree prune\", { cwd: projectRoot });\n463:   } catch {\n464:     // Prune is best-effort — may fail if repo state is already clean\n465:   }\n466:   return removed;\n467: }\n\n(End of file - total 467 lines)\n</content>","title":"src/lib/worktree.ts","metadata":{"preview":"/**\n * worktree.ts — Git worktree lifecycle management.\n *\n * Responsibilities:\n *   - Create feature branches from a base branch\n *   - Create git worktrees for each feature branch\n *   - Run install command in worktrees\n *   - List and remove worktrees\n *   - Copy agent config files into worktrees\n *\n * IMPORTANT: Heavy operations (createWorktree, installDeps) are async\n * to allow true parallelism with Promise.all.\n */\n\nimport { exec, execSync } from \"node:child_process\";\nimport { existsSync, cpSync, statSync } from \"node:fs\";\nimport { resolve, dirname, basename } from \"node:path\";\nimport type { WomboConfig } from \"../config.js\";\n\n// ---------------------------------------------------------------------------","truncated":false,"loaded":[]},"time":{"start":1773351514397,"end":1773351514402}}}}
{"type":"tool_use","timestamp":1773351514821,"sessionID":"ses_31c036cc5ffehJByI1GJ6dwrh0","part":{"id":"prt_ce3fcb11f001A13cbG36hid0j7","sessionID":"ses_31c036cc5ffehJByI1GJ6dwrh0","messageID":"msg_ce3fca642001Ppyjn4N0OF4hZS","type":"tool","callID":"toolu_vrtx_01ESEGyWy62BdeXMQXjxYJBp","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-unit-test-suite/src/lib/features.ts"},"output":"<path>/home/fulgidus/Documents/wombo-unit-test-suite/src/lib/features.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * features.ts — Parse features YAML and provide feature selection/filtering.\n3:  *\n4:  * Responsibilities:\n5:  *   - Load and parse the features file with full type safety\n6:  *   - Parse ISO 8601 durations into comparable minutes\n7:  *   - Filter features by status, priority, difficulty, dependency readiness\n8:  *   - Select features by various strategies (top-priority, quickest-wins, etc.)\n9:  *   - Resolve dependency graphs to determine which features are ready to start\n10:  *   - Write-back capability for feature management commands\n11:  */\n12: \n13: import { readFileSync, writeFileSync, existsSync } from \"node:fs\";\n14: import { resolve, dirname, join } from \"node:path\";\n15: import { parse as parseYaml, stringify as stringifyYaml } from \"yaml\";\n16: import { createInterface } from \"node:readline\";\n17: import type { WomboConfig } from \"../config.js\";\n18: \n19: // ---------------------------------------------------------------------------\n20: // Template path (resolved relative to this source file)\n21: // ---------------------------------------------------------------------------\n22: \n23: export const FEATURES_TEMPLATE_PATH = join(dirname(import.meta.dir), \"templates\", \".features.yml\");\n24: \n25: // ---------------------------------------------------------------------------\n26: // Types\n27: // ---------------------------------------------------------------------------\n28: \n29: export type FeatureStatus =\n30:   | \"backlog\"\n31:   | \"planned\"\n32:   | \"in_progress\"\n33:   | \"blocked\"\n34:   | \"in_review\"\n35:   | \"done\"\n36:   | \"cancelled\";\n37: \n38: export type Priority = \"critical\" | \"high\" | \"medium\" | \"low\" | \"wishlist\";\n39: \n40: export type Difficulty = \"trivial\" | \"easy\" | \"medium\" | \"hard\" | \"very_hard\";\n41: \n42: export interface Subtask {\n43:   id: string;\n44:   title: string;\n45:   description: string;\n46:   status: FeatureStatus;\n47:   completion: number;\n48:   difficulty: Difficulty;\n49:   priority: Priority;\n50:   depends_on: string[];\n51:   effort: string;\n52:   started_at: string | null;\n53:   ended_at: string | null;\n54:   constraints: string[];\n55:   forbidden: string[];\n56:   references: string[];\n57:   notes: string[];\n58:   subtasks: Subtask[];\n59: }\n60: \n61: export interface Feature {\n62:   id: string;\n63:   title: string;\n64:   description: string;\n65:   status: FeatureStatus;\n66:   completion: number;\n67:   difficulty: Difficulty;\n68:   priority: Priority;\n69:   depends_on: string[];\n70:   effort: string;\n71:   started_at: string | null;\n72:   ended_at: string | null;\n73:   constraints: string[];\n74:   forbidden: string[];\n75:   references: string[];\n76:   notes: string[];\n77:   subtasks: Subtask[];\n78: }\n79: \n80: export interface FeaturesFile {\n81:   version: string;\n82:   meta: {\n83:     created_at: string;\n84:     updated_at: string;\n85:     project: string;\n86:     generator: string;\n87:     maintainer: string;\n88:   };\n89:   features: Feature[];\n90:   archive: Feature[];\n91: }\n92: \n93: // Priority ordering (lower = more important)\n94: const PRIORITY_ORDER: Record<Priority, number> = {\n95:   critical: 0,\n96:   high: 1,\n97:   medium: 2,\n98:   low: 3,\n99:   wishlist: 4,\n100: };\n101: \n102: // Difficulty ordering (lower = easier)\n103: const DIFFICULTY_ORDER: Record<Difficulty, number> = {\n104:   trivial: 0,\n105:   easy: 1,\n106:   medium: 2,\n107:   hard: 3,\n108:   very_hard: 4,\n109: };\n110: \n111: // ---------------------------------------------------------------------------\n112: // ISO 8601 Duration Parser\n113: // ---------------------------------------------------------------------------\n114: \n115: /**\n116:  * Parse an ISO 8601 duration string into total minutes.\n117:  * Supports: P[nD][T[nH][nM][nS]]\n118:  * Examples: PT1H -> 60, PT30M -> 30, P1D -> 1440, P2DT4H -> 3360, PT1H30M -> 90\n119:  */\n120: export function parseDurationMinutes(iso: string): number {\n121:   const match = iso.match(\n122:     /^P(?:(\\d+)D)?(?:T(?:(\\d+)H)?(?:(\\d+)M)?(?:(\\d+)S)?)?$/\n123:   );\n124:   if (!match) return Infinity; // unparseable -> sort to end\n125:   const days = parseInt(match[1] || \"0\", 10);\n126:   const hours = parseInt(match[2] || \"0\", 10);\n127:   const minutes = parseInt(match[3] || \"0\", 10);\n128:   const seconds = parseInt(match[4] || \"0\", 10);\n129:   return days * 24 * 60 + hours * 60 + minutes + Math.ceil(seconds / 60);\n130: }\n131: \n132: /**\n133:  * Format minutes into a human-readable string.\n134:  */\n135: export function formatDuration(minutes: number): string {\n136:   if (minutes === Infinity) return \"unknown\";\n137:   if (minutes < 60) return `${minutes}m`;\n138:   const h = Math.floor(minutes / 60);\n139:   const m = minutes % 60;\n140:   if (h >= 24) {\n141:     const d = Math.floor(h / 24);\n142:     const rh = h % 24;\n143:     if (rh === 0 && m === 0) return `${d}d`;\n144:     if (m === 0) return `${d}d ${rh}h`;\n145:     return `${d}d ${rh}h ${m}m`;\n146:   }\n147:   return m === 0 ? `${h}h` : `${h}h ${m}m`;\n148: }\n149: \n150: // ---------------------------------------------------------------------------\n151: // Features File Existence Guard\n152: // ---------------------------------------------------------------------------\n153: \n154: /**\n155:  * Prompt the user with a yes/no question via stdin.\n156:  */\n157: function promptYesNo(question: string): Promise<boolean> {\n158:   const rl = createInterface({ input: process.stdin, output: process.stdout });\n159:   return new Promise((resolve) => {\n160:     rl.question(question, (answer) => {\n161:       rl.close();\n162:       resolve(answer.trim().toLowerCase().startsWith(\"y\"));\n163:     });\n164:   });\n165: }\n166: \n167: /**\n168:  * Ensure the features file exists before any command that needs it.\n169:  * If the file is missing, prompt the user to generate one from the template.\n170:  */\n171: export async function ensureFeaturesFile(\n172:   projectRoot: string,\n173:   config: WomboConfig\n174: ): Promise<void> {\n175:   const filePath = resolve(projectRoot, config.featuresFile);\n176: \n177:   if (existsSync(filePath)) return;\n178: \n179:   console.log(`\\nFeatures file not found: ${config.featuresFile}`);\n180: \n181:   const generate = await promptYesNo(\n182:     \"Generate a new features file from template? (y/N): \"\n183:   );\n184: \n185:   if (!generate) {\n186:     console.error(\n187:       `Cannot proceed without a features file. Create one manually or run again and accept the prompt.`\n188:     );\n189:     process.exit(1);\n190:   }\n191: \n192:   // Read template, update timestamps, write to project root\n193:   const template = readFileSync(FEATURES_TEMPLATE_PATH, \"utf-8\");\n194:   const now = new Date().toISOString();\n195:   const content = template\n196:     .replace(/created_at:\\s*\".*?\"/, `created_at: \"${now}\"`)\n197:     .replace(/updated_at:\\s*\".*?\"/, `updated_at: \"${now}\"`);\n198: \n199:   writeFileSync(filePath, content, \"utf-8\");\n200:   console.log(`Created ${config.featuresFile} from template.\\n`);\n201: }\n202: \n203: // ---------------------------------------------------------------------------\n204: // Loader\n205: // ---------------------------------------------------------------------------\n206: \n207: /**\n208:  * Load and parse the features YAML file from the project root.\n209:  * Uses config.featuresFile for the file path.\n210:  */\n211: export function loadFeatures(\n212:   projectRoot: string,\n213:   config: WomboConfig\n214: ): FeaturesFile {\n215:   const filePath = resolve(projectRoot, config.featuresFile);\n216:   const raw = readFileSync(filePath, \"utf-8\");\n217:   const parsed = parseYaml(raw) as FeaturesFile;\n218: \n219:   // Normalize: ensure top-level arrays are never null/undefined (YAML parses\n220:   // empty keys as null).\n221:   parsed.features = parsed.features ?? [];\n222:   parsed.archive = parsed.archive ?? [];\n223: \n224:   for (const f of [...parsed.features, ...parsed.archive]) {\n225:     normalizeFeature(f);\n226:   }\n227: \n228:   return parsed;\n229: }\n230: \n231: /**\n232:  * Save the features file back to disk (for management commands).\n233:  */\n234: export function saveFeatures(\n235:   projectRoot: string,\n236:   config: WomboConfig,\n237:   data: FeaturesFile\n238: ): void {\n239:   const filePath = resolve(projectRoot, config.featuresFile);\n240:   data.meta.updated_at = new Date().toISOString();\n241:   const yaml = stringifyYaml(data, {\n242:     lineWidth: 120,\n243:     defaultKeyType: \"PLAIN\",\n244:     defaultStringType: \"PLAIN\",\n245:   });\n246:   writeFileSync(filePath, yaml, \"utf-8\");\n247: }\n248: \n249: function normalizeFeature(f: Feature | Subtask): void {\n250:   f.depends_on = f.depends_on ?? [];\n251:   f.constraints = f.constraints ?? [];\n252:   f.forbidden = f.forbidden ?? [];\n253:   f.references = f.references ?? [];\n254:   f.notes = f.notes ?? [];\n255:   f.subtasks = f.subtasks ?? [];\n256:   for (const s of f.subtasks) {\n257:     normalizeFeature(s);\n258:   }\n259: }\n260: \n261: // ---------------------------------------------------------------------------\n262: // Dependency Resolution\n263: // ---------------------------------------------------------------------------\n264: \n265: /**\n266:  * Get all feature IDs that are done (status === \"done\" or completion === 100).\n267:  */\n268: function getDoneIds(features: Feature[], archive: Feature[]): Set<string> {\n269:   const done = new Set<string>();\n270:   const collectDone = (items: (Feature | Subtask)[]) => {\n271:     for (const item of items) {\n272:       if (item.status === \"done\" || item.completion === 100) {\n273:         done.add(item.id);\n274:       }\n275:       if (item.subtasks?.length) {\n276:         collectDone(item.subtasks);\n277:       }\n278:     }\n279:   };\n280:   collectDone(features);\n281:   collectDone(archive);\n282:   return done;\n283: }\n284: \n285: /**\n286:  * Check if a feature's dependencies are all satisfied.\n287:  */\n288: export function areDependenciesMet(\n289:   feature: Feature,\n290:   doneIds: Set<string>\n291: ): boolean {\n292:   return feature.depends_on.every((dep) => doneIds.has(dep));\n293: }\n294: \n295: /**\n296:  * Get all features that are ready to start (backlog + deps met).\n297:  */\n298: export function getReadyFeatures(data: FeaturesFile): Feature[] {\n299:   const doneIds = getDoneIds(data.features, data.archive);\n300:   return data.features.filter(\n301:     (f) =>\n302:       f.status === \"backlog\" &&\n303:       f.completion === 0 &&\n304:       areDependenciesMet(f, doneIds)\n305:   );\n306: }\n307: \n308: /**\n309:  * Get done IDs (exported for use in selection error messages).\n310:  */\n311: export function getDoneFeatureIds(data: FeaturesFile): Set<string> {\n312:   return getDoneIds(data.features, data.archive);\n313: }\n314: \n315: // ---------------------------------------------------------------------------\n316: // Selection Strategies\n317: // ---------------------------------------------------------------------------\n318: \n319: export interface SelectionOptions {\n320:   /** Select top N by priority (highest priority first, then lowest effort) */\n321:   topPriority?: number;\n322:   /** Select N quickest wins (lowest effort first) */\n323:   quickestWins?: number;\n324:   /** Select all features matching this priority level */\n325:   priority?: Priority;\n326:   /** Select all features matching this difficulty level */\n327:   difficulty?: Difficulty;\n328:   /** Select specific feature IDs (comma-separated) */\n329:   featureIds?: string[];\n330:   /** Select all ready features */\n331:   allReady?: boolean;\n332: }\n333: \n334: /**\n335:  * Select features based on the given strategy.\n336:  * Always filters to only ready features (backlog + deps met) first.\n337:  */\n338: export function selectFeatures(\n339:   data: FeaturesFile,\n340:   options: SelectionOptions\n341: ): Feature[] {\n342:   const ready = getReadyFeatures(data);\n343: \n344:   if (options.allReady) {\n345:     return sortByPriorityThenEffort(ready);\n346:   }\n347: \n348:   if (options.featureIds?.length) {\n349:     const idSet = new Set(options.featureIds);\n350:     const selected = ready.filter((f) => idSet.has(f.id));\n351:     const missing = options.featureIds.filter(\n352:       (id) => !selected.find((f) => f.id === id)\n353:     );\n354:     if (missing.length) {\n355:       const allIds = data.features.map((f) => f.id);\n356:       const doneIds = getDoneIds(data.features, data.archive);\n357:       for (const m of missing) {\n358:         if (!allIds.includes(m)) {\n359:           console.error(`  Feature \"${m}\" does not exist in the features file`);\n360:         } else {\n361:           const feat = data.features.find((f) => f.id === m)!;\n362:           console.error(\n363:             `  Feature \"${m}\" is not ready (status: ${feat.status}, deps met: ${areDependenciesMet(feat, doneIds)})`\n364:           );\n365:         }\n366:       }\n367:     }\n368:     return sortByPriorityThenEffort(selected);\n369:   }\n370: \n371:   if (options.priority) {\n372:     return sortByPriorityThenEffort(\n373:       ready.filter((f) => f.priority === options.priority)\n374:     );\n375:   }\n376: \n377:   if (options.difficulty) {\n378:     return sortByEffort(ready.filter((f) => f.difficulty === options.difficulty));\n379:   }\n380: \n381:   if (options.topPriority) {\n382:     return sortByPriorityThenEffort(ready).slice(0, options.topPriority);\n383:   }\n384: \n385:   if (options.quickestWins) {\n386:     return sortByEffort(ready).slice(0, options.quickestWins);\n387:   }\n388: \n389:   // Default: return all ready, sorted by priority\n390:   return sortByPriorityThenEffort(ready);\n391: }\n392: \n393: // ---------------------------------------------------------------------------\n394: // Sorting Helpers\n395: // ---------------------------------------------------------------------------\n396: \n397: function sortByPriorityThenEffort(features: Feature[]): Feature[] {\n398:   return [...features].sort((a, b) => {\n399:     const pDiff = PRIORITY_ORDER[a.priority] - PRIORITY_ORDER[b.priority];\n400:     if (pDiff !== 0) return pDiff;\n401:     return parseDurationMinutes(a.effort) - parseDurationMinutes(b.effort);\n402:   });\n403: }\n404: \n405: function sortByEffort(features: Feature[]): Feature[] {\n406:   return [...features].sort(\n407:     (a, b) => parseDurationMinutes(a.effort) - parseDurationMinutes(b.effort)\n408:   );\n409: }\n410: \n411: // ---------------------------------------------------------------------------\n412: // Utility Exports\n413: // ---------------------------------------------------------------------------\n414: \n415: export { PRIORITY_ORDER, DIFFICULTY_ORDER };\n416: \n417: /**\n418:  * Get a compact summary of a feature for display.\n419:  */\n420: export function featureSummary(f: Feature): string {\n421:   const effort = formatDuration(parseDurationMinutes(f.effort));\n422:   return `[${f.priority}/${f.difficulty}] ${f.id} -- ${f.title} (${effort})`;\n423: }\n424: \n425: /**\n426:  * Recursively search a list of features (and their subtasks) for a matching ID.\n427:  */\n428: function findInList(features: Feature[], id: string): Feature | undefined {\n429:   for (const f of features) {\n430:     if (f.id === id) return f;\n431:     if (f.subtasks?.length) {\n432:       const found = findInList(f.subtasks, id);\n433:       if (found) return found;\n434:     }\n435:   }\n436:   return undefined;\n437: }\n438: \n439: /**\n440:  * Find a feature or subtask by ID across active features, their subtasks\n441:  * (recursively), and the archive list.\n442:  */\n443: export function findFeatureById(\n444:   data: FeaturesFile,\n445:   id: string\n446: ): Feature | undefined {\n447:   return (\n448:     findInList(data.features, id) ??\n449:     (data.archive ? findInList(data.archive, id) : undefined)\n450:   );\n451: }\n452: \n453: /**\n454:  * Create a blank feature with all required fields initialized.\n455:  */\n456: export function createBlankFeature(\n457:   id: string,\n458:   title: string,\n459:   description: string = \"\",\n460:   opts?: {\n461:     priority?: Priority;\n462:     difficulty?: Difficulty;\n463:     effort?: string;\n464:   }\n465: ): Feature {\n466:   return {\n467:     id,\n468:     title,\n469:     description,\n470:     status: \"backlog\",\n471:     completion: 0,\n472:     difficulty: opts?.difficulty ?? \"medium\",\n473:     priority: opts?.priority ?? \"medium\",\n474:     depends_on: [],\n475:     effort: opts?.effort ?? \"PT1H\",\n476:     started_at: null,\n477:     ended_at: null,\n478:     constraints: [],\n479:     forbidden: [],\n480:     references: [],\n481:     notes: [],\n482:     subtasks: [],\n483:   };\n484: }\n485: \n486: /**\n487:  * Get all feature IDs (active + archive), useful for validation.\n488:  */\n489: export function allFeatureIds(data: FeaturesFile): string[] {\n490:   const ids: string[] = [];\n491:   const collect = (items: (Feature | Subtask)[]) => {\n492:     for (const item of items) {\n493:       ids.push(item.id);\n494:       if (item.subtasks?.length) collect(item.subtasks);\n495:     }\n496:   };\n497:   collect(data.features);\n498:   collect(data.archive ?? []);\n499:   return ids;\n500: }\n\n(End of file - total 500 lines)\n</content>","title":"src/lib/features.ts","metadata":{"preview":"/**\n * features.ts — Parse features YAML and provide feature selection/filtering.\n *\n * Responsibilities:\n *   - Load and parse the features file with full type safety\n *   - Parse ISO 8601 durations into comparable minutes\n *   - Filter features by status, priority, difficulty, dependency readiness\n *   - Select features by various strategies (top-priority, quickest-wins, etc.)\n *   - Resolve dependency graphs to determine which features are ready to start\n *   - Write-back capability for feature management commands\n */\n\nimport { readFileSync, writeFileSync, existsSync } from \"node:fs\";\nimport { resolve, dirname, join } from \"node:path\";\nimport { parse as parseYaml, stringify as stringifyYaml } from \"yaml\";\nimport { createInterface } from \"node:readline\";\nimport type { WomboConfig } from \"../config.js\";\n\n// ---------------------------------------------------------------------------\n// Template path (resolved relative to this source file)","truncated":false,"loaded":[]},"time":{"start":1773351514813,"end":1773351514820}}}}
{"type":"tool_use","timestamp":1773351515261,"sessionID":"ses_31c036cc5ffehJByI1GJ6dwrh0","part":{"id":"prt_ce3fcb2c0001a9G2wVgkrnr5ac","sessionID":"ses_31c036cc5ffehJByI1GJ6dwrh0","messageID":"msg_ce3fca642001Ppyjn4N0OF4hZS","type":"tool","callID":"toolu_vrtx_01ShnamEtZKas69xz76YTChu","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-unit-test-suite/src/index.ts"},"output":"<path>/home/fulgidus/Documents/wombo-unit-test-suite/src/index.ts</path>\n<type>file</type>\n<content>1: #!/usr/bin/env bun\n2: /**\n3:  * index.ts — CLI entry point for the Wombo agent orchestration system.\n4:  *\n5:  * Usage:\n6:  *   wombo init\n7:  *   wombo launch --top-priority 3\n8:  *   wombo launch --quickest-wins 5\n9:  *   wombo launch --priority high\n10:  *   wombo launch --difficulty easy\n11:  *   wombo launch --features \"feat-a,feat-b\"\n12:  *   wombo launch --all-ready\n13:  *   wombo launch ... --max-concurrent 3 --model \"anthropic/claude-sonnet-4-20250514\"\n14:  *   wombo launch ... --interactive\n15:  *   wombo resume\n16:  *   wombo status\n17:  *   wombo verify [feature-id]\n18:  *   wombo merge [feature-id]\n19:  *   wombo retry <feature-id>\n20:  *   wombo cleanup\n21:  *   wombo features list [--status <s>] [--priority <p>] [--difficulty <d>] [--ready] [--include-archive]\n22:  *   wombo features add <id> <title> [options]\n23:  *   wombo features set-status <feature-id> <status>\n24:  *   wombo features check\n25:  *   wombo features archive [feature-id] [--dry-run]\n26:  *   wombo features show <feature-id>\n27:  *   wombo features graph [--ascii] [--mermaid] [--subtasks] [--status <s>]\n28:  *   wombo help\n29:  *   wombo --version\n30:  */\n31: \n32: import { resolve } from \"node:path\";\n33: import { existsSync, readFileSync } from \"node:fs\";\n34: import { loadConfig, validateConfig } from \"./config.js\";\n35: import { loadState, saveState } from \"./lib/state.js\";\n36: \n37: // ---------------------------------------------------------------------------\n38: // Dev-mode guard: warn if running the global binary inside the wombo repo\n39: // ---------------------------------------------------------------------------\n40: \n41: function checkDevModeGuard(): void {\n42:   const cwd = process.cwd();\n43:   const pkgPath = resolve(cwd, \"package.json\");\n44: \n45:   // Are we inside the wombo repo?\n46:   if (!existsSync(pkgPath)) return;\n47: \n48:   let pkgName: string | undefined;\n49:   try {\n50:     const raw = readFileSync(pkgPath, \"utf-8\");\n51:     pkgName = JSON.parse(raw).name;\n52:   } catch {\n53:     return;\n54:   }\n55:   if (pkgName !== \"wombo\") return;\n56: \n57:   // We're in the wombo repo. Is the source being run from a different location?\n58:   // import.meta.dir = directory of THIS file (index.ts). If it's under cwd,\n59:   // we're running local source (bun dev). If it's elsewhere (e.g. ~/.bun/install),\n60:   // we're running the globally installed binary.\n61:   const sourceDir = resolve(import.meta.dir);\n62:   const projectSrc = resolve(cwd, \"src\");\n63: \n64:   if (!sourceDir.startsWith(projectSrc)) {\n65:     console.warn(\n66:       \"\\x1b[33m[WARNING]\\x1b[0m You are running the globally installed wombo binary \" +\n67:       \"inside the wombo repo.\\n\" +\n68:       \"  Use \\x1b[1mbun dev <command>\\x1b[0m instead to run from local source.\\n\" +\n69:       \"  See AGENTS.md for details.\\n\"\n70:     );\n71:   }\n72: }\n73: \n74: import { cmdInit } from \"./commands/init.js\";\n75: import { cmdLaunch } from \"./commands/launch.js\";\n76: import { cmdResume } from \"./commands/resume.js\";\n77: import { cmdStatus } from \"./commands/status.js\";\n78: import { cmdVerify } from \"./commands/verify.js\";\n79: import { cmdMerge } from \"./commands/merge.js\";\n80: import { cmdRetry } from \"./commands/retry.js\";\n81: import { cmdCleanup } from \"./commands/cleanup.js\";\n82: import { cmdUpgrade } from \"./commands/upgrade.js\";\n83: import { cmdFeaturesList } from \"./commands/features/list.js\";\n84: import { cmdFeaturesAdd } from \"./commands/features/add.js\";\n85: import { cmdFeaturesSetStatus } from \"./commands/features/set-status.js\";\n86: import { cmdFeaturesCheck } from \"./commands/features/check.js\";\n87: import { cmdFeaturesArchive } from \"./commands/features/archive.js\";\n88: import { cmdFeaturesShow } from \"./commands/features/show.js\";\n89: import { cmdFeaturesGraph } from \"./commands/features/graph.js\";\n90: \n91: import { ensureFeaturesFile } from \"./lib/features.js\";\n92: import type { Priority, Difficulty, FeatureStatus } from \"./lib/features.js\";\n93: import { resolveOutputFormat, type OutputFormat } from \"./lib/output.js\";\n94: import { validateId, validateText, validateBranchName, validateDuration, assertValid } from \"./lib/validate.js\";\n95: import { findCommandDef, commandToSchema, allCommandSchemas } from \"./lib/schema.js\";\n96: \n97: // ---------------------------------------------------------------------------\n98: // Types\n99: // ---------------------------------------------------------------------------\n100: \n101: interface CLIArgs {\n102:   command: string;\n103:   subcommand?: string;\n104:   // Selection options (launch)\n105:   topPriority?: number;\n106:   quickestWins?: number;\n107:   priority?: Priority;\n108:   difficulty?: Difficulty;\n109:   features?: string[];\n110:   allReady?: boolean;\n111:   // Launch / runtime options\n112:   maxConcurrent?: number;\n113:   model?: string;\n114:   interactive: boolean;\n115:   dryRun: boolean;\n116:   baseBranch?: string;\n117:   maxRetries?: number;\n118:   noTui: boolean;\n119:   autoPush: boolean;\n120:   // General\n121:   featureId?: string;\n122:   force: boolean;\n123:   // Output format\n124:   outputFmt: OutputFormat;\n125:   // Upgrade options\n126:   checkOnly: boolean;\n127:   version?: string;\n128:   // Features subcommand extras\n129:   status?: string;\n130:   ready?: boolean;\n131:   includeArchive?: boolean;\n132:   title?: string;\n133:   description?: string;\n134:   effort?: string;\n135:   dependsOn?: string[];\n136:   // Compact output\n137:   fields?: string[];\n138:   // Graph options\n139:   ascii?: boolean;\n140:   mermaidRaw?: boolean;\n141:   graphSubtasks?: boolean;\n142: }\n143: \n144: // ---------------------------------------------------------------------------\n145: // Arg Parsing\n146: // ---------------------------------------------------------------------------\n147: \n148: function parseArgs(argv: string[]): CLIArgs {\n149:   const args = argv.slice(2); // skip 'bun' and script path\n150:   const result: CLIArgs = {\n151:     command: args[0] || \"help\",\n152:     interactive: false,\n153:     dryRun: false,\n154:     noTui: false,\n155:     autoPush: false,\n156:     force: false,\n157:     checkOnly: false,\n158:     outputFmt: resolveOutputFormat(undefined), // auto-detect until --output overrides\n159:   };\n160: \n161:   // If the first arg is \"features\", treat the second positional as the subcommand\n162:   let startIdx = 1;\n163:   if (result.command === \"features\") {\n164:     result.subcommand = args[1] || \"list\";\n165:     startIdx = 2;\n166:   }\n167: \n168:   for (let i = startIdx; i < args.length; i++) {\n169:     const arg = args[i];\n170:     switch (arg) {\n171:       // --- Selection options ---\n172:       case \"--top-priority\":\n173:         result.topPriority = parseInt(args[++i], 10);\n174:         break;\n175:       case \"--quickest-wins\":\n176:         result.quickestWins = parseInt(args[++i], 10);\n177:         break;\n178:       case \"--priority\":\n179:         result.priority = args[++i] as Priority;\n180:         break;\n181:       case \"--difficulty\":\n182:         result.difficulty = args[++i] as Difficulty;\n183:         break;\n184:       case \"--features\":\n185:         result.features = args[++i].split(\",\").map((s) => s.trim());\n186:         break;\n187:       case \"--all-ready\":\n188:         result.allReady = true;\n189:         break;\n190: \n191:       // --- Launch / runtime options ---\n192:       case \"--max-concurrent\":\n193:         result.maxConcurrent = parseInt(args[++i], 10);\n194:         break;\n195:       case \"--model\":\n196:       case \"-m\":\n197:         result.model = args[++i];\n198:         break;\n199:       case \"--interactive\":\n200:         result.interactive = true;\n201:         break;\n202:       case \"--dry-run\":\n203:         result.dryRun = true;\n204:         break;\n205:       case \"--no-tui\":\n206:         result.noTui = true;\n207:         break;\n208:       case \"--auto-push\":\n209:         result.autoPush = true;\n210:         break;\n211:       case \"--base-branch\":\n212:         result.baseBranch = args[++i];\n213:         break;\n214:       case \"--max-retries\":\n215:         result.maxRetries = parseInt(args[++i], 10);\n216:         break;\n217: \n218:       // --- General flags ---\n219:       case \"--force\":\n220:         result.force = true;\n221:         break;\n222:       case \"--check\":\n223:         result.checkOnly = true;\n224:         break;\n225:       case \"--version\":\n226:         result.version = args[++i];\n227:         break;\n228:       case \"--output\":\n229:       case \"-o\":\n230:         result.outputFmt = resolveOutputFormat(args[++i]);\n231:         break;\n232: \n233:       // --- Features subcommand options ---\n234:       case \"--status\":\n235:         result.status = args[++i];\n236:         break;\n237:       case \"--ready\":\n238:         result.ready = true;\n239:         break;\n240:       case \"--include-archive\":\n241:         result.includeArchive = true;\n242:         break;\n243:       case \"--title\":\n244:         result.title = args[++i];\n245:         break;\n246:       case \"--description\":\n247:       case \"--desc\":\n248:         result.description = args[++i];\n249:         break;\n250:       case \"--effort\":\n251:         result.effort = args[++i];\n252:         break;\n253:       case \"--depends-on\":\n254:         result.dependsOn = args[++i].split(\",\").map((s) => s.trim());\n255:         break;\n256:       case \"--fields\":\n257:         result.fields = args[++i].split(\",\").map((s) => s.trim());\n258:         break;\n259: \n260:       // --- Graph options ---\n261:       case \"--ascii\":\n262:         result.ascii = true;\n263:         break;\n264:       case \"--mermaid\":\n265:         result.mermaidRaw = true;\n266:         break;\n267:       case \"--subtasks\":\n268:         result.graphSubtasks = true;\n269:         break;\n270: \n271:       // --- Positional (feature-id, title for add, etc.) ---\n272:       default:\n273:         if (!arg.startsWith(\"-\")) {\n274:           if (!result.featureId) {\n275:             result.featureId = arg;\n276:           } else if (!result.title) {\n277:             result.title = arg;\n278:           }\n279:         }\n280:         break;\n281:     }\n282:   }\n283: \n284:   return result;\n285: }\n286: \n287: // ---------------------------------------------------------------------------\n288: // Help\n289: // ---------------------------------------------------------------------------\n290: \n291: function cmdHelp(): void {\n292:   console.log(`\n293: Wombo — AI Agent Orchestration System\n294: \n295:   WOMBO COMBO! Parallel feature development with AI agents.\n296: \n297: Commands:\n298:   init           Generate wombo.json config in the current project\n299:   launch         Launch a wave of agents to implement features\n300:   resume         Resume a previously stopped wave\n301:   status         Show the status of the current wave\n302:   verify         Run build verification on completed agents\n303:   merge          Merge verified branches into the base branch\n304:   retry          Retry a failed agent\n305:   cleanup        Remove all wave worktrees and tmux sessions\n306:   features       Manage .features.yml (see below)\n307:   upgrade        Check for updates and upgrade wombo\n308:   describe       Emit JSON schema of a command (for AI agents)\n309:   help           Show this help\n310: \n311: Features Subcommands:\n312:   features list            List features (--status, --priority, --difficulty, --ready, --include-archive)\n313:   features add <id> <title> [options]\n314:                            Add a new feature (--desc, --priority, --difficulty, --effort, --depends-on)\n315:   features set-status <id> <status>\n316:                            Change a feature's status\n317:   features check           Validate .features.yml (schema, deps, duplicates, cycles)\n318:   features archive [id]    Move done/cancelled to archive (--dry-run)\n319:   features show <id>       Show feature details\n320:   features graph           Visualize dependency graph (--ascii, --mermaid, --subtasks)\n321: \n322: Selection Options (for launch):\n323:   --top-priority N         Select top N features by priority\n324:   --quickest-wins N        Select N features with lowest effort\n325:   --priority <level>       Filter by priority (critical/high/medium/low/wishlist)\n326:   --difficulty <level>     Filter by difficulty (trivial/easy/medium/hard/very_hard)\n327:   --features \"id1,id2\"     Select specific features by ID\n328:   --all-ready              Select all features whose dependencies are met\n329: \n330: Launch Options:\n331:   --max-concurrent N       Max agents running in parallel (default: from config)\n332:   --model <model>          Model to use (e.g., \"anthropic/claude-sonnet-4-20250514\")\n333:   --interactive            Use tmux TUI mode instead of headless\n334:   --no-tui                 Headless mode without neo-blessed TUI (periodic console dashboard)\n335:   --auto-push              Push base branch to remote after all merges complete\n336:   --dry-run                Show what would be launched without launching\n337:   --base-branch <branch>   Base branch (default: from config)\n338:   --max-retries N          Max retries per agent (default: from config)\n339: \n340: General:\n341:   --version, -V            Print version and exit\n342:   --force                  Force overwrite (e.g., for init) / skip prompts (e.g., for upgrade)\n343:   --output <fmt>           Output format: text (default on TTY) or json (default when piped)\n344:   -o <fmt>                 Alias for --output\n345:   --dry-run                Show what would happen without performing the action\n346:   --fields <list>          Comma-separated fields to include (e.g., id,status,priority)\n347: \n348: Upgrade Options:\n349:   --check                  Only check for updates, don't install\n350:   --version <tag>          Install a specific version (e.g., v0.1.0)\n351: \n352: Examples:\n353:   wombo init\n354:   wombo launch --quickest-wins 3\n355:   wombo launch --priority high --interactive\n356:   wombo launch --features \"auth-flow,search-api\" --max-concurrent 2\n357:   wombo resume\n358:   wombo status\n359:   wombo verify\n360:   wombo merge\n361:   wombo retry auth-flow\n362:   wombo cleanup\n363:   wombo features list --status ready --priority high\n364:   wombo features list --fields id,status,priority --output json\n365:   wombo features add my-feature \"My Cool Feature\" --priority high --difficulty easy\n366:   wombo features set-status my-feature in-progress\n367:   wombo features check\n368:   wombo features archive --dry-run\n369:   wombo features show my-feature\n370:   wombo describe                           # list all commands as JSON\n371:   wombo describe launch                    # describe a specific command\n372:   wombo describe features add              # describe a subcommand\n373: `);\n374: }\n375: \n376: // ---------------------------------------------------------------------------\n377: // Main\n378: // ---------------------------------------------------------------------------\n379: \n380: async function main(): Promise<void> {\n381:   checkDevModeGuard();\n382: \n383:   const PROJECT_ROOT = resolve(process.cwd());\n384:   const args = parseArgs(process.argv);\n385: \n386:   // -----------------------------------------------------------------------\n387:   // Input validation at the CLI boundary\n388:   // -----------------------------------------------------------------------\n389:   if (args.featureId) {\n390:     assertValid(validateId(args.featureId, \"feature ID\"));\n391:   }\n392:   if (args.title) {\n393:     assertValid(validateText(args.title, \"title\"));\n394:   }\n395:   if (args.description) {\n396:     assertValid(validateText(args.description, \"description\"));\n397:   }\n398:   if (args.baseBranch) {\n399:     assertValid(validateBranchName(args.baseBranch, \"base branch\"));\n400:   }\n401:   if (args.effort) {\n402:     assertValid(validateDuration(args.effort, \"effort\"));\n403:   }\n404:   if (args.features) {\n405:     for (const fid of args.features) {\n406:       assertValid(validateId(fid, \"feature ID in --features\"));\n407:     }\n408:   }\n409:   if (args.dependsOn) {\n410:     for (const dep of args.dependsOn) {\n411:       assertValid(validateId(dep, \"dependency ID in --depends-on\"));\n412:     }\n413:   }\n414: \n415:   // Commands that don't need config loading\n416:   if (args.command === \"--version\" || args.command === \"-V\") {\n417:     const pkgPath = resolve(import.meta.dir, \"..\", \"package.json\");\n418:     try {\n419:       const raw = readFileSync(pkgPath, \"utf-8\");\n420:       const pkg = JSON.parse(raw);\n421:       console.log(`wombo ${pkg.version}`);\n422:     } catch {\n423:       console.log(\"wombo (unknown version)\");\n424:     }\n425:     return;\n426:   }\n427: \n428:   if (args.command === \"help\" || args.command === \"--help\" || args.command === \"-h\") {\n429:     cmdHelp();\n430:     return;\n431:   }\n432: \n433:   if (args.command === \"describe\") {\n434:     // Schema introspection: `wombo describe [command]`\n435:     if (!args.featureId) {\n436:       // No command specified — list all commands\n437:       console.log(JSON.stringify(allCommandSchemas(), null, 2));\n438:     } else {\n439:       // Describe a specific command. Handle compound names: \"features list\"\n440:       const cmdName = args.title\n441:         ? `${args.featureId} ${args.title}`\n442:         : args.featureId;\n443:       const def = findCommandDef(cmdName);\n444:       if (!def) {\n445:         console.error(`Unknown command: \"${cmdName}\"`);\n446:         console.error(\"Run 'wombo describe' to list all commands.\");\n447:         process.exit(1);\n448:         return;\n449:       }\n450:       console.log(JSON.stringify(commandToSchema(def), null, 2));\n451:     }\n452:     return;\n453:   }\n454: \n455:   if (args.command === \"init\") {\n456:     await cmdInit({ projectRoot: PROJECT_ROOT, force: args.force });\n457:     return;\n458:   }\n459: \n460:   if (args.command === \"upgrade\") {\n461:     await cmdUpgrade({\n462:       force: args.force,\n463:       version: args.version,\n464:       checkOnly: args.checkOnly,\n465:     });\n466:     return;\n467:   }\n468: \n469:   // Everything else requires config\n470:   const config = loadConfig(PROJECT_ROOT);\n471:   validateConfig(config);\n472: \n473:   // Commands that operate on the features file — ensure it exists first\n474:   const needsFeatures = new Set([\"launch\", \"resume\", \"verify\", \"retry\", \"features\"]);\n475:   if (needsFeatures.has(args.command)) {\n476:     await ensureFeaturesFile(PROJECT_ROOT, config);\n477:   }\n478: \n479:   switch (args.command) {\n480:     case \"launch\":\n481:       await cmdLaunch({\n482:         projectRoot: PROJECT_ROOT,\n483:         config,\n484:         topPriority: args.topPriority,\n485:         quickestWins: args.quickestWins,\n486:         priority: args.priority,\n487:         difficulty: args.difficulty,\n488:         features: args.features,\n489:         allReady: args.allReady,\n490:         maxConcurrent: args.maxConcurrent ?? config.defaults.maxConcurrent,\n491:         model: args.model,\n492:         interactive: args.interactive,\n493:         dryRun: args.dryRun,\n494:         baseBranch: args.baseBranch ?? config.baseBranch,\n495:         maxRetries: args.maxRetries ?? config.defaults.maxRetries,\n496:         noTui: args.noTui,\n497:         autoPush: args.autoPush,\n498:       });\n499:       break;\n500: \n501:     case \"resume\":\n502:       await cmdResume({\n503:         projectRoot: PROJECT_ROOT,\n504:         config,\n505:         maxConcurrent: args.maxConcurrent,\n506:         model: args.model,\n507:         interactive: args.interactive,\n508:         noTui: args.noTui,\n509:         autoPush: args.autoPush,\n510:         baseBranch: args.baseBranch,\n511:         maxRetries: args.maxRetries,\n512:       });\n513:       break;\n514: \n515:     case \"status\":\n516:       await cmdStatus({ projectRoot: PROJECT_ROOT, config });\n517:       break;\n518: \n519:     case \"verify\":\n520:       await cmdVerify({\n521:         projectRoot: PROJECT_ROOT,\n522:         config,\n523:         featureId: args.featureId,\n524:         model: args.model,\n525:         maxRetries: args.maxRetries,\n526:       });\n527:       break;\n528: \n529:     case \"merge\":\n530:       await cmdMerge({\n531:         projectRoot: PROJECT_ROOT,\n532:         config,\n533:         featureId: args.featureId,\n534:         autoPush: args.autoPush,\n535:         dryRun: args.dryRun,\n536:       });\n537:       break;\n538: \n539:     case \"retry\": {\n540:       if (!args.featureId) {\n541:         console.error(\"Usage: wombo retry <feature-id>\");\n542:         process.exit(1);\n543:         return;\n544:       }\n545:       await cmdRetry({\n546:         projectRoot: PROJECT_ROOT,\n547:         config,\n548:         featureId: args.featureId,\n549:         model: args.model,\n550:         interactive: args.interactive,\n551:         dryRun: args.dryRun,\n552:       });\n553:       break;\n554:     }\n555: \n556:     case \"cleanup\":\n557:       await cmdCleanup({ projectRoot: PROJECT_ROOT, config, dryRun: args.dryRun });\n558:       break;\n559: \n560:     case \"features\":\n561:       await handleFeaturesSubcommand(args, PROJECT_ROOT, config);\n562:       break;\n563: \n564:     default:\n565:       console.error(`Unknown command: ${args.command}`);\n566:       cmdHelp();\n567:       process.exit(1);\n568:       return;\n569:   }\n570: }\n571: \n572: // ---------------------------------------------------------------------------\n573: // Features Subcommand Router\n574: // ---------------------------------------------------------------------------\n575: \n576: async function handleFeaturesSubcommand(\n577:   args: CLIArgs,\n578:   projectRoot: string,\n579:   config: import(\"./config.js\").WomboConfig\n580: ): Promise<void> {\n581:   switch (args.subcommand) {\n582:     case \"list\":\n583:     case \"ls\":\n584:       await cmdFeaturesList({\n585:         projectRoot,\n586:         config,\n587:         status: args.status as FeatureStatus | undefined,\n588:         priority: args.priority,\n589:         difficulty: args.difficulty,\n590:         ready: args.ready,\n591:         includeArchive: args.includeArchive,\n592:         outputFmt: args.outputFmt,\n593:         fields: args.fields,\n594:       });\n595:       break;\n596: \n597:     case \"add\": {\n598:       if (!args.featureId || !args.title) {\n599:         console.error(\"Usage: wombo features add <id> <title> [--desc <desc>] [--priority <p>] [--difficulty <d>] [--effort <e>] [--depends-on <ids>]\");\n600:         process.exit(1);\n601:         return;\n602:       }\n603:       await cmdFeaturesAdd({\n604:         projectRoot,\n605:         config,\n606:         id: args.featureId,\n607:         title: args.title,\n608:         description: args.description,\n609:         priority: args.priority,\n610:         difficulty: args.difficulty,\n611:         effort: args.effort,\n612:         dependsOn: args.dependsOn,\n613:         outputFmt: args.outputFmt,\n614:         dryRun: args.dryRun,\n615:       });\n616:       break;\n617:     }\n618: \n619:     case \"set-status\": {\n620:       if (!args.featureId || !args.title) {\n621:         // title holds the second positional arg (the status value)\n622:         // If not provided via positional, check --status flag\n623:         const newStatus = args.title || args.status;\n624:         if (!args.featureId || !newStatus) {\n625:           console.error(\"Usage: wombo features set-status <feature-id> <status>\");\n626:           process.exit(1);\n627:           return;\n628:         }\n629:         await cmdFeaturesSetStatus({\n630:           projectRoot,\n631:           config,\n632:           featureId: args.featureId,\n633:           newStatus,\n634:           outputFmt: args.outputFmt,\n635:           dryRun: args.dryRun,\n636:         });\n637:       } else {\n638:         await cmdFeaturesSetStatus({\n639:           projectRoot,\n640:           config,\n641:           featureId: args.featureId,\n642:           newStatus: args.title, // second positional = new status\n643:           outputFmt: args.outputFmt,\n644:           dryRun: args.dryRun,\n645:         });\n646:       }\n647:       break;\n648:     }\n649: \n650:     case \"check\":\n651:     case \"validate\":\n652:       await cmdFeaturesCheck({ projectRoot, config });\n653:       break;\n654: \n655:     case \"archive\":\n656:       await cmdFeaturesArchive({\n657:         projectRoot,\n658:         config,\n659:         featureId: args.featureId,\n660:         dryRun: args.dryRun,\n661:       });\n662:       break;\n663: \n664:     case \"show\": {\n665:       if (!args.featureId) {\n666:         console.error(\"Usage: wombo features show <feature-id>\");\n667:         process.exit(1);\n668:         return;\n669:       }\n670:       await cmdFeaturesShow({\n671:         projectRoot,\n672:         config,\n673:         featureId: args.featureId,\n674:         outputFmt: args.outputFmt,\n675:         fields: args.fields,\n676:       });\n677:       break;\n678:     }\n679: \n680:     case \"graph\":\n681:       await cmdFeaturesGraph({\n682:         projectRoot,\n683:         config,\n684:         status: args.status as FeatureStatus | undefined,\n685:         ascii: args.ascii,\n686:         mermaid: args.mermaidRaw,\n687:         subtasks: args.graphSubtasks,\n688:         outputFmt: args.outputFmt,\n689:       });\n690:       break;\n691: \n692:     case \"help\":\n693:     case \"--help\":\n694:     case \"-h\":\n695:       cmdHelp();\n696:       break;\n697: \n698:     default:\n699:       console.error(`Unknown features subcommand: ${args.subcommand}`);\n700:       console.error(\"Run 'wombo features help' or 'wombo help' for usage.\");\n701:       process.exit(1);\n702:       return;\n703:   }\n704: }\n705: \n706: // ---------------------------------------------------------------------------\n707: // Error Handlers & Entry\n708: // ---------------------------------------------------------------------------\n709: \n710: // Global error handlers — prevent silent crashes\n711: process.on(\"uncaughtException\", (err) => {\n712:   console.error(`\\n[FATAL] Uncaught exception: ${err.message}`);\n713:   console.error(err.stack);\n714:   try {\n715:     const state = loadState(process.cwd());\n716:     if (state) saveState(process.cwd(), state);\n717:   } catch {}\n718:   process.exit(1);\n719: });\n720: \n721: process.on(\"unhandledRejection\", (reason: any) => {\n722:   console.error(`\\n[FATAL] Unhandled rejection: ${reason?.message || reason}`);\n723:   if (reason?.stack) console.error(reason.stack);\n724:   try {\n725:     const state = loadState(process.cwd());\n726:     if (state) saveState(process.cwd(), state);\n727:   } catch {}\n728:   process.exit(1);\n729: });\n730: \n731: main().catch((err) => {\n732:   console.error(\"Fatal error:\", err.message);\n733:   process.exit(1);\n734: });\n\n(End of file - total 734 lines)\n</content>","title":"src/index.ts","metadata":{"preview":"#!/usr/bin/env bun\n/**\n * index.ts — CLI entry point for the Wombo agent orchestration system.\n *\n * Usage:\n *   wombo init\n *   wombo launch --top-priority 3\n *   wombo launch --quickest-wins 5\n *   wombo launch --priority high\n *   wombo launch --difficulty easy\n *   wombo launch --features \"feat-a,feat-b\"\n *   wombo launch --all-ready\n *   wombo launch ... --max-concurrent 3 --model \"anthropic/claude-sonnet-4-20250514\"\n *   wombo launch ... --interactive\n *   wombo resume\n *   wombo status\n *   wombo verify [feature-id]\n *   wombo merge [feature-id]\n *   wombo retry <feature-id>\n *   wombo cleanup","truncated":false,"loaded":[]},"time":{"start":1773351515257,"end":1773351515260}}}}
{"type":"tool_use","timestamp":1773351515921,"sessionID":"ses_31c036cc5ffehJByI1GJ6dwrh0","part":{"id":"prt_ce3fcb4e2001vHYPuKxXJ5yWq6","sessionID":"ses_31c036cc5ffehJByI1GJ6dwrh0","messageID":"msg_ce3fca642001Ppyjn4N0OF4hZS","type":"tool","callID":"toolu_vrtx_011yh5RB6GXot6QwGniyuoi8","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-unit-test-suite/src/lib/state.ts"},"output":"<path>/home/fulgidus/Documents/wombo-unit-test-suite/src/lib/state.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * state.ts — Persistent wave state management.\n3:  *\n4:  * Responsibilities:\n5:  *   - Define the shape of .wombo-state.json\n6:  *   - Read/write state atomically\n7:  *   - Generate wave IDs\n8:  *   - Update individual agent state within a wave\n9:  */\n10: \n11: import { readFileSync, writeFileSync, existsSync, renameSync } from \"node:fs\";\n12: import { resolve } from \"node:path\";\n13: \n14: // ---------------------------------------------------------------------------\n15: // Types\n16: // ---------------------------------------------------------------------------\n17: \n18: export type AgentStatus =\n19:   | \"queued\"\n20:   | \"installing\"\n21:   | \"running\"\n22:   | \"completed\"\n23:   | \"verified\"\n24:   | \"failed\"\n25:   | \"merged\"\n26:   | \"retry\"\n27:   | \"resolving_conflict\";\n28: \n29: export interface AgentState {\n30:   feature_id: string;\n31:   branch: string;\n32:   worktree: string;\n33:   session_id: string | null;\n34:   pid: number | null;\n35:   status: AgentStatus;\n36:   activity: string | null;\n37:   activity_updated_at: string | null;\n38:   retries: number;\n39:   max_retries: number;\n40:   started_at: string | null;\n41:   completed_at: string | null;\n42:   build_passed: boolean | null;\n43:   build_output: string | null;\n44:   error: string | null;\n45:   /** Estimated effort in milliseconds (from feature's ISO 8601 duration) */\n46:   effort_estimate_ms: number | null;\n47: }\n48: \n49: export interface WaveState {\n50:   wave_id: string;\n51:   base_branch: string;\n52:   started_at: string;\n53:   updated_at: string;\n54:   max_concurrent: number;\n55:   model: string | null;\n56:   interactive: boolean;\n57:   agents: AgentState[];\n58: }\n59: \n60: // ---------------------------------------------------------------------------\n61: // Constants\n62: // ---------------------------------------------------------------------------\n63: \n64: const STATE_FILE = \".wombo-state.json\";\n65: \n66: // ---------------------------------------------------------------------------\n67: // Wave ID Generation\n68: // ---------------------------------------------------------------------------\n69: \n70: /**\n71:  * Generate a unique wave ID based on current timestamp.\n72:  * Format: wave-YYYY-MM-DD-NNN\n73:  */\n74: export function generateWaveId(): string {\n75:   const now = new Date();\n76:   const date = now.toISOString().slice(0, 10);\n77:   const seq = String(now.getHours() * 60 + now.getMinutes()).padStart(3, \"0\");\n78:   return `wave-${date}-${seq}`;\n79: }\n80: \n81: // ---------------------------------------------------------------------------\n82: // State Path\n83: // ---------------------------------------------------------------------------\n84: \n85: function statePath(projectRoot: string): string {\n86:   return resolve(projectRoot, STATE_FILE);\n87: }\n88: \n89: // ---------------------------------------------------------------------------\n90: // Read State\n91: // ---------------------------------------------------------------------------\n92: \n93: /**\n94:  * Load the current wave state from disk. Returns null if no state file exists.\n95:  */\n96: export function loadState(projectRoot: string): WaveState | null {\n97:   const p = statePath(projectRoot);\n98:   if (!existsSync(p)) return null;\n99:   try {\n100:     const raw = readFileSync(p, \"utf-8\");\n101:     return JSON.parse(raw) as WaveState;\n102:   } catch {\n103:     return null;\n104:   }\n105: }\n106: \n107: // ---------------------------------------------------------------------------\n108: // Write State\n109: // ---------------------------------------------------------------------------\n110: \n111: /**\n112:  * Save wave state to disk atomically (write to tmp then rename).\n113:  */\n114: export function saveState(projectRoot: string, state: WaveState): void {\n115:   state.updated_at = new Date().toISOString();\n116:   const p = statePath(projectRoot);\n117:   const tmp = p + \".tmp\";\n118:   writeFileSync(tmp, JSON.stringify(state, null, 2) + \"\\n\", \"utf-8\");\n119:   renameSync(tmp, p);\n120: }\n121: \n122: // ---------------------------------------------------------------------------\n123: // State Mutations\n124: // ---------------------------------------------------------------------------\n125: \n126: /**\n127:  * Create a fresh wave state.\n128:  */\n129: export function createWaveState(opts: {\n130:   baseBranch: string;\n131:   maxConcurrent: number;\n132:   model: string | null;\n133:   interactive: boolean;\n134: }): WaveState {\n135:   return {\n136:     wave_id: generateWaveId(),\n137:     base_branch: opts.baseBranch,\n138:     started_at: new Date().toISOString(),\n139:     updated_at: new Date().toISOString(),\n140:     max_concurrent: opts.maxConcurrent,\n141:     model: opts.model,\n142:     interactive: opts.interactive,\n143:     agents: [],\n144:   };\n145: }\n146: \n147: /**\n148:  * Create an initial agent state for a feature.\n149:  */\n150: export function createAgentState(\n151:   featureId: string,\n152:   branch: string,\n153:   worktreePath: string,\n154:   maxRetries: number = 2\n155: ): AgentState {\n156:   return {\n157:     feature_id: featureId,\n158:     branch,\n159:     worktree: worktreePath,\n160:     session_id: null,\n161:     pid: null,\n162:     status: \"queued\",\n163:     activity: null,\n164:     activity_updated_at: null,\n165:     retries: 0,\n166:     max_retries: maxRetries,\n167:     started_at: null,\n168:     completed_at: null,\n169:     build_passed: null,\n170:     build_output: null,\n171:     error: null,\n172:     effort_estimate_ms: null,\n173:   };\n174: }\n175: \n176: /**\n177:  * Find an agent state by feature ID.\n178:  */\n179: export function getAgent(\n180:   state: WaveState,\n181:   featureId: string\n182: ): AgentState | undefined {\n183:   return state.agents.find((a) => a.feature_id === featureId);\n184: }\n185: \n186: /**\n187:  * Update an agent's state fields.\n188:  */\n189: export function updateAgent(\n190:   state: WaveState,\n191:   featureId: string,\n192:   updates: Partial<AgentState>\n193: ): void {\n194:   const agent = state.agents.find((a) => a.feature_id === featureId);\n195:   if (!agent) throw new Error(`Agent not found for feature: ${featureId}`);\n196:   Object.assign(agent, updates);\n197: }\n198: \n199: /**\n200:  * Get counts of agents by status.\n201:  */\n202: export function agentCounts(state: WaveState): Record<AgentStatus, number> {\n203:   const counts: Record<AgentStatus, number> = {\n204:     queued: 0,\n205:     installing: 0,\n206:     running: 0,\n207:     completed: 0,\n208:     verified: 0,\n209:     failed: 0,\n210:     merged: 0,\n211:     retry: 0,\n212:     resolving_conflict: 0,\n213:   };\n214:   for (const a of state.agents) {\n215:     counts[a.status]++;\n216:   }\n217:   return counts;\n218: }\n219: \n220: /**\n221:  * Get agents that are currently running or installing.\n222:  */\n223: export function activeAgents(state: WaveState): AgentState[] {\n224:   return state.agents.filter(\n225:     (a) => a.status === \"running\" || a.status === \"installing\" || a.status === \"resolving_conflict\"\n226:   );\n227: }\n228: \n229: /**\n230:  * Get agents that are queued and ready to be launched.\n231:  */\n232: export function queuedAgents(state: WaveState): AgentState[] {\n233:   return state.agents.filter((a) => a.status === \"queued\");\n234: }\n235: \n236: /**\n237:  * Check if the wave is fully complete (no queued, installing, running, or retry agents).\n238:  */\n239: export function isWaveComplete(state: WaveState): boolean {\n240:   return state.agents.every(\n241:     (a) =>\n242:       a.status === \"completed\" ||\n243:       a.status === \"verified\" ||\n244:       a.status === \"failed\" ||\n245:       a.status === \"merged\"\n246:   );\n247: }\n\n(End of file - total 247 lines)\n</content>","title":"src/lib/state.ts","metadata":{"preview":"/**\n * state.ts — Persistent wave state management.\n *\n * Responsibilities:\n *   - Define the shape of .wombo-state.json\n *   - Read/write state atomically\n *   - Generate wave IDs\n *   - Update individual agent state within a wave\n */\n\nimport { readFileSync, writeFileSync, existsSync, renameSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type AgentStatus =\n  | \"queued\"\n  | \"installing\"","truncated":false,"loaded":[]},"time":{"start":1773351515916,"end":1773351515919}}}}
