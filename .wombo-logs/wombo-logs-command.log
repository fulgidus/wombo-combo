{"type":"tool_use","timestamp":1773351685905,"sessionID":"ses_31c00d8c6ffeD56RZfp762dPPU","part":{"id":"prt_ce3ff4d7a001u3g15PcmbrXrDT","sessionID":"ses_31c00d8c6ffeD56RZfp762dPPU","messageID":"msg_ce3ff3d37001diBGgM5MmYIKnh","type":"tool","callID":"toolu_vrtx_01MGmY36QEcS7xESG7Lb5kPv","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-wombo-logs-command/src/commands/abort.ts"},"output":"<path>/home/fulgidus/Documents/wombo-wombo-logs-command/src/commands/abort.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * abort.ts — Kill a single running agent without nuking the entire wave.\n3:  *\n4:  * Usage: wombo abort <feature-id> [--requeue] [--output json]\n5:  *\n6:  * Kills the tmux session (if any) and the agent process, then updates\n7:  * wave state to mark the agent as \"failed\" (default) or \"queued\"\n8:  * (if --requeue is passed, returning it to the queue for retry).\n9:  */\n10: \n11: import type { WomboConfig } from \"../config.js\";\n12: import {\n13:   loadState,\n14:   saveState,\n15:   updateAgent,\n16:   type AgentState,\n17: } from \"../lib/state.js\";\n18: import {\n19:   killTmuxSession,\n20:   isProcessRunning,\n21: } from \"../lib/launcher.js\";\n22: import { output, outputError, type OutputFormat } from \"../lib/output.js\";\n23: \n24: // ---------------------------------------------------------------------------\n25: // Types\n26: // ---------------------------------------------------------------------------\n27: \n28: export interface AbortCommandOptions {\n29:   projectRoot: string;\n30:   config: WomboConfig;\n31:   featureId: string;\n32:   /** Return the feature to \"queued\" instead of marking it \"failed\" */\n33:   requeue?: boolean;\n34:   outputFmt: OutputFormat;\n35: }\n36: \n37: // ---------------------------------------------------------------------------\n38: // Command\n39: // ---------------------------------------------------------------------------\n40: \n41: export async function cmdAbort(opts: AbortCommandOptions): Promise<void> {\n42:   const { projectRoot, config, featureId, outputFmt } = opts;\n43: \n44:   // Load wave state\n45:   const state = loadState(projectRoot);\n46:   if (!state) {\n47:     outputError(outputFmt, \"No active wave. Nothing to abort.\");\n48:   }\n49: \n50:   // Find the agent\n51:   const agent = state.agents.find((a: AgentState) => a.feature_id === featureId);\n52:   if (!agent) {\n53:     outputError(\n54:       outputFmt,\n55:       `Agent not found for feature: ${featureId}. Use 'wombo status' to see active agents.`\n56:     );\n57:   }\n58: \n59:   // Only abort agents that are actually active (running, installing, queued, resolving_conflict)\n60:   const abortable = new Set([\"running\", \"installing\", \"queued\", \"resolving_conflict\"]);\n61:   if (!abortable.has(agent.status)) {\n62:     outputError(\n63:       outputFmt,\n64:       `Agent ${featureId} is not in an abortable state (current: ${agent.status}). ` +\n65:         `Only running, installing, queued, or resolving_conflict agents can be aborted.`\n66:     );\n67:   }\n68: \n69:   // 1. Kill the tmux session (if any)\n70:   let tmuxKilled = false;\n71:   try {\n72:     killTmuxSession(featureId, config);\n73:     tmuxKilled = true;\n74:   } catch {\n75:     // Session may not exist — that's fine\n76:   }\n77: \n78:   // 2. Kill the process by PID (if any and still running)\n79:   let processKilled = false;\n80:   if (agent.pid && isProcessRunning(agent.pid)) {\n81:     try {\n82:       process.kill(agent.pid, \"SIGTERM\");\n83:       processKilled = true;\n84:     } catch {\n85:       // Process may have already exited\n86:     }\n87:   }\n88: \n89:   // 3. Update wave state\n90:   const newStatus = opts.requeue ? \"queued\" : \"failed\";\n91:   const updates: Partial<AgentState> = {\n92:     status: newStatus as AgentState[\"status\"],\n93:     error: opts.requeue ? null : \"Aborted by user\",\n94:     completed_at: opts.requeue ? null : new Date().toISOString(),\n95:   };\n96: \n97:   // If requeuing, reset retry-related fields so the agent gets a fresh start\n98:   if (opts.requeue) {\n99:     updates.retries = 0;\n100:     updates.build_passed = null;\n101:     updates.build_output = null;\n102:     updates.started_at = null;\n103:     updates.completed_at = null;\n104:     updates.activity = null;\n105:     updates.activity_updated_at = null;\n106:   }\n107: \n108:   updateAgent(state, featureId, updates);\n109:   saveState(projectRoot, state);\n110: \n111:   // 4. Output result\n112:   const result = {\n113:     feature_id: featureId,\n114:     previous_status: agent.status,\n115:     new_status: newStatus,\n116:     tmux_killed: tmuxKilled,\n117:     process_killed: processKilled,\n118:     requeued: !!opts.requeue,\n119:   };\n120: \n121:   output(outputFmt, result, () => {\n122:     console.log(`\\nAborted agent: ${featureId}`);\n123:     console.log(`  Previous status: ${agent.status}`);\n124:     console.log(`  New status: ${newStatus}`);\n125:     if (tmuxKilled) console.log(`  Killed tmux session: ${config.agent.tmuxPrefix}-${featureId}`);\n126:     if (processKilled) console.log(`  Killed process: PID ${agent.pid}`);\n127:     if (opts.requeue) {\n128:       console.log(`  Feature returned to queue for retry.`);\n129:     } else {\n130:       console.log(`  Feature marked as failed.`);\n131:     }\n132:   });\n133: }\n\n(End of file - total 133 lines)\n</content>","title":"src/commands/abort.ts","metadata":{"preview":"/**\n * abort.ts — Kill a single running agent without nuking the entire wave.\n *\n * Usage: wombo abort <feature-id> [--requeue] [--output json]\n *\n * Kills the tmux session (if any) and the agent process, then updates\n * wave state to mark the agent as \"failed\" (default) or \"queued\"\n * (if --requeue is passed, returning it to the queue for retry).\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport {\n  loadState,\n  saveState,\n  updateAgent,\n  type AgentState,\n} from \"../lib/state.js\";\nimport {\n  killTmuxSession,\n  isProcessRunning,","truncated":false,"loaded":[]},"time":{"start":1773351685902,"end":1773351685905}}}}
