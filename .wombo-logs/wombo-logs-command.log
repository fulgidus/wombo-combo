{"type":"tool_use","timestamp":1773351689431,"sessionID":"ses_31c00d8c6ffeD56RZfp762dPPU","part":{"id":"prt_ce3ff5877001DbhSN7nyGRObMF","sessionID":"ses_31c00d8c6ffeD56RZfp762dPPU","messageID":"msg_ce3ff4f25001DECJBNPZdc97gC","type":"tool","callID":"toolu_vrtx_016EUyX6zhY23RZBkw4i3MLu","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-wombo-logs-command/src/config.ts"},"output":"<path>/home/fulgidus/Documents/wombo-wombo-logs-command/src/config.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * config.ts — Load wombo.json, merge with defaults, validate, expose typed config.\n3:  *\n4:  * The config file lives at the target project root (the repo being orchestrated).\n5:  * All values have sensible defaults so minimal config works out of the box.\n6:  */\n7: \n8: import { readFileSync, existsSync } from \"node:fs\";\n9: import { resolve } from \"node:path\";\n10: \n11: // ---------------------------------------------------------------------------\n12: // Types\n13: // ---------------------------------------------------------------------------\n14: \n15: export interface WomboConfig {\n16:   /** Path to the features YAML file relative to project root */\n17:   featuresFile: string;\n18:   /** Base branch to create feature branches from */\n19:   baseBranch: string;\n20:   /** Build configuration */\n21:   build: {\n22:     /** Build command to run in worktrees */\n23:     command: string;\n24:     /** Build timeout in milliseconds */\n25:     timeout: number;\n26:     /** Build artifact directory (for quick \"did it build?\" checks) */\n27:     artifactDir: string;\n28:   };\n29:   /** Install configuration */\n30:   install: {\n31:     /** Install command to run in worktrees */\n32:     command: string;\n33:     /** Install timeout in milliseconds */\n34:     timeout: number;\n35:   };\n36:   /** Git configuration */\n37:   git: {\n38:     /** Branch name prefix for feature branches */\n39:     branchPrefix: string;\n40:     /** Worktree directory name prefix */\n41:     worktreePrefix: string;\n42:     /** Git remote name */\n43:     remote: string;\n44:     /** Merge strategy flag */\n45:     mergeStrategy: string;\n46:   };\n47:   /** Agent configuration */\n48:   agent: {\n49:     /** Path to agent binary (null = auto-detect) */\n50:     bin: string | null;\n51:     /** Agent name to pass via --agent flag */\n52:     name: string;\n53:     /** Config files/dirs to copy into worktrees */\n54:     configFiles: string[];\n55:     /** tmux session name prefix */\n56:     tmuxPrefix: string;\n57:   };\n58:   /** Backup configuration for features file */\n59:   backup: {\n60:     /** Maximum number of timestamped backups to keep */\n61:     maxBackups: number;\n62:   };\n63:   /** Default runtime values */\n64:   defaults: {\n65:     /** Max concurrent agents */\n66:     maxConcurrent: number;\n67:     /** Max retries per agent */\n68:     maxRetries: number;\n69:   };\n70: }\n71: \n72: // ---------------------------------------------------------------------------\n73: // Defaults\n74: // ---------------------------------------------------------------------------\n75: \n76: export const DEFAULT_CONFIG: WomboConfig = {\n77:   featuresFile: \".features.yml\",\n78:   baseBranch: \"develop\",\n79:   build: {\n80:     command: \"bun run build\",\n81:     timeout: 300_000,\n82:     artifactDir: \"dist\",\n83:   },\n84:   install: {\n85:     command: \"bun install\",\n86:     timeout: 120_000,\n87:   },\n88:   git: {\n89:     branchPrefix: \"feature/\",\n90:     worktreePrefix: \"wombo-\",\n91:     remote: \"origin\",\n92:     mergeStrategy: \"--no-ff\",\n93:   },\n94:   agent: {\n95:     bin: null,\n96:     name: \"wave-worker\",\n97:     configFiles: [\".opencode/\", \"opencode.json\", \"AGENTS.md\", \"agent/\"],\n98:     tmuxPrefix: \"wombo\",\n99:   },\n100:   backup: {\n101:     maxBackups: 5,\n102:   },\n103:   defaults: {\n104:     maxConcurrent: 6,\n105:     maxRetries: 2,\n106:   },\n107: };\n108: \n109: // ---------------------------------------------------------------------------\n110: // Config File Name\n111: // ---------------------------------------------------------------------------\n112: \n113: export const CONFIG_FILE = \"wombo.json\";\n114: \n115: // ---------------------------------------------------------------------------\n116: // Loader\n117: // ---------------------------------------------------------------------------\n118: \n119: /**\n120:  * Deep-merge source into target. Only merges plain objects, not arrays.\n121:  */\n122: function deepMerge<T extends Record<string, any>>(target: T, source: Partial<T>): T {\n123:   const result = { ...target };\n124:   for (const key of Object.keys(source) as (keyof T)[]) {\n125:     const srcVal = source[key];\n126:     const tgtVal = target[key];\n127:     if (\n128:       srcVal !== undefined &&\n129:       srcVal !== null &&\n130:       typeof srcVal === \"object\" &&\n131:       !Array.isArray(srcVal) &&\n132:       typeof tgtVal === \"object\" &&\n133:       !Array.isArray(tgtVal) &&\n134:       tgtVal !== null\n135:     ) {\n136:       result[key] = deepMerge(tgtVal as any, srcVal as any);\n137:     } else if (srcVal !== undefined) {\n138:       result[key] = srcVal as T[keyof T];\n139:     }\n140:   }\n141:   return result;\n142: }\n143: \n144: /**\n145:  * Load wombo.json from the given project root and merge with defaults.\n146:  * Returns the full config. If no config file exists, returns defaults.\n147:  */\n148: export function loadConfig(projectRoot: string): WomboConfig {\n149:   const configPath = resolve(projectRoot, CONFIG_FILE);\n150: \n151:   if (!existsSync(configPath)) {\n152:     return { ...DEFAULT_CONFIG };\n153:   }\n154: \n155:   try {\n156:     const raw = readFileSync(configPath, \"utf-8\");\n157:     const partial = JSON.parse(raw) as Partial<WomboConfig>;\n158:     return deepMerge(DEFAULT_CONFIG, partial);\n159:   } catch (err: any) {\n160:     throw new Error(`Failed to load ${CONFIG_FILE}: ${err.message}`);\n161:   }\n162: }\n163: \n164: /**\n165:  * Resolve the agent binary path. Priority:\n166:  *   1. config.agent.bin (explicit)\n167:  *   2. OPENCODE_BIN env var\n168:  *   3. ~/.opencode/bin/opencode (default install location)\n169:  */\n170: export function resolveAgentBin(config: WomboConfig): string {\n171:   if (config.agent.bin) return config.agent.bin;\n172:   if (process.env.OPENCODE_BIN) return process.env.OPENCODE_BIN;\n173:   return resolve(process.env.HOME || \"~\", \".opencode/bin/opencode\");\n174: }\n175: \n176: /**\n177:  * Validate the config for obvious issues. Throws on error.\n178:  */\n179: export function validateConfig(config: WomboConfig): void {\n180:   if (!config.featuresFile) {\n181:     throw new Error(\"config.featuresFile must be a non-empty string\");\n182:   }\n183:   if (!config.baseBranch) {\n184:     throw new Error(\"config.baseBranch must be a non-empty string\");\n185:   }\n186:   if (!config.build.command) {\n187:     throw new Error(\"config.build.command must be a non-empty string\");\n188:   }\n189:   if (!config.install.command) {\n190:     throw new Error(\"config.install.command must be a non-empty string\");\n191:   }\n192:   if (!config.git.branchPrefix) {\n193:     throw new Error(\"config.git.branchPrefix must be a non-empty string\");\n194:   }\n195:   if (!config.git.worktreePrefix) {\n196:     throw new Error(\"config.git.worktreePrefix must be a non-empty string\");\n197:   }\n198:   if (config.defaults.maxConcurrent < 1) {\n199:     throw new Error(\"config.defaults.maxConcurrent must be >= 1\");\n200:   }\n201:   if (config.defaults.maxRetries < 0) {\n202:     throw new Error(\"config.defaults.maxRetries must be >= 0\");\n203:   }\n204:   if (config.backup.maxBackups < 0) {\n205:     throw new Error(\"config.backup.maxBackups must be >= 0\");\n206:   }\n207: }\n208: \n209: /**\n210:  * Generate the default wombo.json content string (for `wombo init`).\n211:  */\n212: export function generateDefaultConfig(): string {\n213:   return JSON.stringify(DEFAULT_CONFIG, null, 2) + \"\\n\";\n214: }\n\n(End of file - total 214 lines)\n</content>","title":"src/config.ts","metadata":{"preview":"/**\n * config.ts — Load wombo.json, merge with defaults, validate, expose typed config.\n *\n * The config file lives at the target project root (the repo being orchestrated).\n * All values have sensible defaults so minimal config works out of the box.\n */\n\nimport { readFileSync, existsSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface WomboConfig {\n  /** Path to the features YAML file relative to project root */\n  featuresFile: string;\n  /** Base branch to create feature branches from */\n  baseBranch: string;\n  /** Build configuration */","truncated":false,"loaded":[]},"time":{"start":1773351689428,"end":1773351689431}}}}
{"type":"tool_use","timestamp":1773351689848,"sessionID":"ses_31c00d8c6ffeD56RZfp762dPPU","part":{"id":"prt_ce3ff5cd5001RRGsEzKEn90731","sessionID":"ses_31c00d8c6ffeD56RZfp762dPPU","messageID":"msg_ce3ff4f25001DECJBNPZdc97gC","type":"tool","callID":"toolu_vrtx_012q5s38EVz2amSybvQgL6Yz","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-wombo-logs-command/src/lib/validate.ts"},"output":"<path>/home/fulgidus/Documents/wombo-wombo-logs-command/src/lib/validate.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * validate.ts — Input validation / hardening for agent-ready CLI.\n3:  *\n4:  * All user/agent-supplied inputs pass through these validators at the CLI\n5:  * boundary. This prevents hallucinated inputs from corrupting state.\n6:  *\n7:  * Rules:\n8:  *   - Feature IDs: kebab-case only, no path traversals, no query params\n9:  *   - Branch names: no control chars, no \"..\", no spaces\n10:  *   - Free-text (titles, descriptions): no control chars except \\n \\t\n11:  *   - Effort strings: ISO 8601 duration pattern only\n12:  */\n13: \n14: // ---------------------------------------------------------------------------\n15: // Patterns\n16: // ---------------------------------------------------------------------------\n17: \n18: /** Valid feature/subtask ID: lowercase alphanumeric + hyphens, 1-128 chars */\n19: const ID_PATTERN = /^[a-z0-9][a-z0-9-]{0,127}$/;\n20: \n21: /** Control characters below space, excluding \\t (0x09) and \\n (0x0a) */\n22: const CONTROL_CHARS = /[\\x00-\\x08\\x0b\\x0c\\x0e-\\x1f\\x7f]/;\n23: \n24: /** Path traversal sequences */\n25: const PATH_TRAVERSAL = /\\.\\.\\//;\n26: \n27: /** Embedded query params or fragments */\n28: const QUERY_FRAGMENT = /[?#]/;\n29: \n30: /** Percent-encoded sequences (indicates double-encoding risk) */\n31: const PERCENT_ENCODED = /%[0-9a-fA-F]{2}/;\n32: \n33: /** ISO 8601 duration: P[nY][nM][nD][T[nH][nM][nS]] */\n34: const DURATION_PATTERN = /^P(?:\\d+Y)?(?:\\d+M)?(?:\\d+D)?(?:T(?:\\d+H)?(?:\\d+M)?(?:\\d+S)?)?$/;\n35: \n36: // ---------------------------------------------------------------------------\n37: // Result type\n38: // ---------------------------------------------------------------------------\n39: \n40: export interface ValidationResult {\n41:   valid: boolean;\n42:   error?: string;\n43: }\n44: \n45: function ok(): ValidationResult {\n46:   return { valid: true };\n47: }\n48: \n49: function fail(error: string): ValidationResult {\n50:   return { valid: false, error };\n51: }\n52: \n53: // ---------------------------------------------------------------------------\n54: // Validators\n55: // ---------------------------------------------------------------------------\n56: \n57: /**\n58:  * Validate a feature or subtask ID.\n59:  * Must be kebab-case, no traversals, no query params, no encoded chars.\n60:  */\n61: export function validateId(value: string, label: string = \"ID\"): ValidationResult {\n62:   if (!value || value.length === 0) {\n63:     return fail(`${label} must not be empty.`);\n64:   }\n65: \n66:   if (CONTROL_CHARS.test(value)) {\n67:     return fail(`${label} contains control characters.`);\n68:   }\n69: \n70:   if (PATH_TRAVERSAL.test(value)) {\n71:     return fail(`${label} contains path traversal sequence \"../\".`);\n72:   }\n73: \n74:   if (QUERY_FRAGMENT.test(value)) {\n75:     return fail(`${label} contains query/fragment characters (? or #).`);\n76:   }\n77: \n78:   if (PERCENT_ENCODED.test(value)) {\n79:     return fail(`${label} contains percent-encoded characters — possible double-encoding.`);\n80:   }\n81: \n82:   if (!ID_PATTERN.test(value)) {\n83:     return fail(\n84:       `${label} \"${value}\" is invalid. IDs must be kebab-case ` +\n85:       `(lowercase letters, digits, hyphens), 1–128 characters, starting with a letter or digit.`\n86:     );\n87:   }\n88: \n89:   return ok();\n90: }\n91: \n92: /**\n93:  * Validate free-text input (titles, descriptions, notes).\n94:  * Rejects control chars except \\t and \\n.\n95:  */\n96: export function validateText(value: string, label: string = \"text\"): ValidationResult {\n97:   if (CONTROL_CHARS.test(value)) {\n98:     return fail(`${label} contains control characters (non-printable bytes).`);\n99:   }\n100:   return ok();\n101: }\n102: \n103: /**\n104:  * Validate a branch name.\n105:  * No control chars, no \"..\", no spaces, no ~, ^, :, \\, ?, *, [\n106:  */\n107: export function validateBranchName(value: string, label: string = \"branch name\"): ValidationResult {\n108:   if (!value || value.length === 0) {\n109:     return fail(`${label} must not be empty.`);\n110:   }\n111: \n112:   if (CONTROL_CHARS.test(value)) {\n113:     return fail(`${label} contains control characters.`);\n114:   }\n115: \n116:   if (/\\.\\./.test(value)) {\n117:     return fail(`${label} contains \"..\" which is not allowed in git branch names.`);\n118:   }\n119: \n120:   if (/[ ~^:\\\\?*\\[]/.test(value)) {\n121:     return fail(`${label} contains characters not allowed in git branch names.`);\n122:   }\n123: \n124:   return ok();\n125: }\n126: \n127: /**\n128:  * Validate an ISO 8601 duration string.\n129:  */\n130: export function validateDuration(value: string, label: string = \"effort\"): ValidationResult {\n131:   if (!value || value.length === 0) {\n132:     return fail(`${label} must not be empty.`);\n133:   }\n134: \n135:   if (!DURATION_PATTERN.test(value)) {\n136:     return fail(\n137:       `${label} \"${value}\" is not a valid ISO 8601 duration. ` +\n138:       `Expected format: P[nY][nM][nD][T[nH][nM][nS]] (e.g., \"PT2H\", \"P1D\", \"P1DT4H30M\").`\n139:     );\n140:   }\n141: \n142:   return ok();\n143: }\n144: \n145: /**\n146:  * Validate a status value against the allowed set.\n147:  */\n148: export function validateEnum(\n149:   value: string,\n150:   allowed: readonly string[],\n151:   label: string = \"value\"\n152: ): ValidationResult {\n153:   if (!allowed.includes(value)) {\n154:     return fail(`${label} \"${value}\" is not valid. Allowed values: ${allowed.join(\", \")}`);\n155:   }\n156:   return ok();\n157: }\n158: \n159: // ---------------------------------------------------------------------------\n160: // Convenience: validate and exit on failure\n161: // ---------------------------------------------------------------------------\n162: \n163: /**\n164:  * Run a validation and exit with error message if invalid.\n165:  * For use at the CLI boundary.\n166:  */\n167: export function assertValid(result: ValidationResult): void {\n168:   if (!result.valid) {\n169:     console.error(`Validation error: ${result.error}`);\n170:     process.exit(1);\n171:   }\n172: }\n\n(End of file - total 172 lines)\n</content>","title":"src/lib/validate.ts","metadata":{"preview":"/**\n * validate.ts — Input validation / hardening for agent-ready CLI.\n *\n * All user/agent-supplied inputs pass through these validators at the CLI\n * boundary. This prevents hallucinated inputs from corrupting state.\n *\n * Rules:\n *   - Feature IDs: kebab-case only, no path traversals, no query params\n *   - Branch names: no control chars, no \"..\", no spaces\n *   - Free-text (titles, descriptions): no control chars except \\n \\t\n *   - Effort strings: ISO 8601 duration pattern only\n */\n\n// ---------------------------------------------------------------------------\n// Patterns\n// ---------------------------------------------------------------------------\n\n/** Valid feature/subtask ID: lowercase alphanumeric + hyphens, 1-128 chars */\nconst ID_PATTERN = /^[a-z0-9][a-z0-9-]{0,127}$/;\n","truncated":false,"loaded":[]},"time":{"start":1773351689844,"end":1773351689848}}}}
