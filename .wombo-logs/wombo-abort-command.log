{"type":"tool_use","timestamp":1773351516280,"sessionID":"ses_31c036d39ffedecysjCoQobMfd","part":{"id":"prt_ce3fcb741001Mm6TrjjXzX575e","sessionID":"ses_31c036d39ffedecysjCoQobMfd","messageID":"msg_ce3fcaa25001lXgoEh82ey3ueX","type":"tool","callID":"toolu_vrtx_01QSGGZX9BbmZEd8Tf8Zid1L","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-wombo-abort-command/src/lib/state.ts"},"output":"<path>/home/fulgidus/Documents/wombo-wombo-abort-command/src/lib/state.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * state.ts — Persistent wave state management.\n3:  *\n4:  * Responsibilities:\n5:  *   - Define the shape of .wombo-state.json\n6:  *   - Read/write state atomically\n7:  *   - Generate wave IDs\n8:  *   - Update individual agent state within a wave\n9:  */\n10: \n11: import { readFileSync, writeFileSync, existsSync, renameSync } from \"node:fs\";\n12: import { resolve } from \"node:path\";\n13: \n14: // ---------------------------------------------------------------------------\n15: // Types\n16: // ---------------------------------------------------------------------------\n17: \n18: export type AgentStatus =\n19:   | \"queued\"\n20:   | \"installing\"\n21:   | \"running\"\n22:   | \"completed\"\n23:   | \"verified\"\n24:   | \"failed\"\n25:   | \"merged\"\n26:   | \"retry\"\n27:   | \"resolving_conflict\";\n28: \n29: export interface AgentState {\n30:   feature_id: string;\n31:   branch: string;\n32:   worktree: string;\n33:   session_id: string | null;\n34:   pid: number | null;\n35:   status: AgentStatus;\n36:   activity: string | null;\n37:   activity_updated_at: string | null;\n38:   retries: number;\n39:   max_retries: number;\n40:   started_at: string | null;\n41:   completed_at: string | null;\n42:   build_passed: boolean | null;\n43:   build_output: string | null;\n44:   error: string | null;\n45:   /** Estimated effort in milliseconds (from feature's ISO 8601 duration) */\n46:   effort_estimate_ms: number | null;\n47: }\n48: \n49: export interface WaveState {\n50:   wave_id: string;\n51:   base_branch: string;\n52:   started_at: string;\n53:   updated_at: string;\n54:   max_concurrent: number;\n55:   model: string | null;\n56:   interactive: boolean;\n57:   agents: AgentState[];\n58: }\n59: \n60: // ---------------------------------------------------------------------------\n61: // Constants\n62: // ---------------------------------------------------------------------------\n63: \n64: const STATE_FILE = \".wombo-state.json\";\n65: \n66: // ---------------------------------------------------------------------------\n67: // Wave ID Generation\n68: // ---------------------------------------------------------------------------\n69: \n70: /**\n71:  * Generate a unique wave ID based on current timestamp.\n72:  * Format: wave-YYYY-MM-DD-NNN\n73:  */\n74: export function generateWaveId(): string {\n75:   const now = new Date();\n76:   const date = now.toISOString().slice(0, 10);\n77:   const seq = String(now.getHours() * 60 + now.getMinutes()).padStart(3, \"0\");\n78:   return `wave-${date}-${seq}`;\n79: }\n80: \n81: // ---------------------------------------------------------------------------\n82: // State Path\n83: // ---------------------------------------------------------------------------\n84: \n85: function statePath(projectRoot: string): string {\n86:   return resolve(projectRoot, STATE_FILE);\n87: }\n88: \n89: // ---------------------------------------------------------------------------\n90: // Read State\n91: // ---------------------------------------------------------------------------\n92: \n93: /**\n94:  * Load the current wave state from disk. Returns null if no state file exists.\n95:  */\n96: export function loadState(projectRoot: string): WaveState | null {\n97:   const p = statePath(projectRoot);\n98:   if (!existsSync(p)) return null;\n99:   try {\n100:     const raw = readFileSync(p, \"utf-8\");\n101:     return JSON.parse(raw) as WaveState;\n102:   } catch {\n103:     return null;\n104:   }\n105: }\n106: \n107: // ---------------------------------------------------------------------------\n108: // Write State\n109: // ---------------------------------------------------------------------------\n110: \n111: /**\n112:  * Save wave state to disk atomically (write to tmp then rename).\n113:  */\n114: export function saveState(projectRoot: string, state: WaveState): void {\n115:   state.updated_at = new Date().toISOString();\n116:   const p = statePath(projectRoot);\n117:   const tmp = p + \".tmp\";\n118:   writeFileSync(tmp, JSON.stringify(state, null, 2) + \"\\n\", \"utf-8\");\n119:   renameSync(tmp, p);\n120: }\n121: \n122: // ---------------------------------------------------------------------------\n123: // State Mutations\n124: // ---------------------------------------------------------------------------\n125: \n126: /**\n127:  * Create a fresh wave state.\n128:  */\n129: export function createWaveState(opts: {\n130:   baseBranch: string;\n131:   maxConcurrent: number;\n132:   model: string | null;\n133:   interactive: boolean;\n134: }): WaveState {\n135:   return {\n136:     wave_id: generateWaveId(),\n137:     base_branch: opts.baseBranch,\n138:     started_at: new Date().toISOString(),\n139:     updated_at: new Date().toISOString(),\n140:     max_concurrent: opts.maxConcurrent,\n141:     model: opts.model,\n142:     interactive: opts.interactive,\n143:     agents: [],\n144:   };\n145: }\n146: \n147: /**\n148:  * Create an initial agent state for a feature.\n149:  */\n150: export function createAgentState(\n151:   featureId: string,\n152:   branch: string,\n153:   worktreePath: string,\n154:   maxRetries: number = 2\n155: ): AgentState {\n156:   return {\n157:     feature_id: featureId,\n158:     branch,\n159:     worktree: worktreePath,\n160:     session_id: null,\n161:     pid: null,\n162:     status: \"queued\",\n163:     activity: null,\n164:     activity_updated_at: null,\n165:     retries: 0,\n166:     max_retries: maxRetries,\n167:     started_at: null,\n168:     completed_at: null,\n169:     build_passed: null,\n170:     build_output: null,\n171:     error: null,\n172:     effort_estimate_ms: null,\n173:   };\n174: }\n175: \n176: /**\n177:  * Find an agent state by feature ID.\n178:  */\n179: export function getAgent(\n180:   state: WaveState,\n181:   featureId: string\n182: ): AgentState | undefined {\n183:   return state.agents.find((a) => a.feature_id === featureId);\n184: }\n185: \n186: /**\n187:  * Update an agent's state fields.\n188:  */\n189: export function updateAgent(\n190:   state: WaveState,\n191:   featureId: string,\n192:   updates: Partial<AgentState>\n193: ): void {\n194:   const agent = state.agents.find((a) => a.feature_id === featureId);\n195:   if (!agent) throw new Error(`Agent not found for feature: ${featureId}`);\n196:   Object.assign(agent, updates);\n197: }\n198: \n199: /**\n200:  * Get counts of agents by status.\n201:  */\n202: export function agentCounts(state: WaveState): Record<AgentStatus, number> {\n203:   const counts: Record<AgentStatus, number> = {\n204:     queued: 0,\n205:     installing: 0,\n206:     running: 0,\n207:     completed: 0,\n208:     verified: 0,\n209:     failed: 0,\n210:     merged: 0,\n211:     retry: 0,\n212:     resolving_conflict: 0,\n213:   };\n214:   for (const a of state.agents) {\n215:     counts[a.status]++;\n216:   }\n217:   return counts;\n218: }\n219: \n220: /**\n221:  * Get agents that are currently running or installing.\n222:  */\n223: export function activeAgents(state: WaveState): AgentState[] {\n224:   return state.agents.filter(\n225:     (a) => a.status === \"running\" || a.status === \"installing\" || a.status === \"resolving_conflict\"\n226:   );\n227: }\n228: \n229: /**\n230:  * Get agents that are queued and ready to be launched.\n231:  */\n232: export function queuedAgents(state: WaveState): AgentState[] {\n233:   return state.agents.filter((a) => a.status === \"queued\");\n234: }\n235: \n236: /**\n237:  * Check if the wave is fully complete (no queued, installing, running, or retry agents).\n238:  */\n239: export function isWaveComplete(state: WaveState): boolean {\n240:   return state.agents.every(\n241:     (a) =>\n242:       a.status === \"completed\" ||\n243:       a.status === \"verified\" ||\n244:       a.status === \"failed\" ||\n245:       a.status === \"merged\"\n246:   );\n247: }\n\n(End of file - total 247 lines)\n</content>","title":"src/lib/state.ts","metadata":{"preview":"/**\n * state.ts — Persistent wave state management.\n *\n * Responsibilities:\n *   - Define the shape of .wombo-state.json\n *   - Read/write state atomically\n *   - Generate wave IDs\n *   - Update individual agent state within a wave\n */\n\nimport { readFileSync, writeFileSync, existsSync, renameSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type AgentStatus =\n  | \"queued\"\n  | \"installing\"","truncated":false,"loaded":[]},"time":{"start":1773351516276,"end":1773351516279}}}}
{"type":"tool_use","timestamp":1773351516824,"sessionID":"ses_31c036d39ffedecysjCoQobMfd","part":{"id":"prt_ce3fcb875001lfn7GU8OdL2dQR","sessionID":"ses_31c036d39ffedecysjCoQobMfd","messageID":"msg_ce3fcaa25001lXgoEh82ey3ueX","type":"tool","callID":"toolu_vrtx_01PdVWL1YzfKq1HTMre9emi1","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-wombo-abort-command/src/commands/cleanup.ts"},"output":"<path>/home/fulgidus/Documents/wombo-wombo-abort-command/src/commands/cleanup.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * cleanup.ts — Remove all wave-related resources.\n3:  *\n4:  * Usage: wombo cleanup\n5:  *\n6:  * Kills tmux sessions, removes worktrees, removes state and log files.\n7:  */\n8: \n9: import { existsSync, unlinkSync, rmSync } from \"node:fs\";\n10: import { execSync } from \"node:child_process\";\n11: import { resolve } from \"node:path\";\n12: import type { WomboConfig } from \"../config.js\";\n13: import { killAllTmuxSessions } from \"../lib/launcher.js\";\n14: import { cleanupAllWorktrees } from \"../lib/worktree.js\";\n15: \n16: export interface CleanupOptions {\n17:   projectRoot: string;\n18:   config: WomboConfig;\n19:   dryRun?: boolean;\n20: }\n21: \n22: export async function cmdCleanup(opts: CleanupOptions): Promise<void> {\n23:   const { projectRoot, config } = opts;\n24: \n25:   // Dry-run: show what would be cleaned up without doing it\n26:   if (opts.dryRun) {\n27:     console.log(\"\\n[dry-run] Would perform the following cleanup:\\n\");\n28: \n29:     // List tmux sessions that would be killed\n30:     try {\n31:       const sessions = execSync(\"tmux list-sessions -F '#{session_name}'\", {\n32:         encoding: \"utf-8\",\n33:       }).trim();\n34:       const prefix = config.agent.tmuxPrefix;\n35:       const matching = sessions\n36:         .split(\"\\n\")\n37:         .filter((s) => s.startsWith(prefix));\n38:       console.log(`  tmux sessions to kill: ${matching.length}`);\n39:       for (const s of matching) {\n40:         console.log(`    ${s}`);\n41:       }\n42:     } catch {\n43:       console.log(\"  tmux sessions to kill: 0 (no tmux server running)\");\n44:     }\n45: \n46:     // List worktrees that would be removed\n47:     try {\n48:       const worktrees = execSync(\"git worktree list --porcelain\", {\n49:         cwd: projectRoot,\n50:         encoding: \"utf-8\",\n51:       }).trim();\n52:       const prefix = config.git.worktreePrefix;\n53:       const matching = worktrees\n54:         .split(\"\\n\")\n55:         .filter((line) => line.startsWith(\"worktree \") && line.includes(prefix))\n56:         .map((line) => line.replace(\"worktree \", \"\"));\n57:       console.log(`  worktrees to remove: ${matching.length}`);\n58:       for (const w of matching) {\n59:         console.log(`    ${w}`);\n60:       }\n61:     } catch {\n62:       console.log(\"  worktrees to remove: 0\");\n63:     }\n64: \n65:     const statePath = resolve(projectRoot, \".wombo-state.json\");\n66:     const logDir = resolve(projectRoot, \".wombo-logs\");\n67:     if (existsSync(statePath)) console.log(\"  Would remove: .wombo-state.json\");\n68:     if (existsSync(logDir)) console.log(\"  Would remove: .wombo-logs/\");\n69: \n70:     return;\n71:   }\n72: \n73:   console.log(\"\\n--- Wombo: Cleanup ---\\n\");\n74: \n75:   // Kill tmux sessions\n76:   const killed = killAllTmuxSessions(config);\n77:   console.log(`Killed ${killed} tmux session(s)`);\n78: \n79:   // Remove worktrees\n80:   const removed = cleanupAllWorktrees(projectRoot, config);\n81:   console.log(`Removed ${removed} worktree(s)`);\n82: \n83:   // List remaining feature branches\n84:   try {\n85:     const branchPattern = `\"${config.git.branchPrefix}*\"`;\n86:     const branches = execSync(`git branch --list ${branchPattern}`, {\n87:       cwd: projectRoot,\n88:       encoding: \"utf-8\",\n89:     }).trim();\n90:     if (branches) {\n91:       console.log(`\\nRemaining feature branches:\\n${branches}`);\n92:       console.log('Use \"git branch -D <branch>\" to remove manually.');\n93:     }\n94:   } catch {}\n95: \n96:   // Remove state file\n97:   const statePath = resolve(projectRoot, \".wombo-state.json\");\n98:   if (existsSync(statePath)) {\n99:     unlinkSync(statePath);\n100:     console.log(\"Removed .wombo-state.json\");\n101:   }\n102: \n103:   // Remove log directory\n104:   const logDir = resolve(projectRoot, \".wombo-logs\");\n105:   if (existsSync(logDir)) {\n106:     rmSync(logDir, { recursive: true, force: true });\n107:     console.log(\"Removed .wombo-logs/\");\n108:   }\n109: \n110:   console.log(\"\\nCleanup complete.\");\n111: }\n\n(End of file - total 111 lines)\n</content>","title":"src/commands/cleanup.ts","metadata":{"preview":"/**\n * cleanup.ts — Remove all wave-related resources.\n *\n * Usage: wombo cleanup\n *\n * Kills tmux sessions, removes worktrees, removes state and log files.\n */\n\nimport { existsSync, unlinkSync, rmSync } from \"node:fs\";\nimport { execSync } from \"node:child_process\";\nimport { resolve } from \"node:path\";\nimport type { WomboConfig } from \"../config.js\";\nimport { killAllTmuxSessions } from \"../lib/launcher.js\";\nimport { cleanupAllWorktrees } from \"../lib/worktree.js\";\n\nexport interface CleanupOptions {\n  projectRoot: string;\n  config: WomboConfig;\n  dryRun?: boolean;\n}","truncated":false,"loaded":[]},"time":{"start":1773351516822,"end":1773351516824}}}}
{"type":"tool_use","timestamp":1773351517105,"sessionID":"ses_31c036d39ffedecysjCoQobMfd","part":{"id":"prt_ce3fcba97001DWNOqUak2Hhklp","sessionID":"ses_31c036d39ffedecysjCoQobMfd","messageID":"msg_ce3fcaa25001lXgoEh82ey3ueX","type":"tool","callID":"toolu_vrtx_01CsXVKTzvmjcsbVun728rbt","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-wombo-abort-command/src/commands/retry.ts"},"output":"<path>/home/fulgidus/Documents/wombo-wombo-abort-command/src/commands/retry.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * retry.ts — Retry a specific failed agent.\n3:  *\n4:  * Usage: wombo retry <feature-id> [--interactive] [--model <model>]\n5:  *\n6:  * Resets the agent's retry count and re-launches it. Can launch in either\n7:  * headless mode (default) or interactive (tmux) mode.\n8:  */\n9: \n10: import type { WomboConfig } from \"../config.js\";\n11: import { loadFeatures, type Feature } from \"../lib/features.js\";\n12: import {\n13:   loadState,\n14:   saveState,\n15:   updateAgent,\n16: } from \"../lib/state.js\";\n17: import { worktreeReady } from \"../lib/worktree.js\";\n18: import { generatePrompt } from \"../lib/prompt.js\";\n19: import { launchInteractive } from \"../lib/launcher.js\";\n20: import { ProcessMonitor } from \"../lib/monitor.js\";\n21: import { launchSingleHeadless } from \"./launch.js\";\n22: \n23: // ---------------------------------------------------------------------------\n24: // Types\n25: // ---------------------------------------------------------------------------\n26: \n27: export interface RetryCommandOptions {\n28:   projectRoot: string;\n29:   config: WomboConfig;\n30:   featureId: string;\n31:   model?: string;\n32:   interactive: boolean;\n33:   dryRun?: boolean;\n34: }\n35: \n36: // ---------------------------------------------------------------------------\n37: // Command\n38: // ---------------------------------------------------------------------------\n39: \n40: export async function cmdRetry(opts: RetryCommandOptions): Promise<void> {\n41:   const { projectRoot, config } = opts;\n42: \n43:   if (!opts.featureId) {\n44:     console.error(\"Usage: wombo retry <feature-id>\");\n45:     process.exit(1);\n46:     return; // unreachable — helps TypeScript narrow\n47:   }\n48: \n49:   const state = loadState(projectRoot);\n50:   if (!state) {\n51:     console.log(\"No active wave.\");\n52:     return;\n53:   }\n54: \n55:   const agent = state.agents.find((a) => a.feature_id === opts.featureId);\n56:   if (!agent) {\n57:     console.error(`Agent not found for feature: ${opts.featureId}`);\n58:     process.exit(1);\n59:     return; // unreachable — helps TypeScript narrow\n60:   }\n61: \n62:   if (agent.status !== \"failed\") {\n63:     console.error(\n64:       `Agent ${opts.featureId} is not in failed state (current: ${agent.status})`\n65:     );\n66:     process.exit(1);\n67:     return; // unreachable — helps TypeScript narrow\n68:   }\n69: \n70:   // Dry-run: show what would be retried without doing it\n71:   if (opts.dryRun) {\n72:     console.log(`\\n[dry-run] Would retry agent: ${opts.featureId}`);\n73:     console.log(`  Current status: ${agent.status}`);\n74:     console.log(`  Retries so far: ${agent.retries}`);\n75:     console.log(`  Worktree: ${agent.worktree}`);\n76:     console.log(`  Mode: ${opts.interactive ? \"interactive (tmux)\" : \"headless\"}`);\n77:     if (opts.model) console.log(`  Model: ${opts.model}`);\n78:     return;\n79:   }\n80: \n81:   // Reset retry count and re-run\n82:   updateAgent(state, agent.feature_id, {\n83:     status: \"queued\",\n84:     retries: 0,\n85:     error: null,\n86:     build_passed: null,\n87:     build_output: null,\n88:     completed_at: null,\n89:   });\n90:   saveState(projectRoot, state);\n91: \n92:   const data = loadFeatures(projectRoot, config);\n93:   const feature = data.features.find((f) => f.id === opts.featureId);\n94:   if (!feature) {\n95:     console.error(`Feature ${opts.featureId} not found in ${config.featuresFile}`);\n96:     process.exit(1);\n97:     return; // unreachable — helps TypeScript narrow\n98:   }\n99: \n100:   if (opts.interactive) {\n101:     const prompt = generatePrompt(feature, state.base_branch, config);\n102:     launchInteractive({\n103:       worktreePath: agent.worktree,\n104:       featureId: feature.id,\n105:       prompt,\n106:       model: opts.model,\n107:       interactive: true,\n108:       config,\n109:     });\n110: \n111:     updateAgent(state, agent.feature_id, {\n112:       status: \"running\",\n113:       started_at: new Date().toISOString(),\n114:     });\n115:     saveState(projectRoot, state);\n116:     console.log(`Retrying ${opts.featureId} in tmux session ${config.agent.tmuxPrefix}-${opts.featureId}`);\n117:   } else {\n118:     const monitor = new ProcessMonitor(projectRoot);\n119:     await launchSingleHeadless(projectRoot, state, agent, feature, monitor, config, opts.model);\n120:     console.log(`Retrying ${opts.featureId} in headless mode`);\n121:   }\n122: }\n\n(End of file - total 122 lines)\n</content>","title":"src/commands/retry.ts","metadata":{"preview":"/**\n * retry.ts — Retry a specific failed agent.\n *\n * Usage: wombo retry <feature-id> [--interactive] [--model <model>]\n *\n * Resets the agent's retry count and re-launches it. Can launch in either\n * headless mode (default) or interactive (tmux) mode.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport { loadFeatures, type Feature } from \"../lib/features.js\";\nimport {\n  loadState,\n  saveState,\n  updateAgent,\n} from \"../lib/state.js\";\nimport { worktreeReady } from \"../lib/worktree.js\";\nimport { generatePrompt } from \"../lib/prompt.js\";\nimport { launchInteractive } from \"../lib/launcher.js\";\nimport { ProcessMonitor } from \"../lib/monitor.js\";","truncated":false,"loaded":[]},"time":{"start":1773351517103,"end":1773351517105}}}}
{"type":"text","timestamp":1773351517659,"sessionID":"ses_31c036d39ffedecysjCoQobMfd","part":{"id":"prt_ce3fcb24b001ea6HM4c7q7TuER","sessionID":"ses_31c036d39ffedecysjCoQobMfd","messageID":"msg_ce3fcaa25001lXgoEh82ey3ueX","type":"text","text":"Now let me explore the key files for understanding state management, cleanup, retry, and process management:","time":{"start":1773351517659,"end":1773351517659}}}
{"type":"tool_use","timestamp":1773351517666,"sessionID":"ses_31c036d39ffedecysjCoQobMfd","part":{"id":"prt_ce3fcbc14001n5p6MyIL7laYT7","sessionID":"ses_31c036d39ffedecysjCoQobMfd","messageID":"msg_ce3fcaa25001lXgoEh82ey3ueX","type":"tool","callID":"toolu_vrtx_01735yWMx1pa9DMHRd8dBqCm","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-wombo-abort-command/src/lib/output.ts"},"output":"<path>/home/fulgidus/Documents/wombo-wombo-abort-command/src/lib/output.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * output.ts — Shared output helpers for agent-ready CLI.\n3:  *\n4:  * Provides a centralized way for commands to emit structured data that\n5:  * renders as human-readable text on TTY or as JSON when --output json\n6:  * is specified (or when stdout is not a TTY).\n7:  *\n8:  * Usage in commands:\n9:  *   import { output, OutputFormat } from \"../lib/output.js\";\n10:  *\n11:  *   // At the end of a command:\n12:  *   output(format, data);           // emits JSON or human text\n13:  *   outputError(format, message);   // emits error in the right format\n14:  */\n15: \n16: // ---------------------------------------------------------------------------\n17: // Types\n18: // ---------------------------------------------------------------------------\n19: \n20: export type OutputFormat = \"text\" | \"json\";\n21: \n22: // ---------------------------------------------------------------------------\n23: // Helpers\n24: // ---------------------------------------------------------------------------\n25: \n26: /**\n27:  * Determine the output format. Priority:\n28:  *   1. Explicit --output flag value\n29:  *   2. WOMBO_OUTPUT env var (for agent pipelines)\n30:  *   3. Default to \"text\"\n31:  *\n32:  * Note: We intentionally do NOT auto-detect based on TTY. Many legitimate\n33:  * use cases (bun dev, piped to less/grep, CI) have non-TTY stdout but still\n34:  * want human output. Agents should explicitly pass --output json or set\n35:  * WOMBO_OUTPUT=json.\n36:  */\n37: export function resolveOutputFormat(explicit?: string): OutputFormat {\n38:   if (explicit === \"json\") return \"json\";\n39:   if (explicit === \"text\") return \"text\";\n40:   // Check env var for agent pipelines\n41:   const env = process.env.WOMBO_OUTPUT;\n42:   if (env === \"json\") return \"json\";\n43:   return \"text\";\n44: }\n45: \n46: /**\n47:  * Emit structured data. In JSON mode, outputs a single JSON line to stdout.\n48:  * In text mode, calls the provided textRenderer callback.\n49:  */\n50: export function output(\n51:   format: OutputFormat,\n52:   data: unknown,\n53:   textRenderer: () => void\n54: ): void {\n55:   if (format === \"json\") {\n56:     console.log(JSON.stringify(data));\n57:   } else {\n58:     textRenderer();\n59:   }\n60: }\n61: \n62: /**\n63:  * Emit an error. In JSON mode, outputs {\"error\": message} to stderr.\n64:  * In text mode, outputs the message to stderr normally.\n65:  */\n66: export function outputError(format: OutputFormat, message: string, exitCode: number = 1): never {\n67:   if (format === \"json\") {\n68:     console.error(JSON.stringify({ error: message }));\n69:   } else {\n70:     console.error(message);\n71:   }\n72:   process.exit(exitCode);\n73: }\n74: \n75: /**\n76:  * Emit a success/info message. In JSON mode, outputs {\"message\": msg, ...extra}.\n77:  * In text mode, outputs the message to stdout normally.\n78:  */\n79: export function outputMessage(\n80:   format: OutputFormat,\n81:   message: string,\n82:   extra?: Record<string, unknown>\n83: ): void {\n84:   if (format === \"json\") {\n85:     console.log(JSON.stringify({ message, ...extra }));\n86:   } else {\n87:     console.log(message);\n88:   }\n89: }\n90: \n91: // ---------------------------------------------------------------------------\n92: // Field filtering for compact output (--fields)\n93: // ---------------------------------------------------------------------------\n94: \n95: /**\n96:  * Filter an object to only include the specified fields.\n97:  * If fields is undefined/empty, returns the object unchanged.\n98:  */\n99: export function filterFields<T extends Record<string, unknown>>(\n100:   obj: T,\n101:   fields?: string[]\n102: ): Partial<T> {\n103:   if (!fields || fields.length === 0) return obj;\n104:   const result: Partial<T> = {};\n105:   for (const field of fields) {\n106:     if (field in obj) {\n107:       (result as any)[field] = (obj as any)[field];\n108:     }\n109:   }\n110:   return result;\n111: }\n112: \n113: /**\n114:  * Filter an array of objects to only include specified fields per object.\n115:  * If fields is undefined/empty, returns the array unchanged.\n116:  */\n117: export function filterFieldsArray<T extends Record<string, unknown>>(\n118:   arr: T[],\n119:   fields?: string[]\n120: ): Partial<T>[] {\n121:   if (!fields || fields.length === 0) return arr;\n122:   return arr.map((obj) => filterFields(obj, fields));\n123: }\n124: \n125: /**\n126:  * Render a compact text table from an array of objects with selected fields.\n127:  * Used for text-mode --fields output.\n128:  */\n129: export function renderCompactTable(\n130:   items: Record<string, unknown>[],\n131:   fields: string[]\n132: ): void {\n133:   if (items.length === 0) return;\n134: \n135:   // Calculate column widths\n136:   const widths: Record<string, number> = {};\n137:   for (const field of fields) {\n138:     widths[field] = field.length;\n139:     for (const item of items) {\n140:       const val = String(item[field] ?? \"\");\n141:       widths[field] = Math.max(widths[field], val.length);\n142:     }\n143:   }\n144: \n145:   // Header\n146:   const header = fields.map((f) => f.padEnd(widths[f])).join(\"  \");\n147:   console.log(header);\n148:   console.log(fields.map((f) => \"─\".repeat(widths[f])).join(\"  \"));\n149: \n150:   // Rows\n151:   for (const item of items) {\n152:     const row = fields.map((f) => String(item[f] ?? \"\").padEnd(widths[f])).join(\"  \");\n153:     console.log(row);\n154:   }\n155: }\n\n(End of file - total 155 lines)\n</content>","title":"src/lib/output.ts","metadata":{"preview":"/**\n * output.ts — Shared output helpers for agent-ready CLI.\n *\n * Provides a centralized way for commands to emit structured data that\n * renders as human-readable text on TTY or as JSON when --output json\n * is specified (or when stdout is not a TTY).\n *\n * Usage in commands:\n *   import { output, OutputFormat } from \"../lib/output.js\";\n *\n *   // At the end of a command:\n *   output(format, data);           // emits JSON or human text\n *   outputError(format, message);   // emits error in the right format\n */\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type OutputFormat = \"text\" | \"json\";","truncated":false,"loaded":[]},"time":{"start":1773351517657,"end":1773351517664}}}}
