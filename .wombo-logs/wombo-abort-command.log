{"type":"tool_use","timestamp":1773351521681,"sessionID":"ses_31c036d39ffedecysjCoQobMfd","part":{"id":"prt_ce3fcca02001m5zHI3LCYjlivx","sessionID":"ses_31c036d39ffedecysjCoQobMfd","messageID":"msg_ce3fcbe0a001K76iZatTwl2afg","type":"tool","callID":"toolu_vrtx_018iiNEsTpgZEfrtPgWtB17f","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-wombo-abort-command/src/lib/launcher.ts"},"output":"<path>/home/fulgidus/Documents/wombo-wombo-abort-command/src/lib/launcher.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * launcher.ts — Process spawning and tmux session management.\n3:  *\n4:  * Responsibilities:\n5:  *   - Launch agent in headless mode (agent run --format json)\n6:  *   - Launch agent in interactive mode (tmux session with TUI)\n7:  *   - Resume sessions for auto-retry\n8:  *   - Manage tmux sessions (create, list, kill)\n9:  */\n10: \n11: import { spawn, execSync, type ChildProcess } from \"node:child_process\";\n12: import { writeFileSync, unlinkSync } from \"node:fs\";\n13: import type { WomboConfig } from \"../config.js\";\n14: import { resolveAgentBin } from \"../config.js\";\n15: \n16: // ---------------------------------------------------------------------------\n17: // Types\n18: // ---------------------------------------------------------------------------\n19: \n20: export interface LaunchResult {\n21:   pid: number;\n22:   process: ChildProcess;\n23:   sessionId?: string;\n24: }\n25: \n26: export interface LaunchOptions {\n27:   worktreePath: string;\n28:   featureId: string;\n29:   prompt: string;\n30:   model?: string;\n31:   interactive?: boolean;\n32:   config: WomboConfig;\n33: }\n34: \n35: export interface RetryOptions {\n36:   worktreePath: string;\n37:   featureId: string;\n38:   sessionId: string;\n39:   buildErrors: string;\n40:   model?: string;\n41:   interactive?: boolean;\n42:   config: WomboConfig;\n43: }\n44: \n45: // ---------------------------------------------------------------------------\n46: // Helpers\n47: // ---------------------------------------------------------------------------\n48: \n49: function tmuxSessionName(featureId: string, config: WomboConfig): string {\n50:   return `${config.agent.tmuxPrefix}-${featureId}`;\n51: }\n52: \n53: function runSilent(cmd: string): string {\n54:   try {\n55:     return execSync(cmd, { encoding: \"utf-8\", stdio: \"pipe\" }).trim();\n56:   } catch {\n57:     return \"\";\n58:   }\n59: }\n60: \n61: // ---------------------------------------------------------------------------\n62: // Headless Launch\n63: // ---------------------------------------------------------------------------\n64: \n65: /**\n66:  * Launch agent in headless mode with JSON output.\n67:  */\n68: export function launchHeadless(opts: LaunchOptions): LaunchResult {\n69:   const agentBin = resolveAgentBin(opts.config);\n70: \n71:   const args = [\n72:     \"run\",\n73:     \"--format\", \"json\",\n74:     \"--agent\", opts.config.agent.name,\n75:     \"--dir\", opts.worktreePath,\n76:     \"--title\", `wombo: ${opts.featureId}`,\n77:   ];\n78: \n79:   if (opts.model) {\n80:     args.push(\"--model\", opts.model);\n81:   }\n82: \n83:   args.push(opts.prompt);\n84: \n85:   const child = spawn(agentBin, args, {\n86:     stdio: [\"pipe\", \"pipe\", \"pipe\"],\n87:     detached: false,\n88:     env: {\n89:       ...process.env,\n90:       OPENCODE_DIR: opts.worktreePath,\n91:     },\n92:   });\n93: \n94:   // Close stdin so agent starts processing immediately\n95:   child.stdin?.end();\n96: \n97:   return {\n98:     pid: child.pid!,\n99:     process: child,\n100:   };\n101: }\n102: \n103: /**\n104:  * Resume a headless session with a retry message (build errors).\n105:  */\n106: export function retryHeadless(opts: RetryOptions): LaunchResult {\n107:   const agentBin = resolveAgentBin(opts.config);\n108: \n109:   const retryMessage = `The build failed. Please fix the following errors and run \\`${opts.config.build.command}\\` again:\\n\\n\\`\\`\\`\\n${opts.buildErrors}\\n\\`\\`\\`\\n\\nFix all errors, then verify the build passes.`;\n110: \n111:   const args = [\n112:     \"run\",\n113:     \"--format\", \"json\",\n114:     \"--session\", opts.sessionId,\n115:     \"--continue\",\n116:     \"--dir\", opts.worktreePath,\n117:   ];\n118: \n119:   if (opts.model) {\n120:     args.push(\"--model\", opts.model);\n121:   }\n122: \n123:   args.push(retryMessage);\n124: \n125:   const child = spawn(agentBin, args, {\n126:     stdio: [\"pipe\", \"pipe\", \"pipe\"],\n127:     detached: false,\n128:     env: {\n129:       ...process.env,\n130:       OPENCODE_DIR: opts.worktreePath,\n131:     },\n132:   });\n133: \n134:   child.stdin?.end();\n135: \n136:   return {\n137:     pid: child.pid!,\n138:     process: child,\n139:   };\n140: }\n141: \n142: // ---------------------------------------------------------------------------\n143: // Conflict Resolution Launch\n144: // ---------------------------------------------------------------------------\n145: \n146: export interface ConflictResolverOptions {\n147:   worktreePath: string;\n148:   featureId: string;\n149:   prompt: string;\n150:   model?: string;\n151:   config: WomboConfig;\n152: }\n153: \n154: /**\n155:  * Launch a headless agent to resolve merge conflicts.\n156:  *\n157:  * This is similar to `launchHeadless`, but the prompt is a conflict-resolution\n158:  * prompt generated by `generateConflictResolutionPrompt()`. The agent runs in\n159:  * the feature worktree where `git merge <baseBranch>` has already been run,\n160:  * leaving conflict markers in the working tree.\n161:  */\n162: export function launchConflictResolver(opts: ConflictResolverOptions): LaunchResult {\n163:   const agentBin = resolveAgentBin(opts.config);\n164: \n165:   const args = [\n166:     \"run\",\n167:     \"--format\", \"json\",\n168:     \"--agent\", opts.config.agent.name,\n169:     \"--dir\", opts.worktreePath,\n170:     \"--title\", `wombo: conflict-resolve ${opts.featureId}`,\n171:   ];\n172: \n173:   if (opts.model) {\n174:     args.push(\"--model\", opts.model);\n175:   }\n176: \n177:   args.push(opts.prompt);\n178: \n179:   const child = spawn(agentBin, args, {\n180:     stdio: [\"pipe\", \"pipe\", \"pipe\"],\n181:     detached: false,\n182:     env: {\n183:       ...process.env,\n184:       OPENCODE_DIR: opts.worktreePath,\n185:     },\n186:   });\n187: \n188:   child.stdin?.end();\n189: \n190:   return {\n191:     pid: child.pid!,\n192:     process: child,\n193:   };\n194: }\n195: \n196: // ---------------------------------------------------------------------------\n197: // Interactive (tmux) Launch\n198: // ---------------------------------------------------------------------------\n199: \n200: /**\n201:  * Launch agent in a tmux session for interactive use.\n202:  */\n203: export function launchInteractive(opts: LaunchOptions): LaunchResult {\n204:   const agentBin = resolveAgentBin(opts.config);\n205:   const sessionName = tmuxSessionName(opts.featureId, opts.config);\n206: \n207:   // Kill existing session if any\n208:   killTmuxSession(opts.featureId, opts.config);\n209: \n210:   // Build the agent command to run inside tmux\n211:   const ocArgs = [\n212:     agentBin,\n213:     \"--dir\", JSON.stringify(opts.worktreePath),\n214:   ];\n215: \n216:   if (opts.model) {\n217:     ocArgs.push(\"--model\", JSON.stringify(opts.model));\n218:   }\n219: \n220:   const tmuxCmd = ocArgs.join(\" \");\n221: \n222:   // Create a detached tmux session running the agent\n223:   execSync(\n224:     `tmux new-session -d -s \"${sessionName}\" -c \"${opts.worktreePath}\" \"${tmuxCmd}\"`,\n225:     { stdio: \"pipe\" }\n226:   );\n227: \n228:   // Send the prompt as initial message after a brief delay\n229:   setTimeout(() => {\n230:     try {\n231:       const tmpFile = `/tmp/wombo-prompt-${opts.featureId}.txt`;\n232:       writeFileSync(tmpFile, opts.prompt);\n233:       execSync(`tmux load-buffer \"${tmpFile}\"`, { stdio: \"pipe\" });\n234:       execSync(`tmux paste-buffer -t \"${sessionName}\"`, { stdio: \"pipe\" });\n235:       execSync(`tmux send-keys -t \"${sessionName}\" Enter`, { stdio: \"pipe\" });\n236:       try { unlinkSync(tmpFile); } catch {}\n237:     } catch {\n238:       // If prompt sending fails, user can type manually\n239:     }\n240:   }, 3000);\n241: \n242:   // Get the PID of the tmux server pane process\n243:   const panePid = runSilent(\n244:     `tmux list-panes -t \"${sessionName}\" -F \"#{pane_pid}\"`\n245:   );\n246: \n247:   return {\n248:     pid: parseInt(panePid) || 0,\n249:     process: null as any, // No direct process handle in tmux mode\n250:   };\n251: }\n252: \n253: /**\n254:  * Resume an interactive session with retry message.\n255:  */\n256: export function retryInteractive(opts: RetryOptions): LaunchResult {\n257:   const sessionName = tmuxSessionName(opts.featureId, opts.config);\n258: \n259:   const exists = tmuxSessionExists(opts.featureId, opts.config);\n260: \n261:   if (exists) {\n262:     const retryMsg = `The build failed. Fix these errors:\\n${opts.buildErrors}`;\n263:     const tmpFile = `/tmp/wombo-retry-${opts.featureId}.txt`;\n264:     writeFileSync(tmpFile, retryMsg);\n265:     execSync(`tmux load-buffer \"${tmpFile}\"`, { stdio: \"pipe\" });\n266:     execSync(`tmux paste-buffer -t \"${sessionName}\"`, { stdio: \"pipe\" });\n267:     execSync(`tmux send-keys -t \"${sessionName}\" Enter`, { stdio: \"pipe\" });\n268:     try { unlinkSync(tmpFile); } catch {}\n269: \n270:     const panePid = runSilent(\n271:       `tmux list-panes -t \"${sessionName}\" -F \"#{pane_pid}\"`\n272:     );\n273: \n274:     return {\n275:       pid: parseInt(panePid) || 0,\n276:       process: null as any,\n277:     };\n278:   }\n279: \n280:   // Session doesn't exist — launch a new interactive session\n281:   return launchInteractive({\n282:     worktreePath: opts.worktreePath,\n283:     featureId: opts.featureId,\n284:     prompt: `Continue from session ${opts.sessionId}. The build failed:\\n${opts.buildErrors}\\n\\nFix all errors and verify the build passes.`,\n285:     model: opts.model,\n286:     interactive: true,\n287:     config: opts.config,\n288:   });\n289: }\n290: \n291: // ---------------------------------------------------------------------------\n292: // tmux Session Management\n293: // ---------------------------------------------------------------------------\n294: \n295: /**\n296:  * Check if a tmux session exists for a feature.\n297:  */\n298: export function tmuxSessionExists(\n299:   featureId: string,\n300:   config: WomboConfig\n301: ): boolean {\n302:   const sessionName = tmuxSessionName(featureId, config);\n303:   return runSilent(`tmux has-session -t \"${sessionName}\" 2>/dev/null && echo yes`) === \"yes\";\n304: }\n305: \n306: /**\n307:  * Kill a tmux session for a feature.\n308:  */\n309: export function killTmuxSession(\n310:   featureId: string,\n311:   config: WomboConfig\n312: ): void {\n313:   const sessionName = tmuxSessionName(featureId, config);\n314:   runSilent(`tmux kill-session -t \"${sessionName}\" 2>/dev/null`);\n315: }\n316: \n317: /**\n318:  * List all wombo-related tmux sessions.\n319:  */\n320: export function listTmuxSessions(config: WomboConfig): string[] {\n321:   const output = runSilent(\n322:     `tmux list-sessions -F \"#{session_name}\" 2>/dev/null`\n323:   );\n324:   if (!output) return [];\n325:   return output\n326:     .split(\"\\n\")\n327:     .filter((s) => s.startsWith(config.agent.tmuxPrefix + \"-\"));\n328: }\n329: \n330: /**\n331:  * Kill all wombo-related tmux sessions.\n332:  */\n333: export function killAllTmuxSessions(config: WomboConfig): number {\n334:   const sessions = listTmuxSessions(config);\n335:   for (const s of sessions) {\n336:     runSilent(`tmux kill-session -t \"${s}\" 2>/dev/null`);\n337:   }\n338:   return sessions.length;\n339: }\n340: \n341: /**\n342:  * Check if a process is still running by PID.\n343:  */\n344: export function isProcessRunning(pid: number): boolean {\n345:   if (!pid || pid <= 0) return false;\n346:   try {\n347:     process.kill(pid, 0);\n348:     return true;\n349:   } catch {\n350:     return false;\n351:   }\n352: }\n\n(End of file - total 352 lines)\n</content>","title":"src/lib/launcher.ts","metadata":{"preview":"/**\n * launcher.ts — Process spawning and tmux session management.\n *\n * Responsibilities:\n *   - Launch agent in headless mode (agent run --format json)\n *   - Launch agent in interactive mode (tmux session with TUI)\n *   - Resume sessions for auto-retry\n *   - Manage tmux sessions (create, list, kill)\n */\n\nimport { spawn, execSync, type ChildProcess } from \"node:child_process\";\nimport { writeFileSync, unlinkSync } from \"node:fs\";\nimport type { WomboConfig } from \"../config.js\";\nimport { resolveAgentBin } from \"../config.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface LaunchResult {","truncated":false,"loaded":[]},"time":{"start":1773351521662,"end":1773351521675}}}}
{"type":"tool_use","timestamp":1773351522189,"sessionID":"ses_31c036d39ffedecysjCoQobMfd","part":{"id":"prt_ce3fccd830015vE362mh3Tq8wJ","sessionID":"ses_31c036d39ffedecysjCoQobMfd","messageID":"msg_ce3fcbe0a001K76iZatTwl2afg","type":"tool","callID":"toolu_vrtx_01AQjb8o5MUr448m3nrMHdQS","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-wombo-abort-command/src/lib/schema.ts"},"output":"<path>/home/fulgidus/Documents/wombo-wombo-abort-command/src/lib/schema.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * schema.ts — Declarative command/flag registry for schema introspection.\n3:  *\n4:  * Every command and flag is described in a single registry. This registry is\n5:  * the source of truth for:\n6:  *   1. `wombo describe <command>` — emits a JSON schema of accepted args\n7:  *   2. Future help text generation\n8:  *\n9:  * The registry is NOT used for actual arg parsing (that's still the hand-rolled\n10:  * switch in index.ts), but the two must stay in sync. If they drift, `wombo\n11:  * features check` should eventually catch it.\n12:  */\n13: \n14: // ---------------------------------------------------------------------------\n15: // Types\n16: // ---------------------------------------------------------------------------\n17: \n18: export interface FlagDef {\n19:   /** Primary flag name, e.g. \"--dry-run\" */\n20:   name: string;\n21:   /** Short alias, e.g. \"-o\" */\n22:   alias?: string;\n23:   /** Description shown in help / schema */\n24:   description: string;\n25:   /** Type of the value: \"boolean\" flags take no value, others consume next arg */\n26:   type: \"string\" | \"number\" | \"boolean\" | \"string[]\";\n27:   /** Default value (undefined = required or absent) */\n28:   default?: unknown;\n29:   /** For enum-like flags, the set of allowed values */\n30:   enum?: readonly string[];\n31:   /** If true, this flag is required */\n32:   required?: boolean;\n33: }\n34: \n35: export interface PositionalDef {\n36:   /** Name used in usage strings, e.g. \"feature-id\" */\n37:   name: string;\n38:   description: string;\n39:   required?: boolean;\n40: }\n41: \n42: export interface CommandDef {\n43:   /** Command name as typed by the user, e.g. \"launch\" or \"features list\" */\n44:   name: string;\n45:   /** One-line summary */\n46:   summary: string;\n47:   /** Longer description */\n48:   description?: string;\n49:   /** Positional arguments */\n50:   positionals: PositionalDef[];\n51:   /** Named flags */\n52:   flags: FlagDef[];\n53:   /** Whether this command mutates state (used for dry-run indication) */\n54:   mutating: boolean;\n55:   /** Whether this command supports --dry-run */\n56:   supportsDryRun: boolean;\n57:   /** Subcommands (for \"features\" parent) */\n58:   subcommands?: CommandDef[];\n59: }\n60: \n61: // ---------------------------------------------------------------------------\n62: // Global flags (available on every command)\n63: // ---------------------------------------------------------------------------\n64: \n65: const GLOBAL_FLAGS: FlagDef[] = [\n66:   {\n67:     name: \"--output\",\n68:     alias: \"-o\",\n69:     description: \"Output format: text (default) or json\",\n70:     type: \"string\",\n71:     default: \"text\",\n72:     enum: [\"text\", \"json\"],\n73:   },\n74:   {\n75:     name: \"--force\",\n76:     description: \"Force overwrite / skip safety prompts\",\n77:     type: \"boolean\",\n78:     default: false,\n79:   },\n80: ];\n81: \n82: // ---------------------------------------------------------------------------\n83: // Command Registry\n84: // ---------------------------------------------------------------------------\n85: \n86: export const COMMAND_REGISTRY: CommandDef[] = [\n87:   // --- init ---------------------------------------------------------------\n88:   {\n89:     name: \"init\",\n90:     summary: \"Generate wombo.json config in the current project\",\n91:     description:\n92:       \"Interactive guided setup that walks through every config section. \" +\n93:       \"Creates wombo.json and .features.yml from template.\",\n94:     positionals: [],\n95:     flags: [\n96:       {\n97:         name: \"--force\",\n98:         description: \"Overwrite existing config files\",\n99:         type: \"boolean\",\n100:         default: false,\n101:       },\n102:       {\n103:         name: \"--dry-run\",\n104:         description: \"Show what would be created without writing files\",\n105:         type: \"boolean\",\n106:         default: false,\n107:       },\n108:     ],\n109:     mutating: true,\n110:     supportsDryRun: true,\n111:   },\n112: \n113:   // --- launch -------------------------------------------------------------\n114:   {\n115:     name: \"launch\",\n116:     summary: \"Launch a wave of agents to implement features\",\n117:     description:\n118:       \"Select features from .features.yml, create worktrees, and spawn agents. \" +\n119:       \"Supports multiple selection strategies.\",\n120:     positionals: [],\n121:     flags: [\n122:       { name: \"--top-priority\", description: \"Select top N features by priority\", type: \"number\" },\n123:       { name: \"--quickest-wins\", description: \"Select N features with lowest effort\", type: \"number\" },\n124:       { name: \"--priority\", description: \"Filter by priority level\", type: \"string\", enum: [\"critical\", \"high\", \"medium\", \"low\", \"wishlist\"] },\n125:       { name: \"--difficulty\", description: \"Filter by difficulty level\", type: \"string\", enum: [\"trivial\", \"easy\", \"medium\", \"hard\", \"very_hard\"] },\n126:       { name: \"--features\", description: \"Select specific features by comma-separated IDs\", type: \"string\" },\n127:       { name: \"--all-ready\", description: \"Select all features whose dependencies are met\", type: \"boolean\", default: false },\n128:       { name: \"--max-concurrent\", description: \"Max agents running in parallel\", type: \"number\" },\n129:       { name: \"--model\", alias: \"-m\", description: \"Model to use (e.g., anthropic/claude-sonnet-4-20250514)\", type: \"string\" },\n130:       { name: \"--interactive\", description: \"Use tmux TUI mode instead of headless\", type: \"boolean\", default: false },\n131:       { name: \"--no-tui\", description: \"Headless mode without neo-blessed TUI\", type: \"boolean\", default: false },\n132:       { name: \"--auto-push\", description: \"Push base branch to remote after all merges\", type: \"boolean\", default: false },\n133:       { name: \"--dry-run\", description: \"Show what would be launched without launching\", type: \"boolean\", default: false },\n134:       { name: \"--base-branch\", description: \"Base branch (default: from config)\", type: \"string\" },\n135:       { name: \"--max-retries\", description: \"Max retries per agent\", type: \"number\" },\n136:     ],\n137:     mutating: true,\n138:     supportsDryRun: true,\n139:   },\n140: \n141:   // --- resume -------------------------------------------------------------\n142:   {\n143:     name: \"resume\",\n144:     summary: \"Resume a previously stopped wave\",\n145:     positionals: [],\n146:     flags: [\n147:       { name: \"--max-concurrent\", description: \"Max agents running in parallel\", type: \"number\" },\n148:       { name: \"--model\", alias: \"-m\", description: \"Model to use\", type: \"string\" },\n149:       { name: \"--interactive\", description: \"Use tmux TUI mode\", type: \"boolean\", default: false },\n150:       { name: \"--no-tui\", description: \"Headless mode without neo-blessed TUI\", type: \"boolean\", default: false },\n151:       { name: \"--auto-push\", description: \"Push base branch to remote after merges\", type: \"boolean\", default: false },\n152:       { name: \"--base-branch\", description: \"Base branch override\", type: \"string\" },\n153:       { name: \"--max-retries\", description: \"Max retries per agent\", type: \"number\" },\n154:     ],\n155:     mutating: true,\n156:     supportsDryRun: false,\n157:   },\n158: \n159:   // --- status -------------------------------------------------------------\n160:   {\n161:     name: \"status\",\n162:     summary: \"Show the status of the current wave\",\n163:     positionals: [],\n164:     flags: [],\n165:     mutating: false,\n166:     supportsDryRun: false,\n167:   },\n168: \n169:   // --- verify -------------------------------------------------------------\n170:   {\n171:     name: \"verify\",\n172:     summary: \"Run build verification on completed agents\",\n173:     positionals: [\n174:       { name: \"feature-id\", description: \"Specific feature to verify (optional)\", required: false },\n175:     ],\n176:     flags: [\n177:       { name: \"--model\", alias: \"-m\", description: \"Model to use for verification\", type: \"string\" },\n178:       { name: \"--max-retries\", description: \"Max retries\", type: \"number\" },\n179:     ],\n180:     mutating: true,\n181:     supportsDryRun: false,\n182:   },\n183: \n184:   // --- merge --------------------------------------------------------------\n185:   {\n186:     name: \"merge\",\n187:     summary: \"Merge verified branches into the base branch\",\n188:     positionals: [\n189:       { name: \"feature-id\", description: \"Specific feature to merge (optional)\", required: false },\n190:     ],\n191:     flags: [\n192:       { name: \"--auto-push\", description: \"Push base branch to remote after merge\", type: \"boolean\", default: false },\n193:       { name: \"--dry-run\", description: \"Show what would be merged without merging\", type: \"boolean\", default: false },\n194:     ],\n195:     mutating: true,\n196:     supportsDryRun: true,\n197:   },\n198: \n199:   // --- retry --------------------------------------------------------------\n200:   {\n201:     name: \"retry\",\n202:     summary: \"Retry a failed agent\",\n203:     positionals: [\n204:       { name: \"feature-id\", description: \"Feature ID of the failed agent\", required: true },\n205:     ],\n206:     flags: [\n207:       { name: \"--model\", alias: \"-m\", description: \"Model to use\", type: \"string\" },\n208:       { name: \"--interactive\", description: \"Use tmux TUI mode\", type: \"boolean\", default: false },\n209:       { name: \"--dry-run\", description: \"Show what would be retried without retrying\", type: \"boolean\", default: false },\n210:     ],\n211:     mutating: true,\n212:     supportsDryRun: true,\n213:   },\n214: \n215:   // --- cleanup ------------------------------------------------------------\n216:   {\n217:     name: \"cleanup\",\n218:     summary: \"Remove all wave worktrees and tmux sessions\",\n219:     description: \"Kills tmux sessions, removes worktrees, removes state and log files.\",\n220:     positionals: [],\n221:     flags: [\n222:       { name: \"--dry-run\", description: \"Show what would be cleaned up without removing\", type: \"boolean\", default: false },\n223:     ],\n224:     mutating: true,\n225:     supportsDryRun: true,\n226:   },\n227: \n228:   // --- upgrade ------------------------------------------------------------\n229:   {\n230:     name: \"upgrade\",\n231:     summary: \"Check for updates and upgrade wombo\",\n232:     positionals: [],\n233:     flags: [\n234:       { name: \"--check\", description: \"Only check for updates, don't install\", type: \"boolean\", default: false },\n235:       { name: \"--version\", description: \"Install a specific version (e.g., v0.1.0)\", type: \"string\" },\n236:       { name: \"--force\", description: \"Force reinstall even if up to date\", type: \"boolean\", default: false },\n237:     ],\n238:     mutating: true,\n239:     supportsDryRun: false,\n240:   },\n241: \n242:   // --- features (parent with subcommands) ---------------------------------\n243:   {\n244:     name: \"features\",\n245:     summary: \"Manage .features.yml\",\n246:     positionals: [],\n247:     flags: [],\n248:     mutating: false,\n249:     supportsDryRun: false,\n250:     subcommands: [\n251:       {\n252:         name: \"features list\",\n253:         summary: \"List features with optional filtering\",\n254:         positionals: [],\n255:         flags: [\n256:           { name: \"--status\", description: \"Filter by status\", type: \"string\", enum: [\"backlog\", \"planned\", \"in_progress\", \"blocked\", \"in_review\", \"done\", \"cancelled\"] },\n257:           { name: \"--priority\", description: \"Filter by priority\", type: \"string\", enum: [\"critical\", \"high\", \"medium\", \"low\", \"wishlist\"] },\n258:           { name: \"--difficulty\", description: \"Filter by difficulty\", type: \"string\", enum: [\"trivial\", \"easy\", \"medium\", \"hard\", \"very_hard\"] },\n259:           { name: \"--ready\", description: \"Show only ready features (backlog + deps met)\", type: \"boolean\", default: false },\n260:           { name: \"--include-archive\", description: \"Include archived features\", type: \"boolean\", default: false },\n261:           { name: \"--fields\", description: \"Comma-separated list of fields to include in output\", type: \"string\" },\n262:         ],\n263:         mutating: false,\n264:         supportsDryRun: false,\n265:       },\n266:       {\n267:         name: \"features add\",\n268:         summary: \"Add a new feature\",\n269:         positionals: [\n270:           { name: \"id\", description: \"Feature ID (kebab-case)\", required: true },\n271:           { name: \"title\", description: \"Feature title\", required: true },\n272:         ],\n273:         flags: [\n274:           { name: \"--description\", alias: \"--desc\", description: \"Feature description\", type: \"string\" },\n275:           { name: \"--priority\", description: \"Priority level\", type: \"string\", default: \"medium\", enum: [\"critical\", \"high\", \"medium\", \"low\", \"wishlist\"] },\n276:           { name: \"--difficulty\", description: \"Difficulty level\", type: \"string\", default: \"medium\", enum: [\"trivial\", \"easy\", \"medium\", \"hard\", \"very_hard\"] },\n277:           { name: \"--effort\", description: \"Effort estimate (ISO 8601 duration, e.g. PT2H)\", type: \"string\", default: \"PT1H\" },\n278:           { name: \"--depends-on\", description: \"Comma-separated dependency IDs\", type: \"string\" },\n279:           { name: \"--dry-run\", description: \"Show what would be added without writing\", type: \"boolean\", default: false },\n280:         ],\n281:         mutating: true,\n282:         supportsDryRun: true,\n283:       },\n284:       {\n285:         name: \"features set-status\",\n286:         summary: \"Change a feature's status\",\n287:         positionals: [\n288:           { name: \"feature-id\", description: \"Feature ID to update\", required: true },\n289:           { name: \"status\", description: \"New status value\", required: true },\n290:         ],\n291:         flags: [\n292:           { name: \"--dry-run\", description: \"Show what would change without writing\", type: \"boolean\", default: false },\n293:         ],\n294:         mutating: true,\n295:         supportsDryRun: true,\n296:       },\n297:       {\n298:         name: \"features check\",\n299:         summary: \"Validate .features.yml (schema, deps, duplicates, cycles)\",\n300:         positionals: [],\n301:         flags: [],\n302:         mutating: false,\n303:         supportsDryRun: false,\n304:       },\n305:       {\n306:         name: \"features archive\",\n307:         summary: \"Move done/cancelled features to archive section\",\n308:         positionals: [\n309:           { name: \"feature-id\", description: \"Specific feature to archive (optional)\", required: false },\n310:         ],\n311:         flags: [\n312:           { name: \"--dry-run\", description: \"Show what would be archived without moving\", type: \"boolean\", default: false },\n313:         ],\n314:         mutating: true,\n315:         supportsDryRun: true,\n316:       },\n317:       {\n318:         name: \"features show\",\n319:         summary: \"Show detailed information about a specific feature\",\n320:         positionals: [\n321:           { name: \"feature-id\", description: \"Feature ID to display\", required: true },\n322:         ],\n323:         flags: [\n324:           { name: \"--fields\", description: \"Comma-separated list of fields to include in output\", type: \"string\" },\n325:         ],\n326:         mutating: false,\n327:         supportsDryRun: false,\n328:       },\n329:       {\n330:         name: \"features graph\",\n331:         summary: \"Visualize the feature dependency graph as a terminal diagram\",\n332:         description:\n333:           \"Builds a Mermaid flowchart from the features dependency graph and renders \" +\n334:           \"it as a Unicode box diagram. Shows dependency edges, status badges, orphan \" +\n335:           \"detection, dangling dependency warnings, and cycle detection.\",\n336:         positionals: [],\n337:         flags: [\n338:           { name: \"--status\", description: \"Filter graph to features with this status\", type: \"string\", enum: [\"backlog\", \"planned\", \"in_progress\", \"blocked\", \"in_review\", \"done\", \"cancelled\"] },\n339:           { name: \"--ascii\", description: \"Use ASCII-only rendering (no Unicode box chars)\", type: \"boolean\", default: false },\n340:           { name: \"--mermaid\", description: \"Emit raw Mermaid source instead of rendered graph\", type: \"boolean\", default: false },\n341:           { name: \"--subtasks\", description: \"Include subtask-level nodes in the graph\", type: \"boolean\", default: false },\n342:         ],\n343:         mutating: false,\n344:         supportsDryRun: false,\n345:       },\n346:     ],\n347:   },\n348: \n349:   // --- help ---------------------------------------------------------------\n350:   {\n351:     name: \"help\",\n352:     summary: \"Show help text\",\n353:     positionals: [],\n354:     flags: [],\n355:     mutating: false,\n356:     supportsDryRun: false,\n357:   },\n358: \n359:   // --- describe -----------------------------------------------------------\n360:   {\n361:     name: \"describe\",\n362:     summary: \"Emit JSON schema of a command's arguments and flags\",\n363:     description:\n364:       \"Machine-readable introspection for AI agents. Outputs the accepted \" +\n365:       \"positionals, flags, types, defaults, and constraints for a command.\",\n366:     positionals: [\n367:       { name: \"command\", description: \"Command to describe (e.g. 'launch', 'features add')\", required: false },\n368:     ],\n369:     flags: [],\n370:     mutating: false,\n371:     supportsDryRun: false,\n372:   },\n373: ];\n374: \n375: // ---------------------------------------------------------------------------\n376: // Lookup helpers\n377: // ---------------------------------------------------------------------------\n378: \n379: /**\n380:  * Find a command definition by name. Supports compound names like \"features list\".\n381:  */\n382: export function findCommandDef(name: string): CommandDef | undefined {\n383:   // Try direct match first\n384:   const direct = COMMAND_REGISTRY.find((c) => c.name === name);\n385:   if (direct) return direct;\n386: \n387:   // Try compound: \"features list\" -> look in features subcommands\n388:   const parts = name.split(/\\s+/);\n389:   if (parts.length === 2) {\n390:     const parent = COMMAND_REGISTRY.find((c) => c.name === parts[0]);\n391:     if (parent?.subcommands) {\n392:       return parent.subcommands.find((sc) => sc.name === name || sc.name === parts[1]);\n393:     }\n394:   }\n395: \n396:   return undefined;\n397: }\n398: \n399: /**\n400:  * Produce the JSON schema object for a command, suitable for agent consumption.\n401:  */\n402: export function commandToSchema(cmd: CommandDef): Record<string, unknown> {\n403:   const schema: Record<string, unknown> = {\n404:     command: cmd.name,\n405:     summary: cmd.summary,\n406:     mutating: cmd.mutating,\n407:     supports_dry_run: cmd.supportsDryRun,\n408:   };\n409: \n410:   if (cmd.description) {\n411:     schema.description = cmd.description;\n412:   }\n413: \n414:   if (cmd.positionals.length > 0) {\n415:     schema.positionals = cmd.positionals.map((p) => ({\n416:       name: p.name,\n417:       description: p.description,\n418:       required: p.required ?? false,\n419:     }));\n420:   }\n421: \n422:   const allFlags = [...cmd.flags, ...GLOBAL_FLAGS];\n423:   schema.flags = allFlags.map((f) => {\n424:     const entry: Record<string, unknown> = {\n425:       name: f.name,\n426:       type: f.type,\n427:       description: f.description,\n428:     };\n429:     if (f.alias) entry.alias = f.alias;\n430:     if (f.default !== undefined) entry.default = f.default;\n431:     if (f.enum) entry.enum = f.enum;\n432:     if (f.required) entry.required = true;\n433:     return entry;\n434:   });\n435: \n436:   if (cmd.subcommands?.length) {\n437:     schema.subcommands = cmd.subcommands.map((sc) => sc.name);\n438:   }\n439: \n440:   return schema;\n441: }\n442: \n443: /**\n444:  * Produce a listing of all commands (for `wombo describe` with no args).\n445:  */\n446: export function allCommandSchemas(): Record<string, unknown> {\n447:   const commands: Record<string, unknown>[] = [];\n448: \n449:   for (const cmd of COMMAND_REGISTRY) {\n450:     const entry: Record<string, unknown> = {\n451:       name: cmd.name,\n452:       summary: cmd.summary,\n453:       mutating: cmd.mutating,\n454:       supports_dry_run: cmd.supportsDryRun,\n455:     };\n456:     if (cmd.subcommands) {\n457:       entry.subcommands = cmd.subcommands.map((sc) => ({\n458:         name: sc.name,\n459:         summary: sc.summary,\n460:         mutating: sc.mutating,\n461:         supports_dry_run: sc.supportsDryRun,\n462:       }));\n463:     }\n464:     commands.push(entry);\n465:   }\n466: \n467:   return {\n468:     tool: \"wombo\",\n469:     version: \"0.0.2\",\n470:     global_flags: GLOBAL_FLAGS.map((f) => ({\n471:       name: f.name,\n472:       alias: f.alias,\n473:       type: f.type,\n474:       description: f.description,\n475:       default: f.default,\n476:     })),\n477:     commands,\n478:   };\n479: }\n\n(End of file - total 479 lines)\n</content>","title":"src/lib/schema.ts","metadata":{"preview":"/**\n * schema.ts — Declarative command/flag registry for schema introspection.\n *\n * Every command and flag is described in a single registry. This registry is\n * the source of truth for:\n *   1. `wombo describe <command>` — emits a JSON schema of accepted args\n *   2. Future help text generation\n *\n * The registry is NOT used for actual arg parsing (that's still the hand-rolled\n * switch in index.ts), but the two must stay in sync. If they drift, `wombo\n * features check` should eventually catch it.\n */\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface FlagDef {\n  /** Primary flag name, e.g. \"--dry-run\" */\n  name: string;","truncated":false,"loaded":[]},"time":{"start":1773351522164,"end":1773351522183}}}}
{"type":"text","timestamp":1773351522515,"sessionID":"ses_31c036d39ffedecysjCoQobMfd","part":{"id":"prt_ce3fcc610001k2Yv2YGAo5Hwy8","sessionID":"ses_31c036d39ffedecysjCoQobMfd","messageID":"msg_ce3fcbe0a001K76iZatTwl2afg","type":"text","text":"Now let me look at the launcher module and schema module to understand tmux session management and command registration:","time":{"start":1773351522511,"end":1773351522511}}}
{"type":"tool_use","timestamp":1773351522558,"sessionID":"ses_31c036d39ffedecysjCoQobMfd","part":{"id":"prt_ce3fccf77001C3YBVDO3IkaCNJ","sessionID":"ses_31c036d39ffedecysjCoQobMfd","messageID":"msg_ce3fcbe0a001K76iZatTwl2afg","type":"tool","callID":"toolu_vrtx_01MDQgpJdUWyb5P8QoZKPjDo","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-wombo-abort-command/src/lib/monitor.ts"},"output":"<path>/home/fulgidus/Documents/wombo-wombo-abort-command/src/lib/monitor.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * monitor.ts — Parse JSON events from agent and detect completion/failure.\n3:  *\n4:  * Responsibilities:\n5:  *   - Parse newline-delimited JSON events from agent stdout\n6:  *   - Detect session completion (agent finished)\n7:  *   - Detect session ID from events\n8:  *   - Detect errors and failures\n9:  *   - Write per-agent raw log files for diagnostics\n10:  *   - Maintain per-agent parsed activity log for TUI preview\n11:  */\n12: \n13: import type { ChildProcess } from \"node:child_process\";\n14: import { isProcessRunning } from \"./launcher.js\";\n15: import { mkdirSync, appendFileSync, existsSync } from \"node:fs\";\n16: import { resolve } from \"node:path\";\n17: \n18: // ---------------------------------------------------------------------------\n19: // Log directory name (configurable would be overkill here)\n20: // ---------------------------------------------------------------------------\n21: \n22: const LOG_DIR_NAME = \".wombo-logs\";\n23: \n24: // ---------------------------------------------------------------------------\n25: // Types — OpenCode JSON Events\n26: // ---------------------------------------------------------------------------\n27: \n28: export interface OpenCodeEvent {\n29:   type: string;\n30:   sessionID?: string;\n31:   timestamp?: number;\n32:   part?: {\n33:     type?: string;\n34:     tool?: string;\n35:     callID?: string;\n36:     text?: string;\n37:     reason?: string;\n38:     cost?: number;\n39:     tokens?: {\n40:       total: number;\n41:       input: number;\n42:       output: number;\n43:       reasoning: number;\n44:     };\n45:     state?: {\n46:       status?: string;\n47:       input?: Record<string, any>;\n48:       output?: string;\n49:       error?: string;\n50:     };\n51:   };\n52:   [key: string]: any;\n53: }\n54: \n55: // ---------------------------------------------------------------------------\n56: // Event Parser\n57: // ---------------------------------------------------------------------------\n58: \n59: export interface ParsedOutput {\n60:   sessionId: string | null;\n61:   completed: boolean;\n62:   errored: boolean;\n63:   lastError: string | null;\n64:   events: OpenCodeEvent[];\n65: }\n66: \n67: export function parseEvents(rawOutput: string): ParsedOutput {\n68:   const result: ParsedOutput = {\n69:     sessionId: null,\n70:     completed: false,\n71:     errored: false,\n72:     lastError: null,\n73:     events: [],\n74:   };\n75: \n76:   const lines = rawOutput.split(\"\\n\").filter((l) => l.trim());\n77: \n78:   for (const line of lines) {\n79:     try {\n80:       const event = JSON.parse(line) as OpenCodeEvent;\n81:       result.events.push(event);\n82: \n83:       if (event.sessionID && !result.sessionId) {\n84:         result.sessionId = event.sessionID;\n85:       }\n86: \n87:       if (\n88:         event.type === \"step_finish\" &&\n89:         event.part?.reason === \"stop\"\n90:       ) {\n91:         result.completed = true;\n92:       }\n93: \n94:       if (\n95:         event.type === \"tool_use\" &&\n96:         event.part?.state?.status === \"error\"\n97:       ) {\n98:         result.errored = true;\n99:         result.lastError = event.part.state.error ?? \"unknown tool error\";\n100:       }\n101:     } catch {\n102:       // Not valid JSON — skip\n103:     }\n104:   }\n105: \n106:   return result;\n107: }\n108: \n109: // ---------------------------------------------------------------------------\n110: // Activity Extraction\n111: // ---------------------------------------------------------------------------\n112: \n113: function shortPath(fullPath: string | undefined, maxLen: number = 30): string {\n114:   if (!fullPath) return \"\";\n115:   const parts = fullPath.replace(/^\\/+/, \"\").split(\"/\");\n116:   const short =\n117:     parts.length > 1\n118:       ? parts.slice(-2).join(\"/\")\n119:       : parts[parts.length - 1];\n120:   if (short.length <= maxLen) return short;\n121:   const fname = parts[parts.length - 1];\n122:   return fname.length <= maxLen ? fname : fname.slice(0, maxLen - 1) + \"\\u2026\";\n123: }\n124: \n125: function shortCmd(cmd: string | undefined, maxLen: number = 30): string {\n126:   if (!cmd) return \"\";\n127:   const first = cmd.split(\"\\n\")[0].trim();\n128:   if (first.length <= maxLen) return first;\n129:   return first.slice(0, maxLen - 1) + \"\\u2026\";\n130: }\n131: \n132: /**\n133:  * Map an event to a human-readable activity string.\n134:  */\n135: export function extractActivity(event: OpenCodeEvent): string | null {\n136:   switch (event.type) {\n137:     case \"step_start\":\n138:       return \"thinking\\u2026\";\n139: \n140:     case \"tool_use\": {\n141:       const toolName = (event.part?.tool ?? \"\").toLowerCase();\n142:       const input = event.part?.state?.input ?? {};\n143:       const status = event.part?.state?.status ?? \"\";\n144: \n145:       if (status === \"error\") {\n146:         return `${toolName}: error`;\n147:       }\n148: \n149:       switch (toolName) {\n150:         case \"read\":\n151:           return `reading ${shortPath(input.filePath ?? input.path)}`;\n152:         case \"write\":\n153:           return `writing ${shortPath(input.filePath ?? input.path)}`;\n154:         case \"edit\":\n155:           return `editing ${shortPath(input.filePath ?? input.path)}`;\n156:         case \"bash\":\n157:         case \"command\":\n158:         case \"terminal\":\n159:           return `$ ${shortCmd(input.command ?? input.cmd)}`;\n160:         case \"glob\":\n161:           return `finding: ${shortPath(input.pattern)}`;\n162:         case \"grep\":\n163:         case \"search\":\n164:           return `searching: ${(input.pattern ?? \"\").slice(0, 25)}`;\n165:         case \"task\":\n166:           return \"delegating task\\u2026\";\n167:         case \"webfetch\":\n168:         case \"web_fetch\":\n169:           return \"fetching URL\\u2026\";\n170:         case \"todowrite\":\n171:         case \"todo_write\":\n172:           return \"planning\\u2026\";\n173:         case \"question\":\n174:           return \"asking question\\u2026\";\n175:         case \"jcodemunch_index_folder\":\n176:         case \"jcodemunch_index_repo\":\n177:           return \"indexing code\\u2026\";\n178:         case \"jcodemunch_search_symbols\":\n179:         case \"jcodemunch_search_text\":\n180:           return \"searching symbols\\u2026\";\n181:         case \"jcodemunch_get_file_outline\":\n182:           return `outlining ${shortPath(input.file_path)}`;\n183:         case \"jcodemunch_get_symbol\":\n184:         case \"jcodemunch_get_symbols\":\n185:           return \"reading symbol\\u2026\";\n186:         default:\n187:           return `tool: ${toolName}`;\n188:       }\n189:     }\n190: \n191:     case \"text\":\n192:       return \"responding\\u2026\";\n193: \n194:     case \"step_finish\":\n195:       if (event.part?.reason === \"stop\") return \"done\";\n196:       if (event.part?.reason === \"tool-calls\") return null;\n197:       return null;\n198: \n199:     default:\n200:       return null;\n201:   }\n202: }\n203: \n204: /**\n205:  * Format an event into a human-readable log line for the activity stream.\n206:  */\n207: export function formatEventForLog(event: OpenCodeEvent): string | null {\n208:   switch (event.type) {\n209:     case \"step_start\":\n210:       return \"-- step started\";\n211: \n212:     case \"tool_use\": {\n213:       const toolName = event.part?.tool ?? \"unknown\";\n214:       const input = event.part?.state?.input ?? {};\n215:       const status = event.part?.state?.status ?? \"\";\n216:       const output = event.part?.state?.output ?? \"\";\n217:       const error = event.part?.state?.error ?? \"\";\n218: \n219:       let line = `>> ${toolName}`;\n220:       switch (toolName.toLowerCase()) {\n221:         case \"read\":\n222:           line = `>> read ${shortPath(input.filePath ?? input.path, 50)}`;\n223:           break;\n224:         case \"write\":\n225:           line = `>> write ${shortPath(input.filePath ?? input.path, 50)}`;\n226:           break;\n227:         case \"edit\":\n228:           line = `>> edit ${shortPath(input.filePath ?? input.path, 50)}`;\n229:           break;\n230:         case \"bash\":\n231:         case \"command\":\n232:           line = `>> $ ${shortCmd(input.command ?? input.cmd, 60)}`;\n233:           break;\n234:         case \"glob\":\n235:           line = `>> glob ${input.pattern ?? \"\"}`;\n236:           break;\n237:         case \"grep\":\n238:           line = `>> grep \"${(input.pattern ?? \"\").slice(0, 30)}\"`;\n239:           break;\n240:         case \"task\":\n241:           line = `>> task: ${(input.description ?? input.prompt ?? \"\").slice(0, 50)}`;\n242:           break;\n243:       }\n244: \n245:       if (status === \"completed\" && output) {\n246:         const preview = output.split(\"\\n\")[0].slice(0, 80);\n247:         return `${line}\\n   ${preview}${output.length > 80 ? \"\\u2026\" : \"\"}`;\n248:       }\n249:       if (status === \"error\" && error) {\n250:         return `${line}\\n!! ${error.slice(0, 100)}`;\n251:       }\n252:       return line;\n253:     }\n254: \n255:     case \"text\": {\n256:       const text = event.part?.text ?? \"\";\n257:       if (!text.trim()) return null;\n258:       const firstLine = text.split(\"\\n\").find((l: string) => l.trim())?.trim() ?? \"\";\n259:       if (firstLine.length === 0) return null;\n260:       return `   ${firstLine.slice(0, 120)}${firstLine.length > 120 ? \"\\u2026\" : \"\"}`;\n261:     }\n262: \n263:     case \"step_finish\": {\n264:       const reason = event.part?.reason ?? \"\";\n265:       const tokens = event.part?.tokens;\n266:       if (reason === \"stop\") {\n267:         const tokStr = tokens\n268:           ? ` (${tokens.input}in/${tokens.output}out)`\n269:           : \"\";\n270:         return `-- done${tokStr}`;\n271:       }\n272:       return null;\n273:     }\n274: \n275:     default:\n276:       return null;\n277:   }\n278: }\n279: \n280: // ---------------------------------------------------------------------------\n281: // Per-agent Activity Log (in-memory ring buffer for TUI)\n282: // ---------------------------------------------------------------------------\n283: \n284: export interface ActivityEntry {\n285:   timestamp: string;\n286:   text: string;\n287: }\n288: \n289: const MAX_ACTIVITY_LINES = 500;\n290: \n291: // ---------------------------------------------------------------------------\n292: // Process Monitor\n293: // ---------------------------------------------------------------------------\n294: \n295: export interface MonitorCallbacks {\n296:   onSessionId?: (featureId: string, sessionId: string) => void;\n297:   onComplete?: (featureId: string) => void;\n298:   onError?: (featureId: string, error: string) => void;\n299:   onOutput?: (featureId: string, data: string) => void;\n300:   onActivity?: (featureId: string, activity: string) => void;\n301: }\n302: \n303: interface MonitoredProcess {\n304:   featureId: string;\n305:   process: ChildProcess;\n306:   stdout: string;\n307:   stderr: string;\n308:   sessionId: string | null;\n309:   done: boolean;\n310:   lineBuffer: string;\n311:   sawFinalStop: boolean;\n312: }\n313: \n314: /**\n315:  * Monitor a set of headless agent processes.\n316:  * Collects stdout, parses events, and calls callbacks on state changes.\n317:  */\n318: export class ProcessMonitor {\n319:   private processes: Map<string, MonitoredProcess> = new Map();\n320:   private callbacks: MonitorCallbacks;\n321:   private logDir: string;\n322:   /** Per-agent activity log for TUI preview pane */\n323:   public activityLogs: Map<string, ActivityEntry[]> = new Map();\n324: \n325:   constructor(projectRoot: string, callbacks: MonitorCallbacks = {}) {\n326:     this.callbacks = callbacks;\n327:     this.logDir = resolve(projectRoot, LOG_DIR_NAME);\n328:     if (!existsSync(this.logDir)) {\n329:       mkdirSync(this.logDir, { recursive: true });\n330:     }\n331:   }\n332: \n333:   private pushActivity(featureId: string, text: string): void {\n334:     if (!this.activityLogs.has(featureId)) {\n335:       this.activityLogs.set(featureId, []);\n336:     }\n337:     const log = this.activityLogs.get(featureId)!;\n338:     for (const line of text.split(\"\\n\")) {\n339:       log.push({ timestamp: new Date().toISOString().slice(11, 19), text: line });\n340:     }\n341:     if (log.length > MAX_ACTIVITY_LINES) {\n342:       log.splice(0, log.length - MAX_ACTIVITY_LINES);\n343:     }\n344:   }\n345: \n346:   private writeLog(featureId: string, data: string): void {\n347:     try {\n348:       const logFile = resolve(this.logDir, `${featureId}.log`);\n349:       appendFileSync(logFile, data);\n350:     } catch {\n351:       // Non-critical\n352:     }\n353:   }\n354: \n355:   getActivityLog(featureId: string): ActivityEntry[] {\n356:     return this.activityLogs.get(featureId) ?? [];\n357:   }\n358: \n359:   addProcess(featureId: string, child: ChildProcess): void {\n360:     const monitored: MonitoredProcess = {\n361:       featureId,\n362:       process: child,\n363:       stdout: \"\",\n364:       stderr: \"\",\n365:       sessionId: null,\n366:       done: false,\n367:       lineBuffer: \"\",\n368:       sawFinalStop: false,\n369:     };\n370: \n371:     this.pushActivity(featureId, \"-- agent process started\");\n372:     this.writeLog(featureId, `[wombo] Process started at ${new Date().toISOString()}\\n`);\n373: \n374:     child.stdout?.on(\"data\", (data: Buffer) => {\n375:       const chunk = data.toString();\n376:       monitored.stdout += chunk;\n377:       this.callbacks.onOutput?.(featureId, chunk);\n378:       this.writeLog(featureId, chunk);\n379: \n380:       monitored.lineBuffer += chunk;\n381:       const lines = monitored.lineBuffer.split(\"\\n\");\n382:       monitored.lineBuffer = lines.pop() ?? \"\";\n383: \n384:       for (const line of lines) {\n385:         const trimmed = line.trim();\n386:         if (!trimmed) continue;\n387:         try {\n388:           const event = JSON.parse(trimmed) as OpenCodeEvent;\n389: \n390:           if (!monitored.sessionId && event.sessionID) {\n391:             monitored.sessionId = event.sessionID;\n392:             this.callbacks.onSessionId?.(featureId, event.sessionID);\n393:             this.pushActivity(featureId, `-- session: ${event.sessionID}`);\n394:           }\n395: \n396:           const activity = extractActivity(event);\n397:           if (activity) {\n398:             this.callbacks.onActivity?.(featureId, activity);\n399:           }\n400: \n401:           const logLine = formatEventForLog(event);\n402:           if (logLine) {\n403:             this.pushActivity(featureId, logLine);\n404:           }\n405: \n406:           if (\n407:             event.type === \"step_finish\" &&\n408:             event.part?.reason === \"stop\"\n409:           ) {\n410:             monitored.sawFinalStop = true;\n411:           }\n412:         } catch {\n413:           if (trimmed.length > 0 && trimmed.length < 500) {\n414:             this.pushActivity(featureId, `[raw] ${trimmed.slice(0, 120)}`);\n415:           }\n416:         }\n417:       }\n418:     });\n419: \n420:     child.stderr?.on(\"data\", (data: Buffer) => {\n421:       const chunk = data.toString();\n422:       monitored.stderr += chunk;\n423:       this.writeLog(featureId, `[stderr] ${chunk}`);\n424:       const lines = chunk.split(\"\\n\").filter((l) => l.trim());\n425:       for (const line of lines) {\n426:         this.pushActivity(featureId, `[stderr] ${line.trim().slice(0, 120)}`);\n427:       }\n428:     });\n429: \n430:     child.on(\"exit\", (code) => {\n431:       monitored.done = true;\n432:       this.pushActivity(featureId, `-- process exited (code ${code})`);\n433:       this.writeLog(featureId, `\\n[wombo] Process exited with code ${code} at ${new Date().toISOString()}\\n`);\n434: \n435:       if (code === 0 || monitored.sawFinalStop) {\n436:         this.callbacks.onComplete?.(featureId);\n437:       } else {\n438:         const error =\n439:           monitored.stderr.slice(-2000) ||\n440:           `Process exited with code ${code}`;\n441:         this.callbacks.onError?.(featureId, error);\n442:       }\n443:     });\n444: \n445:     child.on(\"error\", (err) => {\n446:       monitored.done = true;\n447:       this.pushActivity(featureId, `!! process error: ${err.message}`);\n448:       this.writeLog(featureId, `\\n[wombo] Process error: ${err.message}\\n`);\n449:       this.callbacks.onError?.(featureId, err.message);\n450:     });\n451: \n452:     this.processes.set(featureId, monitored);\n453:   }\n454: \n455:   getSessionId(featureId: string): string | null {\n456:     return this.processes.get(featureId)?.sessionId ?? null;\n457:   }\n458: \n459:   getOutput(featureId: string): string {\n460:     return this.processes.get(featureId)?.stdout ?? \"\";\n461:   }\n462: \n463:   isRunning(featureId: string): boolean {\n464:     const m = this.processes.get(featureId);\n465:     if (!m) return false;\n466:     if (m.done) return false;\n467:     return isProcessRunning(m.process.pid!);\n468:   }\n469: \n470:   allDone(): boolean {\n471:     for (const m of this.processes.values()) {\n472:       if (!m.done) return false;\n473:     }\n474:     return true;\n475:   }\n476: \n477:   activeCount(): number {\n478:     let count = 0;\n479:     for (const m of this.processes.values()) {\n480:       if (!m.done) count++;\n481:     }\n482:     return count;\n483:   }\n484: \n485:   remove(featureId: string): void {\n486:     const m = this.processes.get(featureId);\n487:     if (m && !m.done) {\n488:       try {\n489:         m.process.kill(\"SIGTERM\");\n490:       } catch {}\n491:     }\n492:     this.processes.delete(featureId);\n493:   }\n494: \n495:   killAll(): void {\n496:     for (const id of this.processes.keys()) {\n497:       this.remove(id);\n498:     }\n499:   }\n500: \n501:   waitAll(pollIntervalMs: number = 1000): Promise<void> {\n502:     return new Promise((resolve) => {\n503:       const check = () => {\n504:         if (this.allDone()) {\n505:           resolve();\n506:         } else {\n507:           setTimeout(check, pollIntervalMs);\n508:         }\n509:       };\n510:       check();\n511:     });\n512:   }\n513: }\n\n(End of file - total 513 lines)\n</content>","title":"src/lib/monitor.ts","metadata":{"preview":"/**\n * monitor.ts — Parse JSON events from agent and detect completion/failure.\n *\n * Responsibilities:\n *   - Parse newline-delimited JSON events from agent stdout\n *   - Detect session completion (agent finished)\n *   - Detect session ID from events\n *   - Detect errors and failures\n *   - Write per-agent raw log files for diagnostics\n *   - Maintain per-agent parsed activity log for TUI preview\n */\n\nimport type { ChildProcess } from \"node:child_process\";\nimport { isProcessRunning } from \"./launcher.js\";\nimport { mkdirSync, appendFileSync, existsSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\n\n// ---------------------------------------------------------------------------\n// Log directory name (configurable would be overkill here)\n// ---------------------------------------------------------------------------","truncated":false,"loaded":[]},"time":{"start":1773351522499,"end":1773351522547}}}}
