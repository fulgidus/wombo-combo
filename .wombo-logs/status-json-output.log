{"type":"tool_use","timestamp":1773351517399,"sessionID":"ses_31c036d5affeENe71rAql6keLu","part":{"id":"prt_ce3fcb992001Tz3MDAVJwQdFrl","sessionID":"ses_31c036d5affeENe71rAql6keLu","messageID":"msg_ce3fcafb40012pGvVWHntx57ZY","type":"tool","callID":"toolu_vrtx_01ShjmH2v22JBpfnFHs3roap","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-status-json-output/src/lib/output.ts"},"output":"<path>/home/fulgidus/Documents/wombo-status-json-output/src/lib/output.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * output.ts — Shared output helpers for agent-ready CLI.\n3:  *\n4:  * Provides a centralized way for commands to emit structured data that\n5:  * renders as human-readable text on TTY or as JSON when --output json\n6:  * is specified (or when stdout is not a TTY).\n7:  *\n8:  * Usage in commands:\n9:  *   import { output, OutputFormat } from \"../lib/output.js\";\n10:  *\n11:  *   // At the end of a command:\n12:  *   output(format, data);           // emits JSON or human text\n13:  *   outputError(format, message);   // emits error in the right format\n14:  */\n15: \n16: // ---------------------------------------------------------------------------\n17: // Types\n18: // ---------------------------------------------------------------------------\n19: \n20: export type OutputFormat = \"text\" | \"json\";\n21: \n22: // ---------------------------------------------------------------------------\n23: // Helpers\n24: // ---------------------------------------------------------------------------\n25: \n26: /**\n27:  * Determine the output format. Priority:\n28:  *   1. Explicit --output flag value\n29:  *   2. WOMBO_OUTPUT env var (for agent pipelines)\n30:  *   3. Default to \"text\"\n31:  *\n32:  * Note: We intentionally do NOT auto-detect based on TTY. Many legitimate\n33:  * use cases (bun dev, piped to less/grep, CI) have non-TTY stdout but still\n34:  * want human output. Agents should explicitly pass --output json or set\n35:  * WOMBO_OUTPUT=json.\n36:  */\n37: export function resolveOutputFormat(explicit?: string): OutputFormat {\n38:   if (explicit === \"json\") return \"json\";\n39:   if (explicit === \"text\") return \"text\";\n40:   // Check env var for agent pipelines\n41:   const env = process.env.WOMBO_OUTPUT;\n42:   if (env === \"json\") return \"json\";\n43:   return \"text\";\n44: }\n45: \n46: /**\n47:  * Emit structured data. In JSON mode, outputs a single JSON line to stdout.\n48:  * In text mode, calls the provided textRenderer callback.\n49:  */\n50: export function output(\n51:   format: OutputFormat,\n52:   data: unknown,\n53:   textRenderer: () => void\n54: ): void {\n55:   if (format === \"json\") {\n56:     console.log(JSON.stringify(data));\n57:   } else {\n58:     textRenderer();\n59:   }\n60: }\n61: \n62: /**\n63:  * Emit an error. In JSON mode, outputs {\"error\": message} to stderr.\n64:  * In text mode, outputs the message to stderr normally.\n65:  */\n66: export function outputError(format: OutputFormat, message: string, exitCode: number = 1): never {\n67:   if (format === \"json\") {\n68:     console.error(JSON.stringify({ error: message }));\n69:   } else {\n70:     console.error(message);\n71:   }\n72:   process.exit(exitCode);\n73: }\n74: \n75: /**\n76:  * Emit a success/info message. In JSON mode, outputs {\"message\": msg, ...extra}.\n77:  * In text mode, outputs the message to stdout normally.\n78:  */\n79: export function outputMessage(\n80:   format: OutputFormat,\n81:   message: string,\n82:   extra?: Record<string, unknown>\n83: ): void {\n84:   if (format === \"json\") {\n85:     console.log(JSON.stringify({ message, ...extra }));\n86:   } else {\n87:     console.log(message);\n88:   }\n89: }\n90: \n91: // ---------------------------------------------------------------------------\n92: // Field filtering for compact output (--fields)\n93: // ---------------------------------------------------------------------------\n94: \n95: /**\n96:  * Filter an object to only include the specified fields.\n97:  * If fields is undefined/empty, returns the object unchanged.\n98:  */\n99: export function filterFields<T extends Record<string, unknown>>(\n100:   obj: T,\n101:   fields?: string[]\n102: ): Partial<T> {\n103:   if (!fields || fields.length === 0) return obj;\n104:   const result: Partial<T> = {};\n105:   for (const field of fields) {\n106:     if (field in obj) {\n107:       (result as any)[field] = (obj as any)[field];\n108:     }\n109:   }\n110:   return result;\n111: }\n112: \n113: /**\n114:  * Filter an array of objects to only include specified fields per object.\n115:  * If fields is undefined/empty, returns the array unchanged.\n116:  */\n117: export function filterFieldsArray<T extends Record<string, unknown>>(\n118:   arr: T[],\n119:   fields?: string[]\n120: ): Partial<T>[] {\n121:   if (!fields || fields.length === 0) return arr;\n122:   return arr.map((obj) => filterFields(obj, fields));\n123: }\n124: \n125: /**\n126:  * Render a compact text table from an array of objects with selected fields.\n127:  * Used for text-mode --fields output.\n128:  */\n129: export function renderCompactTable(\n130:   items: Record<string, unknown>[],\n131:   fields: string[]\n132: ): void {\n133:   if (items.length === 0) return;\n134: \n135:   // Calculate column widths\n136:   const widths: Record<string, number> = {};\n137:   for (const field of fields) {\n138:     widths[field] = field.length;\n139:     for (const item of items) {\n140:       const val = String(item[field] ?? \"\");\n141:       widths[field] = Math.max(widths[field], val.length);\n142:     }\n143:   }\n144: \n145:   // Header\n146:   const header = fields.map((f) => f.padEnd(widths[f])).join(\"  \");\n147:   console.log(header);\n148:   console.log(fields.map((f) => \"─\".repeat(widths[f])).join(\"  \"));\n149: \n150:   // Rows\n151:   for (const item of items) {\n152:     const row = fields.map((f) => String(item[f] ?? \"\").padEnd(widths[f])).join(\"  \");\n153:     console.log(row);\n154:   }\n155: }\n\n(End of file - total 155 lines)\n</content>","title":"src/lib/output.ts","metadata":{"preview":"/**\n * output.ts — Shared output helpers for agent-ready CLI.\n *\n * Provides a centralized way for commands to emit structured data that\n * renders as human-readable text on TTY or as JSON when --output json\n * is specified (or when stdout is not a TTY).\n *\n * Usage in commands:\n *   import { output, OutputFormat } from \"../lib/output.js\";\n *\n *   // At the end of a command:\n *   output(format, data);           // emits JSON or human text\n *   outputError(format, message);   // emits error in the right format\n */\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type OutputFormat = \"text\" | \"json\";","truncated":false,"loaded":[]},"time":{"start":1773351517395,"end":1773351517397}}}}
{"type":"tool_use","timestamp":1773351517775,"sessionID":"ses_31c036d5affeENe71rAql6keLu","part":{"id":"prt_ce3fcbcd40010rVbyOLAVXKfgb","sessionID":"ses_31c036d5affeENe71rAql6keLu","messageID":"msg_ce3fcafb40012pGvVWHntx57ZY","type":"tool","callID":"toolu_vrtx_018Mw2uvvSK96DNBcMnz1gRV","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-status-json-output/src/lib/ui.ts"},"output":"<path>/home/fulgidus/Documents/wombo-status-json-output/src/lib/ui.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * ui.ts — Terminal dashboard for wave status display.\n3:  *\n4:  * Responsibilities:\n5:  *   - Render a live status table of all agents in a wave\n6:  *   - Show progress indicators, timing, retry counts\n7:  *   - Color-coded status output\n8:  *   - Summary statistics\n9:  */\n10: \n11: import type { WaveState, AgentState, AgentStatus } from \"./state.js\";\n12: import { agentCounts } from \"./state.js\";\n13: import { formatDuration, parseDurationMinutes } from \"./features.js\";\n14: \n15: // ---------------------------------------------------------------------------\n16: // ANSI Color Helpers\n17: // ---------------------------------------------------------------------------\n18: \n19: const RESET = \"\\x1b[0m\";\n20: const BOLD = \"\\x1b[1m\";\n21: const DIM = \"\\x1b[2m\";\n22: \n23: const FG = {\n24:   red: \"\\x1b[31m\",\n25:   green: \"\\x1b[32m\",\n26:   yellow: \"\\x1b[33m\",\n27:   blue: \"\\x1b[34m\",\n28:   magenta: \"\\x1b[35m\",\n29:   cyan: \"\\x1b[36m\",\n30:   white: \"\\x1b[37m\",\n31:   gray: \"\\x1b[90m\",\n32: };\n33: \n34: // ---------------------------------------------------------------------------\n35: // Status Colors\n36: // ---------------------------------------------------------------------------\n37: \n38: const STATUS_COLORS: Record<AgentStatus, string> = {\n39:   queued: FG.gray,\n40:   installing: FG.cyan,\n41:   running: FG.blue,\n42:   completed: FG.yellow,\n43:   verified: FG.green,\n44:   failed: FG.red,\n45:   merged: FG.magenta,\n46:   retry: FG.yellow,\n47:   resolving_conflict: FG.cyan,\n48: };\n49: \n50: const STATUS_ICONS: Record<AgentStatus, string> = {\n51:   queued: \".\",\n52:   installing: \">\",\n53:   running: \"*\",\n54:   completed: \"~\",\n55:   verified: \"+\",\n56:   failed: \"!\",\n57:   merged: \"#\",\n58:   retry: \"?\",\n59:   resolving_conflict: \"!\",\n60: };\n61: \n62: // ---------------------------------------------------------------------------\n63: // Formatting Helpers\n64: // ---------------------------------------------------------------------------\n65: \n66: function colorize(text: string, color: string): string {\n67:   return `${color}${text}${RESET}`;\n68: }\n69: \n70: function pad(text: string, width: number): string {\n71:   if (text.length >= width) return text.slice(0, width);\n72:   return text + \" \".repeat(width - text.length);\n73: }\n74: \n75: function padLeft(text: string, width: number): string {\n76:   if (text.length >= width) return text.slice(0, width);\n77:   return \" \".repeat(width - text.length) + text;\n78: }\n79: \n80: function elapsed(startedAt: string | null): string {\n81:   if (!startedAt) return \"-\";\n82:   const start = new Date(startedAt).getTime();\n83:   const now = Date.now();\n84:   const diffMs = now - start;\n85:   const mins = Math.floor(diffMs / 60000);\n86:   if (mins < 60) return `${mins}m`;\n87:   const hours = Math.floor(mins / 60);\n88:   const remMins = mins % 60;\n89:   return `${hours}h${remMins}m`;\n90: }\n91: \n92: // ---------------------------------------------------------------------------\n93: // Table Rendering\n94: // ---------------------------------------------------------------------------\n95: \n96: /**\n97:  * Render the full wave status dashboard to stdout.\n98:  */\n99: export function renderDashboard(state: WaveState): string {\n100:   const lines: string[] = [];\n101: \n102:   // Header\n103:   lines.push(\"\");\n104:   lines.push(\n105:     `${BOLD}Wombo${RESET} ${DIM}${state.wave_id}${RESET}`\n106:   );\n107:   lines.push(\n108:     `${DIM}Base: ${state.base_branch} | Concurrency: ${state.max_concurrent} | Mode: ${state.interactive ? \"interactive\" : \"headless\"}${RESET}`\n109:   );\n110:   if (state.model) {\n111:     lines.push(`${DIM}Model: ${state.model}${RESET}`);\n112:   }\n113:   lines.push(\"\");\n114: \n115:   // Table header\n116:   const header = [\n117:     pad(\"\", 3),\n118:     pad(\"Feature\", 30),\n119:     pad(\"Status\", 12),\n120:     pad(\"Activity\", 30),\n121:     padLeft(\"Retries\", 8),\n122:     padLeft(\"Elapsed\", 8),\n123:   ].join(\" \");\n124:   lines.push(`${BOLD}${header}${RESET}`);\n125:   lines.push(\"-\".repeat(95));\n126: \n127:   // Agent rows\n128:   for (const agent of state.agents) {\n129:     const statusColor = STATUS_COLORS[agent.status];\n130:     const icon = STATUS_ICONS[agent.status];\n131: \n132:     let activityText = \"-\";\n133:     if ((agent.status === \"running\" || agent.status === \"resolving_conflict\") && agent.activity) {\n134:       activityText = agent.activity;\n135:     } else if (agent.status === \"installing\") {\n136:       activityText = \"setting up worktree...\";\n137:     } else if (agent.status === \"retry\") {\n138:       activityText = \"retrying with errors...\";\n139:     } else if (agent.status === \"failed\" && agent.error) {\n140:       activityText = agent.error.split(\"\\n\")[0].slice(0, 28);\n141:     } else if (agent.status === \"verified\") {\n142:       activityText = \"build passed\";\n143:     } else if (agent.status === \"merged\") {\n144:       activityText = agent.branch;\n145:     }\n146: \n147:     const row = [\n148:       colorize(pad(`[${icon}]`, 3), statusColor),\n149:       pad(agent.feature_id, 30),\n150:       colorize(pad(agent.status, 12), statusColor),\n151:       (agent.status === \"running\" ? FG.cyan : DIM) + pad(activityText, 30) + RESET,\n152:       padLeft(\n153:         agent.retries > 0 ? `${agent.retries}/${agent.max_retries}` : \"-\",\n154:         8\n155:       ),\n156:       padLeft(elapsed(agent.started_at), 8),\n157:     ].join(\" \");\n158: \n159:     lines.push(row);\n160:   }\n161: \n162:   // Summary\n163:   lines.push(\"-\".repeat(95));\n164:   const counts = agentCounts(state);\n165:   const summaryParts: string[] = [];\n166: \n167:   if (counts.queued > 0)\n168:     summaryParts.push(colorize(`${counts.queued} queued`, FG.gray));\n169:   if (counts.installing > 0)\n170:     summaryParts.push(colorize(`${counts.installing} installing`, FG.cyan));\n171:   if (counts.running > 0)\n172:     summaryParts.push(colorize(`${counts.running} running`, FG.blue));\n173:   if (counts.completed > 0)\n174:     summaryParts.push(colorize(`${counts.completed} completed`, FG.yellow));\n175:   if (counts.verified > 0)\n176:     summaryParts.push(colorize(`${counts.verified} verified`, FG.green));\n177:   if (counts.failed > 0)\n178:     summaryParts.push(colorize(`${counts.failed} failed`, FG.red));\n179:   if (counts.merged > 0)\n180:     summaryParts.push(colorize(`${counts.merged} merged`, FG.magenta));\n181:   if (counts.retry > 0)\n182:     summaryParts.push(colorize(`${counts.retry} retrying`, FG.yellow));\n183:   if (counts.resolving_conflict > 0)\n184:     summaryParts.push(colorize(`${counts.resolving_conflict} resolving`, FG.cyan));\n185: \n186:   lines.push(summaryParts.join(\" | \"));\n187:   lines.push(\"\");\n188: \n189:   return lines.join(\"\\n\");\n190: }\n191: \n192: /**\n193:  * Print the dashboard to stdout.\n194:  */\n195: export function printDashboard(state: WaveState): void {\n196:   console.log(renderDashboard(state));\n197: }\n198: \n199: /**\n200:  * Print a single-line status update for a feature.\n201:  */\n202: export function printAgentUpdate(\n203:   agent: AgentState,\n204:   message: string\n205: ): void {\n206:   const statusColor = STATUS_COLORS[agent.status];\n207:   const icon = STATUS_ICONS[agent.status];\n208:   console.log(\n209:     `${colorize(`[${icon}]`, statusColor)} ${pad(agent.feature_id, 28)} ${message}`\n210:   );\n211: }\n212: \n213: /**\n214:  * Print a compact summary.\n215:  */\n216: export function printSummary(state: WaveState): void {\n217:   const counts = agentCounts(state);\n218:   const total = state.agents.length;\n219:   const done = counts.verified + counts.merged;\n220:   console.log(\n221:     `\\n${BOLD}Wave ${state.wave_id}${RESET}: ${done}/${total} done, ${counts.running} running, ${counts.failed} failed, ${counts.queued} queued`\n222:   );\n223: }\n224: \n225: /**\n226:  * Clear the terminal screen.\n227:  */\n228: export function clearScreen(): void {\n229:   process.stdout.write(\"\\x1b[2J\\x1b[H\");\n230: }\n231: \n232: /**\n233:  * Print a feature selection table (for launch preview).\n234:  */\n235: export function printFeatureSelection(\n236:   features: Array<{\n237:     id: string;\n238:     title: string;\n239:     priority: string;\n240:     difficulty: string;\n241:     effort: string;\n242:   }>\n243: ): void {\n244:   console.log(\"\");\n245:   console.log(`${BOLD}Selected Features (${features.length}):${RESET}`);\n246:   console.log(\"\");\n247: \n248:   const header = [\n249:     pad(\"#\", 4),\n250:     pad(\"Feature ID\", 30),\n251:     pad(\"Priority\", 10),\n252:     pad(\"Difficulty\", 12),\n253:     padLeft(\"Effort\", 8),\n254:     pad(\"Title\", 40),\n255:   ].join(\" \");\n256:   console.log(`${BOLD}${header}${RESET}`);\n257:   console.log(\"-\".repeat(108));\n258: \n259:   for (let i = 0; i < features.length; i++) {\n260:     const f = features[i];\n261:     const effortMin = parseDurationMinutes(f.effort);\n262:     const row = [\n263:       pad(`${i + 1}.`, 4),\n264:       pad(f.id, 30),\n265:       pad(f.priority, 10),\n266:       pad(f.difficulty, 12),\n267:       padLeft(formatDuration(effortMin), 8),\n268:       pad(f.title, 40),\n269:     ].join(\" \");\n270:     console.log(row);\n271:   }\n272: \n273:   console.log(\"\");\n274: }\n\n(End of file - total 274 lines)\n</content>","title":"src/lib/ui.ts","metadata":{"preview":"/**\n * ui.ts — Terminal dashboard for wave status display.\n *\n * Responsibilities:\n *   - Render a live status table of all agents in a wave\n *   - Show progress indicators, timing, retry counts\n *   - Color-coded status output\n *   - Summary statistics\n */\n\nimport type { WaveState, AgentState, AgentStatus } from \"./state.js\";\nimport { agentCounts } from \"./state.js\";\nimport { formatDuration, parseDurationMinutes } from \"./features.js\";\n\n// ---------------------------------------------------------------------------\n// ANSI Color Helpers\n// ---------------------------------------------------------------------------\n\nconst RESET = \"\\x1b[0m\";\nconst BOLD = \"\\x1b[1m\";","truncated":false,"loaded":[]},"time":{"start":1773351517772,"end":1773351517774}}}}
