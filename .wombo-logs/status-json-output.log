{"type":"tool_use","timestamp":1773351512973,"sessionID":"ses_31c036d5affeENe71rAql6keLu","part":{"id":"prt_ce3fca9120016dikGXF4fb1jJK","sessionID":"ses_31c036d5affeENe71rAql6keLu","messageID":"msg_ce3fc9371001nHMD3AkR8m3BgD","type":"tool","callID":"toolu_vrtx_01MYJwTvhma1nqs9bfKbscDD","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-status-json-output/src/commands/status.ts"},"output":"<path>/home/fulgidus/Documents/wombo-status-json-output/src/commands/status.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * status.ts — Show the status of the current wave.\n3:  *\n4:  * Usage: wombo status\n5:  *\n6:  * Loads the wave state, checks for dead processes, and prints a dashboard.\n7:  */\n8: \n9: import type { WomboConfig } from \"../config.js\";\n10: import { loadState, saveState, updateAgent } from \"../lib/state.js\";\n11: import { isProcessRunning } from \"../lib/launcher.js\";\n12: import { printDashboard } from \"../lib/ui.js\";\n13: \n14: export interface StatusOptions {\n15:   projectRoot: string;\n16:   config: WomboConfig;\n17: }\n18: \n19: export async function cmdStatus(opts: StatusOptions): Promise<void> {\n20:   const state = loadState(opts.projectRoot);\n21:   if (!state) {\n22:     console.log(\"No active wave. Use 'wombo launch' to start one.\");\n23:     return;\n24:   }\n25: \n26:   // Update running agent status from process state\n27:   for (const agent of state.agents) {\n28:     if (agent.status === \"running\" && agent.pid) {\n29:       if (!isProcessRunning(agent.pid)) {\n30:         updateAgent(state, agent.feature_id, {\n31:           status: \"completed\",\n32:           completed_at: new Date().toISOString(),\n33:         });\n34:       }\n35:     }\n36:   }\n37:   saveState(opts.projectRoot, state);\n38: \n39:   printDashboard(state);\n40: }\n\n(End of file - total 40 lines)\n</content>","title":"src/commands/status.ts","metadata":{"preview":"/**\n * status.ts — Show the status of the current wave.\n *\n * Usage: wombo status\n *\n * Loads the wave state, checks for dead processes, and prints a dashboard.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport { loadState, saveState, updateAgent } from \"../lib/state.js\";\nimport { isProcessRunning } from \"../lib/launcher.js\";\nimport { printDashboard } from \"../lib/ui.js\";\n\nexport interface StatusOptions {\n  projectRoot: string;\n  config: WomboConfig;\n}\n\nexport async function cmdStatus(opts: StatusOptions): Promise<void> {\n  const state = loadState(opts.projectRoot);","truncated":false,"loaded":[]},"time":{"start":1773351512962,"end":1773351512972}}}}
{"type":"tool_use","timestamp":1773351513520,"sessionID":"ses_31c036d5affeENe71rAql6keLu","part":{"id":"prt_ce3fcabea001smR1PYBBZFc3rv","sessionID":"ses_31c036d5affeENe71rAql6keLu","messageID":"msg_ce3fc9371001nHMD3AkR8m3BgD","type":"tool","callID":"toolu_vrtx_01VpxUB6P2XyQcJmhx3VCx2f","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-status-json-output/src/index.ts"},"output":"<path>/home/fulgidus/Documents/wombo-status-json-output/src/index.ts</path>\n<type>file</type>\n<content>1: #!/usr/bin/env bun\n2: /**\n3:  * index.ts — CLI entry point for the Wombo agent orchestration system.\n4:  *\n5:  * Usage:\n6:  *   wombo init\n7:  *   wombo launch --top-priority 3\n8:  *   wombo launch --quickest-wins 5\n9:  *   wombo launch --priority high\n10:  *   wombo launch --difficulty easy\n11:  *   wombo launch --features \"feat-a,feat-b\"\n12:  *   wombo launch --all-ready\n13:  *   wombo launch ... --max-concurrent 3 --model \"anthropic/claude-sonnet-4-20250514\"\n14:  *   wombo launch ... --interactive\n15:  *   wombo resume\n16:  *   wombo status\n17:  *   wombo verify [feature-id]\n18:  *   wombo merge [feature-id]\n19:  *   wombo retry <feature-id>\n20:  *   wombo cleanup\n21:  *   wombo features list [--status <s>] [--priority <p>] [--difficulty <d>] [--ready] [--include-archive]\n22:  *   wombo features add <id> <title> [options]\n23:  *   wombo features set-status <feature-id> <status>\n24:  *   wombo features check\n25:  *   wombo features archive [feature-id] [--dry-run]\n26:  *   wombo features show <feature-id>\n27:  *   wombo features graph [--ascii] [--mermaid] [--subtasks] [--status <s>]\n28:  *   wombo help\n29:  *   wombo --version\n30:  */\n31: \n32: import { resolve } from \"node:path\";\n33: import { existsSync, readFileSync } from \"node:fs\";\n34: import { loadConfig, validateConfig } from \"./config.js\";\n35: import { loadState, saveState } from \"./lib/state.js\";\n36: \n37: // ---------------------------------------------------------------------------\n38: // Dev-mode guard: warn if running the global binary inside the wombo repo\n39: // ---------------------------------------------------------------------------\n40: \n41: function checkDevModeGuard(): void {\n42:   const cwd = process.cwd();\n43:   const pkgPath = resolve(cwd, \"package.json\");\n44: \n45:   // Are we inside the wombo repo?\n46:   if (!existsSync(pkgPath)) return;\n47: \n48:   let pkgName: string | undefined;\n49:   try {\n50:     const raw = readFileSync(pkgPath, \"utf-8\");\n51:     pkgName = JSON.parse(raw).name;\n52:   } catch {\n53:     return;\n54:   }\n55:   if (pkgName !== \"wombo\") return;\n56: \n57:   // We're in the wombo repo. Is the source being run from a different location?\n58:   // import.meta.dir = directory of THIS file (index.ts). If it's under cwd,\n59:   // we're running local source (bun dev). If it's elsewhere (e.g. ~/.bun/install),\n60:   // we're running the globally installed binary.\n61:   const sourceDir = resolve(import.meta.dir);\n62:   const projectSrc = resolve(cwd, \"src\");\n63: \n64:   if (!sourceDir.startsWith(projectSrc)) {\n65:     console.warn(\n66:       \"\\x1b[33m[WARNING]\\x1b[0m You are running the globally installed wombo binary \" +\n67:       \"inside the wombo repo.\\n\" +\n68:       \"  Use \\x1b[1mbun dev <command>\\x1b[0m instead to run from local source.\\n\" +\n69:       \"  See AGENTS.md for details.\\n\"\n70:     );\n71:   }\n72: }\n73: \n74: import { cmdInit } from \"./commands/init.js\";\n75: import { cmdLaunch } from \"./commands/launch.js\";\n76: import { cmdResume } from \"./commands/resume.js\";\n77: import { cmdStatus } from \"./commands/status.js\";\n78: import { cmdVerify } from \"./commands/verify.js\";\n79: import { cmdMerge } from \"./commands/merge.js\";\n80: import { cmdRetry } from \"./commands/retry.js\";\n81: import { cmdCleanup } from \"./commands/cleanup.js\";\n82: import { cmdUpgrade } from \"./commands/upgrade.js\";\n83: import { cmdFeaturesList } from \"./commands/features/list.js\";\n84: import { cmdFeaturesAdd } from \"./commands/features/add.js\";\n85: import { cmdFeaturesSetStatus } from \"./commands/features/set-status.js\";\n86: import { cmdFeaturesCheck } from \"./commands/features/check.js\";\n87: import { cmdFeaturesArchive } from \"./commands/features/archive.js\";\n88: import { cmdFeaturesShow } from \"./commands/features/show.js\";\n89: import { cmdFeaturesGraph } from \"./commands/features/graph.js\";\n90: \n91: import { ensureFeaturesFile } from \"./lib/features.js\";\n92: import type { Priority, Difficulty, FeatureStatus } from \"./lib/features.js\";\n93: import { resolveOutputFormat, type OutputFormat } from \"./lib/output.js\";\n94: import { validateId, validateText, validateBranchName, validateDuration, assertValid } from \"./lib/validate.js\";\n95: import { findCommandDef, commandToSchema, allCommandSchemas } from \"./lib/schema.js\";\n96: \n97: // ---------------------------------------------------------------------------\n98: // Types\n99: // ---------------------------------------------------------------------------\n100: \n101: interface CLIArgs {\n102:   command: string;\n103:   subcommand?: string;\n104:   // Selection options (launch)\n105:   topPriority?: number;\n106:   quickestWins?: number;\n107:   priority?: Priority;\n108:   difficulty?: Difficulty;\n109:   features?: string[];\n110:   allReady?: boolean;\n111:   // Launch / runtime options\n112:   maxConcurrent?: number;\n113:   model?: string;\n114:   interactive: boolean;\n115:   dryRun: boolean;\n116:   baseBranch?: string;\n117:   maxRetries?: number;\n118:   noTui: boolean;\n119:   autoPush: boolean;\n120:   // General\n121:   featureId?: string;\n122:   force: boolean;\n123:   // Output format\n124:   outputFmt: OutputFormat;\n125:   // Upgrade options\n126:   checkOnly: boolean;\n127:   version?: string;\n128:   // Features subcommand extras\n129:   status?: string;\n130:   ready?: boolean;\n131:   includeArchive?: boolean;\n132:   title?: string;\n133:   description?: string;\n134:   effort?: string;\n135:   dependsOn?: string[];\n136:   // Compact output\n137:   fields?: string[];\n138:   // Graph options\n139:   ascii?: boolean;\n140:   mermaidRaw?: boolean;\n141:   graphSubtasks?: boolean;\n142: }\n143: \n144: // ---------------------------------------------------------------------------\n145: // Arg Parsing\n146: // ---------------------------------------------------------------------------\n147: \n148: function parseArgs(argv: string[]): CLIArgs {\n149:   const args = argv.slice(2); // skip 'bun' and script path\n150:   const result: CLIArgs = {\n151:     command: args[0] || \"help\",\n152:     interactive: false,\n153:     dryRun: false,\n154:     noTui: false,\n155:     autoPush: false,\n156:     force: false,\n157:     checkOnly: false,\n158:     outputFmt: resolveOutputFormat(undefined), // auto-detect until --output overrides\n159:   };\n160: \n161:   // If the first arg is \"features\", treat the second positional as the subcommand\n162:   let startIdx = 1;\n163:   if (result.command === \"features\") {\n164:     result.subcommand = args[1] || \"list\";\n165:     startIdx = 2;\n166:   }\n167: \n168:   for (let i = startIdx; i < args.length; i++) {\n169:     const arg = args[i];\n170:     switch (arg) {\n171:       // --- Selection options ---\n172:       case \"--top-priority\":\n173:         result.topPriority = parseInt(args[++i], 10);\n174:         break;\n175:       case \"--quickest-wins\":\n176:         result.quickestWins = parseInt(args[++i], 10);\n177:         break;\n178:       case \"--priority\":\n179:         result.priority = args[++i] as Priority;\n180:         break;\n181:       case \"--difficulty\":\n182:         result.difficulty = args[++i] as Difficulty;\n183:         break;\n184:       case \"--features\":\n185:         result.features = args[++i].split(\",\").map((s) => s.trim());\n186:         break;\n187:       case \"--all-ready\":\n188:         result.allReady = true;\n189:         break;\n190: \n191:       // --- Launch / runtime options ---\n192:       case \"--max-concurrent\":\n193:         result.maxConcurrent = parseInt(args[++i], 10);\n194:         break;\n195:       case \"--model\":\n196:       case \"-m\":\n197:         result.model = args[++i];\n198:         break;\n199:       case \"--interactive\":\n200:         result.interactive = true;\n201:         break;\n202:       case \"--dry-run\":\n203:         result.dryRun = true;\n204:         break;\n205:       case \"--no-tui\":\n206:         result.noTui = true;\n207:         break;\n208:       case \"--auto-push\":\n209:         result.autoPush = true;\n210:         break;\n211:       case \"--base-branch\":\n212:         result.baseBranch = args[++i];\n213:         break;\n214:       case \"--max-retries\":\n215:         result.maxRetries = parseInt(args[++i], 10);\n216:         break;\n217: \n218:       // --- General flags ---\n219:       case \"--force\":\n220:         result.force = true;\n221:         break;\n222:       case \"--check\":\n223:         result.checkOnly = true;\n224:         break;\n225:       case \"--version\":\n226:         result.version = args[++i];\n227:         break;\n228:       case \"--output\":\n229:       case \"-o\":\n230:         result.outputFmt = resolveOutputFormat(args[++i]);\n231:         break;\n232: \n233:       // --- Features subcommand options ---\n234:       case \"--status\":\n235:         result.status = args[++i];\n236:         break;\n237:       case \"--ready\":\n238:         result.ready = true;\n239:         break;\n240:       case \"--include-archive\":\n241:         result.includeArchive = true;\n242:         break;\n243:       case \"--title\":\n244:         result.title = args[++i];\n245:         break;\n246:       case \"--description\":\n247:       case \"--desc\":\n248:         result.description = args[++i];\n249:         break;\n250:       case \"--effort\":\n251:         result.effort = args[++i];\n252:         break;\n253:       case \"--depends-on\":\n254:         result.dependsOn = args[++i].split(\",\").map((s) => s.trim());\n255:         break;\n256:       case \"--fields\":\n257:         result.fields = args[++i].split(\",\").map((s) => s.trim());\n258:         break;\n259: \n260:       // --- Graph options ---\n261:       case \"--ascii\":\n262:         result.ascii = true;\n263:         break;\n264:       case \"--mermaid\":\n265:         result.mermaidRaw = true;\n266:         break;\n267:       case \"--subtasks\":\n268:         result.graphSubtasks = true;\n269:         break;\n270: \n271:       // --- Positional (feature-id, title for add, etc.) ---\n272:       default:\n273:         if (!arg.startsWith(\"-\")) {\n274:           if (!result.featureId) {\n275:             result.featureId = arg;\n276:           } else if (!result.title) {\n277:             result.title = arg;\n278:           }\n279:         }\n280:         break;\n281:     }\n282:   }\n283: \n284:   return result;\n285: }\n286: \n287: // ---------------------------------------------------------------------------\n288: // Help\n289: // ---------------------------------------------------------------------------\n290: \n291: function cmdHelp(): void {\n292:   console.log(`\n293: Wombo — AI Agent Orchestration System\n294: \n295:   WOMBO COMBO! Parallel feature development with AI agents.\n296: \n297: Commands:\n298:   init           Generate wombo.json config in the current project\n299:   launch         Launch a wave of agents to implement features\n300:   resume         Resume a previously stopped wave\n301:   status         Show the status of the current wave\n302:   verify         Run build verification on completed agents\n303:   merge          Merge verified branches into the base branch\n304:   retry          Retry a failed agent\n305:   cleanup        Remove all wave worktrees and tmux sessions\n306:   features       Manage .features.yml (see below)\n307:   upgrade        Check for updates and upgrade wombo\n308:   describe       Emit JSON schema of a command (for AI agents)\n309:   help           Show this help\n310: \n311: Features Subcommands:\n312:   features list            List features (--status, --priority, --difficulty, --ready, --include-archive)\n313:   features add <id> <title> [options]\n314:                            Add a new feature (--desc, --priority, --difficulty, --effort, --depends-on)\n315:   features set-status <id> <status>\n316:                            Change a feature's status\n317:   features check           Validate .features.yml (schema, deps, duplicates, cycles)\n318:   features archive [id]    Move done/cancelled to archive (--dry-run)\n319:   features show <id>       Show feature details\n320:   features graph           Visualize dependency graph (--ascii, --mermaid, --subtasks)\n321: \n322: Selection Options (for launch):\n323:   --top-priority N         Select top N features by priority\n324:   --quickest-wins N        Select N features with lowest effort\n325:   --priority <level>       Filter by priority (critical/high/medium/low/wishlist)\n326:   --difficulty <level>     Filter by difficulty (trivial/easy/medium/hard/very_hard)\n327:   --features \"id1,id2\"     Select specific features by ID\n328:   --all-ready              Select all features whose dependencies are met\n329: \n330: Launch Options:\n331:   --max-concurrent N       Max agents running in parallel (default: from config)\n332:   --model <model>          Model to use (e.g., \"anthropic/claude-sonnet-4-20250514\")\n333:   --interactive            Use tmux TUI mode instead of headless\n334:   --no-tui                 Headless mode without neo-blessed TUI (periodic console dashboard)\n335:   --auto-push              Push base branch to remote after all merges complete\n336:   --dry-run                Show what would be launched without launching\n337:   --base-branch <branch>   Base branch (default: from config)\n338:   --max-retries N          Max retries per agent (default: from config)\n339: \n340: General:\n341:   --version, -V            Print version and exit\n342:   --force                  Force overwrite (e.g., for init) / skip prompts (e.g., for upgrade)\n343:   --output <fmt>           Output format: text (default on TTY) or json (default when piped)\n344:   -o <fmt>                 Alias for --output\n345:   --dry-run                Show what would happen without performing the action\n346:   --fields <list>          Comma-separated fields to include (e.g., id,status,priority)\n347: \n348: Upgrade Options:\n349:   --check                  Only check for updates, don't install\n350:   --version <tag>          Install a specific version (e.g., v0.1.0)\n351: \n352: Examples:\n353:   wombo init\n354:   wombo launch --quickest-wins 3\n355:   wombo launch --priority high --interactive\n356:   wombo launch --features \"auth-flow,search-api\" --max-concurrent 2\n357:   wombo resume\n358:   wombo status\n359:   wombo verify\n360:   wombo merge\n361:   wombo retry auth-flow\n362:   wombo cleanup\n363:   wombo features list --status ready --priority high\n364:   wombo features list --fields id,status,priority --output json\n365:   wombo features add my-feature \"My Cool Feature\" --priority high --difficulty easy\n366:   wombo features set-status my-feature in-progress\n367:   wombo features check\n368:   wombo features archive --dry-run\n369:   wombo features show my-feature\n370:   wombo describe                           # list all commands as JSON\n371:   wombo describe launch                    # describe a specific command\n372:   wombo describe features add              # describe a subcommand\n373: `);\n374: }\n375: \n376: // ---------------------------------------------------------------------------\n377: // Main\n378: // ---------------------------------------------------------------------------\n379: \n380: async function main(): Promise<void> {\n381:   checkDevModeGuard();\n382: \n383:   const PROJECT_ROOT = resolve(process.cwd());\n384:   const args = parseArgs(process.argv);\n385: \n386:   // -----------------------------------------------------------------------\n387:   // Input validation at the CLI boundary\n388:   // -----------------------------------------------------------------------\n389:   if (args.featureId) {\n390:     assertValid(validateId(args.featureId, \"feature ID\"));\n391:   }\n392:   if (args.title) {\n393:     assertValid(validateText(args.title, \"title\"));\n394:   }\n395:   if (args.description) {\n396:     assertValid(validateText(args.description, \"description\"));\n397:   }\n398:   if (args.baseBranch) {\n399:     assertValid(validateBranchName(args.baseBranch, \"base branch\"));\n400:   }\n401:   if (args.effort) {\n402:     assertValid(validateDuration(args.effort, \"effort\"));\n403:   }\n404:   if (args.features) {\n405:     for (const fid of args.features) {\n406:       assertValid(validateId(fid, \"feature ID in --features\"));\n407:     }\n408:   }\n409:   if (args.dependsOn) {\n410:     for (const dep of args.dependsOn) {\n411:       assertValid(validateId(dep, \"dependency ID in --depends-on\"));\n412:     }\n413:   }\n414: \n415:   // Commands that don't need config loading\n416:   if (args.command === \"--version\" || args.command === \"-V\") {\n417:     const pkgPath = resolve(import.meta.dir, \"..\", \"package.json\");\n418:     try {\n419:       const raw = readFileSync(pkgPath, \"utf-8\");\n420:       const pkg = JSON.parse(raw);\n421:       console.log(`wombo ${pkg.version}`);\n422:     } catch {\n423:       console.log(\"wombo (unknown version)\");\n424:     }\n425:     return;\n426:   }\n427: \n428:   if (args.command === \"help\" || args.command === \"--help\" || args.command === \"-h\") {\n429:     cmdHelp();\n430:     return;\n431:   }\n432: \n433:   if (args.command === \"describe\") {\n434:     // Schema introspection: `wombo describe [command]`\n435:     if (!args.featureId) {\n436:       // No command specified — list all commands\n437:       console.log(JSON.stringify(allCommandSchemas(), null, 2));\n438:     } else {\n439:       // Describe a specific command. Handle compound names: \"features list\"\n440:       const cmdName = args.title\n441:         ? `${args.featureId} ${args.title}`\n442:         : args.featureId;\n443:       const def = findCommandDef(cmdName);\n444:       if (!def) {\n445:         console.error(`Unknown command: \"${cmdName}\"`);\n446:         console.error(\"Run 'wombo describe' to list all commands.\");\n447:         process.exit(1);\n448:         return;\n449:       }\n450:       console.log(JSON.stringify(commandToSchema(def), null, 2));\n451:     }\n452:     return;\n453:   }\n454: \n455:   if (args.command === \"init\") {\n456:     await cmdInit({ projectRoot: PROJECT_ROOT, force: args.force });\n457:     return;\n458:   }\n459: \n460:   if (args.command === \"upgrade\") {\n461:     await cmdUpgrade({\n462:       force: args.force,\n463:       version: args.version,\n464:       checkOnly: args.checkOnly,\n465:     });\n466:     return;\n467:   }\n468: \n469:   // Everything else requires config\n470:   const config = loadConfig(PROJECT_ROOT);\n471:   validateConfig(config);\n472: \n473:   // Commands that operate on the features file — ensure it exists first\n474:   const needsFeatures = new Set([\"launch\", \"resume\", \"verify\", \"retry\", \"features\"]);\n475:   if (needsFeatures.has(args.command)) {\n476:     await ensureFeaturesFile(PROJECT_ROOT, config);\n477:   }\n478: \n479:   switch (args.command) {\n480:     case \"launch\":\n481:       await cmdLaunch({\n482:         projectRoot: PROJECT_ROOT,\n483:         config,\n484:         topPriority: args.topPriority,\n485:         quickestWins: args.quickestWins,\n486:         priority: args.priority,\n487:         difficulty: args.difficulty,\n488:         features: args.features,\n489:         allReady: args.allReady,\n490:         maxConcurrent: args.maxConcurrent ?? config.defaults.maxConcurrent,\n491:         model: args.model,\n492:         interactive: args.interactive,\n493:         dryRun: args.dryRun,\n494:         baseBranch: args.baseBranch ?? config.baseBranch,\n495:         maxRetries: args.maxRetries ?? config.defaults.maxRetries,\n496:         noTui: args.noTui,\n497:         autoPush: args.autoPush,\n498:       });\n499:       break;\n500: \n501:     case \"resume\":\n502:       await cmdResume({\n503:         projectRoot: PROJECT_ROOT,\n504:         config,\n505:         maxConcurrent: args.maxConcurrent,\n506:         model: args.model,\n507:         interactive: args.interactive,\n508:         noTui: args.noTui,\n509:         autoPush: args.autoPush,\n510:         baseBranch: args.baseBranch,\n511:         maxRetries: args.maxRetries,\n512:       });\n513:       break;\n514: \n515:     case \"status\":\n516:       await cmdStatus({ projectRoot: PROJECT_ROOT, config });\n517:       break;\n518: \n519:     case \"verify\":\n520:       await cmdVerify({\n521:         projectRoot: PROJECT_ROOT,\n522:         config,\n523:         featureId: args.featureId,\n524:         model: args.model,\n525:         maxRetries: args.maxRetries,\n526:       });\n527:       break;\n528: \n529:     case \"merge\":\n530:       await cmdMerge({\n531:         projectRoot: PROJECT_ROOT,\n532:         config,\n533:         featureId: args.featureId,\n534:         autoPush: args.autoPush,\n535:         dryRun: args.dryRun,\n536:       });\n537:       break;\n538: \n539:     case \"retry\": {\n540:       if (!args.featureId) {\n541:         console.error(\"Usage: wombo retry <feature-id>\");\n542:         process.exit(1);\n543:         return;\n544:       }\n545:       await cmdRetry({\n546:         projectRoot: PROJECT_ROOT,\n547:         config,\n548:         featureId: args.featureId,\n549:         model: args.model,\n550:         interactive: args.interactive,\n551:         dryRun: args.dryRun,\n552:       });\n553:       break;\n554:     }\n555: \n556:     case \"cleanup\":\n557:       await cmdCleanup({ projectRoot: PROJECT_ROOT, config, dryRun: args.dryRun });\n558:       break;\n559: \n560:     case \"features\":\n561:       await handleFeaturesSubcommand(args, PROJECT_ROOT, config);\n562:       break;\n563: \n564:     default:\n565:       console.error(`Unknown command: ${args.command}`);\n566:       cmdHelp();\n567:       process.exit(1);\n568:       return;\n569:   }\n570: }\n571: \n572: // ---------------------------------------------------------------------------\n573: // Features Subcommand Router\n574: // ---------------------------------------------------------------------------\n575: \n576: async function handleFeaturesSubcommand(\n577:   args: CLIArgs,\n578:   projectRoot: string,\n579:   config: import(\"./config.js\").WomboConfig\n580: ): Promise<void> {\n581:   switch (args.subcommand) {\n582:     case \"list\":\n583:     case \"ls\":\n584:       await cmdFeaturesList({\n585:         projectRoot,\n586:         config,\n587:         status: args.status as FeatureStatus | undefined,\n588:         priority: args.priority,\n589:         difficulty: args.difficulty,\n590:         ready: args.ready,\n591:         includeArchive: args.includeArchive,\n592:         outputFmt: args.outputFmt,\n593:         fields: args.fields,\n594:       });\n595:       break;\n596: \n597:     case \"add\": {\n598:       if (!args.featureId || !args.title) {\n599:         console.error(\"Usage: wombo features add <id> <title> [--desc <desc>] [--priority <p>] [--difficulty <d>] [--effort <e>] [--depends-on <ids>]\");\n600:         process.exit(1);\n601:         return;\n602:       }\n603:       await cmdFeaturesAdd({\n604:         projectRoot,\n605:         config,\n606:         id: args.featureId,\n607:         title: args.title,\n608:         description: args.description,\n609:         priority: args.priority,\n610:         difficulty: args.difficulty,\n611:         effort: args.effort,\n612:         dependsOn: args.dependsOn,\n613:         outputFmt: args.outputFmt,\n614:         dryRun: args.dryRun,\n615:       });\n616:       break;\n617:     }\n618: \n619:     case \"set-status\": {\n620:       if (!args.featureId || !args.title) {\n621:         // title holds the second positional arg (the status value)\n622:         // If not provided via positional, check --status flag\n623:         const newStatus = args.title || args.status;\n624:         if (!args.featureId || !newStatus) {\n625:           console.error(\"Usage: wombo features set-status <feature-id> <status>\");\n626:           process.exit(1);\n627:           return;\n628:         }\n629:         await cmdFeaturesSetStatus({\n630:           projectRoot,\n631:           config,\n632:           featureId: args.featureId,\n633:           newStatus,\n634:           outputFmt: args.outputFmt,\n635:           dryRun: args.dryRun,\n636:         });\n637:       } else {\n638:         await cmdFeaturesSetStatus({\n639:           projectRoot,\n640:           config,\n641:           featureId: args.featureId,\n642:           newStatus: args.title, // second positional = new status\n643:           outputFmt: args.outputFmt,\n644:           dryRun: args.dryRun,\n645:         });\n646:       }\n647:       break;\n648:     }\n649: \n650:     case \"check\":\n651:     case \"validate\":\n652:       await cmdFeaturesCheck({ projectRoot, config });\n653:       break;\n654: \n655:     case \"archive\":\n656:       await cmdFeaturesArchive({\n657:         projectRoot,\n658:         config,\n659:         featureId: args.featureId,\n660:         dryRun: args.dryRun,\n661:       });\n662:       break;\n663: \n664:     case \"show\": {\n665:       if (!args.featureId) {\n666:         console.error(\"Usage: wombo features show <feature-id>\");\n667:         process.exit(1);\n668:         return;\n669:       }\n670:       await cmdFeaturesShow({\n671:         projectRoot,\n672:         config,\n673:         featureId: args.featureId,\n674:         outputFmt: args.outputFmt,\n675:         fields: args.fields,\n676:       });\n677:       break;\n678:     }\n679: \n680:     case \"graph\":\n681:       await cmdFeaturesGraph({\n682:         projectRoot,\n683:         config,\n684:         status: args.status as FeatureStatus | undefined,\n685:         ascii: args.ascii,\n686:         mermaid: args.mermaidRaw,\n687:         subtasks: args.graphSubtasks,\n688:         outputFmt: args.outputFmt,\n689:       });\n690:       break;\n691: \n692:     case \"help\":\n693:     case \"--help\":\n694:     case \"-h\":\n695:       cmdHelp();\n696:       break;\n697: \n698:     default:\n699:       console.error(`Unknown features subcommand: ${args.subcommand}`);\n700:       console.error(\"Run 'wombo features help' or 'wombo help' for usage.\");\n701:       process.exit(1);\n702:       return;\n703:   }\n704: }\n705: \n706: // ---------------------------------------------------------------------------\n707: // Error Handlers & Entry\n708: // ---------------------------------------------------------------------------\n709: \n710: // Global error handlers — prevent silent crashes\n711: process.on(\"uncaughtException\", (err) => {\n712:   console.error(`\\n[FATAL] Uncaught exception: ${err.message}`);\n713:   console.error(err.stack);\n714:   try {\n715:     const state = loadState(process.cwd());\n716:     if (state) saveState(process.cwd(), state);\n717:   } catch {}\n718:   process.exit(1);\n719: });\n720: \n721: process.on(\"unhandledRejection\", (reason: any) => {\n722:   console.error(`\\n[FATAL] Unhandled rejection: ${reason?.message || reason}`);\n723:   if (reason?.stack) console.error(reason.stack);\n724:   try {\n725:     const state = loadState(process.cwd());\n726:     if (state) saveState(process.cwd(), state);\n727:   } catch {}\n728:   process.exit(1);\n729: });\n730: \n731: main().catch((err) => {\n732:   console.error(\"Fatal error:\", err.message);\n733:   process.exit(1);\n734: });\n\n(End of file - total 734 lines)\n</content>","title":"src/index.ts","metadata":{"preview":"#!/usr/bin/env bun\n/**\n * index.ts — CLI entry point for the Wombo agent orchestration system.\n *\n * Usage:\n *   wombo init\n *   wombo launch --top-priority 3\n *   wombo launch --quickest-wins 5\n *   wombo launch --priority high\n *   wombo launch --difficulty easy\n *   wombo launch --features \"feat-a,feat-b\"\n *   wombo launch --all-ready\n *   wombo launch ... --max-concurrent 3 --model \"anthropic/claude-sonnet-4-20250514\"\n *   wombo launch ... --interactive\n *   wombo resume\n *   wombo status\n *   wombo verify [feature-id]\n *   wombo merge [feature-id]\n *   wombo retry <feature-id>\n *   wombo cleanup","truncated":false,"loaded":[]},"time":{"start":1773351513508,"end":1773351513517}}}}
{"type":"tool_use","timestamp":1773351513959,"sessionID":"ses_31c036d5affeENe71rAql6keLu","part":{"id":"prt_ce3fcada9001r1Biu0QZ052wLH","sessionID":"ses_31c036d5affeENe71rAql6keLu","messageID":"msg_ce3fc9371001nHMD3AkR8m3BgD","type":"tool","callID":"toolu_vrtx_01Ddshu1UhNMkNZgsX19rKph","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-status-json-output/src/lib/state.ts"},"output":"<path>/home/fulgidus/Documents/wombo-status-json-output/src/lib/state.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * state.ts — Persistent wave state management.\n3:  *\n4:  * Responsibilities:\n5:  *   - Define the shape of .wombo-state.json\n6:  *   - Read/write state atomically\n7:  *   - Generate wave IDs\n8:  *   - Update individual agent state within a wave\n9:  */\n10: \n11: import { readFileSync, writeFileSync, existsSync, renameSync } from \"node:fs\";\n12: import { resolve } from \"node:path\";\n13: \n14: // ---------------------------------------------------------------------------\n15: // Types\n16: // ---------------------------------------------------------------------------\n17: \n18: export type AgentStatus =\n19:   | \"queued\"\n20:   | \"installing\"\n21:   | \"running\"\n22:   | \"completed\"\n23:   | \"verified\"\n24:   | \"failed\"\n25:   | \"merged\"\n26:   | \"retry\"\n27:   | \"resolving_conflict\";\n28: \n29: export interface AgentState {\n30:   feature_id: string;\n31:   branch: string;\n32:   worktree: string;\n33:   session_id: string | null;\n34:   pid: number | null;\n35:   status: AgentStatus;\n36:   activity: string | null;\n37:   activity_updated_at: string | null;\n38:   retries: number;\n39:   max_retries: number;\n40:   started_at: string | null;\n41:   completed_at: string | null;\n42:   build_passed: boolean | null;\n43:   build_output: string | null;\n44:   error: string | null;\n45:   /** Estimated effort in milliseconds (from feature's ISO 8601 duration) */\n46:   effort_estimate_ms: number | null;\n47: }\n48: \n49: export interface WaveState {\n50:   wave_id: string;\n51:   base_branch: string;\n52:   started_at: string;\n53:   updated_at: string;\n54:   max_concurrent: number;\n55:   model: string | null;\n56:   interactive: boolean;\n57:   agents: AgentState[];\n58: }\n59: \n60: // ---------------------------------------------------------------------------\n61: // Constants\n62: // ---------------------------------------------------------------------------\n63: \n64: const STATE_FILE = \".wombo-state.json\";\n65: \n66: // ---------------------------------------------------------------------------\n67: // Wave ID Generation\n68: // ---------------------------------------------------------------------------\n69: \n70: /**\n71:  * Generate a unique wave ID based on current timestamp.\n72:  * Format: wave-YYYY-MM-DD-NNN\n73:  */\n74: export function generateWaveId(): string {\n75:   const now = new Date();\n76:   const date = now.toISOString().slice(0, 10);\n77:   const seq = String(now.getHours() * 60 + now.getMinutes()).padStart(3, \"0\");\n78:   return `wave-${date}-${seq}`;\n79: }\n80: \n81: // ---------------------------------------------------------------------------\n82: // State Path\n83: // ---------------------------------------------------------------------------\n84: \n85: function statePath(projectRoot: string): string {\n86:   return resolve(projectRoot, STATE_FILE);\n87: }\n88: \n89: // ---------------------------------------------------------------------------\n90: // Read State\n91: // ---------------------------------------------------------------------------\n92: \n93: /**\n94:  * Load the current wave state from disk. Returns null if no state file exists.\n95:  */\n96: export function loadState(projectRoot: string): WaveState | null {\n97:   const p = statePath(projectRoot);\n98:   if (!existsSync(p)) return null;\n99:   try {\n100:     const raw = readFileSync(p, \"utf-8\");\n101:     return JSON.parse(raw) as WaveState;\n102:   } catch {\n103:     return null;\n104:   }\n105: }\n106: \n107: // ---------------------------------------------------------------------------\n108: // Write State\n109: // ---------------------------------------------------------------------------\n110: \n111: /**\n112:  * Save wave state to disk atomically (write to tmp then rename).\n113:  */\n114: export function saveState(projectRoot: string, state: WaveState): void {\n115:   state.updated_at = new Date().toISOString();\n116:   const p = statePath(projectRoot);\n117:   const tmp = p + \".tmp\";\n118:   writeFileSync(tmp, JSON.stringify(state, null, 2) + \"\\n\", \"utf-8\");\n119:   renameSync(tmp, p);\n120: }\n121: \n122: // ---------------------------------------------------------------------------\n123: // State Mutations\n124: // ---------------------------------------------------------------------------\n125: \n126: /**\n127:  * Create a fresh wave state.\n128:  */\n129: export function createWaveState(opts: {\n130:   baseBranch: string;\n131:   maxConcurrent: number;\n132:   model: string | null;\n133:   interactive: boolean;\n134: }): WaveState {\n135:   return {\n136:     wave_id: generateWaveId(),\n137:     base_branch: opts.baseBranch,\n138:     started_at: new Date().toISOString(),\n139:     updated_at: new Date().toISOString(),\n140:     max_concurrent: opts.maxConcurrent,\n141:     model: opts.model,\n142:     interactive: opts.interactive,\n143:     agents: [],\n144:   };\n145: }\n146: \n147: /**\n148:  * Create an initial agent state for a feature.\n149:  */\n150: export function createAgentState(\n151:   featureId: string,\n152:   branch: string,\n153:   worktreePath: string,\n154:   maxRetries: number = 2\n155: ): AgentState {\n156:   return {\n157:     feature_id: featureId,\n158:     branch,\n159:     worktree: worktreePath,\n160:     session_id: null,\n161:     pid: null,\n162:     status: \"queued\",\n163:     activity: null,\n164:     activity_updated_at: null,\n165:     retries: 0,\n166:     max_retries: maxRetries,\n167:     started_at: null,\n168:     completed_at: null,\n169:     build_passed: null,\n170:     build_output: null,\n171:     error: null,\n172:     effort_estimate_ms: null,\n173:   };\n174: }\n175: \n176: /**\n177:  * Find an agent state by feature ID.\n178:  */\n179: export function getAgent(\n180:   state: WaveState,\n181:   featureId: string\n182: ): AgentState | undefined {\n183:   return state.agents.find((a) => a.feature_id === featureId);\n184: }\n185: \n186: /**\n187:  * Update an agent's state fields.\n188:  */\n189: export function updateAgent(\n190:   state: WaveState,\n191:   featureId: string,\n192:   updates: Partial<AgentState>\n193: ): void {\n194:   const agent = state.agents.find((a) => a.feature_id === featureId);\n195:   if (!agent) throw new Error(`Agent not found for feature: ${featureId}`);\n196:   Object.assign(agent, updates);\n197: }\n198: \n199: /**\n200:  * Get counts of agents by status.\n201:  */\n202: export function agentCounts(state: WaveState): Record<AgentStatus, number> {\n203:   const counts: Record<AgentStatus, number> = {\n204:     queued: 0,\n205:     installing: 0,\n206:     running: 0,\n207:     completed: 0,\n208:     verified: 0,\n209:     failed: 0,\n210:     merged: 0,\n211:     retry: 0,\n212:     resolving_conflict: 0,\n213:   };\n214:   for (const a of state.agents) {\n215:     counts[a.status]++;\n216:   }\n217:   return counts;\n218: }\n219: \n220: /**\n221:  * Get agents that are currently running or installing.\n222:  */\n223: export function activeAgents(state: WaveState): AgentState[] {\n224:   return state.agents.filter(\n225:     (a) => a.status === \"running\" || a.status === \"installing\" || a.status === \"resolving_conflict\"\n226:   );\n227: }\n228: \n229: /**\n230:  * Get agents that are queued and ready to be launched.\n231:  */\n232: export function queuedAgents(state: WaveState): AgentState[] {\n233:   return state.agents.filter((a) => a.status === \"queued\");\n234: }\n235: \n236: /**\n237:  * Check if the wave is fully complete (no queued, installing, running, or retry agents).\n238:  */\n239: export function isWaveComplete(state: WaveState): boolean {\n240:   return state.agents.every(\n241:     (a) =>\n242:       a.status === \"completed\" ||\n243:       a.status === \"verified\" ||\n244:       a.status === \"failed\" ||\n245:       a.status === \"merged\"\n246:   );\n247: }\n\n(End of file - total 247 lines)\n</content>","title":"src/lib/state.ts","metadata":{"preview":"/**\n * state.ts — Persistent wave state management.\n *\n * Responsibilities:\n *   - Define the shape of .wombo-state.json\n *   - Read/write state atomically\n *   - Generate wave IDs\n *   - Update individual agent state within a wave\n */\n\nimport { readFileSync, writeFileSync, existsSync, renameSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type AgentStatus =\n  | \"queued\"\n  | \"installing\"","truncated":false,"loaded":[]},"time":{"start":1773351513949,"end":1773351513958}}}}
