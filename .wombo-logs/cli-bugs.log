{"type":"tool_use","timestamp":1773351517196,"sessionID":"ses_31c036dcfffeZBZKwd7xzopNEA","part":{"id":"prt_ce3fcb952001JmT6Gtoz10NDHX","sessionID":"ses_31c036dcfffeZBZKwd7xzopNEA","messageID":"msg_ce3fcb02e001Jua2912S4gYIxa","type":"tool","callID":"toolu_vrtx_01BVuUSD1WJxcLxUhfXuSD2p","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-cli-bugs/src/index.ts"},"output":"<path>/home/fulgidus/Documents/wombo-cli-bugs/src/index.ts</path>\n<type>file</type>\n<content>1: #!/usr/bin/env bun\n2: /**\n3:  * index.ts — CLI entry point for the Wombo agent orchestration system.\n4:  *\n5:  * Usage:\n6:  *   wombo init\n7:  *   wombo launch --top-priority 3\n8:  *   wombo launch --quickest-wins 5\n9:  *   wombo launch --priority high\n10:  *   wombo launch --difficulty easy\n11:  *   wombo launch --features \"feat-a,feat-b\"\n12:  *   wombo launch --all-ready\n13:  *   wombo launch ... --max-concurrent 3 --model \"anthropic/claude-sonnet-4-20250514\"\n14:  *   wombo launch ... --interactive\n15:  *   wombo resume\n16:  *   wombo status\n17:  *   wombo verify [feature-id]\n18:  *   wombo merge [feature-id]\n19:  *   wombo retry <feature-id>\n20:  *   wombo cleanup\n21:  *   wombo features list [--status <s>] [--priority <p>] [--difficulty <d>] [--ready] [--include-archive]\n22:  *   wombo features add <id> <title> [options]\n23:  *   wombo features set-status <feature-id> <status>\n24:  *   wombo features check\n25:  *   wombo features archive [feature-id] [--dry-run]\n26:  *   wombo features show <feature-id>\n27:  *   wombo features graph [--ascii] [--mermaid] [--subtasks] [--status <s>]\n28:  *   wombo help\n29:  *   wombo --version\n30:  */\n31: \n32: import { resolve } from \"node:path\";\n33: import { existsSync, readFileSync } from \"node:fs\";\n34: import { loadConfig, validateConfig } from \"./config.js\";\n35: import { loadState, saveState } from \"./lib/state.js\";\n36: \n37: // ---------------------------------------------------------------------------\n38: // Dev-mode guard: warn if running the global binary inside the wombo repo\n39: // ---------------------------------------------------------------------------\n40: \n41: function checkDevModeGuard(): void {\n42:   const cwd = process.cwd();\n43:   const pkgPath = resolve(cwd, \"package.json\");\n44: \n45:   // Are we inside the wombo repo?\n46:   if (!existsSync(pkgPath)) return;\n47: \n48:   let pkgName: string | undefined;\n49:   try {\n50:     const raw = readFileSync(pkgPath, \"utf-8\");\n51:     pkgName = JSON.parse(raw).name;\n52:   } catch {\n53:     return;\n54:   }\n55:   if (pkgName !== \"wombo\") return;\n56: \n57:   // We're in the wombo repo. Is the source being run from a different location?\n58:   // import.meta.dir = directory of THIS file (index.ts). If it's under cwd,\n59:   // we're running local source (bun dev). If it's elsewhere (e.g. ~/.bun/install),\n60:   // we're running the globally installed binary.\n61:   const sourceDir = resolve(import.meta.dir);\n62:   const projectSrc = resolve(cwd, \"src\");\n63: \n64:   if (!sourceDir.startsWith(projectSrc)) {\n65:     console.warn(\n66:       \"\\x1b[33m[WARNING]\\x1b[0m You are running the globally installed wombo binary \" +\n67:       \"inside the wombo repo.\\n\" +\n68:       \"  Use \\x1b[1mbun dev <command>\\x1b[0m instead to run from local source.\\n\" +\n69:       \"  See AGENTS.md for details.\\n\"\n70:     );\n71:   }\n72: }\n73: \n74: import { cmdInit } from \"./commands/init.js\";\n75: import { cmdLaunch } from \"./commands/launch.js\";\n76: import { cmdResume } from \"./commands/resume.js\";\n77: import { cmdStatus } from \"./commands/status.js\";\n78: import { cmdVerify } from \"./commands/verify.js\";\n79: import { cmdMerge } from \"./commands/merge.js\";\n80: import { cmdRetry } from \"./commands/retry.js\";\n81: import { cmdCleanup } from \"./commands/cleanup.js\";\n82: import { cmdUpgrade } from \"./commands/upgrade.js\";\n83: import { cmdFeaturesList } from \"./commands/features/list.js\";\n84: import { cmdFeaturesAdd } from \"./commands/features/add.js\";\n85: import { cmdFeaturesSetStatus } from \"./commands/features/set-status.js\";\n86: import { cmdFeaturesCheck } from \"./commands/features/check.js\";\n87: import { cmdFeaturesArchive } from \"./commands/features/archive.js\";\n88: import { cmdFeaturesShow } from \"./commands/features/show.js\";\n89: import { cmdFeaturesGraph } from \"./commands/features/graph.js\";\n90: \n91: import { ensureFeaturesFile } from \"./lib/features.js\";\n92: import type { Priority, Difficulty, FeatureStatus } from \"./lib/features.js\";\n93: import { resolveOutputFormat, type OutputFormat } from \"./lib/output.js\";\n94: import { validateId, validateText, validateBranchName, validateDuration, assertValid } from \"./lib/validate.js\";\n95: import { findCommandDef, commandToSchema, allCommandSchemas } from \"./lib/schema.js\";\n96: \n97: // ---------------------------------------------------------------------------\n98: // Types\n99: // ---------------------------------------------------------------------------\n100: \n101: interface CLIArgs {\n102:   command: string;\n103:   subcommand?: string;\n104:   // Selection options (launch)\n105:   topPriority?: number;\n106:   quickestWins?: number;\n107:   priority?: Priority;\n108:   difficulty?: Difficulty;\n109:   features?: string[];\n110:   allReady?: boolean;\n111:   // Launch / runtime options\n112:   maxConcurrent?: number;\n113:   model?: string;\n114:   interactive: boolean;\n115:   dryRun: boolean;\n116:   baseBranch?: string;\n117:   maxRetries?: number;\n118:   noTui: boolean;\n119:   autoPush: boolean;\n120:   // General\n121:   featureId?: string;\n122:   force: boolean;\n123:   // Output format\n124:   outputFmt: OutputFormat;\n125:   // Upgrade options\n126:   checkOnly: boolean;\n127:   version?: string;\n128:   // Features subcommand extras\n129:   status?: string;\n130:   ready?: boolean;\n131:   includeArchive?: boolean;\n132:   title?: string;\n133:   description?: string;\n134:   effort?: string;\n135:   dependsOn?: string[];\n136:   // Compact output\n137:   fields?: string[];\n138:   // Graph options\n139:   ascii?: boolean;\n140:   mermaidRaw?: boolean;\n141:   graphSubtasks?: boolean;\n142: }\n143: \n144: // ---------------------------------------------------------------------------\n145: // Arg Parsing\n146: // ---------------------------------------------------------------------------\n147: \n148: function parseArgs(argv: string[]): CLIArgs {\n149:   const args = argv.slice(2); // skip 'bun' and script path\n150:   const result: CLIArgs = {\n151:     command: args[0] || \"help\",\n152:     interactive: false,\n153:     dryRun: false,\n154:     noTui: false,\n155:     autoPush: false,\n156:     force: false,\n157:     checkOnly: false,\n158:     outputFmt: resolveOutputFormat(undefined), // auto-detect until --output overrides\n159:   };\n160: \n161:   // If the first arg is \"features\", treat the second positional as the subcommand\n162:   let startIdx = 1;\n163:   if (result.command === \"features\") {\n164:     result.subcommand = args[1] || \"list\";\n165:     startIdx = 2;\n166:   }\n167: \n168:   for (let i = startIdx; i < args.length; i++) {\n169:     const arg = args[i];\n170:     switch (arg) {\n171:       // --- Selection options ---\n172:       case \"--top-priority\":\n173:         result.topPriority = parseInt(args[++i], 10);\n174:         break;\n175:       case \"--quickest-wins\":\n176:         result.quickestWins = parseInt(args[++i], 10);\n177:         break;\n178:       case \"--priority\":\n179:         result.priority = args[++i] as Priority;\n180:         break;\n181:       case \"--difficulty\":\n182:         result.difficulty = args[++i] as Difficulty;\n183:         break;\n184:       case \"--features\":\n185:         result.features = args[++i].split(\",\").map((s) => s.trim());\n186:         break;\n187:       case \"--all-ready\":\n188:         result.allReady = true;\n189:         break;\n190: \n191:       // --- Launch / runtime options ---\n192:       case \"--max-concurrent\":\n193:         result.maxConcurrent = parseInt(args[++i], 10);\n194:         break;\n195:       case \"--model\":\n196:       case \"-m\":\n197:         result.model = args[++i];\n198:         break;\n199:       case \"--interactive\":\n200:         result.interactive = true;\n201:         break;\n202:       case \"--dry-run\":\n203:         result.dryRun = true;\n204:         break;\n205:       case \"--no-tui\":\n206:         result.noTui = true;\n207:         break;\n208:       case \"--auto-push\":\n209:         result.autoPush = true;\n210:         break;\n211:       case \"--base-branch\":\n212:         result.baseBranch = args[++i];\n213:         break;\n214:       case \"--max-retries\":\n215:         result.maxRetries = parseInt(args[++i], 10);\n216:         break;\n217: \n218:       // --- General flags ---\n219:       case \"--force\":\n220:         result.force = true;\n221:         break;\n222:       case \"--check\":\n223:         result.checkOnly = true;\n224:         break;\n225:       case \"--version\":\n226:         result.version = args[++i];\n227:         break;\n228:       case \"--output\":\n229:       case \"-o\":\n230:         result.outputFmt = resolveOutputFormat(args[++i]);\n231:         break;\n232: \n233:       // --- Features subcommand options ---\n234:       case \"--status\":\n235:         result.status = args[++i];\n236:         break;\n237:       case \"--ready\":\n238:         result.ready = true;\n239:         break;\n240:       case \"--include-archive\":\n241:         result.includeArchive = true;\n242:         break;\n243:       case \"--title\":\n244:         result.title = args[++i];\n245:         break;\n246:       case \"--description\":\n247:       case \"--desc\":\n248:         result.description = args[++i];\n249:         break;\n250:       case \"--effort\":\n251:         result.effort = args[++i];\n252:         break;\n253:       case \"--depends-on\":\n254:         result.dependsOn = args[++i].split(\",\").map((s) => s.trim());\n255:         break;\n256:       case \"--fields\":\n257:         result.fields = args[++i].split(\",\").map((s) => s.trim());\n258:         break;\n259: \n260:       // --- Graph options ---\n261:       case \"--ascii\":\n262:         result.ascii = true;\n263:         break;\n264:       case \"--mermaid\":\n265:         result.mermaidRaw = true;\n266:         break;\n267:       case \"--subtasks\":\n268:         result.graphSubtasks = true;\n269:         break;\n270: \n271:       // --- Positional (feature-id, title for add, etc.) ---\n272:       default:\n273:         if (!arg.startsWith(\"-\")) {\n274:           if (!result.featureId) {\n275:             result.featureId = arg;\n276:           } else if (!result.title) {\n277:             result.title = arg;\n278:           }\n279:         }\n280:         break;\n281:     }\n282:   }\n283: \n284:   return result;\n285: }\n286: \n287: // ---------------------------------------------------------------------------\n288: // Help\n289: // ---------------------------------------------------------------------------\n290: \n291: function cmdHelp(): void {\n292:   console.log(`\n293: Wombo — AI Agent Orchestration System\n294: \n295:   WOMBO COMBO! Parallel feature development with AI agents.\n296: \n297: Commands:\n298:   init           Generate wombo.json config in the current project\n299:   launch         Launch a wave of agents to implement features\n300:   resume         Resume a previously stopped wave\n301:   status         Show the status of the current wave\n302:   verify         Run build verification on completed agents\n303:   merge          Merge verified branches into the base branch\n304:   retry          Retry a failed agent\n305:   cleanup        Remove all wave worktrees and tmux sessions\n306:   features       Manage .features.yml (see below)\n307:   upgrade        Check for updates and upgrade wombo\n308:   describe       Emit JSON schema of a command (for AI agents)\n309:   help           Show this help\n310: \n311: Features Subcommands:\n312:   features list            List features (--status, --priority, --difficulty, --ready, --include-archive)\n313:   features add <id> <title> [options]\n314:                            Add a new feature (--desc, --priority, --difficulty, --effort, --depends-on)\n315:   features set-status <id> <status>\n316:                            Change a feature's status\n317:   features check           Validate .features.yml (schema, deps, duplicates, cycles)\n318:   features archive [id]    Move done/cancelled to archive (--dry-run)\n319:   features show <id>       Show feature details\n320:   features graph           Visualize dependency graph (--ascii, --mermaid, --subtasks)\n321: \n322: Selection Options (for launch):\n323:   --top-priority N         Select top N features by priority\n324:   --quickest-wins N        Select N features with lowest effort\n325:   --priority <level>       Filter by priority (critical/high/medium/low/wishlist)\n326:   --difficulty <level>     Filter by difficulty (trivial/easy/medium/hard/very_hard)\n327:   --features \"id1,id2\"     Select specific features by ID\n328:   --all-ready              Select all features whose dependencies are met\n329: \n330: Launch Options:\n331:   --max-concurrent N       Max agents running in parallel (default: from config)\n332:   --model <model>          Model to use (e.g., \"anthropic/claude-sonnet-4-20250514\")\n333:   --interactive            Use tmux TUI mode instead of headless\n334:   --no-tui                 Headless mode without neo-blessed TUI (periodic console dashboard)\n335:   --auto-push              Push base branch to remote after all merges complete\n336:   --dry-run                Show what would be launched without launching\n337:   --base-branch <branch>   Base branch (default: from config)\n338:   --max-retries N          Max retries per agent (default: from config)\n339: \n340: General:\n341:   --version, -V            Print version and exit\n342:   --force                  Force overwrite (e.g., for init) / skip prompts (e.g., for upgrade)\n343:   --output <fmt>           Output format: text (default on TTY) or json (default when piped)\n344:   -o <fmt>                 Alias for --output\n345:   --dry-run                Show what would happen without performing the action\n346:   --fields <list>          Comma-separated fields to include (e.g., id,status,priority)\n347: \n348: Upgrade Options:\n349:   --check                  Only check for updates, don't install\n350:   --version <tag>          Install a specific version (e.g., v0.1.0)\n351: \n352: Examples:\n353:   wombo init\n354:   wombo launch --quickest-wins 3\n355:   wombo launch --priority high --interactive\n356:   wombo launch --features \"auth-flow,search-api\" --max-concurrent 2\n357:   wombo resume\n358:   wombo status\n359:   wombo verify\n360:   wombo merge\n361:   wombo retry auth-flow\n362:   wombo cleanup\n363:   wombo features list --status ready --priority high\n364:   wombo features list --fields id,status,priority --output json\n365:   wombo features add my-feature \"My Cool Feature\" --priority high --difficulty easy\n366:   wombo features set-status my-feature in-progress\n367:   wombo features check\n368:   wombo features archive --dry-run\n369:   wombo features show my-feature\n370:   wombo describe                           # list all commands as JSON\n371:   wombo describe launch                    # describe a specific command\n372:   wombo describe features add              # describe a subcommand\n373: `);\n374: }\n375: \n376: // ---------------------------------------------------------------------------\n377: // Main\n378: // ---------------------------------------------------------------------------\n379: \n380: async function main(): Promise<void> {\n381:   checkDevModeGuard();\n382: \n383:   const PROJECT_ROOT = resolve(process.cwd());\n384:   const args = parseArgs(process.argv);\n385: \n386:   // -----------------------------------------------------------------------\n387:   // Input validation at the CLI boundary\n388:   // -----------------------------------------------------------------------\n389:   if (args.featureId) {\n390:     assertValid(validateId(args.featureId, \"feature ID\"));\n391:   }\n392:   if (args.title) {\n393:     assertValid(validateText(args.title, \"title\"));\n394:   }\n395:   if (args.description) {\n396:     assertValid(validateText(args.description, \"description\"));\n397:   }\n398:   if (args.baseBranch) {\n399:     assertValid(validateBranchName(args.baseBranch, \"base branch\"));\n400:   }\n401:   if (args.effort) {\n402:     assertValid(validateDuration(args.effort, \"effort\"));\n403:   }\n404:   if (args.features) {\n405:     for (const fid of args.features) {\n406:       assertValid(validateId(fid, \"feature ID in --features\"));\n407:     }\n408:   }\n409:   if (args.dependsOn) {\n410:     for (const dep of args.dependsOn) {\n411:       assertValid(validateId(dep, \"dependency ID in --depends-on\"));\n412:     }\n413:   }\n414: \n415:   // Commands that don't need config loading\n416:   if (args.command === \"--version\" || args.command === \"-V\") {\n417:     const pkgPath = resolve(import.meta.dir, \"..\", \"package.json\");\n418:     try {\n419:       const raw = readFileSync(pkgPath, \"utf-8\");\n420:       const pkg = JSON.parse(raw);\n421:       console.log(`wombo ${pkg.version}`);\n422:     } catch {\n423:       console.log(\"wombo (unknown version)\");\n424:     }\n425:     return;\n426:   }\n427: \n428:   if (args.command === \"help\" || args.command === \"--help\" || args.command === \"-h\") {\n429:     cmdHelp();\n430:     return;\n431:   }\n432: \n433:   if (args.command === \"describe\") {\n434:     // Schema introspection: `wombo describe [command]`\n435:     if (!args.featureId) {\n436:       // No command specified — list all commands\n437:       console.log(JSON.stringify(allCommandSchemas(), null, 2));\n438:     } else {\n439:       // Describe a specific command. Handle compound names: \"features list\"\n440:       const cmdName = args.title\n441:         ? `${args.featureId} ${args.title}`\n442:         : args.featureId;\n443:       const def = findCommandDef(cmdName);\n444:       if (!def) {\n445:         console.error(`Unknown command: \"${cmdName}\"`);\n446:         console.error(\"Run 'wombo describe' to list all commands.\");\n447:         process.exit(1);\n448:         return;\n449:       }\n450:       console.log(JSON.stringify(commandToSchema(def), null, 2));\n451:     }\n452:     return;\n453:   }\n454: \n455:   if (args.command === \"init\") {\n456:     await cmdInit({ projectRoot: PROJECT_ROOT, force: args.force });\n457:     return;\n458:   }\n459: \n460:   if (args.command === \"upgrade\") {\n461:     await cmdUpgrade({\n462:       force: args.force,\n463:       version: args.version,\n464:       checkOnly: args.checkOnly,\n465:     });\n466:     return;\n467:   }\n468: \n469:   // Everything else requires config\n470:   const config = loadConfig(PROJECT_ROOT);\n471:   validateConfig(config);\n472: \n473:   // Commands that operate on the features file — ensure it exists first\n474:   const needsFeatures = new Set([\"launch\", \"resume\", \"verify\", \"retry\", \"features\"]);\n475:   if (needsFeatures.has(args.command)) {\n476:     await ensureFeaturesFile(PROJECT_ROOT, config);\n477:   }\n478: \n479:   switch (args.command) {\n480:     case \"launch\":\n481:       await cmdLaunch({\n482:         projectRoot: PROJECT_ROOT,\n483:         config,\n484:         topPriority: args.topPriority,\n485:         quickestWins: args.quickestWins,\n486:         priority: args.priority,\n487:         difficulty: args.difficulty,\n488:         features: args.features,\n489:         allReady: args.allReady,\n490:         maxConcurrent: args.maxConcurrent ?? config.defaults.maxConcurrent,\n491:         model: args.model,\n492:         interactive: args.interactive,\n493:         dryRun: args.dryRun,\n494:         baseBranch: args.baseBranch ?? config.baseBranch,\n495:         maxRetries: args.maxRetries ?? config.defaults.maxRetries,\n496:         noTui: args.noTui,\n497:         autoPush: args.autoPush,\n498:       });\n499:       break;\n500: \n501:     case \"resume\":\n502:       await cmdResume({\n503:         projectRoot: PROJECT_ROOT,\n504:         config,\n505:         maxConcurrent: args.maxConcurrent,\n506:         model: args.model,\n507:         interactive: args.interactive,\n508:         noTui: args.noTui,\n509:         autoPush: args.autoPush,\n510:         baseBranch: args.baseBranch,\n511:         maxRetries: args.maxRetries,\n512:       });\n513:       break;\n514: \n515:     case \"status\":\n516:       await cmdStatus({ projectRoot: PROJECT_ROOT, config });\n517:       break;\n518: \n519:     case \"verify\":\n520:       await cmdVerify({\n521:         projectRoot: PROJECT_ROOT,\n522:         config,\n523:         featureId: args.featureId,\n524:         model: args.model,\n525:         maxRetries: args.maxRetries,\n526:       });\n527:       break;\n528: \n529:     case \"merge\":\n530:       await cmdMerge({\n531:         projectRoot: PROJECT_ROOT,\n532:         config,\n533:         featureId: args.featureId,\n534:         autoPush: args.autoPush,\n535:         dryRun: args.dryRun,\n536:       });\n537:       break;\n538: \n539:     case \"retry\": {\n540:       if (!args.featureId) {\n541:         console.error(\"Usage: wombo retry <feature-id>\");\n542:         process.exit(1);\n543:         return;\n544:       }\n545:       await cmdRetry({\n546:         projectRoot: PROJECT_ROOT,\n547:         config,\n548:         featureId: args.featureId,\n549:         model: args.model,\n550:         interactive: args.interactive,\n551:         dryRun: args.dryRun,\n552:       });\n553:       break;\n554:     }\n555: \n556:     case \"cleanup\":\n557:       await cmdCleanup({ projectRoot: PROJECT_ROOT, config, dryRun: args.dryRun });\n558:       break;\n559: \n560:     case \"features\":\n561:       await handleFeaturesSubcommand(args, PROJECT_ROOT, config);\n562:       break;\n563: \n564:     default:\n565:       console.error(`Unknown command: ${args.command}`);\n566:       cmdHelp();\n567:       process.exit(1);\n568:       return;\n569:   }\n570: }\n571: \n572: // ---------------------------------------------------------------------------\n573: // Features Subcommand Router\n574: // ---------------------------------------------------------------------------\n575: \n576: async function handleFeaturesSubcommand(\n577:   args: CLIArgs,\n578:   projectRoot: string,\n579:   config: import(\"./config.js\").WomboConfig\n580: ): Promise<void> {\n581:   switch (args.subcommand) {\n582:     case \"list\":\n583:     case \"ls\":\n584:       await cmdFeaturesList({\n585:         projectRoot,\n586:         config,\n587:         status: args.status as FeatureStatus | undefined,\n588:         priority: args.priority,\n589:         difficulty: args.difficulty,\n590:         ready: args.ready,\n591:         includeArchive: args.includeArchive,\n592:         outputFmt: args.outputFmt,\n593:         fields: args.fields,\n594:       });\n595:       break;\n596: \n597:     case \"add\": {\n598:       if (!args.featureId || !args.title) {\n599:         console.error(\"Usage: wombo features add <id> <title> [--desc <desc>] [--priority <p>] [--difficulty <d>] [--effort <e>] [--depends-on <ids>]\");\n600:         process.exit(1);\n601:         return;\n602:       }\n603:       await cmdFeaturesAdd({\n604:         projectRoot,\n605:         config,\n606:         id: args.featureId,\n607:         title: args.title,\n608:         description: args.description,\n609:         priority: args.priority,\n610:         difficulty: args.difficulty,\n611:         effort: args.effort,\n612:         dependsOn: args.dependsOn,\n613:         outputFmt: args.outputFmt,\n614:         dryRun: args.dryRun,\n615:       });\n616:       break;\n617:     }\n618: \n619:     case \"set-status\": {\n620:       if (!args.featureId || !args.title) {\n621:         // title holds the second positional arg (the status value)\n622:         // If not provided via positional, check --status flag\n623:         const newStatus = args.title || args.status;\n624:         if (!args.featureId || !newStatus) {\n625:           console.error(\"Usage: wombo features set-status <feature-id> <status>\");\n626:           process.exit(1);\n627:           return;\n628:         }\n629:         await cmdFeaturesSetStatus({\n630:           projectRoot,\n631:           config,\n632:           featureId: args.featureId,\n633:           newStatus,\n634:           outputFmt: args.outputFmt,\n635:           dryRun: args.dryRun,\n636:         });\n637:       } else {\n638:         await cmdFeaturesSetStatus({\n639:           projectRoot,\n640:           config,\n641:           featureId: args.featureId,\n642:           newStatus: args.title, // second positional = new status\n643:           outputFmt: args.outputFmt,\n644:           dryRun: args.dryRun,\n645:         });\n646:       }\n647:       break;\n648:     }\n649: \n650:     case \"check\":\n651:     case \"validate\":\n652:       await cmdFeaturesCheck({ projectRoot, config });\n653:       break;\n654: \n655:     case \"archive\":\n656:       await cmdFeaturesArchive({\n657:         projectRoot,\n658:         config,\n659:         featureId: args.featureId,\n660:         dryRun: args.dryRun,\n661:       });\n662:       break;\n663: \n664:     case \"show\": {\n665:       if (!args.featureId) {\n666:         console.error(\"Usage: wombo features show <feature-id>\");\n667:         process.exit(1);\n668:         return;\n669:       }\n670:       await cmdFeaturesShow({\n671:         projectRoot,\n672:         config,\n673:         featureId: args.featureId,\n674:         outputFmt: args.outputFmt,\n675:         fields: args.fields,\n676:       });\n677:       break;\n678:     }\n679: \n680:     case \"graph\":\n681:       await cmdFeaturesGraph({\n682:         projectRoot,\n683:         config,\n684:         status: args.status as FeatureStatus | undefined,\n685:         ascii: args.ascii,\n686:         mermaid: args.mermaidRaw,\n687:         subtasks: args.graphSubtasks,\n688:         outputFmt: args.outputFmt,\n689:       });\n690:       break;\n691: \n692:     case \"help\":\n693:     case \"--help\":\n694:     case \"-h\":\n695:       cmdHelp();\n696:       break;\n697: \n698:     default:\n699:       console.error(`Unknown features subcommand: ${args.subcommand}`);\n700:       console.error(\"Run 'wombo features help' or 'wombo help' for usage.\");\n701:       process.exit(1);\n702:       return;\n703:   }\n704: }\n705: \n706: // ---------------------------------------------------------------------------\n707: // Error Handlers & Entry\n708: // ---------------------------------------------------------------------------\n709: \n710: // Global error handlers — prevent silent crashes\n711: process.on(\"uncaughtException\", (err) => {\n712:   console.error(`\\n[FATAL] Uncaught exception: ${err.message}`);\n713:   console.error(err.stack);\n714:   try {\n715:     const state = loadState(process.cwd());\n716:     if (state) saveState(process.cwd(), state);\n717:   } catch {}\n718:   process.exit(1);\n719: });\n720: \n721: process.on(\"unhandledRejection\", (reason: any) => {\n722:   console.error(`\\n[FATAL] Unhandled rejection: ${reason?.message || reason}`);\n723:   if (reason?.stack) console.error(reason.stack);\n724:   try {\n725:     const state = loadState(process.cwd());\n726:     if (state) saveState(process.cwd(), state);\n727:   } catch {}\n728:   process.exit(1);\n729: });\n730: \n731: main().catch((err) => {\n732:   console.error(\"Fatal error:\", err.message);\n733:   process.exit(1);\n734: });\n\n(End of file - total 734 lines)\n</content>","title":"src/index.ts","metadata":{"preview":"#!/usr/bin/env bun\n/**\n * index.ts — CLI entry point for the Wombo agent orchestration system.\n *\n * Usage:\n *   wombo init\n *   wombo launch --top-priority 3\n *   wombo launch --quickest-wins 5\n *   wombo launch --priority high\n *   wombo launch --difficulty easy\n *   wombo launch --features \"feat-a,feat-b\"\n *   wombo launch --all-ready\n *   wombo launch ... --max-concurrent 3 --model \"anthropic/claude-sonnet-4-20250514\"\n *   wombo launch ... --interactive\n *   wombo resume\n *   wombo status\n *   wombo verify [feature-id]\n *   wombo merge [feature-id]\n *   wombo retry <feature-id>\n *   wombo cleanup","truncated":false,"loaded":[]},"time":{"start":1773351517188,"end":1773351517194}}}}
{"type":"tool_use","timestamp":1773351517816,"sessionID":"ses_31c036dcfffeZBZKwd7xzopNEA","part":{"id":"prt_ce3fcbc05001opTsCCoKNwgnP5","sessionID":"ses_31c036dcfffeZBZKwd7xzopNEA","messageID":"msg_ce3fcb02e001Jua2912S4gYIxa","type":"tool","callID":"toolu_vrtx_01NwuPYWLjwCG2KFc1bQDygK","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-cli-bugs/src/commands/features/add.ts"},"output":"<path>/home/fulgidus/Documents/wombo-cli-bugs/src/commands/features/add.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * features/add.ts — Add a new feature to the features file.\n3:  *\n4:  * Usage:\n5:  *   wombo features add <id> --title \"Feature Title\" [--description \"...\"]\n6:  *                      [--priority medium] [--difficulty easy] [--effort PT2H]\n7:  *                      [--depends-on \"feat1,feat2\"]\n8:  */\n9: \n10: import type { WomboConfig } from \"../../config.js\";\n11: import {\n12:   loadFeatures,\n13:   saveFeatures,\n14:   createBlankFeature,\n15:   allFeatureIds,\n16:   type Priority,\n17:   type Difficulty,\n18: } from \"../../lib/features.js\";\n19: import { outputError, outputMessage, type OutputFormat } from \"../../lib/output.js\";\n20: \n21: // ---------------------------------------------------------------------------\n22: // Types\n23: // ---------------------------------------------------------------------------\n24: \n25: export interface FeaturesAddOptions {\n26:   projectRoot: string;\n27:   config: WomboConfig;\n28:   id: string;\n29:   title: string;\n30:   description?: string;\n31:   priority?: Priority;\n32:   difficulty?: Difficulty;\n33:   effort?: string;\n34:   dependsOn?: string[];\n35:   outputFmt?: OutputFormat;\n36:   dryRun?: boolean;\n37: }\n38: \n39: // ---------------------------------------------------------------------------\n40: // Command\n41: // ---------------------------------------------------------------------------\n42: \n43: export async function cmdFeaturesAdd(opts: FeaturesAddOptions): Promise<void> {\n44:   const { projectRoot, config } = opts;\n45:   const fmt = opts.outputFmt ?? \"text\";\n46: \n47:   if (!opts.id) {\n48:     outputError(fmt, \"Usage: wombo features add <id> --title \\\"Feature Title\\\"\");\n49:     return;\n50:   }\n51: \n52:   if (!opts.title) {\n53:     outputError(fmt, \"--title is required when adding a feature.\");\n54:     return;\n55:   }\n56: \n57:   const data = loadFeatures(projectRoot, config);\n58: \n59:   // Check for duplicate ID\n60:   const existingIds = allFeatureIds(data);\n61:   if (existingIds.includes(opts.id)) {\n62:     outputError(fmt, `Feature ID \"${opts.id}\" already exists.`);\n63:     return;\n64:   }\n65: \n66:   // Validate depends_on references\n67:   if (opts.dependsOn?.length) {\n68:     for (const dep of opts.dependsOn) {\n69:       if (!existingIds.includes(dep)) {\n70:         outputError(fmt, `Dependency \"${dep}\" does not exist in the features file.`);\n71:         return;\n72:       }\n73:     }\n74:   }\n75: \n76:   // Create the feature\n77:   const feature = createBlankFeature(opts.id, opts.title, opts.description ?? \"\", {\n78:     priority: opts.priority,\n79:     difficulty: opts.difficulty,\n80:     effort: opts.effort,\n81:   });\n82: \n83:   // Set dependencies\n84:   if (opts.dependsOn?.length) {\n85:     feature.depends_on = opts.dependsOn;\n86:   }\n87: \n88:   // Dry-run: show what would be added without writing\n89:   if (opts.dryRun) {\n90:     outputMessage(fmt, `[dry-run] Would add feature: ${opts.id} — ${opts.title}`, {\n91:       dry_run: true,\n92:       id: feature.id,\n93:       title: feature.title,\n94:       priority: feature.priority,\n95:       difficulty: feature.difficulty,\n96:       effort: feature.effort,\n97:       depends_on: feature.depends_on,\n98:     });\n99:     return;\n100:   }\n101: \n102:   // Append to features list\n103:   data.features.push(feature);\n104:   saveFeatures(projectRoot, config, data);\n105: \n106:   outputMessage(fmt, `Added feature: ${opts.id} — ${opts.title}`, {\n107:     id: feature.id,\n108:     title: feature.title,\n109:     priority: feature.priority,\n110:     difficulty: feature.difficulty,\n111:     effort: feature.effort,\n112:     depends_on: feature.depends_on,\n113:   });\n114: \n115:   if (fmt === \"text\") {\n116:     console.log(`  priority: ${feature.priority}, difficulty: ${feature.difficulty}, effort: ${feature.effort}`);\n117:     if (feature.depends_on.length > 0) {\n118:       console.log(`  depends on: ${feature.depends_on.join(\", \")}`);\n119:     }\n120:   }\n121: }\n\n(End of file - total 121 lines)\n</content>","title":"src/commands/features/add.ts","metadata":{"preview":"/**\n * features/add.ts — Add a new feature to the features file.\n *\n * Usage:\n *   wombo features add <id> --title \"Feature Title\" [--description \"...\"]\n *                      [--priority medium] [--difficulty easy] [--effort PT2H]\n *                      [--depends-on \"feat1,feat2\"]\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  saveFeatures,\n  createBlankFeature,\n  allFeatureIds,\n  type Priority,\n  type Difficulty,\n} from \"../../lib/features.js\";\nimport { outputError, outputMessage, type OutputFormat } from \"../../lib/output.js\";\n","truncated":false,"loaded":[]},"time":{"start":1773351517808,"end":1773351517813}}}}
{"type":"tool_use","timestamp":1773351518036,"sessionID":"ses_31c036dcfffeZBZKwd7xzopNEA","part":{"id":"prt_ce3fcbe72001ptW0xlCaxWR35B","sessionID":"ses_31c036dcfffeZBZKwd7xzopNEA","messageID":"msg_ce3fcb02e001Jua2912S4gYIxa","type":"tool","callID":"toolu_vrtx_018hybXKra2GhwwNjMgbSdVP","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-cli-bugs/src/lib/features.ts"},"output":"<path>/home/fulgidus/Documents/wombo-cli-bugs/src/lib/features.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * features.ts — Parse features YAML and provide feature selection/filtering.\n3:  *\n4:  * Responsibilities:\n5:  *   - Load and parse the features file with full type safety\n6:  *   - Parse ISO 8601 durations into comparable minutes\n7:  *   - Filter features by status, priority, difficulty, dependency readiness\n8:  *   - Select features by various strategies (top-priority, quickest-wins, etc.)\n9:  *   - Resolve dependency graphs to determine which features are ready to start\n10:  *   - Write-back capability for feature management commands\n11:  */\n12: \n13: import { readFileSync, writeFileSync, existsSync } from \"node:fs\";\n14: import { resolve, dirname, join } from \"node:path\";\n15: import { parse as parseYaml, stringify as stringifyYaml } from \"yaml\";\n16: import { createInterface } from \"node:readline\";\n17: import type { WomboConfig } from \"../config.js\";\n18: \n19: // ---------------------------------------------------------------------------\n20: // Template path (resolved relative to this source file)\n21: // ---------------------------------------------------------------------------\n22: \n23: export const FEATURES_TEMPLATE_PATH = join(dirname(import.meta.dir), \"templates\", \".features.yml\");\n24: \n25: // ---------------------------------------------------------------------------\n26: // Types\n27: // ---------------------------------------------------------------------------\n28: \n29: export type FeatureStatus =\n30:   | \"backlog\"\n31:   | \"planned\"\n32:   | \"in_progress\"\n33:   | \"blocked\"\n34:   | \"in_review\"\n35:   | \"done\"\n36:   | \"cancelled\";\n37: \n38: export type Priority = \"critical\" | \"high\" | \"medium\" | \"low\" | \"wishlist\";\n39: \n40: export type Difficulty = \"trivial\" | \"easy\" | \"medium\" | \"hard\" | \"very_hard\";\n41: \n42: export interface Subtask {\n43:   id: string;\n44:   title: string;\n45:   description: string;\n46:   status: FeatureStatus;\n47:   completion: number;\n48:   difficulty: Difficulty;\n49:   priority: Priority;\n50:   depends_on: string[];\n51:   effort: string;\n52:   started_at: string | null;\n53:   ended_at: string | null;\n54:   constraints: string[];\n55:   forbidden: string[];\n56:   references: string[];\n57:   notes: string[];\n58:   subtasks: Subtask[];\n59: }\n60: \n61: export interface Feature {\n62:   id: string;\n63:   title: string;\n64:   description: string;\n65:   status: FeatureStatus;\n66:   completion: number;\n67:   difficulty: Difficulty;\n68:   priority: Priority;\n69:   depends_on: string[];\n70:   effort: string;\n71:   started_at: string | null;\n72:   ended_at: string | null;\n73:   constraints: string[];\n74:   forbidden: string[];\n75:   references: string[];\n76:   notes: string[];\n77:   subtasks: Subtask[];\n78: }\n79: \n80: export interface FeaturesFile {\n81:   version: string;\n82:   meta: {\n83:     created_at: string;\n84:     updated_at: string;\n85:     project: string;\n86:     generator: string;\n87:     maintainer: string;\n88:   };\n89:   features: Feature[];\n90:   archive: Feature[];\n91: }\n92: \n93: // Priority ordering (lower = more important)\n94: const PRIORITY_ORDER: Record<Priority, number> = {\n95:   critical: 0,\n96:   high: 1,\n97:   medium: 2,\n98:   low: 3,\n99:   wishlist: 4,\n100: };\n101: \n102: // Difficulty ordering (lower = easier)\n103: const DIFFICULTY_ORDER: Record<Difficulty, number> = {\n104:   trivial: 0,\n105:   easy: 1,\n106:   medium: 2,\n107:   hard: 3,\n108:   very_hard: 4,\n109: };\n110: \n111: // ---------------------------------------------------------------------------\n112: // ISO 8601 Duration Parser\n113: // ---------------------------------------------------------------------------\n114: \n115: /**\n116:  * Parse an ISO 8601 duration string into total minutes.\n117:  * Supports: P[nD][T[nH][nM][nS]]\n118:  * Examples: PT1H -> 60, PT30M -> 30, P1D -> 1440, P2DT4H -> 3360, PT1H30M -> 90\n119:  */\n120: export function parseDurationMinutes(iso: string): number {\n121:   const match = iso.match(\n122:     /^P(?:(\\d+)D)?(?:T(?:(\\d+)H)?(?:(\\d+)M)?(?:(\\d+)S)?)?$/\n123:   );\n124:   if (!match) return Infinity; // unparseable -> sort to end\n125:   const days = parseInt(match[1] || \"0\", 10);\n126:   const hours = parseInt(match[2] || \"0\", 10);\n127:   const minutes = parseInt(match[3] || \"0\", 10);\n128:   const seconds = parseInt(match[4] || \"0\", 10);\n129:   return days * 24 * 60 + hours * 60 + minutes + Math.ceil(seconds / 60);\n130: }\n131: \n132: /**\n133:  * Format minutes into a human-readable string.\n134:  */\n135: export function formatDuration(minutes: number): string {\n136:   if (minutes === Infinity) return \"unknown\";\n137:   if (minutes < 60) return `${minutes}m`;\n138:   const h = Math.floor(minutes / 60);\n139:   const m = minutes % 60;\n140:   if (h >= 24) {\n141:     const d = Math.floor(h / 24);\n142:     const rh = h % 24;\n143:     if (rh === 0 && m === 0) return `${d}d`;\n144:     if (m === 0) return `${d}d ${rh}h`;\n145:     return `${d}d ${rh}h ${m}m`;\n146:   }\n147:   return m === 0 ? `${h}h` : `${h}h ${m}m`;\n148: }\n149: \n150: // ---------------------------------------------------------------------------\n151: // Features File Existence Guard\n152: // ---------------------------------------------------------------------------\n153: \n154: /**\n155:  * Prompt the user with a yes/no question via stdin.\n156:  */\n157: function promptYesNo(question: string): Promise<boolean> {\n158:   const rl = createInterface({ input: process.stdin, output: process.stdout });\n159:   return new Promise((resolve) => {\n160:     rl.question(question, (answer) => {\n161:       rl.close();\n162:       resolve(answer.trim().toLowerCase().startsWith(\"y\"));\n163:     });\n164:   });\n165: }\n166: \n167: /**\n168:  * Ensure the features file exists before any command that needs it.\n169:  * If the file is missing, prompt the user to generate one from the template.\n170:  */\n171: export async function ensureFeaturesFile(\n172:   projectRoot: string,\n173:   config: WomboConfig\n174: ): Promise<void> {\n175:   const filePath = resolve(projectRoot, config.featuresFile);\n176: \n177:   if (existsSync(filePath)) return;\n178: \n179:   console.log(`\\nFeatures file not found: ${config.featuresFile}`);\n180: \n181:   const generate = await promptYesNo(\n182:     \"Generate a new features file from template? (y/N): \"\n183:   );\n184: \n185:   if (!generate) {\n186:     console.error(\n187:       `Cannot proceed without a features file. Create one manually or run again and accept the prompt.`\n188:     );\n189:     process.exit(1);\n190:   }\n191: \n192:   // Read template, update timestamps, write to project root\n193:   const template = readFileSync(FEATURES_TEMPLATE_PATH, \"utf-8\");\n194:   const now = new Date().toISOString();\n195:   const content = template\n196:     .replace(/created_at:\\s*\".*?\"/, `created_at: \"${now}\"`)\n197:     .replace(/updated_at:\\s*\".*?\"/, `updated_at: \"${now}\"`);\n198: \n199:   writeFileSync(filePath, content, \"utf-8\");\n200:   console.log(`Created ${config.featuresFile} from template.\\n`);\n201: }\n202: \n203: // ---------------------------------------------------------------------------\n204: // Loader\n205: // ---------------------------------------------------------------------------\n206: \n207: /**\n208:  * Load and parse the features YAML file from the project root.\n209:  * Uses config.featuresFile for the file path.\n210:  */\n211: export function loadFeatures(\n212:   projectRoot: string,\n213:   config: WomboConfig\n214: ): FeaturesFile {\n215:   const filePath = resolve(projectRoot, config.featuresFile);\n216:   const raw = readFileSync(filePath, \"utf-8\");\n217:   const parsed = parseYaml(raw) as FeaturesFile;\n218: \n219:   // Normalize: ensure top-level arrays are never null/undefined (YAML parses\n220:   // empty keys as null).\n221:   parsed.features = parsed.features ?? [];\n222:   parsed.archive = parsed.archive ?? [];\n223: \n224:   for (const f of [...parsed.features, ...parsed.archive]) {\n225:     normalizeFeature(f);\n226:   }\n227: \n228:   return parsed;\n229: }\n230: \n231: /**\n232:  * Save the features file back to disk (for management commands).\n233:  */\n234: export function saveFeatures(\n235:   projectRoot: string,\n236:   config: WomboConfig,\n237:   data: FeaturesFile\n238: ): void {\n239:   const filePath = resolve(projectRoot, config.featuresFile);\n240:   data.meta.updated_at = new Date().toISOString();\n241:   const yaml = stringifyYaml(data, {\n242:     lineWidth: 120,\n243:     defaultKeyType: \"PLAIN\",\n244:     defaultStringType: \"PLAIN\",\n245:   });\n246:   writeFileSync(filePath, yaml, \"utf-8\");\n247: }\n248: \n249: function normalizeFeature(f: Feature | Subtask): void {\n250:   f.depends_on = f.depends_on ?? [];\n251:   f.constraints = f.constraints ?? [];\n252:   f.forbidden = f.forbidden ?? [];\n253:   f.references = f.references ?? [];\n254:   f.notes = f.notes ?? [];\n255:   f.subtasks = f.subtasks ?? [];\n256:   for (const s of f.subtasks) {\n257:     normalizeFeature(s);\n258:   }\n259: }\n260: \n261: // ---------------------------------------------------------------------------\n262: // Dependency Resolution\n263: // ---------------------------------------------------------------------------\n264: \n265: /**\n266:  * Get all feature IDs that are done (status === \"done\" or completion === 100).\n267:  */\n268: function getDoneIds(features: Feature[], archive: Feature[]): Set<string> {\n269:   const done = new Set<string>();\n270:   const collectDone = (items: (Feature | Subtask)[]) => {\n271:     for (const item of items) {\n272:       if (item.status === \"done\" || item.completion === 100) {\n273:         done.add(item.id);\n274:       }\n275:       if (item.subtasks?.length) {\n276:         collectDone(item.subtasks);\n277:       }\n278:     }\n279:   };\n280:   collectDone(features);\n281:   collectDone(archive);\n282:   return done;\n283: }\n284: \n285: /**\n286:  * Check if a feature's dependencies are all satisfied.\n287:  */\n288: export function areDependenciesMet(\n289:   feature: Feature,\n290:   doneIds: Set<string>\n291: ): boolean {\n292:   return feature.depends_on.every((dep) => doneIds.has(dep));\n293: }\n294: \n295: /**\n296:  * Get all features that are ready to start (backlog + deps met).\n297:  */\n298: export function getReadyFeatures(data: FeaturesFile): Feature[] {\n299:   const doneIds = getDoneIds(data.features, data.archive);\n300:   return data.features.filter(\n301:     (f) =>\n302:       f.status === \"backlog\" &&\n303:       f.completion === 0 &&\n304:       areDependenciesMet(f, doneIds)\n305:   );\n306: }\n307: \n308: /**\n309:  * Get done IDs (exported for use in selection error messages).\n310:  */\n311: export function getDoneFeatureIds(data: FeaturesFile): Set<string> {\n312:   return getDoneIds(data.features, data.archive);\n313: }\n314: \n315: // ---------------------------------------------------------------------------\n316: // Selection Strategies\n317: // ---------------------------------------------------------------------------\n318: \n319: export interface SelectionOptions {\n320:   /** Select top N by priority (highest priority first, then lowest effort) */\n321:   topPriority?: number;\n322:   /** Select N quickest wins (lowest effort first) */\n323:   quickestWins?: number;\n324:   /** Select all features matching this priority level */\n325:   priority?: Priority;\n326:   /** Select all features matching this difficulty level */\n327:   difficulty?: Difficulty;\n328:   /** Select specific feature IDs (comma-separated) */\n329:   featureIds?: string[];\n330:   /** Select all ready features */\n331:   allReady?: boolean;\n332: }\n333: \n334: /**\n335:  * Select features based on the given strategy.\n336:  * Always filters to only ready features (backlog + deps met) first.\n337:  */\n338: export function selectFeatures(\n339:   data: FeaturesFile,\n340:   options: SelectionOptions\n341: ): Feature[] {\n342:   const ready = getReadyFeatures(data);\n343: \n344:   if (options.allReady) {\n345:     return sortByPriorityThenEffort(ready);\n346:   }\n347: \n348:   if (options.featureIds?.length) {\n349:     const idSet = new Set(options.featureIds);\n350:     const selected = ready.filter((f) => idSet.has(f.id));\n351:     const missing = options.featureIds.filter(\n352:       (id) => !selected.find((f) => f.id === id)\n353:     );\n354:     if (missing.length) {\n355:       const allIds = data.features.map((f) => f.id);\n356:       const doneIds = getDoneIds(data.features, data.archive);\n357:       for (const m of missing) {\n358:         if (!allIds.includes(m)) {\n359:           console.error(`  Feature \"${m}\" does not exist in the features file`);\n360:         } else {\n361:           const feat = data.features.find((f) => f.id === m)!;\n362:           console.error(\n363:             `  Feature \"${m}\" is not ready (status: ${feat.status}, deps met: ${areDependenciesMet(feat, doneIds)})`\n364:           );\n365:         }\n366:       }\n367:     }\n368:     return sortByPriorityThenEffort(selected);\n369:   }\n370: \n371:   if (options.priority) {\n372:     return sortByPriorityThenEffort(\n373:       ready.filter((f) => f.priority === options.priority)\n374:     );\n375:   }\n376: \n377:   if (options.difficulty) {\n378:     return sortByEffort(ready.filter((f) => f.difficulty === options.difficulty));\n379:   }\n380: \n381:   if (options.topPriority) {\n382:     return sortByPriorityThenEffort(ready).slice(0, options.topPriority);\n383:   }\n384: \n385:   if (options.quickestWins) {\n386:     return sortByEffort(ready).slice(0, options.quickestWins);\n387:   }\n388: \n389:   // Default: return all ready, sorted by priority\n390:   return sortByPriorityThenEffort(ready);\n391: }\n392: \n393: // ---------------------------------------------------------------------------\n394: // Sorting Helpers\n395: // ---------------------------------------------------------------------------\n396: \n397: function sortByPriorityThenEffort(features: Feature[]): Feature[] {\n398:   return [...features].sort((a, b) => {\n399:     const pDiff = PRIORITY_ORDER[a.priority] - PRIORITY_ORDER[b.priority];\n400:     if (pDiff !== 0) return pDiff;\n401:     return parseDurationMinutes(a.effort) - parseDurationMinutes(b.effort);\n402:   });\n403: }\n404: \n405: function sortByEffort(features: Feature[]): Feature[] {\n406:   return [...features].sort(\n407:     (a, b) => parseDurationMinutes(a.effort) - parseDurationMinutes(b.effort)\n408:   );\n409: }\n410: \n411: // ---------------------------------------------------------------------------\n412: // Utility Exports\n413: // ---------------------------------------------------------------------------\n414: \n415: export { PRIORITY_ORDER, DIFFICULTY_ORDER };\n416: \n417: /**\n418:  * Get a compact summary of a feature for display.\n419:  */\n420: export function featureSummary(f: Feature): string {\n421:   const effort = formatDuration(parseDurationMinutes(f.effort));\n422:   return `[${f.priority}/${f.difficulty}] ${f.id} -- ${f.title} (${effort})`;\n423: }\n424: \n425: /**\n426:  * Recursively search a list of features (and their subtasks) for a matching ID.\n427:  */\n428: function findInList(features: Feature[], id: string): Feature | undefined {\n429:   for (const f of features) {\n430:     if (f.id === id) return f;\n431:     if (f.subtasks?.length) {\n432:       const found = findInList(f.subtasks, id);\n433:       if (found) return found;\n434:     }\n435:   }\n436:   return undefined;\n437: }\n438: \n439: /**\n440:  * Find a feature or subtask by ID across active features, their subtasks\n441:  * (recursively), and the archive list.\n442:  */\n443: export function findFeatureById(\n444:   data: FeaturesFile,\n445:   id: string\n446: ): Feature | undefined {\n447:   return (\n448:     findInList(data.features, id) ??\n449:     (data.archive ? findInList(data.archive, id) : undefined)\n450:   );\n451: }\n452: \n453: /**\n454:  * Create a blank feature with all required fields initialized.\n455:  */\n456: export function createBlankFeature(\n457:   id: string,\n458:   title: string,\n459:   description: string = \"\",\n460:   opts?: {\n461:     priority?: Priority;\n462:     difficulty?: Difficulty;\n463:     effort?: string;\n464:   }\n465: ): Feature {\n466:   return {\n467:     id,\n468:     title,\n469:     description,\n470:     status: \"backlog\",\n471:     completion: 0,\n472:     difficulty: opts?.difficulty ?? \"medium\",\n473:     priority: opts?.priority ?? \"medium\",\n474:     depends_on: [],\n475:     effort: opts?.effort ?? \"PT1H\",\n476:     started_at: null,\n477:     ended_at: null,\n478:     constraints: [],\n479:     forbidden: [],\n480:     references: [],\n481:     notes: [],\n482:     subtasks: [],\n483:   };\n484: }\n485: \n486: /**\n487:  * Get all feature IDs (active + archive), useful for validation.\n488:  */\n489: export function allFeatureIds(data: FeaturesFile): string[] {\n490:   const ids: string[] = [];\n491:   const collect = (items: (Feature | Subtask)[]) => {\n492:     for (const item of items) {\n493:       ids.push(item.id);\n494:       if (item.subtasks?.length) collect(item.subtasks);\n495:     }\n496:   };\n497:   collect(data.features);\n498:   collect(data.archive ?? []);\n499:   return ids;\n500: }\n\n(End of file - total 500 lines)\n</content>","title":"src/lib/features.ts","metadata":{"preview":"/**\n * features.ts — Parse features YAML and provide feature selection/filtering.\n *\n * Responsibilities:\n *   - Load and parse the features file with full type safety\n *   - Parse ISO 8601 durations into comparable minutes\n *   - Filter features by status, priority, difficulty, dependency readiness\n *   - Select features by various strategies (top-priority, quickest-wins, etc.)\n *   - Resolve dependency graphs to determine which features are ready to start\n *   - Write-back capability for feature management commands\n */\n\nimport { readFileSync, writeFileSync, existsSync } from \"node:fs\";\nimport { resolve, dirname, join } from \"node:path\";\nimport { parse as parseYaml, stringify as stringifyYaml } from \"yaml\";\nimport { createInterface } from \"node:readline\";\nimport type { WomboConfig } from \"../config.js\";\n\n// ---------------------------------------------------------------------------\n// Template path (resolved relative to this source file)","truncated":false,"loaded":[]},"time":{"start":1773351518032,"end":1773351518035}}}}
{"type":"tool_use","timestamp":1773351518696,"sessionID":"ses_31c036dcfffeZBZKwd7xzopNEA","part":{"id":"prt_ce3fcbfba001T4WhSzdu5FKxPm","sessionID":"ses_31c036dcfffeZBZKwd7xzopNEA","messageID":"msg_ce3fcb02e001Jua2912S4gYIxa","type":"tool","callID":"toolu_vrtx_01SSrrHJupW5UDbqxqv4ofVE","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-cli-bugs/src/commands/features/archive.ts"},"output":"<path>/home/fulgidus/Documents/wombo-cli-bugs/src/commands/features/archive.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * features/archive.ts — Move done/cancelled features to the archive section.\n3:  *\n4:  * Usage:\n5:  *   wombo features archive              # archive all done + cancelled\n6:  *   wombo features archive <feature-id> # archive a specific feature\n7:  *   wombo features archive --dry-run    # show what would be archived\n8:  */\n9: \n10: import type { WomboConfig } from \"../../config.js\";\n11: import {\n12:   loadFeatures,\n13:   saveFeatures,\n14:   findFeatureById,\n15:   type Feature,\n16: } from \"../../lib/features.js\";\n17: \n18: // ---------------------------------------------------------------------------\n19: // Types\n20: // ---------------------------------------------------------------------------\n21: \n22: export interface FeaturesArchiveOptions {\n23:   projectRoot: string;\n24:   config: WomboConfig;\n25:   featureId?: string;\n26:   dryRun?: boolean;\n27: }\n28: \n29: // ---------------------------------------------------------------------------\n30: // Command\n31: // ---------------------------------------------------------------------------\n32: \n33: export async function cmdFeaturesArchive(opts: FeaturesArchiveOptions): Promise<void> {\n34:   const { projectRoot, config } = opts;\n35: \n36:   const data = loadFeatures(projectRoot, config);\n37: \n38:   // Ensure archive array exists\n39:   if (!data.archive) {\n40:     data.archive = [];\n41:   }\n42: \n43:   let toArchive: Feature[];\n44: \n45:   if (opts.featureId) {\n46:     // Archive a specific feature\n47:     const idx = data.features.findIndex((f) => f.id === opts.featureId);\n48:     if (idx === -1) {\n49:       // Check if already in archive\n50:       if (data.archive.find((f) => f.id === opts.featureId)) {\n51:         console.log(`Feature \"${opts.featureId}\" is already in the archive.`);\n52:         return;\n53:       }\n54:       console.error(`Feature \"${opts.featureId}\" not found.`);\n55:       process.exit(1);\n56:       return;\n57:     }\n58:     toArchive = [data.features[idx]];\n59:   } else {\n60:     // Archive all done + cancelled features\n61:     toArchive = data.features.filter(\n62:       (f) => f.status === \"done\" || f.status === \"cancelled\"\n63:     );\n64:   }\n65: \n66:   if (toArchive.length === 0) {\n67:     console.log(\"No features to archive.\");\n68:     return;\n69:   }\n70: \n71:   if (opts.dryRun) {\n72:     console.log(`\\nWould archive ${toArchive.length} feature(s):\\n`);\n73:     for (const f of toArchive) {\n74:       console.log(`  ${f.id} — ${f.title} (${f.status})`);\n75:     }\n76:     return;\n77:   }\n78: \n79:   // Move features from active to archive\n80:   const archiveIds = new Set(toArchive.map((f) => f.id));\n81:   data.features = data.features.filter((f) => !archiveIds.has(f.id));\n82:   data.archive.push(...toArchive);\n83: \n84:   saveFeatures(projectRoot, config, data);\n85: \n86:   console.log(`\\nArchived ${toArchive.length} feature(s):`);\n87:   for (const f of toArchive) {\n88:     console.log(`  ${f.id} — ${f.title} (${f.status})`);\n89:   }\n90: }\n\n(End of file - total 90 lines)\n</content>","title":"src/commands/features/archive.ts","metadata":{"preview":"/**\n * features/archive.ts — Move done/cancelled features to the archive section.\n *\n * Usage:\n *   wombo features archive              # archive all done + cancelled\n *   wombo features archive <feature-id> # archive a specific feature\n *   wombo features archive --dry-run    # show what would be archived\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  saveFeatures,\n  findFeatureById,\n  type Feature,\n} from \"../../lib/features.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------","truncated":false,"loaded":[]},"time":{"start":1773351518693,"end":1773351518695}}}}
{"type":"tool_use","timestamp":1773351519070,"sessionID":"ses_31c036dcfffeZBZKwd7xzopNEA","part":{"id":"prt_ce3fcc1e6001n07IREfihx5xPS","sessionID":"ses_31c036dcfffeZBZKwd7xzopNEA","messageID":"msg_ce3fcb02e001Jua2912S4gYIxa","type":"tool","callID":"toolu_vrtx_0198eihiscTqponsmGrrWrzg","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-cli-bugs/src/lib/schema.ts"},"output":"<path>/home/fulgidus/Documents/wombo-cli-bugs/src/lib/schema.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * schema.ts — Declarative command/flag registry for schema introspection.\n3:  *\n4:  * Every command and flag is described in a single registry. This registry is\n5:  * the source of truth for:\n6:  *   1. `wombo describe <command>` — emits a JSON schema of accepted args\n7:  *   2. Future help text generation\n8:  *\n9:  * The registry is NOT used for actual arg parsing (that's still the hand-rolled\n10:  * switch in index.ts), but the two must stay in sync. If they drift, `wombo\n11:  * features check` should eventually catch it.\n12:  */\n13: \n14: // ---------------------------------------------------------------------------\n15: // Types\n16: // ---------------------------------------------------------------------------\n17: \n18: export interface FlagDef {\n19:   /** Primary flag name, e.g. \"--dry-run\" */\n20:   name: string;\n21:   /** Short alias, e.g. \"-o\" */\n22:   alias?: string;\n23:   /** Description shown in help / schema */\n24:   description: string;\n25:   /** Type of the value: \"boolean\" flags take no value, others consume next arg */\n26:   type: \"string\" | \"number\" | \"boolean\" | \"string[]\";\n27:   /** Default value (undefined = required or absent) */\n28:   default?: unknown;\n29:   /** For enum-like flags, the set of allowed values */\n30:   enum?: readonly string[];\n31:   /** If true, this flag is required */\n32:   required?: boolean;\n33: }\n34: \n35: export interface PositionalDef {\n36:   /** Name used in usage strings, e.g. \"feature-id\" */\n37:   name: string;\n38:   description: string;\n39:   required?: boolean;\n40: }\n41: \n42: export interface CommandDef {\n43:   /** Command name as typed by the user, e.g. \"launch\" or \"features list\" */\n44:   name: string;\n45:   /** One-line summary */\n46:   summary: string;\n47:   /** Longer description */\n48:   description?: string;\n49:   /** Positional arguments */\n50:   positionals: PositionalDef[];\n51:   /** Named flags */\n52:   flags: FlagDef[];\n53:   /** Whether this command mutates state (used for dry-run indication) */\n54:   mutating: boolean;\n55:   /** Whether this command supports --dry-run */\n56:   supportsDryRun: boolean;\n57:   /** Subcommands (for \"features\" parent) */\n58:   subcommands?: CommandDef[];\n59: }\n60: \n61: // ---------------------------------------------------------------------------\n62: // Global flags (available on every command)\n63: // ---------------------------------------------------------------------------\n64: \n65: const GLOBAL_FLAGS: FlagDef[] = [\n66:   {\n67:     name: \"--output\",\n68:     alias: \"-o\",\n69:     description: \"Output format: text (default) or json\",\n70:     type: \"string\",\n71:     default: \"text\",\n72:     enum: [\"text\", \"json\"],\n73:   },\n74:   {\n75:     name: \"--force\",\n76:     description: \"Force overwrite / skip safety prompts\",\n77:     type: \"boolean\",\n78:     default: false,\n79:   },\n80: ];\n81: \n82: // ---------------------------------------------------------------------------\n83: // Command Registry\n84: // ---------------------------------------------------------------------------\n85: \n86: export const COMMAND_REGISTRY: CommandDef[] = [\n87:   // --- init ---------------------------------------------------------------\n88:   {\n89:     name: \"init\",\n90:     summary: \"Generate wombo.json config in the current project\",\n91:     description:\n92:       \"Interactive guided setup that walks through every config section. \" +\n93:       \"Creates wombo.json and .features.yml from template.\",\n94:     positionals: [],\n95:     flags: [\n96:       {\n97:         name: \"--force\",\n98:         description: \"Overwrite existing config files\",\n99:         type: \"boolean\",\n100:         default: false,\n101:       },\n102:       {\n103:         name: \"--dry-run\",\n104:         description: \"Show what would be created without writing files\",\n105:         type: \"boolean\",\n106:         default: false,\n107:       },\n108:     ],\n109:     mutating: true,\n110:     supportsDryRun: true,\n111:   },\n112: \n113:   // --- launch -------------------------------------------------------------\n114:   {\n115:     name: \"launch\",\n116:     summary: \"Launch a wave of agents to implement features\",\n117:     description:\n118:       \"Select features from .features.yml, create worktrees, and spawn agents. \" +\n119:       \"Supports multiple selection strategies.\",\n120:     positionals: [],\n121:     flags: [\n122:       { name: \"--top-priority\", description: \"Select top N features by priority\", type: \"number\" },\n123:       { name: \"--quickest-wins\", description: \"Select N features with lowest effort\", type: \"number\" },\n124:       { name: \"--priority\", description: \"Filter by priority level\", type: \"string\", enum: [\"critical\", \"high\", \"medium\", \"low\", \"wishlist\"] },\n125:       { name: \"--difficulty\", description: \"Filter by difficulty level\", type: \"string\", enum: [\"trivial\", \"easy\", \"medium\", \"hard\", \"very_hard\"] },\n126:       { name: \"--features\", description: \"Select specific features by comma-separated IDs\", type: \"string\" },\n127:       { name: \"--all-ready\", description: \"Select all features whose dependencies are met\", type: \"boolean\", default: false },\n128:       { name: \"--max-concurrent\", description: \"Max agents running in parallel\", type: \"number\" },\n129:       { name: \"--model\", alias: \"-m\", description: \"Model to use (e.g., anthropic/claude-sonnet-4-20250514)\", type: \"string\" },\n130:       { name: \"--interactive\", description: \"Use tmux TUI mode instead of headless\", type: \"boolean\", default: false },\n131:       { name: \"--no-tui\", description: \"Headless mode without neo-blessed TUI\", type: \"boolean\", default: false },\n132:       { name: \"--auto-push\", description: \"Push base branch to remote after all merges\", type: \"boolean\", default: false },\n133:       { name: \"--dry-run\", description: \"Show what would be launched without launching\", type: \"boolean\", default: false },\n134:       { name: \"--base-branch\", description: \"Base branch (default: from config)\", type: \"string\" },\n135:       { name: \"--max-retries\", description: \"Max retries per agent\", type: \"number\" },\n136:     ],\n137:     mutating: true,\n138:     supportsDryRun: true,\n139:   },\n140: \n141:   // --- resume -------------------------------------------------------------\n142:   {\n143:     name: \"resume\",\n144:     summary: \"Resume a previously stopped wave\",\n145:     positionals: [],\n146:     flags: [\n147:       { name: \"--max-concurrent\", description: \"Max agents running in parallel\", type: \"number\" },\n148:       { name: \"--model\", alias: \"-m\", description: \"Model to use\", type: \"string\" },\n149:       { name: \"--interactive\", description: \"Use tmux TUI mode\", type: \"boolean\", default: false },\n150:       { name: \"--no-tui\", description: \"Headless mode without neo-blessed TUI\", type: \"boolean\", default: false },\n151:       { name: \"--auto-push\", description: \"Push base branch to remote after merges\", type: \"boolean\", default: false },\n152:       { name: \"--base-branch\", description: \"Base branch override\", type: \"string\" },\n153:       { name: \"--max-retries\", description: \"Max retries per agent\", type: \"number\" },\n154:     ],\n155:     mutating: true,\n156:     supportsDryRun: false,\n157:   },\n158: \n159:   // --- status -------------------------------------------------------------\n160:   {\n161:     name: \"status\",\n162:     summary: \"Show the status of the current wave\",\n163:     positionals: [],\n164:     flags: [],\n165:     mutating: false,\n166:     supportsDryRun: false,\n167:   },\n168: \n169:   // --- verify -------------------------------------------------------------\n170:   {\n171:     name: \"verify\",\n172:     summary: \"Run build verification on completed agents\",\n173:     positionals: [\n174:       { name: \"feature-id\", description: \"Specific feature to verify (optional)\", required: false },\n175:     ],\n176:     flags: [\n177:       { name: \"--model\", alias: \"-m\", description: \"Model to use for verification\", type: \"string\" },\n178:       { name: \"--max-retries\", description: \"Max retries\", type: \"number\" },\n179:     ],\n180:     mutating: true,\n181:     supportsDryRun: false,\n182:   },\n183: \n184:   // --- merge --------------------------------------------------------------\n185:   {\n186:     name: \"merge\",\n187:     summary: \"Merge verified branches into the base branch\",\n188:     positionals: [\n189:       { name: \"feature-id\", description: \"Specific feature to merge (optional)\", required: false },\n190:     ],\n191:     flags: [\n192:       { name: \"--auto-push\", description: \"Push base branch to remote after merge\", type: \"boolean\", default: false },\n193:       { name: \"--dry-run\", description: \"Show what would be merged without merging\", type: \"boolean\", default: false },\n194:     ],\n195:     mutating: true,\n196:     supportsDryRun: true,\n197:   },\n198: \n199:   // --- retry --------------------------------------------------------------\n200:   {\n201:     name: \"retry\",\n202:     summary: \"Retry a failed agent\",\n203:     positionals: [\n204:       { name: \"feature-id\", description: \"Feature ID of the failed agent\", required: true },\n205:     ],\n206:     flags: [\n207:       { name: \"--model\", alias: \"-m\", description: \"Model to use\", type: \"string\" },\n208:       { name: \"--interactive\", description: \"Use tmux TUI mode\", type: \"boolean\", default: false },\n209:       { name: \"--dry-run\", description: \"Show what would be retried without retrying\", type: \"boolean\", default: false },\n210:     ],\n211:     mutating: true,\n212:     supportsDryRun: true,\n213:   },\n214: \n215:   // --- cleanup ------------------------------------------------------------\n216:   {\n217:     name: \"cleanup\",\n218:     summary: \"Remove all wave worktrees and tmux sessions\",\n219:     description: \"Kills tmux sessions, removes worktrees, removes state and log files.\",\n220:     positionals: [],\n221:     flags: [\n222:       { name: \"--dry-run\", description: \"Show what would be cleaned up without removing\", type: \"boolean\", default: false },\n223:     ],\n224:     mutating: true,\n225:     supportsDryRun: true,\n226:   },\n227: \n228:   // --- upgrade ------------------------------------------------------------\n229:   {\n230:     name: \"upgrade\",\n231:     summary: \"Check for updates and upgrade wombo\",\n232:     positionals: [],\n233:     flags: [\n234:       { name: \"--check\", description: \"Only check for updates, don't install\", type: \"boolean\", default: false },\n235:       { name: \"--version\", description: \"Install a specific version (e.g., v0.1.0)\", type: \"string\" },\n236:       { name: \"--force\", description: \"Force reinstall even if up to date\", type: \"boolean\", default: false },\n237:     ],\n238:     mutating: true,\n239:     supportsDryRun: false,\n240:   },\n241: \n242:   // --- features (parent with subcommands) ---------------------------------\n243:   {\n244:     name: \"features\",\n245:     summary: \"Manage .features.yml\",\n246:     positionals: [],\n247:     flags: [],\n248:     mutating: false,\n249:     supportsDryRun: false,\n250:     subcommands: [\n251:       {\n252:         name: \"features list\",\n253:         summary: \"List features with optional filtering\",\n254:         positionals: [],\n255:         flags: [\n256:           { name: \"--status\", description: \"Filter by status\", type: \"string\", enum: [\"backlog\", \"planned\", \"in_progress\", \"blocked\", \"in_review\", \"done\", \"cancelled\"] },\n257:           { name: \"--priority\", description: \"Filter by priority\", type: \"string\", enum: [\"critical\", \"high\", \"medium\", \"low\", \"wishlist\"] },\n258:           { name: \"--difficulty\", description: \"Filter by difficulty\", type: \"string\", enum: [\"trivial\", \"easy\", \"medium\", \"hard\", \"very_hard\"] },\n259:           { name: \"--ready\", description: \"Show only ready features (backlog + deps met)\", type: \"boolean\", default: false },\n260:           { name: \"--include-archive\", description: \"Include archived features\", type: \"boolean\", default: false },\n261:           { name: \"--fields\", description: \"Comma-separated list of fields to include in output\", type: \"string\" },\n262:         ],\n263:         mutating: false,\n264:         supportsDryRun: false,\n265:       },\n266:       {\n267:         name: \"features add\",\n268:         summary: \"Add a new feature\",\n269:         positionals: [\n270:           { name: \"id\", description: \"Feature ID (kebab-case)\", required: true },\n271:           { name: \"title\", description: \"Feature title\", required: true },\n272:         ],\n273:         flags: [\n274:           { name: \"--description\", alias: \"--desc\", description: \"Feature description\", type: \"string\" },\n275:           { name: \"--priority\", description: \"Priority level\", type: \"string\", default: \"medium\", enum: [\"critical\", \"high\", \"medium\", \"low\", \"wishlist\"] },\n276:           { name: \"--difficulty\", description: \"Difficulty level\", type: \"string\", default: \"medium\", enum: [\"trivial\", \"easy\", \"medium\", \"hard\", \"very_hard\"] },\n277:           { name: \"--effort\", description: \"Effort estimate (ISO 8601 duration, e.g. PT2H)\", type: \"string\", default: \"PT1H\" },\n278:           { name: \"--depends-on\", description: \"Comma-separated dependency IDs\", type: \"string\" },\n279:           { name: \"--dry-run\", description: \"Show what would be added without writing\", type: \"boolean\", default: false },\n280:         ],\n281:         mutating: true,\n282:         supportsDryRun: true,\n283:       },\n284:       {\n285:         name: \"features set-status\",\n286:         summary: \"Change a feature's status\",\n287:         positionals: [\n288:           { name: \"feature-id\", description: \"Feature ID to update\", required: true },\n289:           { name: \"status\", description: \"New status value\", required: true },\n290:         ],\n291:         flags: [\n292:           { name: \"--dry-run\", description: \"Show what would change without writing\", type: \"boolean\", default: false },\n293:         ],\n294:         mutating: true,\n295:         supportsDryRun: true,\n296:       },\n297:       {\n298:         name: \"features check\",\n299:         summary: \"Validate .features.yml (schema, deps, duplicates, cycles)\",\n300:         positionals: [],\n301:         flags: [],\n302:         mutating: false,\n303:         supportsDryRun: false,\n304:       },\n305:       {\n306:         name: \"features archive\",\n307:         summary: \"Move done/cancelled features to archive section\",\n308:         positionals: [\n309:           { name: \"feature-id\", description: \"Specific feature to archive (optional)\", required: false },\n310:         ],\n311:         flags: [\n312:           { name: \"--dry-run\", description: \"Show what would be archived without moving\", type: \"boolean\", default: false },\n313:         ],\n314:         mutating: true,\n315:         supportsDryRun: true,\n316:       },\n317:       {\n318:         name: \"features show\",\n319:         summary: \"Show detailed information about a specific feature\",\n320:         positionals: [\n321:           { name: \"feature-id\", description: \"Feature ID to display\", required: true },\n322:         ],\n323:         flags: [\n324:           { name: \"--fields\", description: \"Comma-separated list of fields to include in output\", type: \"string\" },\n325:         ],\n326:         mutating: false,\n327:         supportsDryRun: false,\n328:       },\n329:       {\n330:         name: \"features graph\",\n331:         summary: \"Visualize the feature dependency graph as a terminal diagram\",\n332:         description:\n333:           \"Builds a Mermaid flowchart from the features dependency graph and renders \" +\n334:           \"it as a Unicode box diagram. Shows dependency edges, status badges, orphan \" +\n335:           \"detection, dangling dependency warnings, and cycle detection.\",\n336:         positionals: [],\n337:         flags: [\n338:           { name: \"--status\", description: \"Filter graph to features with this status\", type: \"string\", enum: [\"backlog\", \"planned\", \"in_progress\", \"blocked\", \"in_review\", \"done\", \"cancelled\"] },\n339:           { name: \"--ascii\", description: \"Use ASCII-only rendering (no Unicode box chars)\", type: \"boolean\", default: false },\n340:           { name: \"--mermaid\", description: \"Emit raw Mermaid source instead of rendered graph\", type: \"boolean\", default: false },\n341:           { name: \"--subtasks\", description: \"Include subtask-level nodes in the graph\", type: \"boolean\", default: false },\n342:         ],\n343:         mutating: false,\n344:         supportsDryRun: false,\n345:       },\n346:     ],\n347:   },\n348: \n349:   // --- help ---------------------------------------------------------------\n350:   {\n351:     name: \"help\",\n352:     summary: \"Show help text\",\n353:     positionals: [],\n354:     flags: [],\n355:     mutating: false,\n356:     supportsDryRun: false,\n357:   },\n358: \n359:   // --- describe -----------------------------------------------------------\n360:   {\n361:     name: \"describe\",\n362:     summary: \"Emit JSON schema of a command's arguments and flags\",\n363:     description:\n364:       \"Machine-readable introspection for AI agents. Outputs the accepted \" +\n365:       \"positionals, flags, types, defaults, and constraints for a command.\",\n366:     positionals: [\n367:       { name: \"command\", description: \"Command to describe (e.g. 'launch', 'features add')\", required: false },\n368:     ],\n369:     flags: [],\n370:     mutating: false,\n371:     supportsDryRun: false,\n372:   },\n373: ];\n374: \n375: // ---------------------------------------------------------------------------\n376: // Lookup helpers\n377: // ---------------------------------------------------------------------------\n378: \n379: /**\n380:  * Find a command definition by name. Supports compound names like \"features list\".\n381:  */\n382: export function findCommandDef(name: string): CommandDef | undefined {\n383:   // Try direct match first\n384:   const direct = COMMAND_REGISTRY.find((c) => c.name === name);\n385:   if (direct) return direct;\n386: \n387:   // Try compound: \"features list\" -> look in features subcommands\n388:   const parts = name.split(/\\s+/);\n389:   if (parts.length === 2) {\n390:     const parent = COMMAND_REGISTRY.find((c) => c.name === parts[0]);\n391:     if (parent?.subcommands) {\n392:       return parent.subcommands.find((sc) => sc.name === name || sc.name === parts[1]);\n393:     }\n394:   }\n395: \n396:   return undefined;\n397: }\n398: \n399: /**\n400:  * Produce the JSON schema object for a command, suitable for agent consumption.\n401:  */\n402: export function commandToSchema(cmd: CommandDef): Record<string, unknown> {\n403:   const schema: Record<string, unknown> = {\n404:     command: cmd.name,\n405:     summary: cmd.summary,\n406:     mutating: cmd.mutating,\n407:     supports_dry_run: cmd.supportsDryRun,\n408:   };\n409: \n410:   if (cmd.description) {\n411:     schema.description = cmd.description;\n412:   }\n413: \n414:   if (cmd.positionals.length > 0) {\n415:     schema.positionals = cmd.positionals.map((p) => ({\n416:       name: p.name,\n417:       description: p.description,\n418:       required: p.required ?? false,\n419:     }));\n420:   }\n421: \n422:   const allFlags = [...cmd.flags, ...GLOBAL_FLAGS];\n423:   schema.flags = allFlags.map((f) => {\n424:     const entry: Record<string, unknown> = {\n425:       name: f.name,\n426:       type: f.type,\n427:       description: f.description,\n428:     };\n429:     if (f.alias) entry.alias = f.alias;\n430:     if (f.default !== undefined) entry.default = f.default;\n431:     if (f.enum) entry.enum = f.enum;\n432:     if (f.required) entry.required = true;\n433:     return entry;\n434:   });\n435: \n436:   if (cmd.subcommands?.length) {\n437:     schema.subcommands = cmd.subcommands.map((sc) => sc.name);\n438:   }\n439: \n440:   return schema;\n441: }\n442: \n443: /**\n444:  * Produce a listing of all commands (for `wombo describe` with no args).\n445:  */\n446: export function allCommandSchemas(): Record<string, unknown> {\n447:   const commands: Record<string, unknown>[] = [];\n448: \n449:   for (const cmd of COMMAND_REGISTRY) {\n450:     const entry: Record<string, unknown> = {\n451:       name: cmd.name,\n452:       summary: cmd.summary,\n453:       mutating: cmd.mutating,\n454:       supports_dry_run: cmd.supportsDryRun,\n455:     };\n456:     if (cmd.subcommands) {\n457:       entry.subcommands = cmd.subcommands.map((sc) => ({\n458:         name: sc.name,\n459:         summary: sc.summary,\n460:         mutating: sc.mutating,\n461:         supports_dry_run: sc.supportsDryRun,\n462:       }));\n463:     }\n464:     commands.push(entry);\n465:   }\n466: \n467:   return {\n468:     tool: \"wombo\",\n469:     version: \"0.0.2\",\n470:     global_flags: GLOBAL_FLAGS.map((f) => ({\n471:       name: f.name,\n472:       alias: f.alias,\n473:       type: f.type,\n474:       description: f.description,\n475:       default: f.default,\n476:     })),\n477:     commands,\n478:   };\n479: }\n\n(End of file - total 479 lines)\n</content>","title":"src/lib/schema.ts","metadata":{"preview":"/**\n * schema.ts — Declarative command/flag registry for schema introspection.\n *\n * Every command and flag is described in a single registry. This registry is\n * the source of truth for:\n *   1. `wombo describe <command>` — emits a JSON schema of accepted args\n *   2. Future help text generation\n *\n * The registry is NOT used for actual arg parsing (that's still the hand-rolled\n * switch in index.ts), but the two must stay in sync. If they drift, `wombo\n * features check` should eventually catch it.\n */\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface FlagDef {\n  /** Primary flag name, e.g. \"--dry-run\" */\n  name: string;","truncated":false,"loaded":[]},"time":{"start":1773351519065,"end":1773351519068}}}}
{"type":"tool_use","timestamp":1773351519490,"sessionID":"ses_31c036dcfffeZBZKwd7xzopNEA","part":{"id":"prt_ce3fcc35a001sQREmopFmuixOt","sessionID":"ses_31c036dcfffeZBZKwd7xzopNEA","messageID":"msg_ce3fcb02e001Jua2912S4gYIxa","type":"tool","callID":"toolu_vrtx_01PvNkrj7P9TUHGen9B7G2mV","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-cli-bugs/src/commands/status.ts"},"output":"<path>/home/fulgidus/Documents/wombo-cli-bugs/src/commands/status.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * status.ts — Show the status of the current wave.\n3:  *\n4:  * Usage: wombo status\n5:  *\n6:  * Loads the wave state, checks for dead processes, and prints a dashboard.\n7:  */\n8: \n9: import type { WomboConfig } from \"../config.js\";\n10: import { loadState, saveState, updateAgent } from \"../lib/state.js\";\n11: import { isProcessRunning } from \"../lib/launcher.js\";\n12: import { printDashboard } from \"../lib/ui.js\";\n13: \n14: export interface StatusOptions {\n15:   projectRoot: string;\n16:   config: WomboConfig;\n17: }\n18: \n19: export async function cmdStatus(opts: StatusOptions): Promise<void> {\n20:   const state = loadState(opts.projectRoot);\n21:   if (!state) {\n22:     console.log(\"No active wave. Use 'wombo launch' to start one.\");\n23:     return;\n24:   }\n25: \n26:   // Update running agent status from process state\n27:   for (const agent of state.agents) {\n28:     if (agent.status === \"running\" && agent.pid) {\n29:       if (!isProcessRunning(agent.pid)) {\n30:         updateAgent(state, agent.feature_id, {\n31:           status: \"completed\",\n32:           completed_at: new Date().toISOString(),\n33:         });\n34:       }\n35:     }\n36:   }\n37:   saveState(opts.projectRoot, state);\n38: \n39:   printDashboard(state);\n40: }\n\n(End of file - total 40 lines)\n</content>","title":"src/commands/status.ts","metadata":{"preview":"/**\n * status.ts — Show the status of the current wave.\n *\n * Usage: wombo status\n *\n * Loads the wave state, checks for dead processes, and prints a dashboard.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport { loadState, saveState, updateAgent } from \"../lib/state.js\";\nimport { isProcessRunning } from \"../lib/launcher.js\";\nimport { printDashboard } from \"../lib/ui.js\";\n\nexport interface StatusOptions {\n  projectRoot: string;\n  config: WomboConfig;\n}\n\nexport async function cmdStatus(opts: StatusOptions): Promise<void> {\n  const state = loadState(opts.projectRoot);","truncated":false,"loaded":[]},"time":{"start":1773351519479,"end":1773351519489}}}}
{"type":"tool_use","timestamp":1773351519936,"sessionID":"ses_31c036dcfffeZBZKwd7xzopNEA","part":{"id":"prt_ce3fcc577001tuWYda7CYuJfth","sessionID":"ses_31c036dcfffeZBZKwd7xzopNEA","messageID":"msg_ce3fcb02e001Jua2912S4gYIxa","type":"tool","callID":"toolu_vrtx_01JqVNbTQJXHKLzN91mneXS3","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-cli-bugs/src/commands/cleanup.ts"},"output":"<path>/home/fulgidus/Documents/wombo-cli-bugs/src/commands/cleanup.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * cleanup.ts — Remove all wave-related resources.\n3:  *\n4:  * Usage: wombo cleanup\n5:  *\n6:  * Kills tmux sessions, removes worktrees, removes state and log files.\n7:  */\n8: \n9: import { existsSync, unlinkSync, rmSync } from \"node:fs\";\n10: import { execSync } from \"node:child_process\";\n11: import { resolve } from \"node:path\";\n12: import type { WomboConfig } from \"../config.js\";\n13: import { killAllTmuxSessions } from \"../lib/launcher.js\";\n14: import { cleanupAllWorktrees } from \"../lib/worktree.js\";\n15: \n16: export interface CleanupOptions {\n17:   projectRoot: string;\n18:   config: WomboConfig;\n19:   dryRun?: boolean;\n20: }\n21: \n22: export async function cmdCleanup(opts: CleanupOptions): Promise<void> {\n23:   const { projectRoot, config } = opts;\n24: \n25:   // Dry-run: show what would be cleaned up without doing it\n26:   if (opts.dryRun) {\n27:     console.log(\"\\n[dry-run] Would perform the following cleanup:\\n\");\n28: \n29:     // List tmux sessions that would be killed\n30:     try {\n31:       const sessions = execSync(\"tmux list-sessions -F '#{session_name}'\", {\n32:         encoding: \"utf-8\",\n33:       }).trim();\n34:       const prefix = config.agent.tmuxPrefix;\n35:       const matching = sessions\n36:         .split(\"\\n\")\n37:         .filter((s) => s.startsWith(prefix));\n38:       console.log(`  tmux sessions to kill: ${matching.length}`);\n39:       for (const s of matching) {\n40:         console.log(`    ${s}`);\n41:       }\n42:     } catch {\n43:       console.log(\"  tmux sessions to kill: 0 (no tmux server running)\");\n44:     }\n45: \n46:     // List worktrees that would be removed\n47:     try {\n48:       const worktrees = execSync(\"git worktree list --porcelain\", {\n49:         cwd: projectRoot,\n50:         encoding: \"utf-8\",\n51:       }).trim();\n52:       const prefix = config.git.worktreePrefix;\n53:       const matching = worktrees\n54:         .split(\"\\n\")\n55:         .filter((line) => line.startsWith(\"worktree \") && line.includes(prefix))\n56:         .map((line) => line.replace(\"worktree \", \"\"));\n57:       console.log(`  worktrees to remove: ${matching.length}`);\n58:       for (const w of matching) {\n59:         console.log(`    ${w}`);\n60:       }\n61:     } catch {\n62:       console.log(\"  worktrees to remove: 0\");\n63:     }\n64: \n65:     const statePath = resolve(projectRoot, \".wombo-state.json\");\n66:     const logDir = resolve(projectRoot, \".wombo-logs\");\n67:     if (existsSync(statePath)) console.log(\"  Would remove: .wombo-state.json\");\n68:     if (existsSync(logDir)) console.log(\"  Would remove: .wombo-logs/\");\n69: \n70:     return;\n71:   }\n72: \n73:   console.log(\"\\n--- Wombo: Cleanup ---\\n\");\n74: \n75:   // Kill tmux sessions\n76:   const killed = killAllTmuxSessions(config);\n77:   console.log(`Killed ${killed} tmux session(s)`);\n78: \n79:   // Remove worktrees\n80:   const removed = cleanupAllWorktrees(projectRoot, config);\n81:   console.log(`Removed ${removed} worktree(s)`);\n82: \n83:   // List remaining feature branches\n84:   try {\n85:     const branchPattern = `\"${config.git.branchPrefix}*\"`;\n86:     const branches = execSync(`git branch --list ${branchPattern}`, {\n87:       cwd: projectRoot,\n88:       encoding: \"utf-8\",\n89:     }).trim();\n90:     if (branches) {\n91:       console.log(`\\nRemaining feature branches:\\n${branches}`);\n92:       console.log('Use \"git branch -D <branch>\" to remove manually.');\n93:     }\n94:   } catch {}\n95: \n96:   // Remove state file\n97:   const statePath = resolve(projectRoot, \".wombo-state.json\");\n98:   if (existsSync(statePath)) {\n99:     unlinkSync(statePath);\n100:     console.log(\"Removed .wombo-state.json\");\n101:   }\n102: \n103:   // Remove log directory\n104:   const logDir = resolve(projectRoot, \".wombo-logs\");\n105:   if (existsSync(logDir)) {\n106:     rmSync(logDir, { recursive: true, force: true });\n107:     console.log(\"Removed .wombo-logs/\");\n108:   }\n109: \n110:   console.log(\"\\nCleanup complete.\");\n111: }\n\n(End of file - total 111 lines)\n</content>","title":"src/commands/cleanup.ts","metadata":{"preview":"/**\n * cleanup.ts — Remove all wave-related resources.\n *\n * Usage: wombo cleanup\n *\n * Kills tmux sessions, removes worktrees, removes state and log files.\n */\n\nimport { existsSync, unlinkSync, rmSync } from \"node:fs\";\nimport { execSync } from \"node:child_process\";\nimport { resolve } from \"node:path\";\nimport type { WomboConfig } from \"../config.js\";\nimport { killAllTmuxSessions } from \"../lib/launcher.js\";\nimport { cleanupAllWorktrees } from \"../lib/worktree.js\";\n\nexport interface CleanupOptions {\n  projectRoot: string;\n  config: WomboConfig;\n  dryRun?: boolean;\n}","truncated":false,"loaded":[]},"time":{"start":1773351519929,"end":1773351519935}}}}
{"type":"tool_use","timestamp":1773351520419,"sessionID":"ses_31c036dcfffeZBZKwd7xzopNEA","part":{"id":"prt_ce3fcc6bc001yFbPuqNPImx7b5","sessionID":"ses_31c036dcfffeZBZKwd7xzopNEA","messageID":"msg_ce3fcb02e001Jua2912S4gYIxa","type":"tool","callID":"toolu_vrtx_01QqYeybnMxbo8Q5Sy7wXTQF","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-cli-bugs/src/lib/validate.ts"},"output":"<path>/home/fulgidus/Documents/wombo-cli-bugs/src/lib/validate.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * validate.ts — Input validation / hardening for agent-ready CLI.\n3:  *\n4:  * All user/agent-supplied inputs pass through these validators at the CLI\n5:  * boundary. This prevents hallucinated inputs from corrupting state.\n6:  *\n7:  * Rules:\n8:  *   - Feature IDs: kebab-case only, no path traversals, no query params\n9:  *   - Branch names: no control chars, no \"..\", no spaces\n10:  *   - Free-text (titles, descriptions): no control chars except \\n \\t\n11:  *   - Effort strings: ISO 8601 duration pattern only\n12:  */\n13: \n14: // ---------------------------------------------------------------------------\n15: // Patterns\n16: // ---------------------------------------------------------------------------\n17: \n18: /** Valid feature/subtask ID: lowercase alphanumeric + hyphens, 1-128 chars */\n19: const ID_PATTERN = /^[a-z0-9][a-z0-9-]{0,127}$/;\n20: \n21: /** Control characters below space, excluding \\t (0x09) and \\n (0x0a) */\n22: const CONTROL_CHARS = /[\\x00-\\x08\\x0b\\x0c\\x0e-\\x1f\\x7f]/;\n23: \n24: /** Path traversal sequences */\n25: const PATH_TRAVERSAL = /\\.\\.\\//;\n26: \n27: /** Embedded query params or fragments */\n28: const QUERY_FRAGMENT = /[?#]/;\n29: \n30: /** Percent-encoded sequences (indicates double-encoding risk) */\n31: const PERCENT_ENCODED = /%[0-9a-fA-F]{2}/;\n32: \n33: /** ISO 8601 duration: P[nY][nM][nD][T[nH][nM][nS]] */\n34: const DURATION_PATTERN = /^P(?:\\d+Y)?(?:\\d+M)?(?:\\d+D)?(?:T(?:\\d+H)?(?:\\d+M)?(?:\\d+S)?)?$/;\n35: \n36: // ---------------------------------------------------------------------------\n37: // Result type\n38: // ---------------------------------------------------------------------------\n39: \n40: export interface ValidationResult {\n41:   valid: boolean;\n42:   error?: string;\n43: }\n44: \n45: function ok(): ValidationResult {\n46:   return { valid: true };\n47: }\n48: \n49: function fail(error: string): ValidationResult {\n50:   return { valid: false, error };\n51: }\n52: \n53: // ---------------------------------------------------------------------------\n54: // Validators\n55: // ---------------------------------------------------------------------------\n56: \n57: /**\n58:  * Validate a feature or subtask ID.\n59:  * Must be kebab-case, no traversals, no query params, no encoded chars.\n60:  */\n61: export function validateId(value: string, label: string = \"ID\"): ValidationResult {\n62:   if (!value || value.length === 0) {\n63:     return fail(`${label} must not be empty.`);\n64:   }\n65: \n66:   if (CONTROL_CHARS.test(value)) {\n67:     return fail(`${label} contains control characters.`);\n68:   }\n69: \n70:   if (PATH_TRAVERSAL.test(value)) {\n71:     return fail(`${label} contains path traversal sequence \"../\".`);\n72:   }\n73: \n74:   if (QUERY_FRAGMENT.test(value)) {\n75:     return fail(`${label} contains query/fragment characters (? or #).`);\n76:   }\n77: \n78:   if (PERCENT_ENCODED.test(value)) {\n79:     return fail(`${label} contains percent-encoded characters — possible double-encoding.`);\n80:   }\n81: \n82:   if (!ID_PATTERN.test(value)) {\n83:     return fail(\n84:       `${label} \"${value}\" is invalid. IDs must be kebab-case ` +\n85:       `(lowercase letters, digits, hyphens), 1–128 characters, starting with a letter or digit.`\n86:     );\n87:   }\n88: \n89:   return ok();\n90: }\n91: \n92: /**\n93:  * Validate free-text input (titles, descriptions, notes).\n94:  * Rejects control chars except \\t and \\n.\n95:  */\n96: export function validateText(value: string, label: string = \"text\"): ValidationResult {\n97:   if (CONTROL_CHARS.test(value)) {\n98:     return fail(`${label} contains control characters (non-printable bytes).`);\n99:   }\n100:   return ok();\n101: }\n102: \n103: /**\n104:  * Validate a branch name.\n105:  * No control chars, no \"..\", no spaces, no ~, ^, :, \\, ?, *, [\n106:  */\n107: export function validateBranchName(value: string, label: string = \"branch name\"): ValidationResult {\n108:   if (!value || value.length === 0) {\n109:     return fail(`${label} must not be empty.`);\n110:   }\n111: \n112:   if (CONTROL_CHARS.test(value)) {\n113:     return fail(`${label} contains control characters.`);\n114:   }\n115: \n116:   if (/\\.\\./.test(value)) {\n117:     return fail(`${label} contains \"..\" which is not allowed in git branch names.`);\n118:   }\n119: \n120:   if (/[ ~^:\\\\?*\\[]/.test(value)) {\n121:     return fail(`${label} contains characters not allowed in git branch names.`);\n122:   }\n123: \n124:   return ok();\n125: }\n126: \n127: /**\n128:  * Validate an ISO 8601 duration string.\n129:  */\n130: export function validateDuration(value: string, label: string = \"effort\"): ValidationResult {\n131:   if (!value || value.length === 0) {\n132:     return fail(`${label} must not be empty.`);\n133:   }\n134: \n135:   if (!DURATION_PATTERN.test(value)) {\n136:     return fail(\n137:       `${label} \"${value}\" is not a valid ISO 8601 duration. ` +\n138:       `Expected format: P[nY][nM][nD][T[nH][nM][nS]] (e.g., \"PT2H\", \"P1D\", \"P1DT4H30M\").`\n139:     );\n140:   }\n141: \n142:   return ok();\n143: }\n144: \n145: /**\n146:  * Validate a status value against the allowed set.\n147:  */\n148: export function validateEnum(\n149:   value: string,\n150:   allowed: readonly string[],\n151:   label: string = \"value\"\n152: ): ValidationResult {\n153:   if (!allowed.includes(value)) {\n154:     return fail(`${label} \"${value}\" is not valid. Allowed values: ${allowed.join(\", \")}`);\n155:   }\n156:   return ok();\n157: }\n158: \n159: // ---------------------------------------------------------------------------\n160: // Convenience: validate and exit on failure\n161: // ---------------------------------------------------------------------------\n162: \n163: /**\n164:  * Run a validation and exit with error message if invalid.\n165:  * For use at the CLI boundary.\n166:  */\n167: export function assertValid(result: ValidationResult): void {\n168:   if (!result.valid) {\n169:     console.error(`Validation error: ${result.error}`);\n170:     process.exit(1);\n171:   }\n172: }\n\n(End of file - total 172 lines)\n</content>","title":"src/lib/validate.ts","metadata":{"preview":"/**\n * validate.ts — Input validation / hardening for agent-ready CLI.\n *\n * All user/agent-supplied inputs pass through these validators at the CLI\n * boundary. This prevents hallucinated inputs from corrupting state.\n *\n * Rules:\n *   - Feature IDs: kebab-case only, no path traversals, no query params\n *   - Branch names: no control chars, no \"..\", no spaces\n *   - Free-text (titles, descriptions): no control chars except \\n \\t\n *   - Effort strings: ISO 8601 duration pattern only\n */\n\n// ---------------------------------------------------------------------------\n// Patterns\n// ---------------------------------------------------------------------------\n\n/** Valid feature/subtask ID: lowercase alphanumeric + hyphens, 1-128 chars */\nconst ID_PATTERN = /^[a-z0-9][a-z0-9-]{0,127}$/;\n","truncated":false,"loaded":[]},"time":{"start":1773351520369,"end":1773351520417}}}}
{"type":"tool_use","timestamp":1773351520851,"sessionID":"ses_31c036dcfffeZBZKwd7xzopNEA","part":{"id":"prt_ce3fcc87b001FY1fDadvVbMZIc","sessionID":"ses_31c036dcfffeZBZKwd7xzopNEA","messageID":"msg_ce3fcb02e001Jua2912S4gYIxa","type":"tool","callID":"toolu_vrtx_011F5zX6zc1GX5JZq76NznLF","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-cli-bugs/src/lib/output.ts"},"output":"<path>/home/fulgidus/Documents/wombo-cli-bugs/src/lib/output.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * output.ts — Shared output helpers for agent-ready CLI.\n3:  *\n4:  * Provides a centralized way for commands to emit structured data that\n5:  * renders as human-readable text on TTY or as JSON when --output json\n6:  * is specified (or when stdout is not a TTY).\n7:  *\n8:  * Usage in commands:\n9:  *   import { output, OutputFormat } from \"../lib/output.js\";\n10:  *\n11:  *   // At the end of a command:\n12:  *   output(format, data);           // emits JSON or human text\n13:  *   outputError(format, message);   // emits error in the right format\n14:  */\n15: \n16: // ---------------------------------------------------------------------------\n17: // Types\n18: // ---------------------------------------------------------------------------\n19: \n20: export type OutputFormat = \"text\" | \"json\";\n21: \n22: // ---------------------------------------------------------------------------\n23: // Helpers\n24: // ---------------------------------------------------------------------------\n25: \n26: /**\n27:  * Determine the output format. Priority:\n28:  *   1. Explicit --output flag value\n29:  *   2. WOMBO_OUTPUT env var (for agent pipelines)\n30:  *   3. Default to \"text\"\n31:  *\n32:  * Note: We intentionally do NOT auto-detect based on TTY. Many legitimate\n33:  * use cases (bun dev, piped to less/grep, CI) have non-TTY stdout but still\n34:  * want human output. Agents should explicitly pass --output json or set\n35:  * WOMBO_OUTPUT=json.\n36:  */\n37: export function resolveOutputFormat(explicit?: string): OutputFormat {\n38:   if (explicit === \"json\") return \"json\";\n39:   if (explicit === \"text\") return \"text\";\n40:   // Check env var for agent pipelines\n41:   const env = process.env.WOMBO_OUTPUT;\n42:   if (env === \"json\") return \"json\";\n43:   return \"text\";\n44: }\n45: \n46: /**\n47:  * Emit structured data. In JSON mode, outputs a single JSON line to stdout.\n48:  * In text mode, calls the provided textRenderer callback.\n49:  */\n50: export function output(\n51:   format: OutputFormat,\n52:   data: unknown,\n53:   textRenderer: () => void\n54: ): void {\n55:   if (format === \"json\") {\n56:     console.log(JSON.stringify(data));\n57:   } else {\n58:     textRenderer();\n59:   }\n60: }\n61: \n62: /**\n63:  * Emit an error. In JSON mode, outputs {\"error\": message} to stderr.\n64:  * In text mode, outputs the message to stderr normally.\n65:  */\n66: export function outputError(format: OutputFormat, message: string, exitCode: number = 1): never {\n67:   if (format === \"json\") {\n68:     console.error(JSON.stringify({ error: message }));\n69:   } else {\n70:     console.error(message);\n71:   }\n72:   process.exit(exitCode);\n73: }\n74: \n75: /**\n76:  * Emit a success/info message. In JSON mode, outputs {\"message\": msg, ...extra}.\n77:  * In text mode, outputs the message to stdout normally.\n78:  */\n79: export function outputMessage(\n80:   format: OutputFormat,\n81:   message: string,\n82:   extra?: Record<string, unknown>\n83: ): void {\n84:   if (format === \"json\") {\n85:     console.log(JSON.stringify({ message, ...extra }));\n86:   } else {\n87:     console.log(message);\n88:   }\n89: }\n90: \n91: // ---------------------------------------------------------------------------\n92: // Field filtering for compact output (--fields)\n93: // ---------------------------------------------------------------------------\n94: \n95: /**\n96:  * Filter an object to only include the specified fields.\n97:  * If fields is undefined/empty, returns the object unchanged.\n98:  */\n99: export function filterFields<T extends Record<string, unknown>>(\n100:   obj: T,\n101:   fields?: string[]\n102: ): Partial<T> {\n103:   if (!fields || fields.length === 0) return obj;\n104:   const result: Partial<T> = {};\n105:   for (const field of fields) {\n106:     if (field in obj) {\n107:       (result as any)[field] = (obj as any)[field];\n108:     }\n109:   }\n110:   return result;\n111: }\n112: \n113: /**\n114:  * Filter an array of objects to only include specified fields per object.\n115:  * If fields is undefined/empty, returns the array unchanged.\n116:  */\n117: export function filterFieldsArray<T extends Record<string, unknown>>(\n118:   arr: T[],\n119:   fields?: string[]\n120: ): Partial<T>[] {\n121:   if (!fields || fields.length === 0) return arr;\n122:   return arr.map((obj) => filterFields(obj, fields));\n123: }\n124: \n125: /**\n126:  * Render a compact text table from an array of objects with selected fields.\n127:  * Used for text-mode --fields output.\n128:  */\n129: export function renderCompactTable(\n130:   items: Record<string, unknown>[],\n131:   fields: string[]\n132: ): void {\n133:   if (items.length === 0) return;\n134: \n135:   // Calculate column widths\n136:   const widths: Record<string, number> = {};\n137:   for (const field of fields) {\n138:     widths[field] = field.length;\n139:     for (const item of items) {\n140:       const val = String(item[field] ?? \"\");\n141:       widths[field] = Math.max(widths[field], val.length);\n142:     }\n143:   }\n144: \n145:   // Header\n146:   const header = fields.map((f) => f.padEnd(widths[f])).join(\"  \");\n147:   console.log(header);\n148:   console.log(fields.map((f) => \"─\".repeat(widths[f])).join(\"  \"));\n149: \n150:   // Rows\n151:   for (const item of items) {\n152:     const row = fields.map((f) => String(item[f] ?? \"\").padEnd(widths[f])).join(\"  \");\n153:     console.log(row);\n154:   }\n155: }\n\n(End of file - total 155 lines)\n</content>","title":"src/lib/output.ts","metadata":{"preview":"/**\n * output.ts — Shared output helpers for agent-ready CLI.\n *\n * Provides a centralized way for commands to emit structured data that\n * renders as human-readable text on TTY or as JSON when --output json\n * is specified (or when stdout is not a TTY).\n *\n * Usage in commands:\n *   import { output, OutputFormat } from \"../lib/output.js\";\n *\n *   // At the end of a command:\n *   output(format, data);           // emits JSON or human text\n *   outputError(format, message);   // emits error in the right format\n */\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type OutputFormat = \"text\" | \"json\";","truncated":false,"loaded":[]},"time":{"start":1773351520834,"end":1773351520849}}}}
{"type":"tool_use","timestamp":1773351521402,"sessionID":"ses_31c036dcfffeZBZKwd7xzopNEA","part":{"id":"prt_ce3fcca9c001dMc5o1VUE1r7MU","sessionID":"ses_31c036dcfffeZBZKwd7xzopNEA","messageID":"msg_ce3fcb02e001Jua2912S4gYIxa","type":"tool","callID":"toolu_vrtx_01DqjwRj9npjurrUd8oQ5zW6","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-cli-bugs/src/lib/worktree.ts"},"output":"<path>/home/fulgidus/Documents/wombo-cli-bugs/src/lib/worktree.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * worktree.ts — Git worktree lifecycle management.\n3:  *\n4:  * Responsibilities:\n5:  *   - Create feature branches from a base branch\n6:  *   - Create git worktrees for each feature branch\n7:  *   - Run install command in worktrees\n8:  *   - List and remove worktrees\n9:  *   - Copy agent config files into worktrees\n10:  *\n11:  * IMPORTANT: Heavy operations (createWorktree, installDeps) are async\n12:  * to allow true parallelism with Promise.all.\n13:  */\n14: \n15: import { exec, execSync } from \"node:child_process\";\n16: import { existsSync, cpSync, statSync } from \"node:fs\";\n17: import { resolve, dirname, basename } from \"node:path\";\n18: import type { WomboConfig } from \"../config.js\";\n19: \n20: // ---------------------------------------------------------------------------\n21: // Types\n22: // ---------------------------------------------------------------------------\n23: \n24: export interface WorktreeInfo {\n25:   path: string;\n26:   branch: string;\n27:   head: string;\n28:   bare: boolean;\n29: }\n30: \n31: // ---------------------------------------------------------------------------\n32: // Diagnostic Logger\n33: // ---------------------------------------------------------------------------\n34: \n35: function ts(): string {\n36:   return new Date().toISOString().slice(11, 19); // HH:MM:SS\n37: }\n38: \n39: export function log(featureId: string, msg: string): void {\n40:   console.log(`  [${ts()}] ${featureId}: ${msg}`);\n41: }\n42: \n43: // ---------------------------------------------------------------------------\n44: // Async Command Runner\n45: // ---------------------------------------------------------------------------\n46: \n47: /**\n48:  * Run a command asynchronously. Returns stdout on success, throws on failure.\n49:  */\n50: function runAsync(\n51:   cmd: string,\n52:   opts?: { cwd?: string; timeoutMs?: number }\n53: ): Promise<string> {\n54:   return new Promise((resolve, reject) => {\n55:     exec(\n56:       cmd,\n57:       {\n58:         cwd: opts?.cwd,\n59:         encoding: \"utf-8\",\n60:         timeout: opts?.timeoutMs ?? 0,\n61:         maxBuffer: 10 * 1024 * 1024,\n62:       },\n63:       (error, stdout, stderr) => {\n64:         if (error) {\n65:           const errMsg = stderr?.trim() || stdout?.trim() || error.message;\n66:           reject(new Error(`Command failed: ${cmd}\\n${errMsg}`));\n67:         } else {\n68:           resolve((stdout ?? \"\").trim());\n69:         }\n70:       }\n71:     );\n72:   });\n73: }\n74: \n75: /**\n76:  * Synchronous run — only for quick, non-blocking operations.\n77:  */\n78: function runSync(\n79:   cmd: string,\n80:   opts?: { cwd?: string; silent?: boolean; timeoutMs?: number }\n81: ): string {\n82:   try {\n83:     return execSync(cmd, {\n84:       cwd: opts?.cwd,\n85:       encoding: \"utf-8\",\n86:       stdio: opts?.silent ? \"pipe\" : [\"pipe\", \"pipe\", \"pipe\"],\n87:       timeout: opts?.timeoutMs,\n88:       maxBuffer: 10 * 1024 * 1024,\n89:     }).trim();\n90:   } catch (err: any) {\n91:     const stderr = err.stderr?.toString().trim() || \"\";\n92:     const stdout = err.stdout?.toString().trim() || \"\";\n93:     throw new Error(\n94:       `Command failed: ${cmd}\\n${stderr || stdout || err.message}`\n95:     );\n96:   }\n97: }\n98: \n99: // ---------------------------------------------------------------------------\n100: // Branch Management\n101: // ---------------------------------------------------------------------------\n102: \n103: /**\n104:  * Create a feature branch from the base branch.\n105:  * If it already exists and is NOT checked out in a worktree, reset it.\n106:  * If it's checked out in a worktree, leave it alone (resume case).\n107:  */\n108: async function createBranch(\n109:   projectRoot: string,\n110:   branchName: string,\n111:   baseBranch: string\n112: ): Promise<void> {\n113:   const existing = await runAsync(\n114:     `git branch --list \"${branchName}\"`,\n115:     { cwd: projectRoot }\n116:   );\n117:   if (existing.trim()) {\n118:     // Branch exists — try to delete and recreate.\n119:     // If deletion fails (e.g. checked out in worktree), that's fine —\n120:     // we'll reuse the existing branch with its work intact.\n121:     try {\n122:       await runAsync(`git branch -D \"${branchName}\"`, { cwd: projectRoot });\n123:     } catch {\n124:       // Branch is checked out in a worktree — reuse as-is\n125:       return;\n126:     }\n127:   }\n128:   await runAsync(`git branch \"${branchName}\" \"${baseBranch}\"`, {\n129:     cwd: projectRoot,\n130:   });\n131: }\n132: \n133: /**\n134:  * Generate the branch name for a feature using config prefix.\n135:  */\n136: export function featureBranchName(\n137:   featureId: string,\n138:   config: WomboConfig\n139: ): string {\n140:   return `${config.git.branchPrefix}${featureId}`;\n141: }\n142: \n143: /**\n144:  * Generate the worktree path for a feature (sibling directory to project root).\n145:  */\n146: export function worktreePath(\n147:   projectRoot: string,\n148:   featureId: string,\n149:   config: WomboConfig\n150: ): string {\n151:   const parentDir = dirname(projectRoot);\n152:   return resolve(parentDir, `${config.git.worktreePrefix}${featureId}`);\n153: }\n154: \n155: // ---------------------------------------------------------------------------\n156: // Worktree Lifecycle (async)\n157: // ---------------------------------------------------------------------------\n158: \n159: /**\n160:  * Create a git worktree for a feature branch.\n161:  * Returns the absolute path to the worktree.\n162:  *\n163:  * If a valid worktree already exists at the expected path (has .git file),\n164:  * reuses it — this is essential for the resume case where worktrees have\n165:  * real work but may be missing node_modules.\n166:  */\n167: export async function createWorktree(\n168:   projectRoot: string,\n169:   featureId: string,\n170:   baseBranch: string,\n171:   config: WomboConfig\n172: ): Promise<string> {\n173:   const branch = featureBranchName(featureId, config);\n174:   const wtPath = worktreePath(projectRoot, featureId, config);\n175: \n176:   // If a valid worktree already exists, reuse it (resume case).\n177:   // A git worktree has a .git *file* (not directory) pointing to the main repo.\n178:   if (existsSync(wtPath) && existsSync(resolve(wtPath, \".git\"))) {\n179:     log(featureId, \"reusing existing worktree (has work)\");\n180:     // Still copy config files in case they're missing\n181:     copyConfigFiles(projectRoot, wtPath, featureId, config);\n182:     return wtPath;\n183:   }\n184: \n185:   // Create the branch if it doesn't exist\n186:   log(featureId, \"creating branch...\");\n187:   await createBranch(projectRoot, branch, baseBranch);\n188: \n189:   // Remove existing worktree directory if present but invalid\n190:   if (existsSync(wtPath)) {\n191:     log(featureId, \"removing old worktree...\");\n192:     try {\n193:       await runAsync(`git worktree remove --force \"${wtPath}\"`, {\n194:         cwd: projectRoot,\n195:       });\n196:     } catch {\n197:       await runAsync(`rm -rf \"${wtPath}\"`);\n198:       await runAsync(`git worktree prune`, { cwd: projectRoot });\n199:     }\n200:   }\n201: \n202:   // Create the worktree\n203:   log(featureId, \"creating worktree...\");\n204:   await runAsync(`git worktree add \"${wtPath}\" \"${branch}\"`, {\n205:     cwd: projectRoot,\n206:   });\n207: \n208:   // Copy agent config files into worktree\n209:   copyConfigFiles(projectRoot, wtPath, featureId, config);\n210: \n211:   log(featureId, \"worktree ready\");\n212:   return wtPath;\n213: }\n214: \n215: /**\n216:  * Copy agent config files from project root into a worktree.\n217:  * Best-effort — logs warnings but doesn't throw.\n218:  */\n219: function copyConfigFiles(\n220:   projectRoot: string,\n221:   wtPath: string,\n222:   featureId: string,\n223:   config: WomboConfig\n224: ): void {\n225:   for (const configFile of config.agent.configFiles) {\n226:     const srcPath = resolve(projectRoot, configFile);\n227:     if (!existsSync(srcPath)) continue;\n228: \n229:     const destPath = resolve(wtPath, configFile);\n230:     try {\n231:       const stat = statSync(srcPath);\n232:       if (stat.isDirectory()) {\n233:         cpSync(srcPath, destPath, { recursive: true });\n234:       } else {\n235:         cpSync(srcPath, destPath);\n236:       }\n237:     } catch {\n238:       // Non-critical — best effort\n239:     }\n240:   }\n241: \n242:   // Verify all config files were copied successfully\n243:   verifyConfigFiles(projectRoot, wtPath, featureId, config);\n244: }\n245: \n246: // ---------------------------------------------------------------------------\n247: // Config File Verification\n248: // ---------------------------------------------------------------------------\n249: \n250: /**\n251:  * Verify that all expected config files were copied into the worktree.\n252:  * Logs a warning for any that are missing. This is a safety net on top\n253:  * of the best-effort cpSync logic in createWorktree.\n254:  */\n255: function verifyConfigFiles(\n256:   projectRoot: string,\n257:   wtPath: string,\n258:   featureId: string,\n259:   config: WomboConfig\n260: ): void {\n261:   const missing: string[] = [];\n262: \n263:   for (const configFile of config.agent.configFiles) {\n264:     const srcPath = resolve(projectRoot, configFile);\n265:     const destPath = resolve(wtPath, configFile);\n266: \n267:     // Only check files/dirs that exist in the source project\n268:     if (!existsSync(srcPath)) continue;\n269: \n270:     if (!existsSync(destPath)) {\n271:       missing.push(configFile);\n272:     }\n273:   }\n274: \n275:   if (missing.length > 0) {\n276:     log(\n277:       featureId,\n278:       `\\x1b[33mWARNING\\x1b[0m: config files missing in worktree: ${missing.join(\", \")}`\n279:     );\n280:   }\n281: }\n282: \n283: /**\n284:  * Install dependencies in a worktree.\n285:  */\n286: export async function installDeps(\n287:   wtPath: string,\n288:   featureId: string,\n289:   config: WomboConfig\n290: ): Promise<void> {\n291:   log(featureId, `running ${config.install.command}...`);\n292:   const start = Date.now();\n293:   await runAsync(config.install.command, {\n294:     cwd: wtPath,\n295:     timeoutMs: config.install.timeout,\n296:   });\n297:   const elapsed = ((Date.now() - start) / 1000).toFixed(1);\n298:   log(featureId, `install done (${elapsed}s)`);\n299: }\n300: \n301: /**\n302:  * Check if a worktree already exists and has node_modules (fully ready).\n303:  */\n304: export function worktreeReady(wtPath: string): boolean {\n305:   return (\n306:     existsSync(wtPath) &&\n307:     existsSync(resolve(wtPath, \"node_modules\"))\n308:   );\n309: }\n310: \n311: /**\n312:  * Check if a valid git worktree exists at the path (may lack node_modules).\n313:  * A git worktree has a .git *file* (not directory) pointing to the main repo.\n314:  */\n315: export function worktreeExists(wtPath: string): boolean {\n316:   return existsSync(wtPath) && existsSync(resolve(wtPath, \".git\"));\n317: }\n318: \n319: // ---------------------------------------------------------------------------\n320: // Worktree Listing / Cleanup (sync)\n321: // ---------------------------------------------------------------------------\n322: \n323: /**\n324:  * List all git worktrees.\n325:  */\n326: export function listWorktrees(projectRoot: string): WorktreeInfo[] {\n327:   const output = runSync(\"git worktree list --porcelain\", {\n328:     cwd: projectRoot,\n329:     silent: true,\n330:   });\n331:   if (!output) return [];\n332: \n333:   const worktrees: WorktreeInfo[] = [];\n334:   let current: Partial<WorktreeInfo> = {};\n335: \n336:   for (const line of output.split(\"\\n\")) {\n337:     if (line.startsWith(\"worktree \")) {\n338:       if (current.path) worktrees.push(current as WorktreeInfo);\n339:       current = { path: line.slice(9), bare: false };\n340:     } else if (line.startsWith(\"HEAD \")) {\n341:       current.head = line.slice(5);\n342:     } else if (line.startsWith(\"branch \")) {\n343:       current.branch = line.slice(7).replace(\"refs/heads/\", \"\");\n344:     } else if (line === \"bare\") {\n345:       current.bare = true;\n346:     } else if (line === \"\" && current.path) {\n347:       worktrees.push(current as WorktreeInfo);\n348:       current = {};\n349:     }\n350:   }\n351:   if (current.path) worktrees.push(current as WorktreeInfo);\n352: \n353:   return worktrees;\n354: }\n355: \n356: /**\n357:  * List only wombo-related worktrees.\n358:  *\n359:  * SAFETY: Filters by checking that the *basename* of the worktree path\n360:  * starts with the worktreePrefix. A naive `.includes()` on the full path\n361:  * would match the main repo itself if its directory name contained the\n362:  * prefix (e.g. \"wombo-combo\" contains \"wombo-\"), causing cleanup to\n363:  * destroy the project root.\n364:  *\n365:  * Additionally, the main repo worktree (projectRoot) is always excluded\n366:  * as a defensive guard.\n367:  */\n368: export function listWomboWorktrees(\n369:   projectRoot: string,\n370:   config: WomboConfig\n371: ): WorktreeInfo[] {\n372:   const resolvedRoot = resolve(projectRoot);\n373:   return listWorktrees(projectRoot).filter((wt) => {\n374:     // Never include the main project root\n375:     if (resolve(wt.path) === resolvedRoot) return false;\n376:     // Match only worktrees whose directory name starts with the prefix\n377:     return basename(wt.path).startsWith(config.git.worktreePrefix);\n378:   });\n379: }\n380: \n381: /**\n382:  * Remove a worktree and optionally delete its branch.\n383:  *\n384:  * SAFETY: Refuses to remove the project root itself. This is a hard guard\n385:  * against bugs in worktree filtering that could otherwise destroy the main repo.\n386:  */\n387: export function removeWorktree(\n388:   projectRoot: string,\n389:   wtPath: string,\n390:   deleteBranchToo: boolean = true\n391: ): void {\n392:   // Hard safety check: never remove the main project root\n393:   if (resolve(wtPath) === resolve(projectRoot)) {\n394:     throw new Error(\n395:       `SAFETY: refusing to remove project root as worktree: ${wtPath}`\n396:     );\n397:   }\n398: \n399:   const worktrees = listWorktrees(projectRoot);\n400:   const wt = worktrees.find((w) => w.path === wtPath);\n401: \n402:   try {\n403:     runSync(`git worktree remove --force \"${wtPath}\"`, { cwd: projectRoot });\n404:   } catch {\n405:     if (existsSync(wtPath)) {\n406:       runSync(`rm -rf \"${wtPath}\"`);\n407:     }\n408:     runSync(\"git worktree prune\", { cwd: projectRoot });\n409:   }\n410: \n411:   if (deleteBranchToo && wt?.branch) {\n412:     try {\n413:       runSync(`git branch -D \"${wt.branch}\"`, {\n414:         cwd: projectRoot,\n415:         silent: true,\n416:       });\n417:     } catch {\n418:       // Branch may have been merged or already deleted\n419:     }\n420:   }\n421: }\n422: \n423: /**\n424:  * Check if a feature branch has any commits beyond the base branch.\n425:  * Returns true if the branch has diverged (i.e., the agent made commits).\n426:  */\n427: export function branchHasChanges(\n428:   projectRoot: string,\n429:   branch: string,\n430:   baseBranch: string\n431: ): boolean {\n432:   try {\n433:     const count = runSync(\n434:       `git rev-list --count \"${baseBranch}..${branch}\"`,\n435:       { cwd: projectRoot, silent: true }\n436:     );\n437:     return parseInt(count, 10) > 0;\n438:   } catch {\n439:     // If the branch doesn't exist or git fails, assume no changes\n440:     return false;\n441:   }\n442: }\n443: \n444: /**\n445:  * Remove all wombo-related worktrees and prune.\n446:  */\n447: export function cleanupAllWorktrees(\n448:   projectRoot: string,\n449:   config: WomboConfig\n450: ): number {\n451:   const womboWorktrees = listWomboWorktrees(projectRoot, config);\n452:   let removed = 0;\n453:   for (const wt of womboWorktrees) {\n454:     try {\n455:       removeWorktree(projectRoot, wt.path, false);\n456:       removed++;\n457:     } catch (err: any) {\n458:       console.error(`Failed to remove worktree ${wt.path}: ${err.message}`);\n459:     }\n460:   }\n461:   try {\n462:     runSync(\"git worktree prune\", { cwd: projectRoot });\n463:   } catch {\n464:     // Prune is best-effort — may fail if repo state is already clean\n465:   }\n466:   return removed;\n467: }\n\n(End of file - total 467 lines)\n</content>","title":"src/lib/worktree.ts","metadata":{"preview":"/**\n * worktree.ts — Git worktree lifecycle management.\n *\n * Responsibilities:\n *   - Create feature branches from a base branch\n *   - Create git worktrees for each feature branch\n *   - Run install command in worktrees\n *   - List and remove worktrees\n *   - Copy agent config files into worktrees\n *\n * IMPORTANT: Heavy operations (createWorktree, installDeps) are async\n * to allow true parallelism with Promise.all.\n */\n\nimport { exec, execSync } from \"node:child_process\";\nimport { existsSync, cpSync, statSync } from \"node:fs\";\nimport { resolve, dirname, basename } from \"node:path\";\nimport type { WomboConfig } from \"../config.js\";\n\n// ---------------------------------------------------------------------------","truncated":false,"loaded":[]},"time":{"start":1773351521386,"end":1773351521400}}}}
{"type":"text","timestamp":1773351521794,"sessionID":"ses_31c036dcfffeZBZKwd7xzopNEA","part":{"id":"prt_ce3fcb6c6001gApKjfhKZnfU2Q","sessionID":"ses_31c036dcfffeZBZKwd7xzopNEA","messageID":"msg_ce3fcb02e001Jua2912S4gYIxa","type":"text","text":"Now let me read all the key files that need to be modified:","time":{"start":1773351521788,"end":1773351521788}}}
{"type":"tool_use","timestamp":1773351521815,"sessionID":"ses_31c036dcfffeZBZKwd7xzopNEA","part":{"id":"prt_ce3fcccc7001uvykZ5c8wvRAej","sessionID":"ses_31c036dcfffeZBZKwd7xzopNEA","messageID":"msg_ce3fcb02e001Jua2912S4gYIxa","type":"tool","callID":"toolu_vrtx_019WAitSCY6xDLWGUt5rWYHr","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-cli-bugs/src/commands/upgrade.ts"},"output":"<path>/home/fulgidus/Documents/wombo-cli-bugs/src/commands/upgrade.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * upgrade.ts — Self-upgrade wombo from GitHub.\n3:  *\n4:  * Usage:\n5:  *   wombo upgrade              # Check for updates and prompt to install\n6:  *   wombo upgrade --force      # Skip confirmation prompt\n7:  *   wombo upgrade --version v0.1.0  # Install a specific version\n8:  *   wombo upgrade --check      # Only check, don't install\n9:  */\n10: \n11: import { readFileSync } from \"node:fs\";\n12: import { resolve } from \"node:path\";\n13: import { createInterface } from \"node:readline\";\n14: \n15: // ---------------------------------------------------------------------------\n16: // Types\n17: // ---------------------------------------------------------------------------\n18: \n19: export interface UpgradeOptions {\n20:   force: boolean;\n21:   version?: string;\n22:   checkOnly: boolean;\n23: }\n24: \n25: // ---------------------------------------------------------------------------\n26: // Helpers\n27: // ---------------------------------------------------------------------------\n28: \n29: const REPO = \"fulgidus/wombo\";\n30: \n31: /**\n32:  * Get the locally installed version from package.json.\n33:  * Uses import.meta to find the package.json relative to this source file,\n34:  * which works whether running from local source or global install.\n35:  */\n36: function getLocalVersion(): string {\n37:   const pkgPath = resolve(import.meta.dir, \"../../package.json\");\n38:   const raw = readFileSync(pkgPath, \"utf-8\");\n39:   return JSON.parse(raw).version as string;\n40: }\n41: \n42: /**\n43:  * Fetch all v* tags from the remote GitHub repo using git ls-remote.\n44:  * Returns tags sorted by semver descending (latest first).\n45:  */\n46: async function fetchRemoteTags(): Promise<string[]> {\n47:   const proc = Bun.spawn([\"git\", \"ls-remote\", \"--tags\", `https://github.com/${REPO}.git`], {\n48:     stdout: \"pipe\",\n49:     stderr: \"pipe\",\n50:   });\n51: \n52:   const stdout = await new Response(proc.stdout).text();\n53:   const exitCode = await proc.exited;\n54: \n55:   if (exitCode !== 0) {\n56:     const stderr = await new Response(proc.stderr).text();\n57:     throw new Error(`Failed to fetch remote tags: ${stderr.trim()}`);\n58:   }\n59: \n60:   // Parse lines like: \"abc123\\trefs/tags/v0.0.1\"\n61:   const tags: string[] = [];\n62:   for (const line of stdout.split(\"\\n\")) {\n63:     const match = line.match(/refs\\/tags\\/(v\\d+\\.\\d+\\.\\d+)$/);\n64:     if (match) {\n65:       tags.push(match[1]);\n66:     }\n67:   }\n68: \n69:   // Sort descending by semver\n70:   tags.sort((a, b) => {\n71:     const pa = a.slice(1).split(\".\").map(Number);\n72:     const pb = b.slice(1).split(\".\").map(Number);\n73:     for (let i = 0; i < 3; i++) {\n74:       if (pa[i] !== pb[i]) return pb[i] - pa[i];\n75:     }\n76:     return 0;\n77:   });\n78: \n79:   return tags;\n80: }\n81: \n82: /**\n83:  * Compare two semver strings. Returns:\n84:  *   -1 if a < b\n85:  *    0 if a === b\n86:  *    1 if a > b\n87:  */\n88: function compareSemver(a: string, b: string): number {\n89:   const pa = a.replace(/^v/, \"\").split(\".\").map(Number);\n90:   const pb = b.replace(/^v/, \"\").split(\".\").map(Number);\n91:   for (let i = 0; i < 3; i++) {\n92:     if (pa[i] < pb[i]) return -1;\n93:     if (pa[i] > pb[i]) return 1;\n94:   }\n95:   return 0;\n96: }\n97: \n98: /**\n99:  * Prompt the user for yes/no confirmation.\n100:  */\n101: async function confirm(message: string): Promise<boolean> {\n102:   if (!process.stdin.isTTY) return false;\n103: \n104:   const rl = createInterface({ input: process.stdin, output: process.stdout });\n105:   return new Promise<boolean>((resolve) => {\n106:     rl.question(`${message} [y/N] `, (answer) => {\n107:       rl.close();\n108:       resolve(answer.trim().toLowerCase() === \"y\");\n109:     });\n110:   });\n111: }\n112: \n113: // ---------------------------------------------------------------------------\n114: // Command\n115: // ---------------------------------------------------------------------------\n116: \n117: export async function cmdUpgrade(opts: UpgradeOptions): Promise<void> {\n118:   const localVersion = getLocalVersion();\n119:   console.log(`Current version: v${localVersion}`);\n120: \n121:   // If a specific version is requested, skip the check\n122:   if (opts.version) {\n123:     const targetTag = opts.version.startsWith(\"v\") ? opts.version : `v${opts.version}`;\n124:     console.log(`Requested version: ${targetTag}`);\n125: \n126:     if (compareSemver(localVersion, targetTag) === 0) {\n127:       console.log(\"Already at the requested version.\");\n128:       return;\n129:     }\n130: \n131:     if (!opts.force) {\n132:       const ok = await confirm(`Install ${targetTag}?`);\n133:       if (!ok) {\n134:         console.log(\"Upgrade cancelled.\");\n135:         return;\n136:       }\n137:     }\n138: \n139:     await installVersion(targetTag);\n140:     return;\n141:   }\n142: \n143:   // Fetch latest from GitHub\n144:   console.log(`Checking for updates from github.com/${REPO}...`);\n145: \n146:   let tags: string[];\n147:   try {\n148:     tags = await fetchRemoteTags();\n149:   } catch (err: any) {\n150:     console.error(`Failed to check for updates: ${err.message}`);\n151:     process.exit(1);\n152:     return;\n153:   }\n154: \n155:   if (tags.length === 0) {\n156:     console.error(\"No release tags found on the remote repository.\");\n157:     process.exit(1);\n158:     return;\n159:   }\n160: \n161:   const latestTag = tags[0];\n162:   const latestVersion = latestTag.slice(1); // strip 'v'\n163:   console.log(`Latest version:  ${latestTag}`);\n164: \n165:   const cmp = compareSemver(localVersion, latestVersion);\n166:   if (cmp >= 0) {\n167:     console.log(\"You are already up to date.\");\n168:     return;\n169:   }\n170: \n171:   if (opts.checkOnly) {\n172:     console.log(`\\nUpdate available: v${localVersion} → ${latestTag}`);\n173:     console.log(`Run 'wombo upgrade' to install.`);\n174:     return;\n175:   }\n176: \n177:   console.log(`\\nUpdate available: v${localVersion} → ${latestTag}`);\n178: \n179:   if (!opts.force) {\n180:     const ok = await confirm(`Upgrade to ${latestTag}?`);\n181:     if (!ok) {\n182:       console.log(\"Upgrade cancelled.\");\n183:       return;\n184:     }\n185:   }\n186: \n187:   await installVersion(latestTag);\n188: }\n189: \n190: async function installVersion(tag: string): Promise<void> {\n191:   console.log(`\\nInstalling wombo@${tag}...`);\n192: \n193:   const proc = Bun.spawn(\n194:     [\"bun\", \"install\", \"-g\", `github:${REPO}#${tag}`],\n195:     {\n196:       stdout: \"inherit\",\n197:       stderr: \"inherit\",\n198:     }\n199:   );\n200: \n201:   const exitCode = await proc.exited;\n202: \n203:   if (exitCode !== 0) {\n204:     console.error(`\\nInstallation failed (exit code ${exitCode}).`);\n205:     process.exit(1);\n206:     return;\n207:   }\n208: \n209:   console.log(`\\nSuccessfully upgraded to ${tag}.`);\n210: }\n\n(End of file - total 210 lines)\n</content>","title":"src/commands/upgrade.ts","metadata":{"preview":"/**\n * upgrade.ts — Self-upgrade wombo from GitHub.\n *\n * Usage:\n *   wombo upgrade              # Check for updates and prompt to install\n *   wombo upgrade --force      # Skip confirmation prompt\n *   wombo upgrade --version v0.1.0  # Install a specific version\n *   wombo upgrade --check      # Only check, don't install\n */\n\nimport { readFileSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\nimport { createInterface } from \"node:readline\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface UpgradeOptions {\n  force: boolean;","truncated":false,"loaded":[]},"time":{"start":1773351521776,"end":1773351521813}}}}
