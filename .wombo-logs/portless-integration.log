ost_avoided\": {\n      \"claude_opus_4_6\": 2.4807,\n      \"claude_sonnet_4_6\": 1.4884,\n      \"claude_haiku_4_5\": 0.4961,\n      \"gpt5_latest\": 4.9614\n    },\n    \"powered_by\": \"jcodemunch-mcp by jgravelle \\u00b7 https://github.com/jgravelle/jcodemunch-mcp\"\n  }\n}","title":"","metadata":{"truncated":false},"time":{"start":1773351517457,"end":1773351517465},"attachments":[]}}}
