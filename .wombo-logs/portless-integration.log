{"type":"tool_use","timestamp":1773351520686,"sessionID":"ses_31c036dc4ffejmXOCp5uBNFg7f","part":{"id":"prt_ce3fcc6bb001lAHzdFHrhiig5a","sessionID":"ses_31c036dc4ffejmXOCp5uBNFg7f","messageID":"msg_ce3fcbd34001QvnmYVUTtx33ZC","type":"tool","callID":"toolu_vrtx_01M9bArELkhWjZf4XE3Kiz3s","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-portless-integration/src/lib/launcher.ts"},"output":"<path>/home/fulgidus/Documents/wombo-portless-integration/src/lib/launcher.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * launcher.ts — Process spawning and tmux session management.\n3:  *\n4:  * Responsibilities:\n5:  *   - Launch agent in headless mode (agent run --format json)\n6:  *   - Launch agent in interactive mode (tmux session with TUI)\n7:  *   - Resume sessions for auto-retry\n8:  *   - Manage tmux sessions (create, list, kill)\n9:  */\n10: \n11: import { spawn, execSync, type ChildProcess } from \"node:child_process\";\n12: import { writeFileSync, unlinkSync } from \"node:fs\";\n13: import type { WomboConfig } from \"../config.js\";\n14: import { resolveAgentBin } from \"../config.js\";\n15: \n16: // ---------------------------------------------------------------------------\n17: // Types\n18: // ---------------------------------------------------------------------------\n19: \n20: export interface LaunchResult {\n21:   pid: number;\n22:   process: ChildProcess;\n23:   sessionId?: string;\n24: }\n25: \n26: export interface LaunchOptions {\n27:   worktreePath: string;\n28:   featureId: string;\n29:   prompt: string;\n30:   model?: string;\n31:   interactive?: boolean;\n32:   config: WomboConfig;\n33: }\n34: \n35: export interface RetryOptions {\n36:   worktreePath: string;\n37:   featureId: string;\n38:   sessionId: string;\n39:   buildErrors: string;\n40:   model?: string;\n41:   interactive?: boolean;\n42:   config: WomboConfig;\n43: }\n44: \n45: // ---------------------------------------------------------------------------\n46: // Helpers\n47: // ---------------------------------------------------------------------------\n48: \n49: function tmuxSessionName(featureId: string, config: WomboConfig): string {\n50:   return `${config.agent.tmuxPrefix}-${featureId}`;\n51: }\n52: \n53: function runSilent(cmd: string): string {\n54:   try {\n55:     return execSync(cmd, { encoding: \"utf-8\", stdio: \"pipe\" }).trim();\n56:   } catch {\n57:     return \"\";\n58:   }\n59: }\n60: \n61: // ---------------------------------------------------------------------------\n62: // Headless Launch\n63: // ---------------------------------------------------------------------------\n64: \n65: /**\n66:  * Launch agent in headless mode with JSON output.\n67:  */\n68: export function launchHeadless(opts: LaunchOptions): LaunchResult {\n69:   const agentBin = resolveAgentBin(opts.config);\n70: \n71:   const args = [\n72:     \"run\",\n73:     \"--format\", \"json\",\n74:     \"--agent\", opts.config.agent.name,\n75:     \"--dir\", opts.worktreePath,\n76:     \"--title\", `wombo: ${opts.featureId}`,\n77:   ];\n78: \n79:   if (opts.model) {\n80:     args.push(\"--model\", opts.model);\n81:   }\n82: \n83:   args.push(opts.prompt);\n84: \n85:   const child = spawn(agentBin, args, {\n86:     stdio: [\"pipe\", \"pipe\", \"pipe\"],\n87:     detached: false,\n88:     env: {\n89:       ...process.env,\n90:       OPENCODE_DIR: opts.worktreePath,\n91:     },\n92:   });\n93: \n94:   // Close stdin so agent starts processing immediately\n95:   child.stdin?.end();\n96: \n97:   return {\n98:     pid: child.pid!,\n99:     process: child,\n100:   };\n101: }\n102: \n103: /**\n104:  * Resume a headless session with a retry message (build errors).\n105:  */\n106: export function retryHeadless(opts: RetryOptions): LaunchResult {\n107:   const agentBin = resolveAgentBin(opts.config);\n108: \n109:   const retryMessage = `The build failed. Please fix the following errors and run \\`${opts.config.build.command}\\` again:\\n\\n\\`\\`\\`\\n${opts.buildErrors}\\n\\`\\`\\`\\n\\nFix all errors, then verify the build passes.`;\n110: \n111:   const args = [\n112:     \"run\",\n113:     \"--format\", \"json\",\n114:     \"--session\", opts.sessionId,\n115:     \"--continue\",\n116:     \"--dir\", opts.worktreePath,\n117:   ];\n118: \n119:   if (opts.model) {\n120:     args.push(\"--model\", opts.model);\n121:   }\n122: \n123:   args.push(retryMessage);\n124: \n125:   const child = spawn(agentBin, args, {\n126:     stdio: [\"pipe\", \"pipe\", \"pipe\"],\n127:     detached: false,\n128:     env: {\n129:       ...process.env,\n130:       OPENCODE_DIR: opts.worktreePath,\n131:     },\n132:   });\n133: \n134:   child.stdin?.end();\n135: \n136:   return {\n137:     pid: child.pid!,\n138:     process: child,\n139:   };\n140: }\n141: \n142: // ---------------------------------------------------------------------------\n143: // Conflict Resolution Launch\n144: // ---------------------------------------------------------------------------\n145: \n146: export interface ConflictResolverOptions {\n147:   worktreePath: string;\n148:   featureId: string;\n149:   prompt: string;\n150:   model?: string;\n151:   config: WomboConfig;\n152: }\n153: \n154: /**\n155:  * Launch a headless agent to resolve merge conflicts.\n156:  *\n157:  * This is similar to `launchHeadless`, but the prompt is a conflict-resolution\n158:  * prompt generated by `generateConflictResolutionPrompt()`. The agent runs in\n159:  * the feature worktree where `git merge <baseBranch>` has already been run,\n160:  * leaving conflict markers in the working tree.\n161:  */\n162: export function launchConflictResolver(opts: ConflictResolverOptions): LaunchResult {\n163:   const agentBin = resolveAgentBin(opts.config);\n164: \n165:   const args = [\n166:     \"run\",\n167:     \"--format\", \"json\",\n168:     \"--agent\", opts.config.agent.name,\n169:     \"--dir\", opts.worktreePath,\n170:     \"--title\", `wombo: conflict-resolve ${opts.featureId}`,\n171:   ];\n172: \n173:   if (opts.model) {\n174:     args.push(\"--model\", opts.model);\n175:   }\n176: \n177:   args.push(opts.prompt);\n178: \n179:   const child = spawn(agentBin, args, {\n180:     stdio: [\"pipe\", \"pipe\", \"pipe\"],\n181:     detached: false,\n182:     env: {\n183:       ...process.env,\n184:       OPENCODE_DIR: opts.worktreePath,\n185:     },\n186:   });\n187: \n188:   child.stdin?.end();\n189: \n190:   return {\n191:     pid: child.pid!,\n192:     process: child,\n193:   };\n194: }\n195: \n196: // ---------------------------------------------------------------------------\n197: // Interactive (tmux) Launch\n198: // ---------------------------------------------------------------------------\n199: \n200: /**\n201:  * Launch agent in a tmux session for interactive use.\n202:  */\n203: export function launchInteractive(opts: LaunchOptions): LaunchResult {\n204:   const agentBin = resolveAgentBin(opts.config);\n205:   const sessionName = tmuxSessionName(opts.featureId, opts.config);\n206: \n207:   // Kill existing session if any\n208:   killTmuxSession(opts.featureId, opts.config);\n209: \n210:   // Build the agent command to run inside tmux\n211:   const ocArgs = [\n212:     agentBin,\n213:     \"--dir\", JSON.stringify(opts.worktreePath),\n214:   ];\n215: \n216:   if (opts.model) {\n217:     ocArgs.push(\"--model\", JSON.stringify(opts.model));\n218:   }\n219: \n220:   const tmuxCmd = ocArgs.join(\" \");\n221: \n222:   // Create a detached tmux session running the agent\n223:   execSync(\n224:     `tmux new-session -d -s \"${sessionName}\" -c \"${opts.worktreePath}\" \"${tmuxCmd}\"`,\n225:     { stdio: \"pipe\" }\n226:   );\n227: \n228:   // Send the prompt as initial message after a brief delay\n229:   setTimeout(() => {\n230:     try {\n231:       const tmpFile = `/tmp/wombo-prompt-${opts.featureId}.txt`;\n232:       writeFileSync(tmpFile, opts.prompt);\n233:       execSync(`tmux load-buffer \"${tmpFile}\"`, { stdio: \"pipe\" });\n234:       execSync(`tmux paste-buffer -t \"${sessionName}\"`, { stdio: \"pipe\" });\n235:       execSync(`tmux send-keys -t \"${sessionName}\" Enter`, { stdio: \"pipe\" });\n236:       try { unlinkSync(tmpFile); } catch {}\n237:     } catch {\n238:       // If prompt sending fails, user can type manually\n239:     }\n240:   }, 3000);\n241: \n242:   // Get the PID of the tmux server pane process\n243:   const panePid = runSilent(\n244:     `tmux list-panes -t \"${sessionName}\" -F \"#{pane_pid}\"`\n245:   );\n246: \n247:   return {\n248:     pid: parseInt(panePid) || 0,\n249:     process: null as any, // No direct process handle in tmux mode\n250:   };\n251: }\n252: \n253: /**\n254:  * Resume an interactive session with retry message.\n255:  */\n256: export function retryInteractive(opts: RetryOptions): LaunchResult {\n257:   const sessionName = tmuxSessionName(opts.featureId, opts.config);\n258: \n259:   const exists = tmuxSessionExists(opts.featureId, opts.config);\n260: \n261:   if (exists) {\n262:     const retryMsg = `The build failed. Fix these errors:\\n${opts.buildErrors}`;\n263:     const tmpFile = `/tmp/wombo-retry-${opts.featureId}.txt`;\n264:     writeFileSync(tmpFile, retryMsg);\n265:     execSync(`tmux load-buffer \"${tmpFile}\"`, { stdio: \"pipe\" });\n266:     execSync(`tmux paste-buffer -t \"${sessionName}\"`, { stdio: \"pipe\" });\n267:     execSync(`tmux send-keys -t \"${sessionName}\" Enter`, { stdio: \"pipe\" });\n268:     try { unlinkSync(tmpFile); } catch {}\n269: \n270:     const panePid = runSilent(\n271:       `tmux list-panes -t \"${sessionName}\" -F \"#{pane_pid}\"`\n272:     );\n273: \n274:     return {\n275:       pid: parseInt(panePid) || 0,\n276:       process: null as any,\n277:     };\n278:   }\n279: \n280:   // Session doesn't exist — launch a new interactive session\n281:   return launchInteractive({\n282:     worktreePath: opts.worktreePath,\n283:     featureId: opts.featureId,\n284:     prompt: `Continue from session ${opts.sessionId}. The build failed:\\n${opts.buildErrors}\\n\\nFix all errors and verify the build passes.`,\n285:     model: opts.model,\n286:     interactive: true,\n287:     config: opts.config,\n288:   });\n289: }\n290: \n291: // ---------------------------------------------------------------------------\n292: // tmux Session Management\n293: // ---------------------------------------------------------------------------\n294: \n295: /**\n296:  * Check if a tmux session exists for a feature.\n297:  */\n298: export function tmuxSessionExists(\n299:   featureId: string,\n300:   config: WomboConfig\n301: ): boolean {\n302:   const sessionName = tmuxSessionName(featureId, config);\n303:   return runSilent(`tmux has-session -t \"${sessionName}\" 2>/dev/null && echo yes`) === \"yes\";\n304: }\n305: \n306: /**\n307:  * Kill a tmux session for a feature.\n308:  */\n309: export function killTmuxSession(\n310:   featureId: string,\n311:   config: WomboConfig\n312: ): void {\n313:   const sessionName = tmuxSessionName(featureId, config);\n314:   runSilent(`tmux kill-session -t \"${sessionName}\" 2>/dev/null`);\n315: }\n316: \n317: /**\n318:  * List all wombo-related tmux sessions.\n319:  */\n320: export function listTmuxSessions(config: WomboConfig): string[] {\n321:   const output = runSilent(\n322:     `tmux list-sessions -F \"#{session_name}\" 2>/dev/null`\n323:   );\n324:   if (!output) return [];\n325:   return output\n326:     .split(\"\\n\")\n327:     .filter((s) => s.startsWith(config.agent.tmuxPrefix + \"-\"));\n328: }\n329: \n330: /**\n331:  * Kill all wombo-related tmux sessions.\n332:  */\n333: export function killAllTmuxSessions(config: WomboConfig): number {\n334:   const sessions = listTmuxSessions(config);\n335:   for (const s of sessions) {\n336:     runSilent(`tmux kill-session -t \"${s}\" 2>/dev/null`);\n337:   }\n338:   return sessions.length;\n339: }\n340: \n341: /**\n342:  * Check if a process is still running by PID.\n343:  */\n344: export function isProcessRunning(pid: number): boolean {\n345:   if (!pid || pid <= 0) return false;\n346:   try {\n347:     process.kill(pid, 0);\n348:     return true;\n349:   } catch {\n350:     return false;\n351:   }\n352: }\n\n(End of file - total 352 lines)\n</content>","title":"src/lib/launcher.ts","metadata":{"preview":"/**\n * launcher.ts — Process spawning and tmux session management.\n *\n * Responsibilities:\n *   - Launch agent in headless mode (agent run --format json)\n *   - Launch agent in interactive mode (tmux session with TUI)\n *   - Resume sessions for auto-retry\n *   - Manage tmux sessions (create, list, kill)\n */\n\nimport { spawn, execSync, type ChildProcess } from \"node:child_process\";\nimport { writeFileSync, unlinkSync } from \"node:fs\";\nimport type { WomboConfig } from \"../config.js\";\nimport { resolveAgentBin } from \"../config.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface LaunchResult {","truncated":false,"loaded":[]},"time":{"start":1773351520667,"end":1773351520683}}}}
{"type":"tool_use","timestamp":1773351521294,"sessionID":"ses_31c036dc4ffejmXOCp5uBNFg7f","part":{"id":"prt_ce3fcc9fe001r6Oij3DD0BINtr","sessionID":"ses_31c036dc4ffejmXOCp5uBNFg7f","messageID":"msg_ce3fcbd34001QvnmYVUTtx33ZC","type":"tool","callID":"toolu_vrtx_01UepaQ1UVzBfA46d9mBpDEE","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-portless-integration/src/lib/prompt.ts"},"output":"<path>/home/fulgidus/Documents/wombo-portless-integration/src/lib/prompt.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * prompt.ts — Generate agent prompts from feature specs.\n3:  *\n4:  * Responsibilities:\n5:  *   - Transform a Feature into a structured prompt for the agent\n6:  *   - Include feature spec, subtasks, constraints, forbidden items, references\n7:  *   - Generate the build command and success criteria\n8:  *   - All project-specific values come from config (no hardcoded Astro references)\n9:  */\n10: \n11: import type { Feature, Subtask } from \"./features.js\";\n12: import { formatDuration, parseDurationMinutes } from \"./features.js\";\n13: import type { WomboConfig } from \"../config.js\";\n14: \n15: // ---------------------------------------------------------------------------\n16: // Prompt Generation\n17: // ---------------------------------------------------------------------------\n18: \n19: /**\n20:  * Generate the full prompt for an autonomous agent working on a feature.\n21:  */\n22: export function generatePrompt(\n23:   feature: Feature,\n24:   baseBranch: string,\n25:   config: WomboConfig\n26: ): string {\n27:   const sections: string[] = [];\n28: \n29:   // Header\n30:   sections.push(`# Feature Implementation: ${feature.title}`);\n31:   sections.push(`**Feature ID:** \\`${feature.id}\\``);\n32:   sections.push(`**Branch:** \\`${config.git.branchPrefix}${feature.id}\\``);\n33:   sections.push(`**Base:** \\`${baseBranch}\\``);\n34:   sections.push(\n35:     `**Estimated Effort:** ${formatDuration(parseDurationMinutes(feature.effort))}`\n36:   );\n37:   sections.push(\n38:     `**Difficulty:** ${feature.difficulty} | **Priority:** ${feature.priority}`\n39:   );\n40: \n41:   // Description\n42:   sections.push(`\\n## Description\\n`);\n43:   sections.push(feature.description.trim());\n44: \n45:   // Subtasks\n46:   if (feature.subtasks.length > 0) {\n47:     sections.push(`\\n## Subtasks\\n`);\n48:     sections.push(\n49:       \"Complete these in order. Mark each done with a commit when finished.\\n\"\n50:     );\n51:     for (let i = 0; i < feature.subtasks.length; i++) {\n52:       sections.push(formatSubtask(feature.subtasks[i], i + 1, 0));\n53:     }\n54:   }\n55: \n56:   // Constraints\n57:   if (feature.constraints.length > 0) {\n58:     sections.push(`\\n## Constraints\\n`);\n59:     sections.push(\n60:       \"You MUST follow these constraints. Violating any is a failure.\\n\"\n61:     );\n62:     for (const c of feature.constraints) {\n63:       sections.push(`- ${c}`);\n64:     }\n65:   }\n66: \n67:   // Forbidden\n68:   if (feature.forbidden.length > 0) {\n69:     sections.push(`\\n## Forbidden\\n`);\n70:     sections.push(\n71:       \"You MUST NOT do any of the following. Violating any is a failure.\\n\"\n72:     );\n73:     for (const f of feature.forbidden) {\n74:       sections.push(`- ${f}`);\n75:     }\n76:   }\n77: \n78:   // References (files to explore)\n79:   if (feature.references.length > 0) {\n80:     sections.push(`\\n## Key Files to Explore\\n`);\n81:     sections.push(\n82:       \"Start by reading these files to understand the current state:\\n\"\n83:     );\n84:     for (const r of feature.references) {\n85:       sections.push(`- \\`${r}\\``);\n86:     }\n87:   }\n88: \n89:   // Notes\n90:   if (feature.notes.length > 0) {\n91:     sections.push(`\\n## Planning Notes\\n`);\n92:     for (const n of feature.notes) {\n93:       sections.push(`- ${n}`);\n94:     }\n95:   }\n96: \n97:   // Build verification — uses config, no hardcoded Astro command\n98:   sections.push(`\\n## Build Verification\\n`);\n99:   sections.push(\n100:     \"After completing all changes, run the build to verify everything works:\\n\"\n101:   );\n102:   sections.push(\"```bash\");\n103:   sections.push(config.build.command);\n104:   sections.push(\"```\\n\");\n105:   sections.push(\n106:     \"If the build fails, fix the errors before considering the task complete.\"\n107:   );\n108: \n109:   // Commit guidelines\n110:   sections.push(`\\n## Commit Guidelines\\n`);\n111:   sections.push(\"- Use conventional commits: `feat(scope):`, `fix(scope):`, `refactor(scope):`, `docs(scope):`\");\n112:   sections.push(`- Scope should be: \\`${feature.id}\\` or a relevant module name`);\n113:   sections.push(\"- Commit after each logical unit of work (roughly per subtask)\");\n114:   sections.push(\"- Do NOT squash all changes into one commit\");\n115:   sections.push(\"- Do NOT push to remote -- the orchestrator handles that\");\n116:   sections.push(`- Do NOT modify \\`${config.featuresFile}\\` -- the orchestrator handles that`);\n117: \n118:   // Final instruction\n119:   sections.push(`\\n## Execution\\n`);\n120:   sections.push(\"1. Read the key files listed above to understand the codebase\");\n121:   sections.push(\"2. Create a plan (use the TodoWrite tool)\");\n122:   sections.push(\"3. Implement each subtask, committing as you go\");\n123:   sections.push(`4. Run \\`${config.build.command}\\` to verify`);\n124:   sections.push(\"5. If the build passes, you are done\");\n125:   sections.push(\"6. If the build fails, fix the errors and re-run until it passes\");\n126: \n127:   return sections.join(\"\\n\");\n128: }\n129: \n130: // ---------------------------------------------------------------------------\n131: // Subtask Formatting\n132: // ---------------------------------------------------------------------------\n133: \n134: // ---------------------------------------------------------------------------\n135: // Conflict Resolution Prompt\n136: // ---------------------------------------------------------------------------\n137: \n138: /**\n139:  * Generate a prompt for an agent that resolves merge conflicts.\n140:  *\n141:  * The agent is launched in the feature worktree AFTER `git merge <baseBranch>`\n142:  * has been run there, leaving conflict markers in the working tree.\n143:  */\n144: export function generateConflictResolutionPrompt(\n145:   feature: Feature,\n146:   baseBranch: string,\n147:   mergeError: string,\n148:   config: WomboConfig\n149: ): string {\n150:   const sections: string[] = [];\n151: \n152:   sections.push(`# Merge Conflict Resolution: ${feature.title}`);\n153:   sections.push(`**Feature ID:** \\`${feature.id}\\``);\n154:   sections.push(`**Feature Branch:** \\`${config.git.branchPrefix}${feature.id}\\``);\n155:   sections.push(`**Base Branch:** \\`${baseBranch}\\``);\n156: \n157:   sections.push(`\\n## Situation\\n`);\n158:   sections.push(\n159:     `The feature branch \\`${config.git.branchPrefix}${feature.id}\\` has been completed and build-verified, ` +\n160:     `but merging it into \\`${baseBranch}\\` produced conflicts. The base branch (\\`${baseBranch}\\`) has been ` +\n161:     `merged INTO this feature branch's worktree, so the conflict markers are present in the working tree right now.`\n162:   );\n163: \n164:   sections.push(`\\n## Merge Error Output\\n`);\n165:   sections.push(\"```\");\n166:   sections.push(mergeError);\n167:   sections.push(\"```\");\n168: \n169:   sections.push(`\\n## Feature Description\\n`);\n170:   sections.push(feature.description.trim());\n171: \n172:   sections.push(`\\n## Your Task\\n`);\n173:   sections.push(\"1. Find all files with conflict markers (`<<<<<<<`, `=======`, `>>>>>>>`)\");\n174:   sections.push(\"2. Resolve each conflict by combining both sides intelligently:\");\n175:   sections.push(`   - The \\`HEAD\\` side is the feature's work (keep this intent)`);\n176:   sections.push(`   - The \\`${baseBranch}\\` side is upstream changes (integrate these)`);\n177:   sections.push(\"3. Remove ALL conflict markers — no `<<<<<<<`, `=======`, or `>>>>>>>` should remain\");\n178:   sections.push(\"4. Run the build to verify everything compiles:\");\n179:   sections.push(\"   ```bash\");\n180:   sections.push(`   ${config.build.command}`);\n181:   sections.push(\"   ```\");\n182:   sections.push(\"5. If the build fails, fix the errors\");\n183:   sections.push(\"6. Stage all resolved files and commit the merge:\");\n184:   sections.push(\"   ```bash\");\n185:   sections.push(\"   git add -A\");\n186:   sections.push('   git commit --no-edit');\n187:   sections.push(\"   ```\");\n188: \n189:   sections.push(`\\n## Rules\\n`);\n190:   sections.push(\"- Do NOT abort the merge (`git merge --abort`)\");\n191:   sections.push(\"- Do NOT create new branches or rebase\");\n192:   sections.push(\"- Do NOT push to remote\");\n193:   sections.push(`- Do NOT modify \\`${config.featuresFile}\\``);\n194:   sections.push(\"- Keep BOTH the feature's changes and the upstream changes where possible\");\n195:   sections.push(\"- If in doubt, prefer the feature's implementation but ensure upstream additions are not lost\");\n196: \n197:   return sections.join(\"\\n\");\n198: }\n199: \n200: // ---------------------------------------------------------------------------\n201: // Subtask Formatting\n202: // ---------------------------------------------------------------------------\n203: \n204: function formatSubtask(\n205:   subtask: Subtask,\n206:   index: number,\n207:   depth: number\n208: ): string {\n209:   const indent = \"  \".repeat(depth);\n210:   const lines: string[] = [];\n211: \n212:   lines.push(\n213:     `${indent}${index}. **${subtask.title}** (\\`${subtask.id}\\`, ${formatDuration(parseDurationMinutes(subtask.effort))})`\n214:   );\n215:   lines.push(`${indent}   ${subtask.description.trim()}`);\n216: \n217:   if (subtask.constraints.length > 0) {\n218:     for (const c of subtask.constraints) {\n219:       lines.push(`${indent}   - Constraint: ${c}`);\n220:     }\n221:   }\n222:   if (subtask.forbidden.length > 0) {\n223:     for (const f of subtask.forbidden) {\n224:       lines.push(`${indent}   - Forbidden: ${f}`);\n225:     }\n226:   }\n227:   if (subtask.references.length > 0) {\n228:     lines.push(\n229:       `${indent}   - Files: ${subtask.references.map((r) => `\\`${r}\\``).join(\", \")}`\n230:     );\n231:   }\n232:   if (subtask.depends_on.length > 0) {\n233:     lines.push(\n234:       `${indent}   - Depends on: ${subtask.depends_on.map((d) => `\\`${d}\\``).join(\", \")}`\n235:     );\n236:   }\n237: \n238:   // Nested subtasks\n239:   if (subtask.subtasks.length > 0) {\n240:     for (let i = 0; i < subtask.subtasks.length; i++) {\n241:       lines.push(formatSubtask(subtask.subtasks[i], i + 1, depth + 1));\n242:     }\n243:   }\n244: \n245:   return lines.join(\"\\n\");\n246: }\n\n(End of file - total 246 lines)\n</content>","title":"src/lib/prompt.ts","metadata":{"preview":"/**\n * prompt.ts — Generate agent prompts from feature specs.\n *\n * Responsibilities:\n *   - Transform a Feature into a structured prompt for the agent\n *   - Include feature spec, subtasks, constraints, forbidden items, references\n *   - Generate the build command and success criteria\n *   - All project-specific values come from config (no hardcoded Astro references)\n */\n\nimport type { Feature, Subtask } from \"./features.js\";\nimport { formatDuration, parseDurationMinutes } from \"./features.js\";\nimport type { WomboConfig } from \"../config.js\";\n\n// ---------------------------------------------------------------------------\n// Prompt Generation\n// ---------------------------------------------------------------------------\n\n/**\n * Generate the full prompt for an autonomous agent working on a feature.","truncated":false,"loaded":[]},"time":{"start":1773351521286,"end":1773351521292}}}}
{"type":"tool_use","timestamp":1773351521596,"sessionID":"ses_31c036dc4ffejmXOCp5uBNFg7f","part":{"id":"prt_ce3fccc09001lUxOWCVw5fPLDl","sessionID":"ses_31c036dc4ffejmXOCp5uBNFg7f","messageID":"msg_ce3fcbd34001QvnmYVUTtx33ZC","type":"tool","callID":"toolu_vrtx_01GbXSw9hDgmZGpEeudopXaS","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-portless-integration/src/lib/worktree.ts"},"output":"<path>/home/fulgidus/Documents/wombo-portless-integration/src/lib/worktree.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * worktree.ts — Git worktree lifecycle management.\n3:  *\n4:  * Responsibilities:\n5:  *   - Create feature branches from a base branch\n6:  *   - Create git worktrees for each feature branch\n7:  *   - Run install command in worktrees\n8:  *   - List and remove worktrees\n9:  *   - Copy agent config files into worktrees\n10:  *\n11:  * IMPORTANT: Heavy operations (createWorktree, installDeps) are async\n12:  * to allow true parallelism with Promise.all.\n13:  */\n14: \n15: import { exec, execSync } from \"node:child_process\";\n16: import { existsSync, cpSync, statSync } from \"node:fs\";\n17: import { resolve, dirname, basename } from \"node:path\";\n18: import type { WomboConfig } from \"../config.js\";\n19: \n20: // ---------------------------------------------------------------------------\n21: // Types\n22: // ---------------------------------------------------------------------------\n23: \n24: export interface WorktreeInfo {\n25:   path: string;\n26:   branch: string;\n27:   head: string;\n28:   bare: boolean;\n29: }\n30: \n31: // ---------------------------------------------------------------------------\n32: // Diagnostic Logger\n33: // ---------------------------------------------------------------------------\n34: \n35: function ts(): string {\n36:   return new Date().toISOString().slice(11, 19); // HH:MM:SS\n37: }\n38: \n39: export function log(featureId: string, msg: string): void {\n40:   console.log(`  [${ts()}] ${featureId}: ${msg}`);\n41: }\n42: \n43: // ---------------------------------------------------------------------------\n44: // Async Command Runner\n45: // ---------------------------------------------------------------------------\n46: \n47: /**\n48:  * Run a command asynchronously. Returns stdout on success, throws on failure.\n49:  */\n50: function runAsync(\n51:   cmd: string,\n52:   opts?: { cwd?: string; timeoutMs?: number }\n53: ): Promise<string> {\n54:   return new Promise((resolve, reject) => {\n55:     exec(\n56:       cmd,\n57:       {\n58:         cwd: opts?.cwd,\n59:         encoding: \"utf-8\",\n60:         timeout: opts?.timeoutMs ?? 0,\n61:         maxBuffer: 10 * 1024 * 1024,\n62:       },\n63:       (error, stdout, stderr) => {\n64:         if (error) {\n65:           const errMsg = stderr?.trim() || stdout?.trim() || error.message;\n66:           reject(new Error(`Command failed: ${cmd}\\n${errMsg}`));\n67:         } else {\n68:           resolve((stdout ?? \"\").trim());\n69:         }\n70:       }\n71:     );\n72:   });\n73: }\n74: \n75: /**\n76:  * Synchronous run — only for quick, non-blocking operations.\n77:  */\n78: function runSync(\n79:   cmd: string,\n80:   opts?: { cwd?: string; silent?: boolean; timeoutMs?: number }\n81: ): string {\n82:   try {\n83:     return execSync(cmd, {\n84:       cwd: opts?.cwd,\n85:       encoding: \"utf-8\",\n86:       stdio: opts?.silent ? \"pipe\" : [\"pipe\", \"pipe\", \"pipe\"],\n87:       timeout: opts?.timeoutMs,\n88:       maxBuffer: 10 * 1024 * 1024,\n89:     }).trim();\n90:   } catch (err: any) {\n91:     const stderr = err.stderr?.toString().trim() || \"\";\n92:     const stdout = err.stdout?.toString().trim() || \"\";\n93:     throw new Error(\n94:       `Command failed: ${cmd}\\n${stderr || stdout || err.message}`\n95:     );\n96:   }\n97: }\n98: \n99: // ---------------------------------------------------------------------------\n100: // Branch Management\n101: // ---------------------------------------------------------------------------\n102: \n103: /**\n104:  * Create a feature branch from the base branch.\n105:  * If it already exists and is NOT checked out in a worktree, reset it.\n106:  * If it's checked out in a worktree, leave it alone (resume case).\n107:  */\n108: async function createBranch(\n109:   projectRoot: string,\n110:   branchName: string,\n111:   baseBranch: string\n112: ): Promise<void> {\n113:   const existing = await runAsync(\n114:     `git branch --list \"${branchName}\"`,\n115:     { cwd: projectRoot }\n116:   );\n117:   if (existing.trim()) {\n118:     // Branch exists — try to delete and recreate.\n119:     // If deletion fails (e.g. checked out in worktree), that's fine —\n120:     // we'll reuse the existing branch with its work intact.\n121:     try {\n122:       await runAsync(`git branch -D \"${branchName}\"`, { cwd: projectRoot });\n123:     } catch {\n124:       // Branch is checked out in a worktree — reuse as-is\n125:       return;\n126:     }\n127:   }\n128:   await runAsync(`git branch \"${branchName}\" \"${baseBranch}\"`, {\n129:     cwd: projectRoot,\n130:   });\n131: }\n132: \n133: /**\n134:  * Generate the branch name for a feature using config prefix.\n135:  */\n136: export function featureBranchName(\n137:   featureId: string,\n138:   config: WomboConfig\n139: ): string {\n140:   return `${config.git.branchPrefix}${featureId}`;\n141: }\n142: \n143: /**\n144:  * Generate the worktree path for a feature (sibling directory to project root).\n145:  */\n146: export function worktreePath(\n147:   projectRoot: string,\n148:   featureId: string,\n149:   config: WomboConfig\n150: ): string {\n151:   const parentDir = dirname(projectRoot);\n152:   return resolve(parentDir, `${config.git.worktreePrefix}${featureId}`);\n153: }\n154: \n155: // ---------------------------------------------------------------------------\n156: // Worktree Lifecycle (async)\n157: // ---------------------------------------------------------------------------\n158: \n159: /**\n160:  * Create a git worktree for a feature branch.\n161:  * Returns the absolute path to the worktree.\n162:  *\n163:  * If a valid worktree already exists at the expected path (has .git file),\n164:  * reuses it — this is essential for the resume case where worktrees have\n165:  * real work but may be missing node_modules.\n166:  */\n167: export async function createWorktree(\n168:   projectRoot: string,\n169:   featureId: string,\n170:   baseBranch: string,\n171:   config: WomboConfig\n172: ): Promise<string> {\n173:   const branch = featureBranchName(featureId, config);\n174:   const wtPath = worktreePath(projectRoot, featureId, config);\n175: \n176:   // If a valid worktree already exists, reuse it (resume case).\n177:   // A git worktree has a .git *file* (not directory) pointing to the main repo.\n178:   if (existsSync(wtPath) && existsSync(resolve(wtPath, \".git\"))) {\n179:     log(featureId, \"reusing existing worktree (has work)\");\n180:     // Still copy config files in case they're missing\n181:     copyConfigFiles(projectRoot, wtPath, featureId, config);\n182:     return wtPath;\n183:   }\n184: \n185:   // Create the branch if it doesn't exist\n186:   log(featureId, \"creating branch...\");\n187:   await createBranch(projectRoot, branch, baseBranch);\n188: \n189:   // Remove existing worktree directory if present but invalid\n190:   if (existsSync(wtPath)) {\n191:     log(featureId, \"removing old worktree...\");\n192:     try {\n193:       await runAsync(`git worktree remove --force \"${wtPath}\"`, {\n194:         cwd: projectRoot,\n195:       });\n196:     } catch {\n197:       await runAsync(`rm -rf \"${wtPath}\"`);\n198:       await runAsync(`git worktree prune`, { cwd: projectRoot });\n199:     }\n200:   }\n201: \n202:   // Create the worktree\n203:   log(featureId, \"creating worktree...\");\n204:   await runAsync(`git worktree add \"${wtPath}\" \"${branch}\"`, {\n205:     cwd: projectRoot,\n206:   });\n207: \n208:   // Copy agent config files into worktree\n209:   copyConfigFiles(projectRoot, wtPath, featureId, config);\n210: \n211:   log(featureId, \"worktree ready\");\n212:   return wtPath;\n213: }\n214: \n215: /**\n216:  * Copy agent config files from project root into a worktree.\n217:  * Best-effort — logs warnings but doesn't throw.\n218:  */\n219: function copyConfigFiles(\n220:   projectRoot: string,\n221:   wtPath: string,\n222:   featureId: string,\n223:   config: WomboConfig\n224: ): void {\n225:   for (const configFile of config.agent.configFiles) {\n226:     const srcPath = resolve(projectRoot, configFile);\n227:     if (!existsSync(srcPath)) continue;\n228: \n229:     const destPath = resolve(wtPath, configFile);\n230:     try {\n231:       const stat = statSync(srcPath);\n232:       if (stat.isDirectory()) {\n233:         cpSync(srcPath, destPath, { recursive: true });\n234:       } else {\n235:         cpSync(srcPath, destPath);\n236:       }\n237:     } catch {\n238:       // Non-critical — best effort\n239:     }\n240:   }\n241: \n242:   // Verify all config files were copied successfully\n243:   verifyConfigFiles(projectRoot, wtPath, featureId, config);\n244: }\n245: \n246: // ---------------------------------------------------------------------------\n247: // Config File Verification\n248: // ---------------------------------------------------------------------------\n249: \n250: /**\n251:  * Verify that all expected config files were copied into the worktree.\n252:  * Logs a warning for any that are missing. This is a safety net on top\n253:  * of the best-effort cpSync logic in createWorktree.\n254:  */\n255: function verifyConfigFiles(\n256:   projectRoot: string,\n257:   wtPath: string,\n258:   featureId: string,\n259:   config: WomboConfig\n260: ): void {\n261:   const missing: string[] = [];\n262: \n263:   for (const configFile of config.agent.configFiles) {\n264:     const srcPath = resolve(projectRoot, configFile);\n265:     const destPath = resolve(wtPath, configFile);\n266: \n267:     // Only check files/dirs that exist in the source project\n268:     if (!existsSync(srcPath)) continue;\n269: \n270:     if (!existsSync(destPath)) {\n271:       missing.push(configFile);\n272:     }\n273:   }\n274: \n275:   if (missing.length > 0) {\n276:     log(\n277:       featureId,\n278:       `\\x1b[33mWARNING\\x1b[0m: config files missing in worktree: ${missing.join(\", \")}`\n279:     );\n280:   }\n281: }\n282: \n283: /**\n284:  * Install dependencies in a worktree.\n285:  */\n286: export async function installDeps(\n287:   wtPath: string,\n288:   featureId: string,\n289:   config: WomboConfig\n290: ): Promise<void> {\n291:   log(featureId, `running ${config.install.command}...`);\n292:   const start = Date.now();\n293:   await runAsync(config.install.command, {\n294:     cwd: wtPath,\n295:     timeoutMs: config.install.timeout,\n296:   });\n297:   const elapsed = ((Date.now() - start) / 1000).toFixed(1);\n298:   log(featureId, `install done (${elapsed}s)`);\n299: }\n300: \n301: /**\n302:  * Check if a worktree already exists and has node_modules (fully ready).\n303:  */\n304: export function worktreeReady(wtPath: string): boolean {\n305:   return (\n306:     existsSync(wtPath) &&\n307:     existsSync(resolve(wtPath, \"node_modules\"))\n308:   );\n309: }\n310: \n311: /**\n312:  * Check if a valid git worktree exists at the path (may lack node_modules).\n313:  * A git worktree has a .git *file* (not directory) pointing to the main repo.\n314:  */\n315: export function worktreeExists(wtPath: string): boolean {\n316:   return existsSync(wtPath) && existsSync(resolve(wtPath, \".git\"));\n317: }\n318: \n319: // ---------------------------------------------------------------------------\n320: // Worktree Listing / Cleanup (sync)\n321: // ---------------------------------------------------------------------------\n322: \n323: /**\n324:  * List all git worktrees.\n325:  */\n326: export function listWorktrees(projectRoot: string): WorktreeInfo[] {\n327:   const output = runSync(\"git worktree list --porcelain\", {\n328:     cwd: projectRoot,\n329:     silent: true,\n330:   });\n331:   if (!output) return [];\n332: \n333:   const worktrees: WorktreeInfo[] = [];\n334:   let current: Partial<WorktreeInfo> = {};\n335: \n336:   for (const line of output.split(\"\\n\")) {\n337:     if (line.startsWith(\"worktree \")) {\n338:       if (current.path) worktrees.push(current as WorktreeInfo);\n339:       current = { path: line.slice(9), bare: false };\n340:     } else if (line.startsWith(\"HEAD \")) {\n341:       current.head = line.slice(5);\n342:     } else if (line.startsWith(\"branch \")) {\n343:       current.branch = line.slice(7).replace(\"refs/heads/\", \"\");\n344:     } else if (line === \"bare\") {\n345:       current.bare = true;\n346:     } else if (line === \"\" && current.path) {\n347:       worktrees.push(current as WorktreeInfo);\n348:       current = {};\n349:     }\n350:   }\n351:   if (current.path) worktrees.push(current as WorktreeInfo);\n352: \n353:   return worktrees;\n354: }\n355: \n356: /**\n357:  * List only wombo-related worktrees.\n358:  *\n359:  * SAFETY: Filters by checking that the *basename* of the worktree path\n360:  * starts with the worktreePrefix. A naive `.includes()` on the full path\n361:  * would match the main repo itself if its directory name contained the\n362:  * prefix (e.g. \"wombo-combo\" contains \"wombo-\"), causing cleanup to\n363:  * destroy the project root.\n364:  *\n365:  * Additionally, the main repo worktree (projectRoot) is always excluded\n366:  * as a defensive guard.\n367:  */\n368: export function listWomboWorktrees(\n369:   projectRoot: string,\n370:   config: WomboConfig\n371: ): WorktreeInfo[] {\n372:   const resolvedRoot = resolve(projectRoot);\n373:   return listWorktrees(projectRoot).filter((wt) => {\n374:     // Never include the main project root\n375:     if (resolve(wt.path) === resolvedRoot) return false;\n376:     // Match only worktrees whose directory name starts with the prefix\n377:     return basename(wt.path).startsWith(config.git.worktreePrefix);\n378:   });\n379: }\n380: \n381: /**\n382:  * Remove a worktree and optionally delete its branch.\n383:  *\n384:  * SAFETY: Refuses to remove the project root itself. This is a hard guard\n385:  * against bugs in worktree filtering that could otherwise destroy the main repo.\n386:  */\n387: export function removeWorktree(\n388:   projectRoot: string,\n389:   wtPath: string,\n390:   deleteBranchToo: boolean = true\n391: ): void {\n392:   // Hard safety check: never remove the main project root\n393:   if (resolve(wtPath) === resolve(projectRoot)) {\n394:     throw new Error(\n395:       `SAFETY: refusing to remove project root as worktree: ${wtPath}`\n396:     );\n397:   }\n398: \n399:   const worktrees = listWorktrees(projectRoot);\n400:   const wt = worktrees.find((w) => w.path === wtPath);\n401: \n402:   try {\n403:     runSync(`git worktree remove --force \"${wtPath}\"`, { cwd: projectRoot });\n404:   } catch {\n405:     if (existsSync(wtPath)) {\n406:       runSync(`rm -rf \"${wtPath}\"`);\n407:     }\n408:     runSync(\"git worktree prune\", { cwd: projectRoot });\n409:   }\n410: \n411:   if (deleteBranchToo && wt?.branch) {\n412:     try {\n413:       runSync(`git branch -D \"${wt.branch}\"`, {\n414:         cwd: projectRoot,\n415:         silent: true,\n416:       });\n417:     } catch {\n418:       // Branch may have been merged or already deleted\n419:     }\n420:   }\n421: }\n422: \n423: /**\n424:  * Check if a feature branch has any commits beyond the base branch.\n425:  * Returns true if the branch has diverged (i.e., the agent made commits).\n426:  */\n427: export function branchHasChanges(\n428:   projectRoot: string,\n429:   branch: string,\n430:   baseBranch: string\n431: ): boolean {\n432:   try {\n433:     const count = runSync(\n434:       `git rev-list --count \"${baseBranch}..${branch}\"`,\n435:       { cwd: projectRoot, silent: true }\n436:     );\n437:     return parseInt(count, 10) > 0;\n438:   } catch {\n439:     // If the branch doesn't exist or git fails, assume no changes\n440:     return false;\n441:   }\n442: }\n443: \n444: /**\n445:  * Remove all wombo-related worktrees and prune.\n446:  */\n447: export function cleanupAllWorktrees(\n448:   projectRoot: string,\n449:   config: WomboConfig\n450: ): number {\n451:   const womboWorktrees = listWomboWorktrees(projectRoot, config);\n452:   let removed = 0;\n453:   for (const wt of womboWorktrees) {\n454:     try {\n455:       removeWorktree(projectRoot, wt.path, false);\n456:       removed++;\n457:     } catch (err: any) {\n458:       console.error(`Failed to remove worktree ${wt.path}: ${err.message}`);\n459:     }\n460:   }\n461:   try {\n462:     runSync(\"git worktree prune\", { cwd: projectRoot });\n463:   } catch {\n464:     // Prune is best-effort — may fail if repo state is already clean\n465:   }\n466:   return removed;\n467: }\n\n(End of file - total 467 lines)\n</content>","title":"src/lib/worktree.ts","metadata":{"preview":"/**\n * worktree.ts — Git worktree lifecycle management.\n *\n * Responsibilities:\n *   - Create feature branches from a base branch\n *   - Create git worktrees for each feature branch\n *   - Run install command in worktrees\n *   - List and remove worktrees\n *   - Copy agent config files into worktrees\n *\n * IMPORTANT: Heavy operations (createWorktree, installDeps) are async\n * to allow true parallelism with Promise.all.\n */\n\nimport { exec, execSync } from \"node:child_process\";\nimport { existsSync, cpSync, statSync } from \"node:fs\";\nimport { resolve, dirname, basename } from \"node:path\";\nimport type { WomboConfig } from \"../config.js\";\n\n// ---------------------------------------------------------------------------","truncated":false,"loaded":[]},"time":{"start":1773351521579,"end":1773351521591}}}}
{"type":"tool_use","timestamp":1773351522215,"sessionID":"ses_31c036dc4ffejmXOCp5uBNFg7f","part":{"id":"prt_ce3fccd8c0013qqMaWY3Jhe0zX","sessionID":"ses_31c036dc4ffejmXOCp5uBNFg7f","messageID":"msg_ce3fcbd34001QvnmYVUTtx33ZC","type":"tool","callID":"toolu_vrtx_012UV8ffseJJQbeM7Euf9ssz","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-portless-integration/src/config.ts"},"output":"<path>/home/fulgidus/Documents/wombo-portless-integration/src/config.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * config.ts — Load wombo.json, merge with defaults, validate, expose typed config.\n3:  *\n4:  * The config file lives at the target project root (the repo being orchestrated).\n5:  * All values have sensible defaults so minimal config works out of the box.\n6:  */\n7: \n8: import { readFileSync, existsSync } from \"node:fs\";\n9: import { resolve } from \"node:path\";\n10: \n11: // ---------------------------------------------------------------------------\n12: // Types\n13: // ---------------------------------------------------------------------------\n14: \n15: export interface WomboConfig {\n16:   /** Path to the features YAML file relative to project root */\n17:   featuresFile: string;\n18:   /** Base branch to create feature branches from */\n19:   baseBranch: string;\n20:   /** Build configuration */\n21:   build: {\n22:     /** Build command to run in worktrees */\n23:     command: string;\n24:     /** Build timeout in milliseconds */\n25:     timeout: number;\n26:     /** Build artifact directory (for quick \"did it build?\" checks) */\n27:     artifactDir: string;\n28:   };\n29:   /** Install configuration */\n30:   install: {\n31:     /** Install command to run in worktrees */\n32:     command: string;\n33:     /** Install timeout in milliseconds */\n34:     timeout: number;\n35:   };\n36:   /** Git configuration */\n37:   git: {\n38:     /** Branch name prefix for feature branches */\n39:     branchPrefix: string;\n40:     /** Worktree directory name prefix */\n41:     worktreePrefix: string;\n42:     /** Git remote name */\n43:     remote: string;\n44:     /** Merge strategy flag */\n45:     mergeStrategy: string;\n46:   };\n47:   /** Agent configuration */\n48:   agent: {\n49:     /** Path to agent binary (null = auto-detect) */\n50:     bin: string | null;\n51:     /** Agent name to pass via --agent flag */\n52:     name: string;\n53:     /** Config files/dirs to copy into worktrees */\n54:     configFiles: string[];\n55:     /** tmux session name prefix */\n56:     tmuxPrefix: string;\n57:   };\n58:   /** Default runtime values */\n59:   defaults: {\n60:     /** Max concurrent agents */\n61:     maxConcurrent: number;\n62:     /** Max retries per agent */\n63:     maxRetries: number;\n64:   };\n65: }\n66: \n67: // ---------------------------------------------------------------------------\n68: // Defaults\n69: // ---------------------------------------------------------------------------\n70: \n71: export const DEFAULT_CONFIG: WomboConfig = {\n72:   featuresFile: \".features.yml\",\n73:   baseBranch: \"develop\",\n74:   build: {\n75:     command: \"bun run build\",\n76:     timeout: 300_000,\n77:     artifactDir: \"dist\",\n78:   },\n79:   install: {\n80:     command: \"bun install\",\n81:     timeout: 120_000,\n82:   },\n83:   git: {\n84:     branchPrefix: \"feature/\",\n85:     worktreePrefix: \"wombo-\",\n86:     remote: \"origin\",\n87:     mergeStrategy: \"--no-ff\",\n88:   },\n89:   agent: {\n90:     bin: null,\n91:     name: \"wave-worker\",\n92:     configFiles: [\".opencode/\", \"opencode.json\", \"AGENTS.md\", \"agent/\"],\n93:     tmuxPrefix: \"wombo\",\n94:   },\n95:   defaults: {\n96:     maxConcurrent: 6,\n97:     maxRetries: 2,\n98:   },\n99: };\n100: \n101: // ---------------------------------------------------------------------------\n102: // Config File Name\n103: // ---------------------------------------------------------------------------\n104: \n105: export const CONFIG_FILE = \"wombo.json\";\n106: \n107: // ---------------------------------------------------------------------------\n108: // Loader\n109: // ---------------------------------------------------------------------------\n110: \n111: /**\n112:  * Deep-merge source into target. Only merges plain objects, not arrays.\n113:  */\n114: function deepMerge<T extends Record<string, any>>(target: T, source: Partial<T>): T {\n115:   const result = { ...target };\n116:   for (const key of Object.keys(source) as (keyof T)[]) {\n117:     const srcVal = source[key];\n118:     const tgtVal = target[key];\n119:     if (\n120:       srcVal !== undefined &&\n121:       srcVal !== null &&\n122:       typeof srcVal === \"object\" &&\n123:       !Array.isArray(srcVal) &&\n124:       typeof tgtVal === \"object\" &&\n125:       !Array.isArray(tgtVal) &&\n126:       tgtVal !== null\n127:     ) {\n128:       result[key] = deepMerge(tgtVal as any, srcVal as any);\n129:     } else if (srcVal !== undefined) {\n130:       result[key] = srcVal as T[keyof T];\n131:     }\n132:   }\n133:   return result;\n134: }\n135: \n136: /**\n137:  * Load wombo.json from the given project root and merge with defaults.\n138:  * Returns the full config. If no config file exists, returns defaults.\n139:  */\n140: export function loadConfig(projectRoot: string): WomboConfig {\n141:   const configPath = resolve(projectRoot, CONFIG_FILE);\n142: \n143:   if (!existsSync(configPath)) {\n144:     return { ...DEFAULT_CONFIG };\n145:   }\n146: \n147:   try {\n148:     const raw = readFileSync(configPath, \"utf-8\");\n149:     const partial = JSON.parse(raw) as Partial<WomboConfig>;\n150:     return deepMerge(DEFAULT_CONFIG, partial);\n151:   } catch (err: any) {\n152:     throw new Error(`Failed to load ${CONFIG_FILE}: ${err.message}`);\n153:   }\n154: }\n155: \n156: /**\n157:  * Resolve the agent binary path. Priority:\n158:  *   1. config.agent.bin (explicit)\n159:  *   2. OPENCODE_BIN env var\n160:  *   3. ~/.opencode/bin/opencode (default install location)\n161:  */\n162: export function resolveAgentBin(config: WomboConfig): string {\n163:   if (config.agent.bin) return config.agent.bin;\n164:   if (process.env.OPENCODE_BIN) return process.env.OPENCODE_BIN;\n165:   return resolve(process.env.HOME || \"~\", \".opencode/bin/opencode\");\n166: }\n167: \n168: /**\n169:  * Validate the config for obvious issues. Throws on error.\n170:  */\n171: export function validateConfig(config: WomboConfig): void {\n172:   if (!config.featuresFile) {\n173:     throw new Error(\"config.featuresFile must be a non-empty string\");\n174:   }\n175:   if (!config.baseBranch) {\n176:     throw new Error(\"config.baseBranch must be a non-empty string\");\n177:   }\n178:   if (!config.build.command) {\n179:     throw new Error(\"config.build.command must be a non-empty string\");\n180:   }\n181:   if (!config.install.command) {\n182:     throw new Error(\"config.install.command must be a non-empty string\");\n183:   }\n184:   if (!config.git.branchPrefix) {\n185:     throw new Error(\"config.git.branchPrefix must be a non-empty string\");\n186:   }\n187:   if (!config.git.worktreePrefix) {\n188:     throw new Error(\"config.git.worktreePrefix must be a non-empty string\");\n189:   }\n190:   if (config.defaults.maxConcurrent < 1) {\n191:     throw new Error(\"config.defaults.maxConcurrent must be >= 1\");\n192:   }\n193:   if (config.defaults.maxRetries < 0) {\n194:     throw new Error(\"config.defaults.maxRetries must be >= 0\");\n195:   }\n196: }\n197: \n198: /**\n199:  * Generate the default wombo.json content string (for `wombo init`).\n200:  */\n201: export function generateDefaultConfig(): string {\n202:   return JSON.stringify(DEFAULT_CONFIG, null, 2) + \"\\n\";\n203: }\n\n(End of file - total 203 lines)\n</content>","title":"src/config.ts","metadata":{"preview":"/**\n * config.ts — Load wombo.json, merge with defaults, validate, expose typed config.\n *\n * The config file lives at the target project root (the repo being orchestrated).\n * All values have sensible defaults so minimal config works out of the box.\n */\n\nimport { readFileSync, existsSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface WomboConfig {\n  /** Path to the features YAML file relative to project root */\n  featuresFile: string;\n  /** Base branch to create feature branches from */\n  baseBranch: string;\n  /** Build configuration */","truncated":false,"loaded":[]},"time":{"start":1773351522180,"end":1773351522202}}}}
