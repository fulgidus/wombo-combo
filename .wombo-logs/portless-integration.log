{"type":"tool_use","timestamp":1773351531532,"sessionID":"ses_31c036dc4ffejmXOCp5uBNFg7f","part":{"id":"prt_ce3fcf0bf00163l4Xu74SFSx8O","sessionID":"ses_31c036dc4ffejmXOCp5uBNFg7f","messageID":"msg_ce3fce540001O201ROrw1h14Qs","type":"tool","callID":"toolu_vrtx_015BQQ5MWMfTKCokap8otGyy","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-portless-integration/src/lib/templates.ts"},"output":"<path>/home/fulgidus/Documents/wombo-portless-integration/src/lib/templates.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * templates.ts — Resolve paths to bundled template files and install helpers.\n3:  *\n4:  * All template paths are resolved relative to the source file location\n5:  * using import.meta.dir (Bun-specific). This ensures templates are found\n6:  * whether running from source (bun dev) or from an installed package.\n7:  */\n8: \n9: import { join, dirname, resolve } from \"node:path\";\n10: import { existsSync, readFileSync, writeFileSync, mkdirSync } from \"node:fs\";\n11: import type { WomboConfig } from \"../config.js\";\n12: \n13: // ---------------------------------------------------------------------------\n14: // Template Paths\n15: // ---------------------------------------------------------------------------\n16: \n17: /**\n18:  * Absolute path to the bundled wave-worker agent definition template.\n19:  * Used by `wombo init` to install the agent definition into the project,\n20:  * and by `wombo launch` to reinstall it if missing.\n21:  */\n22: export const AGENT_TEMPLATE_PATH = join(dirname(import.meta.dir), \"templates\", \"wave-worker.md\");\n23: \n24: // ---------------------------------------------------------------------------\n25: // Agent Definition Guard\n26: // ---------------------------------------------------------------------------\n27: \n28: /**\n29:  * Ensure the agent definition file exists at the expected path.\n30:  * If missing, reinstall from the bundled template and warn the user.\n31:  *\n32:  * Called at the start of `wombo launch` to prevent the failure mode where\n33:  * agents spawn without their agent definition file.\n34:  *\n35:  * @returns true if the file was reinstalled, false if it already existed.\n36:  */\n37: export function ensureAgentDefinition(\n38:   projectRoot: string,\n39:   config: WomboConfig\n40: ): boolean {\n41:   const agentDir = resolve(projectRoot, \"agent\");\n42:   const agentDefPath = resolve(agentDir, `${config.agent.name}.md`);\n43: \n44:   if (existsSync(agentDefPath)) {\n45:     return false;\n46:   }\n47: \n48:   // Agent definition missing — reinstall from bundled template\n49:   console.warn(\n50:     `\\x1b[33m[WARNING]\\x1b[0m Agent definition not found: agent/${config.agent.name}.md`\n51:   );\n52:   console.warn(`  Reinstalling from bundled template...`);\n53: \n54:   try {\n55:     mkdirSync(agentDir, { recursive: true });\n56:     const template = readFileSync(AGENT_TEMPLATE_PATH, \"utf-8\");\n57:     writeFileSync(agentDefPath, template, \"utf-8\");\n58:     console.warn(`  Restored agent/${config.agent.name}.md\\n`);\n59:     return true;\n60:   } catch (err: any) {\n61:     console.error(\n62:       `  Failed to restore agent definition: ${err.message}`\n63:     );\n64:     console.error(\n65:       `  Agents may launch without their definition file.\\n`\n66:     );\n67:     return false;\n68:   }\n69: }\n\n(End of file - total 69 lines)\n</content>","title":"src/lib/templates.ts","metadata":{"preview":"/**\n * templates.ts — Resolve paths to bundled template files and install helpers.\n *\n * All template paths are resolved relative to the source file location\n * using import.meta.dir (Bun-specific). This ensures templates are found\n * whether running from source (bun dev) or from an installed package.\n */\n\nimport { join, dirname, resolve } from \"node:path\";\nimport { existsSync, readFileSync, writeFileSync, mkdirSync } from \"node:fs\";\nimport type { WomboConfig } from \"../config.js\";\n\n// ---------------------------------------------------------------------------\n// Template Paths\n// ---------------------------------------------------------------------------\n\n/**\n * Absolute path to the bundled wave-worker agent definition template.\n * Used by `wombo init` to install the agent definition into the project,\n * and by `wombo launch` to reinstall it if missing.","truncated":false,"loaded":[]},"time":{"start":1773351531529,"end":1773351531532}}}}
