{"type":"tool_use","timestamp":1773351676278,"sessionID":"ses_31c00ea90ffeMcRFqNZY7ExB1k","part":{"id":"prt_ce3ff27e6001lsk2up5RtkxC3g","sessionID":"ses_31c00ea90ffeMcRFqNZY7ExB1k","messageID":"msg_ce3ff159d001sEskjR4bR7nFF2","type":"tool","callID":"toolu_vrtx_01NPeMRF2hUgx5sgy5VA3cmp","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-cli-ux-polish/src/index.ts"},"output":"<path>/home/fulgidus/Documents/wombo-cli-ux-polish/src/index.ts</path>\n<type>file</type>\n<content>1: #!/usr/bin/env bun\n2: /**\n3:  * index.ts — CLI entry point for the Wombo agent orchestration system.\n4:  *\n5:  * Usage:\n6:  *   wombo init\n7:  *   wombo launch --top-priority 3\n8:  *   wombo launch --quickest-wins 5\n9:  *   wombo launch --priority high\n10:  *   wombo launch --difficulty easy\n11:  *   wombo launch --features \"feat-a,feat-b\"\n12:  *   wombo launch --all-ready\n13:  *   wombo launch ... --max-concurrent 3 --model \"anthropic/claude-sonnet-4-20250514\"\n14:  *   wombo launch ... --interactive\n15:  *   wombo resume\n16:  *   wombo status\n17:  *   wombo verify [feature-id]\n18:  *   wombo merge [feature-id]\n19:  *   wombo retry <feature-id>\n20:  *   wombo abort <feature-id> [--requeue] [--output json]\n21:  *   wombo cleanup\n22:  *   wombo features list [--status <s>] [--priority <p>] [--difficulty <d>] [--ready] [--include-archive]\n23:  *   wombo features add <id> <title> [options]\n24:  *   wombo features set-status <feature-id> <status>\n25:  *   wombo features check\n26:  *   wombo features archive [feature-id] [--dry-run]\n27:  *   wombo features show <feature-id>\n28:  *   wombo features graph [--ascii] [--mermaid] [--subtasks] [--status <s>]\n29:  *   wombo help\n30:  *   wombo --version\n31:  */\n32: \n33: import { resolve } from \"node:path\";\n34: import { existsSync, readFileSync } from \"node:fs\";\n35: import { loadConfig, validateConfig } from \"./config.js\";\n36: import { loadState, saveState } from \"./lib/state.js\";\n37: \n38: // ---------------------------------------------------------------------------\n39: // Dev-mode guard: warn if running the global binary inside the wombo repo\n40: // ---------------------------------------------------------------------------\n41: \n42: function checkDevModeGuard(): void {\n43:   const cwd = process.cwd();\n44:   const pkgPath = resolve(cwd, \"package.json\");\n45: \n46:   // Are we inside the wombo repo?\n47:   if (!existsSync(pkgPath)) return;\n48: \n49:   let pkgName: string | undefined;\n50:   try {\n51:     const raw = readFileSync(pkgPath, \"utf-8\");\n52:     pkgName = JSON.parse(raw).name;\n53:   } catch {\n54:     return;\n55:   }\n56:   if (pkgName !== \"wombo\") return;\n57: \n58:   // We're in the wombo repo. Is the source being run from a different location?\n59:   // import.meta.dir = directory of THIS file (index.ts). If it's under cwd,\n60:   // we're running local source (bun dev). If it's elsewhere (e.g. ~/.bun/install),\n61:   // we're running the globally installed binary.\n62:   const sourceDir = resolve(import.meta.dir);\n63:   const projectSrc = resolve(cwd, \"src\");\n64: \n65:   if (!sourceDir.startsWith(projectSrc)) {\n66:     console.warn(\n67:       \"\\x1b[33m[WARNING]\\x1b[0m You are running the globally installed wombo binary \" +\n68:       \"inside the wombo repo.\\n\" +\n69:       \"  Use \\x1b[1mbun dev <command>\\x1b[0m instead to run from local source.\\n\" +\n70:       \"  See AGENTS.md for details.\\n\"\n71:     );\n72:   }\n73: }\n74: \n75: import { cmdInit } from \"./commands/init.js\";\n76: import { cmdLaunch } from \"./commands/launch.js\";\n77: import { cmdResume } from \"./commands/resume.js\";\n78: import { cmdStatus } from \"./commands/status.js\";\n79: import { cmdVerify } from \"./commands/verify.js\";\n80: import { cmdMerge } from \"./commands/merge.js\";\n81: import { cmdRetry } from \"./commands/retry.js\";\n82: import { cmdCleanup } from \"./commands/cleanup.js\";\n83: import { cmdAbort } from \"./commands/abort.js\";\n84: import { cmdUpgrade } from \"./commands/upgrade.js\";\n85: import { cmdFeaturesList } from \"./commands/features/list.js\";\n86: import { cmdFeaturesAdd } from \"./commands/features/add.js\";\n87: import { cmdFeaturesSetStatus } from \"./commands/features/set-status.js\";\n88: import { cmdFeaturesCheck } from \"./commands/features/check.js\";\n89: import { cmdFeaturesArchive } from \"./commands/features/archive.js\";\n90: import { cmdFeaturesShow } from \"./commands/features/show.js\";\n91: import { cmdFeaturesGraph } from \"./commands/features/graph.js\";\n92: \n93: import { ensureFeaturesFile } from \"./lib/features.js\";\n94: import type { Priority, Difficulty, FeatureStatus } from \"./lib/features.js\";\n95: import { resolveOutputFormat, type OutputFormat } from \"./lib/output.js\";\n96: import { validateId, validateText, validateBranchName, validateDuration, assertValid } from \"./lib/validate.js\";\n97: import { findCommandDef, commandToSchema, allCommandSchemas } from \"./lib/schema.js\";\n98: \n99: // ---------------------------------------------------------------------------\n100: // Types\n101: // ---------------------------------------------------------------------------\n102: \n103: interface CLIArgs {\n104:   command: string;\n105:   subcommand?: string;\n106:   // Selection options (launch)\n107:   topPriority?: number;\n108:   quickestWins?: number;\n109:   priority?: Priority;\n110:   difficulty?: Difficulty;\n111:   features?: string[];\n112:   allReady?: boolean;\n113:   // Launch / runtime options\n114:   maxConcurrent?: number;\n115:   model?: string;\n116:   interactive: boolean;\n117:   dryRun: boolean;\n118:   baseBranch?: string;\n119:   maxRetries?: number;\n120:   noTui: boolean;\n121:   autoPush: boolean;\n122:   // Abort options\n123:   requeue: boolean;\n124:   // General\n125:   featureId?: string;\n126:   force: boolean;\n127:   // Output format\n128:   outputFmt: OutputFormat;\n129:   // Upgrade options\n130:   checkOnly: boolean;\n131:   version?: string;\n132:   // Features subcommand extras\n133:   status?: string;\n134:   ready?: boolean;\n135:   includeArchive?: boolean;\n136:   title?: string;\n137:   description?: string;\n138:   effort?: string;\n139:   dependsOn?: string[];\n140:   // Compact output\n141:   fields?: string[];\n142:   // Graph options\n143:   ascii?: boolean;\n144:   mermaidRaw?: boolean;\n145:   graphSubtasks?: boolean;\n146: }\n147: \n148: // ---------------------------------------------------------------------------\n149: // Arg Parsing\n150: // ---------------------------------------------------------------------------\n151: \n152: function parseArgs(argv: string[]): CLIArgs {\n153:   const args = argv.slice(2); // skip 'bun' and script path\n154:   const result: CLIArgs = {\n155:     command: args[0] || \"help\",\n156:     interactive: false,\n157:     dryRun: false,\n158:     noTui: false,\n159:     autoPush: false,\n160:     requeue: false,\n161:     force: false,\n162:     checkOnly: false,\n163:     outputFmt: resolveOutputFormat(undefined), // auto-detect until --output overrides\n164:   };\n165: \n166:   // If the first arg is \"features\", treat the second positional as the subcommand\n167:   let startIdx = 1;\n168:   if (result.command === \"features\") {\n169:     result.subcommand = args[1] || \"list\";\n170:     startIdx = 2;\n171:   }\n172: \n173:   for (let i = startIdx; i < args.length; i++) {\n174:     const arg = args[i];\n175:     switch (arg) {\n176:       // --- Selection options ---\n177:       case \"--top-priority\":\n178:         result.topPriority = parseInt(args[++i], 10);\n179:         break;\n180:       case \"--quickest-wins\":\n181:         result.quickestWins = parseInt(args[++i], 10);\n182:         break;\n183:       case \"--priority\":\n184:         result.priority = args[++i] as Priority;\n185:         break;\n186:       case \"--difficulty\":\n187:         result.difficulty = args[++i] as Difficulty;\n188:         break;\n189:       case \"--features\":\n190:         result.features = args[++i].split(\",\").map((s) => s.trim());\n191:         break;\n192:       case \"--all-ready\":\n193:         result.allReady = true;\n194:         break;\n195: \n196:       // --- Launch / runtime options ---\n197:       case \"--max-concurrent\":\n198:         result.maxConcurrent = parseInt(args[++i], 10);\n199:         break;\n200:       case \"--model\":\n201:       case \"-m\":\n202:         result.model = args[++i];\n203:         break;\n204:       case \"--interactive\":\n205:         result.interactive = true;\n206:         break;\n207:       case \"--dry-run\":\n208:         result.dryRun = true;\n209:         break;\n210:       case \"--no-tui\":\n211:         result.noTui = true;\n212:         break;\n213:       case \"--auto-push\":\n214:         result.autoPush = true;\n215:         break;\n216:       case \"--requeue\":\n217:         result.requeue = true;\n218:         break;\n219:       case \"--base-branch\":\n220:         result.baseBranch = args[++i];\n221:         break;\n222:       case \"--max-retries\":\n223:         result.maxRetries = parseInt(args[++i], 10);\n224:         break;\n225: \n226:       // --- General flags ---\n227:       case \"--force\":\n228:         result.force = true;\n229:         break;\n230:       case \"--check\":\n231:         result.checkOnly = true;\n232:         break;\n233:       case \"--version\":\n234:         result.version = args[++i];\n235:         break;\n236:       case \"--output\":\n237:       case \"-o\":\n238:         result.outputFmt = resolveOutputFormat(args[++i]);\n239:         break;\n240: \n241:       // --- Features subcommand options ---\n242:       case \"--status\":\n243:         result.status = args[++i];\n244:         break;\n245:       case \"--ready\":\n246:         result.ready = true;\n247:         break;\n248:       case \"--include-archive\":\n249:         result.includeArchive = true;\n250:         break;\n251:       case \"--title\":\n252:         result.title = args[++i];\n253:         break;\n254:       case \"--description\":\n255:       case \"--desc\":\n256:         result.description = args[++i];\n257:         break;\n258:       case \"--effort\":\n259:         result.effort = args[++i];\n260:         break;\n261:       case \"--depends-on\":\n262:         result.dependsOn = args[++i].split(\",\").map((s) => s.trim());\n263:         break;\n264:       case \"--fields\":\n265:         result.fields = args[++i].split(\",\").map((s) => s.trim());\n266:         break;\n267: \n268:       // --- Graph options ---\n269:       case \"--ascii\":\n270:         result.ascii = true;\n271:         break;\n272:       case \"--mermaid\":\n273:         result.mermaidRaw = true;\n274:         break;\n275:       case \"--subtasks\":\n276:         result.graphSubtasks = true;\n277:         break;\n278: \n279:       // --- Positional (feature-id, title for add, etc.) ---\n280:       default:\n281:         if (!arg.startsWith(\"-\")) {\n282:           if (!result.featureId) {\n283:             result.featureId = arg;\n284:           } else if (!result.title) {\n285:             result.title = arg;\n286:           }\n287:         }\n288:         break;\n289:     }\n290:   }\n291: \n292:   return result;\n293: }\n294: \n295: // ---------------------------------------------------------------------------\n296: // Help\n297: // ---------------------------------------------------------------------------\n298: \n299: function cmdHelp(): void {\n300:   console.log(`\n301: Wombo — AI Agent Orchestration System\n302: \n303:   WOMBO COMBO! Parallel feature development with AI agents.\n304: \n305: Commands:\n306:   init           Generate wombo.json config in the current project\n307:   launch         Launch a wave of agents to implement features\n308:   resume         Resume a previously stopped wave\n309:   status         Show the status of the current wave\n310:   verify         Run build verification on completed agents\n311:   merge          Merge verified branches into the base branch\n312:   retry          Retry a failed agent\n313:   abort          Kill a single running agent (--requeue to return to queue)\n314:   cleanup        Remove all wave worktrees and tmux sessions\n315:   features       Manage .features.yml (see below)\n316:   upgrade        Check for updates and upgrade wombo\n317:   describe       Emit JSON schema of a command (for AI agents)\n318:   help           Show this help\n319: \n320: Features Subcommands:\n321:   features list            List features (--status, --priority, --difficulty, --ready, --include-archive)\n322:   features add <id> <title> [options]\n323:                            Add a new feature (--desc, --priority, --difficulty, --effort, --depends-on)\n324:   features set-status <id> <status>\n325:                            Change a feature's status\n326:   features check           Validate .features.yml (schema, deps, duplicates, cycles)\n327:   features archive [id]    Move done/cancelled to archive (--dry-run)\n328:   features show <id>       Show feature details\n329:   features graph           Visualize dependency graph (--ascii, --mermaid, --subtasks)\n330: \n331: Selection Options (for launch):\n332:   --top-priority N         Select top N features by priority\n333:   --quickest-wins N        Select N features with lowest effort\n334:   --priority <level>       Filter by priority (critical/high/medium/low/wishlist)\n335:   --difficulty <level>     Filter by difficulty (trivial/easy/medium/hard/very_hard)\n336:   --features \"id1,id2\"     Select specific features by ID\n337:   --all-ready              Select all features whose dependencies are met\n338: \n339: Launch Options:\n340:   --max-concurrent N       Max agents running in parallel (default: from config)\n341:   --model <model>          Model to use (e.g., \"anthropic/claude-sonnet-4-20250514\")\n342:   --interactive            Use tmux TUI mode instead of headless\n343:   --no-tui                 Headless mode without neo-blessed TUI (periodic console dashboard)\n344:   --auto-push              Push base branch to remote after all merges complete\n345:   --dry-run                Show what would be launched without launching\n346:   --base-branch <branch>   Base branch (default: from config)\n347:   --max-retries N          Max retries per agent (default: from config)\n348: \n349: General:\n350:   --version, -V            Print version and exit\n351:   --force                  Force overwrite (e.g., for init) / skip prompts (e.g., for upgrade)\n352:   --output <fmt>           Output format: text (default on TTY) or json (default when piped)\n353:   -o <fmt>                 Alias for --output\n354:   --dry-run                Show what would happen without performing the action\n355:   --fields <list>          Comma-separated fields to include (e.g., id,status,priority)\n356: \n357: Upgrade Options:\n358:   --check                  Only check for updates, don't install\n359:   --version <tag>          Install a specific version (e.g., v0.1.0)\n360: \n361: Examples:\n362:   wombo init\n363:   wombo launch --quickest-wins 3\n364:   wombo launch --priority high --interactive\n365:   wombo launch --features \"auth-flow,search-api\" --max-concurrent 2\n366:   wombo resume\n367:   wombo status\n368:   wombo verify\n369:   wombo merge\n370:   wombo retry auth-flow\n371:   wombo abort auth-flow\n372:   wombo abort auth-flow --requeue\n373:   wombo abort auth-flow --output json\n374:   wombo cleanup\n375:   wombo features list --status ready --priority high\n376:   wombo features list --fields id,status,priority --output json\n377:   wombo features add my-feature \"My Cool Feature\" --priority high --difficulty easy\n378:   wombo features set-status my-feature in-progress\n379:   wombo features check\n380:   wombo features archive --dry-run\n381:   wombo features show my-feature\n382:   wombo describe                           # list all commands as JSON\n383:   wombo describe launch                    # describe a specific command\n384:   wombo describe features add              # describe a subcommand\n385: `);\n386: }\n387: \n388: // ---------------------------------------------------------------------------\n389: // Main\n390: // ---------------------------------------------------------------------------\n391: \n392: async function main(): Promise<void> {\n393:   checkDevModeGuard();\n394: \n395:   const PROJECT_ROOT = resolve(process.cwd());\n396:   const args = parseArgs(process.argv);\n397: \n398:   // -----------------------------------------------------------------------\n399:   // Input validation at the CLI boundary\n400:   // -----------------------------------------------------------------------\n401:   if (args.featureId) {\n402:     assertValid(validateId(args.featureId, \"feature ID\"));\n403:   }\n404:   if (args.title) {\n405:     assertValid(validateText(args.title, \"title\"));\n406:   }\n407:   if (args.description) {\n408:     assertValid(validateText(args.description, \"description\"));\n409:   }\n410:   if (args.baseBranch) {\n411:     assertValid(validateBranchName(args.baseBranch, \"base branch\"));\n412:   }\n413:   if (args.effort) {\n414:     assertValid(validateDuration(args.effort, \"effort\"));\n415:   }\n416:   if (args.features) {\n417:     for (const fid of args.features) {\n418:       assertValid(validateId(fid, \"feature ID in --features\"));\n419:     }\n420:   }\n421:   if (args.dependsOn) {\n422:     for (const dep of args.dependsOn) {\n423:       assertValid(validateId(dep, \"dependency ID in --depends-on\"));\n424:     }\n425:   }\n426: \n427:   // Commands that don't need config loading\n428:   if (args.command === \"--version\" || args.command === \"-V\") {\n429:     const pkgPath = resolve(import.meta.dir, \"..\", \"package.json\");\n430:     try {\n431:       const raw = readFileSync(pkgPath, \"utf-8\");\n432:       const pkg = JSON.parse(raw);\n433:       console.log(`wombo ${pkg.version}`);\n434:     } catch {\n435:       console.log(\"wombo (unknown version)\");\n436:     }\n437:     return;\n438:   }\n439: \n440:   if (args.command === \"help\" || args.command === \"--help\" || args.command === \"-h\") {\n441:     cmdHelp();\n442:     return;\n443:   }\n444: \n445:   if (args.command === \"describe\") {\n446:     // Schema introspection: `wombo describe [command]`\n447:     if (!args.featureId) {\n448:       // No command specified — list all commands\n449:       console.log(JSON.stringify(allCommandSchemas(), null, 2));\n450:     } else {\n451:       // Describe a specific command. Handle compound names: \"features list\"\n452:       const cmdName = args.title\n453:         ? `${args.featureId} ${args.title}`\n454:         : args.featureId;\n455:       const def = findCommandDef(cmdName);\n456:       if (!def) {\n457:         console.error(`Unknown command: \"${cmdName}\"`);\n458:         console.error(\"Run 'wombo describe' to list all commands.\");\n459:         process.exit(1);\n460:         return;\n461:       }\n462:       console.log(JSON.stringify(commandToSchema(def), null, 2));\n463:     }\n464:     return;\n465:   }\n466: \n467:   if (args.command === \"init\") {\n468:     await cmdInit({ projectRoot: PROJECT_ROOT, force: args.force });\n469:     return;\n470:   }\n471: \n472:   if (args.command === \"upgrade\") {\n473:     await cmdUpgrade({\n474:       force: args.force,\n475:       version: args.version,\n476:       checkOnly: args.checkOnly,\n477:     });\n478:     return;\n479:   }\n480: \n481:   // Everything else requires config\n482:   const config = loadConfig(PROJECT_ROOT);\n483:   validateConfig(config);\n484: \n485:   // Commands that operate on the features file — ensure it exists first\n486:   const needsFeatures = new Set([\"launch\", \"resume\", \"verify\", \"retry\", \"features\"]);\n487:   if (needsFeatures.has(args.command)) {\n488:     await ensureFeaturesFile(PROJECT_ROOT, config);\n489:   }\n490: \n491:   switch (args.command) {\n492:     case \"launch\":\n493:       await cmdLaunch({\n494:         projectRoot: PROJECT_ROOT,\n495:         config,\n496:         topPriority: args.topPriority,\n497:         quickestWins: args.quickestWins,\n498:         priority: args.priority,\n499:         difficulty: args.difficulty,\n500:         features: args.features,\n501:         allReady: args.allReady,\n502:         maxConcurrent: args.maxConcurrent ?? config.defaults.maxConcurrent,\n503:         model: args.model,\n504:         interactive: args.interactive,\n505:         dryRun: args.dryRun,\n506:         baseBranch: args.baseBranch ?? config.baseBranch,\n507:         maxRetries: args.maxRetries ?? config.defaults.maxRetries,\n508:         noTui: args.noTui,\n509:         autoPush: args.autoPush,\n510:         outputFmt: args.outputFmt,\n511:       });\n512:       break;\n513: \n514:     case \"resume\":\n515:       await cmdResume({\n516:         projectRoot: PROJECT_ROOT,\n517:         config,\n518:         maxConcurrent: args.maxConcurrent,\n519:         model: args.model,\n520:         interactive: args.interactive,\n521:         noTui: args.noTui,\n522:         autoPush: args.autoPush,\n523:         baseBranch: args.baseBranch,\n524:         maxRetries: args.maxRetries,\n525:       });\n526:       break;\n527: \n528:     case \"status\":\n529:       await cmdStatus({ projectRoot: PROJECT_ROOT, config });\n530:       break;\n531: \n532:     case \"verify\":\n533:       await cmdVerify({\n534:         projectRoot: PROJECT_ROOT,\n535:         config,\n536:         featureId: args.featureId,\n537:         model: args.model,\n538:         maxRetries: args.maxRetries,\n539:       });\n540:       break;\n541: \n542:     case \"merge\":\n543:       await cmdMerge({\n544:         projectRoot: PROJECT_ROOT,\n545:         config,\n546:         featureId: args.featureId,\n547:         autoPush: args.autoPush,\n548:         dryRun: args.dryRun,\n549:       });\n550:       break;\n551: \n552:     case \"retry\": {\n553:       if (!args.featureId) {\n554:         console.error(\"Usage: wombo retry <feature-id>\");\n555:         process.exit(1);\n556:         return;\n557:       }\n558:       await cmdRetry({\n559:         projectRoot: PROJECT_ROOT,\n560:         config,\n561:         featureId: args.featureId,\n562:         model: args.model,\n563:         interactive: args.interactive,\n564:         dryRun: args.dryRun,\n565:       });\n566:       break;\n567:     }\n568: \n569:     case \"cleanup\":\n570:       await cmdCleanup({ projectRoot: PROJECT_ROOT, config, dryRun: args.dryRun });\n571:       break;\n572: \n573:     case \"abort\": {\n574:       if (!args.featureId) {\n575:         console.error(\"Usage: wombo abort <feature-id> [--requeue] [--output json]\");\n576:         process.exit(1);\n577:         return;\n578:       }\n579:       await cmdAbort({\n580:         projectRoot: PROJECT_ROOT,\n581:         config,\n582:         featureId: args.featureId,\n583:         requeue: args.requeue,\n584:         outputFmt: args.outputFmt,\n585:       });\n586:       break;\n587:     }\n588: \n589:     case \"features\":\n590:       await handleFeaturesSubcommand(args, PROJECT_ROOT, config);\n591:       break;\n592: \n593:     default:\n594:       console.error(`Unknown command: ${args.command}`);\n595:       cmdHelp();\n596:       process.exit(1);\n597:       return;\n598:   }\n599: }\n600: \n601: // ---------------------------------------------------------------------------\n602: // Features Subcommand Router\n603: // ---------------------------------------------------------------------------\n604: \n605: async function handleFeaturesSubcommand(\n606:   args: CLIArgs,\n607:   projectRoot: string,\n608:   config: import(\"./config.js\").WomboConfig\n609: ): Promise<void> {\n610:   switch (args.subcommand) {\n611:     case \"list\":\n612:     case \"ls\":\n613:       await cmdFeaturesList({\n614:         projectRoot,\n615:         config,\n616:         status: args.status as FeatureStatus | undefined,\n617:         priority: args.priority,\n618:         difficulty: args.difficulty,\n619:         ready: args.ready,\n620:         includeArchive: args.includeArchive,\n621:         outputFmt: args.outputFmt,\n622:         fields: args.fields,\n623:       });\n624:       break;\n625: \n626:     case \"add\": {\n627:       if (!args.featureId || !args.title) {\n628:         console.error(\"Usage: wombo features add <id> <title> [--desc <desc>] [--priority <p>] [--difficulty <d>] [--effort <e>] [--depends-on <ids>]\");\n629:         process.exit(1);\n630:         return;\n631:       }\n632:       await cmdFeaturesAdd({\n633:         projectRoot,\n634:         config,\n635:         id: args.featureId,\n636:         title: args.title,\n637:         description: args.description,\n638:         priority: args.priority,\n639:         difficulty: args.difficulty,\n640:         effort: args.effort,\n641:         dependsOn: args.dependsOn,\n642:         outputFmt: args.outputFmt,\n643:         dryRun: args.dryRun,\n644:       });\n645:       break;\n646:     }\n647: \n648:     case \"set-status\": {\n649:       if (!args.featureId || !args.title) {\n650:         // title holds the second positional arg (the status value)\n651:         // If not provided via positional, check --status flag\n652:         const newStatus = args.title || args.status;\n653:         if (!args.featureId || !newStatus) {\n654:           console.error(\"Usage: wombo features set-status <feature-id> <status>\");\n655:           process.exit(1);\n656:           return;\n657:         }\n658:         await cmdFeaturesSetStatus({\n659:           projectRoot,\n660:           config,\n661:           featureId: args.featureId,\n662:           newStatus,\n663:           outputFmt: args.outputFmt,\n664:           dryRun: args.dryRun,\n665:         });\n666:       } else {\n667:         await cmdFeaturesSetStatus({\n668:           projectRoot,\n669:           config,\n670:           featureId: args.featureId,\n671:           newStatus: args.title, // second positional = new status\n672:           outputFmt: args.outputFmt,\n673:           dryRun: args.dryRun,\n674:         });\n675:       }\n676:       break;\n677:     }\n678: \n679:     case \"check\":\n680:     case \"validate\":\n681:       await cmdFeaturesCheck({ projectRoot, config });\n682:       break;\n683: \n684:     case \"archive\":\n685:       await cmdFeaturesArchive({\n686:         projectRoot,\n687:         config,\n688:         featureId: args.featureId,\n689:         dryRun: args.dryRun,\n690:       });\n691:       break;\n692: \n693:     case \"show\": {\n694:       if (!args.featureId) {\n695:         console.error(\"Usage: wombo features show <feature-id>\");\n696:         process.exit(1);\n697:         return;\n698:       }\n699:       await cmdFeaturesShow({\n700:         projectRoot,\n701:         config,\n702:         featureId: args.featureId,\n703:         outputFmt: args.outputFmt,\n704:         fields: args.fields,\n705:       });\n706:       break;\n707:     }\n708: \n709:     case \"graph\":\n710:       await cmdFeaturesGraph({\n711:         projectRoot,\n712:         config,\n713:         status: args.status as FeatureStatus | undefined,\n714:         ascii: args.ascii,\n715:         mermaid: args.mermaidRaw,\n716:         subtasks: args.graphSubtasks,\n717:         outputFmt: args.outputFmt,\n718:       });\n719:       break;\n720: \n721:     case \"help\":\n722:     case \"--help\":\n723:     case \"-h\":\n724:       cmdHelp();\n725:       break;\n726: \n727:     default:\n728:       console.error(`Unknown features subcommand: ${args.subcommand}`);\n729:       console.error(\"Run 'wombo features help' or 'wombo help' for usage.\");\n730:       process.exit(1);\n731:       return;\n732:   }\n733: }\n734: \n735: // ---------------------------------------------------------------------------\n736: // Error Handlers & Entry\n737: // ---------------------------------------------------------------------------\n738: \n739: // Global error handlers — prevent silent crashes\n740: process.on(\"uncaughtException\", (err) => {\n741:   console.error(`\\n[FATAL] Uncaught exception: ${err.message}`);\n742:   console.error(err.stack);\n743:   try {\n744:     const state = loadState(process.cwd());\n745:     if (state) saveState(process.cwd(), state);\n746:   } catch {}\n747:   process.exit(1);\n748: });\n749: \n750: process.on(\"unhandledRejection\", (reason: any) => {\n751:   console.error(`\\n[FATAL] Unhandled rejection: ${reason?.message || reason}`);\n752:   if (reason?.stack) console.error(reason.stack);\n753:   try {\n754:     const state = loadState(process.cwd());\n755:     if (state) saveState(process.cwd(), state);\n756:   } catch {}\n757:   process.exit(1);\n758: });\n759: \n760: main().catch((err) => {\n761:   console.error(\"Fatal error:\", err.message);\n762:   process.exit(1);\n763: });\n\n(End of file - total 763 lines)\n</content>","title":"src/index.ts","metadata":{"preview":"#!/usr/bin/env bun\n/**\n * index.ts — CLI entry point for the Wombo agent orchestration system.\n *\n * Usage:\n *   wombo init\n *   wombo launch --top-priority 3\n *   wombo launch --quickest-wins 5\n *   wombo launch --priority high\n *   wombo launch --difficulty easy\n *   wombo launch --features \"feat-a,feat-b\"\n *   wombo launch --all-ready\n *   wombo launch ... --max-concurrent 3 --model \"anthropic/claude-sonnet-4-20250514\"\n *   wombo launch ... --interactive\n *   wombo resume\n *   wombo status\n *   wombo verify [feature-id]\n *   wombo merge [feature-id]\n *   wombo retry <feature-id>\n *   wombo abort <feature-id> [--requeue] [--output json]","truncated":false,"loaded":[]},"time":{"start":1773351676250,"end":1773351676274}}}}
