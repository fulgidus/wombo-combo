{"type":"tool_use","timestamp":1773351679462,"sessionID":"ses_31c00ea90ffeMcRFqNZY7ExB1k","part":{"id":"prt_ce3ff338a0018WgBylcdy7MO2l","sessionID":"ses_31c00ea90ffeMcRFqNZY7ExB1k","messageID":"msg_ce3ff29b1001EXxeQ97IEiIzFP","type":"tool","callID":"toolu_vrtx_018sJHWcbsfzTWXdrAdjJBuw","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-cli-ux-polish/src/commands/launch.ts"},"output":"<path>/home/fulgidus/Documents/wombo-cli-ux-polish/src/commands/launch.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * launch.ts — Launch a wave of agents.\n3:  *\n4:  * Usage: wombo launch [selection options] [launch options]\n5:  *\n6:  * This is the primary entry point for starting a new wave. It selects features\n7:  * from the features file, creates a wave state, sets up worktrees, and launches\n8:  * agent processes (either headless or interactive via tmux).\n9:  *\n10:  * IMPORTANT: This file also exports shared helper functions that are reused\n11:  * by resume.ts and other commands:\n12:  *   - launchSingleHeadless\n13:  *   - handleBuildVerification\n14:  *   - handleRetry\n15:  *   - launchNextQueued\n16:  */\n17: \n18: import { execSync } from \"node:child_process\";\n19: import type { WomboConfig } from \"../config.js\";\n20: import type { Feature, SelectionOptions, Priority, Difficulty } from \"../lib/features.js\";\n21: import { loadFeatures, selectFeatures, parseDurationMinutes, saveFeatures } from \"../lib/features.js\";\n22: import {\n23:   loadState,\n24:   saveState,\n25:   createWaveState,\n26:   createAgentState,\n27:   updateAgent,\n28:   activeAgents,\n29:   queuedAgents,\n30:   isWaveComplete,\n31:   type WaveState,\n32:   type AgentState,\n33: } from \"../lib/state.js\";\n34: import {\n35:   createWorktree,\n36:   installDeps,\n37:   featureBranchName,\n38:   worktreePath,\n39:   worktreeReady,\n40:   branchHasChanges,\n41:   branchExists,\n42:   removeWorktree,\n43:   log as wtLog,\n44: } from \"../lib/worktree.js\";\n45: import { generatePrompt, generateConflictResolutionPrompt } from \"../lib/prompt.js\";\n46: import {\n47:   launchHeadless,\n48:   retryHeadless,\n49:   launchInteractive,\n50:   retryInteractive,\n51:   launchConflictResolver,\n52:   isProcessRunning,\n53: } from \"../lib/launcher.js\";\n54: import { ProcessMonitor } from \"../lib/monitor.js\";\n55: import { runBuild } from \"../lib/verifier.js\";\n56: import { mergeBranch, mergeBaseIntoFeature, pushBaseBranch } from \"../lib/merger.js\";\n57: import {\n58:   printDashboard,\n59:   printFeatureSelection,\n60:   printAgentUpdate,\n61: } from \"../lib/ui.js\";\n62: import { WomboTUI } from \"../lib/tui.js\";\n63: import { ensureAgentDefinition } from \"../lib/templates.js\";\n64: import { outputError, type OutputFormat } from \"../lib/output.js\";\n65: \n66: // ---------------------------------------------------------------------------\n67: // Types\n68: // ---------------------------------------------------------------------------\n69: \n70: export interface LaunchCommandOptions {\n71:   projectRoot: string;\n72:   config: WomboConfig;\n73:   // Selection\n74:   topPriority?: number;\n75:   quickestWins?: number;\n76:   priority?: Priority;\n77:   difficulty?: Difficulty;\n78:   features?: string[];\n79:   allReady?: boolean;\n80:   // Launch\n81:   maxConcurrent: number;\n82:   model?: string;\n83:   interactive: boolean;\n84:   dryRun: boolean;\n85:   baseBranch: string;\n86:   maxRetries: number;\n87:   noTui: boolean;\n88:   autoPush: boolean;\n89:   // Output\n90:   outputFmt?: OutputFormat;\n91: }\n92: \n93: // ---------------------------------------------------------------------------\n94: // Shared Helpers (exported for resume.ts and others)\n95: // ---------------------------------------------------------------------------\n96: \n97: /**\n98:  * Mark a feature as done in the features file after a successful merge.\n99:  * Updates status to \"done\", completion to 100, and sets ended_at.\n100:  *\n101:  * GUARD: Verifies that the feature branch has actually been merged into\n102:  * baseBranch before allowing the status change. This prevents callers\n103:  * from accidentally marking verified-but-unmerged features as done.\n104:  */\n105: export function markFeatureDone(\n106:   projectRoot: string,\n107:   featureId: string,\n108:   config: WomboConfig,\n109:   baseBranch: string\n110: ): void {\n111:   try {\n112:     // Verify the feature branch was actually merged into base\n113:     const branch = featureBranchName(featureId, config);\n114:     try {\n115:       execSync(`git merge-base --is-ancestor \"${branch}\" \"${baseBranch}\"`, {\n116:         cwd: projectRoot,\n117:         stdio: \"pipe\",\n118:       });\n119:     } catch {\n120:       // git merge-base --is-ancestor exits non-zero if NOT an ancestor\n121:       console.error(\n122:         `Warning: ${featureId} branch \"${branch}\" is not merged into \"${baseBranch}\" — refusing to mark as done`\n123:       );\n124:       return;\n125:     }\n126: \n127:     const data = loadFeatures(projectRoot, config);\n128:     const feature = data.features.find((f) => f.id === featureId);\n129:     if (feature && feature.status !== \"done\") {\n130:       feature.status = \"done\";\n131:       feature.completion = 100;\n132:       feature.ended_at = new Date().toISOString();\n133:       saveFeatures(projectRoot, config, data);\n134:     }\n135:   } catch (err: any) {\n136:     // Non-fatal — log but don't crash the wave\n137:     console.error(`Warning: failed to update feature status for ${featureId}: ${err.message}`);\n138:   }\n139: }\n140: \n141: /**\n142:  * Launch a single agent in headless mode.\n143:  * Sets up worktree, installs deps, generates prompt, launches agent process.\n144:  */\n145: export async function launchSingleHeadless(\n146:   projectRoot: string,\n147:   state: WaveState,\n148:   agent: AgentState,\n149:   feature: Feature,\n150:   monitor: ProcessMonitor,\n151:   config: WomboConfig,\n152:   model?: string\n153: ): Promise<void> {\n154:   updateAgent(state, agent.feature_id, {\n155:     status: \"installing\",\n156:     started_at: new Date().toISOString(),\n157:     activity: \"setting up worktree...\",\n158:   });\n159:   saveState(projectRoot, state);\n160: \n161:   try {\n162:     // Skip worktree setup if already ready (resume case)\n163:     if (worktreeReady(agent.worktree)) {\n164:       wtLog(agent.feature_id, \"worktree already exists, skipping setup\");\n165:     } else {\n166:       // Create worktree (async — doesn't block other agents)\n167:       await createWorktree(projectRoot, feature.id, state.base_branch, config);\n168: \n169:       // Install dependencies (async)\n170:       updateAgent(state, agent.feature_id, { activity: \"installing deps...\" });\n171:       await installDeps(agent.worktree, feature.id, config);\n172:     }\n173: \n174:     // Generate prompt\n175:     const prompt = generatePrompt(feature, state.base_branch, config);\n176: \n177:     // Launch agent\n178:     wtLog(agent.feature_id, \"launching agent...\");\n179:     const result = launchHeadless({\n180:       worktreePath: agent.worktree,\n181:       featureId: feature.id,\n182:       prompt,\n183:       model,\n184:       config,\n185:     });\n186: \n187:     updateAgent(state, agent.feature_id, {\n188:       status: \"running\",\n189:       pid: result.pid,\n190:       activity: \"starting...\",\n191:     });\n192:     saveState(projectRoot, state);\n193: \n194:     monitor.addProcess(feature.id, result.process);\n195:     wtLog(agent.feature_id, `running (PID: ${result.pid})`);\n196:   } catch (err: any) {\n197:     updateAgent(state, agent.feature_id, {\n198:       status: \"failed\",\n199:       error: err.message,\n200:       activity: null,\n201:       completed_at: new Date().toISOString(),\n202:     });\n203:     saveState(projectRoot, state);\n204:     wtLog(agent.feature_id, `SETUP FAILED: ${err.message.split(\"\\n\")[0]}`);\n205:   }\n206: }\n207: \n208: /**\n209:  * Handle build verification after agent completion.\n210:  * Runs build, auto-merges on pass, retries on failure if retries remain.\n211:  *\n212:  * ASYNC — runs build and merge without blocking the event loop.\n213:  */\n214: export async function handleBuildVerification(\n215:   projectRoot: string,\n216:   state: WaveState,\n217:   agent: AgentState,\n218:   feature: Feature,\n219:   config: WomboConfig,\n220:   model?: string,\n221:   monitor?: ProcessMonitor\n222: ): Promise<void> {\n223:   try {\n224:     printAgentUpdate(agent, \"verifying build...\");\n225: \n226:     const buildResult = await runBuild(agent.worktree, config);\n227: \n228:     if (buildResult.passed) {\n229:       updateAgent(state, agent.feature_id, {\n230:         status: \"verified\",\n231:         build_passed: true,\n232:         build_output: null,\n233:       });\n234:       saveState(projectRoot, state);\n235:       printAgentUpdate(agent, `BUILD PASSED (${Math.round(buildResult.durationMs / 1000)}s)`);\n236: \n237:       // Auto-merge: attempt merge + conflict resolution\n238:       await attemptMerge(projectRoot, state, agent, feature, config, model);\n239:     } else {\n240:       if (agent.retries < agent.max_retries) {\n241:         updateAgent(state, agent.feature_id, {\n242:           status: \"retry\",\n243:           retries: agent.retries + 1,\n244:           build_passed: false,\n245:           build_output: buildResult.errorSummary,\n246:         });\n247:         saveState(projectRoot, state);\n248:         printAgentUpdate(\n249:           agent,\n250:           `BUILD FAILED — retrying (${agent.retries}/${agent.max_retries})`\n251:         );\n252: \n253:         // Retry with build errors\n254:         if (agent.session_id) {\n255:           const retryResult = retryHeadless({\n256:             worktreePath: agent.worktree,\n257:             featureId: agent.feature_id,\n258:             sessionId: agent.session_id,\n259:             buildErrors: buildResult.errorSummary,\n260:             model,\n261:             config,\n262:           });\n263: \n264:           updateAgent(state, agent.feature_id, {\n265:             status: \"running\",\n266:             pid: retryResult.pid,\n267:           });\n268:           saveState(projectRoot, state);\n269: \n270:           // Add retry process to monitor so events are tracked\n271:           if (monitor) {\n272:             monitor.addProcess(agent.feature_id, retryResult.process);\n273:           }\n274:         }\n275:       } else {\n276:         updateAgent(state, agent.feature_id, {\n277:           status: \"failed\",\n278:           build_passed: false,\n279:           build_output: buildResult.errorSummary,\n280:           error: `Build failed after ${agent.max_retries} retries`,\n281:           completed_at: new Date().toISOString(),\n282:         });\n283:         saveState(projectRoot, state);\n284:         printAgentUpdate(agent, \"BUILD FAILED — max retries reached\");\n285:       }\n286:     }\n287:   } catch (err: any) {\n288:     // Catch-all — never let build verification crash the process\n289:     printAgentUpdate(agent, `VERIFY ERROR: ${err.message?.slice(0, 100)}`);\n290:     updateAgent(state, agent.feature_id, {\n291:       status: \"failed\",\n292:       error: `Build verification error: ${err.message}`,\n293:       completed_at: new Date().toISOString(),\n294:     });\n295:     saveState(projectRoot, state);\n296:   }\n297: }\n298: \n299: /**\n300:  * Attempt to merge a verified agent's branch into the base branch.\n301:  *\n302:  * Handles conflict detection, base-into-feature merge, and resolver agent\n303:  * launch. Extracted from handleBuildVerification so it can be called\n304:  * independently (e.g., from resume's sequential merge phase).\n305:  */\n306: export async function attemptMerge(\n307:   projectRoot: string,\n308:   state: WaveState,\n309:   agent: AgentState,\n310:   feature: Feature,\n311:   config: WomboConfig,\n312:   model?: string,\n313: ): Promise<void> {\n314:   printAgentUpdate(agent, \"auto-merging...\");\n315:   try {\n316:     const mergeResult = await mergeBranch(projectRoot, agent.branch, state.base_branch, config);\n317: \n318:     if (mergeResult.success) {\n319:       updateAgent(state, agent.feature_id, {\n320:         status: \"merged\",\n321:         completed_at: new Date().toISOString(),\n322:       });\n323:       saveState(projectRoot, state);\n324:       printAgentUpdate(agent, `MERGED (${mergeResult.commitHash?.slice(0, 7)})`);\n325: \n326:       // Mark feature as done in .features.yml so it won't be re-selected\n327:       markFeatureDone(projectRoot, agent.feature_id, config, state.base_branch);\n328: \n329:       // Clean up worktree after successful merge\n330:       try {\n331:         removeWorktree(projectRoot, agent.worktree, true);\n332:         printAgentUpdate(agent, \"worktree and branch removed\");\n333:       } catch {\n334:         // Not critical — worktree cleanup is best-effort\n335:       }\n336:     } else {\n337:       // Merge failed — attempt automatic conflict resolution\n338:       const mergeError = mergeResult.error ?? \"Unknown merge error\";\n339:       printAgentUpdate(agent, `MERGE CONFLICT — attempting resolution...`);\n340: \n341:       try {\n342:         // Merge base INTO the feature worktree to create conflict markers\n343:         const conflictResult = await mergeBaseIntoFeature(\n344:           agent.worktree,\n345:           state.base_branch,\n346:           config\n347:         );\n348: \n349:         if (conflictResult.error && !conflictResult.conflicting) {\n350:           printAgentUpdate(agent, `CONFLICT SETUP FAILED: ${conflictResult.error.slice(0, 100)}`);\n351:           return; // Leave as \"verified\" for manual resolution\n352:         }\n353: \n354:         if (!conflictResult.conflicting) {\n355:           // Base merged cleanly into feature — retry merge into base.\n356:           printAgentUpdate(agent, \"base merged cleanly into feature — retrying merge...\");\n357:           const retryMerge = await mergeBranch(projectRoot, agent.branch, state.base_branch, config);\n358:           if (retryMerge.success) {\n359:             updateAgent(state, agent.feature_id, {\n360:               status: \"merged\",\n361:               completed_at: new Date().toISOString(),\n362:             });\n363:             saveState(projectRoot, state);\n364:             printAgentUpdate(agent, `MERGED after rebase (${retryMerge.commitHash?.slice(0, 7)})`);\n365:             markFeatureDone(projectRoot, agent.feature_id, config, state.base_branch);\n366:             try {\n367:               removeWorktree(projectRoot, agent.worktree, true);\n368:             } catch {}\n369:             return;\n370:           }\n371: \n372:           // Retry still failed — launch resolver agent\n373:           printAgentUpdate(agent, `retry merge still failed — launching resolver agent...`);\n374: \n375:           const secondConflict = await mergeBaseIntoFeature(\n376:             agent.worktree,\n377:             state.base_branch,\n378:             config\n379:           );\n380: \n381:           const conflictFiles = secondConflict.conflicting\n382:             ? secondConflict.files\n383:             : [\"(unknown — merge direction mismatch)\"];\n384:           const resolverMergeError = retryMerge.error ?? mergeError;\n385: \n386:           await launchResolverAndRetryMerge(\n387:             projectRoot, state, agent, feature, config, model,\n388:             resolverMergeError, conflictFiles\n389:           );\n390:           return;\n391:         }\n392: \n393:         // There are real conflicts — launch a resolver agent\n394:         printAgentUpdate(\n395:           agent,\n396:           `${conflictResult.files.length} conflicting file(s): ${conflictResult.files.join(\", \")}`\n397:         );\n398: \n399:         await launchResolverAndRetryMerge(\n400:           projectRoot, state, agent, feature, config, model,\n401:           mergeError, conflictResult.files\n402:         );\n403:       } catch (conflictErr: any) {\n404:         printAgentUpdate(agent, `CONFLICT RESOLUTION ERROR: ${conflictErr.message?.slice(0, 100)}`);\n405:         // Leave as \"verified\" for manual resolution\n406:       }\n407:     }\n408:   } catch (mergeErr: any) {\n409:     printAgentUpdate(agent, `AUTO-MERGE ERROR: ${mergeErr.message?.slice(0, 100)}`);\n410:   }\n411: }\n412: \n413: /**\n414:  * Launch a conflict resolver agent, wait for it to finish, re-verify build,\n415:  * and retry the merge. Extracted to avoid duplicating the resolver flow.\n416:  */\n417: async function launchResolverAndRetryMerge(\n418:   projectRoot: string,\n419:   state: WaveState,\n420:   agent: AgentState,\n421:   feature: Feature,\n422:   config: WomboConfig,\n423:   model: string | undefined,\n424:   mergeError: string,\n425:   conflictFiles: string[]\n426: ): Promise<void> {\n427:   const conflictPrompt = generateConflictResolutionPrompt(\n428:     feature,\n429:     state.base_branch,\n430:     mergeError,\n431:     config\n432:   );\n433: \n434:   updateAgent(state, agent.feature_id, {\n435:     status: \"resolving_conflict\",\n436:     activity: `resolving ${conflictFiles.length} conflict(s)...`,\n437:   });\n438:   saveState(projectRoot, state);\n439: \n440:   const resolverResult = launchConflictResolver({\n441:     worktreePath: agent.worktree,\n442:     featureId: agent.feature_id,\n443:     prompt: conflictPrompt,\n444:     model,\n445:     config,\n446:   });\n447: \n448:   updateAgent(state, agent.feature_id, {\n449:     pid: resolverResult.pid,\n450:   });\n451:   saveState(projectRoot, state);\n452: \n453:   // Wait for the resolver process to complete, then re-verify and retry merge.\n454:   // We intentionally do NOT add the resolver to the ProcessMonitor because\n455:   // the monitor's onComplete callback would trigger handleBuildVerification\n456:   // again, causing infinite recursion. Instead we await the process directly.\n457:   const resolverExitCode = await new Promise<number | null>((resolve) => {\n458:     resolverResult.process.on(\"exit\", (code) => resolve(code));\n459:     resolverResult.process.on(\"error\", () => resolve(null));\n460:   });\n461: \n462:   printAgentUpdate(agent, `conflict resolver exited (code ${resolverExitCode}) — re-verifying build...`);\n463: \n464:   // Re-verify build after conflict resolution\n465:   const rebuildResult = await runBuild(agent.worktree, config);\n466: \n467:   if (!rebuildResult.passed) {\n468:     printAgentUpdate(agent, `POST-CONFLICT BUILD FAILED`);\n469:     updateAgent(state, agent.feature_id, {\n470:       status: \"failed\",\n471:       build_passed: false,\n472:       build_output: rebuildResult.errorSummary,\n473:       error: \"Build failed after conflict resolution\",\n474:       completed_at: new Date().toISOString(),\n475:     });\n476:     saveState(projectRoot, state);\n477:     return;\n478:   }\n479: \n480:   printAgentUpdate(agent, \"post-conflict build passed — retrying merge...\");\n481: \n482:   const retryMerge = await mergeBranch(\n483:     projectRoot,\n484:     agent.branch,\n485:     state.base_branch,\n486:     config\n487:   );\n488: \n489:   if (retryMerge.success) {\n490:     updateAgent(state, agent.feature_id, {\n491:       status: \"merged\",\n492:       build_passed: true,\n493:       completed_at: new Date().toISOString(),\n494:     });\n495:     saveState(projectRoot, state);\n496:     printAgentUpdate(agent, `MERGED after conflict resolution (${retryMerge.commitHash?.slice(0, 7)})`);\n497:     markFeatureDone(projectRoot, agent.feature_id, config, state.base_branch);\n498:     try {\n499:       removeWorktree(projectRoot, agent.worktree, true);\n500:     } catch {}\n501:   } else {\n502:     printAgentUpdate(agent, `POST-CONFLICT MERGE FAILED: ${retryMerge.error}`);\n503:     updateAgent(state, agent.feature_id, {\n504:       status: \"failed\",\n505:       error: `Merge still failed after conflict resolution: ${retryMerge.error}`,\n506:       completed_at: new Date().toISOString(),\n507:     });\n508:     saveState(projectRoot, state);\n509:   }\n510: }\n511: \n512: /**\n513:  * Handle retry of a failed agent (error-based, not build-based).\n514:  */\n515: export function handleRetry(\n516:   projectRoot: string,\n517:   state: WaveState,\n518:   agent: AgentState,\n519:   monitor: ProcessMonitor,\n520:   config: WomboConfig,\n521:   model?: string\n522: ): void {\n523:   if (!agent.session_id || !agent.error) return;\n524: \n525:   const retryResult = retryHeadless({\n526:     worktreePath: agent.worktree,\n527:     featureId: agent.feature_id,\n528:     sessionId: agent.session_id,\n529:     buildErrors: agent.error,\n530:     model,\n531:     config,\n532:   });\n533: \n534:   updateAgent(state, agent.feature_id, {\n535:     status: \"running\",\n536:     pid: retryResult.pid,\n537:   });\n538:   saveState(projectRoot, state);\n539: \n540:   monitor.addProcess(agent.feature_id, retryResult.process);\n541: }\n542: \n543: /**\n544:  * Launch the next queued agent if capacity allows.\n545:  */\n546: export function launchNextQueued(\n547:   projectRoot: string,\n548:   state: WaveState,\n549:   featureMap: Map<string, Feature>,\n550:   monitor: ProcessMonitor,\n551:   config: WomboConfig,\n552:   model?: string\n553: ): void {\n554:   const active = activeAgents(state);\n555:   const queued = queuedAgents(state);\n556: \n557:   if (active.length < state.max_concurrent && queued.length > 0) {\n558:     const next = queued[0];\n559:     const feature = featureMap.get(next.feature_id);\n560:     if (feature) {\n561:       launchSingleHeadless(projectRoot, state, next, feature, monitor, config, model);\n562:     }\n563:   }\n564: }\n565: \n566: // ---------------------------------------------------------------------------\n567: // Headless Wave Launch\n568: // ---------------------------------------------------------------------------\n569: \n570: async function launchWaveHeadless(\n571:   projectRoot: string,\n572:   state: WaveState,\n573:   features: Feature[],\n574:   opts: LaunchCommandOptions\n575: ): Promise<void> {\n576:   const { config, model } = opts;\n577:   const featureMap = new Map(features.map((f) => [f.id, f]));\n578: \n579:   const monitor = new ProcessMonitor(projectRoot, {\n580:     onSessionId: (featureId, sessionId) => {\n581:       updateAgent(state, featureId, { session_id: sessionId });\n582:       saveState(projectRoot, state);\n583:     },\n584:     onComplete: (featureId) => {\n585:       updateAgent(state, featureId, {\n586:         status: \"completed\",\n587:         completed_at: new Date().toISOString(),\n588:       });\n589:       saveState(projectRoot, state);\n590: \n591:       // Run build verification — fire-and-forget\n592:       const agent = state.agents.find((a) => a.feature_id === featureId)!;\n593:       handleBuildVerification(projectRoot, state, agent, featureMap.get(featureId)!, config, model, monitor)\n594:         .then(() => launchNextQueued(projectRoot, state, featureMap, monitor, config, model))\n595:         .catch((err) => {\n596:           wtLog(featureId, `BUILD VERIFICATION UNHANDLED ERROR: ${err.message}`);\n597:           launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n598:         });\n599:     },\n600:     onError: (featureId, error) => {\n601:       const agent = state.agents.find((a) => a.feature_id === featureId)!;\n602:       if (agent.retries < agent.max_retries) {\n603:         updateAgent(state, featureId, {\n604:           status: \"retry\",\n605:           retries: agent.retries + 1,\n606:           error,\n607:         });\n608:         saveState(projectRoot, state);\n609: \n610:         // Retry\n611:         handleRetry(projectRoot, state, agent, monitor, config, model);\n612:       } else {\n613:         updateAgent(state, featureId, {\n614:           status: \"failed\",\n615:           error,\n616:           completed_at: new Date().toISOString(),\n617:         });\n618:         saveState(projectRoot, state);\n619:       }\n620: \n621:       // Try to launch next queued agent\n622:       launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n623:     },\n624:     onOutput: (_featureId, _data) => {\n625:       // Raw output — logged to file by ProcessMonitor\n626:     },\n627:     onActivity: (featureId, activity) => {\n628:       updateAgent(state, featureId, {\n629:         activity,\n630:         activity_updated_at: new Date().toISOString(),\n631:       });\n632:       // Don't save to disk on every activity — too frequent.\n633:     },\n634:   });\n635: \n636:   // Create the TUI — it will auto-refresh and show activity from the monitor\n637:   const tuiRef = { current: null as WomboTUI | null };\n638:   const startTUI = () => {\n639:     tuiRef.current = new WomboTUI({\n640:       state,\n641:       monitor,\n642:       projectRoot,\n643:       interactive: false,\n644:       config,\n645:       onQuit: () => {\n646:         // Same as SIGINT — save state and exit\n647:         for (const agent of state.agents) {\n648:           if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n649:             updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n650:           }\n651:         }\n652:         monitor.killAll();\n653:         saveState(projectRoot, state);\n654:         console.log(\"State saved. Use 'wombo resume' to continue.\");\n655:         process.exit(0);\n656:       },\n657:     });\n658:     tuiRef.current.start();\n659:   };\n660: \n661:   // Handle graceful shutdown\n662:   process.on(\"SIGINT\", () => {\n663:     if (tuiRef.current) tuiRef.current.stop();\n664:     for (const agent of state.agents) {\n665:       if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n666:         updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n667:       }\n668:     }\n669:     monitor.killAll();\n670:     saveState(projectRoot, state);\n671:     console.log(\"\\nState saved. Use 'wombo resume' to continue.\");\n672:     process.exit(0);\n673:   });\n674: \n675:   // Launch initial batch — set up worktrees in parallel\n676:   const tolaunch = queuedAgents(state).slice(0, opts.maxConcurrent);\n677:   console.log(`Setting up ${tolaunch.length} agent(s) in parallel...\\n`);\n678: \n679:   await Promise.all(\n680:     tolaunch.map((agent) =>\n681:       launchSingleHeadless(\n682:         projectRoot,\n683:         state,\n684:         agent,\n685:         featureMap.get(agent.feature_id)!,\n686:         monitor,\n687:         config,\n688:         model\n689:       )\n690:     )\n691:   );\n692: \n693:   const launched = state.agents.filter((a) => a.status === \"running\").length;\n694: \n695:   // Start the TUI dashboard (or skip if --no-tui)\n696:   if (opts.noTui) {\n697:     console.log(`${launched} agent(s) running. (--no-tui mode, dashboard prints every 15s)\\n`);\n698:     printDashboard(state);\n699:   } else {\n700:     console.log(`${launched} agent(s) running. Launching TUI...\\n`);\n701:     startTUI();\n702:   }\n703: \n704:   // Background monitoring loop — checks for dead processes and launches queued\n705:   const POLL_INTERVAL = 5000;\n706:   let dashboardCounter = 0;\n707:   while (!isWaveComplete(state)) {\n708:     await new Promise((r) => setTimeout(r, POLL_INTERVAL));\n709: \n710:     // Check for completed processes that weren't caught by event handlers\n711:     for (const agent of state.agents) {\n712:       if (\n713:         (agent.status === \"running\" || agent.status === \"resolving_conflict\") &&\n714:         agent.pid &&\n715:         !isProcessRunning(agent.pid) &&\n716:         !monitor.isRunning(agent.feature_id)\n717:       ) {\n718:         if (agent.status === \"resolving_conflict\") {\n719:           // Conflict resolver died — the await in handleBuildVerification\n720:           // will resolve via the 'exit' event, so nothing to do here\n721:           continue;\n722:         }\n723:         // Process exited but we didn't get a callback\n724:         // Check if the agent actually made any commits\n725:         if (!branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n726:           // Agent died without producing any code — mark as failed, not completed\n727:           updateAgent(state, agent.feature_id, {\n728:             status: \"failed\",\n729:             error: \"Agent process exited without making any commits\",\n730:             activity: null,\n731:             completed_at: new Date().toISOString(),\n732:           });\n733:           saveState(projectRoot, state);\n734:           wtLog(agent.feature_id, \"process died with no code changes — marked failed\");\n735:         } else {\n736:           updateAgent(state, agent.feature_id, {\n737:             status: \"completed\",\n738:             completed_at: new Date().toISOString(),\n739:             activity: \"done\",\n740:           });\n741:           saveState(projectRoot, state);\n742:           try {\n743:             await handleBuildVerification(projectRoot, state, agent, featureMap.get(agent.feature_id)!, config, model, monitor);\n744:           } catch (err: any) {\n745:             wtLog(agent.feature_id, `POLL VERIFY ERROR: ${err.message}`);\n746:           }\n747:         }\n748:         launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n749:       }\n750:     }\n751: \n752:     // Persist state periodically\n753:     saveState(projectRoot, state);\n754: \n755:     // Update TUI state reference (or print dashboard in --no-tui mode)\n756:     if (tuiRef.current) {\n757:       tuiRef.current.updateState(state);\n758:     } else if (opts.noTui) {\n759:       dashboardCounter++;\n760:       if (dashboardCounter % 3 === 0) {\n761:         printDashboard(state);\n762: \n763:         // Auto-push base branch if requested\n764:         if (opts.autoPush) {\n765:           const anyMerged = state.agents.some((a) => a.status === \"merged\");\n766:           if (anyMerged) {\n767:             await pushBaseBranch(projectRoot, state.base_branch, config);\n768:           } else {\n769:             console.log(\"No branches were merged — skipping push.\");\n770:           }\n771:         }\n772:       }\n773:     }\n774:   }\n775: \n776:   // Wave complete — tear down TUI and show final summary\n777:   if (tuiRef.current) tuiRef.current.stop();\n778:   printDashboard(state);\n779: \n780:   // Auto-push base branch if requested\n781:   if (opts.autoPush) {\n782:     await pushBaseBranch(projectRoot, state.base_branch, config);\n783:   }\n784: \n785:   console.log(\"Wave complete.\");\n786: }\n787: \n788: // ---------------------------------------------------------------------------\n789: // Interactive Wave Launch\n790: // ---------------------------------------------------------------------------\n791: \n792: async function launchWaveInteractive(\n793:   projectRoot: string,\n794:   state: WaveState,\n795:   features: Feature[],\n796:   opts: LaunchCommandOptions\n797: ): Promise<void> {\n798:   const { config, model } = opts;\n799:   const featureMap = new Map(features.map((f) => [f.id, f]));\n800: \n801:   // Show dashboard immediately\n802:   printDashboard(state);\n803: \n804:   // Launch initial batch in tmux — parallelize setup\n805:   const tolaunch = queuedAgents(state).slice(0, opts.maxConcurrent);\n806:   console.log(`Setting up ${tolaunch.length} agent(s) in parallel...\\n`);\n807: \n808:   await Promise.all(\n809:     tolaunch.map(async (agent) => {\n810:       updateAgent(state, agent.feature_id, {\n811:         status: \"installing\",\n812:         started_at: new Date().toISOString(),\n813:         activity: \"setting up worktree...\",\n814:       });\n815:       saveState(projectRoot, state);\n816: \n817:       try {\n818:         if (worktreeReady(agent.worktree)) {\n819:           wtLog(agent.feature_id, \"worktree already exists, skipping setup\");\n820:         } else {\n821:           await createWorktree(projectRoot, agent.feature_id, state.base_branch, config);\n822:           updateAgent(state, agent.feature_id, { activity: \"installing deps...\" });\n823:           await installDeps(agent.worktree, agent.feature_id, config);\n824:         }\n825: \n826:         const prompt = generatePrompt(\n827:           featureMap.get(agent.feature_id)!,\n828:           state.base_branch,\n829:           config\n830:         );\n831: \n832:         wtLog(agent.feature_id, \"launching tmux session...\");\n833:         const result = launchInteractive({\n834:           worktreePath: agent.worktree,\n835:           featureId: agent.feature_id,\n836:           prompt,\n837:           model,\n838:           interactive: true,\n839:           config,\n840:         });\n841: \n842:         updateAgent(state, agent.feature_id, {\n843:           status: \"running\",\n844:           pid: result.pid,\n845:           activity: \"tmux session active\",\n846:         });\n847:         saveState(projectRoot, state);\n848:         wtLog(agent.feature_id, `tmux session: ${config.agent.tmuxPrefix}-${agent.feature_id}`);\n849:       } catch (err: any) {\n850:         updateAgent(state, agent.feature_id, {\n851:           status: \"failed\",\n852:           error: err.message,\n853:           activity: null,\n854:           completed_at: new Date().toISOString(),\n855:         });\n856:         saveState(projectRoot, state);\n857:         wtLog(agent.feature_id, `SETUP FAILED: ${err.message.split(\"\\n\")[0]}`);\n858:       }\n859:     })\n860:   );\n861: \n862:   console.log(\"\\nInteractive sessions launched. Use these commands:\");\n863:   console.log(`  tmux attach -t ${config.agent.tmuxPrefix}-<feature-id>   # attach to a session`);\n864:   console.log(\"  tmux ls                                                  # list sessions\");\n865:   console.log(\"  wombo status                                             # check status\");\n866:   console.log(\"  wombo verify                                             # verify builds\");\n867:   console.log(\"  wombo merge                                              # merge verified\");\n868:   console.log(\"  wombo cleanup                                            # remove worktrees\");\n869: \n870:   printDashboard(state);\n871: }\n872: \n873: // ---------------------------------------------------------------------------\n874: // Main Command\n875: // ---------------------------------------------------------------------------\n876: \n877: export async function cmdLaunch(opts: LaunchCommandOptions): Promise<void> {\n878:   const { projectRoot, config } = opts;\n879: \n880:   console.log(\"\\n--- Wombo: Launch ---\\n\");\n881: \n882:   // Ensure agent definition exists — reinstall from template if missing\n883:   ensureAgentDefinition(projectRoot, config);\n884: \n885:   // -------------------------------------------------------------------------\n886:   // Validate that the configured baseBranch exists as a local branch\n887:   // -------------------------------------------------------------------------\n888:   if (!branchExists(projectRoot, opts.baseBranch)) {\n889:     const fmt = opts.outputFmt ?? \"text\";\n890:     const msg = `Base branch \"${opts.baseBranch}\" does not exist as a local branch. ` +\n891:       `Create it first (e.g. \"git checkout -b ${opts.baseBranch}\") or specify ` +\n892:       `a different branch with --base-branch.`;\n893:     outputError(fmt, msg);\n894:   }\n895: \n896:   // -------------------------------------------------------------------------\n897:   // Check for existing wave state — don't overwrite work in progress\n898:   // -------------------------------------------------------------------------\n899:   const existingState = loadState(projectRoot);\n900:   if (existingState) {\n901:     const merged = existingState.agents.filter((a) => a.status === \"merged\");\n902:     const verified = existingState.agents.filter((a) => a.status === \"verified\");\n903:     const completed = existingState.agents.filter((a) => a.status === \"completed\");\n904:     const running = existingState.agents.filter((a) => a.status === \"running\");\n905:     const queued = existingState.agents.filter((a) => a.status === \"queued\");\n906:     const failed = existingState.agents.filter((a) => a.status === \"failed\");\n907: \n908:     const hasWork = merged.length > 0 || verified.length > 0 || completed.length > 0 || running.length > 0;\n909: \n910:     if (hasWork) {\n911:       console.log(`Existing wave found: ${existingState.wave_id}`);\n912:       console.log(`  ${merged.length} merged, ${verified.length} verified, ${completed.length} completed, ${running.length} running, ${queued.length} queued, ${failed.length} failed`);\n913: \n914:       // Finalize any merged agents by marking their features as done\n915:       if (merged.length > 0) {\n916:         console.log(\"\\nFinalizing merged features in .features.yml...\");\n917:         for (const agent of merged) {\n918:           markFeatureDone(projectRoot, agent.feature_id, config, existingState.base_branch);\n919:           // Clean up worktree and branch (already merged, safe to delete)\n920:           try {\n921:             removeWorktree(projectRoot, agent.worktree, true);\n922:             console.log(`  ${agent.feature_id}: marked done, worktree removed`);\n923:           } catch {\n924:             console.log(`  ${agent.feature_id}: marked done (worktree already cleaned)`);\n925:           }\n926:         }\n927:       }\n928: \n929:       // Verified agents: build passed but NOT merged — do NOT mark done.\n930:       // Leave them for 'wombo resume' to attempt the merge.\n931:       if (verified.length > 0) {\n932:         for (const agent of verified) {\n933:           console.log(`  ${agent.feature_id}: verified (not yet merged) — use 'wombo resume' to merge`);\n934:         }\n935:       }\n936: \n937:       const activeCount = running.length + completed.length + queued.length;\n938:       if (activeCount > 0) {\n939:         console.error(`\\nWave ${existingState.wave_id} has ${activeCount} unfinished agent(s).`);\n940:         console.error(\"Use 'wombo resume' to continue the existing wave,\");\n941:         console.error(\"or 'wombo cleanup' to clear it before starting a new one.\");\n942:         process.exit(1);\n943:       }\n944: \n945:       // All agents are in terminal states (merged/verified/failed) — safe to start fresh\n946:       console.log(\"\\nAll agents in previous wave are finished. Starting fresh wave.\\n\");\n947:     }\n948:   }\n949: \n950:   // Load features\n951:   const data = loadFeatures(projectRoot, config);\n952: \n953:   // Build selection options\n954:   const selOpts: SelectionOptions = {};\n955:   if (opts.topPriority) selOpts.topPriority = opts.topPriority;\n956:   if (opts.quickestWins) selOpts.quickestWins = opts.quickestWins;\n957:   if (opts.priority) selOpts.priority = opts.priority;\n958:   if (opts.difficulty) selOpts.difficulty = opts.difficulty;\n959:   if (opts.features) selOpts.featureIds = opts.features;\n960:   if (opts.allReady) selOpts.allReady = true;\n961: \n962:   // Select features\n963:   const selected = selectFeatures(data, selOpts);\n964: \n965:   if (selected.length === 0) {\n966:     if (opts.allReady) {\n967:       console.error(\n968:         \"No launchable features found. All features may be done, cancelled, or have unmet dependencies.\"\n969:       );\n970:     } else {\n971:       console.error(\n972:         \"No features matched the selection criteria. Use --all-ready to see all available.\"\n973:       );\n974:     }\n975:     process.exit(1);\n976:   }\n977: \n978:   // Show selection\n979:   printFeatureSelection(\n980:     selected.map((f) => ({\n981:       id: f.id,\n982:       title: f.title,\n983:       priority: f.priority,\n984:       difficulty: f.difficulty,\n985:       effort: f.effort,\n986:     }))\n987:   );\n988: \n989:   if (opts.dryRun) {\n990:     console.log(\"Dry run — not launching agents.\");\n991:     return;\n992:   }\n993: \n994:   // Create wave state\n995:   const state = createWaveState({\n996:     baseBranch: opts.baseBranch,\n997:     maxConcurrent: opts.maxConcurrent,\n998:     model: opts.model ?? null,\n999:     interactive: opts.interactive,\n1000:   });\n1001: \n1002:   // Create agent entries for all selected features\n1003:   for (const feature of selected) {\n1004:     const branch = featureBranchName(feature.id, config);\n1005:     const wtPath = worktreePath(projectRoot, feature.id, config);\n1006:     const agent = createAgentState(feature.id, branch, wtPath, opts.maxRetries);\n1007:     // Set effort estimate from feature spec\n1008:     const effortMinutes = parseDurationMinutes(feature.effort);\n1009:     agent.effort_estimate_ms = effortMinutes === Infinity ? null : effortMinutes * 60 * 1000;\n1010:     state.agents.push(agent);\n1011:   }\n1012: \n1013:   saveState(projectRoot, state);\n1014:   console.log(`Wave ${state.wave_id} created with ${selected.length} agents.`);\n1015: \n1016:   // Launch agents up to max_concurrent\n1017:   if (opts.interactive) {\n1018:     await launchWaveInteractive(projectRoot, state, selected, opts);\n1019:   } else {\n1020:     await launchWaveHeadless(projectRoot, state, selected, opts);\n1021:   }\n1022: }\n\n(End of file - total 1022 lines)\n</content>","title":"src/commands/launch.ts","metadata":{"preview":"/**\n * launch.ts — Launch a wave of agents.\n *\n * Usage: wombo launch [selection options] [launch options]\n *\n * This is the primary entry point for starting a new wave. It selects features\n * from the features file, creates a wave state, sets up worktrees, and launches\n * agent processes (either headless or interactive via tmux).\n *\n * IMPORTANT: This file also exports shared helper functions that are reused\n * by resume.ts and other commands:\n *   - launchSingleHeadless\n *   - handleBuildVerification\n *   - handleRetry\n *   - launchNextQueued\n */\n\nimport { execSync } from \"node:child_process\";\nimport type { WomboConfig } from \"../config.js\";\nimport type { Feature, SelectionOptions, Priority, Difficulty } from \"../lib/features.js\";","truncated":false,"loaded":[]},"time":{"start":1773351679455,"end":1773351679460}}}}
