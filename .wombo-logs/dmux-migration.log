{"type":"tool_use","timestamp":1773352360641,"sessionID":"ses_31bfd06f5ffeleRCi6uuMulALr","part":{"id":"prt_ce4099987001rk588nhA51klVZ","sessionID":"ses_31bfd06f5ffeleRCi6uuMulALr","messageID":"msg_ce4098fd40015SE7xIFe7a3vBH","type":"tool","callID":"toolu_vrtx_014Y2jbBQWZNtjBTuyebYRCa","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-dmux-migration/src/commands/launch.ts"},"output":"<path>/home/fulgidus/Documents/wombo-dmux-migration/src/commands/launch.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * launch.ts — Launch a wave of agents.\n3:  *\n4:  * Usage: wombo launch [selection options] [launch options]\n5:  *\n6:  * This is the primary entry point for starting a new wave. It selects features\n7:  * from the features file, creates a wave state, sets up worktrees, and launches\n8:  * agent processes (either headless or interactive via dmux/tmux).\n9:  *\n10:  * IMPORTANT: This file also exports shared helper functions that are reused\n11:  * by resume.ts and other commands:\n12:  *   - launchSingleHeadless\n13:  *   - handleBuildVerification\n14:  *   - handleRetry\n15:  *   - launchNextQueued\n16:  */\n17: \n18: import { execSync } from \"node:child_process\";\n19: import type { WomboConfig } from \"../config.js\";\n20: import type { Feature, SelectionOptions, Priority, Difficulty } from \"../lib/features.js\";\n21: import { loadFeatures, selectFeatures, parseDurationMinutes, saveFeatures } from \"../lib/features.js\";\n22: import {\n23:   loadState,\n24:   saveState,\n25:   createWaveState,\n26:   createAgentState,\n27:   updateAgent,\n28:   activeAgents,\n29:   queuedAgents,\n30:   isWaveComplete,\n31:   type WaveState,\n32:   type AgentState,\n33: } from \"../lib/state.js\";\n34: import {\n35:   createWorktree,\n36:   installDeps,\n37:   featureBranchName,\n38:   worktreePath,\n39:   worktreeReady,\n40:   branchHasChanges,\n41:   branchExists,\n42:   removeWorktree,\n43:   log as wtLog,\n44: } from \"../lib/worktree.js\";\n45: import { generatePrompt, generateConflictResolutionPrompt } from \"../lib/prompt.js\";\n46: import {\n47:   launchHeadless,\n48:   retryHeadless,\n49:   launchInteractive,\n50:   retryInteractive,\n51:   launchConflictResolver,\n52:   isProcessRunning,\n53:   getMultiplexerName,\n54: } from \"../lib/launcher.js\";\n55: import { ProcessMonitor } from \"../lib/monitor.js\";\n56: import { runBuild } from \"../lib/verifier.js\";\n57: import { mergeBranch, mergeBaseIntoFeature, pushBaseBranch } from \"../lib/merger.js\";\n58: import {\n59:   printDashboard,\n60:   printFeatureSelection,\n61:   printAgentUpdate,\n62: } from \"../lib/ui.js\";\n63: import { WomboTUI } from \"../lib/tui.js\";\n64: import { ensureAgentDefinition } from \"../lib/templates.js\";\n65: import { outputError, type OutputFormat } from \"../lib/output.js\";\n66: import {\n67:   detectMultiplexer,\n68:   muxAttachCommand,\n69:   muxListCommand,\n70: } from \"../lib/multiplexer.js\";\n71: \n72: // ---------------------------------------------------------------------------\n73: // Types\n74: // ---------------------------------------------------------------------------\n75: \n76: export interface LaunchCommandOptions {\n77:   projectRoot: string;\n78:   config: WomboConfig;\n79:   // Selection\n80:   topPriority?: number;\n81:   quickestWins?: number;\n82:   priority?: Priority;\n83:   difficulty?: Difficulty;\n84:   features?: string[];\n85:   allReady?: boolean;\n86:   // Launch\n87:   maxConcurrent: number;\n88:   model?: string;\n89:   interactive: boolean;\n90:   dryRun: boolean;\n91:   baseBranch: string;\n92:   maxRetries: number;\n93:   noTui: boolean;\n94:   autoPush: boolean;\n95:   // Output\n96:   outputFmt?: OutputFormat;\n97: }\n98: \n99: // ---------------------------------------------------------------------------\n100: // Shared Helpers (exported for resume.ts and others)\n101: // ---------------------------------------------------------------------------\n102: \n103: /**\n104:  * Mark a feature as done in the features file after a successful merge.\n105:  * Updates status to \"done\", completion to 100, and sets ended_at.\n106:  *\n107:  * GUARD: Verifies that the feature branch has actually been merged into\n108:  * baseBranch before allowing the status change. This prevents callers\n109:  * from accidentally marking verified-but-unmerged features as done.\n110:  */\n111: export function markFeatureDone(\n112:   projectRoot: string,\n113:   featureId: string,\n114:   config: WomboConfig,\n115:   baseBranch: string\n116: ): void {\n117:   try {\n118:     // Verify the feature branch was actually merged into base\n119:     const branch = featureBranchName(featureId, config);\n120:     try {\n121:       execSync(`git merge-base --is-ancestor \"${branch}\" \"${baseBranch}\"`, {\n122:         cwd: projectRoot,\n123:         stdio: \"pipe\",\n124:       });\n125:     } catch {\n126:       // git merge-base --is-ancestor exits non-zero if NOT an ancestor\n127:       console.error(\n128:         `Warning: ${featureId} branch \"${branch}\" is not merged into \"${baseBranch}\" — refusing to mark as done`\n129:       );\n130:       return;\n131:     }\n132: \n133:     const data = loadFeatures(projectRoot, config);\n134:     const feature = data.features.find((f) => f.id === featureId);\n135:     if (feature && feature.status !== \"done\") {\n136:       feature.status = \"done\";\n137:       feature.completion = 100;\n138:       feature.ended_at = new Date().toISOString();\n139:       saveFeatures(projectRoot, config, data);\n140:     }\n141:   } catch (err: any) {\n142:     // Non-fatal — log but don't crash the wave\n143:     console.error(`Warning: failed to update feature status for ${featureId}: ${err.message}`);\n144:   }\n145: }\n146: \n147: /**\n148:  * Launch a single agent in headless mode.\n149:  * Sets up worktree, installs deps, generates prompt, launches agent process.\n150:  */\n151: export async function launchSingleHeadless(\n152:   projectRoot: string,\n153:   state: WaveState,\n154:   agent: AgentState,\n155:   feature: Feature,\n156:   monitor: ProcessMonitor,\n157:   config: WomboConfig,\n158:   model?: string\n159: ): Promise<void> {\n160:   updateAgent(state, agent.feature_id, {\n161:     status: \"installing\",\n162:     started_at: new Date().toISOString(),\n163:     activity: \"setting up worktree...\",\n164:   });\n165:   saveState(projectRoot, state);\n166: \n167:   try {\n168:     // Skip worktree setup if already ready (resume case)\n169:     if (worktreeReady(agent.worktree)) {\n170:       wtLog(agent.feature_id, \"worktree already exists, skipping setup\");\n171:     } else {\n172:       // Create worktree (async — doesn't block other agents)\n173:       await createWorktree(projectRoot, feature.id, state.base_branch, config);\n174: \n175:       // Install dependencies (async)\n176:       updateAgent(state, agent.feature_id, { activity: \"installing deps...\" });\n177:       await installDeps(agent.worktree, feature.id, config);\n178:     }\n179: \n180:     // Generate prompt\n181:     const prompt = generatePrompt(feature, state.base_branch, config);\n182: \n183:     // Launch agent\n184:     wtLog(agent.feature_id, \"launching agent...\");\n185:     const result = launchHeadless({\n186:       worktreePath: agent.worktree,\n187:       featureId: feature.id,\n188:       prompt,\n189:       model,\n190:       config,\n191:     });\n192: \n193:     updateAgent(state, agent.feature_id, {\n194:       status: \"running\",\n195:       pid: result.pid,\n196:       activity: \"starting...\",\n197:     });\n198:     saveState(projectRoot, state);\n199: \n200:     monitor.addProcess(feature.id, result.process);\n201:     wtLog(agent.feature_id, `running (PID: ${result.pid})`);\n202:   } catch (err: any) {\n203:     updateAgent(state, agent.feature_id, {\n204:       status: \"failed\",\n205:       error: err.message,\n206:       activity: null,\n207:       completed_at: new Date().toISOString(),\n208:     });\n209:     saveState(projectRoot, state);\n210:     wtLog(agent.feature_id, `SETUP FAILED: ${err.message.split(\"\\n\")[0]}`);\n211:   }\n212: }\n213: \n214: /**\n215:  * Handle build verification after agent completion.\n216:  * Runs build, auto-merges on pass, retries on failure if retries remain.\n217:  *\n218:  * ASYNC — runs build and merge without blocking the event loop.\n219:  */\n220: export async function handleBuildVerification(\n221:   projectRoot: string,\n222:   state: WaveState,\n223:   agent: AgentState,\n224:   feature: Feature,\n225:   config: WomboConfig,\n226:   model?: string,\n227:   monitor?: ProcessMonitor\n228: ): Promise<void> {\n229:   try {\n230:     printAgentUpdate(agent, \"verifying build...\");\n231: \n232:     const buildResult = await runBuild(agent.worktree, config);\n233: \n234:     if (buildResult.passed) {\n235:       updateAgent(state, agent.feature_id, {\n236:         status: \"verified\",\n237:         build_passed: true,\n238:         build_output: null,\n239:       });\n240:       saveState(projectRoot, state);\n241:       printAgentUpdate(agent, `BUILD PASSED (${Math.round(buildResult.durationMs / 1000)}s)`);\n242: \n243:       // Auto-merge: attempt merge + conflict resolution\n244:       await attemptMerge(projectRoot, state, agent, feature, config, model);\n245:     } else {\n246:       if (agent.retries < agent.max_retries) {\n247:         updateAgent(state, agent.feature_id, {\n248:           status: \"retry\",\n249:           retries: agent.retries + 1,\n250:           build_passed: false,\n251:           build_output: buildResult.errorSummary,\n252:         });\n253:         saveState(projectRoot, state);\n254:         printAgentUpdate(\n255:           agent,\n256:           `BUILD FAILED — retrying (${agent.retries}/${agent.max_retries})`\n257:         );\n258: \n259:         // Retry with build errors\n260:         if (agent.session_id) {\n261:           const retryResult = retryHeadless({\n262:             worktreePath: agent.worktree,\n263:             featureId: agent.feature_id,\n264:             sessionId: agent.session_id,\n265:             buildErrors: buildResult.errorSummary,\n266:             model,\n267:             config,\n268:           });\n269: \n270:           updateAgent(state, agent.feature_id, {\n271:             status: \"running\",\n272:             pid: retryResult.pid,\n273:           });\n274:           saveState(projectRoot, state);\n275: \n276:           // Add retry process to monitor so events are tracked\n277:           if (monitor) {\n278:             monitor.addProcess(agent.feature_id, retryResult.process);\n279:           }\n280:         }\n281:       } else {\n282:         updateAgent(state, agent.feature_id, {\n283:           status: \"failed\",\n284:           build_passed: false,\n285:           build_output: buildResult.errorSummary,\n286:           error: `Build failed after ${agent.max_retries} retries`,\n287:           completed_at: new Date().toISOString(),\n288:         });\n289:         saveState(projectRoot, state);\n290:         printAgentUpdate(agent, \"BUILD FAILED — max retries reached\");\n291:       }\n292:     }\n293:   } catch (err: any) {\n294:     // Catch-all — never let build verification crash the process\n295:     printAgentUpdate(agent, `VERIFY ERROR: ${err.message?.slice(0, 100)}`);\n296:     updateAgent(state, agent.feature_id, {\n297:       status: \"failed\",\n298:       error: `Build verification error: ${err.message}`,\n299:       completed_at: new Date().toISOString(),\n300:     });\n301:     saveState(projectRoot, state);\n302:   }\n303: }\n304: \n305: /**\n306:  * Attempt to merge a verified agent's branch into the base branch.\n307:  *\n308:  * Handles conflict detection, base-into-feature merge, and resolver agent\n309:  * launch. Extracted from handleBuildVerification so it can be called\n310:  * independently (e.g., from resume's sequential merge phase).\n311:  */\n312: export async function attemptMerge(\n313:   projectRoot: string,\n314:   state: WaveState,\n315:   agent: AgentState,\n316:   feature: Feature,\n317:   config: WomboConfig,\n318:   model?: string,\n319: ): Promise<void> {\n320:   printAgentUpdate(agent, \"auto-merging...\");\n321:   try {\n322:     const mergeResult = await mergeBranch(projectRoot, agent.branch, state.base_branch, config);\n323: \n324:     if (mergeResult.success) {\n325:       updateAgent(state, agent.feature_id, {\n326:         status: \"merged\",\n327:         completed_at: new Date().toISOString(),\n328:       });\n329:       saveState(projectRoot, state);\n330:       printAgentUpdate(agent, `MERGED (${mergeResult.commitHash?.slice(0, 7)})`);\n331: \n332:       // Mark feature as done in .features.yml so it won't be re-selected\n333:       markFeatureDone(projectRoot, agent.feature_id, config, state.base_branch);\n334: \n335:       // Clean up worktree after successful merge\n336:       try {\n337:         removeWorktree(projectRoot, agent.worktree, true);\n338:         printAgentUpdate(agent, \"worktree and branch removed\");\n339:       } catch {\n340:         // Not critical — worktree cleanup is best-effort\n341:       }\n342:     } else {\n343:       // Merge failed — attempt automatic conflict resolution\n344:       const mergeError = mergeResult.error ?? \"Unknown merge error\";\n345:       printAgentUpdate(agent, `MERGE CONFLICT — attempting resolution...`);\n346: \n347:       try {\n348:         // Merge base INTO the feature worktree to create conflict markers\n349:         const conflictResult = await mergeBaseIntoFeature(\n350:           agent.worktree,\n351:           state.base_branch,\n352:           config\n353:         );\n354: \n355:         if (conflictResult.error && !conflictResult.conflicting) {\n356:           printAgentUpdate(agent, `CONFLICT SETUP FAILED: ${conflictResult.error.slice(0, 100)}`);\n357:           return; // Leave as \"verified\" for manual resolution\n358:         }\n359: \n360:         if (!conflictResult.conflicting) {\n361:           // Base merged cleanly into feature — retry merge into base.\n362:           printAgentUpdate(agent, \"base merged cleanly into feature — retrying merge...\");\n363:           const retryMerge = await mergeBranch(projectRoot, agent.branch, state.base_branch, config);\n364:           if (retryMerge.success) {\n365:             updateAgent(state, agent.feature_id, {\n366:               status: \"merged\",\n367:               completed_at: new Date().toISOString(),\n368:             });\n369:             saveState(projectRoot, state);\n370:             printAgentUpdate(agent, `MERGED after rebase (${retryMerge.commitHash?.slice(0, 7)})`);\n371:             markFeatureDone(projectRoot, agent.feature_id, config, state.base_branch);\n372:             try {\n373:               removeWorktree(projectRoot, agent.worktree, true);\n374:             } catch {}\n375:             return;\n376:           }\n377: \n378:           // Retry still failed — launch resolver agent\n379:           printAgentUpdate(agent, `retry merge still failed — launching resolver agent...`);\n380: \n381:           const secondConflict = await mergeBaseIntoFeature(\n382:             agent.worktree,\n383:             state.base_branch,\n384:             config\n385:           );\n386: \n387:           const conflictFiles = secondConflict.conflicting\n388:             ? secondConflict.files\n389:             : [\"(unknown — merge direction mismatch)\"];\n390:           const resolverMergeError = retryMerge.error ?? mergeError;\n391: \n392:           await launchResolverAndRetryMerge(\n393:             projectRoot, state, agent, feature, config, model,\n394:             resolverMergeError, conflictFiles\n395:           );\n396:           return;\n397:         }\n398: \n399:         // There are real conflicts — launch a resolver agent\n400:         printAgentUpdate(\n401:           agent,\n402:           `${conflictResult.files.length} conflicting file(s): ${conflictResult.files.join(\", \")}`\n403:         );\n404: \n405:         await launchResolverAndRetryMerge(\n406:           projectRoot, state, agent, feature, config, model,\n407:           mergeError, conflictResult.files\n408:         );\n409:       } catch (conflictErr: any) {\n410:         printAgentUpdate(agent, `CONFLICT RESOLUTION ERROR: ${conflictErr.message?.slice(0, 100)}`);\n411:         // Leave as \"verified\" for manual resolution\n412:       }\n413:     }\n414:   } catch (mergeErr: any) {\n415:     printAgentUpdate(agent, `AUTO-MERGE ERROR: ${mergeErr.message?.slice(0, 100)}`);\n416:   }\n417: }\n418: \n419: /**\n420:  * Launch a conflict resolver agent, wait for it to finish, re-verify build,\n421:  * and retry the merge. Extracted to avoid duplicating the resolver flow.\n422:  */\n423: async function launchResolverAndRetryMerge(\n424:   projectRoot: string,\n425:   state: WaveState,\n426:   agent: AgentState,\n427:   feature: Feature,\n428:   config: WomboConfig,\n429:   model: string | undefined,\n430:   mergeError: string,\n431:   conflictFiles: string[]\n432: ): Promise<void> {\n433:   const conflictPrompt = generateConflictResolutionPrompt(\n434:     feature,\n435:     state.base_branch,\n436:     mergeError,\n437:     config\n438:   );\n439: \n440:   updateAgent(state, agent.feature_id, {\n441:     status: \"resolving_conflict\",\n442:     activity: `resolving ${conflictFiles.length} conflict(s)...`,\n443:   });\n444:   saveState(projectRoot, state);\n445: \n446:   const resolverResult = launchConflictResolver({\n447:     worktreePath: agent.worktree,\n448:     featureId: agent.feature_id,\n449:     prompt: conflictPrompt,\n450:     model,\n451:     config,\n452:   });\n453: \n454:   updateAgent(state, agent.feature_id, {\n455:     pid: resolverResult.pid,\n456:   });\n457:   saveState(projectRoot, state);\n458: \n459:   // Wait for the resolver process to complete, then re-verify and retry merge.\n460:   // We intentionally do NOT add the resolver to the ProcessMonitor because\n461:   // the monitor's onComplete callback would trigger handleBuildVerification\n462:   // again, causing infinite recursion. Instead we await the process directly.\n463:   const resolverExitCode = await new Promise<number | null>((resolve) => {\n464:     resolverResult.process.on(\"exit\", (code) => resolve(code));\n465:     resolverResult.process.on(\"error\", () => resolve(null));\n466:   });\n467: \n468:   printAgentUpdate(agent, `conflict resolver exited (code ${resolverExitCode}) — re-verifying build...`);\n469: \n470:   // Re-verify build after conflict resolution\n471:   const rebuildResult = await runBuild(agent.worktree, config);\n472: \n473:   if (!rebuildResult.passed) {\n474:     printAgentUpdate(agent, `POST-CONFLICT BUILD FAILED`);\n475:     updateAgent(state, agent.feature_id, {\n476:       status: \"failed\",\n477:       build_passed: false,\n478:       build_output: rebuildResult.errorSummary,\n479:       error: \"Build failed after conflict resolution\",\n480:       completed_at: new Date().toISOString(),\n481:     });\n482:     saveState(projectRoot, state);\n483:     return;\n484:   }\n485: \n486:   printAgentUpdate(agent, \"post-conflict build passed — retrying merge...\");\n487: \n488:   const retryMerge = await mergeBranch(\n489:     projectRoot,\n490:     agent.branch,\n491:     state.base_branch,\n492:     config\n493:   );\n494: \n495:   if (retryMerge.success) {\n496:     updateAgent(state, agent.feature_id, {\n497:       status: \"merged\",\n498:       build_passed: true,\n499:       completed_at: new Date().toISOString(),\n500:     });\n501:     saveState(projectRoot, state);\n502:     printAgentUpdate(agent, `MERGED after conflict resolution (${retryMerge.commitHash?.slice(0, 7)})`);\n503:     markFeatureDone(projectRoot, agent.feature_id, config, state.base_branch);\n504:     try {\n505:       removeWorktree(projectRoot, agent.worktree, true);\n506:     } catch {}\n507:   } else {\n508:     printAgentUpdate(agent, `POST-CONFLICT MERGE FAILED: ${retryMerge.error}`);\n509:     updateAgent(state, agent.feature_id, {\n510:       status: \"failed\",\n511:       error: `Merge still failed after conflict resolution: ${retryMerge.error}`,\n512:       completed_at: new Date().toISOString(),\n513:     });\n514:     saveState(projectRoot, state);\n515:   }\n516: }\n517: \n518: /**\n519:  * Handle retry of a failed agent (error-based, not build-based).\n520:  */\n521: export function handleRetry(\n522:   projectRoot: string,\n523:   state: WaveState,\n524:   agent: AgentState,\n525:   monitor: ProcessMonitor,\n526:   config: WomboConfig,\n527:   model?: string\n528: ): void {\n529:   if (!agent.session_id || !agent.error) return;\n530: \n531:   const retryResult = retryHeadless({\n532:     worktreePath: agent.worktree,\n533:     featureId: agent.feature_id,\n534:     sessionId: agent.session_id,\n535:     buildErrors: agent.error,\n536:     model,\n537:     config,\n538:   });\n539: \n540:   updateAgent(state, agent.feature_id, {\n541:     status: \"running\",\n542:     pid: retryResult.pid,\n543:   });\n544:   saveState(projectRoot, state);\n545: \n546:   monitor.addProcess(agent.feature_id, retryResult.process);\n547: }\n548: \n549: /**\n550:  * Launch the next queued agent if capacity allows.\n551:  */\n552: export function launchNextQueued(\n553:   projectRoot: string,\n554:   state: WaveState,\n555:   featureMap: Map<string, Feature>,\n556:   monitor: ProcessMonitor,\n557:   config: WomboConfig,\n558:   model?: string\n559: ): void {\n560:   const active = activeAgents(state);\n561:   const queued = queuedAgents(state);\n562: \n563:   if (active.length < state.max_concurrent && queued.length > 0) {\n564:     const next = queued[0];\n565:     const feature = featureMap.get(next.feature_id);\n566:     if (feature) {\n567:       launchSingleHeadless(projectRoot, state, next, feature, monitor, config, model);\n568:     }\n569:   }\n570: }\n571: \n572: // ---------------------------------------------------------------------------\n573: // Headless Wave Launch\n574: // ---------------------------------------------------------------------------\n575: \n576: async function launchWaveHeadless(\n577:   projectRoot: string,\n578:   state: WaveState,\n579:   features: Feature[],\n580:   opts: LaunchCommandOptions\n581: ): Promise<void> {\n582:   const { config, model } = opts;\n583:   const featureMap = new Map(features.map((f) => [f.id, f]));\n584: \n585:   const monitor = new ProcessMonitor(projectRoot, {\n586:     onSessionId: (featureId, sessionId) => {\n587:       updateAgent(state, featureId, { session_id: sessionId });\n588:       saveState(projectRoot, state);\n589:     },\n590:     onComplete: (featureId) => {\n591:       updateAgent(state, featureId, {\n592:         status: \"completed\",\n593:         completed_at: new Date().toISOString(),\n594:       });\n595:       saveState(projectRoot, state);\n596: \n597:       // Run build verification — fire-and-forget\n598:       const agent = state.agents.find((a) => a.feature_id === featureId)!;\n599:       handleBuildVerification(projectRoot, state, agent, featureMap.get(featureId)!, config, model, monitor)\n600:         .then(() => launchNextQueued(projectRoot, state, featureMap, monitor, config, model))\n601:         .catch((err) => {\n602:           wtLog(featureId, `BUILD VERIFICATION UNHANDLED ERROR: ${err.message}`);\n603:           launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n604:         });\n605:     },\n606:     onError: (featureId, error) => {\n607:       const agent = state.agents.find((a) => a.feature_id === featureId)!;\n608:       if (agent.retries < agent.max_retries) {\n609:         updateAgent(state, featureId, {\n610:           status: \"retry\",\n611:           retries: agent.retries + 1,\n612:           error,\n613:         });\n614:         saveState(projectRoot, state);\n615: \n616:         // Retry\n617:         handleRetry(projectRoot, state, agent, monitor, config, model);\n618:       } else {\n619:         updateAgent(state, featureId, {\n620:           status: \"failed\",\n621:           error,\n622:           completed_at: new Date().toISOString(),\n623:         });\n624:         saveState(projectRoot, state);\n625:       }\n626: \n627:       // Try to launch next queued agent\n628:       launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n629:     },\n630:     onOutput: (_featureId, _data) => {\n631:       // Raw output — logged to file by ProcessMonitor\n632:     },\n633:     onActivity: (featureId, activity) => {\n634:       updateAgent(state, featureId, {\n635:         activity,\n636:         activity_updated_at: new Date().toISOString(),\n637:       });\n638:       // Don't save to disk on every activity — too frequent.\n639:     },\n640:   });\n641: \n642:   // Create the TUI — it will auto-refresh and show activity from the monitor\n643:   const tuiRef = { current: null as WomboTUI | null };\n644:   const startTUI = () => {\n645:     tuiRef.current = new WomboTUI({\n646:       state,\n647:       monitor,\n648:       projectRoot,\n649:       interactive: false,\n650:       config,\n651:       onQuit: () => {\n652:         // Same as SIGINT — save state and exit\n653:         for (const agent of state.agents) {\n654:           if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n655:             updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n656:           }\n657:         }\n658:         monitor.killAll();\n659:         saveState(projectRoot, state);\n660:         console.log(\"State saved. Use 'wombo resume' to continue.\");\n661:         process.exit(0);\n662:       },\n663:     });\n664:     tuiRef.current.start();\n665:   };\n666: \n667:   // Handle graceful shutdown\n668:   process.on(\"SIGINT\", () => {\n669:     if (tuiRef.current) tuiRef.current.stop();\n670:     for (const agent of state.agents) {\n671:       if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n672:         updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n673:       }\n674:     }\n675:     monitor.killAll();\n676:     saveState(projectRoot, state);\n677:     console.log(\"\\nState saved. Use 'wombo resume' to continue.\");\n678:     process.exit(0);\n679:   });\n680: \n681:   // Launch initial batch — set up worktrees in parallel\n682:   const tolaunch = queuedAgents(state).slice(0, opts.maxConcurrent);\n683:   console.log(`Setting up ${tolaunch.length} agent(s) in parallel...\\n`);\n684: \n685:   await Promise.all(\n686:     tolaunch.map((agent) =>\n687:       launchSingleHeadless(\n688:         projectRoot,\n689:         state,\n690:         agent,\n691:         featureMap.get(agent.feature_id)!,\n692:         monitor,\n693:         config,\n694:         model\n695:       )\n696:     )\n697:   );\n698: \n699:   const launched = state.agents.filter((a) => a.status === \"running\").length;\n700: \n701:   // Start the TUI dashboard (or skip if --no-tui)\n702:   if (opts.noTui) {\n703:     console.log(`${launched} agent(s) running. (--no-tui mode, dashboard prints every 15s)\\n`);\n704:     printDashboard(state);\n705:   } else {\n706:     console.log(`${launched} agent(s) running. Launching TUI...\\n`);\n707:     startTUI();\n708:   }\n709: \n710:   // Background monitoring loop — checks for dead processes and launches queued\n711:   const POLL_INTERVAL = 5000;\n712:   let dashboardCounter = 0;\n713:   while (!isWaveComplete(state)) {\n714:     await new Promise((r) => setTimeout(r, POLL_INTERVAL));\n715: \n716:     // Check for completed processes that weren't caught by event handlers\n717:     for (const agent of state.agents) {\n718:       if (\n719:         (agent.status === \"running\" || agent.status === \"resolving_conflict\") &&\n720:         agent.pid &&\n721:         !isProcessRunning(agent.pid) &&\n722:         !monitor.isRunning(agent.feature_id)\n723:       ) {\n724:         if (agent.status === \"resolving_conflict\") {\n725:           // Conflict resolver died — the await in handleBuildVerification\n726:           // will resolve via the 'exit' event, so nothing to do here\n727:           continue;\n728:         }\n729:         // Process exited but we didn't get a callback\n730:         // Check if the agent actually made any commits\n731:         if (!branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n732:           // Agent died without producing any code — mark as failed, not completed\n733:           updateAgent(state, agent.feature_id, {\n734:             status: \"failed\",\n735:             error: \"Agent process exited without making any commits\",\n736:             activity: null,\n737:             completed_at: new Date().toISOString(),\n738:           });\n739:           saveState(projectRoot, state);\n740:           wtLog(agent.feature_id, \"process died with no code changes — marked failed\");\n741:         } else {\n742:           updateAgent(state, agent.feature_id, {\n743:             status: \"completed\",\n744:             completed_at: new Date().toISOString(),\n745:             activity: \"done\",\n746:           });\n747:           saveState(projectRoot, state);\n748:           try {\n749:             await handleBuildVerification(projectRoot, state, agent, featureMap.get(agent.feature_id)!, config, model, monitor);\n750:           } catch (err: any) {\n751:             wtLog(agent.feature_id, `POLL VERIFY ERROR: ${err.message}`);\n752:           }\n753:         }\n754:         launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n755:       }\n756:     }\n757: \n758:     // Persist state periodically\n759:     saveState(projectRoot, state);\n760: \n761:     // Update TUI state reference (or print dashboard in --no-tui mode)\n762:     if (tuiRef.current) {\n763:       tuiRef.current.updateState(state);\n764:     } else if (opts.noTui) {\n765:       dashboardCounter++;\n766:       if (dashboardCounter % 3 === 0) {\n767:         printDashboard(state);\n768: \n769:         // Auto-push base branch if requested\n770:         if (opts.autoPush) {\n771:           const anyMerged = state.agents.some((a) => a.status === \"merged\");\n772:           if (anyMerged) {\n773:             await pushBaseBranch(projectRoot, state.base_branch, config);\n774:           } else {\n775:             console.log(\"No branches were merged — skipping push.\");\n776:           }\n777:         }\n778:       }\n779:     }\n780:   }\n781: \n782:   // Wave complete — tear down TUI and show final summary\n783:   if (tuiRef.current) tuiRef.current.stop();\n784:   printDashboard(state);\n785: \n786:   // Auto-push base branch if requested\n787:   if (opts.autoPush) {\n788:     await pushBaseBranch(projectRoot, state.base_branch, config);\n789:   }\n790: \n791:   console.log(\"Wave complete.\");\n792: }\n793: \n794: // ---------------------------------------------------------------------------\n795: // Interactive Wave Launch\n796: // ---------------------------------------------------------------------------\n797: \n798: async function launchWaveInteractive(\n799:   projectRoot: string,\n800:   state: WaveState,\n801:   features: Feature[],\n802:   opts: LaunchCommandOptions\n803: ): Promise<void> {\n804:   const { config, model } = opts;\n805:   const featureMap = new Map(features.map((f) => [f.id, f]));\n806: \n807:   // Show dashboard immediately\n808:   printDashboard(state);\n809: \n810:   // Launch initial batch — parallelize setup\n811:   const tolaunch = queuedAgents(state).slice(0, opts.maxConcurrent);\n812:   console.log(`Setting up ${tolaunch.length} agent(s) in parallel...\\n`);\n813: \n814:   await Promise.all(\n815:     tolaunch.map(async (agent) => {\n816:       updateAgent(state, agent.feature_id, {\n817:         status: \"installing\",\n818:         started_at: new Date().toISOString(),\n819:         activity: \"setting up worktree...\",\n820:       });\n821:       saveState(projectRoot, state);\n822: \n823:       try {\n824:         if (worktreeReady(agent.worktree)) {\n825:           wtLog(agent.feature_id, \"worktree already exists, skipping setup\");\n826:         } else {\n827:           await createWorktree(projectRoot, agent.feature_id, state.base_branch, config);\n828:           updateAgent(state, agent.feature_id, { activity: \"installing deps...\" });\n829:           await installDeps(agent.worktree, agent.feature_id, config);\n830:         }\n831: \n832:         const prompt = generatePrompt(\n833:           featureMap.get(agent.feature_id)!,\n834:           state.base_branch,\n835:           config\n836:         );\n837: \n838:         wtLog(agent.feature_id, \"launching interactive session...\");\n839:         const result = launchInteractive({\n840:           worktreePath: agent.worktree,\n841:           featureId: agent.feature_id,\n842:           prompt,\n843:           model,\n844:           interactive: true,\n845:           config,\n846:         });\n847: \n848:         const muxName = getMultiplexerName(config);\n849:         updateAgent(state, agent.feature_id, {\n850:           status: \"running\",\n851:           pid: result.pid,\n852:           activity: `${muxName} session active`,\n853:         });\n854:         saveState(projectRoot, state);\n855:         wtLog(agent.feature_id, `${muxName} session: ${config.agent.tmuxPrefix}-${agent.feature_id}`);\n856:       } catch (err: any) {\n857:         updateAgent(state, agent.feature_id, {\n858:           status: \"failed\",\n859:           error: err.message,\n860:           activity: null,\n861:           completed_at: new Date().toISOString(),\n862:         });\n863:         saveState(projectRoot, state);\n864:         wtLog(agent.feature_id, `SETUP FAILED: ${err.message.split(\"\\n\")[0]}`);\n865:       }\n866:     })\n867:   );\n868: \n869:   const mux = detectMultiplexer(config.agent.multiplexer);\n870:   const muxName = getMultiplexerName(config);\n871:   console.log(\"\\nInteractive sessions launched. Use these commands:\");\n872:   console.log(`  ${muxAttachCommand(mux, `${config.agent.tmuxPrefix}-<feature-id>`)}   # attach to a session`);\n873:   console.log(`  ${muxListCommand(mux)}${\" \".repeat(Math.max(1, 54 - muxListCommand(mux).length))}# list sessions`);\n874:   console.log(\"  wombo status                                             # check status\");\n875:   console.log(\"  wombo verify                                             # verify builds\");\n876:   console.log(\"  wombo merge                                              # merge verified\");\n877:   console.log(\"  wombo cleanup                                            # remove worktrees\");\n878: \n879:   printDashboard(state);\n880: }\n881: \n882: // ---------------------------------------------------------------------------\n883: // Main Command\n884: // ---------------------------------------------------------------------------\n885: \n886: export async function cmdLaunch(opts: LaunchCommandOptions): Promise<void> {\n887:   const { projectRoot, config } = opts;\n888: \n889:   console.log(\"\\n--- Wombo: Launch ---\\n\");\n890: \n891:   // Ensure agent definition exists — reinstall from template if missing\n892:   ensureAgentDefinition(projectRoot, config);\n893: \n894:   // -------------------------------------------------------------------------\n895:   // Validate that the configured baseBranch exists as a local branch\n896:   // -------------------------------------------------------------------------\n897:   if (!branchExists(projectRoot, opts.baseBranch)) {\n898:     const fmt = opts.outputFmt ?? \"text\";\n899:     const msg = `Base branch \"${opts.baseBranch}\" does not exist as a local branch. ` +\n900:       `Create it first (e.g. \"git checkout -b ${opts.baseBranch}\") or specify ` +\n901:       `a different branch with --base-branch.`;\n902:     outputError(fmt, msg);\n903:   }\n904: \n905:   // -------------------------------------------------------------------------\n906:   // Check for existing wave state — don't overwrite work in progress\n907:   // -------------------------------------------------------------------------\n908:   const existingState = loadState(projectRoot);\n909:   if (existingState) {\n910:     const merged = existingState.agents.filter((a) => a.status === \"merged\");\n911:     const verified = existingState.agents.filter((a) => a.status === \"verified\");\n912:     const completed = existingState.agents.filter((a) => a.status === \"completed\");\n913:     const running = existingState.agents.filter((a) => a.status === \"running\");\n914:     const queued = existingState.agents.filter((a) => a.status === \"queued\");\n915:     const failed = existingState.agents.filter((a) => a.status === \"failed\");\n916: \n917:     const hasWork = merged.length > 0 || verified.length > 0 || completed.length > 0 || running.length > 0;\n918: \n919:     if (hasWork) {\n920:       console.log(`Existing wave found: ${existingState.wave_id}`);\n921:       console.log(`  ${merged.length} merged, ${verified.length} verified, ${completed.length} completed, ${running.length} running, ${queued.length} queued, ${failed.length} failed`);\n922: \n923:       // Finalize any merged agents by marking their features as done\n924:       if (merged.length > 0) {\n925:         console.log(\"\\nFinalizing merged features in .features.yml...\");\n926:         for (const agent of merged) {\n927:           markFeatureDone(projectRoot, agent.feature_id, config, existingState.base_branch);\n928:           // Clean up worktree and branch (already merged, safe to delete)\n929:           try {\n930:             removeWorktree(projectRoot, agent.worktree, true);\n931:             console.log(`  ${agent.feature_id}: marked done, worktree removed`);\n932:           } catch {\n933:             console.log(`  ${agent.feature_id}: marked done (worktree already cleaned)`);\n934:           }\n935:         }\n936:       }\n937: \n938:       // Verified agents: build passed but NOT merged — do NOT mark done.\n939:       // Leave them for 'wombo resume' to attempt the merge.\n940:       if (verified.length > 0) {\n941:         for (const agent of verified) {\n942:           console.log(`  ${agent.feature_id}: verified (not yet merged) — use 'wombo resume' to merge`);\n943:         }\n944:       }\n945: \n946:       const activeCount = running.length + completed.length + queued.length;\n947:       if (activeCount > 0) {\n948:         console.error(`\\nWave ${existingState.wave_id} has ${activeCount} unfinished agent(s).`);\n949:         console.error(\"Use 'wombo resume' to continue the existing wave,\");\n950:         console.error(\"or 'wombo cleanup' to clear it before starting a new one.\");\n951:         process.exit(1);\n952:       }\n953: \n954:       // All agents are in terminal states (merged/verified/failed) — safe to start fresh\n955:       console.log(\"\\nAll agents in previous wave are finished. Starting fresh wave.\\n\");\n956:     }\n957:   }\n958: \n959:   // Load features\n960:   const data = loadFeatures(projectRoot, config);\n961: \n962:   // Build selection options\n963:   const selOpts: SelectionOptions = {};\n964:   if (opts.topPriority) selOpts.topPriority = opts.topPriority;\n965:   if (opts.quickestWins) selOpts.quickestWins = opts.quickestWins;\n966:   if (opts.priority) selOpts.priority = opts.priority;\n967:   if (opts.difficulty) selOpts.difficulty = opts.difficulty;\n968:   if (opts.features) selOpts.featureIds = opts.features;\n969:   if (opts.allReady) selOpts.allReady = true;\n970: \n971:   // Select features\n972:   const selected = selectFeatures(data, selOpts);\n973: \n974:   if (selected.length === 0) {\n975:     if (opts.allReady) {\n976:       console.error(\n977:         \"No launchable features found (all features are done, cancelled, or have unmet dependencies).\\n\" +\n978:         \"Run 'wombo features list' to review feature statuses.\"\n979:       );\n980:     } else {\n981:       console.error(\n982:         \"No features matched the selection criteria.\\n\" +\n983:         \"Use --all-ready to select all features whose dependencies are met,\\n\" +\n984:         \"or run 'wombo features list --ready' to see available features.\"\n985:       );\n986:     }\n987:     process.exit(1);\n988:   }\n989: \n990:   // Show selection\n991:   printFeatureSelection(\n992:     selected.map((f) => ({\n993:       id: f.id,\n994:       title: f.title,\n995:       priority: f.priority,\n996:       difficulty: f.difficulty,\n997:       effort: f.effort,\n998:     }))\n999:   );\n1000: \n1001:   if (opts.dryRun) {\n1002:     console.log(\"Dry run — not launching agents.\");\n1003:     return;\n1004:   }\n1005: \n1006:   // Create wave state\n1007:   const state = createWaveState({\n1008:     baseBranch: opts.baseBranch,\n1009:     maxConcurrent: opts.maxConcurrent,\n1010:     model: opts.model ?? null,\n1011:     interactive: opts.interactive,\n1012:   });\n1013: \n1014:   // Create agent entries for all selected features\n1015:   for (const feature of selected) {\n1016:     const branch = featureBranchName(feature.id, config);\n1017:     const wtPath = worktreePath(projectRoot, feature.id, config);\n1018:     const agent = createAgentState(feature.id, branch, wtPath, opts.maxRetries);\n1019:     // Set effort estimate from feature spec\n1020:     const effortMinutes = parseDurationMinutes(feature.effort);\n1021:     agent.effort_estimate_ms = effortMinutes === Infinity ? null : effortMinutes * 60 * 1000;\n1022:     state.agents.push(agent);\n1023:   }\n1024: \n1025:   saveState(projectRoot, state);\n1026:   console.log(`Wave ${state.wave_id} created with ${selected.length} agents.`);\n1027: \n1028:   // Launch agents up to max_concurrent\n1029:   if (opts.interactive) {\n1030:     await launchWaveInteractive(projectRoot, state, selected, opts);\n1031:   } else {\n1032:     await launchWaveHeadless(projectRoot, state, selected, opts);\n1033:   }\n1034: }\n\n(End of file - total 1034 lines)\n</content>","title":"src/commands/launch.ts","metadata":{"preview":"/**\n * launch.ts — Launch a wave of agents.\n *\n * Usage: wombo launch [selection options] [launch options]\n *\n * This is the primary entry point for starting a new wave. It selects features\n * from the features file, creates a wave state, sets up worktrees, and launches\n * agent processes (either headless or interactive via dmux/tmux).\n *\n * IMPORTANT: This file also exports shared helper functions that are reused\n * by resume.ts and other commands:\n *   - launchSingleHeadless\n *   - handleBuildVerification\n *   - handleRetry\n *   - launchNextQueued\n */\n\nimport { execSync } from \"node:child_process\";\nimport type { WomboConfig } from \"../config.js\";\nimport type { Feature, SelectionOptions, Priority, Difficulty } from \"../lib/features.js\";","truncated":false,"loaded":[]},"time":{"start":1773352360635,"end":1773352360640}}}}
{"type":"tool_use","timestamp":1773352361011,"sessionID":"ses_31bfd06f5ffeleRCi6uuMulALr","part":{"id":"prt_ce4099b8d001HVZxirNdk7WOeb","sessionID":"ses_31bfd06f5ffeleRCi6uuMulALr","messageID":"msg_ce4098fd40015SE7xIFe7a3vBH","type":"tool","callID":"toolu_vrtx_01HXUoRQ9PgHi2uEpYXgEGvd","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-dmux-migration/src/commands/resume.ts"},"output":"<path>/home/fulgidus/Documents/wombo-dmux-migration/src/commands/resume.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * resume.ts — Resume a previously stopped wave.\n3:  *\n4:  * Usage: wombo resume [options]\n5:  *\n6:  * Restores from .wombo-state.json:\n7:  *   - Agents in \"running\"/\"installing\" whose PID is dead → re-check or re-launch\n8:  *   - Agents in \"queued\" → launch them\n9:  *   - Agents in terminal states (verified/failed/merged) → leave alone\n10:  */\n11: \n12: import type { WomboConfig } from \"../config.js\";\n13: import type { Feature } from \"../lib/features.js\";\n14: import { loadFeatures } from \"../lib/features.js\";\n15: import {\n16:   loadState,\n17:   saveState,\n18:   updateAgent,\n19:   queuedAgents,\n20:   isWaveComplete,\n21:   type WaveState,\n22:   type AgentState,\n23: } from \"../lib/state.js\";\n24: import {\n25:   createWorktree,\n26:   installDeps,\n27:   worktreeReady,\n28:   worktreeExists,\n29:   branchHasChanges,\n30:   removeWorktree,\n31:   log as wtLog,\n32: } from \"../lib/worktree.js\";\n33: import { generatePrompt } from \"../lib/prompt.js\";\n34: import {\n35:   launchInteractive,\n36:   isProcessRunning,\n37:   getMultiplexerName,\n38: } from \"../lib/launcher.js\";\n39: import { ProcessMonitor } from \"../lib/monitor.js\";\n40: import { pushBaseBranch } from \"../lib/merger.js\";\n41: import { runBuild } from \"../lib/verifier.js\";\n42: import { printDashboard, printAgentUpdate } from \"../lib/ui.js\";\n43: import { WomboTUI } from \"../lib/tui.js\";\n44: import {\n45:   launchSingleHeadless,\n46:   handleBuildVerification,\n47:   handleRetry,\n48:   launchNextQueued,\n49:   markFeatureDone,\n50:   attemptMerge,\n51: } from \"./launch.js\";\n52: import {\n53:   detectMultiplexer,\n54:   muxAttachCommand,\n55: } from \"../lib/multiplexer.js\";\n56: \n57: // ---------------------------------------------------------------------------\n58: // Types\n59: // ---------------------------------------------------------------------------\n60: \n61: export interface ResumeCommandOptions {\n62:   projectRoot: string;\n63:   config: WomboConfig;\n64:   maxConcurrent?: number;\n65:   model?: string;\n66:   interactive: boolean;\n67:   noTui: boolean;\n68:   autoPush: boolean;\n69:   baseBranch?: string;\n70:   maxRetries?: number;\n71: }\n72: \n73: // ---------------------------------------------------------------------------\n74: // Command\n75: // ---------------------------------------------------------------------------\n76: \n77: export async function cmdResume(opts: ResumeCommandOptions): Promise<void> {\n78:   const { projectRoot, config } = opts;\n79: \n80:   const state = loadState(projectRoot);\n81:   if (!state) {\n82:     console.error(\"No wave state found. Use 'wombo launch' to start a new wave.\");\n83:     process.exit(1);\n84:     return; // unreachable — helps TypeScript narrow\n85:   }\n86: \n87:   console.log(`\\n--- Wombo: Resume ${state.wave_id} ---\\n`);\n88: \n89:   // Load feature data for prompt generation\n90:   const data = loadFeatures(projectRoot, config);\n91:   const featureMap = new Map(data.features.map((f) => [f.id, f]));\n92: \n93:   // Triage agents by current state\n94:   let toRelaunch: AgentState[] = [];\n95:   let toVerify: AgentState[] = [];\n96: \n97:   for (const agent of state.agents) {\n98:     switch (agent.status) {\n99:       case \"running\":\n100:       case \"installing\":\n101:       case \"retry\":\n102:       case \"resolving_conflict\":\n103:         // Was in-flight when we stopped — check if PID is still alive\n104:         if (agent.pid && isProcessRunning(agent.pid)) {\n105:           console.log(`  ${agent.feature_id}: still running (PID ${agent.pid}), leaving alone`);\n106:         } else {\n107:           // Process is dead — check if worktree exists with meaningful changes.\n108:           // Use worktreeExists (not worktreeReady) because node_modules may be\n109:           // missing — the worktree still has code that should be verified.\n110:           if (worktreeExists(agent.worktree) && branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n111:             // Worktree exists AND branch has commits — try build verification\n112:             console.log(`  ${agent.feature_id}: process dead, worktree has changes — will verify build`);\n113:             toVerify.push(agent);\n114:           } else {\n115:             // No worktree, or worktree exists but branch has no commits (agent did nothing)\n116:             const reason = worktreeExists(agent.worktree)\n117:               ? \"worktree exists but no code changes\"\n118:               : \"no worktree\";\n119:             console.log(`  ${agent.feature_id}: process dead, ${reason} — will re-launch`);\n120:             updateAgent(state, agent.feature_id, {\n121:               status: \"queued\",\n122:               pid: null,\n123:               activity: null,\n124:               session_id: null,\n125:             });\n126:             toRelaunch.push(agent);\n127:           }\n128:         }\n129:         break;\n130: \n131:       case \"queued\":\n132:         console.log(`  ${agent.feature_id}: queued — will launch`);\n133:         toRelaunch.push(agent);\n134:         break;\n135: \n136:       case \"completed\":\n137:         // Completed but not verified — verify\n138:         console.log(`  ${agent.feature_id}: completed — will verify build`);\n139:         toVerify.push(agent);\n140:         break;\n141: \n142:       case \"verified\":\n143:         // Build passed but NOT yet merged — need to attempt merge (+ conflict resolution)\n144:         console.log(`  ${agent.feature_id}: verified — will attempt merge`);\n145:         toVerify.push(agent);\n146:         break;\n147: \n148:       case \"merged\":\n149:         console.log(`  ${agent.feature_id}: merged — marking feature as done`);\n150:         markFeatureDone(projectRoot, agent.feature_id, config, state.base_branch);\n151:         try {\n152:           removeWorktree(projectRoot, agent.worktree, true);\n153:           console.log(`  ${agent.feature_id}: worktree and branch removed`);\n154:         } catch {\n155:           // Already cleaned — not critical\n156:         }\n157:         break;\n158: \n159:       case \"failed\":\n160:         // If the worktree exists with code changes and retries remain,\n161:         // attempt build verification rather than discarding the work.\n162:         if (agent.retries < agent.max_retries &&\n163:             worktreeExists(agent.worktree) &&\n164:             branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n165:           console.log(`  ${agent.feature_id}: failed but has work (retry ${agent.retries}/${agent.max_retries}) — will verify build`);\n166:           // Clear stale error and mark as completed so handleBuildVerification\n167:           // processes it correctly (it expects a non-failed agent)\n168:           updateAgent(state, agent.feature_id, {\n169:             status: \"completed\",\n170:             error: null,\n171:             build_passed: null,\n172:             build_output: null,\n173:             completed_at: new Date().toISOString(),\n174:           });\n175:           toVerify.push(agent);\n176:         } else if (agent.retries < agent.max_retries) {\n177:           // No worktree or no changes — re-launch from scratch\n178:           console.log(`  ${agent.feature_id}: failed, no salvageable work (retry ${agent.retries}/${agent.max_retries}) — will re-launch`);\n179:           updateAgent(state, agent.feature_id, {\n180:             status: \"queued\",\n181:             pid: null,\n182:             error: null,\n183:             build_passed: null,\n184:             build_output: null,\n185:             activity: null,\n186:             session_id: null,\n187:             completed_at: null,\n188:           });\n189:           toRelaunch.push(agent);\n190:         } else {\n191:           console.log(`  ${agent.feature_id}: failed — max retries reached (use 'wombo retry' to reset)`);\n192:         }\n193:         break;\n194:     }\n195:   }\n196: \n197:   saveState(projectRoot, state);\n198: \n199:   // ---------------------------------------------------------------------------\n200:   // Phase 1: Parallel build verification\n201:   // Each agent's worktree is independent, so dep install + build can run\n202:   // concurrently. Merges must remain sequential (they mutate the project root).\n203:   // ---------------------------------------------------------------------------\n204:   if (toVerify.length > 0) {\n205:     console.log(`\\nVerifying ${toVerify.length} agent(s) in parallel...\\n`);\n206: \n207:     const verifyResults = await Promise.all(\n208:       toVerify.map(async (agent): Promise<{ agent: AgentState; needsMerge: boolean }> => {\n209:         const feature = featureMap.get(agent.feature_id);\n210:         if (!feature) return { agent, needsMerge: false };\n211: \n212:         // Already verified — skip build, go straight to merge\n213:         if (agent.status === \"verified\") {\n214:           printAgentUpdate(agent, \"already verified — queued for merge\");\n215:           return { agent, needsMerge: true };\n216:         }\n217: \n218:         printAgentUpdate(agent, \"verifying build...\");\n219: \n220:         // Ensure deps are installed — worktree may exist without node_modules\n221:         // (e.g., failed agents whose setup was interrupted)\n222:         if (!worktreeReady(agent.worktree) && worktreeExists(agent.worktree)) {\n223:           try {\n224:             printAgentUpdate(agent, \"installing deps...\");\n225:             await installDeps(agent.worktree, agent.feature_id, config);\n226:           } catch (depErr: any) {\n227:             printAgentUpdate(agent, `dep install failed: ${depErr.message}`);\n228:             updateAgent(state, agent.feature_id, {\n229:               status: \"failed\",\n230:               error: `Dependency install failed: ${depErr.message}`,\n231:               retries: agent.retries + 1,\n232:               completed_at: new Date().toISOString(),\n233:             });\n234:             saveState(projectRoot, state);\n235:             return { agent, needsMerge: false };\n236:           }\n237:         }\n238: \n239:         try {\n240:           const buildResult = await runBuild(agent.worktree, config);\n241:           if (buildResult.passed) {\n242:             updateAgent(state, agent.feature_id, {\n243:               status: \"verified\",\n244:               build_passed: true,\n245:               build_output: null,\n246:             });\n247:             saveState(projectRoot, state);\n248:             printAgentUpdate(agent, `BUILD PASSED (${Math.round(buildResult.durationMs / 1000)}s)`);\n249:             return { agent, needsMerge: true };\n250:           } else {\n251:             // Build failed\n252:             if (agent.retries < agent.max_retries) {\n253:               updateAgent(state, agent.feature_id, {\n254:                 status: \"retry\",\n255:                 retries: agent.retries + 1,\n256:                 build_passed: false,\n257:                 build_output: buildResult.errorSummary,\n258:               });\n259:               saveState(projectRoot, state);\n260:               printAgentUpdate(agent, `BUILD FAILED — will retry (${agent.retries + 1}/${agent.max_retries})`);\n261:             } else {\n262:               updateAgent(state, agent.feature_id, {\n263:                 status: \"failed\",\n264:                 build_passed: false,\n265:                 build_output: buildResult.errorSummary,\n266:                 error: `Build failed after ${agent.max_retries} retries`,\n267:                 completed_at: new Date().toISOString(),\n268:               });\n269:               saveState(projectRoot, state);\n270:               printAgentUpdate(agent, \"BUILD FAILED — max retries reached\");\n271:             }\n272:             return { agent, needsMerge: false };\n273:           }\n274:         } catch (err: any) {\n275:           printAgentUpdate(agent, `verify error: ${err.message}`);\n276:           updateAgent(state, agent.feature_id, {\n277:             status: \"failed\",\n278:             error: `Build verification error: ${err.message}`,\n279:             completed_at: new Date().toISOString(),\n280:           });\n281:           saveState(projectRoot, state);\n282:           return { agent, needsMerge: false };\n283:         }\n284:       })\n285:     );\n286: \n287:     saveState(projectRoot, state);\n288: \n289:     // -------------------------------------------------------------------------\n290:     // Phase 2: Sequential merge for verified agents\n291:     // Merges must be sequential because they operate on the project root.\n292:     // -------------------------------------------------------------------------\n293:     const toMerge = verifyResults.filter((r) => r.needsMerge);\n294:     if (toMerge.length > 0) {\n295:       console.log(`\\nMerging ${toMerge.length} verified agent(s)...\\n`);\n296:       for (const { agent } of toMerge) {\n297:         const feature = featureMap.get(agent.feature_id);\n298:         if (!feature) continue;\n299:         try {\n300:           await attemptMerge(projectRoot, state, agent, feature, config, opts.model);\n301:         } catch (err: any) {\n302:           printAgentUpdate(agent, `merge error: ${err.message}`);\n303:         }\n304:       }\n305:     }\n306: \n307:     // Collect agents that need re-launching from verify results\n308:     for (const { agent } of verifyResults) {\n309:       if (agent.status === \"retry\" || agent.status === \"running\") {\n310:         toRelaunch.push(agent);\n311:       }\n312:     }\n313:   }\n314: \n315:   // Re-launch agents\n316:   const maxConcurrent = opts.maxConcurrent ?? state.max_concurrent;\n317:   const toLaunchNow = toRelaunch.slice(0, maxConcurrent);\n318:   if (toLaunchNow.length === 0) {\n319:     console.log(\"\\nNo agents need (re)launching.\");\n320:     printDashboard(state);\n321:     return;\n322:   }\n323: \n324:   console.log(`\\nRe-launching ${toLaunchNow.length} agent(s)...\\n`);\n325:   printDashboard(state);\n326: \n327:   const model = opts.model ?? state.model ?? undefined;\n328: \n329:   if (opts.interactive) {\n330:     // Interactive resume\n331:     await Promise.all(\n332:       toLaunchNow.map(async (agent) => {\n333:         const feature = featureMap.get(agent.feature_id);\n334:         if (!feature) return;\n335: \n336:         updateAgent(state, agent.feature_id, {\n337:           status: \"installing\",\n338:           started_at: new Date().toISOString(),\n339:           activity: \"resuming...\",\n340:         });\n341:         saveState(projectRoot, state);\n342: \n343:         try {\n344:           if (!worktreeReady(agent.worktree)) {\n345:             await createWorktree(projectRoot, agent.feature_id, state.base_branch, config);\n346:             await installDeps(agent.worktree, agent.feature_id, config);\n347:           }\n348: \n349:           const prompt = generatePrompt(feature, state.base_branch, config);\n350:           const result = launchInteractive({\n351:             worktreePath: agent.worktree,\n352:             featureId: feature.id,\n353:             prompt,\n354:             model,\n355:             interactive: true,\n356:             config,\n357:           });\n358: \n359:           const muxName = getMultiplexerName(config);\n360:           updateAgent(state, agent.feature_id, {\n361:             status: \"running\",\n362:             pid: result.pid,\n363:             activity: `${muxName} session active`,\n364:           });\n365:           saveState(projectRoot, state);\n366:         } catch (err: any) {\n367:           updateAgent(state, agent.feature_id, {\n368:             status: \"failed\",\n369:             error: err.message,\n370:             activity: null,\n371:             completed_at: new Date().toISOString(),\n372:           });\n373:           saveState(projectRoot, state);\n374:         }\n375:       })\n376:     );\n377: \n378:     printDashboard(state);\n379:     const mux = detectMultiplexer(config.agent.multiplexer);\n380:     console.log(`\\nResume complete. Use '${muxAttachCommand(mux, `${config.agent.tmuxPrefix}-<id>`)}' to check sessions.`);\n381:   } else {\n382:     // Headless resume — re-enter monitoring loop\n383:     const monitor = new ProcessMonitor(projectRoot, {\n384:       onSessionId: (featureId, sessionId) => {\n385:         updateAgent(state, featureId, { session_id: sessionId });\n386:         saveState(projectRoot, state);\n387:       },\n388:       onComplete: (featureId) => {\n389:         updateAgent(state, featureId, {\n390:           status: \"completed\",\n391:           completed_at: new Date().toISOString(),\n392:           activity: \"done\",\n393:         });\n394:         saveState(projectRoot, state);\n395:         wtLog(featureId, \"agent completed — verifying build...\");\n396: \n397:         const agent = state.agents.find((a) => a.feature_id === featureId)!;\n398:         const feature = featureMap.get(featureId)!;\n399:         handleBuildVerification(projectRoot, state, agent, feature, config, model, monitor)\n400:           .then(() => launchNextQueued(projectRoot, state, featureMap, monitor, config, model))\n401:           .catch((err) => {\n402:             wtLog(featureId, `BUILD VERIFICATION UNHANDLED ERROR: ${err.message}`);\n403:             launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n404:           });\n405:       },\n406:       onError: (featureId, error) => {\n407:         const agent = state.agents.find((a) => a.feature_id === featureId)!;\n408:         if (agent.retries < agent.max_retries) {\n409:           updateAgent(state, featureId, {\n410:             status: \"retry\",\n411:             retries: agent.retries + 1,\n412:             error,\n413:             activity: \"retrying...\",\n414:           });\n415:           saveState(projectRoot, state);\n416:           handleRetry(projectRoot, state, agent, monitor, config, model);\n417:         } else {\n418:           updateAgent(state, featureId, {\n419:             status: \"failed\",\n420:             error,\n421:             activity: null,\n422:             completed_at: new Date().toISOString(),\n423:           });\n424:           saveState(projectRoot, state);\n425:         }\n426:         launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n427:       },\n428:       onActivity: (featureId, activity) => {\n429:         updateAgent(state, featureId, {\n430:           activity,\n431:           activity_updated_at: new Date().toISOString(),\n432:         });\n433:       },\n434:     });\n435: \n436:     // Handle graceful shutdown\n437:     const tuiRef = { current: null as WomboTUI | null };\n438:     process.on(\"SIGINT\", () => {\n439:       if (tuiRef.current) tuiRef.current.stop();\n440:       for (const agent of state.agents) {\n441:         if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n442:           updateAgent(state, agent.feature_id, {\n443:             activity: \"interrupted\",\n444:           });\n445:         }\n446:       }\n447:       monitor.killAll();\n448:       saveState(projectRoot, state);\n449:       console.log(\"\\nState saved. Use 'wombo resume' to continue.\");\n450:       process.exit(0);\n451:     });\n452: \n453:     await Promise.all(\n454:       toLaunchNow.map((agent) => {\n455:         const feature = featureMap.get(agent.feature_id);\n456:         if (!feature) return Promise.resolve();\n457:         return launchSingleHeadless(projectRoot, state, agent, feature, monitor, config, model);\n458:       })\n459:     );\n460: \n461:     // Start TUI dashboard (or skip if --no-tui)\n462:     if (!opts.noTui) {\n463:       tuiRef.current = new WomboTUI({\n464:         state,\n465:         monitor,\n466:         projectRoot,\n467:         interactive: false,\n468:         config,\n469:         onQuit: () => {\n470:           for (const agent of state.agents) {\n471:             if (agent.status === \"running\") {\n472:               updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n473:             }\n474:           }\n475:           monitor.killAll();\n476:           saveState(projectRoot, state);\n477:           console.log(\"State saved. Use 'wombo resume' to continue.\");\n478:           process.exit(0);\n479:         },\n480:       });\n481:       tuiRef.current.start();\n482:     } else {\n483:       console.log(\"(--no-tui mode, dashboard prints every 15s)\\n\");\n484:       printDashboard(state);\n485:     }\n486: \n487:     // Monitoring loop\n488:     const POLL_INTERVAL = 5000;\n489:     let dashboardCounter = 0;\n490:     while (!isWaveComplete(state)) {\n491:       await new Promise((r) => setTimeout(r, POLL_INTERVAL));\n492: \n493:       for (const agent of state.agents) {\n494:         if (\n495:           (agent.status === \"running\" || agent.status === \"resolving_conflict\") &&\n496:           agent.pid &&\n497:           !isProcessRunning(agent.pid) &&\n498:           !monitor.isRunning(agent.feature_id)\n499:         ) {\n500:           if (agent.status === \"resolving_conflict\") {\n501:             // Conflict resolver died unexpectedly — mark as failed\n502:             updateAgent(state, agent.feature_id, {\n503:               status: \"failed\",\n504:               error: \"Conflict resolver process died unexpectedly\",\n505:               activity: null,\n506:               completed_at: new Date().toISOString(),\n507:             });\n508:             saveState(projectRoot, state);\n509:             wtLog(agent.feature_id, \"conflict resolver died — marked failed\");\n510:             launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n511:             continue;\n512:           }\n513:           // Check if the agent actually made any commits\n514:           if (!branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n515:             // Agent died without producing any code — mark as failed\n516:             updateAgent(state, agent.feature_id, {\n517:               status: \"failed\",\n518:               error: \"Agent process exited without making any commits\",\n519:               activity: null,\n520:               completed_at: new Date().toISOString(),\n521:             });\n522:             saveState(projectRoot, state);\n523:             wtLog(agent.feature_id, \"process died with no code changes — marked failed\");\n524:           } else {\n525:             updateAgent(state, agent.feature_id, {\n526:               status: \"completed\",\n527:               completed_at: new Date().toISOString(),\n528:               activity: \"done\",\n529:             });\n530:             saveState(projectRoot, state);\n531:             const feature = featureMap.get(agent.feature_id)!;\n532:             try {\n533:               await handleBuildVerification(projectRoot, state, agent, feature, config, model, monitor);\n534:             } catch (err: any) {\n535:               wtLog(agent.feature_id, `POLL VERIFY ERROR: ${err.message}`);\n536:             }\n537:           }\n538:           launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n539:         }\n540:       }\n541: \n542:       saveState(projectRoot, state);\n543:       if (tuiRef.current) {\n544:         tuiRef.current.updateState(state);\n545:       } else if (opts.noTui) {\n546:         dashboardCounter++;\n547:         if (dashboardCounter % 3 === 0) {\n548:           printDashboard(state);\n549:         }\n550:       }\n551:     }\n552: \n553:     if (tuiRef.current) tuiRef.current.stop();\n554:     printDashboard(state);\n555: \n556:     // Auto-push base branch if requested\n557:     if (opts.autoPush) {\n558:       await pushBaseBranch(projectRoot, state.base_branch, config);\n559:     }\n560: \n561:     console.log(\"Wave complete.\");\n562:   }\n563: }\n\n(End of file - total 563 lines)\n</content>","title":"src/commands/resume.ts","metadata":{"preview":"/**\n * resume.ts — Resume a previously stopped wave.\n *\n * Usage: wombo resume [options]\n *\n * Restores from .wombo-state.json:\n *   - Agents in \"running\"/\"installing\" whose PID is dead → re-check or re-launch\n *   - Agents in \"queued\" → launch them\n *   - Agents in terminal states (verified/failed/merged) → leave alone\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport type { Feature } from \"../lib/features.js\";\nimport { loadFeatures } from \"../lib/features.js\";\nimport {\n  loadState,\n  saveState,\n  updateAgent,\n  queuedAgents,\n  isWaveComplete,","truncated":false,"loaded":[]},"time":{"start":1773352361007,"end":1773352361010}}}}
{"type":"tool_use","timestamp":1773352361559,"sessionID":"ses_31bfd06f5ffeleRCi6uuMulALr","part":{"id":"prt_ce4099c970017WoQMohrYWOKr5","sessionID":"ses_31bfd06f5ffeleRCi6uuMulALr","messageID":"msg_ce4098fd40015SE7xIFe7a3vBH","type":"tool","callID":"toolu_vrtx_01TMKAsgnBrShmeyQ6Qac5Cg","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-dmux-migration/src/commands/retry.ts"},"output":"<path>/home/fulgidus/Documents/wombo-dmux-migration/src/commands/retry.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * retry.ts — Retry a specific failed agent.\n3:  *\n4:  * Usage: wombo retry <feature-id> [--interactive] [--model <model>]\n5:  *\n6:  * Resets the agent's retry count and re-launches it. Can launch in either\n7:  * headless mode (default) or interactive (dmux/tmux) mode.\n8:  */\n9: \n10: import type { WomboConfig } from \"../config.js\";\n11: import { loadFeatures, type Feature } from \"../lib/features.js\";\n12: import {\n13:   loadState,\n14:   saveState,\n15:   updateAgent,\n16: } from \"../lib/state.js\";\n17: import { worktreeReady } from \"../lib/worktree.js\";\n18: import { generatePrompt } from \"../lib/prompt.js\";\n19: import { launchInteractive, getMultiplexerName } from \"../lib/launcher.js\";\n20: import { ProcessMonitor } from \"../lib/monitor.js\";\n21: import { launchSingleHeadless } from \"./launch.js\";\n22: \n23: // ---------------------------------------------------------------------------\n24: // Types\n25: // ---------------------------------------------------------------------------\n26: \n27: export interface RetryCommandOptions {\n28:   projectRoot: string;\n29:   config: WomboConfig;\n30:   featureId: string;\n31:   model?: string;\n32:   interactive: boolean;\n33:   dryRun?: boolean;\n34: }\n35: \n36: // ---------------------------------------------------------------------------\n37: // Command\n38: // ---------------------------------------------------------------------------\n39: \n40: export async function cmdRetry(opts: RetryCommandOptions): Promise<void> {\n41:   const { projectRoot, config } = opts;\n42: \n43:   if (!opts.featureId) {\n44:     console.error(\"Usage: wombo retry <feature-id>\");\n45:     process.exit(1);\n46:     return; // unreachable — helps TypeScript narrow\n47:   }\n48: \n49:   const state = loadState(projectRoot);\n50:   if (!state) {\n51:     console.log(\"No active wave.\");\n52:     return;\n53:   }\n54: \n55:   const agent = state.agents.find((a) => a.feature_id === opts.featureId);\n56:   if (!agent) {\n57:     console.error(`Agent not found for feature: ${opts.featureId}`);\n58:     process.exit(1);\n59:     return; // unreachable — helps TypeScript narrow\n60:   }\n61: \n62:   if (agent.status !== \"failed\") {\n63:     console.error(\n64:       `Agent ${opts.featureId} is not in failed state (current: ${agent.status})`\n65:     );\n66:     process.exit(1);\n67:     return; // unreachable — helps TypeScript narrow\n68:   }\n69: \n70:   // Dry-run: show what would be retried without doing it\n71:   if (opts.dryRun) {\n72:     console.log(`\\n[dry-run] Would retry agent: ${opts.featureId}`);\n73:     console.log(`  Current status: ${agent.status}`);\n74:     console.log(`  Retries so far: ${agent.retries}`);\n75:     console.log(`  Worktree: ${agent.worktree}`);\n76:     console.log(`  Mode: ${opts.interactive ? \"interactive (multiplexer)\" : \"headless\"}`);\n77:     if (opts.model) console.log(`  Model: ${opts.model}`);\n78:     return;\n79:   }\n80: \n81:   // Reset retry count and re-run\n82:   updateAgent(state, agent.feature_id, {\n83:     status: \"queued\",\n84:     retries: 0,\n85:     error: null,\n86:     build_passed: null,\n87:     build_output: null,\n88:     completed_at: null,\n89:   });\n90:   saveState(projectRoot, state);\n91: \n92:   const data = loadFeatures(projectRoot, config);\n93:   const feature = data.features.find((f) => f.id === opts.featureId);\n94:   if (!feature) {\n95:     console.error(`Feature ${opts.featureId} not found in ${config.featuresFile}`);\n96:     process.exit(1);\n97:     return; // unreachable — helps TypeScript narrow\n98:   }\n99: \n100:   if (opts.interactive) {\n101:     const prompt = generatePrompt(feature, state.base_branch, config);\n102:     launchInteractive({\n103:       worktreePath: agent.worktree,\n104:       featureId: feature.id,\n105:       prompt,\n106:       model: opts.model,\n107:       interactive: true,\n108:       config,\n109:     });\n110: \n111:     updateAgent(state, agent.feature_id, {\n112:       status: \"running\",\n113:       started_at: new Date().toISOString(),\n114:     });\n115:     saveState(projectRoot, state);\n116:     const muxName = getMultiplexerName(config);\n117:     console.log(`Retrying ${opts.featureId} in ${muxName} session ${config.agent.tmuxPrefix}-${opts.featureId}`);\n118:   } else {\n119:     const monitor = new ProcessMonitor(projectRoot);\n120:     await launchSingleHeadless(projectRoot, state, agent, feature, monitor, config, opts.model);\n121:     console.log(`Retrying ${opts.featureId} in headless mode`);\n122:   }\n123: }\n\n(End of file - total 123 lines)\n</content>","title":"src/commands/retry.ts","metadata":{"preview":"/**\n * retry.ts — Retry a specific failed agent.\n *\n * Usage: wombo retry <feature-id> [--interactive] [--model <model>]\n *\n * Resets the agent's retry count and re-launches it. Can launch in either\n * headless mode (default) or interactive (dmux/tmux) mode.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport { loadFeatures, type Feature } from \"../lib/features.js\";\nimport {\n  loadState,\n  saveState,\n  updateAgent,\n} from \"../lib/state.js\";\nimport { worktreeReady } from \"../lib/worktree.js\";\nimport { generatePrompt } from \"../lib/prompt.js\";\nimport { launchInteractive, getMultiplexerName } from \"../lib/launcher.js\";\nimport { ProcessMonitor } from \"../lib/monitor.js\";","truncated":false,"loaded":[]},"time":{"start":1773352361556,"end":1773352361559}}}}
{"type":"tool_use","timestamp":1773352361976,"sessionID":"ses_31bfd06f5ffeleRCi6uuMulALr","part":{"id":"prt_ce4099f20001kG9ldK4PdN6Ube","sessionID":"ses_31bfd06f5ffeleRCi6uuMulALr","messageID":"msg_ce4098fd40015SE7xIFe7a3vBH","type":"tool","callID":"toolu_vrtx_014BAhvwGVRsp6gXkKo6kCHm","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-dmux-migration/src/commands/init.ts"},"output":"<path>/home/fulgidus/Documents/wombo-dmux-migration/src/commands/init.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * init.ts — Interactive guided setup for wombo.json.\n3:  *\n4:  * Usage: wombo init [--force]\n5:  *\n6:  * Walks the user through every config section, showing defaults and\n7:  * accepting overrides.  Press Enter on any prompt to keep the default.\n8:  */\n9: \n10: import { existsSync, writeFileSync, readFileSync, mkdirSync } from \"node:fs\";\n11: import { resolve } from \"node:path\";\n12: import { createInterface } from \"node:readline\";\n13: import { CONFIG_FILE, DEFAULT_CONFIG, type WomboConfig } from \"../config.js\";\n14: import { FEATURES_TEMPLATE_PATH } from \"../lib/features.js\";\n15: import { renderAgentTemplate } from \"../lib/templates.js\";\n16: \n17: export interface InitOptions {\n18:   projectRoot: string;\n19:   force?: boolean;\n20: }\n21: \n22: // ---------------------------------------------------------------------------\n23: // Prompt helper — reads one line at a time from stdin\n24: // ---------------------------------------------------------------------------\n25: \n26: class Prompter {\n27:   private lines: AsyncIterableIterator<string>;\n28:   private done = false;\n29:   private rl: ReturnType<typeof createInterface>;\n30: \n31:   constructor() {\n32:     this.rl = createInterface({ input: process.stdin, output: process.stdout, terminal: process.stdin.isTTY ?? false });\n33:     this.lines = this.rl[Symbol.asyncIterator]();\n34:   }\n35: \n36:   /** Read one line from stdin after printing the prompt. */\n37:   private async ask(prompt: string): Promise<string> {\n38:     if (this.done) return \"\";\n39:     process.stdout.write(prompt);\n40:     const result = await this.lines.next();\n41:     if (result.done) {\n42:       this.done = true;\n43:       return \"\";\n44:     }\n45:     return result.value.trim();\n46:   }\n47: \n48:   async string(label: string, defaultVal: string): Promise<string> {\n49:     const answer = await this.ask(`  ${label} [${defaultVal}]: `);\n50:     return answer || defaultVal;\n51:   }\n52: \n53:   async number(label: string, defaultVal: number): Promise<number> {\n54:     const answer = await this.ask(`  ${label} [${defaultVal}]: `);\n55:     if (!answer) return defaultVal;\n56:     const n = parseInt(answer, 10);\n57:     return isNaN(n) ? defaultVal : n;\n58:   }\n59: \n60:   async stringOrNull(label: string, defaultVal: string | null): Promise<string | null> {\n61:     const display = defaultVal ?? \"auto-detect\";\n62:     const answer = await this.ask(`  ${label} [${display}]: `);\n63:     if (!answer) return defaultVal;\n64:     if (answer.toLowerCase() === \"null\" || answer.toLowerCase() === \"auto\") return null;\n65:     return answer;\n66:   }\n67: \n68:   async stringList(label: string, defaultVal: string[]): Promise<string[]> {\n69:     const display = defaultVal.join(\", \");\n70:     const answer = await this.ask(`  ${label} [${display}]: `);\n71:     if (!answer) return defaultVal;\n72:     return answer.split(\",\").map((s) => s.trim()).filter(Boolean);\n73:   }\n74: \n75:   async yesNo(label: string, defaultVal: boolean): Promise<boolean> {\n76:     const display = defaultVal ? \"Y/n\" : \"y/N\";\n77:     const answer = await this.ask(`  ${label} [${display}]: `);\n78:     if (!answer) return defaultVal;\n79:     return answer.toLowerCase().startsWith(\"y\");\n80:   }\n81: \n82:   close(): void {\n83:     this.rl.close();\n84:   }\n85: }\n86: \n87: // ---------------------------------------------------------------------------\n88: // Section printer\n89: // ---------------------------------------------------------------------------\n90: \n91: function section(title: string): void {\n92:   console.log(`\\n--- ${title} ${\"─\".repeat(Math.max(0, 56 - title.length))}`);\n93: }\n94: \n95: // ---------------------------------------------------------------------------\n96: // Command\n97: // ---------------------------------------------------------------------------\n98: \n99: export async function cmdInit(opts: InitOptions): Promise<void> {\n100:   const configPath = resolve(opts.projectRoot, CONFIG_FILE);\n101: \n102:   if (existsSync(configPath) && !opts.force) {\n103:     console.error(\n104:       `${CONFIG_FILE} already exists. Use --force to overwrite.`\n105:     );\n106:     process.exit(1);\n107:   }\n108: \n109:   console.log(`\\nWombo — Project Setup`);\n110:   console.log(`Configuring ${CONFIG_FILE} for ${opts.projectRoot}`);\n111:   console.log(`Press Enter to accept the default shown in [brackets].\\n`);\n112: \n113:   const p = new Prompter();\n114: \n115:   try {\n116:     const cfg: WomboConfig = structuredClone(DEFAULT_CONFIG);\n117: \n118:     // -- General ----------------------------------------------------------\n119:     section(\"General\");\n120:     cfg.featuresFile = await p.string(\"Features YAML file\", cfg.featuresFile);\n121:     cfg.baseBranch = await p.string(\"Base branch\", cfg.baseBranch);\n122: \n123:     // -- Build ------------------------------------------------------------\n124:     section(\"Build\");\n125:     cfg.build.command = await p.string(\"Build command\", cfg.build.command);\n126:     cfg.build.timeout = await p.number(\"Build timeout (ms)\", cfg.build.timeout);\n127:     cfg.build.artifactDir = await p.string(\"Artifact directory\", cfg.build.artifactDir);\n128: \n129:     // -- Install ----------------------------------------------------------\n130:     section(\"Install\");\n131:     cfg.install.command = await p.string(\"Install command\", cfg.install.command);\n132:     cfg.install.timeout = await p.number(\"Install timeout (ms)\", cfg.install.timeout);\n133: \n134:     // -- Git --------------------------------------------------------------\n135:     section(\"Git\");\n136:     cfg.git.branchPrefix = await p.string(\"Branch prefix\", cfg.git.branchPrefix);\n137:     cfg.git.worktreePrefix = await p.string(\"Worktree prefix\", cfg.git.worktreePrefix);\n138:     cfg.git.remote = await p.string(\"Remote name\", cfg.git.remote);\n139:     cfg.git.mergeStrategy = await p.string(\"Merge strategy flag\", cfg.git.mergeStrategy);\n140: \n141:     // -- Agent ------------------------------------------------------------\n142:     section(\"Agent\");\n143:     cfg.agent.bin = await p.stringOrNull(\"Agent binary path (or 'auto')\", cfg.agent.bin);\n144:     cfg.agent.name = await p.string(\"Agent name\", cfg.agent.name);\n145:     cfg.agent.configFiles = await p.stringList(\n146:       \"Config files to copy (comma-sep)\",\n147:       cfg.agent.configFiles\n148:     );\n149:     cfg.agent.tmuxPrefix = await p.string(\"tmux session prefix\", cfg.agent.tmuxPrefix);\n150: \n151:     // -- Defaults ---------------------------------------------------------\n152:     section(\"Runtime Defaults\");\n153:     cfg.defaults.maxConcurrent = await p.number(\"Max concurrent agents\", cfg.defaults.maxConcurrent);\n154:     cfg.defaults.maxRetries = await p.number(\"Max retries per agent\", cfg.defaults.maxRetries);\n155: \n156:     // -- Write config ------------------------------------------------------\n157:     console.log(`\\n${\"─\".repeat(60)}`);\n158:     const json = JSON.stringify(cfg, null, 2) + \"\\n\";\n159:     writeFileSync(configPath, json, \"utf-8\");\n160:     console.log(`\\nCreated ${CONFIG_FILE}`);\n161: \n162:     // -- Create features file from template -------------------------------\n163:     const featuresPath = resolve(opts.projectRoot, cfg.featuresFile);\n164:     if (existsSync(featuresPath) && !opts.force) {\n165:       console.log(`${cfg.featuresFile} already exists, skipping.`);\n166:     } else {\n167:       const template = readFileSync(FEATURES_TEMPLATE_PATH, \"utf-8\");\n168:       const now = new Date().toISOString();\n169:       const content = template\n170:         .replace(/created_at:\\s*\".*?\"/, `created_at: \"${now}\"`)\n171:         .replace(/updated_at:\\s*\".*?\"/, `updated_at: \"${now}\"`);\n172:       writeFileSync(featuresPath, content, \"utf-8\");\n173:       console.log(`Created ${cfg.featuresFile} from template.`);\n174:     }\n175: \n176:     // -- Install agent definition template --------------------------------\n177:     const agentDir = resolve(opts.projectRoot, \"agent\");\n178:     const agentDefPath = resolve(agentDir, `${cfg.agent.name}.md`);\n179: \n180:     let installAgent = true;\n181:     if (existsSync(agentDefPath) && !opts.force) {\n182:       installAgent = await p.yesNo(\n183:         `agent/${cfg.agent.name}.md already exists. Overwrite?`,\n184:         false\n185:       );\n186:     }\n187: \n188:     if (installAgent) {\n189:       mkdirSync(agentDir, { recursive: true });\n190:       const agentTemplate = renderAgentTemplate(cfg, opts.projectRoot);\n191:       writeFileSync(agentDefPath, agentTemplate, \"utf-8\");\n192:       console.log(`Created agent/${cfg.agent.name}.md from template.`);\n193:     } else {\n194:       console.log(`agent/${cfg.agent.name}.md already exists, skipping.`);\n195:     }\n196: \n197:     // Ensure agent/ is in configFiles\n198:     if (!cfg.agent.configFiles.includes(\"agent/\")) {\n199:       cfg.agent.configFiles.push(\"agent/\");\n200:       // Re-write config with updated configFiles\n201:       const updatedJson = JSON.stringify(cfg, null, 2) + \"\\n\";\n202:       writeFileSync(configPath, updatedJson, \"utf-8\");\n203:       console.log(`Added agent/ to configFiles in ${CONFIG_FILE}.`);\n204:     }\n205: \n206:     console.log(`\\nYou're all set! Run 'wombo help' to see available commands.\\n`);\n207:   } finally {\n208:     p.close();\n209:   }\n210: }\n\n(End of file - total 210 lines)\n</content>","title":"src/commands/init.ts","metadata":{"preview":"/**\n * init.ts — Interactive guided setup for wombo.json.\n *\n * Usage: wombo init [--force]\n *\n * Walks the user through every config section, showing defaults and\n * accepting overrides.  Press Enter on any prompt to keep the default.\n */\n\nimport { existsSync, writeFileSync, readFileSync, mkdirSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\nimport { createInterface } from \"node:readline\";\nimport { CONFIG_FILE, DEFAULT_CONFIG, type WomboConfig } from \"../config.js\";\nimport { FEATURES_TEMPLATE_PATH } from \"../lib/features.js\";\nimport { renderAgentTemplate } from \"../lib/templates.js\";\n\nexport interface InitOptions {\n  projectRoot: string;\n  force?: boolean;\n}","truncated":false,"loaded":[]},"time":{"start":1773352361967,"end":1773352361975}}}}
{"type":"tool_use","timestamp":1773352362381,"sessionID":"ses_31bfd06f5ffeleRCi6uuMulALr","part":{"id":"prt_ce409a0ba001In6BBW67dmRh7n","sessionID":"ses_31bfd06f5ffeleRCi6uuMulALr","messageID":"msg_ce4098fd40015SE7xIFe7a3vBH","type":"tool","callID":"toolu_vrtx_01DGZ3E3CgSanyCSjR9TxCLS","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-dmux-migration/src/lib/schema.ts"},"output":"<path>/home/fulgidus/Documents/wombo-dmux-migration/src/lib/schema.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * schema.ts — Declarative command/flag registry for schema introspection.\n3:  *\n4:  * Every command and flag is described in a single registry. This registry is\n5:  * the source of truth for:\n6:  *   1. `wombo describe <command>` — emits a JSON schema of accepted args\n7:  *   2. Future help text generation\n8:  *\n9:  * The registry is NOT used for actual arg parsing (that's still the hand-rolled\n10:  * switch in index.ts), but the two must stay in sync. If they drift, `wombo\n11:  * features check` should eventually catch it.\n12:  */\n13: \n14: // ---------------------------------------------------------------------------\n15: // Types\n16: // ---------------------------------------------------------------------------\n17: \n18: export interface FlagDef {\n19:   /** Primary flag name, e.g. \"--dry-run\" */\n20:   name: string;\n21:   /** Short alias, e.g. \"-o\" */\n22:   alias?: string;\n23:   /** Description shown in help / schema */\n24:   description: string;\n25:   /** Type of the value: \"boolean\" flags take no value, others consume next arg */\n26:   type: \"string\" | \"number\" | \"boolean\" | \"string[]\";\n27:   /** Default value (undefined = required or absent) */\n28:   default?: unknown;\n29:   /** For enum-like flags, the set of allowed values */\n30:   enum?: readonly string[];\n31:   /** If true, this flag is required */\n32:   required?: boolean;\n33: }\n34: \n35: export interface PositionalDef {\n36:   /** Name used in usage strings, e.g. \"feature-id\" */\n37:   name: string;\n38:   description: string;\n39:   required?: boolean;\n40: }\n41: \n42: export interface CommandDef {\n43:   /** Command name as typed by the user, e.g. \"launch\" or \"features list\" */\n44:   name: string;\n45:   /** One-line summary */\n46:   summary: string;\n47:   /** Longer description */\n48:   description?: string;\n49:   /** Positional arguments */\n50:   positionals: PositionalDef[];\n51:   /** Named flags */\n52:   flags: FlagDef[];\n53:   /** Whether this command mutates state (used for dry-run indication) */\n54:   mutating: boolean;\n55:   /** Whether this command supports --dry-run */\n56:   supportsDryRun: boolean;\n57:   /** Subcommands (for \"features\" parent) */\n58:   subcommands?: CommandDef[];\n59: }\n60: \n61: // ---------------------------------------------------------------------------\n62: // Global flags (available on every command)\n63: // ---------------------------------------------------------------------------\n64: \n65: const GLOBAL_FLAGS: FlagDef[] = [\n66:   {\n67:     name: \"--output\",\n68:     alias: \"-o\",\n69:     description: \"Output format: text (default) or json\",\n70:     type: \"string\",\n71:     default: \"text\",\n72:     enum: [\"text\", \"json\"],\n73:   },\n74:   {\n75:     name: \"--force\",\n76:     description: \"Force overwrite / skip safety prompts\",\n77:     type: \"boolean\",\n78:     default: false,\n79:   },\n80: ];\n81: \n82: // ---------------------------------------------------------------------------\n83: // Command Registry\n84: // ---------------------------------------------------------------------------\n85: \n86: export const COMMAND_REGISTRY: CommandDef[] = [\n87:   // --- init ---------------------------------------------------------------\n88:   {\n89:     name: \"init\",\n90:     summary: \"Generate wombo.json config in the current project\",\n91:     description:\n92:       \"Interactive guided setup that walks through every config section. \" +\n93:       \"Creates wombo.json and .features.yml from template.\",\n94:     positionals: [],\n95:     flags: [\n96:       {\n97:         name: \"--force\",\n98:         description: \"Overwrite existing config files\",\n99:         type: \"boolean\",\n100:         default: false,\n101:       },\n102:       {\n103:         name: \"--dry-run\",\n104:         description: \"Show what would be created without writing files\",\n105:         type: \"boolean\",\n106:         default: false,\n107:       },\n108:     ],\n109:     mutating: true,\n110:     supportsDryRun: true,\n111:   },\n112: \n113:   // --- launch -------------------------------------------------------------\n114:   {\n115:     name: \"launch\",\n116:     summary: \"Launch a wave of agents to implement features\",\n117:     description:\n118:       \"Select features from .features.yml, create worktrees, and spawn agents. \" +\n119:       \"Supports multiple selection strategies.\",\n120:     positionals: [],\n121:     flags: [\n122:       { name: \"--top-priority\", description: \"Select top N features by priority\", type: \"number\" },\n123:       { name: \"--quickest-wins\", description: \"Select N features with lowest effort\", type: \"number\" },\n124:       { name: \"--priority\", description: \"Filter by priority level\", type: \"string\", enum: [\"critical\", \"high\", \"medium\", \"low\", \"wishlist\"] },\n125:       { name: \"--difficulty\", description: \"Filter by difficulty level\", type: \"string\", enum: [\"trivial\", \"easy\", \"medium\", \"hard\", \"very_hard\"] },\n126:       { name: \"--features\", description: \"Select specific features by comma-separated IDs\", type: \"string\" },\n127:       { name: \"--all-ready\", description: \"Select all features whose dependencies are met\", type: \"boolean\", default: false },\n128:       { name: \"--max-concurrent\", description: \"Max agents running in parallel\", type: \"number\" },\n129:       { name: \"--model\", alias: \"-m\", description: \"Model to use (e.g., anthropic/claude-sonnet-4-20250514)\", type: \"string\" },\n130:       { name: \"--interactive\", description: \"Use tmux TUI mode instead of headless\", type: \"boolean\", default: false },\n131:       { name: \"--no-tui\", description: \"Headless mode without neo-blessed TUI\", type: \"boolean\", default: false },\n132:       { name: \"--auto-push\", description: \"Push base branch to remote after all merges\", type: \"boolean\", default: false },\n133:       { name: \"--dry-run\", description: \"Show what would be launched without launching\", type: \"boolean\", default: false },\n134:       { name: \"--base-branch\", description: \"Base branch (default: from config)\", type: \"string\" },\n135:       { name: \"--max-retries\", description: \"Max retries per agent\", type: \"number\" },\n136:     ],\n137:     mutating: true,\n138:     supportsDryRun: true,\n139:   },\n140: \n141:   // --- resume -------------------------------------------------------------\n142:   {\n143:     name: \"resume\",\n144:     summary: \"Resume a previously stopped wave\",\n145:     positionals: [],\n146:     flags: [\n147:       { name: \"--max-concurrent\", description: \"Max agents running in parallel\", type: \"number\" },\n148:       { name: \"--model\", alias: \"-m\", description: \"Model to use\", type: \"string\" },\n149:       { name: \"--interactive\", description: \"Use tmux TUI mode\", type: \"boolean\", default: false },\n150:       { name: \"--no-tui\", description: \"Headless mode without neo-blessed TUI\", type: \"boolean\", default: false },\n151:       { name: \"--auto-push\", description: \"Push base branch to remote after merges\", type: \"boolean\", default: false },\n152:       { name: \"--base-branch\", description: \"Base branch override\", type: \"string\" },\n153:       { name: \"--max-retries\", description: \"Max retries per agent\", type: \"number\" },\n154:     ],\n155:     mutating: true,\n156:     supportsDryRun: false,\n157:   },\n158: \n159:   // --- status -------------------------------------------------------------\n160:   {\n161:     name: \"status\",\n162:     summary: \"Show the status of the current wave\",\n163:     positionals: [],\n164:     flags: [],\n165:     mutating: false,\n166:     supportsDryRun: false,\n167:   },\n168: \n169:   // --- verify -------------------------------------------------------------\n170:   {\n171:     name: \"verify\",\n172:     summary: \"Run build verification on completed agents\",\n173:     positionals: [\n174:       { name: \"feature-id\", description: \"Specific feature to verify (optional)\", required: false },\n175:     ],\n176:     flags: [\n177:       { name: \"--model\", alias: \"-m\", description: \"Model to use for verification\", type: \"string\" },\n178:       { name: \"--max-retries\", description: \"Max retries\", type: \"number\" },\n179:     ],\n180:     mutating: true,\n181:     supportsDryRun: false,\n182:   },\n183: \n184:   // --- merge --------------------------------------------------------------\n185:   {\n186:     name: \"merge\",\n187:     summary: \"Merge verified branches into the base branch\",\n188:     positionals: [\n189:       { name: \"feature-id\", description: \"Specific feature to merge (optional)\", required: false },\n190:     ],\n191:     flags: [\n192:       { name: \"--auto-push\", description: \"Push base branch to remote after merge\", type: \"boolean\", default: false },\n193:       { name: \"--dry-run\", description: \"Show what would be merged without merging\", type: \"boolean\", default: false },\n194:     ],\n195:     mutating: true,\n196:     supportsDryRun: true,\n197:   },\n198: \n199:   // --- retry --------------------------------------------------------------\n200:   {\n201:     name: \"retry\",\n202:     summary: \"Retry a failed agent\",\n203:     positionals: [\n204:       { name: \"feature-id\", description: \"Feature ID of the failed agent\", required: true },\n205:     ],\n206:     flags: [\n207:       { name: \"--model\", alias: \"-m\", description: \"Model to use\", type: \"string\" },\n208:       { name: \"--interactive\", description: \"Use tmux TUI mode\", type: \"boolean\", default: false },\n209:       { name: \"--dry-run\", description: \"Show what would be retried without retrying\", type: \"boolean\", default: false },\n210:     ],\n211:     mutating: true,\n212:     supportsDryRun: true,\n213:   },\n214: \n215:   // --- cleanup ------------------------------------------------------------\n216:   {\n217:     name: \"cleanup\",\n218:     summary: \"Remove all wave worktrees and tmux sessions\",\n219:     description: \"Kills tmux sessions, removes worktrees, removes state and log files.\",\n220:     positionals: [],\n221:     flags: [\n222:       { name: \"--dry-run\", description: \"Show what would be cleaned up without removing\", type: \"boolean\", default: false },\n223:     ],\n224:     mutating: true,\n225:     supportsDryRun: true,\n226:   },\n227: \n228:   // --- abort --------------------------------------------------------------\n229:   {\n230:     name: \"abort\",\n231:     summary: \"Kill a single running agent without affecting the rest of the wave\",\n232:     description:\n233:       \"Kills the tmux session and agent process for a specific feature, then \" +\n234:       \"marks the agent as failed. Use --requeue to return the feature to the \" +\n235:       \"queue instead of marking it failed.\",\n236:     positionals: [\n237:       { name: \"feature-id\", description: \"Feature ID of the agent to abort\", required: true },\n238:     ],\n239:     flags: [\n240:       { name: \"--requeue\", description: \"Return the feature to queued instead of marking it failed\", type: \"boolean\", default: false },\n241:     ],\n242:     mutating: true,\n243:     supportsDryRun: false,\n244:   },\n245: \n246:   // --- upgrade ------------------------------------------------------------\n247:   {\n248:     name: \"upgrade\",\n249:     summary: \"Check for updates and upgrade wombo\",\n250:     positionals: [],\n251:     flags: [\n252:       { name: \"--check\", description: \"Only check for updates, don't install\", type: \"boolean\", default: false },\n253:       { name: \"--version\", description: \"Install a specific version (e.g., v0.1.0)\", type: \"string\" },\n254:       { name: \"--force\", description: \"Force reinstall even if up to date\", type: \"boolean\", default: false },\n255:     ],\n256:     mutating: true,\n257:     supportsDryRun: false,\n258:   },\n259: \n260:   // --- logs ---------------------------------------------------------------\n261:   {\n262:     name: \"logs\",\n263:     summary: \"Pretty-print agent logs from .wombo-logs/<feature-id>.log\",\n264:     description:\n265:       \"Reads log files written by agents during headless runs and displays \" +\n266:       \"them with colorized output. Supports tailing and following.\",\n267:     positionals: [\n268:       { name: \"feature-id\", description: \"Feature ID whose logs to display\", required: true },\n269:     ],\n270:     flags: [\n271:       { name: \"--tail\", description: \"Show only the last N lines\", type: \"number\" },\n272:       { name: \"--follow\", alias: \"-f\", description: \"Stream new output as it arrives (like tail -f)\", type: \"boolean\", default: false },\n273:     ],\n274:     mutating: false,\n275:     supportsDryRun: false,\n276:   },\n277: \n278:   // --- features (parent with subcommands) ---------------------------------\n279:   {\n280:     name: \"features\",\n281:     summary: \"Manage .features.yml\",\n282:     positionals: [],\n283:     flags: [],\n284:     mutating: false,\n285:     supportsDryRun: false,\n286:     subcommands: [\n287:       {\n288:         name: \"features list\",\n289:         summary: \"List features with optional filtering\",\n290:         positionals: [],\n291:         flags: [\n292:           { name: \"--status\", description: \"Filter by status\", type: \"string\", enum: [\"backlog\", \"planned\", \"in_progress\", \"blocked\", \"in_review\", \"done\", \"cancelled\"] },\n293:           { name: \"--priority\", description: \"Filter by priority\", type: \"string\", enum: [\"critical\", \"high\", \"medium\", \"low\", \"wishlist\"] },\n294:           { name: \"--difficulty\", description: \"Filter by difficulty\", type: \"string\", enum: [\"trivial\", \"easy\", \"medium\", \"hard\", \"very_hard\"] },\n295:           { name: \"--ready\", description: \"Show only ready features (backlog + deps met)\", type: \"boolean\", default: false },\n296:           { name: \"--include-archive\", description: \"Include archived features\", type: \"boolean\", default: false },\n297:           { name: \"--fields\", description: \"Comma-separated list of fields to include in output\", type: \"string\" },\n298:         ],\n299:         mutating: false,\n300:         supportsDryRun: false,\n301:       },\n302:       {\n303:         name: \"features add\",\n304:         summary: \"Add a new feature\",\n305:         positionals: [\n306:           { name: \"id\", description: \"Feature ID (kebab-case)\", required: true },\n307:           { name: \"title\", description: \"Feature title\", required: true },\n308:         ],\n309:         flags: [\n310:           { name: \"--description\", alias: \"--desc\", description: \"Feature description\", type: \"string\" },\n311:           { name: \"--priority\", description: \"Priority level\", type: \"string\", default: \"medium\", enum: [\"critical\", \"high\", \"medium\", \"low\", \"wishlist\"] },\n312:           { name: \"--difficulty\", description: \"Difficulty level\", type: \"string\", default: \"medium\", enum: [\"trivial\", \"easy\", \"medium\", \"hard\", \"very_hard\"] },\n313:           { name: \"--effort\", description: \"Effort estimate (ISO 8601 duration, e.g. PT2H)\", type: \"string\", default: \"PT1H\" },\n314:           { name: \"--depends-on\", description: \"Comma-separated dependency IDs\", type: \"string\" },\n315:           { name: \"--dry-run\", description: \"Show what would be added without writing\", type: \"boolean\", default: false },\n316:         ],\n317:         mutating: true,\n318:         supportsDryRun: true,\n319:       },\n320:       {\n321:         name: \"features set-status\",\n322:         summary: \"Change a feature's status\",\n323:         positionals: [\n324:           { name: \"feature-id\", description: \"Feature ID to update\", required: true },\n325:           { name: \"status\", description: \"New status value\", required: true },\n326:         ],\n327:         flags: [\n328:           { name: \"--dry-run\", description: \"Show what would change without writing\", type: \"boolean\", default: false },\n329:         ],\n330:         mutating: true,\n331:         supportsDryRun: true,\n332:       },\n333:       {\n334:         name: \"features check\",\n335:         summary: \"Validate .features.yml (schema, deps, duplicates, cycles)\",\n336:         positionals: [],\n337:         flags: [],\n338:         mutating: false,\n339:         supportsDryRun: false,\n340:       },\n341:       {\n342:         name: \"features archive\",\n343:         summary: \"Move done/cancelled features to archive section\",\n344:         positionals: [\n345:           { name: \"feature-id\", description: \"Specific feature to archive (optional)\", required: false },\n346:         ],\n347:         flags: [\n348:           { name: \"--dry-run\", description: \"Show what would be archived without moving\", type: \"boolean\", default: false },\n349:         ],\n350:         mutating: true,\n351:         supportsDryRun: true,\n352:       },\n353:       {\n354:         name: \"features show\",\n355:         summary: \"Show detailed information about a specific feature\",\n356:         positionals: [\n357:           { name: \"feature-id\", description: \"Feature ID to display\", required: true },\n358:         ],\n359:         flags: [\n360:           { name: \"--fields\", description: \"Comma-separated list of fields to include in output\", type: \"string\" },\n361:         ],\n362:         mutating: false,\n363:         supportsDryRun: false,\n364:       },\n365:       {\n366:         name: \"features graph\",\n367:         summary: \"Visualize the feature dependency graph as a terminal diagram\",\n368:         description:\n369:           \"Builds a Mermaid flowchart from the features dependency graph and renders \" +\n370:           \"it as a Unicode box diagram. Shows dependency edges, status badges, orphan \" +\n371:           \"detection, dangling dependency warnings, and cycle detection.\",\n372:         positionals: [],\n373:         flags: [\n374:           { name: \"--status\", description: \"Filter graph to features with this status\", type: \"string\", enum: [\"backlog\", \"planned\", \"in_progress\", \"blocked\", \"in_review\", \"done\", \"cancelled\"] },\n375:           { name: \"--ascii\", description: \"Use ASCII-only rendering (no Unicode box chars)\", type: \"boolean\", default: false },\n376:           { name: \"--mermaid\", description: \"Emit raw Mermaid source instead of rendered graph\", type: \"boolean\", default: false },\n377:           { name: \"--subtasks\", description: \"Include subtask-level nodes in the graph\", type: \"boolean\", default: false },\n378:         ],\n379:         mutating: false,\n380:         supportsDryRun: false,\n381:       },\n382:     ],\n383:   },\n384: \n385:   // --- help ---------------------------------------------------------------\n386:   {\n387:     name: \"help\",\n388:     summary: \"Show help text\",\n389:     positionals: [],\n390:     flags: [],\n391:     mutating: false,\n392:     supportsDryRun: false,\n393:   },\n394: \n395:   // --- describe -----------------------------------------------------------\n396:   {\n397:     name: \"describe\",\n398:     summary: \"Emit JSON schema of a command's arguments and flags\",\n399:     description:\n400:       \"Machine-readable introspection for AI agents. Outputs the accepted \" +\n401:       \"positionals, flags, types, defaults, and constraints for a command.\",\n402:     positionals: [\n403:       { name: \"command\", description: \"Command to describe (e.g. 'launch', 'features add')\", required: false },\n404:     ],\n405:     flags: [],\n406:     mutating: false,\n407:     supportsDryRun: false,\n408:   },\n409: ];\n410: \n411: // ---------------------------------------------------------------------------\n412: // Lookup helpers\n413: // ---------------------------------------------------------------------------\n414: \n415: /**\n416:  * Find a command definition by name. Supports compound names like \"features list\".\n417:  */\n418: export function findCommandDef(name: string): CommandDef | undefined {\n419:   // Try direct match first\n420:   const direct = COMMAND_REGISTRY.find((c) => c.name === name);\n421:   if (direct) return direct;\n422: \n423:   // Try compound: \"features list\" -> look in features subcommands\n424:   const parts = name.split(/\\s+/);\n425:   if (parts.length === 2) {\n426:     const parent = COMMAND_REGISTRY.find((c) => c.name === parts[0]);\n427:     if (parent?.subcommands) {\n428:       return parent.subcommands.find((sc) => sc.name === name || sc.name === parts[1]);\n429:     }\n430:   }\n431: \n432:   return undefined;\n433: }\n434: \n435: /**\n436:  * Produce the JSON schema object for a command, suitable for agent consumption.\n437:  */\n438: export function commandToSchema(cmd: CommandDef): Record<string, unknown> {\n439:   const schema: Record<string, unknown> = {\n440:     command: cmd.name,\n441:     summary: cmd.summary,\n442:     mutating: cmd.mutating,\n443:     supports_dry_run: cmd.supportsDryRun,\n444:   };\n445: \n446:   if (cmd.description) {\n447:     schema.description = cmd.description;\n448:   }\n449: \n450:   if (cmd.positionals.length > 0) {\n451:     schema.positionals = cmd.positionals.map((p) => ({\n452:       name: p.name,\n453:       description: p.description,\n454:       required: p.required ?? false,\n455:     }));\n456:   }\n457: \n458:   const allFlags = [...cmd.flags, ...GLOBAL_FLAGS];\n459:   schema.flags = allFlags.map((f) => {\n460:     const entry: Record<string, unknown> = {\n461:       name: f.name,\n462:       type: f.type,\n463:       description: f.description,\n464:     };\n465:     if (f.alias) entry.alias = f.alias;\n466:     if (f.default !== undefined) entry.default = f.default;\n467:     if (f.enum) entry.enum = f.enum;\n468:     if (f.required) entry.required = true;\n469:     return entry;\n470:   });\n471: \n472:   if (cmd.subcommands?.length) {\n473:     schema.subcommands = cmd.subcommands.map((sc) => sc.name);\n474:   }\n475: \n476:   return schema;\n477: }\n478: \n479: /**\n480:  * Produce a listing of all commands (for `wombo describe` with no args).\n481:  */\n482: export function allCommandSchemas(): Record<string, unknown> {\n483:   const commands: Record<string, unknown>[] = [];\n484: \n485:   for (const cmd of COMMAND_REGISTRY) {\n486:     const entry: Record<string, unknown> = {\n487:       name: cmd.name,\n488:       summary: cmd.summary,\n489:       mutating: cmd.mutating,\n490:       supports_dry_run: cmd.supportsDryRun,\n491:     };\n492:     if (cmd.subcommands) {\n493:       entry.subcommands = cmd.subcommands.map((sc) => ({\n494:         name: sc.name,\n495:         summary: sc.summary,\n496:         mutating: sc.mutating,\n497:         supports_dry_run: sc.supportsDryRun,\n498:       }));\n499:     }\n500:     commands.push(entry);\n501:   }\n502: \n503:   return {\n504:     tool: \"wombo\",\n505:     version: \"0.0.2\",\n506:     global_flags: GLOBAL_FLAGS.map((f) => ({\n507:       name: f.name,\n508:       alias: f.alias,\n509:       type: f.type,\n510:       description: f.description,\n511:       default: f.default,\n512:     })),\n513:     commands,\n514:   };\n515: }\n\n(End of file - total 515 lines)\n</content>","title":"src/lib/schema.ts","metadata":{"preview":"/**\n * schema.ts — Declarative command/flag registry for schema introspection.\n *\n * Every command and flag is described in a single registry. This registry is\n * the source of truth for:\n *   1. `wombo describe <command>` — emits a JSON schema of accepted args\n *   2. Future help text generation\n *\n * The registry is NOT used for actual arg parsing (that's still the hand-rolled\n * switch in index.ts), but the two must stay in sync. If they drift, `wombo\n * features check` should eventually catch it.\n */\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface FlagDef {\n  /** Primary flag name, e.g. \"--dry-run\" */\n  name: string;","truncated":false,"loaded":[]},"time":{"start":1773352362376,"end":1773352362380}}}}
{"type":"tool_use","timestamp":1773352362844,"sessionID":"ses_31bfd06f5ffeleRCi6uuMulALr","part":{"id":"prt_ce409a253001sAF8hpcplXwwyb","sessionID":"ses_31bfd06f5ffeleRCi6uuMulALr","messageID":"msg_ce4098fd40015SE7xIFe7a3vBH","type":"tool","callID":"toolu_vrtx_018XRTkoBWNAESzZyAXJ4oYs","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-dmux-migration/src/index.ts"},"output":"<path>/home/fulgidus/Documents/wombo-dmux-migration/src/index.ts</path>\n<type>file</type>\n<content>1: #!/usr/bin/env bun\n2: /**\n3:  * index.ts — CLI entry point for the Wombo agent orchestration system.\n4:  *\n5:  * Usage:\n6:  *   wombo init\n7:  *   wombo launch --top-priority 3\n8:  *   wombo launch --quickest-wins 5\n9:  *   wombo launch --priority high\n10:  *   wombo launch --difficulty easy\n11:  *   wombo launch --features \"feat-a,feat-b\"\n12:  *   wombo launch --all-ready\n13:  *   wombo launch ... --max-concurrent 3 --model \"anthropic/claude-sonnet-4-20250514\"\n14:  *   wombo launch ... --interactive\n15:  *   wombo resume\n16:  *   wombo status\n17:  *   wombo verify [feature-id]\n18:  *   wombo merge [feature-id]\n19:  *   wombo retry <feature-id>\n20:  *   wombo abort <feature-id> [--requeue] [--output json]\n21:  *   wombo logs <feature-id> [--tail N] [--follow] [--output json]\n22:  *   wombo cleanup\n23:  *   wombo features list [--status <s>] [--priority <p>] [--difficulty <d>] [--ready] [--include-archive]\n24:  *   wombo features add <id> <title> [options]\n25:  *   wombo features set-status <feature-id> <status>\n26:  *   wombo features check\n27:  *   wombo features archive [feature-id] [--dry-run]\n28:  *   wombo features show <feature-id>\n29:  *   wombo features graph [--ascii] [--mermaid] [--subtasks] [--status <s>]\n30:  *   wombo help\n31:  *   wombo --version\n32:  */\n33: \n34: import { resolve } from \"node:path\";\n35: import { existsSync, readFileSync } from \"node:fs\";\n36: import { loadConfig, validateConfig } from \"./config.js\";\n37: import { loadState, saveState } from \"./lib/state.js\";\n38: \n39: // ---------------------------------------------------------------------------\n40: // Dev-mode guard: warn if running the global binary inside the wombo repo\n41: // ---------------------------------------------------------------------------\n42: \n43: function checkDevModeGuard(): void {\n44:   const cwd = process.cwd();\n45:   const pkgPath = resolve(cwd, \"package.json\");\n46: \n47:   // Are we inside the wombo repo?\n48:   if (!existsSync(pkgPath)) return;\n49: \n50:   let pkgName: string | undefined;\n51:   try {\n52:     const raw = readFileSync(pkgPath, \"utf-8\");\n53:     pkgName = JSON.parse(raw).name;\n54:   } catch {\n55:     return;\n56:   }\n57:   if (pkgName !== \"wombo\") return;\n58: \n59:   // We're in the wombo repo. Is the source being run from a different location?\n60:   // import.meta.dir = directory of THIS file (index.ts). If it's under cwd,\n61:   // we're running local source (bun dev). If it's elsewhere (e.g. ~/.bun/install),\n62:   // we're running the globally installed binary.\n63:   const sourceDir = resolve(import.meta.dir);\n64:   const projectSrc = resolve(cwd, \"src\");\n65: \n66:   if (!sourceDir.startsWith(projectSrc)) {\n67:     console.warn(\n68:       \"\\x1b[33m[WARNING]\\x1b[0m You are running the globally installed wombo binary \" +\n69:       \"inside the wombo repo.\\n\" +\n70:       \"  Use \\x1b[1mbun dev <command>\\x1b[0m instead to run from local source.\\n\" +\n71:       \"  See AGENTS.md for details.\\n\"\n72:     );\n73:   }\n74: }\n75: \n76: import { cmdInit } from \"./commands/init.js\";\n77: import { cmdLaunch } from \"./commands/launch.js\";\n78: import { cmdResume } from \"./commands/resume.js\";\n79: import { cmdStatus } from \"./commands/status.js\";\n80: import { cmdVerify } from \"./commands/verify.js\";\n81: import { cmdMerge } from \"./commands/merge.js\";\n82: import { cmdRetry } from \"./commands/retry.js\";\n83: import { cmdCleanup } from \"./commands/cleanup.js\";\n84: import { cmdAbort } from \"./commands/abort.js\";\n85: import { cmdLogs } from \"./commands/logs.js\";\n86: import { cmdUpgrade } from \"./commands/upgrade.js\";\n87: import { cmdFeaturesList } from \"./commands/features/list.js\";\n88: import { cmdFeaturesAdd } from \"./commands/features/add.js\";\n89: import { cmdFeaturesSetStatus } from \"./commands/features/set-status.js\";\n90: import { cmdFeaturesCheck } from \"./commands/features/check.js\";\n91: import { cmdFeaturesArchive } from \"./commands/features/archive.js\";\n92: import { cmdFeaturesShow } from \"./commands/features/show.js\";\n93: import { cmdFeaturesGraph } from \"./commands/features/graph.js\";\n94: \n95: import { ensureFeaturesFile } from \"./lib/features.js\";\n96: import type { Priority, Difficulty, FeatureStatus } from \"./lib/features.js\";\n97: import { resolveOutputFormat, type OutputFormat } from \"./lib/output.js\";\n98: import { validateId, validateText, validateBranchName, validateDuration, assertValid } from \"./lib/validate.js\";\n99: import { findCommandDef, commandToSchema, allCommandSchemas } from \"./lib/schema.js\";\n100: \n101: // ---------------------------------------------------------------------------\n102: // Types\n103: // ---------------------------------------------------------------------------\n104: \n105: interface CLIArgs {\n106:   command: string;\n107:   subcommand?: string;\n108:   // Selection options (launch)\n109:   topPriority?: number;\n110:   quickestWins?: number;\n111:   priority?: Priority;\n112:   difficulty?: Difficulty;\n113:   features?: string[];\n114:   allReady?: boolean;\n115:   // Launch / runtime options\n116:   maxConcurrent?: number;\n117:   model?: string;\n118:   interactive: boolean;\n119:   dryRun: boolean;\n120:   baseBranch?: string;\n121:   maxRetries?: number;\n122:   noTui: boolean;\n123:   autoPush: boolean;\n124:   // Abort options\n125:   requeue: boolean;\n126:   // General\n127:   featureId?: string;\n128:   force: boolean;\n129:   // Output format\n130:   outputFmt: OutputFormat;\n131:   // Upgrade options\n132:   checkOnly: boolean;\n133:   version?: string;\n134:   // Features subcommand extras\n135:   status?: string;\n136:   ready?: boolean;\n137:   includeArchive?: boolean;\n138:   title?: string;\n139:   description?: string;\n140:   effort?: string;\n141:   dependsOn?: string[];\n142:   // Logs options\n143:   tail?: number;\n144:   follow?: boolean;\n145:   // Compact output\n146:   fields?: string[];\n147:   // Graph options\n148:   ascii?: boolean;\n149:   mermaidRaw?: boolean;\n150:   graphSubtasks?: boolean;\n151: }\n152: \n153: // ---------------------------------------------------------------------------\n154: // Arg Parsing\n155: // ---------------------------------------------------------------------------\n156: \n157: function parseArgs(argv: string[]): CLIArgs {\n158:   const args = argv.slice(2); // skip 'bun' and script path\n159:   const result: CLIArgs = {\n160:     command: args[0] || \"help\",\n161:     interactive: false,\n162:     dryRun: false,\n163:     noTui: false,\n164:     autoPush: false,\n165:     requeue: false,\n166:     force: false,\n167:     checkOnly: false,\n168:     outputFmt: resolveOutputFormat(undefined), // auto-detect until --output overrides\n169:   };\n170: \n171:   // If the first arg is \"features\", treat the second positional as the subcommand\n172:   let startIdx = 1;\n173:   if (result.command === \"features\") {\n174:     result.subcommand = args[1] || \"list\";\n175:     startIdx = 2;\n176:   }\n177: \n178:   for (let i = startIdx; i < args.length; i++) {\n179:     const arg = args[i];\n180:     switch (arg) {\n181:       // --- Selection options ---\n182:       case \"--top-priority\":\n183:         result.topPriority = parseInt(args[++i], 10);\n184:         break;\n185:       case \"--quickest-wins\":\n186:         result.quickestWins = parseInt(args[++i], 10);\n187:         break;\n188:       case \"--priority\":\n189:         result.priority = args[++i] as Priority;\n190:         break;\n191:       case \"--difficulty\":\n192:         result.difficulty = args[++i] as Difficulty;\n193:         break;\n194:       case \"--features\":\n195:         result.features = args[++i].split(\",\").map((s) => s.trim());\n196:         break;\n197:       case \"--all-ready\":\n198:         result.allReady = true;\n199:         break;\n200: \n201:       // --- Launch / runtime options ---\n202:       case \"--max-concurrent\":\n203:         result.maxConcurrent = parseInt(args[++i], 10);\n204:         break;\n205:       case \"--model\":\n206:       case \"-m\":\n207:         result.model = args[++i];\n208:         break;\n209:       case \"--interactive\":\n210:         result.interactive = true;\n211:         break;\n212:       case \"--dry-run\":\n213:         result.dryRun = true;\n214:         break;\n215:       case \"--no-tui\":\n216:         result.noTui = true;\n217:         break;\n218:       case \"--auto-push\":\n219:         result.autoPush = true;\n220:         break;\n221:       case \"--requeue\":\n222:         result.requeue = true;\n223:         break;\n224:       case \"--base-branch\":\n225:         result.baseBranch = args[++i];\n226:         break;\n227:       case \"--max-retries\":\n228:         result.maxRetries = parseInt(args[++i], 10);\n229:         break;\n230: \n231:       // --- General flags ---\n232:       case \"--force\":\n233:         result.force = true;\n234:         break;\n235:       case \"--check\":\n236:         result.checkOnly = true;\n237:         break;\n238:       case \"--version\":\n239:         result.version = args[++i];\n240:         break;\n241:       case \"--output\":\n242:       case \"-o\":\n243:         result.outputFmt = resolveOutputFormat(args[++i]);\n244:         break;\n245: \n246:       // --- Features subcommand options ---\n247:       case \"--status\":\n248:         result.status = args[++i];\n249:         break;\n250:       case \"--ready\":\n251:         result.ready = true;\n252:         break;\n253:       case \"--include-archive\":\n254:         result.includeArchive = true;\n255:         break;\n256:       case \"--title\":\n257:         result.title = args[++i];\n258:         break;\n259:       case \"--description\":\n260:       case \"--desc\":\n261:         result.description = args[++i];\n262:         break;\n263:       case \"--effort\":\n264:         result.effort = args[++i];\n265:         break;\n266:       case \"--depends-on\":\n267:         result.dependsOn = args[++i].split(\",\").map((s) => s.trim());\n268:         break;\n269:       case \"--fields\":\n270:         result.fields = args[++i].split(\",\").map((s) => s.trim());\n271:         break;\n272: \n273:       // --- Graph options ---\n274:       case \"--ascii\":\n275:         result.ascii = true;\n276:         break;\n277:       case \"--mermaid\":\n278:         result.mermaidRaw = true;\n279:         break;\n280:       case \"--subtasks\":\n281:         result.graphSubtasks = true;\n282:         break;\n283: \n284:       // --- Logs options ---\n285:       case \"--tail\":\n286:         result.tail = parseInt(args[++i], 10);\n287:         break;\n288:       case \"--follow\":\n289:       case \"-f\":\n290:         result.follow = true;\n291:         break;\n292: \n293:       // --- Positional (feature-id, title for add, etc.) ---\n294:       default:\n295:         if (!arg.startsWith(\"-\")) {\n296:           if (!result.featureId) {\n297:             result.featureId = arg;\n298:           } else if (!result.title) {\n299:             result.title = arg;\n300:           }\n301:         }\n302:         break;\n303:     }\n304:   }\n305: \n306:   return result;\n307: }\n308: \n309: // ---------------------------------------------------------------------------\n310: // Help\n311: // ---------------------------------------------------------------------------\n312: \n313: function cmdHelp(): void {\n314:   console.log(`\n315: Wombo — AI Agent Orchestration System\n316: \n317:   WOMBO COMBO! Parallel feature development with AI agents.\n318: \n319: Commands:\n320:   init           Generate wombo.json config in the current project\n321:   launch         Launch a wave of agents to implement features\n322:   resume         Resume a previously stopped wave\n323:   status         Show the status of the current wave\n324:   verify         Run build verification on completed agents\n325:   merge          Merge verified branches into the base branch\n326:   retry          Retry a failed agent\n327:   abort          Kill a single running agent (--requeue to return to queue)\n328:   logs           Pretty-print agent logs for a feature\n329:   cleanup        Remove all wave worktrees and tmux sessions\n330:   features       Manage .features.yml (see below)\n331:   upgrade        Check for updates and upgrade wombo\n332:   describe       Emit JSON schema of a command (for AI agents)\n333:   help           Show this help\n334: \n335: Features Subcommands:\n336:   features list            List features (--status, --priority, --difficulty, --ready, --include-archive)\n337:   features add <id> <title> [options]\n338:                            Add a new feature (--desc, --priority, --difficulty, --effort, --depends-on)\n339:   features set-status <id> <status>\n340:                            Change a feature's status\n341:   features check           Validate .features.yml (schema, deps, duplicates, cycles)\n342:   features archive [id]    Move done/cancelled to archive (--dry-run)\n343:   features show <id>       Show feature details\n344:   features graph           Visualize dependency graph (--ascii, --mermaid, --subtasks)\n345: \n346: Selection Options (for launch):\n347:   --top-priority N         Select top N features by priority\n348:   --quickest-wins N        Select N features with lowest effort\n349:   --priority <level>       Filter by priority (critical/high/medium/low/wishlist)\n350:   --difficulty <level>     Filter by difficulty (trivial/easy/medium/hard/very_hard)\n351:   --features \"id1,id2\"     Select specific features by ID\n352:   --all-ready              Select all features whose dependencies are met\n353: \n354: Launch Options:\n355:   --max-concurrent N       Max agents running in parallel (default: from config)\n356:   --model <model>          Model to use (e.g., \"anthropic/claude-sonnet-4-20250514\")\n357:   --interactive            Use tmux TUI mode instead of headless\n358:   --no-tui                 Headless mode without neo-blessed TUI (periodic console dashboard)\n359:   --auto-push              Push base branch to remote after all merges complete\n360:   --dry-run                Show what would be launched without launching\n361:   --base-branch <branch>   Base branch (default: from config)\n362:   --max-retries N          Max retries per agent (default: from config)\n363: \n364: General:\n365:   --version, -V            Print version and exit\n366:   --force                  Force overwrite (e.g., for init) / skip prompts (e.g., for upgrade)\n367:   --output <fmt>           Output format: text (default on TTY) or json (default when piped)\n368:   -o <fmt>                 Alias for --output\n369:   --dry-run                Show what would happen without performing the action\n370:   --fields <list>          Comma-separated fields to include (e.g., id,status,priority)\n371: \n372: Upgrade Options:\n373:   --check                  Only check for updates, don't install\n374:   --version <tag>          Install a specific version (e.g., v0.1.0)\n375: \n376: Logs Options:\n377:   --tail N                 Show only the last N lines\n378:   --follow, -f             Stream new output as it arrives (like tail -f)\n379: \n380: Examples:\n381:   wombo init\n382:   wombo launch --quickest-wins 3\n383:   wombo launch --priority high --interactive\n384:   wombo launch --features \"auth-flow,search-api\" --max-concurrent 2\n385:   wombo resume\n386:   wombo status\n387:   wombo verify\n388:   wombo merge\n389:   wombo retry auth-flow\n390:   wombo abort auth-flow\n391:   wombo abort auth-flow --requeue\n392:   wombo abort auth-flow --output json\n393:   wombo logs auth-flow\n394:   wombo logs auth-flow --tail 50\n395:   wombo logs auth-flow --follow\n396:   wombo logs auth-flow --output json\n397:   wombo cleanup\n398:   wombo features list --status ready --priority high\n399:   wombo features list --fields id,status,priority --output json\n400:   wombo features add my-feature \"My Cool Feature\" --priority high --difficulty easy\n401:   wombo features set-status my-feature in-progress\n402:   wombo features check\n403:   wombo features archive --dry-run\n404:   wombo features show my-feature\n405:   wombo describe                           # list all commands as JSON\n406:   wombo describe launch                    # describe a specific command\n407:   wombo describe features add              # describe a subcommand\n408: `);\n409: }\n410: \n411: // ---------------------------------------------------------------------------\n412: // Main\n413: // ---------------------------------------------------------------------------\n414: \n415: async function main(): Promise<void> {\n416:   checkDevModeGuard();\n417: \n418:   const PROJECT_ROOT = resolve(process.cwd());\n419:   const args = parseArgs(process.argv);\n420: \n421:   // -----------------------------------------------------------------------\n422:   // Input validation at the CLI boundary\n423:   // -----------------------------------------------------------------------\n424:   if (args.featureId) {\n425:     assertValid(validateId(args.featureId, \"feature ID\"));\n426:   }\n427:   if (args.title) {\n428:     assertValid(validateText(args.title, \"title\"));\n429:   }\n430:   if (args.description) {\n431:     assertValid(validateText(args.description, \"description\"));\n432:   }\n433:   if (args.baseBranch) {\n434:     assertValid(validateBranchName(args.baseBranch, \"base branch\"));\n435:   }\n436:   if (args.effort) {\n437:     assertValid(validateDuration(args.effort, \"effort\"));\n438:   }\n439:   if (args.features) {\n440:     for (const fid of args.features) {\n441:       assertValid(validateId(fid, \"feature ID in --features\"));\n442:     }\n443:   }\n444:   if (args.dependsOn) {\n445:     for (const dep of args.dependsOn) {\n446:       assertValid(validateId(dep, \"dependency ID in --depends-on\"));\n447:     }\n448:   }\n449: \n450:   // Commands that don't need config loading\n451:   if (args.command === \"--version\" || args.command === \"-V\") {\n452:     const pkgPath = resolve(import.meta.dir, \"..\", \"package.json\");\n453:     const pkgFile = Bun.file(pkgPath);\n454:     try {\n455:       const pkg = await pkgFile.json();\n456:       console.log(`wombo ${pkg.version ?? \"(unknown version)\"}`);\n457:     } catch {\n458:       console.log(\"wombo (unknown version)\");\n459:     }\n460:     return;\n461:   }\n462: \n463:   if (args.command === \"help\" || args.command === \"--help\" || args.command === \"-h\") {\n464:     cmdHelp();\n465:     return;\n466:   }\n467: \n468:   if (args.command === \"describe\") {\n469:     // Schema introspection: `wombo describe [command]`\n470:     if (!args.featureId) {\n471:       // No command specified — list all commands\n472:       console.log(JSON.stringify(allCommandSchemas(), null, 2));\n473:     } else {\n474:       // Describe a specific command. Handle compound names: \"features list\"\n475:       const cmdName = args.title\n476:         ? `${args.featureId} ${args.title}`\n477:         : args.featureId;\n478:       const def = findCommandDef(cmdName);\n479:       if (!def) {\n480:         console.error(`Unknown command: \"${cmdName}\"`);\n481:         console.error(\"Run 'wombo describe' to list all commands.\");\n482:         process.exit(1);\n483:         return;\n484:       }\n485:       console.log(JSON.stringify(commandToSchema(def), null, 2));\n486:     }\n487:     return;\n488:   }\n489: \n490:   if (args.command === \"init\") {\n491:     await cmdInit({ projectRoot: PROJECT_ROOT, force: args.force });\n492:     return;\n493:   }\n494: \n495:   if (args.command === \"upgrade\") {\n496:     await cmdUpgrade({\n497:       force: args.force,\n498:       version: args.version,\n499:       checkOnly: args.checkOnly,\n500:     });\n501:     return;\n502:   }\n503: \n504:   if (args.command === \"logs\") {\n505:     if (!args.featureId) {\n506:       console.error(\"Usage: wombo logs <feature-id> [--tail N] [--follow] [--output json]\");\n507:       process.exit(1);\n508:       return;\n509:     }\n510:     await cmdLogs({\n511:       projectRoot: PROJECT_ROOT,\n512:       featureId: args.featureId,\n513:       tail: args.tail,\n514:       follow: args.follow,\n515:       outputFmt: args.outputFmt,\n516:     });\n517:     return;\n518:   }\n519: \n520:   // Everything else requires config\n521:   const config = loadConfig(PROJECT_ROOT);\n522:   validateConfig(config);\n523: \n524:   // Commands that operate on the features file — ensure it exists first\n525:   const needsFeatures = new Set([\"launch\", \"resume\", \"verify\", \"retry\", \"features\"]);\n526:   if (needsFeatures.has(args.command)) {\n527:     await ensureFeaturesFile(PROJECT_ROOT, config);\n528:   }\n529: \n530:   switch (args.command) {\n531:     case \"launch\":\n532:       await cmdLaunch({\n533:         projectRoot: PROJECT_ROOT,\n534:         config,\n535:         topPriority: args.topPriority,\n536:         quickestWins: args.quickestWins,\n537:         priority: args.priority,\n538:         difficulty: args.difficulty,\n539:         features: args.features,\n540:         allReady: args.allReady,\n541:         maxConcurrent: args.maxConcurrent ?? config.defaults.maxConcurrent,\n542:         model: args.model,\n543:         interactive: args.interactive,\n544:         dryRun: args.dryRun,\n545:         baseBranch: args.baseBranch ?? config.baseBranch,\n546:         maxRetries: args.maxRetries ?? config.defaults.maxRetries,\n547:         noTui: args.noTui,\n548:         autoPush: args.autoPush,\n549:         outputFmt: args.outputFmt,\n550:       });\n551:       break;\n552: \n553:     case \"resume\":\n554:       await cmdResume({\n555:         projectRoot: PROJECT_ROOT,\n556:         config,\n557:         maxConcurrent: args.maxConcurrent,\n558:         model: args.model,\n559:         interactive: args.interactive,\n560:         noTui: args.noTui,\n561:         autoPush: args.autoPush,\n562:         baseBranch: args.baseBranch,\n563:         maxRetries: args.maxRetries,\n564:       });\n565:       break;\n566: \n567:     case \"status\":\n568:       await cmdStatus({ projectRoot: PROJECT_ROOT, config });\n569:       break;\n570: \n571:     case \"verify\":\n572:       await cmdVerify({\n573:         projectRoot: PROJECT_ROOT,\n574:         config,\n575:         featureId: args.featureId,\n576:         model: args.model,\n577:         maxRetries: args.maxRetries,\n578:       });\n579:       break;\n580: \n581:     case \"merge\":\n582:       await cmdMerge({\n583:         projectRoot: PROJECT_ROOT,\n584:         config,\n585:         featureId: args.featureId,\n586:         autoPush: args.autoPush,\n587:         dryRun: args.dryRun,\n588:       });\n589:       break;\n590: \n591:     case \"retry\": {\n592:       if (!args.featureId) {\n593:         console.error(\"Usage: wombo retry <feature-id>\");\n594:         process.exit(1);\n595:         return;\n596:       }\n597:       await cmdRetry({\n598:         projectRoot: PROJECT_ROOT,\n599:         config,\n600:         featureId: args.featureId,\n601:         model: args.model,\n602:         interactive: args.interactive,\n603:         dryRun: args.dryRun,\n604:       });\n605:       break;\n606:     }\n607: \n608:     case \"cleanup\":\n609:       await cmdCleanup({ projectRoot: PROJECT_ROOT, config, dryRun: args.dryRun });\n610:       break;\n611: \n612:     case \"abort\": {\n613:       if (!args.featureId) {\n614:         console.error(\"Usage: wombo abort <feature-id> [--requeue] [--output json]\");\n615:         process.exit(1);\n616:         return;\n617:       }\n618:       await cmdAbort({\n619:         projectRoot: PROJECT_ROOT,\n620:         config,\n621:         featureId: args.featureId,\n622:         requeue: args.requeue,\n623:         outputFmt: args.outputFmt,\n624:       });\n625:       break;\n626:     }\n627: \n628:     case \"features\":\n629:       await handleFeaturesSubcommand(args, PROJECT_ROOT, config);\n630:       break;\n631: \n632:     default:\n633:       console.error(`Unknown command: ${args.command}`);\n634:       cmdHelp();\n635:       process.exit(1);\n636:       return;\n637:   }\n638: }\n639: \n640: // ---------------------------------------------------------------------------\n641: // Features Subcommand Router\n642: // ---------------------------------------------------------------------------\n643: \n644: async function handleFeaturesSubcommand(\n645:   args: CLIArgs,\n646:   projectRoot: string,\n647:   config: import(\"./config.js\").WomboConfig\n648: ): Promise<void> {\n649:   switch (args.subcommand) {\n650:     case \"list\":\n651:     case \"ls\":\n652:       await cmdFeaturesList({\n653:         projectRoot,\n654:         config,\n655:         status: args.status as FeatureStatus | undefined,\n656:         priority: args.priority,\n657:         difficulty: args.difficulty,\n658:         ready: args.ready,\n659:         includeArchive: args.includeArchive,\n660:         outputFmt: args.outputFmt,\n661:         fields: args.fields,\n662:       });\n663:       break;\n664: \n665:     case \"add\": {\n666:       if (!args.featureId || !args.title) {\n667:         console.error(\"Usage: wombo features add <id> <title> [--desc <desc>] [--priority <p>] [--difficulty <d>] [--effort <e>] [--depends-on <ids>]\");\n668:         process.exit(1);\n669:         return;\n670:       }\n671:       await cmdFeaturesAdd({\n672:         projectRoot,\n673:         config,\n674:         id: args.featureId,\n675:         title: args.title,\n676:         description: args.description,\n677:         priority: args.priority,\n678:         difficulty: args.difficulty,\n679:         effort: args.effort,\n680:         dependsOn: args.dependsOn,\n681:         outputFmt: args.outputFmt,\n682:         dryRun: args.dryRun,\n683:       });\n684:       break;\n685:     }\n686: \n687:     case \"set-status\": {\n688:       if (!args.featureId || !args.title) {\n689:         // title holds the second positional arg (the status value)\n690:         // If not provided via positional, check --status flag\n691:         const newStatus = args.title || args.status;\n692:         if (!args.featureId || !newStatus) {\n693:           console.error(\"Usage: wombo features set-status <feature-id> <status>\");\n694:           process.exit(1);\n695:           return;\n696:         }\n697:         await cmdFeaturesSetStatus({\n698:           projectRoot,\n699:           config,\n700:           featureId: args.featureId,\n701:           newStatus,\n702:           outputFmt: args.outputFmt,\n703:           dryRun: args.dryRun,\n704:         });\n705:       } else {\n706:         await cmdFeaturesSetStatus({\n707:           projectRoot,\n708:           config,\n709:           featureId: args.featureId,\n710:           newStatus: args.title, // second positional = new status\n711:           outputFmt: args.outputFmt,\n712:           dryRun: args.dryRun,\n713:         });\n714:       }\n715:       break;\n716:     }\n717: \n718:     case \"check\":\n719:     case \"validate\":\n720:       await cmdFeaturesCheck({ projectRoot, config });\n721:       break;\n722: \n723:     case \"archive\":\n724:       await cmdFeaturesArchive({\n725:         projectRoot,\n726:         config,\n727:         featureId: args.featureId,\n728:         dryRun: args.dryRun,\n729:       });\n730:       break;\n731: \n732:     case \"show\": {\n733:       if (!args.featureId) {\n734:         console.error(\"Usage: wombo features show <feature-id>\");\n735:         process.exit(1);\n736:         return;\n737:       }\n738:       await cmdFeaturesShow({\n739:         projectRoot,\n740:         config,\n741:         featureId: args.featureId,\n742:         outputFmt: args.outputFmt,\n743:         fields: args.fields,\n744:       });\n745:       break;\n746:     }\n747: \n748:     case \"graph\":\n749:       await cmdFeaturesGraph({\n750:         projectRoot,\n751:         config,\n752:         status: args.status as FeatureStatus | undefined,\n753:         ascii: args.ascii,\n754:         mermaid: args.mermaidRaw,\n755:         subtasks: args.graphSubtasks,\n756:         outputFmt: args.outputFmt,\n757:       });\n758:       break;\n759: \n760:     case \"help\":\n761:     case \"--help\":\n762:     case \"-h\":\n763:       cmdHelp();\n764:       break;\n765: \n766:     default:\n767:       console.error(`Unknown features subcommand: ${args.subcommand}`);\n768:       console.error(\"Run 'wombo features help' or 'wombo help' for usage.\");\n769:       process.exit(1);\n770:       return;\n771:   }\n772: }\n773: \n774: // ---------------------------------------------------------------------------\n775: // Error Handlers & Entry\n776: // ---------------------------------------------------------------------------\n777: \n778: // Global error handlers — prevent silent crashes\n779: process.on(\"uncaughtException\", (err) => {\n780:   console.error(`\\n[FATAL] Uncaught exception: ${err.message}`);\n781:   console.error(err.stack);\n782:   try {\n783:     const state = loadState(process.cwd());\n784:     if (state) saveState(process.cwd(), state);\n785:   } catch {}\n786:   process.exit(1);\n787: });\n788: \n789: process.on(\"unhandledRejection\", (reason: any) => {\n790:   console.error(`\\n[FATAL] Unhandled rejection: ${reason?.message || reason}`);\n791:   if (reason?.stack) console.error(reason.stack);\n792:   try {\n793:     const state = loadState(process.cwd());\n794:     if (state) saveState(process.cwd(), state);\n795:   } catch {}\n796:   process.exit(1);\n797: });\n798: \n799: main().catch((err) => {\n800:   console.error(\"Fatal error:\", err.message);\n801:   process.exit(1);\n802: });\n\n(End of file - total 802 lines)\n</content>","title":"src/index.ts","metadata":{"preview":"#!/usr/bin/env bun\n/**\n * index.ts — CLI entry point for the Wombo agent orchestration system.\n *\n * Usage:\n *   wombo init\n *   wombo launch --top-priority 3\n *   wombo launch --quickest-wins 5\n *   wombo launch --priority high\n *   wombo launch --difficulty easy\n *   wombo launch --features \"feat-a,feat-b\"\n *   wombo launch --all-ready\n *   wombo launch ... --max-concurrent 3 --model \"anthropic/claude-sonnet-4-20250514\"\n *   wombo launch ... --interactive\n *   wombo resume\n *   wombo status\n *   wombo verify [feature-id]\n *   wombo merge [feature-id]\n *   wombo retry <feature-id>\n *   wombo abort <feature-id> [--requeue] [--output json]","truncated":false,"loaded":[]},"time":{"start":1773352362841,"end":1773352362843}}}}
