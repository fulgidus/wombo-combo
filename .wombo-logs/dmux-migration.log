{"type":"tool_use","timestamp":1773351949131,"sessionID":"ses_31bfd06f5ffeleRCi6uuMulALr","part":{"id":"prt_ce40348e2001OKoF0Dk6S1Pd04","sessionID":"ses_31bfd06f5ffeleRCi6uuMulALr","messageID":"msg_ce4033e11001UisMXbYxUk3Oip","type":"tool","callID":"toolu_vrtx_01NUFKyDchfGKx4YjfrRFPsu","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-dmux-migration/src/lib/tui.ts"},"output":"<path>/home/fulgidus/Documents/wombo-dmux-migration/src/lib/tui.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tui.ts — Blessed-based TUI dashboard for Wombo.\n3:  *\n4:  * Layout:\n5:  *   ┌─────────────────────────────────────────────┐\n6:  *   │ Header: Wave ID, base branch, mode, model   │\n7:  *   ├──────────────────────────┬──────────────────┤\n8:  *   │ Agent Table              │ Preview Pane     │\n9:  *   │ (selectable rows with    │ (parsed activity │\n10:  *   │  status, activity,       │  stream for the  │\n11:  *   │  progress bars, elapsed) │  selected agent) │\n12:  *   ├──────────────────────────┴──────────────────┤\n13:  *   │ Status bar: keybinds + summary counts       │\n14:  *   └─────────────────────────────────────────────┘\n15:  *\n16:  * Keybinds:\n17:  *   Up/Down   — navigate agent list\n18:  *   Enter     — tmux attach to selected agent (interactive mode)\n19:  *   b         — show build log for selected agent\n20:  *   p         — toggle auto-scroll (pause/resume)\n21:  *   q / C-c   — quit\n22:  */\n23: \n24: import blessed from \"neo-blessed\";\n25: import type { Widgets } from \"neo-blessed\";\n26: import type { WaveState, AgentState, AgentStatus } from \"./state.js\";\n27: import { agentCounts } from \"./state.js\";\n28: import type { ProcessMonitor, ActivityEntry } from \"./monitor.js\";\n29: import { execSync } from \"node:child_process\";\n30: import { readFileSync } from \"node:fs\";\n31: import { resolve } from \"node:path\";\n32: import type { WomboConfig } from \"../config.js\";\n33: \n34: // ---------------------------------------------------------------------------\n35: // Types\n36: // ---------------------------------------------------------------------------\n37: \n38: export interface TUIOptions {\n39:   state: WaveState;\n40:   monitor: ProcessMonitor;\n41:   onQuit: () => void;\n42:   /** Whether the wave is running in interactive (tmux) mode. */\n43:   interactive?: boolean;\n44:   /** Project root path (for locating log files). */\n45:   projectRoot: string;\n46:   /** Config (for tmux session prefix, log dir, etc.) */\n47:   config: WomboConfig;\n48: }\n49: \n50: // ---------------------------------------------------------------------------\n51: // Color Map\n52: // ---------------------------------------------------------------------------\n53: \n54: const STATUS_COLORS: Record<AgentStatus, string> = {\n55:   queued: \"gray\",\n56:   installing: \"cyan\",\n57:   running: \"blue\",\n58:   completed: \"yellow\",\n59:   verified: \"green\",\n60:   failed: \"red\",\n61:   merged: \"magenta\",\n62:   retry: \"yellow\",\n63:   resolving_conflict: \"cyan\",\n64: };\n65: \n66: const STATUS_ICONS: Record<AgentStatus, string> = {\n67:   queued: \"·\",\n68:   installing: \"⟳\",\n69:   running: \"●\",\n70:   completed: \"○\",\n71:   verified: \"✓\",\n72:   failed: \"✗\",\n73:   merged: \"◆\",\n74:   retry: \"↻\",\n75:   resolving_conflict: \"⚡\",\n76: };\n77: \n78: // ---------------------------------------------------------------------------\n79: // Helpers\n80: // ---------------------------------------------------------------------------\n81: \n82: /**\n83:  * Escape curly braces so blessed doesn't interpret them as formatting tags.\n84:  * Blessed uses {color-fg}...{/color-fg} syntax; unmatched or malformed braces\n85:  * in user-provided text (JSON, Python dicts, shell commands, etc.) crash the\n86:  * renderer. We replace { and } with the Unicode fullwidth equivalents which\n87:  * render visually similar but are not parsed by blessed.\n88:  */\n89: function escapeBlessedTags(text: string): string {\n90:   return text.replace(/\\{/g, \"｛\").replace(/\\}/g, \"｝\");\n91: }\n92: \n93: function elapsed(startedAt: string | null): string {\n94:   if (!startedAt) return \"-\";\n95:   const start = new Date(startedAt).getTime();\n96:   const diffMs = Date.now() - start;\n97:   const secs = Math.floor(diffMs / 1000);\n98:   if (secs < 60) return `${secs}s`;\n99:   const mins = Math.floor(secs / 60);\n100:   if (mins < 60) return `${mins}m`;\n101:   const hours = Math.floor(mins / 60);\n102:   return `${hours}h${mins % 60}m`;\n103: }\n104: \n105: function progressBar(\n106:   elapsedMs: number,\n107:   estimateMs: number,\n108:   width: number = 10\n109: ): string {\n110:   if (estimateMs <= 0) return \"░\".repeat(width);\n111:   const ratio = Math.min(elapsedMs / estimateMs, 1);\n112:   const filled = Math.round(ratio * width);\n113:   return \"█\".repeat(filled) + \"░\".repeat(width - filled);\n114: }\n115: \n116: // ---------------------------------------------------------------------------\n117: // TUI Dashboard Class\n118: // ---------------------------------------------------------------------------\n119: \n120: export class WomboTUI {\n121:   private screen: Widgets.Screen;\n122:   private headerBox: Widgets.BoxElement;\n123:   private agentList: Widgets.ListElement;\n124:   private previewBox: Widgets.Log;\n125:   private statusBar: Widgets.BoxElement;\n126:   private buildLogBox: Widgets.Log;\n127: \n128:   private state: WaveState;\n129:   private monitor: ProcessMonitor;\n130:   private onQuit: () => void;\n131:   private interactive: boolean;\n132:   private projectRoot: string;\n133:   private config: WomboConfig;\n134: \n135:   private selectedIndex: number = 0;\n136:   private autoScroll: boolean = true;\n137:   private showingBuildLog: boolean = false;\n138:   private showingLogFile: boolean = false;\n139:   private logFileBox: Widgets.Log | null = null;\n140:   private refreshTimer: ReturnType<typeof setInterval> | null = null;\n141: \n142:   /** Saved originals for console interception */\n143:   private origConsoleLog: typeof console.log = console.log;\n144:   private origConsoleError: typeof console.error = console.error;\n145:   private origConsoleWarn: typeof console.warn = console.warn;\n146:   /** System messages captured while TUI is active */\n147:   private systemMessages: ActivityEntry[] = [];\n148: \n149:   constructor(opts: TUIOptions) {\n150:     this.state = opts.state;\n151:     this.monitor = opts.monitor;\n152:     this.onQuit = opts.onQuit;\n153:     this.interactive = opts.interactive ?? false;\n154:     this.projectRoot = opts.projectRoot;\n155:     this.config = opts.config;\n156: \n157:     // Create screen\n158:     this.screen = blessed.screen({\n159:       smartCSR: true,\n160:       title: `Wombo — ${opts.state.wave_id}`,\n161:       fullUnicode: true,\n162:     });\n163: \n164:     // Header\n165:     this.headerBox = blessed.box({\n166:       top: 0,\n167:       left: 0,\n168:       width: \"100%\",\n169:       height: 3,\n170:       tags: true,\n171:       style: {\n172:         fg: \"white\",\n173:         bg: \"black\",\n174:       },\n175:     });\n176: \n177:     // Agent list (left pane)\n178:     this.agentList = blessed.list({\n179:       top: 3,\n180:       left: 0,\n181:       width: \"55%\",\n182:       height: \"100%-6\",\n183:       tags: true,\n184:       scrollable: true,\n185:       mouse: true,\n186:       keys: true,\n187:       vi: true,\n188:       border: {\n189:         type: \"line\",\n190:       },\n191:       style: {\n192:         border: { fg: \"gray\" },\n193:         selected: {\n194:           bg: \"blue\",\n195:           fg: \"white\",\n196:           bold: true,\n197:         },\n198:         item: {\n199:           fg: \"white\",\n200:         },\n201:       },\n202:       label: \" Agents \",\n203:     });\n204: \n205:     // Preview pane (right pane)\n206:     this.previewBox = blessed.log({\n207:       top: 3,\n208:       left: \"55%\",\n209:       width: \"45%\",\n210:       height: \"100%-6\",\n211:       tags: true,\n212:       scrollable: true,\n213:       mouse: true,\n214:       keys: false,\n215:       scrollbar: {\n216:         ch: \"│\",\n217:         style: { fg: \"cyan\" },\n218:       },\n219:       border: {\n220:         type: \"line\",\n221:       },\n222:       style: {\n223:         border: { fg: \"gray\" },\n224:         fg: \"white\",\n225:       },\n226:       label: \" Activity \",\n227:     });\n228: \n229:     // Build log overlay (hidden by default)\n230:     this.buildLogBox = blessed.log({\n231:       top: 3,\n232:       left: \"10%\",\n233:       width: \"80%\",\n234:       height: \"100%-6\",\n235:       tags: true,\n236:       scrollable: true,\n237:       mouse: true,\n238:       keys: true,\n239:       scrollbar: {\n240:         ch: \"│\",\n241:         style: { fg: \"yellow\" },\n242:       },\n243:       border: {\n244:         type: \"line\",\n245:       },\n246:       style: {\n247:         border: { fg: \"yellow\" },\n248:         fg: \"white\",\n249:       },\n250:       label: \" Build Log \",\n251:       hidden: true,\n252:     });\n253: \n254:     // Status bar\n255:     this.statusBar = blessed.box({\n256:       bottom: 0,\n257:       left: 0,\n258:       width: \"100%\",\n259:       height: 3,\n260:       tags: true,\n261:       style: {\n262:         fg: \"white\",\n263:         bg: \"black\",\n264:       },\n265:     });\n266: \n267:     // Assemble\n268:     this.screen.append(this.headerBox);\n269:     this.screen.append(this.agentList);\n270:     this.screen.append(this.previewBox);\n271:     this.screen.append(this.buildLogBox);\n272:     this.screen.append(this.statusBar);\n273: \n274:     // Focus the agent list\n275:     this.agentList.focus();\n276: \n277:     // Bind keys\n278:     this.bindKeys();\n279:   }\n280: \n281:   // -------------------------------------------------------------------------\n282:   // Key Bindings\n283:   // -------------------------------------------------------------------------\n284: \n285:   private bindKeys(): void {\n286:     // Quit\n287:     this.screen.key([\"q\", \"C-c\"], () => {\n288:       this.stop();\n289:       this.onQuit();\n290:     });\n291: \n292:     // Navigate agent list\n293:     this.agentList.on(\"select item\", (_item: any, index: number) => {\n294:       this.selectedIndex = index;\n295:       this.refreshPreview();\n296:     });\n297: \n298:     // Enter — tmux attach\n299:     this.screen.key([\"enter\"], () => {\n300:       this.tmuxAttach();\n301:     });\n302: \n303:     // b — toggle build log\n304:     this.screen.key([\"b\"], () => {\n305:       this.toggleBuildLog();\n306:     });\n307: \n308:     // p — toggle auto-scroll\n309:     this.screen.key([\"p\"], () => {\n310:       this.autoScroll = !this.autoScroll;\n311:       this.refreshStatusBar();\n312:     });\n313: \n314:     // Escape — close build log or log file overlay\n315:     this.screen.key([\"escape\"], () => {\n316:       if (this.showingBuildLog) {\n317:         this.showingBuildLog = false;\n318:         this.buildLogBox.hide();\n319:         this.agentList.focus();\n320:         this.screen.render();\n321:       } else if (this.showingLogFile && this.logFileBox) {\n322:         this.showingLogFile = false;\n323:         this.logFileBox.destroy();\n324:         this.logFileBox = null;\n325:         this.agentList.focus();\n326:         this.screen.render();\n327:       }\n328:     });\n329:   }\n330: \n331:   // -------------------------------------------------------------------------\n332:   // Start / Stop\n333:   // -------------------------------------------------------------------------\n334: \n335:   start(): void {\n336:     this.interceptConsole();\n337:     this.refresh();\n338:     this.screen.render();\n339: \n340:     // Auto-refresh every 2 seconds\n341:     this.refreshTimer = setInterval(() => {\n342:       this.refresh();\n343:     }, 2000);\n344:   }\n345: \n346:   stop(): void {\n347:     this.restoreConsole();\n348:     if (this.refreshTimer) {\n349:       clearInterval(this.refreshTimer);\n350:       this.refreshTimer = null;\n351:     }\n352:     this.screen.destroy();\n353:   }\n354: \n355:   /**\n356:    * Intercept console.log/error/warn so they don't corrupt the TUI.\n357:    * Messages are captured into systemMessages and shown in the preview\n358:    * when no specific agent is producing activity.\n359:    */\n360:   private interceptConsole(): void {\n361:     this.origConsoleLog = console.log;\n362:     this.origConsoleError = console.error;\n363:     this.origConsoleWarn = console.warn;\n364: \n365:     const capture = (...args: any[]) => {\n366:       const text = args\n367:         .map((a) => (typeof a === \"string\" ? a : JSON.stringify(a)))\n368:         .join(\" \");\n369:       // Strip ANSI codes for clean TUI display\n370:       const clean = text.replace(/\\x1b\\[[0-9;]*m/g, \"\");\n371:       if (!clean.trim()) return;\n372:       this.systemMessages.push({\n373:         timestamp: new Date().toISOString().slice(11, 19),\n374:         text: clean,\n375:       });\n376:       // Keep bounded\n377:       if (this.systemMessages.length > 200) {\n378:         this.systemMessages.splice(0, this.systemMessages.length - 200);\n379:       }\n380:     };\n381: \n382:     console.log = capture;\n383:     console.error = capture;\n384:     console.warn = capture;\n385:   }\n386: \n387:   /**\n388:    * Restore original console methods.\n389:    */\n390:   private restoreConsole(): void {\n391:     console.log = this.origConsoleLog;\n392:     console.error = this.origConsoleError;\n393:     console.warn = this.origConsoleWarn;\n394:   }\n395: \n396:   /**\n397:    * Update the state reference (called from the monitoring loop).\n398:    */\n399:   updateState(state: WaveState): void {\n400:     this.state = state;\n401:   }\n402: \n403:   // -------------------------------------------------------------------------\n404:   // Refresh Logic\n405:   // -------------------------------------------------------------------------\n406: \n407:   private refresh(): void {\n408:     this.refreshHeader();\n409:     this.refreshAgentList();\n410:     this.refreshPreview();\n411:     this.refreshStatusBar();\n412:     this.screen.render();\n413:   }\n414: \n415:   private refreshHeader(): void {\n416:     const s = this.state;\n417:     const counts = agentCounts(s);\n418:     const total = s.agents.length;\n419:     const done = counts.verified + counts.merged;\n420: \n421:     let line1 = ` {bold}Wombo{/bold} {gray-fg}${s.wave_id}{/gray-fg}`;\n422:     line1 += `  {gray-fg}│{/gray-fg}  Base: {cyan-fg}${s.base_branch}{/cyan-fg}`;\n423:     line1 += `  {gray-fg}│{/gray-fg}  Mode: ${s.interactive ? \"{green-fg}interactive{/green-fg}\" : \"{blue-fg}headless{/blue-fg}\"}`;\n424:     if (s.model) {\n425:       line1 += `  {gray-fg}│{/gray-fg}  Model: {yellow-fg}${s.model}{/yellow-fg}`;\n426:     }\n427: \n428:     let line2 = ` Progress: {green-fg}${done}{/green-fg}/{white-fg}${total}{/white-fg}`;\n429:     if (counts.running > 0)\n430:       line2 += `  {blue-fg}${counts.running} running{/blue-fg}`;\n431:     if (counts.failed > 0)\n432:       line2 += `  {red-fg}${counts.failed} failed{/red-fg}`;\n433:     if (counts.queued > 0)\n434:       line2 += `  {gray-fg}${counts.queued} queued{/gray-fg}`;\n435:     if (counts.retry > 0)\n436:       line2 += `  {yellow-fg}${counts.retry} retrying{/yellow-fg}`;\n437:     if (counts.resolving_conflict > 0)\n438:       line2 += `  {cyan-fg}${counts.resolving_conflict} resolving{/cyan-fg}`;\n439: \n440:     this.headerBox.setContent(`${line1}\\n${line2}`);\n441:   }\n442: \n443:   private refreshAgentList(): void {\n444:     const items: string[] = [];\n445: \n446:     for (let i = 0; i < this.state.agents.length; i++) {\n447:       const a = this.state.agents[i];\n448:       const color = STATUS_COLORS[a.status];\n449:       const icon = STATUS_ICONS[a.status];\n450: \n451:       // Feature ID (padded)\n452:       const fid =\n453:         a.feature_id.length > 24\n454:           ? a.feature_id.slice(0, 23) + \"…\"\n455:           : a.feature_id.padEnd(24);\n456: \n457:       // Status\n458:       const st = `{${color}-fg}${icon} ${a.status.padEnd(10)}{/${color}-fg}`;\n459: \n460:       // Progress bar\n461:       let pbar = \"\";\n462:       if ((a.status === \"running\" || a.status === \"resolving_conflict\") && a.started_at) {\n463:         const elapsedMs = Date.now() - new Date(a.started_at).getTime();\n464:         // Use actual effort estimate from feature data, fallback to 1h\n465:         const estimateMs = a.effort_estimate_ms ?? 60 * 60 * 1000;\n466:         pbar = ` {cyan-fg}${progressBar(elapsedMs, estimateMs, 8)}{/cyan-fg}`;\n467:       } else if (a.status === \"verified\" || a.status === \"merged\") {\n468:         pbar = ` {green-fg}${\"█\".repeat(8)}{/green-fg}`;\n469:       } else if (a.status === \"failed\") {\n470:         pbar = ` {red-fg}${\"█\".repeat(8)}{/red-fg}`;\n471:       }\n472: \n473:       // Activity (for running/resolving agents)\n474:       let act = \"\";\n475:       if ((a.status === \"running\" || a.status === \"resolving_conflict\") && a.activity) {\n476:         const rawAct =\n477:           a.activity.length > 25 ? a.activity.slice(0, 24) + \"…\" : a.activity;\n478:         const actText = escapeBlessedTags(rawAct);\n479:         act = ` {cyan-fg}${actText}{/cyan-fg}`;\n480:       } else if (a.status === \"installing\") {\n481:         act = \" {cyan-fg}setting up…{/cyan-fg}\";\n482:       }\n483: \n484:       // Elapsed\n485:       const el = elapsed(a.started_at);\n486: \n487:       // Retries\n488:       const retries =\n489:         a.retries > 0 ? ` {yellow-fg}↻${a.retries}{/yellow-fg}` : \"\";\n490: \n491:       items.push(\n492:         ` ${fid} ${st}${pbar}${act}${retries} {gray-fg}${el}{/gray-fg}`\n493:       );\n494:     }\n495: \n496:     // Preserve selection\n497:     const prevSelected = this.selectedIndex;\n498:     this.agentList.setItems(items as any);\n499:     if (prevSelected < items.length) {\n500:       this.agentList.select(prevSelected);\n501:     }\n502:   }\n503: \n504:   private refreshPreview(): void {\n505:     const agent = this.state.agents[this.selectedIndex];\n506:     if (!agent) {\n507:       this.previewBox.setContent(\"{gray-fg}No agent selected{/gray-fg}\");\n508:       return;\n509:     }\n510: \n511:     // Update label\n512:     this.previewBox.setLabel(` ${agent.feature_id} — Activity `);\n513: \n514:     // Get activity log from monitor\n515:     const log = this.monitor.getActivityLog(agent.feature_id);\n516: \n517:     // Also include system messages (build verification, etc.)\n518:     // that mention this agent's feature_id\n519:     const relevantSys = this.systemMessages.filter((m) =>\n520:       m.text.includes(agent.feature_id)\n521:     );\n522: \n523:     if (log.length === 0 && relevantSys.length === 0) {\n524:       this.previewBox.setContent(\n525:         \"{gray-fg}No activity yet. Waiting for agent output…{/gray-fg}\"\n526:       );\n527:       return;\n528:     }\n529: \n530:     // Format log entries\n531:     const lines: string[] = [];\n532:     for (const entry of log) {\n533:       lines.push(this.formatActivityLine(entry));\n534:     }\n535: \n536:     // Append relevant system messages\n537:     if (relevantSys.length > 0) {\n538:       lines.push(\"\");\n539:       lines.push(\"{yellow-fg}-- system --{/yellow-fg}\");\n540:       for (const entry of relevantSys) {\n541:         const ts = `{gray-fg}${entry.timestamp}{/gray-fg}`;\n542:         lines.push(`${ts} {yellow-fg}${escapeBlessedTags(entry.text)}{/yellow-fg}`);\n543:       }\n544:     }\n545: \n546:     this.previewBox.setContent(lines.join(\"\\n\"));\n547: \n548:     // Auto-scroll to bottom\n549:     if (this.autoScroll) {\n550:       this.previewBox.setScrollPerc(100);\n551:     }\n552:   }\n553: \n554:   private formatActivityLine(entry: ActivityEntry): string {\n555:     const ts = `{gray-fg}${entry.timestamp}{/gray-fg}`;\n556:     let text = escapeBlessedTags(entry.text);\n557: \n558:     // Color-code different line types\n559:     if (text.startsWith(\">>\")) {\n560:       text = `{cyan-fg}${text}{/cyan-fg}`;\n561:     } else if (text.startsWith(\"!!\")) {\n562:       text = `{red-fg}${text}{/red-fg}`;\n563:     } else if (text.startsWith(\"--\")) {\n564:       text = `{green-fg}${text}{/green-fg}`;\n565:     } else if (text.startsWith(\"[stderr]\")) {\n566:       text = `{red-fg}${text}{/red-fg}`;\n567:     } else if (text.startsWith(\"[raw]\")) {\n568:       text = `{gray-fg}${text}{/gray-fg}`;\n569:     } else if (text.startsWith(\"   \")) {\n570:       text = `{white-fg}${text}{/white-fg}`;\n571:     }\n572: \n573:     return `${ts} ${text}`;\n574:   }\n575: \n576:   private refreshStatusBar(): void {\n577:     const scrollStatus = this.autoScroll\n578:       ? \"{green-fg}auto-scroll{/green-fg}\"\n579:       : \"{yellow-fg}paused{/yellow-fg}\";\n580: \n581:     const agent = this.state.agents[this.selectedIndex];\n582:     const agentInfo = agent\n583:       ? `{gray-fg}Selected: {white-fg}${agent.feature_id}{/white-fg}{/gray-fg}`\n584:       : \"\";\n585: \n586:     const enterHint = this.interactive\n587:       ? \"{gray-fg}Enter{/gray-fg} tmux attach\"\n588:       : \"{gray-fg}Enter{/gray-fg} view log\";\n589: \n590:     const line1 = ` {bold}Keys:{/bold} {gray-fg}↑↓{/gray-fg} navigate  ${enterHint}  {gray-fg}b{/gray-fg} build log  {gray-fg}p{/gray-fg} ${scrollStatus}  {gray-fg}q{/gray-fg} quit`;\n591:     const line2 = ` ${agentInfo}`;\n592: \n593:     this.statusBar.setContent(`${line1}\\n${line2}`);\n594:   }\n595: \n596:   // -------------------------------------------------------------------------\n597:   // Actions\n598:   // -------------------------------------------------------------------------\n599: \n600:   private tmuxAttach(): void {\n601:     const agent = this.state.agents[this.selectedIndex];\n602:     if (!agent) return;\n603: \n604:     if (!this.interactive) {\n605:       // Headless mode — show the raw log file in an overlay\n606:       this.showLogFile(agent);\n607:       return;\n608:     }\n609: \n610:     const sessionName = `${this.config.agent.tmuxPrefix}-${agent.feature_id}`;\n611: \n612:     // Check if tmux session exists\n613:     try {\n614:       execSync(`tmux has-session -t \"${sessionName}\" 2>/dev/null`, {\n615:         stdio: \"pipe\",\n616:       });\n617:     } catch {\n618:       // No session — show message in preview\n619:       this.monitor.activityLogs.get(agent.feature_id)?.push({\n620:         timestamp: new Date().toISOString().slice(11, 19),\n621:         text: `!! No tmux session '${sessionName}' found`,\n622:       });\n623:       this.refreshPreview();\n624:       this.screen.render();\n625:       return;\n626:     }\n627: \n628:     // Detach from blessed, attach to tmux\n629:     this.restoreConsole();\n630:     this.screen.destroy();\n631:     try {\n632:       execSync(`tmux attach -t \"${sessionName}\"`, {\n633:         stdio: \"inherit\",\n634:       });\n635:     } catch {\n636:       // User detached from tmux — resume TUI\n637:     }\n638: \n639:     // Re-create screen after returning from tmux\n640:     this.recreateScreen();\n641:   }\n642: \n643:   /**\n644:    * Show the raw log file for an agent in an overlay (headless mode).\n645:    */\n646:   private showLogFile(agent: AgentState): void {\n647:     if (this.showingLogFile) {\n648:       // Toggle off\n649:       this.showingLogFile = false;\n650:       if (this.logFileBox) {\n651:         this.logFileBox.destroy();\n652:         this.logFileBox = null;\n653:       }\n654:       this.agentList.focus();\n655:       this.screen.render();\n656:       return;\n657:     }\n658: \n659:     const logPath = resolve(\n660:       this.projectRoot,\n661:       \".wombo-logs\",\n662:       `${agent.feature_id}.log`\n663:     );\n664:     let content: string;\n665:     try {\n666:       content = readFileSync(logPath, \"utf-8\");\n667:       if (!content.trim()) {\n668:         content =\n669:           \"{gray-fg}Log file is empty. Agent may not have started producing output yet.{/gray-fg}\";\n670:       }\n671:     } catch {\n672:       content = \"{gray-fg}No log file found at \" + logPath + \"{/gray-fg}\";\n673:     }\n674: \n675:     // Create overlay\n676:     this.logFileBox = blessed.log({\n677:       top: 3,\n678:       left: \"5%\",\n679:       width: \"90%\",\n680:       height: \"100%-6\",\n681:       tags: true,\n682:       scrollable: true,\n683:       mouse: true,\n684:       keys: true,\n685:       scrollbar: {\n686:         ch: \"│\",\n687:         style: { fg: \"cyan\" },\n688:       },\n689:       border: {\n690:         type: \"line\",\n691:       },\n692:       style: {\n693:         border: { fg: \"cyan\" },\n694:         fg: \"white\",\n695:       },\n696:       label: ` Log — ${agent.feature_id} (Esc to close) `,\n697:     });\n698: \n699:     this.screen.append(this.logFileBox);\n700: \n701:     // Truncate to last 200 lines to keep TUI responsive\n702:     const lines = content.split(\"\\n\");\n703:     const truncated =\n704:       lines.length > 200 ? lines.slice(-200).join(\"\\n\") : content;\n705:     this.logFileBox.setContent(escapeBlessedTags(truncated));\n706:     this.logFileBox.setScrollPerc(100);\n707:     this.logFileBox.focus();\n708:     this.showingLogFile = true;\n709:     this.screen.render();\n710:   }\n711: \n712:   private toggleBuildLog(): void {\n713:     const agent = this.state.agents[this.selectedIndex];\n714:     if (!agent) return;\n715: \n716:     if (this.showingBuildLog) {\n717:       this.showingBuildLog = false;\n718:       this.buildLogBox.hide();\n719:       this.agentList.focus();\n720:     } else {\n721:       this.showingBuildLog = true;\n722:       this.buildLogBox.setLabel(` Build Log — ${agent.feature_id} `);\n723: \n724:       if (agent.build_output) {\n725:         this.buildLogBox.setContent(escapeBlessedTags(agent.build_output));\n726:       } else if (agent.build_passed === true) {\n727:         this.buildLogBox.setContent(\n728:           \"{green-fg}Build passed — no errors.{/green-fg}\"\n729:         );\n730:       } else if (agent.build_passed === false) {\n731:         this.buildLogBox.setContent(\n732:           \"{red-fg}Build failed — no output captured.{/red-fg}\"\n733:         );\n734:       } else {\n735:         this.buildLogBox.setContent(\n736:           \"{gray-fg}No build has been run yet.{/gray-fg}\"\n737:         );\n738:       }\n739: \n740:       this.buildLogBox.show();\n741:       this.buildLogBox.focus();\n742:     }\n743:     this.screen.render();\n744:   }\n745: \n746:   /**\n747:    * Re-create the screen after returning from tmux attach.\n748:    * Blessed can't resume after destroy, so we rebuild everything.\n749:    */\n750:   private recreateScreen(): void {\n751:     // Re-create screen\n752:     this.screen = blessed.screen({\n753:       smartCSR: true,\n754:       title: `Wombo — ${this.state.wave_id}`,\n755:       fullUnicode: true,\n756:     });\n757: \n758:     // Re-create all widgets\n759:     this.headerBox = blessed.box({\n760:       top: 0,\n761:       left: 0,\n762:       width: \"100%\",\n763:       height: 3,\n764:       tags: true,\n765:       style: { fg: \"white\", bg: \"black\" },\n766:     });\n767: \n768:     this.agentList = blessed.list({\n769:       top: 3,\n770:       left: 0,\n771:       width: \"55%\",\n772:       height: \"100%-6\",\n773:       tags: true,\n774:       scrollable: true,\n775:       mouse: true,\n776:       keys: true,\n777:       vi: true,\n778:       border: { type: \"line\" },\n779:       style: {\n780:         border: { fg: \"gray\" },\n781:         selected: { bg: \"blue\", fg: \"white\", bold: true },\n782:         item: { fg: \"white\" },\n783:       },\n784:       label: \" Agents \",\n785:     });\n786: \n787:     this.previewBox = blessed.log({\n788:       top: 3,\n789:       left: \"55%\",\n790:       width: \"45%\",\n791:       height: \"100%-6\",\n792:       tags: true,\n793:       scrollable: true,\n794:       mouse: true,\n795:       keys: false,\n796:       scrollbar: { ch: \"│\", style: { fg: \"cyan\" } },\n797:       border: { type: \"line\" },\n798:       style: { border: { fg: \"gray\" }, fg: \"white\" },\n799:       label: \" Activity \",\n800:     });\n801: \n802:     this.buildLogBox = blessed.log({\n803:       top: 3,\n804:       left: \"10%\",\n805:       width: \"80%\",\n806:       height: \"100%-6\",\n807:       tags: true,\n808:       scrollable: true,\n809:       mouse: true,\n810:       keys: true,\n811:       scrollbar: { ch: \"│\", style: { fg: \"yellow\" } },\n812:       border: { type: \"line\" },\n813:       style: { border: { fg: \"yellow\" }, fg: \"white\" },\n814:       label: \" Build Log \",\n815:       hidden: true,\n816:     });\n817: \n818:     this.statusBar = blessed.box({\n819:       bottom: 0,\n820:       left: 0,\n821:       width: \"100%\",\n822:       height: 3,\n823:       tags: true,\n824:       style: { fg: \"white\", bg: \"black\" },\n825:     });\n826: \n827:     this.screen.append(this.headerBox);\n828:     this.screen.append(this.agentList);\n829:     this.screen.append(this.previewBox);\n830:     this.screen.append(this.buildLogBox);\n831:     this.screen.append(this.statusBar);\n832: \n833:     this.agentList.focus();\n834:     this.showingBuildLog = false;\n835:     this.showingLogFile = false;\n836:     this.logFileBox = null;\n837:     this.interceptConsole();\n838:     this.bindKeys();\n839:     this.refresh();\n840:   }\n841: }\n\n(End of file - total 841 lines)\n</content>","title":"src/lib/tui.ts","metadata":{"preview":"/**\n * tui.ts — Blessed-based TUI dashboard for Wombo.\n *\n * Layout:\n *   ┌─────────────────────────────────────────────┐\n *   │ Header: Wave ID, base branch, mode, model   │\n *   ├──────────────────────────┬──────────────────┤\n *   │ Agent Table              │ Preview Pane     │\n *   │ (selectable rows with    │ (parsed activity │\n *   │  status, activity,       │  stream for the  │\n *   │  progress bars, elapsed) │  selected agent) │\n *   ├──────────────────────────┴──────────────────┤\n *   │ Status bar: keybinds + summary counts       │\n *   └─────────────────────────────────────────────┘\n *\n * Keybinds:\n *   Up/Down   — navigate agent list\n *   Enter     — tmux attach to selected agent (interactive mode)\n *   b         — show build log for selected agent\n *   p         — toggle auto-scroll (pause/resume)","truncated":false,"loaded":[]},"time":{"start":1773351949128,"end":1773351949130}}}}
