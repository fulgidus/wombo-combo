{"type":"tool_use","timestamp":1773351936905,"sessionID":"ses_31bfd06f5ffeleRCi6uuMulALr","part":{"id":"prt_ce4031fea001xPUtNJTPva2nSt","sessionID":"ses_31bfd06f5ffeleRCi6uuMulALr","messageID":"msg_ce4031222001s0lWIc4kxiIOzQ","type":"tool","callID":"toolu_vrtx_01LWg3Fjy74ynbhP9od7Jsii","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-dmux-migration/src/lib/monitor.ts"},"output":"<path>/home/fulgidus/Documents/wombo-dmux-migration/src/lib/monitor.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * monitor.ts — Parse JSON events from agent and detect completion/failure.\n3:  *\n4:  * Responsibilities:\n5:  *   - Parse newline-delimited JSON events from agent stdout\n6:  *   - Detect session completion (agent finished)\n7:  *   - Detect session ID from events\n8:  *   - Detect errors and failures\n9:  *   - Write per-agent raw log files for diagnostics\n10:  *   - Maintain per-agent parsed activity log for TUI preview\n11:  */\n12: \n13: import type { ChildProcess } from \"node:child_process\";\n14: import { isProcessRunning } from \"./launcher.js\";\n15: import { mkdirSync, appendFileSync, existsSync } from \"node:fs\";\n16: import { resolve } from \"node:path\";\n17: \n18: // ---------------------------------------------------------------------------\n19: // Log directory name (configurable would be overkill here)\n20: // ---------------------------------------------------------------------------\n21: \n22: const LOG_DIR_NAME = \".wombo-logs\";\n23: \n24: // ---------------------------------------------------------------------------\n25: // Types — OpenCode JSON Events\n26: // ---------------------------------------------------------------------------\n27: \n28: export interface OpenCodeEvent {\n29:   type: string;\n30:   sessionID?: string;\n31:   timestamp?: number;\n32:   part?: {\n33:     type?: string;\n34:     tool?: string;\n35:     callID?: string;\n36:     text?: string;\n37:     reason?: string;\n38:     cost?: number;\n39:     tokens?: {\n40:       total: number;\n41:       input: number;\n42:       output: number;\n43:       reasoning: number;\n44:     };\n45:     state?: {\n46:       status?: string;\n47:       input?: Record<string, any>;\n48:       output?: string;\n49:       error?: string;\n50:     };\n51:   };\n52:   [key: string]: any;\n53: }\n54: \n55: // ---------------------------------------------------------------------------\n56: // Event Parser\n57: // ---------------------------------------------------------------------------\n58: \n59: export interface ParsedOutput {\n60:   sessionId: string | null;\n61:   completed: boolean;\n62:   errored: boolean;\n63:   lastError: string | null;\n64:   events: OpenCodeEvent[];\n65: }\n66: \n67: export function parseEvents(rawOutput: string): ParsedOutput {\n68:   const result: ParsedOutput = {\n69:     sessionId: null,\n70:     completed: false,\n71:     errored: false,\n72:     lastError: null,\n73:     events: [],\n74:   };\n75: \n76:   const lines = rawOutput.split(\"\\n\").filter((l) => l.trim());\n77: \n78:   for (const line of lines) {\n79:     try {\n80:       const event = JSON.parse(line) as OpenCodeEvent;\n81:       result.events.push(event);\n82: \n83:       if (event.sessionID && !result.sessionId) {\n84:         result.sessionId = event.sessionID;\n85:       }\n86: \n87:       if (\n88:         event.type === \"step_finish\" &&\n89:         event.part?.reason === \"stop\"\n90:       ) {\n91:         result.completed = true;\n92:       }\n93: \n94:       if (\n95:         event.type === \"tool_use\" &&\n96:         event.part?.state?.status === \"error\"\n97:       ) {\n98:         result.errored = true;\n99:         result.lastError = event.part.state.error ?? \"unknown tool error\";\n100:       }\n101:     } catch {\n102:       // Not valid JSON — skip\n103:     }\n104:   }\n105: \n106:   return result;\n107: }\n108: \n109: // ---------------------------------------------------------------------------\n110: // Activity Extraction\n111: // ---------------------------------------------------------------------------\n112: \n113: function shortPath(fullPath: string | undefined, maxLen: number = 30): string {\n114:   if (!fullPath) return \"\";\n115:   const parts = fullPath.replace(/^\\/+/, \"\").split(\"/\");\n116:   const short =\n117:     parts.length > 1\n118:       ? parts.slice(-2).join(\"/\")\n119:       : parts[parts.length - 1];\n120:   if (short.length <= maxLen) return short;\n121:   const fname = parts[parts.length - 1];\n122:   return fname.length <= maxLen ? fname : fname.slice(0, maxLen - 1) + \"\\u2026\";\n123: }\n124: \n125: function shortCmd(cmd: string | undefined, maxLen: number = 30): string {\n126:   if (!cmd) return \"\";\n127:   const first = cmd.split(\"\\n\")[0].trim();\n128:   if (first.length <= maxLen) return first;\n129:   return first.slice(0, maxLen - 1) + \"\\u2026\";\n130: }\n131: \n132: /**\n133:  * Map an event to a human-readable activity string.\n134:  */\n135: export function extractActivity(event: OpenCodeEvent): string | null {\n136:   switch (event.type) {\n137:     case \"step_start\":\n138:       return \"thinking\\u2026\";\n139: \n140:     case \"tool_use\": {\n141:       const toolName = (event.part?.tool ?? \"\").toLowerCase();\n142:       const input = event.part?.state?.input ?? {};\n143:       const status = event.part?.state?.status ?? \"\";\n144: \n145:       if (status === \"error\") {\n146:         return `${toolName}: error`;\n147:       }\n148: \n149:       switch (toolName) {\n150:         case \"read\":\n151:           return `reading ${shortPath(input.filePath ?? input.path)}`;\n152:         case \"write\":\n153:           return `writing ${shortPath(input.filePath ?? input.path)}`;\n154:         case \"edit\":\n155:           return `editing ${shortPath(input.filePath ?? input.path)}`;\n156:         case \"bash\":\n157:         case \"command\":\n158:         case \"terminal\":\n159:           return `$ ${shortCmd(input.command ?? input.cmd)}`;\n160:         case \"glob\":\n161:           return `finding: ${shortPath(input.pattern)}`;\n162:         case \"grep\":\n163:         case \"search\":\n164:           return `searching: ${(input.pattern ?? \"\").slice(0, 25)}`;\n165:         case \"task\":\n166:           return \"delegating task\\u2026\";\n167:         case \"webfetch\":\n168:         case \"web_fetch\":\n169:           return \"fetching URL\\u2026\";\n170:         case \"todowrite\":\n171:         case \"todo_write\":\n172:           return \"planning\\u2026\";\n173:         case \"question\":\n174:           return \"asking question\\u2026\";\n175:         case \"jcodemunch_index_folder\":\n176:         case \"jcodemunch_index_repo\":\n177:           return \"indexing code\\u2026\";\n178:         case \"jcodemunch_search_symbols\":\n179:         case \"jcodemunch_search_text\":\n180:           return \"searching symbols\\u2026\";\n181:         case \"jcodemunch_get_file_outline\":\n182:           return `outlining ${shortPath(input.file_path)}`;\n183:         case \"jcodemunch_get_symbol\":\n184:         case \"jcodemunch_get_symbols\":\n185:           return \"reading symbol\\u2026\";\n186:         default:\n187:           return `tool: ${toolName}`;\n188:       }\n189:     }\n190: \n191:     case \"text\":\n192:       return \"responding\\u2026\";\n193: \n194:     case \"step_finish\":\n195:       if (event.part?.reason === \"stop\") return \"done\";\n196:       if (event.part?.reason === \"tool-calls\") return null;\n197:       return null;\n198: \n199:     default:\n200:       return null;\n201:   }\n202: }\n203: \n204: /**\n205:  * Format an event into a human-readable log line for the activity stream.\n206:  */\n207: export function formatEventForLog(event: OpenCodeEvent): string | null {\n208:   switch (event.type) {\n209:     case \"step_start\":\n210:       return \"-- step started\";\n211: \n212:     case \"tool_use\": {\n213:       const toolName = event.part?.tool ?? \"unknown\";\n214:       const input = event.part?.state?.input ?? {};\n215:       const status = event.part?.state?.status ?? \"\";\n216:       const output = event.part?.state?.output ?? \"\";\n217:       const error = event.part?.state?.error ?? \"\";\n218: \n219:       let line = `>> ${toolName}`;\n220:       switch (toolName.toLowerCase()) {\n221:         case \"read\":\n222:           line = `>> read ${shortPath(input.filePath ?? input.path, 50)}`;\n223:           break;\n224:         case \"write\":\n225:           line = `>> write ${shortPath(input.filePath ?? input.path, 50)}`;\n226:           break;\n227:         case \"edit\":\n228:           line = `>> edit ${shortPath(input.filePath ?? input.path, 50)}`;\n229:           break;\n230:         case \"bash\":\n231:         case \"command\":\n232:           line = `>> $ ${shortCmd(input.command ?? input.cmd, 60)}`;\n233:           break;\n234:         case \"glob\":\n235:           line = `>> glob ${input.pattern ?? \"\"}`;\n236:           break;\n237:         case \"grep\":\n238:           line = `>> grep \"${(input.pattern ?? \"\").slice(0, 30)}\"`;\n239:           break;\n240:         case \"task\":\n241:           line = `>> task: ${(input.description ?? input.prompt ?? \"\").slice(0, 50)}`;\n242:           break;\n243:       }\n244: \n245:       if (status === \"completed\" && output) {\n246:         const preview = output.split(\"\\n\")[0].slice(0, 80);\n247:         return `${line}\\n   ${preview}${output.length > 80 ? \"\\u2026\" : \"\"}`;\n248:       }\n249:       if (status === \"error\" && error) {\n250:         return `${line}\\n!! ${error.slice(0, 100)}`;\n251:       }\n252:       return line;\n253:     }\n254: \n255:     case \"text\": {\n256:       const text = event.part?.text ?? \"\";\n257:       if (!text.trim()) return null;\n258:       const firstLine = text.split(\"\\n\").find((l: string) => l.trim())?.trim() ?? \"\";\n259:       if (firstLine.length === 0) return null;\n260:       return `   ${firstLine.slice(0, 120)}${firstLine.length > 120 ? \"\\u2026\" : \"\"}`;\n261:     }\n262: \n263:     case \"step_finish\": {\n264:       const reason = event.part?.reason ?? \"\";\n265:       const tokens = event.part?.tokens;\n266:       if (reason === \"stop\") {\n267:         const tokStr = tokens\n268:           ? ` (${tokens.input}in/${tokens.output}out)`\n269:           : \"\";\n270:         return `-- done${tokStr}`;\n271:       }\n272:       return null;\n273:     }\n274: \n275:     default:\n276:       return null;\n277:   }\n278: }\n279: \n280: // ---------------------------------------------------------------------------\n281: // Per-agent Activity Log (in-memory ring buffer for TUI)\n282: // ---------------------------------------------------------------------------\n283: \n284: export interface ActivityEntry {\n285:   timestamp: string;\n286:   text: string;\n287: }\n288: \n289: const MAX_ACTIVITY_LINES = 500;\n290: \n291: // ---------------------------------------------------------------------------\n292: // Process Monitor\n293: // ---------------------------------------------------------------------------\n294: \n295: export interface MonitorCallbacks {\n296:   onSessionId?: (featureId: string, sessionId: string) => void;\n297:   onComplete?: (featureId: string) => void;\n298:   onError?: (featureId: string, error: string) => void;\n299:   onOutput?: (featureId: string, data: string) => void;\n300:   onActivity?: (featureId: string, activity: string) => void;\n301: }\n302: \n303: interface MonitoredProcess {\n304:   featureId: string;\n305:   process: ChildProcess;\n306:   stdout: string;\n307:   stderr: string;\n308:   sessionId: string | null;\n309:   done: boolean;\n310:   lineBuffer: string;\n311:   sawFinalStop: boolean;\n312: }\n313: \n314: /**\n315:  * Monitor a set of headless agent processes.\n316:  * Collects stdout, parses events, and calls callbacks on state changes.\n317:  */\n318: export class ProcessMonitor {\n319:   private processes: Map<string, MonitoredProcess> = new Map();\n320:   private callbacks: MonitorCallbacks;\n321:   private logDir: string;\n322:   /** Per-agent activity log for TUI preview pane */\n323:   public activityLogs: Map<string, ActivityEntry[]> = new Map();\n324: \n325:   constructor(projectRoot: string, callbacks: MonitorCallbacks = {}) {\n326:     this.callbacks = callbacks;\n327:     this.logDir = resolve(projectRoot, LOG_DIR_NAME);\n328:     if (!existsSync(this.logDir)) {\n329:       mkdirSync(this.logDir, { recursive: true });\n330:     }\n331:   }\n332: \n333:   private pushActivity(featureId: string, text: string): void {\n334:     if (!this.activityLogs.has(featureId)) {\n335:       this.activityLogs.set(featureId, []);\n336:     }\n337:     const log = this.activityLogs.get(featureId)!;\n338:     for (const line of text.split(\"\\n\")) {\n339:       log.push({ timestamp: new Date().toISOString().slice(11, 19), text: line });\n340:     }\n341:     if (log.length > MAX_ACTIVITY_LINES) {\n342:       log.splice(0, log.length - MAX_ACTIVITY_LINES);\n343:     }\n344:   }\n345: \n346:   private writeLog(featureId: string, data: string): void {\n347:     try {\n348:       const logFile = resolve(this.logDir, `${featureId}.log`);\n349:       appendFileSync(logFile, data);\n350:     } catch {\n351:       // Non-critical\n352:     }\n353:   }\n354: \n355:   getActivityLog(featureId: string): ActivityEntry[] {\n356:     return this.activityLogs.get(featureId) ?? [];\n357:   }\n358: \n359:   addProcess(featureId: string, child: ChildProcess): void {\n360:     const monitored: MonitoredProcess = {\n361:       featureId,\n362:       process: child,\n363:       stdout: \"\",\n364:       stderr: \"\",\n365:       sessionId: null,\n366:       done: false,\n367:       lineBuffer: \"\",\n368:       sawFinalStop: false,\n369:     };\n370: \n371:     this.pushActivity(featureId, \"-- agent process started\");\n372:     this.writeLog(featureId, `[wombo] Process started at ${new Date().toISOString()}\\n`);\n373: \n374:     child.stdout?.on(\"data\", (data: Buffer) => {\n375:       const chunk = data.toString();\n376:       monitored.stdout += chunk;\n377:       this.callbacks.onOutput?.(featureId, chunk);\n378:       this.writeLog(featureId, chunk);\n379: \n380:       monitored.lineBuffer += chunk;\n381:       const lines = monitored.lineBuffer.split(\"\\n\");\n382:       monitored.lineBuffer = lines.pop() ?? \"\";\n383: \n384:       for (const line of lines) {\n385:         const trimmed = line.trim();\n386:         if (!trimmed) continue;\n387:         try {\n388:           const event = JSON.parse(trimmed) as OpenCodeEvent;\n389: \n390:           if (!monitored.sessionId && event.sessionID) {\n391:             monitored.sessionId = event.sessionID;\n392:             this.callbacks.onSessionId?.(featureId, event.sessionID);\n393:             this.pushActivity(featureId, `-- session: ${event.sessionID}`);\n394:           }\n395: \n396:           const activity = extractActivity(event);\n397:           if (activity) {\n398:             this.callbacks.onActivity?.(featureId, activity);\n399:           }\n400: \n401:           const logLine = formatEventForLog(event);\n402:           if (logLine) {\n403:             this.pushActivity(featureId, logLine);\n404:           }\n405: \n406:           if (\n407:             event.type === \"step_finish\" &&\n408:             event.part?.reason === \"stop\"\n409:           ) {\n410:             monitored.sawFinalStop = true;\n411:           }\n412:         } catch {\n413:           if (trimmed.length > 0 && trimmed.length < 500) {\n414:             this.pushActivity(featureId, `[raw] ${trimmed.slice(0, 120)}`);\n415:           }\n416:         }\n417:       }\n418:     });\n419: \n420:     child.stderr?.on(\"data\", (data: Buffer) => {\n421:       const chunk = data.toString();\n422:       monitored.stderr += chunk;\n423:       this.writeLog(featureId, `[stderr] ${chunk}`);\n424:       const lines = chunk.split(\"\\n\").filter((l) => l.trim());\n425:       for (const line of lines) {\n426:         this.pushActivity(featureId, `[stderr] ${line.trim().slice(0, 120)}`);\n427:       }\n428:     });\n429: \n430:     child.on(\"exit\", (code) => {\n431:       monitored.done = true;\n432:       this.pushActivity(featureId, `-- process exited (code ${code})`);\n433:       this.writeLog(featureId, `\\n[wombo] Process exited with code ${code} at ${new Date().toISOString()}\\n`);\n434: \n435:       if (code === 0 || monitored.sawFinalStop) {\n436:         this.callbacks.onComplete?.(featureId);\n437:       } else {\n438:         const error =\n439:           monitored.stderr.slice(-2000) ||\n440:           `Process exited with code ${code}`;\n441:         this.callbacks.onError?.(featureId, error);\n442:       }\n443:     });\n444: \n445:     child.on(\"error\", (err) => {\n446:       monitored.done = true;\n447:       this.pushActivity(featureId, `!! process error: ${err.message}`);\n448:       this.writeLog(featureId, `\\n[wombo] Process error: ${err.message}\\n`);\n449:       this.callbacks.onError?.(featureId, err.message);\n450:     });\n451: \n452:     this.processes.set(featureId, monitored);\n453:   }\n454: \n455:   getSessionId(featureId: string): string | null {\n456:     return this.processes.get(featureId)?.sessionId ?? null;\n457:   }\n458: \n459:   getOutput(featureId: string): string {\n460:     return this.processes.get(featureId)?.stdout ?? \"\";\n461:   }\n462: \n463:   isRunning(featureId: string): boolean {\n464:     const m = this.processes.get(featureId);\n465:     if (!m) return false;\n466:     if (m.done) return false;\n467:     return isProcessRunning(m.process.pid!);\n468:   }\n469: \n470:   allDone(): boolean {\n471:     for (const m of this.processes.values()) {\n472:       if (!m.done) return false;\n473:     }\n474:     return true;\n475:   }\n476: \n477:   activeCount(): number {\n478:     let count = 0;\n479:     for (const m of this.processes.values()) {\n480:       if (!m.done) count++;\n481:     }\n482:     return count;\n483:   }\n484: \n485:   remove(featureId: string): void {\n486:     const m = this.processes.get(featureId);\n487:     if (m && !m.done) {\n488:       try {\n489:         m.process.kill(\"SIGTERM\");\n490:       } catch {}\n491:     }\n492:     this.processes.delete(featureId);\n493:   }\n494: \n495:   killAll(): void {\n496:     for (const id of this.processes.keys()) {\n497:       this.remove(id);\n498:     }\n499:   }\n500: \n501:   waitAll(pollIntervalMs: number = 1000): Promise<void> {\n502:     return new Promise((resolve) => {\n503:       const check = () => {\n504:         if (this.allDone()) {\n505:           resolve();\n506:         } else {\n507:           setTimeout(check, pollIntervalMs);\n508:         }\n509:       };\n510:       check();\n511:     });\n512:   }\n513: }\n\n(End of file - total 513 lines)\n</content>","title":"src/lib/monitor.ts","metadata":{"preview":"/**\n * monitor.ts — Parse JSON events from agent and detect completion/failure.\n *\n * Responsibilities:\n *   - Parse newline-delimited JSON events from agent stdout\n *   - Detect session completion (agent finished)\n *   - Detect session ID from events\n *   - Detect errors and failures\n *   - Write per-agent raw log files for diagnostics\n *   - Maintain per-agent parsed activity log for TUI preview\n */\n\nimport type { ChildProcess } from \"node:child_process\";\nimport { isProcessRunning } from \"./launcher.js\";\nimport { mkdirSync, appendFileSync, existsSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\n\n// ---------------------------------------------------------------------------\n// Log directory name (configurable would be overkill here)\n// ---------------------------------------------------------------------------","truncated":false,"loaded":[]},"time":{"start":1773351936900,"end":1773351936904}}}}
