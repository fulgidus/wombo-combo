{"type":"tool_use","timestamp":1773351931342,"sessionID":"ses_31bfd06f5ffeleRCi6uuMulALr","part":{"id":"prt_ce4030ca5001ef5v9GLntrnTyb","sessionID":"ses_31bfd06f5ffeleRCi6uuMulALr","messageID":"msg_ce402f9410018IOQiVm4dmZOPX","type":"tool","callID":"toolu_vrtx_015utaKoM7UyNEQ6tJ5nESXD","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-dmux-migration/package.json"},"output":"<path>/home/fulgidus/Documents/wombo-dmux-migration/package.json</path>\n<type>file</type>\n<content>1: {\n2:     \"name\": \"wombo-combo\",\n3:     \"version\": \"0.0.9\",\n4:     \"description\": \"WOMBO COMBO! — AI agent orchestration system for parallel feature development\",\n5:     \"type\": \"module\",\n6:     \"bin\": {\n7:         \"woco\": \"./src/index.ts\",\n8:         \"wombo\": \"./src/index.ts\"\n9:     },\n10:     \"files\": [\n11:         \"src/**/*.ts\",\n12:         \"src/templates/.features.yml\",\n13:         \"src/templates/wave-worker.md\"\n14:     ],\n15:     \"scripts\": {\n16:         \"dev\": \"bun src/index.ts\",\n17:         \"wombo\": \"bun src/index.ts\",\n18:         \"start\": \"bun src/index.ts\",\n19:         \"build\": \"bun build src/index.ts --outdir dist --target node\",\n20:         \"typecheck\": \"tsc --noEmit\"\n21:     },\n22:     \"repository\": {\n23:         \"type\": \"git\",\n24:         \"url\": \"git+https://github.com/fulgidus/wombo-combo.git\"\n25:     },\n26:     \"homepage\": \"https://github.com/fulgidus/wombo-combo\",\n27:     \"bugs\": {\n28:         \"url\": \"https://github.com/fulgidus/wombo-combo/issues\"\n29:     },\n30:     \"keywords\": [\n31:         \"ai\",\n32:         \"agent\",\n33:         \"orchestration\",\n34:         \"parallel\",\n35:         \"feature-development\",\n36:         \"cli\",\n37:         \"wombo-combo\",\n38:         \"woco\"\n39:     ],\n40:     \"author\": \"fulgidus\",\n41:     \"license\": \"MIT\",\n42:     \"engines\": {\n43:         \"bun\": \">=1.0.0\"\n44:     },\n45:     \"dependencies\": {\n46:         \"mermaidtui\": \"^0.0.5\",\n47:         \"neo-blessed\": \"^0.2.0\",\n48:         \"yaml\": \"^2.7.1\"\n49:     },\n50:     \"devDependencies\": {\n51:         \"@types/blessed\": \"^0.1.25\",\n52:         \"@types/bun\": \"latest\",\n53:         \"typescript\": \"^5.8.2\"\n54:     }\n55: }\n\n(End of file - total 55 lines)\n</content>","title":"package.json","metadata":{"preview":"{\n    \"name\": \"wombo-combo\",\n    \"version\": \"0.0.9\",\n    \"description\": \"WOMBO COMBO! — AI agent orchestration system for parallel feature development\",\n    \"type\": \"module\",\n    \"bin\": {\n        \"woco\": \"./src/index.ts\",\n        \"wombo\": \"./src/index.ts\"\n    },\n    \"files\": [\n        \"src/**/*.ts\",\n        \"src/templates/.features.yml\",\n        \"src/templates/wave-worker.md\"\n    ],\n    \"scripts\": {\n        \"dev\": \"bun src/index.ts\",\n        \"wombo\": \"bun src/index.ts\",\n        \"start\": \"bun src/index.ts\",\n        \"build\": \"bun build src/index.ts --outdir dist --target node\",\n        \"typecheck\": \"tsc --noEmit\"","truncated":false,"loaded":[]},"time":{"start":1773351931333,"end":1773351931341}}}}
{"type":"tool_use","timestamp":1773351932073,"sessionID":"ses_31bfd06f5ffeleRCi6uuMulALr","part":{"id":"prt_ce4030e28001Yzn9fVhlOp5M39","sessionID":"ses_31bfd06f5ffeleRCi6uuMulALr","messageID":"msg_ce402f9410018IOQiVm4dmZOPX","type":"tool","callID":"toolu_vrtx_01Bd5Xde5t6Ms2kkjULbgZde","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-dmux-migration/src/lib/launcher.ts"},"output":"<path>/home/fulgidus/Documents/wombo-dmux-migration/src/lib/launcher.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * launcher.ts — Process spawning and tmux session management.\n3:  *\n4:  * Responsibilities:\n5:  *   - Launch agent in headless mode (agent run --format json)\n6:  *   - Launch agent in interactive mode (tmux session with TUI)\n7:  *   - Resume sessions for auto-retry\n8:  *   - Manage tmux sessions (create, list, kill)\n9:  */\n10: \n11: import { spawn, execSync, type ChildProcess } from \"node:child_process\";\n12: import { writeFileSync, unlinkSync } from \"node:fs\";\n13: import type { WomboConfig } from \"../config.js\";\n14: import { resolveAgentBin } from \"../config.js\";\n15: \n16: // ---------------------------------------------------------------------------\n17: // Types\n18: // ---------------------------------------------------------------------------\n19: \n20: export interface LaunchResult {\n21:   pid: number;\n22:   process: ChildProcess;\n23:   sessionId?: string;\n24: }\n25: \n26: export interface LaunchOptions {\n27:   worktreePath: string;\n28:   featureId: string;\n29:   prompt: string;\n30:   model?: string;\n31:   interactive?: boolean;\n32:   config: WomboConfig;\n33: }\n34: \n35: export interface RetryOptions {\n36:   worktreePath: string;\n37:   featureId: string;\n38:   sessionId: string;\n39:   buildErrors: string;\n40:   model?: string;\n41:   interactive?: boolean;\n42:   config: WomboConfig;\n43: }\n44: \n45: // ---------------------------------------------------------------------------\n46: // Helpers\n47: // ---------------------------------------------------------------------------\n48: \n49: function tmuxSessionName(featureId: string, config: WomboConfig): string {\n50:   return `${config.agent.tmuxPrefix}-${featureId}`;\n51: }\n52: \n53: function runSilent(cmd: string): string {\n54:   try {\n55:     return execSync(cmd, { encoding: \"utf-8\", stdio: \"pipe\" }).trim();\n56:   } catch {\n57:     return \"\";\n58:   }\n59: }\n60: \n61: // ---------------------------------------------------------------------------\n62: // Headless Launch\n63: // ---------------------------------------------------------------------------\n64: \n65: /**\n66:  * Launch agent in headless mode with JSON output.\n67:  */\n68: export function launchHeadless(opts: LaunchOptions): LaunchResult {\n69:   const agentBin = resolveAgentBin(opts.config);\n70: \n71:   const args = [\n72:     \"run\",\n73:     \"--format\", \"json\",\n74:     \"--agent\", opts.config.agent.name,\n75:     \"--dir\", opts.worktreePath,\n76:     \"--title\", `wombo: ${opts.featureId}`,\n77:   ];\n78: \n79:   if (opts.model) {\n80:     args.push(\"--model\", opts.model);\n81:   }\n82: \n83:   args.push(opts.prompt);\n84: \n85:   const child = spawn(agentBin, args, {\n86:     stdio: [\"pipe\", \"pipe\", \"pipe\"],\n87:     detached: false,\n88:     env: {\n89:       ...process.env,\n90:       OPENCODE_DIR: opts.worktreePath,\n91:     },\n92:   });\n93: \n94:   // Close stdin so agent starts processing immediately\n95:   child.stdin?.end();\n96: \n97:   return {\n98:     pid: child.pid!,\n99:     process: child,\n100:   };\n101: }\n102: \n103: /**\n104:  * Resume a headless session with a retry message (build errors).\n105:  */\n106: export function retryHeadless(opts: RetryOptions): LaunchResult {\n107:   const agentBin = resolveAgentBin(opts.config);\n108: \n109:   const retryMessage = `The build failed. Please fix the following errors and run \\`${opts.config.build.command}\\` again:\\n\\n\\`\\`\\`\\n${opts.buildErrors}\\n\\`\\`\\`\\n\\nFix all errors, then verify the build passes.`;\n110: \n111:   const args = [\n112:     \"run\",\n113:     \"--format\", \"json\",\n114:     \"--session\", opts.sessionId,\n115:     \"--continue\",\n116:     \"--dir\", opts.worktreePath,\n117:   ];\n118: \n119:   if (opts.model) {\n120:     args.push(\"--model\", opts.model);\n121:   }\n122: \n123:   args.push(retryMessage);\n124: \n125:   const child = spawn(agentBin, args, {\n126:     stdio: [\"pipe\", \"pipe\", \"pipe\"],\n127:     detached: false,\n128:     env: {\n129:       ...process.env,\n130:       OPENCODE_DIR: opts.worktreePath,\n131:     },\n132:   });\n133: \n134:   child.stdin?.end();\n135: \n136:   return {\n137:     pid: child.pid!,\n138:     process: child,\n139:   };\n140: }\n141: \n142: // ---------------------------------------------------------------------------\n143: // Conflict Resolution Launch\n144: // ---------------------------------------------------------------------------\n145: \n146: export interface ConflictResolverOptions {\n147:   worktreePath: string;\n148:   featureId: string;\n149:   prompt: string;\n150:   model?: string;\n151:   config: WomboConfig;\n152: }\n153: \n154: /**\n155:  * Launch a headless agent to resolve merge conflicts.\n156:  *\n157:  * This is similar to `launchHeadless`, but the prompt is a conflict-resolution\n158:  * prompt generated by `generateConflictResolutionPrompt()`. The agent runs in\n159:  * the feature worktree where `git merge <baseBranch>` has already been run,\n160:  * leaving conflict markers in the working tree.\n161:  */\n162: export function launchConflictResolver(opts: ConflictResolverOptions): LaunchResult {\n163:   const agentBin = resolveAgentBin(opts.config);\n164: \n165:   const args = [\n166:     \"run\",\n167:     \"--format\", \"json\",\n168:     \"--agent\", opts.config.agent.name,\n169:     \"--dir\", opts.worktreePath,\n170:     \"--title\", `wombo: conflict-resolve ${opts.featureId}`,\n171:   ];\n172: \n173:   if (opts.model) {\n174:     args.push(\"--model\", opts.model);\n175:   }\n176: \n177:   args.push(opts.prompt);\n178: \n179:   const child = spawn(agentBin, args, {\n180:     stdio: [\"pipe\", \"pipe\", \"pipe\"],\n181:     detached: false,\n182:     env: {\n183:       ...process.env,\n184:       OPENCODE_DIR: opts.worktreePath,\n185:     },\n186:   });\n187: \n188:   child.stdin?.end();\n189: \n190:   return {\n191:     pid: child.pid!,\n192:     process: child,\n193:   };\n194: }\n195: \n196: // ---------------------------------------------------------------------------\n197: // Interactive (tmux) Launch\n198: // ---------------------------------------------------------------------------\n199: \n200: /**\n201:  * Launch agent in a tmux session for interactive use.\n202:  */\n203: export function launchInteractive(opts: LaunchOptions): LaunchResult {\n204:   const agentBin = resolveAgentBin(opts.config);\n205:   const sessionName = tmuxSessionName(opts.featureId, opts.config);\n206: \n207:   // Kill existing session if any\n208:   killTmuxSession(opts.featureId, opts.config);\n209: \n210:   // Build the agent command to run inside tmux\n211:   const ocArgs = [\n212:     agentBin,\n213:     \"--dir\", JSON.stringify(opts.worktreePath),\n214:   ];\n215: \n216:   if (opts.model) {\n217:     ocArgs.push(\"--model\", JSON.stringify(opts.model));\n218:   }\n219: \n220:   const tmuxCmd = ocArgs.join(\" \");\n221: \n222:   // Create a detached tmux session running the agent\n223:   execSync(\n224:     `tmux new-session -d -s \"${sessionName}\" -c \"${opts.worktreePath}\" \"${tmuxCmd}\"`,\n225:     { stdio: \"pipe\" }\n226:   );\n227: \n228:   // Send the prompt as initial message after a brief delay\n229:   setTimeout(() => {\n230:     try {\n231:       const tmpFile = `/tmp/wombo-prompt-${opts.featureId}.txt`;\n232:       writeFileSync(tmpFile, opts.prompt);\n233:       execSync(`tmux load-buffer \"${tmpFile}\"`, { stdio: \"pipe\" });\n234:       execSync(`tmux paste-buffer -t \"${sessionName}\"`, { stdio: \"pipe\" });\n235:       execSync(`tmux send-keys -t \"${sessionName}\" Enter`, { stdio: \"pipe\" });\n236:       try { unlinkSync(tmpFile); } catch {}\n237:     } catch {\n238:       // If prompt sending fails, user can type manually\n239:     }\n240:   }, 3000);\n241: \n242:   // Get the PID of the tmux server pane process\n243:   const panePid = runSilent(\n244:     `tmux list-panes -t \"${sessionName}\" -F \"#{pane_pid}\"`\n245:   );\n246: \n247:   return {\n248:     pid: parseInt(panePid) || 0,\n249:     process: null as any, // No direct process handle in tmux mode\n250:   };\n251: }\n252: \n253: /**\n254:  * Resume an interactive session with retry message.\n255:  */\n256: export function retryInteractive(opts: RetryOptions): LaunchResult {\n257:   const sessionName = tmuxSessionName(opts.featureId, opts.config);\n258: \n259:   const exists = tmuxSessionExists(opts.featureId, opts.config);\n260: \n261:   if (exists) {\n262:     const retryMsg = `The build failed. Fix these errors:\\n${opts.buildErrors}`;\n263:     const tmpFile = `/tmp/wombo-retry-${opts.featureId}.txt`;\n264:     writeFileSync(tmpFile, retryMsg);\n265:     execSync(`tmux load-buffer \"${tmpFile}\"`, { stdio: \"pipe\" });\n266:     execSync(`tmux paste-buffer -t \"${sessionName}\"`, { stdio: \"pipe\" });\n267:     execSync(`tmux send-keys -t \"${sessionName}\" Enter`, { stdio: \"pipe\" });\n268:     try { unlinkSync(tmpFile); } catch {}\n269: \n270:     const panePid = runSilent(\n271:       `tmux list-panes -t \"${sessionName}\" -F \"#{pane_pid}\"`\n272:     );\n273: \n274:     return {\n275:       pid: parseInt(panePid) || 0,\n276:       process: null as any,\n277:     };\n278:   }\n279: \n280:   // Session doesn't exist — launch a new interactive session\n281:   return launchInteractive({\n282:     worktreePath: opts.worktreePath,\n283:     featureId: opts.featureId,\n284:     prompt: `Continue from session ${opts.sessionId}. The build failed:\\n${opts.buildErrors}\\n\\nFix all errors and verify the build passes.`,\n285:     model: opts.model,\n286:     interactive: true,\n287:     config: opts.config,\n288:   });\n289: }\n290: \n291: // ---------------------------------------------------------------------------\n292: // tmux Session Management\n293: // ---------------------------------------------------------------------------\n294: \n295: /**\n296:  * Check if a tmux session exists for a feature.\n297:  */\n298: export function tmuxSessionExists(\n299:   featureId: string,\n300:   config: WomboConfig\n301: ): boolean {\n302:   const sessionName = tmuxSessionName(featureId, config);\n303:   return runSilent(`tmux has-session -t \"${sessionName}\" 2>/dev/null && echo yes`) === \"yes\";\n304: }\n305: \n306: /**\n307:  * Kill a tmux session for a feature.\n308:  */\n309: export function killTmuxSession(\n310:   featureId: string,\n311:   config: WomboConfig\n312: ): void {\n313:   const sessionName = tmuxSessionName(featureId, config);\n314:   runSilent(`tmux kill-session -t \"${sessionName}\" 2>/dev/null`);\n315: }\n316: \n317: /**\n318:  * List all wombo-related tmux sessions.\n319:  */\n320: export function listTmuxSessions(config: WomboConfig): string[] {\n321:   const output = runSilent(\n322:     `tmux list-sessions -F \"#{session_name}\" 2>/dev/null`\n323:   );\n324:   if (!output) return [];\n325:   return output\n326:     .split(\"\\n\")\n327:     .filter((s) => s.startsWith(config.agent.tmuxPrefix + \"-\"));\n328: }\n329: \n330: /**\n331:  * Kill all wombo-related tmux sessions.\n332:  */\n333: export function killAllTmuxSessions(config: WomboConfig): number {\n334:   const sessions = listTmuxSessions(config);\n335:   for (const s of sessions) {\n336:     runSilent(`tmux kill-session -t \"${s}\" 2>/dev/null`);\n337:   }\n338:   return sessions.length;\n339: }\n340: \n341: /**\n342:  * Check if a process is still running by PID.\n343:  */\n344: export function isProcessRunning(pid: number): boolean {\n345:   if (!pid || pid <= 0) return false;\n346:   try {\n347:     process.kill(pid, 0);\n348:     return true;\n349:   } catch {\n350:     return false;\n351:   }\n352: }\n\n(End of file - total 352 lines)\n</content>","title":"src/lib/launcher.ts","metadata":{"preview":"/**\n * launcher.ts — Process spawning and tmux session management.\n *\n * Responsibilities:\n *   - Launch agent in headless mode (agent run --format json)\n *   - Launch agent in interactive mode (tmux session with TUI)\n *   - Resume sessions for auto-retry\n *   - Manage tmux sessions (create, list, kill)\n */\n\nimport { spawn, execSync, type ChildProcess } from \"node:child_process\";\nimport { writeFileSync, unlinkSync } from \"node:fs\";\nimport type { WomboConfig } from \"../config.js\";\nimport { resolveAgentBin } from \"../config.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface LaunchResult {","truncated":false,"loaded":[]},"time":{"start":1773351932069,"end":1773351932072}}}}
{"type":"tool_use","timestamp":1773351932407,"sessionID":"ses_31bfd06f5ffeleRCi6uuMulALr","part":{"id":"prt_ce40310a6001t9Y0SOEJL21Ntb","sessionID":"ses_31bfd06f5ffeleRCi6uuMulALr","messageID":"msg_ce402f9410018IOQiVm4dmZOPX","type":"tool","callID":"toolu_vrtx_01Movamq4pWwFwyUR4XLZZje","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-dmux-migration/src/config.ts"},"output":"<path>/home/fulgidus/Documents/wombo-dmux-migration/src/config.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * config.ts — Load wombo.json, merge with defaults, validate, expose typed config.\n3:  *\n4:  * The config file lives at the target project root (the repo being orchestrated).\n5:  * All values have sensible defaults so minimal config works out of the box.\n6:  */\n7: \n8: import { readFileSync, existsSync } from \"node:fs\";\n9: import { resolve } from \"node:path\";\n10: \n11: // ---------------------------------------------------------------------------\n12: // Types\n13: // ---------------------------------------------------------------------------\n14: \n15: export interface WomboConfig {\n16:   /** Path to the features YAML file relative to project root */\n17:   featuresFile: string;\n18:   /** Base branch to create feature branches from */\n19:   baseBranch: string;\n20:   /** Build configuration */\n21:   build: {\n22:     /** Build command to run in worktrees */\n23:     command: string;\n24:     /** Build timeout in milliseconds */\n25:     timeout: number;\n26:     /** Build artifact directory (for quick \"did it build?\" checks) */\n27:     artifactDir: string;\n28:   };\n29:   /** Install configuration */\n30:   install: {\n31:     /** Install command to run in worktrees */\n32:     command: string;\n33:     /** Install timeout in milliseconds */\n34:     timeout: number;\n35:   };\n36:   /** Git configuration */\n37:   git: {\n38:     /** Branch name prefix for feature branches */\n39:     branchPrefix: string;\n40:     /** Worktree directory name prefix */\n41:     worktreePrefix: string;\n42:     /** Git remote name */\n43:     remote: string;\n44:     /** Merge strategy flag */\n45:     mergeStrategy: string;\n46:   };\n47:   /** Agent configuration */\n48:   agent: {\n49:     /** Path to agent binary (null = auto-detect) */\n50:     bin: string | null;\n51:     /** Agent name to pass via --agent flag */\n52:     name: string;\n53:     /** Config files/dirs to copy into worktrees */\n54:     configFiles: string[];\n55:     /** tmux session name prefix */\n56:     tmuxPrefix: string;\n57:   };\n58:   /** Backup configuration for features file */\n59:   backup: {\n60:     /** Maximum number of timestamped backups to keep */\n61:     maxBackups: number;\n62:   };\n63:   /** Default runtime values */\n64:   defaults: {\n65:     /** Max concurrent agents */\n66:     maxConcurrent: number;\n67:     /** Max retries per agent */\n68:     maxRetries: number;\n69:   };\n70: }\n71: \n72: // ---------------------------------------------------------------------------\n73: // Defaults\n74: // ---------------------------------------------------------------------------\n75: \n76: export const DEFAULT_CONFIG: WomboConfig = {\n77:   featuresFile: \".features.yml\",\n78:   baseBranch: \"develop\",\n79:   build: {\n80:     command: \"bun run build\",\n81:     timeout: 300_000,\n82:     artifactDir: \"dist\",\n83:   },\n84:   install: {\n85:     command: \"bun install\",\n86:     timeout: 120_000,\n87:   },\n88:   git: {\n89:     branchPrefix: \"feature/\",\n90:     worktreePrefix: \"wombo-\",\n91:     remote: \"origin\",\n92:     mergeStrategy: \"--no-ff\",\n93:   },\n94:   agent: {\n95:     bin: null,\n96:     name: \"wave-worker\",\n97:     configFiles: [\".opencode/\", \"opencode.json\", \"AGENTS.md\", \"agent/\"],\n98:     tmuxPrefix: \"wombo\",\n99:   },\n100:   backup: {\n101:     maxBackups: 5,\n102:   },\n103:   defaults: {\n104:     maxConcurrent: 6,\n105:     maxRetries: 2,\n106:   },\n107: };\n108: \n109: // ---------------------------------------------------------------------------\n110: // Config File Name\n111: // ---------------------------------------------------------------------------\n112: \n113: export const CONFIG_FILE = \"wombo.json\";\n114: \n115: // ---------------------------------------------------------------------------\n116: // Loader\n117: // ---------------------------------------------------------------------------\n118: \n119: /**\n120:  * Deep-merge source into target. Only merges plain objects, not arrays.\n121:  */\n122: function deepMerge<T extends Record<string, any>>(target: T, source: Partial<T>): T {\n123:   const result = { ...target };\n124:   for (const key of Object.keys(source) as (keyof T)[]) {\n125:     const srcVal = source[key];\n126:     const tgtVal = target[key];\n127:     if (\n128:       srcVal !== undefined &&\n129:       srcVal !== null &&\n130:       typeof srcVal === \"object\" &&\n131:       !Array.isArray(srcVal) &&\n132:       typeof tgtVal === \"object\" &&\n133:       !Array.isArray(tgtVal) &&\n134:       tgtVal !== null\n135:     ) {\n136:       result[key] = deepMerge(tgtVal as any, srcVal as any);\n137:     } else if (srcVal !== undefined) {\n138:       result[key] = srcVal as T[keyof T];\n139:     }\n140:   }\n141:   return result;\n142: }\n143: \n144: /**\n145:  * Load wombo.json from the given project root and merge with defaults.\n146:  * Returns the full config. If no config file exists, returns defaults.\n147:  */\n148: export function loadConfig(projectRoot: string): WomboConfig {\n149:   const configPath = resolve(projectRoot, CONFIG_FILE);\n150: \n151:   if (!existsSync(configPath)) {\n152:     return { ...DEFAULT_CONFIG };\n153:   }\n154: \n155:   try {\n156:     const raw = readFileSync(configPath, \"utf-8\");\n157:     const partial = JSON.parse(raw) as Partial<WomboConfig>;\n158:     return deepMerge(DEFAULT_CONFIG, partial);\n159:   } catch (err: any) {\n160:     throw new Error(`Failed to load ${CONFIG_FILE}: ${err.message}`);\n161:   }\n162: }\n163: \n164: /**\n165:  * Resolve the agent binary path. Priority:\n166:  *   1. config.agent.bin (explicit)\n167:  *   2. OPENCODE_BIN env var\n168:  *   3. ~/.opencode/bin/opencode (default install location)\n169:  */\n170: export function resolveAgentBin(config: WomboConfig): string {\n171:   if (config.agent.bin) return config.agent.bin;\n172:   if (process.env.OPENCODE_BIN) return process.env.OPENCODE_BIN;\n173:   return resolve(process.env.HOME || \"~\", \".opencode/bin/opencode\");\n174: }\n175: \n176: /**\n177:  * Validate the config for obvious issues. Throws on error.\n178:  */\n179: export function validateConfig(config: WomboConfig): void {\n180:   if (!config.featuresFile) {\n181:     throw new Error(\"config.featuresFile must be a non-empty string\");\n182:   }\n183:   if (!config.baseBranch) {\n184:     throw new Error(\"config.baseBranch must be a non-empty string\");\n185:   }\n186:   if (!config.build.command) {\n187:     throw new Error(\"config.build.command must be a non-empty string\");\n188:   }\n189:   if (!config.install.command) {\n190:     throw new Error(\"config.install.command must be a non-empty string\");\n191:   }\n192:   if (!config.git.branchPrefix) {\n193:     throw new Error(\"config.git.branchPrefix must be a non-empty string\");\n194:   }\n195:   if (!config.git.worktreePrefix) {\n196:     throw new Error(\"config.git.worktreePrefix must be a non-empty string\");\n197:   }\n198:   if (config.defaults.maxConcurrent < 1) {\n199:     throw new Error(\"config.defaults.maxConcurrent must be >= 1\");\n200:   }\n201:   if (config.defaults.maxRetries < 0) {\n202:     throw new Error(\"config.defaults.maxRetries must be >= 0\");\n203:   }\n204:   if (config.backup.maxBackups < 0) {\n205:     throw new Error(\"config.backup.maxBackups must be >= 0\");\n206:   }\n207: }\n208: \n209: /**\n210:  * Generate the default wombo.json content string (for `wombo init`).\n211:  */\n212: export function generateDefaultConfig(): string {\n213:   return JSON.stringify(DEFAULT_CONFIG, null, 2) + \"\\n\";\n214: }\n\n(End of file - total 214 lines)\n</content>","title":"src/config.ts","metadata":{"preview":"/**\n * config.ts — Load wombo.json, merge with defaults, validate, expose typed config.\n *\n * The config file lives at the target project root (the repo being orchestrated).\n * All values have sensible defaults so minimal config works out of the box.\n */\n\nimport { readFileSync, existsSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface WomboConfig {\n  /** Path to the features YAML file relative to project root */\n  featuresFile: string;\n  /** Base branch to create feature branches from */\n  baseBranch: string;\n  /** Build configuration */","truncated":false,"loaded":[]},"time":{"start":1773351932395,"end":1773351932405}}}}
