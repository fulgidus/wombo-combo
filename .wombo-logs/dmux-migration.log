{"type":"tool_use","timestamp":1773352367089,"sessionID":"ses_31bfd06f5ffeleRCi6uuMulALr","part":{"id":"prt_ce409b120001AKkj3DKHdiWIfy","sessionID":"ses_31bfd06f5ffeleRCi6uuMulALr","messageID":"msg_ce409a37e001pbDc1ENutT4xtv","type":"tool","callID":"toolu_vrtx_015uVs3J7wv1FoiwCnginaGs","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-dmux-migration/src/lib/multiplexer.ts"},"output":"<path>/home/fulgidus/Documents/wombo-dmux-migration/src/lib/multiplexer.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * multiplexer.ts — Abstraction layer for terminal multiplexers (dmux/tmux).\n3:  *\n4:  * Provides a unified API for session management that works with either\n5:  * dmux (preferred, Rust-based) or tmux (fallback). Auto-detects which\n6:  * multiplexer is available, preferring dmux when both are present.\n7:  *\n8:  * Configurable via wombo.json `agent.multiplexer` field:\n9:  *   - \"auto\"  — prefer dmux, fall back to tmux (default)\n10:  *   - \"dmux\"  — use dmux only (error if not available)\n11:  *   - \"tmux\"  — use tmux only (error if not available)\n12:  */\n13: \n14: import { execSync } from \"node:child_process\";\n15: \n16: // ---------------------------------------------------------------------------\n17: // Types\n18: // ---------------------------------------------------------------------------\n19: \n20: export type MultiplexerBackend = \"dmux\" | \"tmux\";\n21: export type MultiplexerPreference = \"auto\" | \"dmux\" | \"tmux\";\n22: \n23: export interface MultiplexerInfo {\n24:   /** Which backend is active */\n25:   backend: MultiplexerBackend;\n26:   /** The binary name (e.g., \"dmux\" or \"tmux\") */\n27:   bin: string;\n28: }\n29: \n30: // ---------------------------------------------------------------------------\n31: // Detection\n32: // ---------------------------------------------------------------------------\n33: \n34: /** Cache the detection result so we only check once per process. */\n35: let cachedDetection: MultiplexerInfo | null = null;\n36: let cachedPreference: MultiplexerPreference | null = null;\n37: \n38: function isAvailable(bin: string): boolean {\n39:   try {\n40:     execSync(`which ${bin}`, { encoding: \"utf-8\", stdio: \"pipe\" });\n41:     return true;\n42:   } catch {\n43:     return false;\n44:   }\n45: }\n46: \n47: /**\n48:  * Detect which multiplexer is available. Results are cached.\n49:  *\n50:  * @param preference - User preference from config (\"auto\", \"dmux\", \"tmux\")\n51:  * @returns MultiplexerInfo with the selected backend\n52:  * @throws Error if the preferred multiplexer is not available\n53:  */\n54: export function detectMultiplexer(\n55:   preference: MultiplexerPreference = \"auto\"\n56: ): MultiplexerInfo {\n57:   // Return cached result if preference hasn't changed\n58:   if (cachedDetection && cachedPreference === preference) {\n59:     return cachedDetection;\n60:   }\n61: \n62:   let result: MultiplexerInfo;\n63: \n64:   switch (preference) {\n65:     case \"dmux\":\n66:       if (!isAvailable(\"dmux\")) {\n67:         throw new Error(\n68:           \"dmux is configured as the multiplexer but is not installed. \" +\n69:             \"Install dmux or set agent.multiplexer to 'auto' or 'tmux' in wombo.json.\"\n70:         );\n71:       }\n72:       result = { backend: \"dmux\", bin: \"dmux\" };\n73:       break;\n74: \n75:     case \"tmux\":\n76:       if (!isAvailable(\"tmux\")) {\n77:         throw new Error(\n78:           \"tmux is configured as the multiplexer but is not installed. \" +\n79:             \"Install tmux or set agent.multiplexer to 'auto' or 'dmux' in wombo.json.\"\n80:         );\n81:       }\n82:       result = { backend: \"tmux\", bin: \"tmux\" };\n83:       break;\n84: \n85:     case \"auto\":\n86:     default:\n87:       if (isAvailable(\"dmux\")) {\n88:         result = { backend: \"dmux\", bin: \"dmux\" };\n89:       } else if (isAvailable(\"tmux\")) {\n90:         result = { backend: \"tmux\", bin: \"tmux\" };\n91:       } else {\n92:         throw new Error(\n93:           \"No terminal multiplexer found. Install dmux (preferred) or tmux.\\n\" +\n94:             \"  dmux: https://github.com/nicholasgasior/dmux\\n\" +\n95:             \"  tmux: https://github.com/tmux/tmux\"\n96:         );\n97:       }\n98:       break;\n99:   }\n100: \n101:   cachedDetection = result;\n102:   cachedPreference = preference;\n103:   return result;\n104: }\n105: \n106: /**\n107:  * Reset the cached detection (useful for testing or config changes).\n108:  */\n109: export function resetMultiplexerCache(): void {\n110:   cachedDetection = null;\n111:   cachedPreference = null;\n112: }\n113: \n114: // ---------------------------------------------------------------------------\n115: // Helpers\n116: // ---------------------------------------------------------------------------\n117: \n118: function runSilent(cmd: string): string {\n119:   try {\n120:     return execSync(cmd, { encoding: \"utf-8\", stdio: \"pipe\" }).trim();\n121:   } catch {\n122:     return \"\";\n123:   }\n124: }\n125: \n126: // ---------------------------------------------------------------------------\n127: // Unified Session Management API\n128: // ---------------------------------------------------------------------------\n129: \n130: /**\n131:  * Create a new detached session running a command.\n132:  */\n133: export function muxNewSession(\n134:   mux: MultiplexerInfo,\n135:   sessionName: string,\n136:   workDir: string,\n137:   command: string\n138: ): void {\n139:   switch (mux.backend) {\n140:     case \"dmux\":\n141:       execSync(\n142:         `dmux new-session -d -s \"${sessionName}\" -c \"${workDir}\" \"${command}\"`,\n143:         { stdio: \"pipe\" }\n144:       );\n145:       break;\n146:     case \"tmux\":\n147:       execSync(\n148:         `tmux new-session -d -s \"${sessionName}\" -c \"${workDir}\" \"${command}\"`,\n149:         { stdio: \"pipe\" }\n150:       );\n151:       break;\n152:   }\n153: }\n154: \n155: /**\n156:  * Check if a session with the given name exists.\n157:  */\n158: export function muxHasSession(\n159:   mux: MultiplexerInfo,\n160:   sessionName: string\n161: ): boolean {\n162:   switch (mux.backend) {\n163:     case \"dmux\":\n164:       return (\n165:         runSilent(\n166:           `dmux has-session -t \"${sessionName}\" 2>/dev/null && echo yes`\n167:         ) === \"yes\"\n168:       );\n169:     case \"tmux\":\n170:       return (\n171:         runSilent(\n172:           `tmux has-session -t \"${sessionName}\" 2>/dev/null && echo yes`\n173:         ) === \"yes\"\n174:       );\n175:   }\n176: }\n177: \n178: /**\n179:  * Kill a specific session.\n180:  */\n181: export function muxKillSession(\n182:   mux: MultiplexerInfo,\n183:   sessionName: string\n184: ): void {\n185:   switch (mux.backend) {\n186:     case \"dmux\":\n187:       runSilent(`dmux kill-session -t \"${sessionName}\" 2>/dev/null`);\n188:       break;\n189:     case \"tmux\":\n190:       runSilent(`tmux kill-session -t \"${sessionName}\" 2>/dev/null`);\n191:       break;\n192:   }\n193: }\n194: \n195: /**\n196:  * List all session names.\n197:  */\n198: export function muxListSessions(mux: MultiplexerInfo): string[] {\n199:   let output: string;\n200:   switch (mux.backend) {\n201:     case \"dmux\":\n202:       output = runSilent(\n203:         `dmux list-sessions -F \"#{session_name}\" 2>/dev/null`\n204:       );\n205:       break;\n206:     case \"tmux\":\n207:       output = runSilent(\n208:         `tmux list-sessions -F \"#{session_name}\" 2>/dev/null`\n209:       );\n210:       break;\n211:   }\n212:   if (!output) return [];\n213:   return output.split(\"\\n\").filter(Boolean);\n214: }\n215: \n216: /**\n217:  * Get the PID of the main pane in a session.\n218:  */\n219: export function muxGetPanePid(\n220:   mux: MultiplexerInfo,\n221:   sessionName: string\n222: ): number {\n223:   let output: string;\n224:   switch (mux.backend) {\n225:     case \"dmux\":\n226:       output = runSilent(\n227:         `dmux list-panes -t \"${sessionName}\" -F \"#{pane_pid}\"`\n228:       );\n229:       break;\n230:     case \"tmux\":\n231:       output = runSilent(\n232:         `tmux list-panes -t \"${sessionName}\" -F \"#{pane_pid}\"`\n233:       );\n234:       break;\n235:   }\n236:   return parseInt(output) || 0;\n237: }\n238: \n239: /**\n240:  * Load text into the paste buffer.\n241:  */\n242: export function muxLoadBuffer(\n243:   mux: MultiplexerInfo,\n244:   filePath: string\n245: ): void {\n246:   switch (mux.backend) {\n247:     case \"dmux\":\n248:       execSync(`dmux load-buffer \"${filePath}\"`, { stdio: \"pipe\" });\n249:       break;\n250:     case \"tmux\":\n251:       execSync(`tmux load-buffer \"${filePath}\"`, { stdio: \"pipe\" });\n252:       break;\n253:   }\n254: }\n255: \n256: /**\n257:  * Paste the buffer into a session.\n258:  */\n259: export function muxPasteBuffer(\n260:   mux: MultiplexerInfo,\n261:   sessionName: string\n262: ): void {\n263:   switch (mux.backend) {\n264:     case \"dmux\":\n265:       execSync(`dmux paste-buffer -t \"${sessionName}\"`, { stdio: \"pipe\" });\n266:       break;\n267:     case \"tmux\":\n268:       execSync(`tmux paste-buffer -t \"${sessionName}\"`, { stdio: \"pipe\" });\n269:       break;\n270:   }\n271: }\n272: \n273: /**\n274:  * Send keys (e.g., Enter) to a session.\n275:  */\n276: export function muxSendKeys(\n277:   mux: MultiplexerInfo,\n278:   sessionName: string,\n279:   keys: string\n280: ): void {\n281:   switch (mux.backend) {\n282:     case \"dmux\":\n283:       execSync(`dmux send-keys -t \"${sessionName}\" ${keys}`, {\n284:         stdio: \"pipe\",\n285:       });\n286:       break;\n287:     case \"tmux\":\n288:       execSync(`tmux send-keys -t \"${sessionName}\" ${keys}`, {\n289:         stdio: \"pipe\",\n290:       });\n291:       break;\n292:   }\n293: }\n294: \n295: /**\n296:  * Attach to a session (blocks until user detaches).\n297:  */\n298: export function muxAttach(\n299:   mux: MultiplexerInfo,\n300:   sessionName: string\n301: ): void {\n302:   switch (mux.backend) {\n303:     case \"dmux\":\n304:       execSync(`dmux attach -t \"${sessionName}\"`, { stdio: \"inherit\" });\n305:       break;\n306:     case \"tmux\":\n307:       execSync(`tmux attach -t \"${sessionName}\"`, { stdio: \"inherit\" });\n308:       break;\n309:   }\n310: }\n311: \n312: /**\n313:  * Get the multiplexer name for display purposes.\n314:  * Returns \"dmux\" or \"tmux\".\n315:  */\n316: export function muxDisplayName(mux: MultiplexerInfo): string {\n317:   return mux.backend;\n318: }\n319: \n320: /**\n321:  * Build the attach command string (for display to user).\n322:  */\n323: export function muxAttachCommand(\n324:   mux: MultiplexerInfo,\n325:   sessionName: string\n326: ): string {\n327:   return `${mux.bin} attach -t ${sessionName}`;\n328: }\n329: \n330: /**\n331:  * Build the list-sessions command string (for display to user).\n332:  */\n333: export function muxListCommand(mux: MultiplexerInfo): string {\n334:   return `${mux.bin} ls`;\n335: }\n\n(End of file - total 335 lines)\n</content>","title":"src/lib/multiplexer.ts","metadata":{"preview":"/**\n * multiplexer.ts — Abstraction layer for terminal multiplexers (dmux/tmux).\n *\n * Provides a unified API for session management that works with either\n * dmux (preferred, Rust-based) or tmux (fallback). Auto-detects which\n * multiplexer is available, preferring dmux when both are present.\n *\n * Configurable via wombo.json `agent.multiplexer` field:\n *   - \"auto\"  — prefer dmux, fall back to tmux (default)\n *   - \"dmux\"  — use dmux only (error if not available)\n *   - \"tmux\"  — use tmux only (error if not available)\n */\n\nimport { execSync } from \"node:child_process\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type MultiplexerBackend = \"dmux\" | \"tmux\";","truncated":false,"loaded":[]},"time":{"start":1773352367087,"end":1773352367088}}}}
{"type":"tool_use","timestamp":1773352367916,"sessionID":"ses_31bfd06f5ffeleRCi6uuMulALr","part":{"id":"prt_ce409b4b90010J9ksxHJwLqKxW","sessionID":"ses_31bfd06f5ffeleRCi6uuMulALr","messageID":"msg_ce409a37e001pbDc1ENutT4xtv","type":"tool","callID":"toolu_vrtx_01CgZ6w5b9dNYavPJSz5si18","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-dmux-migration/src/config.ts"},"output":"<path>/home/fulgidus/Documents/wombo-dmux-migration/src/config.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * config.ts — Load wombo.json, merge with defaults, validate, expose typed config.\n3:  *\n4:  * The config file lives at the target project root (the repo being orchestrated).\n5:  * All values have sensible defaults so minimal config works out of the box.\n6:  */\n7: \n8: import { readFileSync, existsSync } from \"node:fs\";\n9: import { resolve } from \"node:path\";\n10: import type { MultiplexerPreference } from \"./lib/multiplexer.js\";\n11: \n12: // ---------------------------------------------------------------------------\n13: // Types\n14: // ---------------------------------------------------------------------------\n15: \n16: export interface WomboConfig {\n17:   /** Path to the features YAML file relative to project root */\n18:   featuresFile: string;\n19:   /** Base branch to create feature branches from */\n20:   baseBranch: string;\n21:   /** Build configuration */\n22:   build: {\n23:     /** Build command to run in worktrees */\n24:     command: string;\n25:     /** Build timeout in milliseconds */\n26:     timeout: number;\n27:     /** Build artifact directory (for quick \"did it build?\" checks) */\n28:     artifactDir: string;\n29:   };\n30:   /** Install configuration */\n31:   install: {\n32:     /** Install command to run in worktrees */\n33:     command: string;\n34:     /** Install timeout in milliseconds */\n35:     timeout: number;\n36:   };\n37:   /** Git configuration */\n38:   git: {\n39:     /** Branch name prefix for feature branches */\n40:     branchPrefix: string;\n41:     /** Worktree directory name prefix */\n42:     worktreePrefix: string;\n43:     /** Git remote name */\n44:     remote: string;\n45:     /** Merge strategy flag */\n46:     mergeStrategy: string;\n47:   };\n48:   /** Agent configuration */\n49:   agent: {\n50:     /** Path to agent binary (null = auto-detect) */\n51:     bin: string | null;\n52:     /** Agent name to pass via --agent flag */\n53:     name: string;\n54:     /** Config files/dirs to copy into worktrees */\n55:     configFiles: string[];\n56:     /** Session name prefix for terminal multiplexer */\n57:     tmuxPrefix: string;\n58:     /** Terminal multiplexer preference: \"auto\" (prefer dmux), \"dmux\", or \"tmux\" */\n59:     multiplexer: MultiplexerPreference;\n60:   };\n61:   /** Backup configuration for features file */\n62:   backup: {\n63:     /** Maximum number of timestamped backups to keep */\n64:     maxBackups: number;\n65:   };\n66:   /** Default runtime values */\n67:   defaults: {\n68:     /** Max concurrent agents */\n69:     maxConcurrent: number;\n70:     /** Max retries per agent */\n71:     maxRetries: number;\n72:   };\n73: }\n74: \n75: // ---------------------------------------------------------------------------\n76: // Defaults\n77: // ---------------------------------------------------------------------------\n78: \n79: export const DEFAULT_CONFIG: WomboConfig = {\n80:   featuresFile: \".features.yml\",\n81:   baseBranch: \"develop\",\n82:   build: {\n83:     command: \"bun run build\",\n84:     timeout: 300_000,\n85:     artifactDir: \"dist\",\n86:   },\n87:   install: {\n88:     command: \"bun install\",\n89:     timeout: 120_000,\n90:   },\n91:   git: {\n92:     branchPrefix: \"feature/\",\n93:     worktreePrefix: \"wombo-\",\n94:     remote: \"origin\",\n95:     mergeStrategy: \"--no-ff\",\n96:   },\n97:   agent: {\n98:     bin: null,\n99:     name: \"wave-worker\",\n100:     configFiles: [\".opencode/\", \"opencode.json\", \"AGENTS.md\", \"agent/\"],\n101:     tmuxPrefix: \"wombo\",\n102:     multiplexer: \"auto\",\n103:   },\n104:   backup: {\n105:     maxBackups: 5,\n106:   },\n107:   defaults: {\n108:     maxConcurrent: 6,\n109:     maxRetries: 2,\n110:   },\n111: };\n112: \n113: // ---------------------------------------------------------------------------\n114: // Config File Name\n115: // ---------------------------------------------------------------------------\n116: \n117: export const CONFIG_FILE = \"wombo.json\";\n118: \n119: // ---------------------------------------------------------------------------\n120: // Loader\n121: // ---------------------------------------------------------------------------\n122: \n123: /**\n124:  * Deep-merge source into target. Only merges plain objects, not arrays.\n125:  */\n126: function deepMerge<T extends Record<string, any>>(target: T, source: Partial<T>): T {\n127:   const result = { ...target };\n128:   for (const key of Object.keys(source) as (keyof T)[]) {\n129:     const srcVal = source[key];\n130:     const tgtVal = target[key];\n131:     if (\n132:       srcVal !== undefined &&\n133:       srcVal !== null &&\n134:       typeof srcVal === \"object\" &&\n135:       !Array.isArray(srcVal) &&\n136:       typeof tgtVal === \"object\" &&\n137:       !Array.isArray(tgtVal) &&\n138:       tgtVal !== null\n139:     ) {\n140:       result[key] = deepMerge(tgtVal as any, srcVal as any);\n141:     } else if (srcVal !== undefined) {\n142:       result[key] = srcVal as T[keyof T];\n143:     }\n144:   }\n145:   return result;\n146: }\n147: \n148: /**\n149:  * Load wombo.json from the given project root and merge with defaults.\n150:  * Returns the full config. If no config file exists, returns defaults.\n151:  */\n152: export function loadConfig(projectRoot: string): WomboConfig {\n153:   const configPath = resolve(projectRoot, CONFIG_FILE);\n154: \n155:   if (!existsSync(configPath)) {\n156:     return { ...DEFAULT_CONFIG };\n157:   }\n158: \n159:   try {\n160:     const raw = readFileSync(configPath, \"utf-8\");\n161:     const partial = JSON.parse(raw) as Partial<WomboConfig>;\n162:     return deepMerge(DEFAULT_CONFIG, partial);\n163:   } catch (err: any) {\n164:     throw new Error(`Failed to load ${CONFIG_FILE}: ${err.message}`);\n165:   }\n166: }\n167: \n168: /**\n169:  * Resolve the agent binary path. Priority:\n170:  *   1. config.agent.bin (explicit)\n171:  *   2. OPENCODE_BIN env var\n172:  *   3. ~/.opencode/bin/opencode (default install location)\n173:  */\n174: export function resolveAgentBin(config: WomboConfig): string {\n175:   if (config.agent.bin) return config.agent.bin;\n176:   if (process.env.OPENCODE_BIN) return process.env.OPENCODE_BIN;\n177:   return resolve(process.env.HOME || \"~\", \".opencode/bin/opencode\");\n178: }\n179: \n180: /**\n181:  * Validate the config for obvious issues. Throws on error.\n182:  */\n183: export function validateConfig(config: WomboConfig): void {\n184:   if (!config.featuresFile) {\n185:     throw new Error(\"config.featuresFile must be a non-empty string\");\n186:   }\n187:   if (!config.baseBranch) {\n188:     throw new Error(\"config.baseBranch must be a non-empty string\");\n189:   }\n190:   if (!config.build.command) {\n191:     throw new Error(\"config.build.command must be a non-empty string\");\n192:   }\n193:   if (!config.install.command) {\n194:     throw new Error(\"config.install.command must be a non-empty string\");\n195:   }\n196:   if (!config.git.branchPrefix) {\n197:     throw new Error(\"config.git.branchPrefix must be a non-empty string\");\n198:   }\n199:   if (!config.git.worktreePrefix) {\n200:     throw new Error(\"config.git.worktreePrefix must be a non-empty string\");\n201:   }\n202:   if (config.defaults.maxConcurrent < 1) {\n203:     throw new Error(\"config.defaults.maxConcurrent must be >= 1\");\n204:   }\n205:   if (config.defaults.maxRetries < 0) {\n206:     throw new Error(\"config.defaults.maxRetries must be >= 0\");\n207:   }\n208:   if (config.backup.maxBackups < 0) {\n209:     throw new Error(\"config.backup.maxBackups must be >= 0\");\n210:   }\n211: }\n212: \n213: /**\n214:  * Generate the default wombo.json content string (for `wombo init`).\n215:  */\n216: export function generateDefaultConfig(): string {\n217:   return JSON.stringify(DEFAULT_CONFIG, null, 2) + \"\\n\";\n218: }\n\n(End of file - total 218 lines)\n</content>","title":"src/config.ts","metadata":{"preview":"/**\n * config.ts — Load wombo.json, merge with defaults, validate, expose typed config.\n *\n * The config file lives at the target project root (the repo being orchestrated).\n * All values have sensible defaults so minimal config works out of the box.\n */\n\nimport { readFileSync, existsSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\nimport type { MultiplexerPreference } from \"./lib/multiplexer.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface WomboConfig {\n  /** Path to the features YAML file relative to project root */\n  featuresFile: string;\n  /** Base branch to create feature branches from */\n  baseBranch: string;","truncated":false,"loaded":[]},"time":{"start":1773352367905,"end":1773352367915}}}}
