{"type":"tool_use","timestamp":1773351941428,"sessionID":"ses_31bfd06f5ffeleRCi6uuMulALr","part":{"id":"prt_ce403347a0014QUVB5Oh9EoJ9m","sessionID":"ses_31bfd06f5ffeleRCi6uuMulALr","messageID":"msg_ce4032631001Qh3VBZpcxsurpq","type":"tool","callID":"toolu_vrtx_01NpcFC4ypYTZAK8oe2VqKVQ","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-dmux-migration/src/commands/cleanup.ts"},"output":"<path>/home/fulgidus/Documents/wombo-dmux-migration/src/commands/cleanup.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * cleanup.ts — Remove all wave-related resources.\n3:  *\n4:  * Usage: wombo cleanup\n5:  *\n6:  * Kills tmux sessions, removes worktrees, removes state and log files.\n7:  */\n8: \n9: import { existsSync, unlinkSync, rmSync } from \"node:fs\";\n10: import { execSync } from \"node:child_process\";\n11: import { resolve } from \"node:path\";\n12: import type { WomboConfig } from \"../config.js\";\n13: import { killAllTmuxSessions } from \"../lib/launcher.js\";\n14: import { cleanupAllWorktrees } from \"../lib/worktree.js\";\n15: \n16: export interface CleanupOptions {\n17:   projectRoot: string;\n18:   config: WomboConfig;\n19:   dryRun?: boolean;\n20: }\n21: \n22: export async function cmdCleanup(opts: CleanupOptions): Promise<void> {\n23:   const { projectRoot, config } = opts;\n24: \n25:   // Dry-run: show what would be cleaned up without doing it\n26:   if (opts.dryRun) {\n27:     console.log(\"\\n[dry-run] Would perform the following cleanup:\\n\");\n28: \n29:     // List tmux sessions that would be killed\n30:     try {\n31:       const sessions = execSync(\"tmux list-sessions -F '#{session_name}'\", {\n32:         encoding: \"utf-8\",\n33:       }).trim();\n34:       const prefix = config.agent.tmuxPrefix;\n35:       const matching = sessions\n36:         .split(\"\\n\")\n37:         .filter((s) => s.startsWith(prefix));\n38:       console.log(`  tmux sessions to kill: ${matching.length}`);\n39:       for (const s of matching) {\n40:         console.log(`    ${s}`);\n41:       }\n42:     } catch {\n43:       console.log(\"  tmux sessions to kill: 0 (no tmux server running)\");\n44:     }\n45: \n46:     // List worktrees that would be removed\n47:     try {\n48:       const worktrees = execSync(\"git worktree list --porcelain\", {\n49:         cwd: projectRoot,\n50:         encoding: \"utf-8\",\n51:       }).trim();\n52:       const prefix = config.git.worktreePrefix;\n53:       const matching = worktrees\n54:         .split(\"\\n\")\n55:         .filter((line) => line.startsWith(\"worktree \") && line.includes(prefix))\n56:         .map((line) => line.replace(\"worktree \", \"\"));\n57:       console.log(`  worktrees to remove: ${matching.length}`);\n58:       for (const w of matching) {\n59:         console.log(`    ${w}`);\n60:       }\n61:     } catch {\n62:       console.log(\"  worktrees to remove: 0\");\n63:     }\n64: \n65:     const statePath = resolve(projectRoot, \".wombo-state.json\");\n66:     const logDir = resolve(projectRoot, \".wombo-logs\");\n67:     if (existsSync(statePath)) console.log(\"  Would remove: .wombo-state.json\");\n68:     if (existsSync(logDir)) console.log(\"  Would remove: .wombo-logs/\");\n69: \n70:     return;\n71:   }\n72: \n73:   console.log(\"\\n--- Wombo: Cleanup ---\\n\");\n74: \n75:   // Kill tmux sessions\n76:   const killed = killAllTmuxSessions(config);\n77:   console.log(`Killed ${killed} tmux session(s)`);\n78: \n79:   // Remove worktrees\n80:   const removed = cleanupAllWorktrees(projectRoot, config);\n81:   console.log(`Removed ${removed} worktree(s)`);\n82: \n83:   // List remaining feature branches\n84:   try {\n85:     const branchPattern = `\"${config.git.branchPrefix}*\"`;\n86:     const branches = execSync(`git branch --list ${branchPattern}`, {\n87:       cwd: projectRoot,\n88:       encoding: \"utf-8\",\n89:     }).trim();\n90:     if (branches) {\n91:       console.log(`\\nRemaining feature branches:\\n${branches}`);\n92:       console.log('Use \"git branch -D <branch>\" to remove manually.');\n93:     }\n94:   } catch {}\n95: \n96:   // Remove state file\n97:   const statePath = resolve(projectRoot, \".wombo-state.json\");\n98:   if (existsSync(statePath)) {\n99:     unlinkSync(statePath);\n100:     console.log(\"Removed .wombo-state.json\");\n101:   }\n102: \n103:   // Remove log directory\n104:   const logDir = resolve(projectRoot, \".wombo-logs\");\n105:   if (existsSync(logDir)) {\n106:     rmSync(logDir, { recursive: true, force: true });\n107:     console.log(\"Removed .wombo-logs/\");\n108:   }\n109: \n110:   console.log(\"\\nCleanup complete.\");\n111: }\n\n(End of file - total 111 lines)\n</content>","title":"src/commands/cleanup.ts","metadata":{"preview":"/**\n * cleanup.ts — Remove all wave-related resources.\n *\n * Usage: wombo cleanup\n *\n * Kills tmux sessions, removes worktrees, removes state and log files.\n */\n\nimport { existsSync, unlinkSync, rmSync } from \"node:fs\";\nimport { execSync } from \"node:child_process\";\nimport { resolve } from \"node:path\";\nimport type { WomboConfig } from \"../config.js\";\nimport { killAllTmuxSessions } from \"../lib/launcher.js\";\nimport { cleanupAllWorktrees } from \"../lib/worktree.js\";\n\nexport interface CleanupOptions {\n  projectRoot: string;\n  config: WomboConfig;\n  dryRun?: boolean;\n}","truncated":false,"loaded":[]},"time":{"start":1773351941423,"end":1773351941427}}}}
{"type":"tool_use","timestamp":1773351941940,"sessionID":"ses_31bfd06f5ffeleRCi6uuMulALr","part":{"id":"prt_ce4033597001qxSwcfBx8HPm0n","sessionID":"ses_31bfd06f5ffeleRCi6uuMulALr","messageID":"msg_ce4032631001Qh3VBZpcxsurpq","type":"tool","callID":"toolu_vrtx_011dT73XFqU443bcesH82ow9","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-dmux-migration/src/commands/abort.ts"},"output":"<path>/home/fulgidus/Documents/wombo-dmux-migration/src/commands/abort.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * abort.ts — Kill a single running agent without nuking the entire wave.\n3:  *\n4:  * Usage: wombo abort <feature-id> [--requeue] [--output json]\n5:  *\n6:  * Kills the tmux session (if any) and the agent process, then updates\n7:  * wave state to mark the agent as \"failed\" (default) or \"queued\"\n8:  * (if --requeue is passed, returning it to the queue for retry).\n9:  */\n10: \n11: import type { WomboConfig } from \"../config.js\";\n12: import {\n13:   loadState,\n14:   saveState,\n15:   updateAgent,\n16:   type AgentState,\n17: } from \"../lib/state.js\";\n18: import {\n19:   killTmuxSession,\n20:   isProcessRunning,\n21: } from \"../lib/launcher.js\";\n22: import { output, outputError, type OutputFormat } from \"../lib/output.js\";\n23: \n24: // ---------------------------------------------------------------------------\n25: // Types\n26: // ---------------------------------------------------------------------------\n27: \n28: export interface AbortCommandOptions {\n29:   projectRoot: string;\n30:   config: WomboConfig;\n31:   featureId: string;\n32:   /** Return the feature to \"queued\" instead of marking it \"failed\" */\n33:   requeue?: boolean;\n34:   outputFmt: OutputFormat;\n35: }\n36: \n37: // ---------------------------------------------------------------------------\n38: // Command\n39: // ---------------------------------------------------------------------------\n40: \n41: export async function cmdAbort(opts: AbortCommandOptions): Promise<void> {\n42:   const { projectRoot, config, featureId, outputFmt } = opts;\n43: \n44:   // Load wave state\n45:   const state = loadState(projectRoot);\n46:   if (!state) {\n47:     outputError(outputFmt, \"No active wave. Nothing to abort.\");\n48:   }\n49: \n50:   // Find the agent\n51:   const agent = state.agents.find((a: AgentState) => a.feature_id === featureId);\n52:   if (!agent) {\n53:     outputError(\n54:       outputFmt,\n55:       `Agent not found for feature: ${featureId}. Use 'wombo status' to see active agents.`\n56:     );\n57:   }\n58: \n59:   // Only abort agents that are actually active (running, installing, queued, resolving_conflict)\n60:   const abortable = new Set([\"running\", \"installing\", \"queued\", \"resolving_conflict\"]);\n61:   if (!abortable.has(agent.status)) {\n62:     outputError(\n63:       outputFmt,\n64:       `Agent ${featureId} is not in an abortable state (current: ${agent.status}). ` +\n65:         `Only running, installing, queued, or resolving_conflict agents can be aborted.`\n66:     );\n67:   }\n68: \n69:   // 1. Kill the tmux session (if any)\n70:   let tmuxKilled = false;\n71:   try {\n72:     killTmuxSession(featureId, config);\n73:     tmuxKilled = true;\n74:   } catch {\n75:     // Session may not exist — that's fine\n76:   }\n77: \n78:   // 2. Kill the process by PID (if any and still running)\n79:   let processKilled = false;\n80:   if (agent.pid && isProcessRunning(agent.pid)) {\n81:     try {\n82:       process.kill(agent.pid, \"SIGTERM\");\n83:       processKilled = true;\n84:     } catch {\n85:       // Process may have already exited\n86:     }\n87:   }\n88: \n89:   // 3. Update wave state\n90:   const newStatus = opts.requeue ? \"queued\" : \"failed\";\n91:   const updates: Partial<AgentState> = {\n92:     status: newStatus as AgentState[\"status\"],\n93:     error: opts.requeue ? null : \"Aborted by user\",\n94:     completed_at: opts.requeue ? null : new Date().toISOString(),\n95:   };\n96: \n97:   // If requeuing, reset retry-related fields so the agent gets a fresh start\n98:   if (opts.requeue) {\n99:     updates.retries = 0;\n100:     updates.build_passed = null;\n101:     updates.build_output = null;\n102:     updates.started_at = null;\n103:     updates.completed_at = null;\n104:     updates.activity = null;\n105:     updates.activity_updated_at = null;\n106:   }\n107: \n108:   updateAgent(state, featureId, updates);\n109:   saveState(projectRoot, state);\n110: \n111:   // 4. Output result\n112:   const result = {\n113:     feature_id: featureId,\n114:     previous_status: agent.status,\n115:     new_status: newStatus,\n116:     tmux_killed: tmuxKilled,\n117:     process_killed: processKilled,\n118:     requeued: !!opts.requeue,\n119:   };\n120: \n121:   output(outputFmt, result, () => {\n122:     console.log(`\\nAborted agent: ${featureId}`);\n123:     console.log(`  Previous status: ${agent.status}`);\n124:     console.log(`  New status: ${newStatus}`);\n125:     if (tmuxKilled) console.log(`  Killed tmux session: ${config.agent.tmuxPrefix}-${featureId}`);\n126:     if (processKilled) console.log(`  Killed process: PID ${agent.pid}`);\n127:     if (opts.requeue) {\n128:       console.log(`  Feature returned to queue for retry.`);\n129:     } else {\n130:       console.log(`  Feature marked as failed.`);\n131:     }\n132:   });\n133: }\n\n(End of file - total 133 lines)\n</content>","title":"src/commands/abort.ts","metadata":{"preview":"/**\n * abort.ts — Kill a single running agent without nuking the entire wave.\n *\n * Usage: wombo abort <feature-id> [--requeue] [--output json]\n *\n * Kills the tmux session (if any) and the agent process, then updates\n * wave state to mark the agent as \"failed\" (default) or \"queued\"\n * (if --requeue is passed, returning it to the queue for retry).\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport {\n  loadState,\n  saveState,\n  updateAgent,\n  type AgentState,\n} from \"../lib/state.js\";\nimport {\n  killTmuxSession,\n  isProcessRunning,","truncated":false,"loaded":[]},"time":{"start":1773351941932,"end":1773351941938}}}}
{"type":"tool_use","timestamp":1773351942503,"sessionID":"ses_31bfd06f5ffeleRCi6uuMulALr","part":{"id":"prt_ce4033794001785UvXLWDF7hj7","sessionID":"ses_31bfd06f5ffeleRCi6uuMulALr","messageID":"msg_ce4032631001Qh3VBZpcxsurpq","type":"tool","callID":"toolu_vrtx_01Hq4HPQr4XcU9asZT1qmN9P","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-dmux-migration/src/commands/launch.ts"},"output":"<path>/home/fulgidus/Documents/wombo-dmux-migration/src/commands/launch.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * launch.ts — Launch a wave of agents.\n3:  *\n4:  * Usage: wombo launch [selection options] [launch options]\n5:  *\n6:  * This is the primary entry point for starting a new wave. It selects features\n7:  * from the features file, creates a wave state, sets up worktrees, and launches\n8:  * agent processes (either headless or interactive via tmux).\n9:  *\n10:  * IMPORTANT: This file also exports shared helper functions that are reused\n11:  * by resume.ts and other commands:\n12:  *   - launchSingleHeadless\n13:  *   - handleBuildVerification\n14:  *   - handleRetry\n15:  *   - launchNextQueued\n16:  */\n17: \n18: import { execSync } from \"node:child_process\";\n19: import type { WomboConfig } from \"../config.js\";\n20: import type { Feature, SelectionOptions, Priority, Difficulty } from \"../lib/features.js\";\n21: import { loadFeatures, selectFeatures, parseDurationMinutes, saveFeatures } from \"../lib/features.js\";\n22: import {\n23:   loadState,\n24:   saveState,\n25:   createWaveState,\n26:   createAgentState,\n27:   updateAgent,\n28:   activeAgents,\n29:   queuedAgents,\n30:   isWaveComplete,\n31:   type WaveState,\n32:   type AgentState,\n33: } from \"../lib/state.js\";\n34: import {\n35:   createWorktree,\n36:   installDeps,\n37:   featureBranchName,\n38:   worktreePath,\n39:   worktreeReady,\n40:   branchHasChanges,\n41:   branchExists,\n42:   removeWorktree,\n43:   log as wtLog,\n44: } from \"../lib/worktree.js\";\n45: import { generatePrompt, generateConflictResolutionPrompt } from \"../lib/prompt.js\";\n46: import {\n47:   launchHeadless,\n48:   retryHeadless,\n49:   launchInteractive,\n50:   retryInteractive,\n51:   launchConflictResolver,\n52:   isProcessRunning,\n53: } from \"../lib/launcher.js\";\n54: import { ProcessMonitor } from \"../lib/monitor.js\";\n55: import { runBuild } from \"../lib/verifier.js\";\n56: import { mergeBranch, mergeBaseIntoFeature, pushBaseBranch } from \"../lib/merger.js\";\n57: import {\n58:   printDashboard,\n59:   printFeatureSelection,\n60:   printAgentUpdate,\n61: } from \"../lib/ui.js\";\n62: import { WomboTUI } from \"../lib/tui.js\";\n63: import { ensureAgentDefinition } from \"../lib/templates.js\";\n64: import { outputError, type OutputFormat } from \"../lib/output.js\";\n65: \n66: // ---------------------------------------------------------------------------\n67: // Types\n68: // ---------------------------------------------------------------------------\n69: \n70: export interface LaunchCommandOptions {\n71:   projectRoot: string;\n72:   config: WomboConfig;\n73:   // Selection\n74:   topPriority?: number;\n75:   quickestWins?: number;\n76:   priority?: Priority;\n77:   difficulty?: Difficulty;\n78:   features?: string[];\n79:   allReady?: boolean;\n80:   // Launch\n81:   maxConcurrent: number;\n82:   model?: string;\n83:   interactive: boolean;\n84:   dryRun: boolean;\n85:   baseBranch: string;\n86:   maxRetries: number;\n87:   noTui: boolean;\n88:   autoPush: boolean;\n89:   // Output\n90:   outputFmt?: OutputFormat;\n91: }\n92: \n93: // ---------------------------------------------------------------------------\n94: // Shared Helpers (exported for resume.ts and others)\n95: // ---------------------------------------------------------------------------\n96: \n97: /**\n98:  * Mark a feature as done in the features file after a successful merge.\n99:  * Updates status to \"done\", completion to 100, and sets ended_at.\n100:  *\n101:  * GUARD: Verifies that the feature branch has actually been merged into\n102:  * baseBranch before allowing the status change. This prevents callers\n103:  * from accidentally marking verified-but-unmerged features as done.\n104:  */\n105: export function markFeatureDone(\n106:   projectRoot: string,\n107:   featureId: string,\n108:   config: WomboConfig,\n109:   baseBranch: string\n110: ): void {\n111:   try {\n112:     // Verify the feature branch was actually merged into base\n113:     const branch = featureBranchName(featureId, config);\n114:     try {\n115:       execSync(`git merge-base --is-ancestor \"${branch}\" \"${baseBranch}\"`, {\n116:         cwd: projectRoot,\n117:         stdio: \"pipe\",\n118:       });\n119:     } catch {\n120:       // git merge-base --is-ancestor exits non-zero if NOT an ancestor\n121:       console.error(\n122:         `Warning: ${featureId} branch \"${branch}\" is not merged into \"${baseBranch}\" — refusing to mark as done`\n123:       );\n124:       return;\n125:     }\n126: \n127:     const data = loadFeatures(projectRoot, config);\n128:     const feature = data.features.find((f) => f.id === featureId);\n129:     if (feature && feature.status !== \"done\") {\n130:       feature.status = \"done\";\n131:       feature.completion = 100;\n132:       feature.ended_at = new Date().toISOString();\n133:       saveFeatures(projectRoot, config, data);\n134:     }\n135:   } catch (err: any) {\n136:     // Non-fatal — log but don't crash the wave\n137:     console.error(`Warning: failed to update feature status for ${featureId}: ${err.message}`);\n138:   }\n139: }\n140: \n141: /**\n142:  * Launch a single agent in headless mode.\n143:  * Sets up worktree, installs deps, generates prompt, launches agent process.\n144:  */\n145: export async function launchSingleHeadless(\n146:   projectRoot: string,\n147:   state: WaveState,\n148:   agent: AgentState,\n149:   feature: Feature,\n150:   monitor: ProcessMonitor,\n151:   config: WomboConfig,\n152:   model?: string\n153: ): Promise<void> {\n154:   updateAgent(state, agent.feature_id, {\n155:     status: \"installing\",\n156:     started_at: new Date().toISOString(),\n157:     activity: \"setting up worktree...\",\n158:   });\n159:   saveState(projectRoot, state);\n160: \n161:   try {\n162:     // Skip worktree setup if already ready (resume case)\n163:     if (worktreeReady(agent.worktree)) {\n164:       wtLog(agent.feature_id, \"worktree already exists, skipping setup\");\n165:     } else {\n166:       // Create worktree (async — doesn't block other agents)\n167:       await createWorktree(projectRoot, feature.id, state.base_branch, config);\n168: \n169:       // Install dependencies (async)\n170:       updateAgent(state, agent.feature_id, { activity: \"installing deps...\" });\n171:       await installDeps(agent.worktree, feature.id, config);\n172:     }\n173: \n174:     // Generate prompt\n175:     const prompt = generatePrompt(feature, state.base_branch, config);\n176: \n177:     // Launch agent\n178:     wtLog(agent.feature_id, \"launching agent...\");\n179:     const result = launchHeadless({\n180:       worktreePath: agent.worktree,\n181:       featureId: feature.id,\n182:       prompt,\n183:       model,\n184:       config,\n185:     });\n186: \n187:     updateAgent(state, agent.feature_id, {\n188:       status: \"running\",\n189:       pid: result.pid,\n190:       activity: \"starting...\",\n191:     });\n192:     saveState(projectRoot, state);\n193: \n194:     monitor.addProcess(feature.id, result.process);\n195:     wtLog(agent.feature_id, `running (PID: ${result.pid})`);\n196:   } catch (err: any) {\n197:     updateAgent(state, agent.feature_id, {\n198:       status: \"failed\",\n199:       error: err.message,\n200:       activity: null,\n201:       completed_at: new Date().toISOString(),\n202:     });\n203:     saveState(projectRoot, state);\n204:     wtLog(agent.feature_id, `SETUP FAILED: ${err.message.split(\"\\n\")[0]}`);\n205:   }\n206: }\n207: \n208: /**\n209:  * Handle build verification after agent completion.\n210:  * Runs build, auto-merges on pass, retries on failure if retries remain.\n211:  *\n212:  * ASYNC — runs build and merge without blocking the event loop.\n213:  */\n214: export async function handleBuildVerification(\n215:   projectRoot: string,\n216:   state: WaveState,\n217:   agent: AgentState,\n218:   feature: Feature,\n219:   config: WomboConfig,\n220:   model?: string,\n221:   monitor?: ProcessMonitor\n222: ): Promise<void> {\n223:   try {\n224:     printAgentUpdate(agent, \"verifying build...\");\n225: \n226:     const buildResult = await runBuild(agent.worktree, config);\n227: \n228:     if (buildResult.passed) {\n229:       updateAgent(state, agent.feature_id, {\n230:         status: \"verified\",\n231:         build_passed: true,\n232:         build_output: null,\n233:       });\n234:       saveState(projectRoot, state);\n235:       printAgentUpdate(agent, `BUILD PASSED (${Math.round(buildResult.durationMs / 1000)}s)`);\n236: \n237:       // Auto-merge: attempt merge + conflict resolution\n238:       await attemptMerge(projectRoot, state, agent, feature, config, model);\n239:     } else {\n240:       if (agent.retries < agent.max_retries) {\n241:         updateAgent(state, agent.feature_id, {\n242:           status: \"retry\",\n243:           retries: agent.retries + 1,\n244:           build_passed: false,\n245:           build_output: buildResult.errorSummary,\n246:         });\n247:         saveState(projectRoot, state);\n248:         printAgentUpdate(\n249:           agent,\n250:           `BUILD FAILED — retrying (${agent.retries}/${agent.max_retries})`\n251:         );\n252: \n253:         // Retry with build errors\n254:         if (agent.session_id) {\n255:           const retryResult = retryHeadless({\n256:             worktreePath: agent.worktree,\n257:             featureId: agent.feature_id,\n258:             sessionId: agent.session_id,\n259:             buildErrors: buildResult.errorSummary,\n260:             model,\n261:             config,\n262:           });\n263: \n264:           updateAgent(state, agent.feature_id, {\n265:             status: \"running\",\n266:             pid: retryResult.pid,\n267:           });\n268:           saveState(projectRoot, state);\n269: \n270:           // Add retry process to monitor so events are tracked\n271:           if (monitor) {\n272:             monitor.addProcess(agent.feature_id, retryResult.process);\n273:           }\n274:         }\n275:       } else {\n276:         updateAgent(state, agent.feature_id, {\n277:           status: \"failed\",\n278:           build_passed: false,\n279:           build_output: buildResult.errorSummary,\n280:           error: `Build failed after ${agent.max_retries} retries`,\n281:           completed_at: new Date().toISOString(),\n282:         });\n283:         saveState(projectRoot, state);\n284:         printAgentUpdate(agent, \"BUILD FAILED — max retries reached\");\n285:       }\n286:     }\n287:   } catch (err: any) {\n288:     // Catch-all — never let build verification crash the process\n289:     printAgentUpdate(agent, `VERIFY ERROR: ${err.message?.slice(0, 100)}`);\n290:     updateAgent(state, agent.feature_id, {\n291:       status: \"failed\",\n292:       error: `Build verification error: ${err.message}`,\n293:       completed_at: new Date().toISOString(),\n294:     });\n295:     saveState(projectRoot, state);\n296:   }\n297: }\n298: \n299: /**\n300:  * Attempt to merge a verified agent's branch into the base branch.\n301:  *\n302:  * Handles conflict detection, base-into-feature merge, and resolver agent\n303:  * launch. Extracted from handleBuildVerification so it can be called\n304:  * independently (e.g., from resume's sequential merge phase).\n305:  */\n306: export async function attemptMerge(\n307:   projectRoot: string,\n308:   state: WaveState,\n309:   agent: AgentState,\n310:   feature: Feature,\n311:   config: WomboConfig,\n312:   model?: string,\n313: ): Promise<void> {\n314:   printAgentUpdate(agent, \"auto-merging...\");\n315:   try {\n316:     const mergeResult = await mergeBranch(projectRoot, agent.branch, state.base_branch, config);\n317: \n318:     if (mergeResult.success) {\n319:       updateAgent(state, agent.feature_id, {\n320:         status: \"merged\",\n321:         completed_at: new Date().toISOString(),\n322:       });\n323:       saveState(projectRoot, state);\n324:       printAgentUpdate(agent, `MERGED (${mergeResult.commitHash?.slice(0, 7)})`);\n325: \n326:       // Mark feature as done in .features.yml so it won't be re-selected\n327:       markFeatureDone(projectRoot, agent.feature_id, config, state.base_branch);\n328: \n329:       // Clean up worktree after successful merge\n330:       try {\n331:         removeWorktree(projectRoot, agent.worktree, true);\n332:         printAgentUpdate(agent, \"worktree and branch removed\");\n333:       } catch {\n334:         // Not critical — worktree cleanup is best-effort\n335:       }\n336:     } else {\n337:       // Merge failed — attempt automatic conflict resolution\n338:       const mergeError = mergeResult.error ?? \"Unknown merge error\";\n339:       printAgentUpdate(agent, `MERGE CONFLICT — attempting resolution...`);\n340: \n341:       try {\n342:         // Merge base INTO the feature worktree to create conflict markers\n343:         const conflictResult = await mergeBaseIntoFeature(\n344:           agent.worktree,\n345:           state.base_branch,\n346:           config\n347:         );\n348: \n349:         if (conflictResult.error && !conflictResult.conflicting) {\n350:           printAgentUpdate(agent, `CONFLICT SETUP FAILED: ${conflictResult.error.slice(0, 100)}`);\n351:           return; // Leave as \"verified\" for manual resolution\n352:         }\n353: \n354:         if (!conflictResult.conflicting) {\n355:           // Base merged cleanly into feature — retry merge into base.\n356:           printAgentUpdate(agent, \"base merged cleanly into feature — retrying merge...\");\n357:           const retryMerge = await mergeBranch(projectRoot, agent.branch, state.base_branch, config);\n358:           if (retryMerge.success) {\n359:             updateAgent(state, agent.feature_id, {\n360:               status: \"merged\",\n361:               completed_at: new Date().toISOString(),\n362:             });\n363:             saveState(projectRoot, state);\n364:             printAgentUpdate(agent, `MERGED after rebase (${retryMerge.commitHash?.slice(0, 7)})`);\n365:             markFeatureDone(projectRoot, agent.feature_id, config, state.base_branch);\n366:             try {\n367:               removeWorktree(projectRoot, agent.worktree, true);\n368:             } catch {}\n369:             return;\n370:           }\n371: \n372:           // Retry still failed — launch resolver agent\n373:           printAgentUpdate(agent, `retry merge still failed — launching resolver agent...`);\n374: \n375:           const secondConflict = await mergeBaseIntoFeature(\n376:             agent.worktree,\n377:             state.base_branch,\n378:             config\n379:           );\n380: \n381:           const conflictFiles = secondConflict.conflicting\n382:             ? secondConflict.files\n383:             : [\"(unknown — merge direction mismatch)\"];\n384:           const resolverMergeError = retryMerge.error ?? mergeError;\n385: \n386:           await launchResolverAndRetryMerge(\n387:             projectRoot, state, agent, feature, config, model,\n388:             resolverMergeError, conflictFiles\n389:           );\n390:           return;\n391:         }\n392: \n393:         // There are real conflicts — launch a resolver agent\n394:         printAgentUpdate(\n395:           agent,\n396:           `${conflictResult.files.length} conflicting file(s): ${conflictResult.files.join(\", \")}`\n397:         );\n398: \n399:         await launchResolverAndRetryMerge(\n400:           projectRoot, state, agent, feature, config, model,\n401:           mergeError, conflictResult.files\n402:         );\n403:       } catch (conflictErr: any) {\n404:         printAgentUpdate(agent, `CONFLICT RESOLUTION ERROR: ${conflictErr.message?.slice(0, 100)}`);\n405:         // Leave as \"verified\" for manual resolution\n406:       }\n407:     }\n408:   } catch (mergeErr: any) {\n409:     printAgentUpdate(agent, `AUTO-MERGE ERROR: ${mergeErr.message?.slice(0, 100)}`);\n410:   }\n411: }\n412: \n413: /**\n414:  * Launch a conflict resolver agent, wait for it to finish, re-verify build,\n415:  * and retry the merge. Extracted to avoid duplicating the resolver flow.\n416:  */\n417: async function launchResolverAndRetryMerge(\n418:   projectRoot: string,\n419:   state: WaveState,\n420:   agent: AgentState,\n421:   feature: Feature,\n422:   config: WomboConfig,\n423:   model: string | undefined,\n424:   mergeError: string,\n425:   conflictFiles: string[]\n426: ): Promise<void> {\n427:   const conflictPrompt = generateConflictResolutionPrompt(\n428:     feature,\n429:     state.base_branch,\n430:     mergeError,\n431:     config\n432:   );\n433: \n434:   updateAgent(state, agent.feature_id, {\n435:     status: \"resolving_conflict\",\n436:     activity: `resolving ${conflictFiles.length} conflict(s)...`,\n437:   });\n438:   saveState(projectRoot, state);\n439: \n440:   const resolverResult = launchConflictResolver({\n441:     worktreePath: agent.worktree,\n442:     featureId: agent.feature_id,\n443:     prompt: conflictPrompt,\n444:     model,\n445:     config,\n446:   });\n447: \n448:   updateAgent(state, agent.feature_id, {\n449:     pid: resolverResult.pid,\n450:   });\n451:   saveState(projectRoot, state);\n452: \n453:   // Wait for the resolver process to complete, then re-verify and retry merge.\n454:   // We intentionally do NOT add the resolver to the ProcessMonitor because\n455:   // the monitor's onComplete callback would trigger handleBuildVerification\n456:   // again, causing infinite recursion. Instead we await the process directly.\n457:   const resolverExitCode = await new Promise<number | null>((resolve) => {\n458:     resolverResult.process.on(\"exit\", (code) => resolve(code));\n459:     resolverResult.process.on(\"error\", () => resolve(null));\n460:   });\n461: \n462:   printAgentUpdate(agent, `conflict resolver exited (code ${resolverExitCode}) — re-verifying build...`);\n463: \n464:   // Re-verify build after conflict resolution\n465:   const rebuildResult = await runBuild(agent.worktree, config);\n466: \n467:   if (!rebuildResult.passed) {\n468:     printAgentUpdate(agent, `POST-CONFLICT BUILD FAILED`);\n469:     updateAgent(state, agent.feature_id, {\n470:       status: \"failed\",\n471:       build_passed: false,\n472:       build_output: rebuildResult.errorSummary,\n473:       error: \"Build failed after conflict resolution\",\n474:       completed_at: new Date().toISOString(),\n475:     });\n476:     saveState(projectRoot, state);\n477:     return;\n478:   }\n479: \n480:   printAgentUpdate(agent, \"post-conflict build passed — retrying merge...\");\n481: \n482:   const retryMerge = await mergeBranch(\n483:     projectRoot,\n484:     agent.branch,\n485:     state.base_branch,\n486:     config\n487:   );\n488: \n489:   if (retryMerge.success) {\n490:     updateAgent(state, agent.feature_id, {\n491:       status: \"merged\",\n492:       build_passed: true,\n493:       completed_at: new Date().toISOString(),\n494:     });\n495:     saveState(projectRoot, state);\n496:     printAgentUpdate(agent, `MERGED after conflict resolution (${retryMerge.commitHash?.slice(0, 7)})`);\n497:     markFeatureDone(projectRoot, agent.feature_id, config, state.base_branch);\n498:     try {\n499:       removeWorktree(projectRoot, agent.worktree, true);\n500:     } catch {}\n501:   } else {\n502:     printAgentUpdate(agent, `POST-CONFLICT MERGE FAILED: ${retryMerge.error}`);\n503:     updateAgent(state, agent.feature_id, {\n504:       status: \"failed\",\n505:       error: `Merge still failed after conflict resolution: ${retryMerge.error}`,\n506:       completed_at: new Date().toISOString(),\n507:     });\n508:     saveState(projectRoot, state);\n509:   }\n510: }\n511: \n512: /**\n513:  * Handle retry of a failed agent (error-based, not build-based).\n514:  */\n515: export function handleRetry(\n516:   projectRoot: string,\n517:   state: WaveState,\n518:   agent: AgentState,\n519:   monitor: ProcessMonitor,\n520:   config: WomboConfig,\n521:   model?: string\n522: ): void {\n523:   if (!agent.session_id || !agent.error) return;\n524: \n525:   const retryResult = retryHeadless({\n526:     worktreePath: agent.worktree,\n527:     featureId: agent.feature_id,\n528:     sessionId: agent.session_id,\n529:     buildErrors: agent.error,\n530:     model,\n531:     config,\n532:   });\n533: \n534:   updateAgent(state, agent.feature_id, {\n535:     status: \"running\",\n536:     pid: retryResult.pid,\n537:   });\n538:   saveState(projectRoot, state);\n539: \n540:   monitor.addProcess(agent.feature_id, retryResult.process);\n541: }\n542: \n543: /**\n544:  * Launch the next queued agent if capacity allows.\n545:  */\n546: export function launchNextQueued(\n547:   projectRoot: string,\n548:   state: WaveState,\n549:   featureMap: Map<string, Feature>,\n550:   monitor: ProcessMonitor,\n551:   config: WomboConfig,\n552:   model?: string\n553: ): void {\n554:   const active = activeAgents(state);\n555:   const queued = queuedAgents(state);\n556: \n557:   if (active.length < state.max_concurrent && queued.length > 0) {\n558:     const next = queued[0];\n559:     const feature = featureMap.get(next.feature_id);\n560:     if (feature) {\n561:       launchSingleHeadless(projectRoot, state, next, feature, monitor, config, model);\n562:     }\n563:   }\n564: }\n565: \n566: // ---------------------------------------------------------------------------\n567: // Headless Wave Launch\n568: // ---------------------------------------------------------------------------\n569: \n570: async function launchWaveHeadless(\n571:   projectRoot: string,\n572:   state: WaveState,\n573:   features: Feature[],\n574:   opts: LaunchCommandOptions\n575: ): Promise<void> {\n576:   const { config, model } = opts;\n577:   const featureMap = new Map(features.map((f) => [f.id, f]));\n578: \n579:   const monitor = new ProcessMonitor(projectRoot, {\n580:     onSessionId: (featureId, sessionId) => {\n581:       updateAgent(state, featureId, { session_id: sessionId });\n582:       saveState(projectRoot, state);\n583:     },\n584:     onComplete: (featureId) => {\n585:       updateAgent(state, featureId, {\n586:         status: \"completed\",\n587:         completed_at: new Date().toISOString(),\n588:       });\n589:       saveState(projectRoot, state);\n590: \n591:       // Run build verification — fire-and-forget\n592:       const agent = state.agents.find((a) => a.feature_id === featureId)!;\n593:       handleBuildVerification(projectRoot, state, agent, featureMap.get(featureId)!, config, model, monitor)\n594:         .then(() => launchNextQueued(projectRoot, state, featureMap, monitor, config, model))\n595:         .catch((err) => {\n596:           wtLog(featureId, `BUILD VERIFICATION UNHANDLED ERROR: ${err.message}`);\n597:           launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n598:         });\n599:     },\n600:     onError: (featureId, error) => {\n601:       const agent = state.agents.find((a) => a.feature_id === featureId)!;\n602:       if (agent.retries < agent.max_retries) {\n603:         updateAgent(state, featureId, {\n604:           status: \"retry\",\n605:           retries: agent.retries + 1,\n606:           error,\n607:         });\n608:         saveState(projectRoot, state);\n609: \n610:         // Retry\n611:         handleRetry(projectRoot, state, agent, monitor, config, model);\n612:       } else {\n613:         updateAgent(state, featureId, {\n614:           status: \"failed\",\n615:           error,\n616:           completed_at: new Date().toISOString(),\n617:         });\n618:         saveState(projectRoot, state);\n619:       }\n620: \n621:       // Try to launch next queued agent\n622:       launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n623:     },\n624:     onOutput: (_featureId, _data) => {\n625:       // Raw output — logged to file by ProcessMonitor\n626:     },\n627:     onActivity: (featureId, activity) => {\n628:       updateAgent(state, featureId, {\n629:         activity,\n630:         activity_updated_at: new Date().toISOString(),\n631:       });\n632:       // Don't save to disk on every activity — too frequent.\n633:     },\n634:   });\n635: \n636:   // Create the TUI — it will auto-refresh and show activity from the monitor\n637:   const tuiRef = { current: null as WomboTUI | null };\n638:   const startTUI = () => {\n639:     tuiRef.current = new WomboTUI({\n640:       state,\n641:       monitor,\n642:       projectRoot,\n643:       interactive: false,\n644:       config,\n645:       onQuit: () => {\n646:         // Same as SIGINT — save state and exit\n647:         for (const agent of state.agents) {\n648:           if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n649:             updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n650:           }\n651:         }\n652:         monitor.killAll();\n653:         saveState(projectRoot, state);\n654:         console.log(\"State saved. Use 'wombo resume' to continue.\");\n655:         process.exit(0);\n656:       },\n657:     });\n658:     tuiRef.current.start();\n659:   };\n660: \n661:   // Handle graceful shutdown\n662:   process.on(\"SIGINT\", () => {\n663:     if (tuiRef.current) tuiRef.current.stop();\n664:     for (const agent of state.agents) {\n665:       if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n666:         updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n667:       }\n668:     }\n669:     monitor.killAll();\n670:     saveState(projectRoot, state);\n671:     console.log(\"\\nState saved. Use 'wombo resume' to continue.\");\n672:     process.exit(0);\n673:   });\n674: \n675:   // Launch initial batch — set up worktrees in parallel\n676:   const tolaunch = queuedAgents(state).slice(0, opts.maxConcurrent);\n677:   console.log(`Setting up ${tolaunch.length} agent(s) in parallel...\\n`);\n678: \n679:   await Promise.all(\n680:     tolaunch.map((agent) =>\n681:       launchSingleHeadless(\n682:         projectRoot,\n683:         state,\n684:         agent,\n685:         featureMap.get(agent.feature_id)!,\n686:         monitor,\n687:         config,\n688:         model\n689:       )\n690:     )\n691:   );\n692: \n693:   const launched = state.agents.filter((a) => a.status === \"running\").length;\n694: \n695:   // Start the TUI dashboard (or skip if --no-tui)\n696:   if (opts.noTui) {\n697:     console.log(`${launched} agent(s) running. (--no-tui mode, dashboard prints every 15s)\\n`);\n698:     printDashboard(state);\n699:   } else {\n700:     console.log(`${launched} agent(s) running. Launching TUI...\\n`);\n701:     startTUI();\n702:   }\n703: \n704:   // Background monitoring loop — checks for dead processes and launches queued\n705:   const POLL_INTERVAL = 5000;\n706:   let dashboardCounter = 0;\n707:   while (!isWaveComplete(state)) {\n708:     await new Promise((r) => setTimeout(r, POLL_INTERVAL));\n709: \n710:     // Check for completed processes that weren't caught by event handlers\n711:     for (const agent of state.agents) {\n712:       if (\n713:         (agent.status === \"running\" || agent.status === \"resolving_conflict\") &&\n714:         agent.pid &&\n715:         !isProcessRunning(agent.pid) &&\n716:         !monitor.isRunning(agent.feature_id)\n717:       ) {\n718:         if (agent.status === \"resolving_conflict\") {\n719:           // Conflict resolver died — the await in handleBuildVerification\n720:           // will resolve via the 'exit' event, so nothing to do here\n721:           continue;\n722:         }\n723:         // Process exited but we didn't get a callback\n724:         // Check if the agent actually made any commits\n725:         if (!branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n726:           // Agent died without producing any code — mark as failed, not completed\n727:           updateAgent(state, agent.feature_id, {\n728:             status: \"failed\",\n729:             error: \"Agent process exited without making any commits\",\n730:             activity: null,\n731:             completed_at: new Date().toISOString(),\n732:           });\n733:           saveState(projectRoot, state);\n734:           wtLog(agent.feature_id, \"process died with no code changes — marked failed\");\n735:         } else {\n736:           updateAgent(state, agent.feature_id, {\n737:             status: \"completed\",\n738:             completed_at: new Date().toISOString(),\n739:             activity: \"done\",\n740:           });\n741:           saveState(projectRoot, state);\n742:           try {\n743:             await handleBuildVerification(projectRoot, state, agent, featureMap.get(agent.feature_id)!, config, model, monitor);\n744:           } catch (err: any) {\n745:             wtLog(agent.feature_id, `POLL VERIFY ERROR: ${err.message}`);\n746:           }\n747:         }\n748:         launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n749:       }\n750:     }\n751: \n752:     // Persist state periodically\n753:     saveState(projectRoot, state);\n754: \n755:     // Update TUI state reference (or print dashboard in --no-tui mode)\n756:     if (tuiRef.current) {\n757:       tuiRef.current.updateState(state);\n758:     } else if (opts.noTui) {\n759:       dashboardCounter++;\n760:       if (dashboardCounter % 3 === 0) {\n761:         printDashboard(state);\n762: \n763:         // Auto-push base branch if requested\n764:         if (opts.autoPush) {\n765:           const anyMerged = state.agents.some((a) => a.status === \"merged\");\n766:           if (anyMerged) {\n767:             await pushBaseBranch(projectRoot, state.base_branch, config);\n768:           } else {\n769:             console.log(\"No branches were merged — skipping push.\");\n770:           }\n771:         }\n772:       }\n773:     }\n774:   }\n775: \n776:   // Wave complete — tear down TUI and show final summary\n777:   if (tuiRef.current) tuiRef.current.stop();\n778:   printDashboard(state);\n779: \n780:   // Auto-push base branch if requested\n781:   if (opts.autoPush) {\n782:     await pushBaseBranch(projectRoot, state.base_branch, config);\n783:   }\n784: \n785:   console.log(\"Wave complete.\");\n786: }\n787: \n788: // ---------------------------------------------------------------------------\n789: // Interactive Wave Launch\n790: // ---------------------------------------------------------------------------\n791: \n792: async function launchWaveInteractive(\n793:   projectRoot: string,\n794:   state: WaveState,\n795:   features: Feature[],\n796:   opts: LaunchCommandOptions\n797: ): Promise<void> {\n798:   const { config, model } = opts;\n799:   const featureMap = new Map(features.map((f) => [f.id, f]));\n800: \n801:   // Show dashboard immediately\n802:   printDashboard(state);\n803: \n804:   // Launch initial batch in tmux — parallelize setup\n805:   const tolaunch = queuedAgents(state).slice(0, opts.maxConcurrent);\n806:   console.log(`Setting up ${tolaunch.length} agent(s) in parallel...\\n`);\n807: \n808:   await Promise.all(\n809:     tolaunch.map(async (agent) => {\n810:       updateAgent(state, agent.feature_id, {\n811:         status: \"installing\",\n812:         started_at: new Date().toISOString(),\n813:         activity: \"setting up worktree...\",\n814:       });\n815:       saveState(projectRoot, state);\n816: \n817:       try {\n818:         if (worktreeReady(agent.worktree)) {\n819:           wtLog(agent.feature_id, \"worktree already exists, skipping setup\");\n820:         } else {\n821:           await createWorktree(projectRoot, agent.feature_id, state.base_branch, config);\n822:           updateAgent(state, agent.feature_id, { activity: \"installing deps...\" });\n823:           await installDeps(agent.worktree, agent.feature_id, config);\n824:         }\n825: \n826:         const prompt = generatePrompt(\n827:           featureMap.get(agent.feature_id)!,\n828:           state.base_branch,\n829:           config\n830:         );\n831: \n832:         wtLog(agent.feature_id, \"launching tmux session...\");\n833:         const result = launchInteractive({\n834:           worktreePath: agent.worktree,\n835:           featureId: agent.feature_id,\n836:           prompt,\n837:           model,\n838:           interactive: true,\n839:           config,\n840:         });\n841: \n842:         updateAgent(state, agent.feature_id, {\n843:           status: \"running\",\n844:           pid: result.pid,\n845:           activity: \"tmux session active\",\n846:         });\n847:         saveState(projectRoot, state);\n848:         wtLog(agent.feature_id, `tmux session: ${config.agent.tmuxPrefix}-${agent.feature_id}`);\n849:       } catch (err: any) {\n850:         updateAgent(state, agent.feature_id, {\n851:           status: \"failed\",\n852:           error: err.message,\n853:           activity: null,\n854:           completed_at: new Date().toISOString(),\n855:         });\n856:         saveState(projectRoot, state);\n857:         wtLog(agent.feature_id, `SETUP FAILED: ${err.message.split(\"\\n\")[0]}`);\n858:       }\n859:     })\n860:   );\n861: \n862:   console.log(\"\\nInteractive sessions launched. Use these commands:\");\n863:   console.log(`  tmux attach -t ${config.agent.tmuxPrefix}-<feature-id>   # attach to a session`);\n864:   console.log(\"  tmux ls                                                  # list sessions\");\n865:   console.log(\"  wombo status                                             # check status\");\n866:   console.log(\"  wombo verify                                             # verify builds\");\n867:   console.log(\"  wombo merge                                              # merge verified\");\n868:   console.log(\"  wombo cleanup                                            # remove worktrees\");\n869: \n870:   printDashboard(state);\n871: }\n872: \n873: // ---------------------------------------------------------------------------\n874: // Main Command\n875: // ---------------------------------------------------------------------------\n876: \n877: export async function cmdLaunch(opts: LaunchCommandOptions): Promise<void> {\n878:   const { projectRoot, config } = opts;\n879: \n880:   console.log(\"\\n--- Wombo: Launch ---\\n\");\n881: \n882:   // Ensure agent definition exists — reinstall from template if missing\n883:   ensureAgentDefinition(projectRoot, config);\n884: \n885:   // -------------------------------------------------------------------------\n886:   // Validate that the configured baseBranch exists as a local branch\n887:   // -------------------------------------------------------------------------\n888:   if (!branchExists(projectRoot, opts.baseBranch)) {\n889:     const fmt = opts.outputFmt ?? \"text\";\n890:     const msg = `Base branch \"${opts.baseBranch}\" does not exist as a local branch. ` +\n891:       `Create it first (e.g. \"git checkout -b ${opts.baseBranch}\") or specify ` +\n892:       `a different branch with --base-branch.`;\n893:     outputError(fmt, msg);\n894:   }\n895: \n896:   // -------------------------------------------------------------------------\n897:   // Check for existing wave state — don't overwrite work in progress\n898:   // -------------------------------------------------------------------------\n899:   const existingState = loadState(projectRoot);\n900:   if (existingState) {\n901:     const merged = existingState.agents.filter((a) => a.status === \"merged\");\n902:     const verified = existingState.agents.filter((a) => a.status === \"verified\");\n903:     const completed = existingState.agents.filter((a) => a.status === \"completed\");\n904:     const running = existingState.agents.filter((a) => a.status === \"running\");\n905:     const queued = existingState.agents.filter((a) => a.status === \"queued\");\n906:     const failed = existingState.agents.filter((a) => a.status === \"failed\");\n907: \n908:     const hasWork = merged.length > 0 || verified.length > 0 || completed.length > 0 || running.length > 0;\n909: \n910:     if (hasWork) {\n911:       console.log(`Existing wave found: ${existingState.wave_id}`);\n912:       console.log(`  ${merged.length} merged, ${verified.length} verified, ${completed.length} completed, ${running.length} running, ${queued.length} queued, ${failed.length} failed`);\n913: \n914:       // Finalize any merged agents by marking their features as done\n915:       if (merged.length > 0) {\n916:         console.log(\"\\nFinalizing merged features in .features.yml...\");\n917:         for (const agent of merged) {\n918:           markFeatureDone(projectRoot, agent.feature_id, config, existingState.base_branch);\n919:           // Clean up worktree and branch (already merged, safe to delete)\n920:           try {\n921:             removeWorktree(projectRoot, agent.worktree, true);\n922:             console.log(`  ${agent.feature_id}: marked done, worktree removed`);\n923:           } catch {\n924:             console.log(`  ${agent.feature_id}: marked done (worktree already cleaned)`);\n925:           }\n926:         }\n927:       }\n928: \n929:       // Verified agents: build passed but NOT merged — do NOT mark done.\n930:       // Leave them for 'wombo resume' to attempt the merge.\n931:       if (verified.length > 0) {\n932:         for (const agent of verified) {\n933:           console.log(`  ${agent.feature_id}: verified (not yet merged) — use 'wombo resume' to merge`);\n934:         }\n935:       }\n936: \n937:       const activeCount = running.length + completed.length + queued.length;\n938:       if (activeCount > 0) {\n939:         console.error(`\\nWave ${existingState.wave_id} has ${activeCount} unfinished agent(s).`);\n940:         console.error(\"Use 'wombo resume' to continue the existing wave,\");\n941:         console.error(\"or 'wombo cleanup' to clear it before starting a new one.\");\n942:         process.exit(1);\n943:       }\n944: \n945:       // All agents are in terminal states (merged/verified/failed) — safe to start fresh\n946:       console.log(\"\\nAll agents in previous wave are finished. Starting fresh wave.\\n\");\n947:     }\n948:   }\n949: \n950:   // Load features\n951:   const data = loadFeatures(projectRoot, config);\n952: \n953:   // Build selection options\n954:   const selOpts: SelectionOptions = {};\n955:   if (opts.topPriority) selOpts.topPriority = opts.topPriority;\n956:   if (opts.quickestWins) selOpts.quickestWins = opts.quickestWins;\n957:   if (opts.priority) selOpts.priority = opts.priority;\n958:   if (opts.difficulty) selOpts.difficulty = opts.difficulty;\n959:   if (opts.features) selOpts.featureIds = opts.features;\n960:   if (opts.allReady) selOpts.allReady = true;\n961: \n962:   // Select features\n963:   const selected = selectFeatures(data, selOpts);\n964: \n965:   if (selected.length === 0) {\n966:     if (opts.allReady) {\n967:       console.error(\n968:         \"No launchable features found (all features are done, cancelled, or have unmet dependencies).\\n\" +\n969:         \"Run 'wombo features list' to review feature statuses.\"\n970:       );\n971:     } else {\n972:       console.error(\n973:         \"No features matched the selection criteria.\\n\" +\n974:         \"Use --all-ready to select all features whose dependencies are met,\\n\" +\n975:         \"or run 'wombo features list --ready' to see available features.\"\n976:       );\n977:     }\n978:     process.exit(1);\n979:   }\n980: \n981:   // Show selection\n982:   printFeatureSelection(\n983:     selected.map((f) => ({\n984:       id: f.id,\n985:       title: f.title,\n986:       priority: f.priority,\n987:       difficulty: f.difficulty,\n988:       effort: f.effort,\n989:     }))\n990:   );\n991: \n992:   if (opts.dryRun) {\n993:     console.log(\"Dry run — not launching agents.\");\n994:     return;\n995:   }\n996: \n997:   // Create wave state\n998:   const state = createWaveState({\n999:     baseBranch: opts.baseBranch,\n1000:     maxConcurrent: opts.maxConcurrent,\n1001:     model: opts.model ?? null,\n1002:     interactive: opts.interactive,\n1003:   });\n1004: \n1005:   // Create agent entries for all selected features\n1006:   for (const feature of selected) {\n1007:     const branch = featureBranchName(feature.id, config);\n1008:     const wtPath = worktreePath(projectRoot, feature.id, config);\n1009:     const agent = createAgentState(feature.id, branch, wtPath, opts.maxRetries);\n1010:     // Set effort estimate from feature spec\n1011:     const effortMinutes = parseDurationMinutes(feature.effort);\n1012:     agent.effort_estimate_ms = effortMinutes === Infinity ? null : effortMinutes * 60 * 1000;\n1013:     state.agents.push(agent);\n1014:   }\n1015: \n1016:   saveState(projectRoot, state);\n1017:   console.log(`Wave ${state.wave_id} created with ${selected.length} agents.`);\n1018: \n1019:   // Launch agents up to max_concurrent\n1020:   if (opts.interactive) {\n1021:     await launchWaveInteractive(projectRoot, state, selected, opts);\n1022:   } else {\n1023:     await launchWaveHeadless(projectRoot, state, selected, opts);\n1024:   }\n1025: }\n\n(End of file - total 1025 lines)\n</content>","title":"src/commands/launch.ts","metadata":{"preview":"/**\n * launch.ts — Launch a wave of agents.\n *\n * Usage: wombo launch [selection options] [launch options]\n *\n * This is the primary entry point for starting a new wave. It selects features\n * from the features file, creates a wave state, sets up worktrees, and launches\n * agent processes (either headless or interactive via tmux).\n *\n * IMPORTANT: This file also exports shared helper functions that are reused\n * by resume.ts and other commands:\n *   - launchSingleHeadless\n *   - handleBuildVerification\n *   - handleRetry\n *   - launchNextQueued\n */\n\nimport { execSync } from \"node:child_process\";\nimport type { WomboConfig } from \"../config.js\";\nimport type { Feature, SelectionOptions, Priority, Difficulty } from \"../lib/features.js\";","truncated":false,"loaded":[]},"time":{"start":1773351942498,"end":1773351942502}}}}
{"type":"tool_use","timestamp":1773351942748,"sessionID":"ses_31bfd06f5ffeleRCi6uuMulALr","part":{"id":"prt_ce4033963001qJ6qnoj1yZGeid","sessionID":"ses_31bfd06f5ffeleRCi6uuMulALr","messageID":"msg_ce4032631001Qh3VBZpcxsurpq","type":"tool","callID":"toolu_vrtx_01HBjcrF9PNX2BecVoG3DHvJ","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-dmux-migration/src/commands/resume.ts"},"output":"<path>/home/fulgidus/Documents/wombo-dmux-migration/src/commands/resume.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * resume.ts — Resume a previously stopped wave.\n3:  *\n4:  * Usage: wombo resume [options]\n5:  *\n6:  * Restores from .wombo-state.json:\n7:  *   - Agents in \"running\"/\"installing\" whose PID is dead → re-check or re-launch\n8:  *   - Agents in \"queued\" → launch them\n9:  *   - Agents in terminal states (verified/failed/merged) → leave alone\n10:  */\n11: \n12: import type { WomboConfig } from \"../config.js\";\n13: import type { Feature } from \"../lib/features.js\";\n14: import { loadFeatures } from \"../lib/features.js\";\n15: import {\n16:   loadState,\n17:   saveState,\n18:   updateAgent,\n19:   queuedAgents,\n20:   isWaveComplete,\n21:   type WaveState,\n22:   type AgentState,\n23: } from \"../lib/state.js\";\n24: import {\n25:   createWorktree,\n26:   installDeps,\n27:   worktreeReady,\n28:   worktreeExists,\n29:   branchHasChanges,\n30:   removeWorktree,\n31:   log as wtLog,\n32: } from \"../lib/worktree.js\";\n33: import { generatePrompt } from \"../lib/prompt.js\";\n34: import {\n35:   launchInteractive,\n36:   isProcessRunning,\n37: } from \"../lib/launcher.js\";\n38: import { ProcessMonitor } from \"../lib/monitor.js\";\n39: import { pushBaseBranch } from \"../lib/merger.js\";\n40: import { runBuild } from \"../lib/verifier.js\";\n41: import { printDashboard, printAgentUpdate } from \"../lib/ui.js\";\n42: import { WomboTUI } from \"../lib/tui.js\";\n43: import {\n44:   launchSingleHeadless,\n45:   handleBuildVerification,\n46:   handleRetry,\n47:   launchNextQueued,\n48:   markFeatureDone,\n49:   attemptMerge,\n50: } from \"./launch.js\";\n51: \n52: // ---------------------------------------------------------------------------\n53: // Types\n54: // ---------------------------------------------------------------------------\n55: \n56: export interface ResumeCommandOptions {\n57:   projectRoot: string;\n58:   config: WomboConfig;\n59:   maxConcurrent?: number;\n60:   model?: string;\n61:   interactive: boolean;\n62:   noTui: boolean;\n63:   autoPush: boolean;\n64:   baseBranch?: string;\n65:   maxRetries?: number;\n66: }\n67: \n68: // ---------------------------------------------------------------------------\n69: // Command\n70: // ---------------------------------------------------------------------------\n71: \n72: export async function cmdResume(opts: ResumeCommandOptions): Promise<void> {\n73:   const { projectRoot, config } = opts;\n74: \n75:   const state = loadState(projectRoot);\n76:   if (!state) {\n77:     console.error(\"No wave state found. Use 'wombo launch' to start a new wave.\");\n78:     process.exit(1);\n79:     return; // unreachable — helps TypeScript narrow\n80:   }\n81: \n82:   console.log(`\\n--- Wombo: Resume ${state.wave_id} ---\\n`);\n83: \n84:   // Load feature data for prompt generation\n85:   const data = loadFeatures(projectRoot, config);\n86:   const featureMap = new Map(data.features.map((f) => [f.id, f]));\n87: \n88:   // Triage agents by current state\n89:   let toRelaunch: AgentState[] = [];\n90:   let toVerify: AgentState[] = [];\n91: \n92:   for (const agent of state.agents) {\n93:     switch (agent.status) {\n94:       case \"running\":\n95:       case \"installing\":\n96:       case \"retry\":\n97:       case \"resolving_conflict\":\n98:         // Was in-flight when we stopped — check if PID is still alive\n99:         if (agent.pid && isProcessRunning(agent.pid)) {\n100:           console.log(`  ${agent.feature_id}: still running (PID ${agent.pid}), leaving alone`);\n101:         } else {\n102:           // Process is dead — check if worktree exists with meaningful changes.\n103:           // Use worktreeExists (not worktreeReady) because node_modules may be\n104:           // missing — the worktree still has code that should be verified.\n105:           if (worktreeExists(agent.worktree) && branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n106:             // Worktree exists AND branch has commits — try build verification\n107:             console.log(`  ${agent.feature_id}: process dead, worktree has changes — will verify build`);\n108:             toVerify.push(agent);\n109:           } else {\n110:             // No worktree, or worktree exists but branch has no commits (agent did nothing)\n111:             const reason = worktreeExists(agent.worktree)\n112:               ? \"worktree exists but no code changes\"\n113:               : \"no worktree\";\n114:             console.log(`  ${agent.feature_id}: process dead, ${reason} — will re-launch`);\n115:             updateAgent(state, agent.feature_id, {\n116:               status: \"queued\",\n117:               pid: null,\n118:               activity: null,\n119:               session_id: null,\n120:             });\n121:             toRelaunch.push(agent);\n122:           }\n123:         }\n124:         break;\n125: \n126:       case \"queued\":\n127:         console.log(`  ${agent.feature_id}: queued — will launch`);\n128:         toRelaunch.push(agent);\n129:         break;\n130: \n131:       case \"completed\":\n132:         // Completed but not verified — verify\n133:         console.log(`  ${agent.feature_id}: completed — will verify build`);\n134:         toVerify.push(agent);\n135:         break;\n136: \n137:       case \"verified\":\n138:         // Build passed but NOT yet merged — need to attempt merge (+ conflict resolution)\n139:         console.log(`  ${agent.feature_id}: verified — will attempt merge`);\n140:         toVerify.push(agent);\n141:         break;\n142: \n143:       case \"merged\":\n144:         console.log(`  ${agent.feature_id}: merged — marking feature as done`);\n145:         markFeatureDone(projectRoot, agent.feature_id, config, state.base_branch);\n146:         try {\n147:           removeWorktree(projectRoot, agent.worktree, true);\n148:           console.log(`  ${agent.feature_id}: worktree and branch removed`);\n149:         } catch {\n150:           // Already cleaned — not critical\n151:         }\n152:         break;\n153: \n154:       case \"failed\":\n155:         // If the worktree exists with code changes and retries remain,\n156:         // attempt build verification rather than discarding the work.\n157:         if (agent.retries < agent.max_retries &&\n158:             worktreeExists(agent.worktree) &&\n159:             branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n160:           console.log(`  ${agent.feature_id}: failed but has work (retry ${agent.retries}/${agent.max_retries}) — will verify build`);\n161:           // Clear stale error and mark as completed so handleBuildVerification\n162:           // processes it correctly (it expects a non-failed agent)\n163:           updateAgent(state, agent.feature_id, {\n164:             status: \"completed\",\n165:             error: null,\n166:             build_passed: null,\n167:             build_output: null,\n168:             completed_at: new Date().toISOString(),\n169:           });\n170:           toVerify.push(agent);\n171:         } else if (agent.retries < agent.max_retries) {\n172:           // No worktree or no changes — re-launch from scratch\n173:           console.log(`  ${agent.feature_id}: failed, no salvageable work (retry ${agent.retries}/${agent.max_retries}) — will re-launch`);\n174:           updateAgent(state, agent.feature_id, {\n175:             status: \"queued\",\n176:             pid: null,\n177:             error: null,\n178:             build_passed: null,\n179:             build_output: null,\n180:             activity: null,\n181:             session_id: null,\n182:             completed_at: null,\n183:           });\n184:           toRelaunch.push(agent);\n185:         } else {\n186:           console.log(`  ${agent.feature_id}: failed — max retries reached (use 'wombo retry' to reset)`);\n187:         }\n188:         break;\n189:     }\n190:   }\n191: \n192:   saveState(projectRoot, state);\n193: \n194:   // ---------------------------------------------------------------------------\n195:   // Phase 1: Parallel build verification\n196:   // Each agent's worktree is independent, so dep install + build can run\n197:   // concurrently. Merges must remain sequential (they mutate the project root).\n198:   // ---------------------------------------------------------------------------\n199:   if (toVerify.length > 0) {\n200:     console.log(`\\nVerifying ${toVerify.length} agent(s) in parallel...\\n`);\n201: \n202:     const verifyResults = await Promise.all(\n203:       toVerify.map(async (agent): Promise<{ agent: AgentState; needsMerge: boolean }> => {\n204:         const feature = featureMap.get(agent.feature_id);\n205:         if (!feature) return { agent, needsMerge: false };\n206: \n207:         // Already verified — skip build, go straight to merge\n208:         if (agent.status === \"verified\") {\n209:           printAgentUpdate(agent, \"already verified — queued for merge\");\n210:           return { agent, needsMerge: true };\n211:         }\n212: \n213:         printAgentUpdate(agent, \"verifying build...\");\n214: \n215:         // Ensure deps are installed — worktree may exist without node_modules\n216:         // (e.g., failed agents whose setup was interrupted)\n217:         if (!worktreeReady(agent.worktree) && worktreeExists(agent.worktree)) {\n218:           try {\n219:             printAgentUpdate(agent, \"installing deps...\");\n220:             await installDeps(agent.worktree, agent.feature_id, config);\n221:           } catch (depErr: any) {\n222:             printAgentUpdate(agent, `dep install failed: ${depErr.message}`);\n223:             updateAgent(state, agent.feature_id, {\n224:               status: \"failed\",\n225:               error: `Dependency install failed: ${depErr.message}`,\n226:               retries: agent.retries + 1,\n227:               completed_at: new Date().toISOString(),\n228:             });\n229:             saveState(projectRoot, state);\n230:             return { agent, needsMerge: false };\n231:           }\n232:         }\n233: \n234:         try {\n235:           const buildResult = await runBuild(agent.worktree, config);\n236:           if (buildResult.passed) {\n237:             updateAgent(state, agent.feature_id, {\n238:               status: \"verified\",\n239:               build_passed: true,\n240:               build_output: null,\n241:             });\n242:             saveState(projectRoot, state);\n243:             printAgentUpdate(agent, `BUILD PASSED (${Math.round(buildResult.durationMs / 1000)}s)`);\n244:             return { agent, needsMerge: true };\n245:           } else {\n246:             // Build failed\n247:             if (agent.retries < agent.max_retries) {\n248:               updateAgent(state, agent.feature_id, {\n249:                 status: \"retry\",\n250:                 retries: agent.retries + 1,\n251:                 build_passed: false,\n252:                 build_output: buildResult.errorSummary,\n253:               });\n254:               saveState(projectRoot, state);\n255:               printAgentUpdate(agent, `BUILD FAILED — will retry (${agent.retries + 1}/${agent.max_retries})`);\n256:             } else {\n257:               updateAgent(state, agent.feature_id, {\n258:                 status: \"failed\",\n259:                 build_passed: false,\n260:                 build_output: buildResult.errorSummary,\n261:                 error: `Build failed after ${agent.max_retries} retries`,\n262:                 completed_at: new Date().toISOString(),\n263:               });\n264:               saveState(projectRoot, state);\n265:               printAgentUpdate(agent, \"BUILD FAILED — max retries reached\");\n266:             }\n267:             return { agent, needsMerge: false };\n268:           }\n269:         } catch (err: any) {\n270:           printAgentUpdate(agent, `verify error: ${err.message}`);\n271:           updateAgent(state, agent.feature_id, {\n272:             status: \"failed\",\n273:             error: `Build verification error: ${err.message}`,\n274:             completed_at: new Date().toISOString(),\n275:           });\n276:           saveState(projectRoot, state);\n277:           return { agent, needsMerge: false };\n278:         }\n279:       })\n280:     );\n281: \n282:     saveState(projectRoot, state);\n283: \n284:     // -------------------------------------------------------------------------\n285:     // Phase 2: Sequential merge for verified agents\n286:     // Merges must be sequential because they operate on the project root.\n287:     // -------------------------------------------------------------------------\n288:     const toMerge = verifyResults.filter((r) => r.needsMerge);\n289:     if (toMerge.length > 0) {\n290:       console.log(`\\nMerging ${toMerge.length} verified agent(s)...\\n`);\n291:       for (const { agent } of toMerge) {\n292:         const feature = featureMap.get(agent.feature_id);\n293:         if (!feature) continue;\n294:         try {\n295:           await attemptMerge(projectRoot, state, agent, feature, config, opts.model);\n296:         } catch (err: any) {\n297:           printAgentUpdate(agent, `merge error: ${err.message}`);\n298:         }\n299:       }\n300:     }\n301: \n302:     // Collect agents that need re-launching from verify results\n303:     for (const { agent } of verifyResults) {\n304:       if (agent.status === \"retry\" || agent.status === \"running\") {\n305:         toRelaunch.push(agent);\n306:       }\n307:     }\n308:   }\n309: \n310:   // Re-launch agents\n311:   const maxConcurrent = opts.maxConcurrent ?? state.max_concurrent;\n312:   const toLaunchNow = toRelaunch.slice(0, maxConcurrent);\n313:   if (toLaunchNow.length === 0) {\n314:     console.log(\"\\nNo agents need (re)launching.\");\n315:     printDashboard(state);\n316:     return;\n317:   }\n318: \n319:   console.log(`\\nRe-launching ${toLaunchNow.length} agent(s)...\\n`);\n320:   printDashboard(state);\n321: \n322:   const model = opts.model ?? state.model ?? undefined;\n323: \n324:   if (opts.interactive) {\n325:     // Interactive resume\n326:     await Promise.all(\n327:       toLaunchNow.map(async (agent) => {\n328:         const feature = featureMap.get(agent.feature_id);\n329:         if (!feature) return;\n330: \n331:         updateAgent(state, agent.feature_id, {\n332:           status: \"installing\",\n333:           started_at: new Date().toISOString(),\n334:           activity: \"resuming...\",\n335:         });\n336:         saveState(projectRoot, state);\n337: \n338:         try {\n339:           if (!worktreeReady(agent.worktree)) {\n340:             await createWorktree(projectRoot, agent.feature_id, state.base_branch, config);\n341:             await installDeps(agent.worktree, agent.feature_id, config);\n342:           }\n343: \n344:           const prompt = generatePrompt(feature, state.base_branch, config);\n345:           const result = launchInteractive({\n346:             worktreePath: agent.worktree,\n347:             featureId: feature.id,\n348:             prompt,\n349:             model,\n350:             interactive: true,\n351:             config,\n352:           });\n353: \n354:           updateAgent(state, agent.feature_id, {\n355:             status: \"running\",\n356:             pid: result.pid,\n357:             activity: \"tmux session active\",\n358:           });\n359:           saveState(projectRoot, state);\n360:         } catch (err: any) {\n361:           updateAgent(state, agent.feature_id, {\n362:             status: \"failed\",\n363:             error: err.message,\n364:             activity: null,\n365:             completed_at: new Date().toISOString(),\n366:           });\n367:           saveState(projectRoot, state);\n368:         }\n369:       })\n370:     );\n371: \n372:     printDashboard(state);\n373:     console.log(`\\nResume complete. Use 'tmux attach -t ${config.agent.tmuxPrefix}-<id>' to check sessions.`);\n374:   } else {\n375:     // Headless resume — re-enter monitoring loop\n376:     const monitor = new ProcessMonitor(projectRoot, {\n377:       onSessionId: (featureId, sessionId) => {\n378:         updateAgent(state, featureId, { session_id: sessionId });\n379:         saveState(projectRoot, state);\n380:       },\n381:       onComplete: (featureId) => {\n382:         updateAgent(state, featureId, {\n383:           status: \"completed\",\n384:           completed_at: new Date().toISOString(),\n385:           activity: \"done\",\n386:         });\n387:         saveState(projectRoot, state);\n388:         wtLog(featureId, \"agent completed — verifying build...\");\n389: \n390:         const agent = state.agents.find((a) => a.feature_id === featureId)!;\n391:         const feature = featureMap.get(featureId)!;\n392:         handleBuildVerification(projectRoot, state, agent, feature, config, model, monitor)\n393:           .then(() => launchNextQueued(projectRoot, state, featureMap, monitor, config, model))\n394:           .catch((err) => {\n395:             wtLog(featureId, `BUILD VERIFICATION UNHANDLED ERROR: ${err.message}`);\n396:             launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n397:           });\n398:       },\n399:       onError: (featureId, error) => {\n400:         const agent = state.agents.find((a) => a.feature_id === featureId)!;\n401:         if (agent.retries < agent.max_retries) {\n402:           updateAgent(state, featureId, {\n403:             status: \"retry\",\n404:             retries: agent.retries + 1,\n405:             error,\n406:             activity: \"retrying...\",\n407:           });\n408:           saveState(projectRoot, state);\n409:           handleRetry(projectRoot, state, agent, monitor, config, model);\n410:         } else {\n411:           updateAgent(state, featureId, {\n412:             status: \"failed\",\n413:             error,\n414:             activity: null,\n415:             completed_at: new Date().toISOString(),\n416:           });\n417:           saveState(projectRoot, state);\n418:         }\n419:         launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n420:       },\n421:       onActivity: (featureId, activity) => {\n422:         updateAgent(state, featureId, {\n423:           activity,\n424:           activity_updated_at: new Date().toISOString(),\n425:         });\n426:       },\n427:     });\n428: \n429:     // Handle graceful shutdown\n430:     const tuiRef = { current: null as WomboTUI | null };\n431:     process.on(\"SIGINT\", () => {\n432:       if (tuiRef.current) tuiRef.current.stop();\n433:       for (const agent of state.agents) {\n434:         if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n435:           updateAgent(state, agent.feature_id, {\n436:             activity: \"interrupted\",\n437:           });\n438:         }\n439:       }\n440:       monitor.killAll();\n441:       saveState(projectRoot, state);\n442:       console.log(\"\\nState saved. Use 'wombo resume' to continue.\");\n443:       process.exit(0);\n444:     });\n445: \n446:     await Promise.all(\n447:       toLaunchNow.map((agent) => {\n448:         const feature = featureMap.get(agent.feature_id);\n449:         if (!feature) return Promise.resolve();\n450:         return launchSingleHeadless(projectRoot, state, agent, feature, monitor, config, model);\n451:       })\n452:     );\n453: \n454:     // Start TUI dashboard (or skip if --no-tui)\n455:     if (!opts.noTui) {\n456:       tuiRef.current = new WomboTUI({\n457:         state,\n458:         monitor,\n459:         projectRoot,\n460:         interactive: false,\n461:         config,\n462:         onQuit: () => {\n463:           for (const agent of state.agents) {\n464:             if (agent.status === \"running\") {\n465:               updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n466:             }\n467:           }\n468:           monitor.killAll();\n469:           saveState(projectRoot, state);\n470:           console.log(\"State saved. Use 'wombo resume' to continue.\");\n471:           process.exit(0);\n472:         },\n473:       });\n474:       tuiRef.current.start();\n475:     } else {\n476:       console.log(\"(--no-tui mode, dashboard prints every 15s)\\n\");\n477:       printDashboard(state);\n478:     }\n479: \n480:     // Monitoring loop\n481:     const POLL_INTERVAL = 5000;\n482:     let dashboardCounter = 0;\n483:     while (!isWaveComplete(state)) {\n484:       await new Promise((r) => setTimeout(r, POLL_INTERVAL));\n485: \n486:       for (const agent of state.agents) {\n487:         if (\n488:           (agent.status === \"running\" || agent.status === \"resolving_conflict\") &&\n489:           agent.pid &&\n490:           !isProcessRunning(agent.pid) &&\n491:           !monitor.isRunning(agent.feature_id)\n492:         ) {\n493:           if (agent.status === \"resolving_conflict\") {\n494:             // Conflict resolver died unexpectedly — mark as failed\n495:             updateAgent(state, agent.feature_id, {\n496:               status: \"failed\",\n497:               error: \"Conflict resolver process died unexpectedly\",\n498:               activity: null,\n499:               completed_at: new Date().toISOString(),\n500:             });\n501:             saveState(projectRoot, state);\n502:             wtLog(agent.feature_id, \"conflict resolver died — marked failed\");\n503:             launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n504:             continue;\n505:           }\n506:           // Check if the agent actually made any commits\n507:           if (!branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n508:             // Agent died without producing any code — mark as failed\n509:             updateAgent(state, agent.feature_id, {\n510:               status: \"failed\",\n511:               error: \"Agent process exited without making any commits\",\n512:               activity: null,\n513:               completed_at: new Date().toISOString(),\n514:             });\n515:             saveState(projectRoot, state);\n516:             wtLog(agent.feature_id, \"process died with no code changes — marked failed\");\n517:           } else {\n518:             updateAgent(state, agent.feature_id, {\n519:               status: \"completed\",\n520:               completed_at: new Date().toISOString(),\n521:               activity: \"done\",\n522:             });\n523:             saveState(projectRoot, state);\n524:             const feature = featureMap.get(agent.feature_id)!;\n525:             try {\n526:               await handleBuildVerification(projectRoot, state, agent, feature, config, model, monitor);\n527:             } catch (err: any) {\n528:               wtLog(agent.feature_id, `POLL VERIFY ERROR: ${err.message}`);\n529:             }\n530:           }\n531:           launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n532:         }\n533:       }\n534: \n535:       saveState(projectRoot, state);\n536:       if (tuiRef.current) {\n537:         tuiRef.current.updateState(state);\n538:       } else if (opts.noTui) {\n539:         dashboardCounter++;\n540:         if (dashboardCounter % 3 === 0) {\n541:           printDashboard(state);\n542:         }\n543:       }\n544:     }\n545: \n546:     if (tuiRef.current) tuiRef.current.stop();\n547:     printDashboard(state);\n548: \n549:     // Auto-push base branch if requested\n550:     if (opts.autoPush) {\n551:       await pushBaseBranch(projectRoot, state.base_branch, config);\n552:     }\n553: \n554:     console.log(\"Wave complete.\");\n555:   }\n556: }\n\n(End of file - total 556 lines)\n</content>","title":"src/commands/resume.ts","metadata":{"preview":"/**\n * resume.ts — Resume a previously stopped wave.\n *\n * Usage: wombo resume [options]\n *\n * Restores from .wombo-state.json:\n *   - Agents in \"running\"/\"installing\" whose PID is dead → re-check or re-launch\n *   - Agents in \"queued\" → launch them\n *   - Agents in terminal states (verified/failed/merged) → leave alone\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport type { Feature } from \"../lib/features.js\";\nimport { loadFeatures } from \"../lib/features.js\";\nimport {\n  loadState,\n  saveState,\n  updateAgent,\n  queuedAgents,\n  isWaveComplete,","truncated":false,"loaded":[]},"time":{"start":1773351942734,"end":1773351942743}}}}
{"type":"tool_use","timestamp":1773351943159,"sessionID":"ses_31bfd06f5ffeleRCi6uuMulALr","part":{"id":"prt_ce4033ab6001r88r8z1kIKWYFw","sessionID":"ses_31bfd06f5ffeleRCi6uuMulALr","messageID":"msg_ce4032631001Qh3VBZpcxsurpq","type":"tool","callID":"toolu_vrtx_01FJkYeuX7n7SYVg4XznmSai","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-dmux-migration/src/commands/retry.ts"},"output":"<path>/home/fulgidus/Documents/wombo-dmux-migration/src/commands/retry.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * retry.ts — Retry a specific failed agent.\n3:  *\n4:  * Usage: wombo retry <feature-id> [--interactive] [--model <model>]\n5:  *\n6:  * Resets the agent's retry count and re-launches it. Can launch in either\n7:  * headless mode (default) or interactive (tmux) mode.\n8:  */\n9: \n10: import type { WomboConfig } from \"../config.js\";\n11: import { loadFeatures, type Feature } from \"../lib/features.js\";\n12: import {\n13:   loadState,\n14:   saveState,\n15:   updateAgent,\n16: } from \"../lib/state.js\";\n17: import { worktreeReady } from \"../lib/worktree.js\";\n18: import { generatePrompt } from \"../lib/prompt.js\";\n19: import { launchInteractive } from \"../lib/launcher.js\";\n20: import { ProcessMonitor } from \"../lib/monitor.js\";\n21: import { launchSingleHeadless } from \"./launch.js\";\n22: \n23: // ---------------------------------------------------------------------------\n24: // Types\n25: // ---------------------------------------------------------------------------\n26: \n27: export interface RetryCommandOptions {\n28:   projectRoot: string;\n29:   config: WomboConfig;\n30:   featureId: string;\n31:   model?: string;\n32:   interactive: boolean;\n33:   dryRun?: boolean;\n34: }\n35: \n36: // ---------------------------------------------------------------------------\n37: // Command\n38: // ---------------------------------------------------------------------------\n39: \n40: export async function cmdRetry(opts: RetryCommandOptions): Promise<void> {\n41:   const { projectRoot, config } = opts;\n42: \n43:   if (!opts.featureId) {\n44:     console.error(\"Usage: wombo retry <feature-id>\");\n45:     process.exit(1);\n46:     return; // unreachable — helps TypeScript narrow\n47:   }\n48: \n49:   const state = loadState(projectRoot);\n50:   if (!state) {\n51:     console.log(\"No active wave.\");\n52:     return;\n53:   }\n54: \n55:   const agent = state.agents.find((a) => a.feature_id === opts.featureId);\n56:   if (!agent) {\n57:     console.error(`Agent not found for feature: ${opts.featureId}`);\n58:     process.exit(1);\n59:     return; // unreachable — helps TypeScript narrow\n60:   }\n61: \n62:   if (agent.status !== \"failed\") {\n63:     console.error(\n64:       `Agent ${opts.featureId} is not in failed state (current: ${agent.status})`\n65:     );\n66:     process.exit(1);\n67:     return; // unreachable — helps TypeScript narrow\n68:   }\n69: \n70:   // Dry-run: show what would be retried without doing it\n71:   if (opts.dryRun) {\n72:     console.log(`\\n[dry-run] Would retry agent: ${opts.featureId}`);\n73:     console.log(`  Current status: ${agent.status}`);\n74:     console.log(`  Retries so far: ${agent.retries}`);\n75:     console.log(`  Worktree: ${agent.worktree}`);\n76:     console.log(`  Mode: ${opts.interactive ? \"interactive (tmux)\" : \"headless\"}`);\n77:     if (opts.model) console.log(`  Model: ${opts.model}`);\n78:     return;\n79:   }\n80: \n81:   // Reset retry count and re-run\n82:   updateAgent(state, agent.feature_id, {\n83:     status: \"queued\",\n84:     retries: 0,\n85:     error: null,\n86:     build_passed: null,\n87:     build_output: null,\n88:     completed_at: null,\n89:   });\n90:   saveState(projectRoot, state);\n91: \n92:   const data = loadFeatures(projectRoot, config);\n93:   const feature = data.features.find((f) => f.id === opts.featureId);\n94:   if (!feature) {\n95:     console.error(`Feature ${opts.featureId} not found in ${config.featuresFile}`);\n96:     process.exit(1);\n97:     return; // unreachable — helps TypeScript narrow\n98:   }\n99: \n100:   if (opts.interactive) {\n101:     const prompt = generatePrompt(feature, state.base_branch, config);\n102:     launchInteractive({\n103:       worktreePath: agent.worktree,\n104:       featureId: feature.id,\n105:       prompt,\n106:       model: opts.model,\n107:       interactive: true,\n108:       config,\n109:     });\n110: \n111:     updateAgent(state, agent.feature_id, {\n112:       status: \"running\",\n113:       started_at: new Date().toISOString(),\n114:     });\n115:     saveState(projectRoot, state);\n116:     console.log(`Retrying ${opts.featureId} in tmux session ${config.agent.tmuxPrefix}-${opts.featureId}`);\n117:   } else {\n118:     const monitor = new ProcessMonitor(projectRoot);\n119:     await launchSingleHeadless(projectRoot, state, agent, feature, monitor, config, opts.model);\n120:     console.log(`Retrying ${opts.featureId} in headless mode`);\n121:   }\n122: }\n\n(End of file - total 122 lines)\n</content>","title":"src/commands/retry.ts","metadata":{"preview":"/**\n * retry.ts — Retry a specific failed agent.\n *\n * Usage: wombo retry <feature-id> [--interactive] [--model <model>]\n *\n * Resets the agent's retry count and re-launches it. Can launch in either\n * headless mode (default) or interactive (tmux) mode.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport { loadFeatures, type Feature } from \"../lib/features.js\";\nimport {\n  loadState,\n  saveState,\n  updateAgent,\n} from \"../lib/state.js\";\nimport { worktreeReady } from \"../lib/worktree.js\";\nimport { generatePrompt } from \"../lib/prompt.js\";\nimport { launchInteractive } from \"../lib/launcher.js\";\nimport { ProcessMonitor } from \"../lib/monitor.js\";","truncated":false,"loaded":[]},"time":{"start":1773351943149,"end":1773351943158}}}}
