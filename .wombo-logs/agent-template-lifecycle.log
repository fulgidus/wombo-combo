{"type":"text","timestamp":1773351577551,"sessionID":"ses_31c036d95ffenGqgaxNYTZEsYh","part":{"id":"prt_ce3fd977d002h2g2Qi3Mbbr8ka","sessionID":"ses_31c036d95ffenGqgaxNYTZEsYh","messageID":"msg_ce3fd8f94001DdkXtv58J6K8Xw","type":"text","text":"Now I see what values can be templated. The template contains hardcoded values that should be customizable per-project:\n\n1. `.features.yml` → should use `{{featuresFile}}` (from config)\n2. `feature/<feature-id>` → the branch prefix should be `{{branchPrefix}}`\n3. `Bun (not Node). TypeScript, strict mode, ESM only.` → this is project-specific and should be `{{runtime}}`\n4. The build command reference on line 44 → should use `{{buildCommand}}`\n\nLet me also look at how `generatePrompt` works to understand what gets passed to agents:","time":{"start":1773351577551,"end":1773351577551}}}
{"type":"tool_use","timestamp":1773351577554,"sessionID":"ses_31c036d95ffenGqgaxNYTZEsYh","part":{"id":"prt_ce3fda4de001PJ7fMsBmaCBMiY","sessionID":"ses_31c036d95ffenGqgaxNYTZEsYh","messageID":"msg_ce3fd8f94001DdkXtv58J6K8Xw","type":"tool","callID":"toolu_vrtx_01JXQ8KDAVH4KWK1uFavVZpv","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-agent-template-lifecycle/src/lib/prompt.ts"},"output":"<path>/home/fulgidus/Documents/wombo-agent-template-lifecycle/src/lib/prompt.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * prompt.ts — Generate agent prompts from feature specs.\n3:  *\n4:  * Responsibilities:\n5:  *   - Transform a Feature into a structured prompt for the agent\n6:  *   - Include feature spec, subtasks, constraints, forbidden items, references\n7:  *   - Generate the build command and success criteria\n8:  *   - All project-specific values come from config (no hardcoded Astro references)\n9:  */\n10: \n11: import type { Feature, Subtask } from \"./features.js\";\n12: import { formatDuration, parseDurationMinutes } from \"./features.js\";\n13: import type { WomboConfig } from \"../config.js\";\n14: \n15: // ---------------------------------------------------------------------------\n16: // Prompt Generation\n17: // ---------------------------------------------------------------------------\n18: \n19: /**\n20:  * Generate the full prompt for an autonomous agent working on a feature.\n21:  */\n22: export function generatePrompt(\n23:   feature: Feature,\n24:   baseBranch: string,\n25:   config: WomboConfig\n26: ): string {\n27:   const sections: string[] = [];\n28: \n29:   // Header\n30:   sections.push(`# Feature Implementation: ${feature.title}`);\n31:   sections.push(`**Feature ID:** \\`${feature.id}\\``);\n32:   sections.push(`**Branch:** \\`${config.git.branchPrefix}${feature.id}\\``);\n33:   sections.push(`**Base:** \\`${baseBranch}\\``);\n34:   sections.push(\n35:     `**Estimated Effort:** ${formatDuration(parseDurationMinutes(feature.effort))}`\n36:   );\n37:   sections.push(\n38:     `**Difficulty:** ${feature.difficulty} | **Priority:** ${feature.priority}`\n39:   );\n40: \n41:   // Description\n42:   sections.push(`\\n## Description\\n`);\n43:   sections.push(feature.description.trim());\n44: \n45:   // Subtasks\n46:   if (feature.subtasks.length > 0) {\n47:     sections.push(`\\n## Subtasks\\n`);\n48:     sections.push(\n49:       \"Complete these in order. Mark each done with a commit when finished.\\n\"\n50:     );\n51:     for (let i = 0; i < feature.subtasks.length; i++) {\n52:       sections.push(formatSubtask(feature.subtasks[i], i + 1, 0));\n53:     }\n54:   }\n55: \n56:   // Constraints\n57:   if (feature.constraints.length > 0) {\n58:     sections.push(`\\n## Constraints\\n`);\n59:     sections.push(\n60:       \"You MUST follow these constraints. Violating any is a failure.\\n\"\n61:     );\n62:     for (const c of feature.constraints) {\n63:       sections.push(`- ${c}`);\n64:     }\n65:   }\n66: \n67:   // Forbidden\n68:   if (feature.forbidden.length > 0) {\n69:     sections.push(`\\n## Forbidden\\n`);\n70:     sections.push(\n71:       \"You MUST NOT do any of the following. Violating any is a failure.\\n\"\n72:     );\n73:     for (const f of feature.forbidden) {\n74:       sections.push(`- ${f}`);\n75:     }\n76:   }\n77: \n78:   // References (files to explore)\n79:   if (feature.references.length > 0) {\n80:     sections.push(`\\n## Key Files to Explore\\n`);\n81:     sections.push(\n82:       \"Start by reading these files to understand the current state:\\n\"\n83:     );\n84:     for (const r of feature.references) {\n85:       sections.push(`- \\`${r}\\``);\n86:     }\n87:   }\n88: \n89:   // Notes\n90:   if (feature.notes.length > 0) {\n91:     sections.push(`\\n## Planning Notes\\n`);\n92:     for (const n of feature.notes) {\n93:       sections.push(`- ${n}`);\n94:     }\n95:   }\n96: \n97:   // Build verification — uses config, no hardcoded Astro command\n98:   sections.push(`\\n## Build Verification\\n`);\n99:   sections.push(\n100:     \"After completing all changes, run the build to verify everything works:\\n\"\n101:   );\n102:   sections.push(\"```bash\");\n103:   sections.push(config.build.command);\n104:   sections.push(\"```\\n\");\n105:   sections.push(\n106:     \"If the build fails, fix the errors before considering the task complete.\"\n107:   );\n108: \n109:   // Commit guidelines\n110:   sections.push(`\\n## Commit Guidelines\\n`);\n111:   sections.push(\"- Use conventional commits: `feat(scope):`, `fix(scope):`, `refactor(scope):`, `docs(scope):`\");\n112:   sections.push(`- Scope should be: \\`${feature.id}\\` or a relevant module name`);\n113:   sections.push(\"- Commit after each logical unit of work (roughly per subtask)\");\n114:   sections.push(\"- Do NOT squash all changes into one commit\");\n115:   sections.push(\"- Do NOT push to remote -- the orchestrator handles that\");\n116:   sections.push(`- Do NOT modify \\`${config.featuresFile}\\` -- the orchestrator handles that`);\n117: \n118:   // Final instruction\n119:   sections.push(`\\n## Execution\\n`);\n120:   sections.push(\"1. Read the key files listed above to understand the codebase\");\n121:   sections.push(\"2. Create a plan (use the TodoWrite tool)\");\n122:   sections.push(\"3. Implement each subtask, committing as you go\");\n123:   sections.push(`4. Run \\`${config.build.command}\\` to verify`);\n124:   sections.push(\"5. If the build passes, you are done\");\n125:   sections.push(\"6. If the build fails, fix the errors and re-run until it passes\");\n126: \n127:   return sections.join(\"\\n\");\n128: }\n129: \n130: // ---------------------------------------------------------------------------\n131: // Subtask Formatting\n132: // ---------------------------------------------------------------------------\n133: \n134: // ---------------------------------------------------------------------------\n135: // Conflict Resolution Prompt\n136: // ---------------------------------------------------------------------------\n137: \n138: /**\n139:  * Generate a prompt for an agent that resolves merge conflicts.\n140:  *\n141:  * The agent is launched in the feature worktree AFTER `git merge <baseBranch>`\n142:  * has been run there, leaving conflict markers in the working tree.\n143:  */\n144: export function generateConflictResolutionPrompt(\n145:   feature: Feature,\n146:   baseBranch: string,\n147:   mergeError: string,\n148:   config: WomboConfig\n149: ): string {\n150:   const sections: string[] = [];\n151: \n152:   sections.push(`# Merge Conflict Resolution: ${feature.title}`);\n153:   sections.push(`**Feature ID:** \\`${feature.id}\\``);\n154:   sections.push(`**Feature Branch:** \\`${config.git.branchPrefix}${feature.id}\\``);\n155:   sections.push(`**Base Branch:** \\`${baseBranch}\\``);\n156: \n157:   sections.push(`\\n## Situation\\n`);\n158:   sections.push(\n159:     `The feature branch \\`${config.git.branchPrefix}${feature.id}\\` has been completed and build-verified, ` +\n160:     `but merging it into \\`${baseBranch}\\` produced conflicts. The base branch (\\`${baseBranch}\\`) has been ` +\n161:     `merged INTO this feature branch's worktree, so the conflict markers are present in the working tree right now.`\n162:   );\n163: \n164:   sections.push(`\\n## Merge Error Output\\n`);\n165:   sections.push(\"```\");\n166:   sections.push(mergeError);\n167:   sections.push(\"```\");\n168: \n169:   sections.push(`\\n## Feature Description\\n`);\n170:   sections.push(feature.description.trim());\n171: \n172:   sections.push(`\\n## Your Task\\n`);\n173:   sections.push(\"1. Find all files with conflict markers (`<<<<<<<`, `=======`, `>>>>>>>`)\");\n174:   sections.push(\"2. Resolve each conflict by combining both sides intelligently:\");\n175:   sections.push(`   - The \\`HEAD\\` side is the feature's work (keep this intent)`);\n176:   sections.push(`   - The \\`${baseBranch}\\` side is upstream changes (integrate these)`);\n177:   sections.push(\"3. Remove ALL conflict markers — no `<<<<<<<`, `=======`, or `>>>>>>>` should remain\");\n178:   sections.push(\"4. Run the build to verify everything compiles:\");\n179:   sections.push(\"   ```bash\");\n180:   sections.push(`   ${config.build.command}`);\n181:   sections.push(\"   ```\");\n182:   sections.push(\"5. If the build fails, fix the errors\");\n183:   sections.push(\"6. Stage all resolved files and commit the merge:\");\n184:   sections.push(\"   ```bash\");\n185:   sections.push(\"   git add -A\");\n186:   sections.push('   git commit --no-edit');\n187:   sections.push(\"   ```\");\n188: \n189:   sections.push(`\\n## Rules\\n`);\n190:   sections.push(\"- Do NOT abort the merge (`git merge --abort`)\");\n191:   sections.push(\"- Do NOT create new branches or rebase\");\n192:   sections.push(\"- Do NOT push to remote\");\n193:   sections.push(`- Do NOT modify \\`${config.featuresFile}\\``);\n194:   sections.push(\"- Keep BOTH the feature's changes and the upstream changes where possible\");\n195:   sections.push(\"- If in doubt, prefer the feature's implementation but ensure upstream additions are not lost\");\n196: \n197:   return sections.join(\"\\n\");\n198: }\n199: \n200: // ---------------------------------------------------------------------------\n201: // Subtask Formatting\n202: // ---------------------------------------------------------------------------\n203: \n204: function formatSubtask(\n205:   subtask: Subtask,\n206:   index: number,\n207:   depth: number\n208: ): string {\n209:   const indent = \"  \".repeat(depth);\n210:   const lines: string[] = [];\n211: \n212:   lines.push(\n213:     `${indent}${index}. **${subtask.title}** (\\`${subtask.id}\\`, ${formatDuration(parseDurationMinutes(subtask.effort))})`\n214:   );\n215:   lines.push(`${indent}   ${subtask.description.trim()}`);\n216: \n217:   if (subtask.constraints.length > 0) {\n218:     for (const c of subtask.constraints) {\n219:       lines.push(`${indent}   - Constraint: ${c}`);\n220:     }\n221:   }\n222:   if (subtask.forbidden.length > 0) {\n223:     for (const f of subtask.forbidden) {\n224:       lines.push(`${indent}   - Forbidden: ${f}`);\n225:     }\n226:   }\n227:   if (subtask.references.length > 0) {\n228:     lines.push(\n229:       `${indent}   - Files: ${subtask.references.map((r) => `\\`${r}\\``).join(\", \")}`\n230:     );\n231:   }\n232:   if (subtask.depends_on.length > 0) {\n233:     lines.push(\n234:       `${indent}   - Depends on: ${subtask.depends_on.map((d) => `\\`${d}\\``).join(\", \")}`\n235:     );\n236:   }\n237: \n238:   // Nested subtasks\n239:   if (subtask.subtasks.length > 0) {\n240:     for (let i = 0; i < subtask.subtasks.length; i++) {\n241:       lines.push(formatSubtask(subtask.subtasks[i], i + 1, depth + 1));\n242:     }\n243:   }\n244: \n245:   return lines.join(\"\\n\");\n246: }\n\n(End of file - total 246 lines)\n</content>","title":"src/lib/prompt.ts","metadata":{"preview":"/**\n * prompt.ts — Generate agent prompts from feature specs.\n *\n * Responsibilities:\n *   - Transform a Feature into a structured prompt for the agent\n *   - Include feature spec, subtasks, constraints, forbidden items, references\n *   - Generate the build command and success criteria\n *   - All project-specific values come from config (no hardcoded Astro references)\n */\n\nimport type { Feature, Subtask } from \"./features.js\";\nimport { formatDuration, parseDurationMinutes } from \"./features.js\";\nimport type { WomboConfig } from \"../config.js\";\n\n// ---------------------------------------------------------------------------\n// Prompt Generation\n// ---------------------------------------------------------------------------\n\n/**\n * Generate the full prompt for an autonomous agent working on a feature.","truncated":false,"loaded":[]},"time":{"start":1773351577550,"end":1773351577553}}}}
