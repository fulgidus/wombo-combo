tring,\n259:   config: WomboConfig\n260: ): void {\n261:   const missing: string[] = [];\n262: \n263:   for (const configFile of config.agent.configFiles) {\n264:     const srcPath = resolve(projectRoot, configFile);\n265:     const destPath = resolve(wtPath, configFile);\n266: \n267:     // Only check files/dirs that exist in the source project\n268:     if (!existsSync(srcPath)) continue;\n269: \n270:     if (!existsSync(destPath)) {\n271:       missing.push(configFile);\n272:     }\n273:   }\n274: \n275:   if (missing.length > 0) {\n276:     log(\n277:       featureId,\n278:       `\\x1b[33mWARNING\\x1b[0m: config files missing in worktree: ${missing.join(\", \")}`\n279:     );\n280:   }\n281: }\n282: \n\n(Showing lines 218-282 of 467. Use offset=283 to continue.)\n</content>","title":"src/lib/worktree.ts","metadata":{"preview":" */\nfunction copyConfigFiles(\n  projectRoot: string,\n  wtPath: string,\n  featureId: string,\n  config: WomboConfig\n): void {\n  for (const configFile of config.agent.configFiles) {\n    const srcPath = resolve(projectRoot, configFile);\n    if (!existsSync(srcPath)) continue;\n\n    const destPath = resolve(wtPath, configFile);\n    try {\n      const stat = statSync(srcPath);\n      if (stat.isDirectory()) {\n        cpSync(srcPath, destPath, { recursive: true });\n      } else {\n        cpSync(srcPath, destPath);\n      }\n    } catch {","truncated":true,"loaded":[]},"time":{"start":1773351687127,"end":1773351687130}}}}
