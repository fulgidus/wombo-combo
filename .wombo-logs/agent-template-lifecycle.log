{"type":"tool_use","timestamp":1773351521632,"sessionID":"ses_31c036d95ffenGqgaxNYTZEsYh","part":{"id":"prt_ce3fccaf9001zaPGZHb0E7TxlD","sessionID":"ses_31c036d95ffenGqgaxNYTZEsYh","messageID":"msg_ce3fcbf32001W6vTR2NUD395kI","type":"tool","callID":"toolu_vrtx_01BhMEauHbBNRBBCPKAKmt9X","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-agent-template-lifecycle/src/commands/init.ts"},"output":"<path>/home/fulgidus/Documents/wombo-agent-template-lifecycle/src/commands/init.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * init.ts — Interactive guided setup for wombo.json.\n3:  *\n4:  * Usage: wombo init [--force]\n5:  *\n6:  * Walks the user through every config section, showing defaults and\n7:  * accepting overrides.  Press Enter on any prompt to keep the default.\n8:  */\n9: \n10: import { existsSync, writeFileSync, readFileSync, mkdirSync } from \"node:fs\";\n11: import { resolve } from \"node:path\";\n12: import { createInterface } from \"node:readline\";\n13: import { CONFIG_FILE, DEFAULT_CONFIG, type WomboConfig } from \"../config.js\";\n14: import { FEATURES_TEMPLATE_PATH } from \"../lib/features.js\";\n15: import { AGENT_TEMPLATE_PATH } from \"../lib/templates.js\";\n16: \n17: export interface InitOptions {\n18:   projectRoot: string;\n19:   force?: boolean;\n20: }\n21: \n22: // ---------------------------------------------------------------------------\n23: // Prompt helper — reads one line at a time from stdin\n24: // ---------------------------------------------------------------------------\n25: \n26: class Prompter {\n27:   private lines: AsyncIterableIterator<string>;\n28:   private done = false;\n29:   private rl: ReturnType<typeof createInterface>;\n30: \n31:   constructor() {\n32:     this.rl = createInterface({ input: process.stdin, output: process.stdout, terminal: process.stdin.isTTY ?? false });\n33:     this.lines = this.rl[Symbol.asyncIterator]();\n34:   }\n35: \n36:   /** Read one line from stdin after printing the prompt. */\n37:   private async ask(prompt: string): Promise<string> {\n38:     if (this.done) return \"\";\n39:     process.stdout.write(prompt);\n40:     const result = await this.lines.next();\n41:     if (result.done) {\n42:       this.done = true;\n43:       return \"\";\n44:     }\n45:     return result.value.trim();\n46:   }\n47: \n48:   async string(label: string, defaultVal: string): Promise<string> {\n49:     const answer = await this.ask(`  ${label} [${defaultVal}]: `);\n50:     return answer || defaultVal;\n51:   }\n52: \n53:   async number(label: string, defaultVal: number): Promise<number> {\n54:     const answer = await this.ask(`  ${label} [${defaultVal}]: `);\n55:     if (!answer) return defaultVal;\n56:     const n = parseInt(answer, 10);\n57:     return isNaN(n) ? defaultVal : n;\n58:   }\n59: \n60:   async stringOrNull(label: string, defaultVal: string | null): Promise<string | null> {\n61:     const display = defaultVal ?? \"auto-detect\";\n62:     const answer = await this.ask(`  ${label} [${display}]: `);\n63:     if (!answer) return defaultVal;\n64:     if (answer.toLowerCase() === \"null\" || answer.toLowerCase() === \"auto\") return null;\n65:     return answer;\n66:   }\n67: \n68:   async stringList(label: string, defaultVal: string[]): Promise<string[]> {\n69:     const display = defaultVal.join(\", \");\n70:     const answer = await this.ask(`  ${label} [${display}]: `);\n71:     if (!answer) return defaultVal;\n72:     return answer.split(\",\").map((s) => s.trim()).filter(Boolean);\n73:   }\n74: \n75:   async yesNo(label: string, defaultVal: boolean): Promise<boolean> {\n76:     const display = defaultVal ? \"Y/n\" : \"y/N\";\n77:     const answer = await this.ask(`  ${label} [${display}]: `);\n78:     if (!answer) return defaultVal;\n79:     return answer.toLowerCase().startsWith(\"y\");\n80:   }\n81: \n82:   close(): void {\n83:     this.rl.close();\n84:   }\n85: }\n86: \n87: // ---------------------------------------------------------------------------\n88: // Section printer\n89: // ---------------------------------------------------------------------------\n90: \n91: function section(title: string): void {\n92:   console.log(`\\n--- ${title} ${\"─\".repeat(Math.max(0, 56 - title.length))}`);\n93: }\n94: \n95: // ---------------------------------------------------------------------------\n96: // Command\n97: // ---------------------------------------------------------------------------\n98: \n99: export async function cmdInit(opts: InitOptions): Promise<void> {\n100:   const configPath = resolve(opts.projectRoot, CONFIG_FILE);\n101: \n102:   if (existsSync(configPath) && !opts.force) {\n103:     console.error(\n104:       `${CONFIG_FILE} already exists. Use --force to overwrite.`\n105:     );\n106:     process.exit(1);\n107:   }\n108: \n109:   console.log(`\\nWombo — Project Setup`);\n110:   console.log(`Configuring ${CONFIG_FILE} for ${opts.projectRoot}`);\n111:   console.log(`Press Enter to accept the default shown in [brackets].\\n`);\n112: \n113:   const p = new Prompter();\n114: \n115:   try {\n116:     const cfg: WomboConfig = structuredClone(DEFAULT_CONFIG);\n117: \n118:     // -- General ----------------------------------------------------------\n119:     section(\"General\");\n120:     cfg.featuresFile = await p.string(\"Features YAML file\", cfg.featuresFile);\n121:     cfg.baseBranch = await p.string(\"Base branch\", cfg.baseBranch);\n122: \n123:     // -- Build ------------------------------------------------------------\n124:     section(\"Build\");\n125:     cfg.build.command = await p.string(\"Build command\", cfg.build.command);\n126:     cfg.build.timeout = await p.number(\"Build timeout (ms)\", cfg.build.timeout);\n127:     cfg.build.artifactDir = await p.string(\"Artifact directory\", cfg.build.artifactDir);\n128: \n129:     // -- Install ----------------------------------------------------------\n130:     section(\"Install\");\n131:     cfg.install.command = await p.string(\"Install command\", cfg.install.command);\n132:     cfg.install.timeout = await p.number(\"Install timeout (ms)\", cfg.install.timeout);\n133: \n134:     // -- Git --------------------------------------------------------------\n135:     section(\"Git\");\n136:     cfg.git.branchPrefix = await p.string(\"Branch prefix\", cfg.git.branchPrefix);\n137:     cfg.git.worktreePrefix = await p.string(\"Worktree prefix\", cfg.git.worktreePrefix);\n138:     cfg.git.remote = await p.string(\"Remote name\", cfg.git.remote);\n139:     cfg.git.mergeStrategy = await p.string(\"Merge strategy flag\", cfg.git.mergeStrategy);\n140: \n141:     // -- Agent ------------------------------------------------------------\n142:     section(\"Agent\");\n143:     cfg.agent.bin = await p.stringOrNull(\"Agent binary path (or 'auto')\", cfg.agent.bin);\n144:     cfg.agent.name = await p.string(\"Agent name\", cfg.agent.name);\n145:     cfg.agent.configFiles = await p.stringList(\n146:       \"Config files to copy (comma-sep)\",\n147:       cfg.agent.configFiles\n148:     );\n149:     cfg.agent.tmuxPrefix = await p.string(\"tmux session prefix\", cfg.agent.tmuxPrefix);\n150: \n151:     // -- Defaults ---------------------------------------------------------\n152:     section(\"Runtime Defaults\");\n153:     cfg.defaults.maxConcurrent = await p.number(\"Max concurrent agents\", cfg.defaults.maxConcurrent);\n154:     cfg.defaults.maxRetries = await p.number(\"Max retries per agent\", cfg.defaults.maxRetries);\n155: \n156:     // -- Write config ------------------------------------------------------\n157:     console.log(`\\n${\"─\".repeat(60)}`);\n158:     const json = JSON.stringify(cfg, null, 2) + \"\\n\";\n159:     writeFileSync(configPath, json, \"utf-8\");\n160:     console.log(`\\nCreated ${CONFIG_FILE}`);\n161: \n162:     // -- Create features file from template -------------------------------\n163:     const featuresPath = resolve(opts.projectRoot, cfg.featuresFile);\n164:     if (existsSync(featuresPath) && !opts.force) {\n165:       console.log(`${cfg.featuresFile} already exists, skipping.`);\n166:     } else {\n167:       const template = readFileSync(FEATURES_TEMPLATE_PATH, \"utf-8\");\n168:       const now = new Date().toISOString();\n169:       const content = template\n170:         .replace(/created_at:\\s*\".*?\"/, `created_at: \"${now}\"`)\n171:         .replace(/updated_at:\\s*\".*?\"/, `updated_at: \"${now}\"`);\n172:       writeFileSync(featuresPath, content, \"utf-8\");\n173:       console.log(`Created ${cfg.featuresFile} from template.`);\n174:     }\n175: \n176:     // -- Install agent definition template --------------------------------\n177:     const agentDir = resolve(opts.projectRoot, \"agent\");\n178:     const agentDefPath = resolve(agentDir, `${cfg.agent.name}.md`);\n179: \n180:     let installAgent = true;\n181:     if (existsSync(agentDefPath) && !opts.force) {\n182:       installAgent = await p.yesNo(\n183:         `agent/${cfg.agent.name}.md already exists. Overwrite?`,\n184:         false\n185:       );\n186:     }\n187: \n188:     if (installAgent) {\n189:       mkdirSync(agentDir, { recursive: true });\n190:       const agentTemplate = readFileSync(AGENT_TEMPLATE_PATH, \"utf-8\");\n191:       writeFileSync(agentDefPath, agentTemplate, \"utf-8\");\n192:       console.log(`Created agent/${cfg.agent.name}.md from template.`);\n193:     } else {\n194:       console.log(`agent/${cfg.agent.name}.md already exists, skipping.`);\n195:     }\n196: \n197:     // Ensure agent/ is in configFiles\n198:     if (!cfg.agent.configFiles.includes(\"agent/\")) {\n199:       cfg.agent.configFiles.push(\"agent/\");\n200:       // Re-write config with updated configFiles\n201:       const updatedJson = JSON.stringify(cfg, null, 2) + \"\\n\";\n202:       writeFileSync(configPath, updatedJson, \"utf-8\");\n203:       console.log(`Added agent/ to configFiles in ${CONFIG_FILE}.`);\n204:     }\n205: \n206:     console.log(`\\nYou're all set! Run 'wombo help' to see available commands.\\n`);\n207:   } finally {\n208:     p.close();\n209:   }\n210: }\n\n(End of file - total 210 lines)\n</content>","title":"src/commands/init.ts","metadata":{"preview":"/**\n * init.ts — Interactive guided setup for wombo.json.\n *\n * Usage: wombo init [--force]\n *\n * Walks the user through every config section, showing defaults and\n * accepting overrides.  Press Enter on any prompt to keep the default.\n */\n\nimport { existsSync, writeFileSync, readFileSync, mkdirSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\nimport { createInterface } from \"node:readline\";\nimport { CONFIG_FILE, DEFAULT_CONFIG, type WomboConfig } from \"../config.js\";\nimport { FEATURES_TEMPLATE_PATH } from \"../lib/features.js\";\nimport { AGENT_TEMPLATE_PATH } from \"../lib/templates.js\";\n\nexport interface InitOptions {\n  projectRoot: string;\n  force?: boolean;\n}","truncated":false,"loaded":[]},"time":{"start":1773351521601,"end":1773351521621}}}}
{"type":"tool_use","timestamp":1773351521934,"sessionID":"ses_31c036d95ffenGqgaxNYTZEsYh","part":{"id":"prt_ce3fccd4b001rLOmj52ESjicAS","sessionID":"ses_31c036d95ffenGqgaxNYTZEsYh","messageID":"msg_ce3fcbf32001W6vTR2NUD395kI","type":"tool","callID":"toolu_vrtx_01EfzJycwVusiyHyeFEwp3LW","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-agent-template-lifecycle/src/commands/launch.ts"},"output":"<path>/home/fulgidus/Documents/wombo-agent-template-lifecycle/src/commands/launch.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * launch.ts — Launch a wave of agents.\n3:  *\n4:  * Usage: wombo launch [selection options] [launch options]\n5:  *\n6:  * This is the primary entry point for starting a new wave. It selects features\n7:  * from the features file, creates a wave state, sets up worktrees, and launches\n8:  * agent processes (either headless or interactive via tmux).\n9:  *\n10:  * IMPORTANT: This file also exports shared helper functions that are reused\n11:  * by resume.ts and other commands:\n12:  *   - launchSingleHeadless\n13:  *   - handleBuildVerification\n14:  *   - handleRetry\n15:  *   - launchNextQueued\n16:  */\n17: \n18: import { execSync } from \"node:child_process\";\n19: import type { WomboConfig } from \"../config.js\";\n20: import type { Feature, SelectionOptions, Priority, Difficulty } from \"../lib/features.js\";\n21: import { loadFeatures, selectFeatures, parseDurationMinutes, saveFeatures } from \"../lib/features.js\";\n22: import {\n23:   loadState,\n24:   saveState,\n25:   createWaveState,\n26:   createAgentState,\n27:   updateAgent,\n28:   activeAgents,\n29:   queuedAgents,\n30:   isWaveComplete,\n31:   type WaveState,\n32:   type AgentState,\n33: } from \"../lib/state.js\";\n34: import {\n35:   createWorktree,\n36:   installDeps,\n37:   featureBranchName,\n38:   worktreePath,\n39:   worktreeReady,\n40:   branchHasChanges,\n41:   removeWorktree,\n42:   log as wtLog,\n43: } from \"../lib/worktree.js\";\n44: import { generatePrompt, generateConflictResolutionPrompt } from \"../lib/prompt.js\";\n45: import {\n46:   launchHeadless,\n47:   retryHeadless,\n48:   launchInteractive,\n49:   retryInteractive,\n50:   launchConflictResolver,\n51:   isProcessRunning,\n52: } from \"../lib/launcher.js\";\n53: import { ProcessMonitor } from \"../lib/monitor.js\";\n54: import { runBuild } from \"../lib/verifier.js\";\n55: import { mergeBranch, mergeBaseIntoFeature, pushBaseBranch } from \"../lib/merger.js\";\n56: import {\n57:   printDashboard,\n58:   printFeatureSelection,\n59:   printAgentUpdate,\n60: } from \"../lib/ui.js\";\n61: import { WomboTUI } from \"../lib/tui.js\";\n62: import { ensureAgentDefinition } from \"../lib/templates.js\";\n63: \n64: // ---------------------------------------------------------------------------\n65: // Types\n66: // ---------------------------------------------------------------------------\n67: \n68: export interface LaunchCommandOptions {\n69:   projectRoot: string;\n70:   config: WomboConfig;\n71:   // Selection\n72:   topPriority?: number;\n73:   quickestWins?: number;\n74:   priority?: Priority;\n75:   difficulty?: Difficulty;\n76:   features?: string[];\n77:   allReady?: boolean;\n78:   // Launch\n79:   maxConcurrent: number;\n80:   model?: string;\n81:   interactive: boolean;\n82:   dryRun: boolean;\n83:   baseBranch: string;\n84:   maxRetries: number;\n85:   noTui: boolean;\n86:   autoPush: boolean;\n87: }\n88: \n89: // ---------------------------------------------------------------------------\n90: // Shared Helpers (exported for resume.ts and others)\n91: // ---------------------------------------------------------------------------\n92: \n93: /**\n94:  * Mark a feature as done in the features file after a successful merge.\n95:  * Updates status to \"done\", completion to 100, and sets ended_at.\n96:  *\n97:  * GUARD: Verifies that the feature branch has actually been merged into\n98:  * baseBranch before allowing the status change. This prevents callers\n99:  * from accidentally marking verified-but-unmerged features as done.\n100:  */\n101: export function markFeatureDone(\n102:   projectRoot: string,\n103:   featureId: string,\n104:   config: WomboConfig,\n105:   baseBranch: string\n106: ): void {\n107:   try {\n108:     // Verify the feature branch was actually merged into base\n109:     const branch = featureBranchName(featureId, config);\n110:     try {\n111:       execSync(`git merge-base --is-ancestor \"${branch}\" \"${baseBranch}\"`, {\n112:         cwd: projectRoot,\n113:         stdio: \"pipe\",\n114:       });\n115:     } catch {\n116:       // git merge-base --is-ancestor exits non-zero if NOT an ancestor\n117:       console.error(\n118:         `Warning: ${featureId} branch \"${branch}\" is not merged into \"${baseBranch}\" — refusing to mark as done`\n119:       );\n120:       return;\n121:     }\n122: \n123:     const data = loadFeatures(projectRoot, config);\n124:     const feature = data.features.find((f) => f.id === featureId);\n125:     if (feature && feature.status !== \"done\") {\n126:       feature.status = \"done\";\n127:       feature.completion = 100;\n128:       feature.ended_at = new Date().toISOString();\n129:       saveFeatures(projectRoot, config, data);\n130:     }\n131:   } catch (err: any) {\n132:     // Non-fatal — log but don't crash the wave\n133:     console.error(`Warning: failed to update feature status for ${featureId}: ${err.message}`);\n134:   }\n135: }\n136: \n137: /**\n138:  * Launch a single agent in headless mode.\n139:  * Sets up worktree, installs deps, generates prompt, launches agent process.\n140:  */\n141: export async function launchSingleHeadless(\n142:   projectRoot: string,\n143:   state: WaveState,\n144:   agent: AgentState,\n145:   feature: Feature,\n146:   monitor: ProcessMonitor,\n147:   config: WomboConfig,\n148:   model?: string\n149: ): Promise<void> {\n150:   updateAgent(state, agent.feature_id, {\n151:     status: \"installing\",\n152:     started_at: new Date().toISOString(),\n153:     activity: \"setting up worktree...\",\n154:   });\n155:   saveState(projectRoot, state);\n156: \n157:   try {\n158:     // Skip worktree setup if already ready (resume case)\n159:     if (worktreeReady(agent.worktree)) {\n160:       wtLog(agent.feature_id, \"worktree already exists, skipping setup\");\n161:     } else {\n162:       // Create worktree (async — doesn't block other agents)\n163:       await createWorktree(projectRoot, feature.id, state.base_branch, config);\n164: \n165:       // Install dependencies (async)\n166:       updateAgent(state, agent.feature_id, { activity: \"installing deps...\" });\n167:       await installDeps(agent.worktree, feature.id, config);\n168:     }\n169: \n170:     // Generate prompt\n171:     const prompt = generatePrompt(feature, state.base_branch, config);\n172: \n173:     // Launch agent\n174:     wtLog(agent.feature_id, \"launching agent...\");\n175:     const result = launchHeadless({\n176:       worktreePath: agent.worktree,\n177:       featureId: feature.id,\n178:       prompt,\n179:       model,\n180:       config,\n181:     });\n182: \n183:     updateAgent(state, agent.feature_id, {\n184:       status: \"running\",\n185:       pid: result.pid,\n186:       activity: \"starting...\",\n187:     });\n188:     saveState(projectRoot, state);\n189: \n190:     monitor.addProcess(feature.id, result.process);\n191:     wtLog(agent.feature_id, `running (PID: ${result.pid})`);\n192:   } catch (err: any) {\n193:     updateAgent(state, agent.feature_id, {\n194:       status: \"failed\",\n195:       error: err.message,\n196:       activity: null,\n197:       completed_at: new Date().toISOString(),\n198:     });\n199:     saveState(projectRoot, state);\n200:     wtLog(agent.feature_id, `SETUP FAILED: ${err.message.split(\"\\n\")[0]}`);\n201:   }\n202: }\n203: \n204: /**\n205:  * Handle build verification after agent completion.\n206:  * Runs build, auto-merges on pass, retries on failure if retries remain.\n207:  *\n208:  * ASYNC — runs build and merge without blocking the event loop.\n209:  */\n210: export async function handleBuildVerification(\n211:   projectRoot: string,\n212:   state: WaveState,\n213:   agent: AgentState,\n214:   feature: Feature,\n215:   config: WomboConfig,\n216:   model?: string,\n217:   monitor?: ProcessMonitor\n218: ): Promise<void> {\n219:   try {\n220:     printAgentUpdate(agent, \"verifying build...\");\n221: \n222:     const buildResult = await runBuild(agent.worktree, config);\n223: \n224:     if (buildResult.passed) {\n225:       updateAgent(state, agent.feature_id, {\n226:         status: \"verified\",\n227:         build_passed: true,\n228:         build_output: null,\n229:       });\n230:       saveState(projectRoot, state);\n231:       printAgentUpdate(agent, `BUILD PASSED (${Math.round(buildResult.durationMs / 1000)}s)`);\n232: \n233:       // Auto-merge: attempt merge + conflict resolution\n234:       await attemptMerge(projectRoot, state, agent, feature, config, model);\n235:     } else {\n236:       if (agent.retries < agent.max_retries) {\n237:         updateAgent(state, agent.feature_id, {\n238:           status: \"retry\",\n239:           retries: agent.retries + 1,\n240:           build_passed: false,\n241:           build_output: buildResult.errorSummary,\n242:         });\n243:         saveState(projectRoot, state);\n244:         printAgentUpdate(\n245:           agent,\n246:           `BUILD FAILED — retrying (${agent.retries}/${agent.max_retries})`\n247:         );\n248: \n249:         // Retry with build errors\n250:         if (agent.session_id) {\n251:           const retryResult = retryHeadless({\n252:             worktreePath: agent.worktree,\n253:             featureId: agent.feature_id,\n254:             sessionId: agent.session_id,\n255:             buildErrors: buildResult.errorSummary,\n256:             model,\n257:             config,\n258:           });\n259: \n260:           updateAgent(state, agent.feature_id, {\n261:             status: \"running\",\n262:             pid: retryResult.pid,\n263:           });\n264:           saveState(projectRoot, state);\n265: \n266:           // Add retry process to monitor so events are tracked\n267:           if (monitor) {\n268:             monitor.addProcess(agent.feature_id, retryResult.process);\n269:           }\n270:         }\n271:       } else {\n272:         updateAgent(state, agent.feature_id, {\n273:           status: \"failed\",\n274:           build_passed: false,\n275:           build_output: buildResult.errorSummary,\n276:           error: `Build failed after ${agent.max_retries} retries`,\n277:           completed_at: new Date().toISOString(),\n278:         });\n279:         saveState(projectRoot, state);\n280:         printAgentUpdate(agent, \"BUILD FAILED — max retries reached\");\n281:       }\n282:     }\n283:   } catch (err: any) {\n284:     // Catch-all — never let build verification crash the process\n285:     printAgentUpdate(agent, `VERIFY ERROR: ${err.message?.slice(0, 100)}`);\n286:     updateAgent(state, agent.feature_id, {\n287:       status: \"failed\",\n288:       error: `Build verification error: ${err.message}`,\n289:       completed_at: new Date().toISOString(),\n290:     });\n291:     saveState(projectRoot, state);\n292:   }\n293: }\n294: \n295: /**\n296:  * Attempt to merge a verified agent's branch into the base branch.\n297:  *\n298:  * Handles conflict detection, base-into-feature merge, and resolver agent\n299:  * launch. Extracted from handleBuildVerification so it can be called\n300:  * independently (e.g., from resume's sequential merge phase).\n301:  */\n302: export async function attemptMerge(\n303:   projectRoot: string,\n304:   state: WaveState,\n305:   agent: AgentState,\n306:   feature: Feature,\n307:   config: WomboConfig,\n308:   model?: string,\n309: ): Promise<void> {\n310:   printAgentUpdate(agent, \"auto-merging...\");\n311:   try {\n312:     const mergeResult = await mergeBranch(projectRoot, agent.branch, state.base_branch, config);\n313: \n314:     if (mergeResult.success) {\n315:       updateAgent(state, agent.feature_id, {\n316:         status: \"merged\",\n317:         completed_at: new Date().toISOString(),\n318:       });\n319:       saveState(projectRoot, state);\n320:       printAgentUpdate(agent, `MERGED (${mergeResult.commitHash?.slice(0, 7)})`);\n321: \n322:       // Mark feature as done in .features.yml so it won't be re-selected\n323:       markFeatureDone(projectRoot, agent.feature_id, config, state.base_branch);\n324: \n325:       // Clean up worktree after successful merge\n326:       try {\n327:         removeWorktree(projectRoot, agent.worktree, true);\n328:         printAgentUpdate(agent, \"worktree and branch removed\");\n329:       } catch {\n330:         // Not critical — worktree cleanup is best-effort\n331:       }\n332:     } else {\n333:       // Merge failed — attempt automatic conflict resolution\n334:       const mergeError = mergeResult.error ?? \"Unknown merge error\";\n335:       printAgentUpdate(agent, `MERGE CONFLICT — attempting resolution...`);\n336: \n337:       try {\n338:         // Merge base INTO the feature worktree to create conflict markers\n339:         const conflictResult = await mergeBaseIntoFeature(\n340:           agent.worktree,\n341:           state.base_branch,\n342:           config\n343:         );\n344: \n345:         if (conflictResult.error && !conflictResult.conflicting) {\n346:           printAgentUpdate(agent, `CONFLICT SETUP FAILED: ${conflictResult.error.slice(0, 100)}`);\n347:           return; // Leave as \"verified\" for manual resolution\n348:         }\n349: \n350:         if (!conflictResult.conflicting) {\n351:           // Base merged cleanly into feature — retry merge into base.\n352:           printAgentUpdate(agent, \"base merged cleanly into feature — retrying merge...\");\n353:           const retryMerge = await mergeBranch(projectRoot, agent.branch, state.base_branch, config);\n354:           if (retryMerge.success) {\n355:             updateAgent(state, agent.feature_id, {\n356:               status: \"merged\",\n357:               completed_at: new Date().toISOString(),\n358:             });\n359:             saveState(projectRoot, state);\n360:             printAgentUpdate(agent, `MERGED after rebase (${retryMerge.commitHash?.slice(0, 7)})`);\n361:             markFeatureDone(projectRoot, agent.feature_id, config, state.base_branch);\n362:             try {\n363:               removeWorktree(projectRoot, agent.worktree, true);\n364:             } catch {}\n365:             return;\n366:           }\n367: \n368:           // Retry still failed — launch resolver agent\n369:           printAgentUpdate(agent, `retry merge still failed — launching resolver agent...`);\n370: \n371:           const secondConflict = await mergeBaseIntoFeature(\n372:             agent.worktree,\n373:             state.base_branch,\n374:             config\n375:           );\n376: \n377:           const conflictFiles = secondConflict.conflicting\n378:             ? secondConflict.files\n379:             : [\"(unknown — merge direction mismatch)\"];\n380:           const resolverMergeError = retryMerge.error ?? mergeError;\n381: \n382:           await launchResolverAndRetryMerge(\n383:             projectRoot, state, agent, feature, config, model,\n384:             resolverMergeError, conflictFiles\n385:           );\n386:           return;\n387:         }\n388: \n389:         // There are real conflicts — launch a resolver agent\n390:         printAgentUpdate(\n391:           agent,\n392:           `${conflictResult.files.length} conflicting file(s): ${conflictResult.files.join(\", \")}`\n393:         );\n394: \n395:         await launchResolverAndRetryMerge(\n396:           projectRoot, state, agent, feature, config, model,\n397:           mergeError, conflictResult.files\n398:         );\n399:       } catch (conflictErr: any) {\n400:         printAgentUpdate(agent, `CONFLICT RESOLUTION ERROR: ${conflictErr.message?.slice(0, 100)}`);\n401:         // Leave as \"verified\" for manual resolution\n402:       }\n403:     }\n404:   } catch (mergeErr: any) {\n405:     printAgentUpdate(agent, `AUTO-MERGE ERROR: ${mergeErr.message?.slice(0, 100)}`);\n406:   }\n407: }\n408: \n409: /**\n410:  * Launch a conflict resolver agent, wait for it to finish, re-verify build,\n411:  * and retry the merge. Extracted to avoid duplicating the resolver flow.\n412:  */\n413: async function launchResolverAndRetryMerge(\n414:   projectRoot: string,\n415:   state: WaveState,\n416:   agent: AgentState,\n417:   feature: Feature,\n418:   config: WomboConfig,\n419:   model: string | undefined,\n420:   mergeError: string,\n421:   conflictFiles: string[]\n422: ): Promise<void> {\n423:   const conflictPrompt = generateConflictResolutionPrompt(\n424:     feature,\n425:     state.base_branch,\n426:     mergeError,\n427:     config\n428:   );\n429: \n430:   updateAgent(state, agent.feature_id, {\n431:     status: \"resolving_conflict\",\n432:     activity: `resolving ${conflictFiles.length} conflict(s)...`,\n433:   });\n434:   saveState(projectRoot, state);\n435: \n436:   const resolverResult = launchConflictResolver({\n437:     worktreePath: agent.worktree,\n438:     featureId: agent.feature_id,\n439:     prompt: conflictPrompt,\n440:     model,\n441:     config,\n442:   });\n443: \n444:   updateAgent(state, agent.feature_id, {\n445:     pid: resolverResult.pid,\n446:   });\n447:   saveState(projectRoot, state);\n448: \n449:   // Wait for the resolver process to complete, then re-verify and retry merge.\n450:   // We intentionally do NOT add the resolver to the ProcessMonitor because\n451:   // the monitor's onComplete callback would trigger handleBuildVerification\n452:   // again, causing infinite recursion. Instead we await the process directly.\n453:   const resolverExitCode = await new Promise<number | null>((resolve) => {\n454:     resolverResult.process.on(\"exit\", (code) => resolve(code));\n455:     resolverResult.process.on(\"error\", () => resolve(null));\n456:   });\n457: \n458:   printAgentUpdate(agent, `conflict resolver exited (code ${resolverExitCode}) — re-verifying build...`);\n459: \n460:   // Re-verify build after conflict resolution\n461:   const rebuildResult = await runBuild(agent.worktree, config);\n462: \n463:   if (!rebuildResult.passed) {\n464:     printAgentUpdate(agent, `POST-CONFLICT BUILD FAILED`);\n465:     updateAgent(state, agent.feature_id, {\n466:       status: \"failed\",\n467:       build_passed: false,\n468:       build_output: rebuildResult.errorSummary,\n469:       error: \"Build failed after conflict resolution\",\n470:       completed_at: new Date().toISOString(),\n471:     });\n472:     saveState(projectRoot, state);\n473:     return;\n474:   }\n475: \n476:   printAgentUpdate(agent, \"post-conflict build passed — retrying merge...\");\n477: \n478:   const retryMerge = await mergeBranch(\n479:     projectRoot,\n480:     agent.branch,\n481:     state.base_branch,\n482:     config\n483:   );\n484: \n485:   if (retryMerge.success) {\n486:     updateAgent(state, agent.feature_id, {\n487:       status: \"merged\",\n488:       build_passed: true,\n489:       completed_at: new Date().toISOString(),\n490:     });\n491:     saveState(projectRoot, state);\n492:     printAgentUpdate(agent, `MERGED after conflict resolution (${retryMerge.commitHash?.slice(0, 7)})`);\n493:     markFeatureDone(projectRoot, agent.feature_id, config, state.base_branch);\n494:     try {\n495:       removeWorktree(projectRoot, agent.worktree, true);\n496:     } catch {}\n497:   } else {\n498:     printAgentUpdate(agent, `POST-CONFLICT MERGE FAILED: ${retryMerge.error}`);\n499:     updateAgent(state, agent.feature_id, {\n500:       status: \"failed\",\n501:       error: `Merge still failed after conflict resolution: ${retryMerge.error}`,\n502:       completed_at: new Date().toISOString(),\n503:     });\n504:     saveState(projectRoot, state);\n505:   }\n506: }\n507: \n508: /**\n509:  * Handle retry of a failed agent (error-based, not build-based).\n510:  */\n511: export function handleRetry(\n512:   projectRoot: string,\n513:   state: WaveState,\n514:   agent: AgentState,\n515:   monitor: ProcessMonitor,\n516:   config: WomboConfig,\n517:   model?: string\n518: ): void {\n519:   if (!agent.session_id || !agent.error) return;\n520: \n521:   const retryResult = retryHeadless({\n522:     worktreePath: agent.worktree,\n523:     featureId: agent.feature_id,\n524:     sessionId: agent.session_id,\n525:     buildErrors: agent.error,\n526:     model,\n527:     config,\n528:   });\n529: \n530:   updateAgent(state, agent.feature_id, {\n531:     status: \"running\",\n532:     pid: retryResult.pid,\n533:   });\n534:   saveState(projectRoot, state);\n535: \n536:   monitor.addProcess(agent.feature_id, retryResult.process);\n537: }\n538: \n539: /**\n540:  * Launch the next queued agent if capacity allows.\n541:  */\n542: export function launchNextQueued(\n543:   projectRoot: string,\n544:   state: WaveState,\n545:   featureMap: Map<string, Feature>,\n546:   monitor: ProcessMonitor,\n547:   config: WomboConfig,\n548:   model?: string\n549: ): void {\n550:   const active = activeAgents(state);\n551:   const queued = queuedAgents(state);\n552: \n553:   if (active.length < state.max_concurrent && queued.length > 0) {\n554:     const next = queued[0];\n555:     const feature = featureMap.get(next.feature_id);\n556:     if (feature) {\n557:       launchSingleHeadless(projectRoot, state, next, feature, monitor, config, model);\n558:     }\n559:   }\n560: }\n561: \n562: // ---------------------------------------------------------------------------\n563: // Headless Wave Launch\n564: // ---------------------------------------------------------------------------\n565: \n566: async function launchWaveHeadless(\n567:   projectRoot: string,\n568:   state: WaveState,\n569:   features: Feature[],\n570:   opts: LaunchCommandOptions\n571: ): Promise<void> {\n572:   const { config, model } = opts;\n573:   const featureMap = new Map(features.map((f) => [f.id, f]));\n574: \n575:   const monitor = new ProcessMonitor(projectRoot, {\n576:     onSessionId: (featureId, sessionId) => {\n577:       updateAgent(state, featureId, { session_id: sessionId });\n578:       saveState(projectRoot, state);\n579:     },\n580:     onComplete: (featureId) => {\n581:       updateAgent(state, featureId, {\n582:         status: \"completed\",\n583:         completed_at: new Date().toISOString(),\n584:       });\n585:       saveState(projectRoot, state);\n586: \n587:       // Run build verification — fire-and-forget\n588:       const agent = state.agents.find((a) => a.feature_id === featureId)!;\n589:       handleBuildVerification(projectRoot, state, agent, featureMap.get(featureId)!, config, model, monitor)\n590:         .then(() => launchNextQueued(projectRoot, state, featureMap, monitor, config, model))\n591:         .catch((err) => {\n592:           wtLog(featureId, `BUILD VERIFICATION UNHANDLED ERROR: ${err.message}`);\n593:           launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n594:         });\n595:     },\n596:     onError: (featureId, error) => {\n597:       const agent = state.agents.find((a) => a.feature_id === featureId)!;\n598:       if (agent.retries < agent.max_retries) {\n599:         updateAgent(state, featureId, {\n600:           status: \"retry\",\n601:           retries: agent.retries + 1,\n602:           error,\n603:         });\n604:         saveState(projectRoot, state);\n605: \n606:         // Retry\n607:         handleRetry(projectRoot, state, agent, monitor, config, model);\n608:       } else {\n609:         updateAgent(state, featureId, {\n610:           status: \"failed\",\n611:           error,\n612:           completed_at: new Date().toISOString(),\n613:         });\n614:         saveState(projectRoot, state);\n615:       }\n616: \n617:       // Try to launch next queued agent\n618:       launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n619:     },\n620:     onOutput: (_featureId, _data) => {\n621:       // Raw output — logged to file by ProcessMonitor\n622:     },\n623:     onActivity: (featureId, activity) => {\n624:       updateAgent(state, featureId, {\n625:         activity,\n626:         activity_updated_at: new Date().toISOString(),\n627:       });\n628:       // Don't save to disk on every activity — too frequent.\n629:     },\n630:   });\n631: \n632:   // Create the TUI — it will auto-refresh and show activity from the monitor\n633:   const tuiRef = { current: null as WomboTUI | null };\n634:   const startTUI = () => {\n635:     tuiRef.current = new WomboTUI({\n636:       state,\n637:       monitor,\n638:       projectRoot,\n639:       interactive: false,\n640:       config,\n641:       onQuit: () => {\n642:         // Same as SIGINT — save state and exit\n643:         for (const agent of state.agents) {\n644:           if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n645:             updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n646:           }\n647:         }\n648:         monitor.killAll();\n649:         saveState(projectRoot, state);\n650:         console.log(\"State saved. Use 'wombo resume' to continue.\");\n651:         process.exit(0);\n652:       },\n653:     });\n654:     tuiRef.current.start();\n655:   };\n656: \n657:   // Handle graceful shutdown\n658:   process.on(\"SIGINT\", () => {\n659:     if (tuiRef.current) tuiRef.current.stop();\n660:     for (const agent of state.agents) {\n661:       if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n662:         updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n663:       }\n664:     }\n665:     monitor.killAll();\n666:     saveState(projectRoot, state);\n667:     console.log(\"\\nState saved. Use 'wombo resume' to continue.\");\n668:     process.exit(0);\n669:   });\n670: \n671:   // Launch initial batch — set up worktrees in parallel\n672:   const tolaunch = queuedAgents(state).slice(0, opts.maxConcurrent);\n673:   console.log(`Setting up ${tolaunch.length} agent(s) in parallel...\\n`);\n674: \n675:   await Promise.all(\n676:     tolaunch.map((agent) =>\n677:       launchSingleHeadless(\n678:         projectRoot,\n679:         state,\n680:         agent,\n681:         featureMap.get(agent.feature_id)!,\n682:         monitor,\n683:         config,\n684:         model\n685:       )\n686:     )\n687:   );\n688: \n689:   const launched = state.agents.filter((a) => a.status === \"running\").length;\n690: \n691:   // Start the TUI dashboard (or skip if --no-tui)\n692:   if (opts.noTui) {\n693:     console.log(`${launched} agent(s) running. (--no-tui mode, dashboard prints every 15s)\\n`);\n694:     printDashboard(state);\n695:   } else {\n696:     console.log(`${launched} agent(s) running. Launching TUI...\\n`);\n697:     startTUI();\n698:   }\n699: \n700:   // Background monitoring loop — checks for dead processes and launches queued\n701:   const POLL_INTERVAL = 5000;\n702:   let dashboardCounter = 0;\n703:   while (!isWaveComplete(state)) {\n704:     await new Promise((r) => setTimeout(r, POLL_INTERVAL));\n705: \n706:     // Check for completed processes that weren't caught by event handlers\n707:     for (const agent of state.agents) {\n708:       if (\n709:         (agent.status === \"running\" || agent.status === \"resolving_conflict\") &&\n710:         agent.pid &&\n711:         !isProcessRunning(agent.pid) &&\n712:         !monitor.isRunning(agent.feature_id)\n713:       ) {\n714:         if (agent.status === \"resolving_conflict\") {\n715:           // Conflict resolver died — the await in handleBuildVerification\n716:           // will resolve via the 'exit' event, so nothing to do here\n717:           continue;\n718:         }\n719:         // Process exited but we didn't get a callback\n720:         // Check if the agent actually made any commits\n721:         if (!branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n722:           // Agent died without producing any code — mark as failed, not completed\n723:           updateAgent(state, agent.feature_id, {\n724:             status: \"failed\",\n725:             error: \"Agent process exited without making any commits\",\n726:             activity: null,\n727:             completed_at: new Date().toISOString(),\n728:           });\n729:           saveState(projectRoot, state);\n730:           wtLog(agent.feature_id, \"process died with no code changes — marked failed\");\n731:         } else {\n732:           updateAgent(state, agent.feature_id, {\n733:             status: \"completed\",\n734:             completed_at: new Date().toISOString(),\n735:             activity: \"done\",\n736:           });\n737:           saveState(projectRoot, state);\n738:           try {\n739:             await handleBuildVerification(projectRoot, state, agent, featureMap.get(agent.feature_id)!, config, model, monitor);\n740:           } catch (err: any) {\n741:             wtLog(agent.feature_id, `POLL VERIFY ERROR: ${err.message}`);\n742:           }\n743:         }\n744:         launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n745:       }\n746:     }\n747: \n748:     // Persist state periodically\n749:     saveState(projectRoot, state);\n750: \n751:     // Update TUI state reference (or print dashboard in --no-tui mode)\n752:     if (tuiRef.current) {\n753:       tuiRef.current.updateState(state);\n754:     } else if (opts.noTui) {\n755:       dashboardCounter++;\n756:       if (dashboardCounter % 3 === 0) {\n757:         printDashboard(state);\n758: \n759:         // Auto-push base branch if requested\n760:         if (opts.autoPush) {\n761:           const anyMerged = state.agents.some((a) => a.status === \"merged\");\n762:           if (anyMerged) {\n763:             await pushBaseBranch(projectRoot, state.base_branch, config);\n764:           } else {\n765:             console.log(\"No branches were merged — skipping push.\");\n766:           }\n767:         }\n768:       }\n769:     }\n770:   }\n771: \n772:   // Wave complete — tear down TUI and show final summary\n773:   if (tuiRef.current) tuiRef.current.stop();\n774:   printDashboard(state);\n775: \n776:   // Auto-push base branch if requested\n777:   if (opts.autoPush) {\n778:     await pushBaseBranch(projectRoot, state.base_branch, config);\n779:   }\n780: \n781:   console.log(\"Wave complete.\");\n782: }\n783: \n784: // ---------------------------------------------------------------------------\n785: // Interactive Wave Launch\n786: // ---------------------------------------------------------------------------\n787: \n788: async function launchWaveInteractive(\n789:   projectRoot: string,\n790:   state: WaveState,\n791:   features: Feature[],\n792:   opts: LaunchCommandOptions\n793: ): Promise<void> {\n794:   const { config, model } = opts;\n795:   const featureMap = new Map(features.map((f) => [f.id, f]));\n796: \n797:   // Show dashboard immediately\n798:   printDashboard(state);\n799: \n800:   // Launch initial batch in tmux — parallelize setup\n801:   const tolaunch = queuedAgents(state).slice(0, opts.maxConcurrent);\n802:   console.log(`Setting up ${tolaunch.length} agent(s) in parallel...\\n`);\n803: \n804:   await Promise.all(\n805:     tolaunch.map(async (agent) => {\n806:       updateAgent(state, agent.feature_id, {\n807:         status: \"installing\",\n808:         started_at: new Date().toISOString(),\n809:         activity: \"setting up worktree...\",\n810:       });\n811:       saveState(projectRoot, state);\n812: \n813:       try {\n814:         if (worktreeReady(agent.worktree)) {\n815:           wtLog(agent.feature_id, \"worktree already exists, skipping setup\");\n816:         } else {\n817:           await createWorktree(projectRoot, agent.feature_id, state.base_branch, config);\n818:           updateAgent(state, agent.feature_id, { activity: \"installing deps...\" });\n819:           await installDeps(agent.worktree, agent.feature_id, config);\n820:         }\n821: \n822:         const prompt = generatePrompt(\n823:           featureMap.get(agent.feature_id)!,\n824:           state.base_branch,\n825:           config\n826:         );\n827: \n828:         wtLog(agent.feature_id, \"launching tmux session...\");\n829:         const result = launchInteractive({\n830:           worktreePath: agent.worktree,\n831:           featureId: agent.feature_id,\n832:           prompt,\n833:           model,\n834:           interactive: true,\n835:           config,\n836:         });\n837: \n838:         updateAgent(state, agent.feature_id, {\n839:           status: \"running\",\n840:           pid: result.pid,\n841:           activity: \"tmux session active\",\n842:         });\n843:         saveState(projectRoot, state);\n844:         wtLog(agent.feature_id, `tmux session: ${config.agent.tmuxPrefix}-${agent.feature_id}`);\n845:       } catch (err: any) {\n846:         updateAgent(state, agent.feature_id, {\n847:           status: \"failed\",\n848:           error: err.message,\n849:           activity: null,\n850:           completed_at: new Date().toISOString(),\n851:         });\n852:         saveState(projectRoot, state);\n853:         wtLog(agent.feature_id, `SETUP FAILED: ${err.message.split(\"\\n\")[0]}`);\n854:       }\n855:     })\n856:   );\n857: \n858:   console.log(\"\\nInteractive sessions launched. Use these commands:\");\n859:   console.log(`  tmux attach -t ${config.agent.tmuxPrefix}-<feature-id>   # attach to a session`);\n860:   console.log(\"  tmux ls                                                  # list sessions\");\n861:   console.log(\"  wombo status                                             # check status\");\n862:   console.log(\"  wombo verify                                             # verify builds\");\n863:   console.log(\"  wombo merge                                              # merge verified\");\n864:   console.log(\"  wombo cleanup                                            # remove worktrees\");\n865: \n866:   printDashboard(state);\n867: }\n868: \n869: // ---------------------------------------------------------------------------\n870: // Main Command\n871: // ---------------------------------------------------------------------------\n872: \n873: export async function cmdLaunch(opts: LaunchCommandOptions): Promise<void> {\n874:   const { projectRoot, config } = opts;\n875: \n876:   console.log(\"\\n--- Wombo: Launch ---\\n\");\n877: \n878:   // Ensure agent definition exists — reinstall from template if missing\n879:   ensureAgentDefinition(projectRoot, config);\n880: \n881:   // -------------------------------------------------------------------------\n882:   // Check for existing wave state — don't overwrite work in progress\n883:   // -------------------------------------------------------------------------\n884:   const existingState = loadState(projectRoot);\n885:   if (existingState) {\n886:     const merged = existingState.agents.filter((a) => a.status === \"merged\");\n887:     const verified = existingState.agents.filter((a) => a.status === \"verified\");\n888:     const completed = existingState.agents.filter((a) => a.status === \"completed\");\n889:     const running = existingState.agents.filter((a) => a.status === \"running\");\n890:     const queued = existingState.agents.filter((a) => a.status === \"queued\");\n891:     const failed = existingState.agents.filter((a) => a.status === \"failed\");\n892: \n893:     const hasWork = merged.length > 0 || verified.length > 0 || completed.length > 0 || running.length > 0;\n894: \n895:     if (hasWork) {\n896:       console.log(`Existing wave found: ${existingState.wave_id}`);\n897:       console.log(`  ${merged.length} merged, ${verified.length} verified, ${completed.length} completed, ${running.length} running, ${queued.length} queued, ${failed.length} failed`);\n898: \n899:       // Finalize any merged agents by marking their features as done\n900:       if (merged.length > 0) {\n901:         console.log(\"\\nFinalizing merged features in .features.yml...\");\n902:         for (const agent of merged) {\n903:           markFeatureDone(projectRoot, agent.feature_id, config, existingState.base_branch);\n904:           // Clean up worktree and branch (already merged, safe to delete)\n905:           try {\n906:             removeWorktree(projectRoot, agent.worktree, true);\n907:             console.log(`  ${agent.feature_id}: marked done, worktree removed`);\n908:           } catch {\n909:             console.log(`  ${agent.feature_id}: marked done (worktree already cleaned)`);\n910:           }\n911:         }\n912:       }\n913: \n914:       // Verified agents: build passed but NOT merged — do NOT mark done.\n915:       // Leave them for 'wombo resume' to attempt the merge.\n916:       if (verified.length > 0) {\n917:         for (const agent of verified) {\n918:           console.log(`  ${agent.feature_id}: verified (not yet merged) — use 'wombo resume' to merge`);\n919:         }\n920:       }\n921: \n922:       const activeCount = running.length + completed.length + queued.length;\n923:       if (activeCount > 0) {\n924:         console.error(`\\nWave ${existingState.wave_id} has ${activeCount} unfinished agent(s).`);\n925:         console.error(\"Use 'wombo resume' to continue the existing wave,\");\n926:         console.error(\"or 'wombo cleanup' to clear it before starting a new one.\");\n927:         process.exit(1);\n928:       }\n929: \n930:       // All agents are in terminal states (merged/verified/failed) — safe to start fresh\n931:       console.log(\"\\nAll agents in previous wave are finished. Starting fresh wave.\\n\");\n932:     }\n933:   }\n934: \n935:   // Load features\n936:   const data = loadFeatures(projectRoot, config);\n937: \n938:   // Build selection options\n939:   const selOpts: SelectionOptions = {};\n940:   if (opts.topPriority) selOpts.topPriority = opts.topPriority;\n941:   if (opts.quickestWins) selOpts.quickestWins = opts.quickestWins;\n942:   if (opts.priority) selOpts.priority = opts.priority;\n943:   if (opts.difficulty) selOpts.difficulty = opts.difficulty;\n944:   if (opts.features) selOpts.featureIds = opts.features;\n945:   if (opts.allReady) selOpts.allReady = true;\n946: \n947:   // Select features\n948:   const selected = selectFeatures(data, selOpts);\n949: \n950:   if (selected.length === 0) {\n951:     if (opts.allReady) {\n952:       console.error(\n953:         \"No launchable features found. All features may be done, cancelled, or have unmet dependencies.\"\n954:       );\n955:     } else {\n956:       console.error(\n957:         \"No features matched the selection criteria. Use --all-ready to see all available.\"\n958:       );\n959:     }\n960:     process.exit(1);\n961:   }\n962: \n963:   // Show selection\n964:   printFeatureSelection(\n965:     selected.map((f) => ({\n966:       id: f.id,\n967:       title: f.title,\n968:       priority: f.priority,\n969:       difficulty: f.difficulty,\n970:       effort: f.effort,\n971:     }))\n972:   );\n973: \n974:   if (opts.dryRun) {\n975:     console.log(\"Dry run — not launching agents.\");\n976:     return;\n977:   }\n978: \n979:   // Create wave state\n980:   const state = createWaveState({\n981:     baseBranch: opts.baseBranch,\n982:     maxConcurrent: opts.maxConcurrent,\n983:     model: opts.model ?? null,\n984:     interactive: opts.interactive,\n985:   });\n986: \n987:   // Create agent entries for all selected features\n988:   for (const feature of selected) {\n989:     const branch = featureBranchName(feature.id, config);\n990:     const wtPath = worktreePath(projectRoot, feature.id, config);\n991:     const agent = createAgentState(feature.id, branch, wtPath, opts.maxRetries);\n992:     // Set effort estimate from feature spec\n993:     const effortMinutes = parseDurationMinutes(feature.effort);\n994:     agent.effort_estimate_ms = effortMinutes === Infinity ? null : effortMinutes * 60 * 1000;\n995:     state.agents.push(agent);\n996:   }\n997: \n998:   saveState(projectRoot, state);\n999:   console.log(`Wave ${state.wave_id} created with ${selected.length} agents.`);\n1000: \n1001:   // Launch agents up to max_concurrent\n1002:   if (opts.interactive) {\n1003:     await launchWaveInteractive(projectRoot, state, selected, opts);\n1004:   } else {\n1005:     await launchWaveHeadless(projectRoot, state, selected, opts);\n1006:   }\n1007: }\n\n(End of file - total 1007 lines)\n</content>","title":"src/commands/launch.ts","metadata":{"preview":"/**\n * launch.ts — Launch a wave of agents.\n *\n * Usage: wombo launch [selection options] [launch options]\n *\n * This is the primary entry point for starting a new wave. It selects features\n * from the features file, creates a wave state, sets up worktrees, and launches\n * agent processes (either headless or interactive via tmux).\n *\n * IMPORTANT: This file also exports shared helper functions that are reused\n * by resume.ts and other commands:\n *   - launchSingleHeadless\n *   - handleBuildVerification\n *   - handleRetry\n *   - launchNextQueued\n */\n\nimport { execSync } from \"node:child_process\";\nimport type { WomboConfig } from \"../config.js\";\nimport type { Feature, SelectionOptions, Priority, Difficulty } from \"../lib/features.js\";","truncated":false,"loaded":[]},"time":{"start":1773351521905,"end":1773351521927}}}}
{"type":"tool_use","timestamp":1773351523077,"sessionID":"ses_31c036d95ffenGqgaxNYTZEsYh","part":{"id":"prt_ce3fccecf001bt9yC8WO9jo2mB","sessionID":"ses_31c036d95ffenGqgaxNYTZEsYh","messageID":"msg_ce3fcbf32001W6vTR2NUD395kI","type":"tool","callID":"toolu_vrtx_01Exb1dVCWUoCsy8PmT6mvWS","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-agent-template-lifecycle/src/lib/worktree.ts"},"output":"<path>/home/fulgidus/Documents/wombo-agent-template-lifecycle/src/lib/worktree.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * worktree.ts — Git worktree lifecycle management.\n3:  *\n4:  * Responsibilities:\n5:  *   - Create feature branches from a base branch\n6:  *   - Create git worktrees for each feature branch\n7:  *   - Run install command in worktrees\n8:  *   - List and remove worktrees\n9:  *   - Copy agent config files into worktrees\n10:  *\n11:  * IMPORTANT: Heavy operations (createWorktree, installDeps) are async\n12:  * to allow true parallelism with Promise.all.\n13:  */\n14: \n15: import { exec, execSync } from \"node:child_process\";\n16: import { existsSync, cpSync, statSync } from \"node:fs\";\n17: import { resolve, dirname, basename } from \"node:path\";\n18: import type { WomboConfig } from \"../config.js\";\n19: \n20: // ---------------------------------------------------------------------------\n21: // Types\n22: // ---------------------------------------------------------------------------\n23: \n24: export interface WorktreeInfo {\n25:   path: string;\n26:   branch: string;\n27:   head: string;\n28:   bare: boolean;\n29: }\n30: \n31: // ---------------------------------------------------------------------------\n32: // Diagnostic Logger\n33: // ---------------------------------------------------------------------------\n34: \n35: function ts(): string {\n36:   return new Date().toISOString().slice(11, 19); // HH:MM:SS\n37: }\n38: \n39: export function log(featureId: string, msg: string): void {\n40:   console.log(`  [${ts()}] ${featureId}: ${msg}`);\n41: }\n42: \n43: // ---------------------------------------------------------------------------\n44: // Async Command Runner\n45: // ---------------------------------------------------------------------------\n46: \n47: /**\n48:  * Run a command asynchronously. Returns stdout on success, throws on failure.\n49:  */\n50: function runAsync(\n51:   cmd: string,\n52:   opts?: { cwd?: string; timeoutMs?: number }\n53: ): Promise<string> {\n54:   return new Promise((resolve, reject) => {\n55:     exec(\n56:       cmd,\n57:       {\n58:         cwd: opts?.cwd,\n59:         encoding: \"utf-8\",\n60:         timeout: opts?.timeoutMs ?? 0,\n61:         maxBuffer: 10 * 1024 * 1024,\n62:       },\n63:       (error, stdout, stderr) => {\n64:         if (error) {\n65:           const errMsg = stderr?.trim() || stdout?.trim() || error.message;\n66:           reject(new Error(`Command failed: ${cmd}\\n${errMsg}`));\n67:         } else {\n68:           resolve((stdout ?? \"\").trim());\n69:         }\n70:       }\n71:     );\n72:   });\n73: }\n74: \n75: /**\n76:  * Synchronous run — only for quick, non-blocking operations.\n77:  */\n78: function runSync(\n79:   cmd: string,\n80:   opts?: { cwd?: string; silent?: boolean; timeoutMs?: number }\n81: ): string {\n82:   try {\n83:     return execSync(cmd, {\n84:       cwd: opts?.cwd,\n85:       encoding: \"utf-8\",\n86:       stdio: opts?.silent ? \"pipe\" : [\"pipe\", \"pipe\", \"pipe\"],\n87:       timeout: opts?.timeoutMs,\n88:       maxBuffer: 10 * 1024 * 1024,\n89:     }).trim();\n90:   } catch (err: any) {\n91:     const stderr = err.stderr?.toString().trim() || \"\";\n92:     const stdout = err.stdout?.toString().trim() || \"\";\n93:     throw new Error(\n94:       `Command failed: ${cmd}\\n${stderr || stdout || err.message}`\n95:     );\n96:   }\n97: }\n98: \n99: // ---------------------------------------------------------------------------\n100: // Branch Management\n101: // ---------------------------------------------------------------------------\n102: \n103: /**\n104:  * Create a feature branch from the base branch.\n105:  * If it already exists and is NOT checked out in a worktree, reset it.\n106:  * If it's checked out in a worktree, leave it alone (resume case).\n107:  */\n108: async function createBranch(\n109:   projectRoot: string,\n110:   branchName: string,\n111:   baseBranch: string\n112: ): Promise<void> {\n113:   const existing = await runAsync(\n114:     `git branch --list \"${branchName}\"`,\n115:     { cwd: projectRoot }\n116:   );\n117:   if (existing.trim()) {\n118:     // Branch exists — try to delete and recreate.\n119:     // If deletion fails (e.g. checked out in worktree), that's fine —\n120:     // we'll reuse the existing branch with its work intact.\n121:     try {\n122:       await runAsync(`git branch -D \"${branchName}\"`, { cwd: projectRoot });\n123:     } catch {\n124:       // Branch is checked out in a worktree — reuse as-is\n125:       return;\n126:     }\n127:   }\n128:   await runAsync(`git branch \"${branchName}\" \"${baseBranch}\"`, {\n129:     cwd: projectRoot,\n130:   });\n131: }\n132: \n133: /**\n134:  * Generate the branch name for a feature using config prefix.\n135:  */\n136: export function featureBranchName(\n137:   featureId: string,\n138:   config: WomboConfig\n139: ): string {\n140:   return `${config.git.branchPrefix}${featureId}`;\n141: }\n142: \n143: /**\n144:  * Generate the worktree path for a feature (sibling directory to project root).\n145:  */\n146: export function worktreePath(\n147:   projectRoot: string,\n148:   featureId: string,\n149:   config: WomboConfig\n150: ): string {\n151:   const parentDir = dirname(projectRoot);\n152:   return resolve(parentDir, `${config.git.worktreePrefix}${featureId}`);\n153: }\n154: \n155: // ---------------------------------------------------------------------------\n156: // Worktree Lifecycle (async)\n157: // ---------------------------------------------------------------------------\n158: \n159: /**\n160:  * Create a git worktree for a feature branch.\n161:  * Returns the absolute path to the worktree.\n162:  *\n163:  * If a valid worktree already exists at the expected path (has .git file),\n164:  * reuses it — this is essential for the resume case where worktrees have\n165:  * real work but may be missing node_modules.\n166:  */\n167: export async function createWorktree(\n168:   projectRoot: string,\n169:   featureId: string,\n170:   baseBranch: string,\n171:   config: WomboConfig\n172: ): Promise<string> {\n173:   const branch = featureBranchName(featureId, config);\n174:   const wtPath = worktreePath(projectRoot, featureId, config);\n175: \n176:   // If a valid worktree already exists, reuse it (resume case).\n177:   // A git worktree has a .git *file* (not directory) pointing to the main repo.\n178:   if (existsSync(wtPath) && existsSync(resolve(wtPath, \".git\"))) {\n179:     log(featureId, \"reusing existing worktree (has work)\");\n180:     // Still copy config files in case they're missing\n181:     copyConfigFiles(projectRoot, wtPath, featureId, config);\n182:     return wtPath;\n183:   }\n184: \n185:   // Create the branch if it doesn't exist\n186:   log(featureId, \"creating branch...\");\n187:   await createBranch(projectRoot, branch, baseBranch);\n188: \n189:   // Remove existing worktree directory if present but invalid\n190:   if (existsSync(wtPath)) {\n191:     log(featureId, \"removing old worktree...\");\n192:     try {\n193:       await runAsync(`git worktree remove --force \"${wtPath}\"`, {\n194:         cwd: projectRoot,\n195:       });\n196:     } catch {\n197:       await runAsync(`rm -rf \"${wtPath}\"`);\n198:       await runAsync(`git worktree prune`, { cwd: projectRoot });\n199:     }\n200:   }\n201: \n202:   // Create the worktree\n203:   log(featureId, \"creating worktree...\");\n204:   await runAsync(`git worktree add \"${wtPath}\" \"${branch}\"`, {\n205:     cwd: projectRoot,\n206:   });\n207: \n208:   // Copy agent config files into worktree\n209:   copyConfigFiles(projectRoot, wtPath, featureId, config);\n210: \n211:   log(featureId, \"worktree ready\");\n212:   return wtPath;\n213: }\n214: \n215: /**\n216:  * Copy agent config files from project root into a worktree.\n217:  * Best-effort — logs warnings but doesn't throw.\n218:  */\n219: function copyConfigFiles(\n220:   projectRoot: string,\n221:   wtPath: string,\n222:   featureId: string,\n223:   config: WomboConfig\n224: ): void {\n225:   for (const configFile of config.agent.configFiles) {\n226:     const srcPath = resolve(projectRoot, configFile);\n227:     if (!existsSync(srcPath)) continue;\n228: \n229:     const destPath = resolve(wtPath, configFile);\n230:     try {\n231:       const stat = statSync(srcPath);\n232:       if (stat.isDirectory()) {\n233:         cpSync(srcPath, destPath, { recursive: true });\n234:       } else {\n235:         cpSync(srcPath, destPath);\n236:       }\n237:     } catch {\n238:       // Non-critical — best effort\n239:     }\n240:   }\n241: \n242:   // Verify all config files were copied successfully\n243:   verifyConfigFiles(projectRoot, wtPath, featureId, config);\n244: }\n245: \n246: // ---------------------------------------------------------------------------\n247: // Config File Verification\n248: // ---------------------------------------------------------------------------\n249: \n250: /**\n251:  * Verify that all expected config files were copied into the worktree.\n252:  * Logs a warning for any that are missing. This is a safety net on top\n253:  * of the best-effort cpSync logic in createWorktree.\n254:  */\n255: function verifyConfigFiles(\n256:   projectRoot: string,\n257:   wtPath: string,\n258:   featureId: string,\n259:   config: WomboConfig\n260: ): void {\n261:   const missing: string[] = [];\n262: \n263:   for (const configFile of config.agent.configFiles) {\n264:     const srcPath = resolve(projectRoot, configFile);\n265:     const destPath = resolve(wtPath, configFile);\n266: \n267:     // Only check files/dirs that exist in the source project\n268:     if (!existsSync(srcPath)) continue;\n269: \n270:     if (!existsSync(destPath)) {\n271:       missing.push(configFile);\n272:     }\n273:   }\n274: \n275:   if (missing.length > 0) {\n276:     log(\n277:       featureId,\n278:       `\\x1b[33mWARNING\\x1b[0m: config files missing in worktree: ${missing.join(\", \")}`\n279:     );\n280:   }\n281: }\n282: \n283: /**\n284:  * Install dependencies in a worktree.\n285:  */\n286: export async function installDeps(\n287:   wtPath: string,\n288:   featureId: string,\n289:   config: WomboConfig\n290: ): Promise<void> {\n291:   log(featureId, `running ${config.install.command}...`);\n292:   const start = Date.now();\n293:   await runAsync(config.install.command, {\n294:     cwd: wtPath,\n295:     timeoutMs: config.install.timeout,\n296:   });\n297:   const elapsed = ((Date.now() - start) / 1000).toFixed(1);\n298:   log(featureId, `install done (${elapsed}s)`);\n299: }\n300: \n301: /**\n302:  * Check if a worktree already exists and has node_modules (fully ready).\n303:  */\n304: export function worktreeReady(wtPath: string): boolean {\n305:   return (\n306:     existsSync(wtPath) &&\n307:     existsSync(resolve(wtPath, \"node_modules\"))\n308:   );\n309: }\n310: \n311: /**\n312:  * Check if a valid git worktree exists at the path (may lack node_modules).\n313:  * A git worktree has a .git *file* (not directory) pointing to the main repo.\n314:  */\n315: export function worktreeExists(wtPath: string): boolean {\n316:   return existsSync(wtPath) && existsSync(resolve(wtPath, \".git\"));\n317: }\n318: \n319: // ---------------------------------------------------------------------------\n320: // Worktree Listing / Cleanup (sync)\n321: // ---------------------------------------------------------------------------\n322: \n323: /**\n324:  * List all git worktrees.\n325:  */\n326: export function listWorktrees(projectRoot: string): WorktreeInfo[] {\n327:   const output = runSync(\"git worktree list --porcelain\", {\n328:     cwd: projectRoot,\n329:     silent: true,\n330:   });\n331:   if (!output) return [];\n332: \n333:   const worktrees: WorktreeInfo[] = [];\n334:   let current: Partial<WorktreeInfo> = {};\n335: \n336:   for (const line of output.split(\"\\n\")) {\n337:     if (line.startsWith(\"worktree \")) {\n338:       if (current.path) worktrees.push(current as WorktreeInfo);\n339:       current = { path: line.slice(9), bare: false };\n340:     } else if (line.startsWith(\"HEAD \")) {\n341:       current.head = line.slice(5);\n342:     } else if (line.startsWith(\"branch \")) {\n343:       current.branch = line.slice(7).replace(\"refs/heads/\", \"\");\n344:     } else if (line === \"bare\") {\n345:       current.bare = true;\n346:     } else if (line === \"\" && current.path) {\n347:       worktrees.push(current as WorktreeInfo);\n348:       current = {};\n349:     }\n350:   }\n351:   if (current.path) worktrees.push(current as WorktreeInfo);\n352: \n353:   return worktrees;\n354: }\n355: \n356: /**\n357:  * List only wombo-related worktrees.\n358:  *\n359:  * SAFETY: Filters by checking that the *basename* of the worktree path\n360:  * starts with the worktreePrefix. A naive `.includes()` on the full path\n361:  * would match the main repo itself if its directory name contained the\n362:  * prefix (e.g. \"wombo-combo\" contains \"wombo-\"), causing cleanup to\n363:  * destroy the project root.\n364:  *\n365:  * Additionally, the main repo worktree (projectRoot) is always excluded\n366:  * as a defensive guard.\n367:  */\n368: export function listWomboWorktrees(\n369:   projectRoot: string,\n370:   config: WomboConfig\n371: ): WorktreeInfo[] {\n372:   const resolvedRoot = resolve(projectRoot);\n373:   return listWorktrees(projectRoot).filter((wt) => {\n374:     // Never include the main project root\n375:     if (resolve(wt.path) === resolvedRoot) return false;\n376:     // Match only worktrees whose directory name starts with the prefix\n377:     return basename(wt.path).startsWith(config.git.worktreePrefix);\n378:   });\n379: }\n380: \n381: /**\n382:  * Remove a worktree and optionally delete its branch.\n383:  *\n384:  * SAFETY: Refuses to remove the project root itself. This is a hard guard\n385:  * against bugs in worktree filtering that could otherwise destroy the main repo.\n386:  */\n387: export function removeWorktree(\n388:   projectRoot: string,\n389:   wtPath: string,\n390:   deleteBranchToo: boolean = true\n391: ): void {\n392:   // Hard safety check: never remove the main project root\n393:   if (resolve(wtPath) === resolve(projectRoot)) {\n394:     throw new Error(\n395:       `SAFETY: refusing to remove project root as worktree: ${wtPath}`\n396:     );\n397:   }\n398: \n399:   const worktrees = listWorktrees(projectRoot);\n400:   const wt = worktrees.find((w) => w.path === wtPath);\n401: \n402:   try {\n403:     runSync(`git worktree remove --force \"${wtPath}\"`, { cwd: projectRoot });\n404:   } catch {\n405:     if (existsSync(wtPath)) {\n406:       runSync(`rm -rf \"${wtPath}\"`);\n407:     }\n408:     runSync(\"git worktree prune\", { cwd: projectRoot });\n409:   }\n410: \n411:   if (deleteBranchToo && wt?.branch) {\n412:     try {\n413:       runSync(`git branch -D \"${wt.branch}\"`, {\n414:         cwd: projectRoot,\n415:         silent: true,\n416:       });\n417:     } catch {\n418:       // Branch may have been merged or already deleted\n419:     }\n420:   }\n421: }\n422: \n423: /**\n424:  * Check if a feature branch has any commits beyond the base branch.\n425:  * Returns true if the branch has diverged (i.e., the agent made commits).\n426:  */\n427: export function branchHasChanges(\n428:   projectRoot: string,\n429:   branch: string,\n430:   baseBranch: string\n431: ): boolean {\n432:   try {\n433:     const count = runSync(\n434:       `git rev-list --count \"${baseBranch}..${branch}\"`,\n435:       { cwd: projectRoot, silent: true }\n436:     );\n437:     return parseInt(count, 10) > 0;\n438:   } catch {\n439:     // If the branch doesn't exist or git fails, assume no changes\n440:     return false;\n441:   }\n442: }\n443: \n444: /**\n445:  * Remove all wombo-related worktrees and prune.\n446:  */\n447: export function cleanupAllWorktrees(\n448:   projectRoot: string,\n449:   config: WomboConfig\n450: ): number {\n451:   const womboWorktrees = listWomboWorktrees(projectRoot, config);\n452:   let removed = 0;\n453:   for (const wt of womboWorktrees) {\n454:     try {\n455:       removeWorktree(projectRoot, wt.path, false);\n456:       removed++;\n457:     } catch (err: any) {\n458:       console.error(`Failed to remove worktree ${wt.path}: ${err.message}`);\n459:     }\n460:   }\n461:   try {\n462:     runSync(\"git worktree prune\", { cwd: projectRoot });\n463:   } catch {\n464:     // Prune is best-effort — may fail if repo state is already clean\n465:   }\n466:   return removed;\n467: }\n\n(End of file - total 467 lines)\n</content>","title":"src/lib/worktree.ts","metadata":{"preview":"/**\n * worktree.ts — Git worktree lifecycle management.\n *\n * Responsibilities:\n *   - Create feature branches from a base branch\n *   - Create git worktrees for each feature branch\n *   - Run install command in worktrees\n *   - List and remove worktrees\n *   - Copy agent config files into worktrees\n *\n * IMPORTANT: Heavy operations (createWorktree, installDeps) are async\n * to allow true parallelism with Promise.all.\n */\n\nimport { exec, execSync } from \"node:child_process\";\nimport { existsSync, cpSync, statSync } from \"node:fs\";\nimport { resolve, dirname, basename } from \"node:path\";\nimport type { WomboConfig } from \"../config.js\";\n\n// ---------------------------------------------------------------------------","truncated":false,"loaded":[]},"time":{"start":1773351522919,"end":1773351523065}}}}
{"type":"tool_use","timestamp":1773351523088,"sessionID":"ses_31c036d95ffenGqgaxNYTZEsYh","part":{"id":"prt_ce3fcd27d0010KqKzoMPR2Sxj6","sessionID":"ses_31c036d95ffenGqgaxNYTZEsYh","messageID":"msg_ce3fcbf32001W6vTR2NUD395kI","type":"tool","callID":"toolu_vrtx_012UjvtkeDMj1VWfSUHuvPjV","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-agent-template-lifecycle/src/config.ts"},"output":"<path>/home/fulgidus/Documents/wombo-agent-template-lifecycle/src/config.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * config.ts — Load wombo.json, merge with defaults, validate, expose typed config.\n3:  *\n4:  * The config file lives at the target project root (the repo being orchestrated).\n5:  * All values have sensible defaults so minimal config works out of the box.\n6:  */\n7: \n8: import { readFileSync, existsSync } from \"node:fs\";\n9: import { resolve } from \"node:path\";\n10: \n11: // ---------------------------------------------------------------------------\n12: // Types\n13: // ---------------------------------------------------------------------------\n14: \n15: export interface WomboConfig {\n16:   /** Path to the features YAML file relative to project root */\n17:   featuresFile: string;\n18:   /** Base branch to create feature branches from */\n19:   baseBranch: string;\n20:   /** Build configuration */\n21:   build: {\n22:     /** Build command to run in worktrees */\n23:     command: string;\n24:     /** Build timeout in milliseconds */\n25:     timeout: number;\n26:     /** Build artifact directory (for quick \"did it build?\" checks) */\n27:     artifactDir: string;\n28:   };\n29:   /** Install configuration */\n30:   install: {\n31:     /** Install command to run in worktrees */\n32:     command: string;\n33:     /** Install timeout in milliseconds */\n34:     timeout: number;\n35:   };\n36:   /** Git configuration */\n37:   git: {\n38:     /** Branch name prefix for feature branches */\n39:     branchPrefix: string;\n40:     /** Worktree directory name prefix */\n41:     worktreePrefix: string;\n42:     /** Git remote name */\n43:     remote: string;\n44:     /** Merge strategy flag */\n45:     mergeStrategy: string;\n46:   };\n47:   /** Agent configuration */\n48:   agent: {\n49:     /** Path to agent binary (null = auto-detect) */\n50:     bin: string | null;\n51:     /** Agent name to pass via --agent flag */\n52:     name: string;\n53:     /** Config files/dirs to copy into worktrees */\n54:     configFiles: string[];\n55:     /** tmux session name prefix */\n56:     tmuxPrefix: string;\n57:   };\n58:   /** Default runtime values */\n59:   defaults: {\n60:     /** Max concurrent agents */\n61:     maxConcurrent: number;\n62:     /** Max retries per agent */\n63:     maxRetries: number;\n64:   };\n65: }\n66: \n67: // ---------------------------------------------------------------------------\n68: // Defaults\n69: // ---------------------------------------------------------------------------\n70: \n71: export const DEFAULT_CONFIG: WomboConfig = {\n72:   featuresFile: \".features.yml\",\n73:   baseBranch: \"develop\",\n74:   build: {\n75:     command: \"bun run build\",\n76:     timeout: 300_000,\n77:     artifactDir: \"dist\",\n78:   },\n79:   install: {\n80:     command: \"bun install\",\n81:     timeout: 120_000,\n82:   },\n83:   git: {\n84:     branchPrefix: \"feature/\",\n85:     worktreePrefix: \"wombo-\",\n86:     remote: \"origin\",\n87:     mergeStrategy: \"--no-ff\",\n88:   },\n89:   agent: {\n90:     bin: null,\n91:     name: \"wave-worker\",\n92:     configFiles: [\".opencode/\", \"opencode.json\", \"AGENTS.md\", \"agent/\"],\n93:     tmuxPrefix: \"wombo\",\n94:   },\n95:   defaults: {\n96:     maxConcurrent: 6,\n97:     maxRetries: 2,\n98:   },\n99: };\n100: \n101: // ---------------------------------------------------------------------------\n102: // Config File Name\n103: // ---------------------------------------------------------------------------\n104: \n105: export const CONFIG_FILE = \"wombo.json\";\n106: \n107: // ---------------------------------------------------------------------------\n108: // Loader\n109: // ---------------------------------------------------------------------------\n110: \n111: /**\n112:  * Deep-merge source into target. Only merges plain objects, not arrays.\n113:  */\n114: function deepMerge<T extends Record<string, any>>(target: T, source: Partial<T>): T {\n115:   const result = { ...target };\n116:   for (const key of Object.keys(source) as (keyof T)[]) {\n117:     const srcVal = source[key];\n118:     const tgtVal = target[key];\n119:     if (\n120:       srcVal !== undefined &&\n121:       srcVal !== null &&\n122:       typeof srcVal === \"object\" &&\n123:       !Array.isArray(srcVal) &&\n124:       typeof tgtVal === \"object\" &&\n125:       !Array.isArray(tgtVal) &&\n126:       tgtVal !== null\n127:     ) {\n128:       result[key] = deepMerge(tgtVal as any, srcVal as any);\n129:     } else if (srcVal !== undefined) {\n130:       result[key] = srcVal as T[keyof T];\n131:     }\n132:   }\n133:   return result;\n134: }\n135: \n136: /**\n137:  * Load wombo.json from the given project root and merge with defaults.\n138:  * Returns the full config. If no config file exists, returns defaults.\n139:  */\n140: export function loadConfig(projectRoot: string): WomboConfig {\n141:   const configPath = resolve(projectRoot, CONFIG_FILE);\n142: \n143:   if (!existsSync(configPath)) {\n144:     return { ...DEFAULT_CONFIG };\n145:   }\n146: \n147:   try {\n148:     const raw = readFileSync(configPath, \"utf-8\");\n149:     const partial = JSON.parse(raw) as Partial<WomboConfig>;\n150:     return deepMerge(DEFAULT_CONFIG, partial);\n151:   } catch (err: any) {\n152:     throw new Error(`Failed to load ${CONFIG_FILE}: ${err.message}`);\n153:   }\n154: }\n155: \n156: /**\n157:  * Resolve the agent binary path. Priority:\n158:  *   1. config.agent.bin (explicit)\n159:  *   2. OPENCODE_BIN env var\n160:  *   3. ~/.opencode/bin/opencode (default install location)\n161:  */\n162: export function resolveAgentBin(config: WomboConfig): string {\n163:   if (config.agent.bin) return config.agent.bin;\n164:   if (process.env.OPENCODE_BIN) return process.env.OPENCODE_BIN;\n165:   return resolve(process.env.HOME || \"~\", \".opencode/bin/opencode\");\n166: }\n167: \n168: /**\n169:  * Validate the config for obvious issues. Throws on error.\n170:  */\n171: export function validateConfig(config: WomboConfig): void {\n172:   if (!config.featuresFile) {\n173:     throw new Error(\"config.featuresFile must be a non-empty string\");\n174:   }\n175:   if (!config.baseBranch) {\n176:     throw new Error(\"config.baseBranch must be a non-empty string\");\n177:   }\n178:   if (!config.build.command) {\n179:     throw new Error(\"config.build.command must be a non-empty string\");\n180:   }\n181:   if (!config.install.command) {\n182:     throw new Error(\"config.install.command must be a non-empty string\");\n183:   }\n184:   if (!config.git.branchPrefix) {\n185:     throw new Error(\"config.git.branchPrefix must be a non-empty string\");\n186:   }\n187:   if (!config.git.worktreePrefix) {\n188:     throw new Error(\"config.git.worktreePrefix must be a non-empty string\");\n189:   }\n190:   if (config.defaults.maxConcurrent < 1) {\n191:     throw new Error(\"config.defaults.maxConcurrent must be >= 1\");\n192:   }\n193:   if (config.defaults.maxRetries < 0) {\n194:     throw new Error(\"config.defaults.maxRetries must be >= 0\");\n195:   }\n196: }\n197: \n198: /**\n199:  * Generate the default wombo.json content string (for `wombo init`).\n200:  */\n201: export function generateDefaultConfig(): string {\n202:   return JSON.stringify(DEFAULT_CONFIG, null, 2) + \"\\n\";\n203: }\n\n(End of file - total 203 lines)\n</content>","title":"src/config.ts","metadata":{"preview":"/**\n * config.ts — Load wombo.json, merge with defaults, validate, expose typed config.\n *\n * The config file lives at the target project root (the repo being orchestrated).\n * All values have sensible defaults so minimal config works out of the box.\n */\n\nimport { readFileSync, existsSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface WomboConfig {\n  /** Path to the features YAML file relative to project root */\n  featuresFile: string;\n  /** Base branch to create feature branches from */\n  baseBranch: string;\n  /** Build configuration */","truncated":false,"loaded":[]},"time":{"start":1773351522985,"end":1773351523087}}}}
{"type":"tool_use","timestamp":1773351523323,"sessionID":"ses_31c036d95ffenGqgaxNYTZEsYh","part":{"id":"prt_ce3fcd2d0001PzKN3LgNGtSb5a","sessionID":"ses_31c036d95ffenGqgaxNYTZEsYh","messageID":"msg_ce3fcbf32001W6vTR2NUD395kI","type":"tool","callID":"toolu_vrtx_01ExoixTLY3J79cdTjZjoV9T","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-agent-template-lifecycle/src/lib/templates.ts"},"output":"<path>/home/fulgidus/Documents/wombo-agent-template-lifecycle/src/lib/templates.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * templates.ts — Resolve paths to bundled template files and install helpers.\n3:  *\n4:  * All template paths are resolved relative to the source file location\n5:  * using import.meta.dir (Bun-specific). This ensures templates are found\n6:  * whether running from source (bun dev) or from an installed package.\n7:  */\n8: \n9: import { join, dirname, resolve } from \"node:path\";\n10: import { existsSync, readFileSync, writeFileSync, mkdirSync } from \"node:fs\";\n11: import type { WomboConfig } from \"../config.js\";\n12: \n13: // ---------------------------------------------------------------------------\n14: // Template Paths\n15: // ---------------------------------------------------------------------------\n16: \n17: /**\n18:  * Absolute path to the bundled wave-worker agent definition template.\n19:  * Used by `wombo init` to install the agent definition into the project,\n20:  * and by `wombo launch` to reinstall it if missing.\n21:  */\n22: export const AGENT_TEMPLATE_PATH = join(dirname(import.meta.dir), \"templates\", \"wave-worker.md\");\n23: \n24: // ---------------------------------------------------------------------------\n25: // Agent Definition Guard\n26: // ---------------------------------------------------------------------------\n27: \n28: /**\n29:  * Ensure the agent definition file exists at the expected path.\n30:  * If missing, reinstall from the bundled template and warn the user.\n31:  *\n32:  * Called at the start of `wombo launch` to prevent the failure mode where\n33:  * agents spawn without their agent definition file.\n34:  *\n35:  * @returns true if the file was reinstalled, false if it already existed.\n36:  */\n37: export function ensureAgentDefinition(\n38:   projectRoot: string,\n39:   config: WomboConfig\n40: ): boolean {\n41:   const agentDir = resolve(projectRoot, \"agent\");\n42:   const agentDefPath = resolve(agentDir, `${config.agent.name}.md`);\n43: \n44:   if (existsSync(agentDefPath)) {\n45:     return false;\n46:   }\n47: \n48:   // Agent definition missing — reinstall from bundled template\n49:   console.warn(\n50:     `\\x1b[33m[WARNING]\\x1b[0m Agent definition not found: agent/${config.agent.name}.md`\n51:   );\n52:   console.warn(`  Reinstalling from bundled template...`);\n53: \n54:   try {\n55:     mkdirSync(agentDir, { recursive: true });\n56:     const template = readFileSync(AGENT_TEMPLATE_PATH, \"utf-8\");\n57:     writeFileSync(agentDefPath, template, \"utf-8\");\n58:     console.warn(`  Restored agent/${config.agent.name}.md\\n`);\n59:     return true;\n60:   } catch (err: any) {\n61:     console.error(\n62:       `  Failed to restore agent definition: ${err.message}`\n63:     );\n64:     console.error(\n65:       `  Agents may launch without their definition file.\\n`\n66:     );\n67:     return false;\n68:   }\n69: }\n\n(End of file - total 69 lines)\n</content>","title":"src/lib/templates.ts","metadata":{"preview":"/**\n * templates.ts — Resolve paths to bundled template files and install helpers.\n *\n * All template paths are resolved relative to the source file location\n * using import.meta.dir (Bun-specific). This ensures templates are found\n * whether running from source (bun dev) or from an installed package.\n */\n\nimport { join, dirname, resolve } from \"node:path\";\nimport { existsSync, readFileSync, writeFileSync, mkdirSync } from \"node:fs\";\nimport type { WomboConfig } from \"../config.js\";\n\n// ---------------------------------------------------------------------------\n// Template Paths\n// ---------------------------------------------------------------------------\n\n/**\n * Absolute path to the bundled wave-worker agent definition template.\n * Used by `wombo init` to install the agent definition into the project,\n * and by `wombo launch` to reinstall it if missing.","truncated":false,"loaded":[]},"time":{"start":1773351523309,"end":1773351523320}}}}
