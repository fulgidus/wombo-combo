{"type":"tool_use","timestamp":1773351513484,"sessionID":"ses_31c036c38ffeeD8S5Pofc6twWk","part":{"id":"prt_ce3fcabdb00108S3MrFQa5t25f","sessionID":"ses_31c036c38ffeeD8S5Pofc6twWk","messageID":"msg_ce3fc9442001yNaqsoban0GpaM","type":"tool","callID":"toolu_vrtx_012rcpf5YQfPRtyuE7JhhBsf","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-features-file-backup/src/config.ts"},"output":"<path>/home/fulgidus/Documents/wombo-features-file-backup/src/config.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * config.ts — Load wombo.json, merge with defaults, validate, expose typed config.\n3:  *\n4:  * The config file lives at the target project root (the repo being orchestrated).\n5:  * All values have sensible defaults so minimal config works out of the box.\n6:  */\n7: \n8: import { readFileSync, existsSync } from \"node:fs\";\n9: import { resolve } from \"node:path\";\n10: \n11: // ---------------------------------------------------------------------------\n12: // Types\n13: // ---------------------------------------------------------------------------\n14: \n15: export interface WomboConfig {\n16:   /** Path to the features YAML file relative to project root */\n17:   featuresFile: string;\n18:   /** Base branch to create feature branches from */\n19:   baseBranch: string;\n20:   /** Build configuration */\n21:   build: {\n22:     /** Build command to run in worktrees */\n23:     command: string;\n24:     /** Build timeout in milliseconds */\n25:     timeout: number;\n26:     /** Build artifact directory (for quick \"did it build?\" checks) */\n27:     artifactDir: string;\n28:   };\n29:   /** Install configuration */\n30:   install: {\n31:     /** Install command to run in worktrees */\n32:     command: string;\n33:     /** Install timeout in milliseconds */\n34:     timeout: number;\n35:   };\n36:   /** Git configuration */\n37:   git: {\n38:     /** Branch name prefix for feature branches */\n39:     branchPrefix: string;\n40:     /** Worktree directory name prefix */\n41:     worktreePrefix: string;\n42:     /** Git remote name */\n43:     remote: string;\n44:     /** Merge strategy flag */\n45:     mergeStrategy: string;\n46:   };\n47:   /** Agent configuration */\n48:   agent: {\n49:     /** Path to agent binary (null = auto-detect) */\n50:     bin: string | null;\n51:     /** Agent name to pass via --agent flag */\n52:     name: string;\n53:     /** Config files/dirs to copy into worktrees */\n54:     configFiles: string[];\n55:     /** tmux session name prefix */\n56:     tmuxPrefix: string;\n57:   };\n58:   /** Default runtime values */\n59:   defaults: {\n60:     /** Max concurrent agents */\n61:     maxConcurrent: number;\n62:     /** Max retries per agent */\n63:     maxRetries: number;\n64:   };\n65: }\n66: \n67: // ---------------------------------------------------------------------------\n68: // Defaults\n69: // ---------------------------------------------------------------------------\n70: \n71: export const DEFAULT_CONFIG: WomboConfig = {\n72:   featuresFile: \".features.yml\",\n73:   baseBranch: \"develop\",\n74:   build: {\n75:     command: \"bun run build\",\n76:     timeout: 300_000,\n77:     artifactDir: \"dist\",\n78:   },\n79:   install: {\n80:     command: \"bun install\",\n81:     timeout: 120_000,\n82:   },\n83:   git: {\n84:     branchPrefix: \"feature/\",\n85:     worktreePrefix: \"wombo-\",\n86:     remote: \"origin\",\n87:     mergeStrategy: \"--no-ff\",\n88:   },\n89:   agent: {\n90:     bin: null,\n91:     name: \"wave-worker\",\n92:     configFiles: [\".opencode/\", \"opencode.json\", \"AGENTS.md\", \"agent/\"],\n93:     tmuxPrefix: \"wombo\",\n94:   },\n95:   defaults: {\n96:     maxConcurrent: 6,\n97:     maxRetries: 2,\n98:   },\n99: };\n100: \n101: // ---------------------------------------------------------------------------\n102: // Config File Name\n103: // ---------------------------------------------------------------------------\n104: \n105: export const CONFIG_FILE = \"wombo.json\";\n106: \n107: // ---------------------------------------------------------------------------\n108: // Loader\n109: // ---------------------------------------------------------------------------\n110: \n111: /**\n112:  * Deep-merge source into target. Only merges plain objects, not arrays.\n113:  */\n114: function deepMerge<T extends Record<string, any>>(target: T, source: Partial<T>): T {\n115:   const result = { ...target };\n116:   for (const key of Object.keys(source) as (keyof T)[]) {\n117:     const srcVal = source[key];\n118:     const tgtVal = target[key];\n119:     if (\n120:       srcVal !== undefined &&\n121:       srcVal !== null &&\n122:       typeof srcVal === \"object\" &&\n123:       !Array.isArray(srcVal) &&\n124:       typeof tgtVal === \"object\" &&\n125:       !Array.isArray(tgtVal) &&\n126:       tgtVal !== null\n127:     ) {\n128:       result[key] = deepMerge(tgtVal as any, srcVal as any);\n129:     } else if (srcVal !== undefined) {\n130:       result[key] = srcVal as T[keyof T];\n131:     }\n132:   }\n133:   return result;\n134: }\n135: \n136: /**\n137:  * Load wombo.json from the given project root and merge with defaults.\n138:  * Returns the full config. If no config file exists, returns defaults.\n139:  */\n140: export function loadConfig(projectRoot: string): WomboConfig {\n141:   const configPath = resolve(projectRoot, CONFIG_FILE);\n142: \n143:   if (!existsSync(configPath)) {\n144:     return { ...DEFAULT_CONFIG };\n145:   }\n146: \n147:   try {\n148:     const raw = readFileSync(configPath, \"utf-8\");\n149:     const partial = JSON.parse(raw) as Partial<WomboConfig>;\n150:     return deepMerge(DEFAULT_CONFIG, partial);\n151:   } catch (err: any) {\n152:     throw new Error(`Failed to load ${CONFIG_FILE}: ${err.message}`);\n153:   }\n154: }\n155: \n156: /**\n157:  * Resolve the agent binary path. Priority:\n158:  *   1. config.agent.bin (explicit)\n159:  *   2. OPENCODE_BIN env var\n160:  *   3. ~/.opencode/bin/opencode (default install location)\n161:  */\n162: export function resolveAgentBin(config: WomboConfig): string {\n163:   if (config.agent.bin) return config.agent.bin;\n164:   if (process.env.OPENCODE_BIN) return process.env.OPENCODE_BIN;\n165:   return resolve(process.env.HOME || \"~\", \".opencode/bin/opencode\");\n166: }\n167: \n168: /**\n169:  * Validate the config for obvious issues. Throws on error.\n170:  */\n171: export function validateConfig(config: WomboConfig): void {\n172:   if (!config.featuresFile) {\n173:     throw new Error(\"config.featuresFile must be a non-empty string\");\n174:   }\n175:   if (!config.baseBranch) {\n176:     throw new Error(\"config.baseBranch must be a non-empty string\");\n177:   }\n178:   if (!config.build.command) {\n179:     throw new Error(\"config.build.command must be a non-empty string\");\n180:   }\n181:   if (!config.install.command) {\n182:     throw new Error(\"config.install.command must be a non-empty string\");\n183:   }\n184:   if (!config.git.branchPrefix) {\n185:     throw new Error(\"config.git.branchPrefix must be a non-empty string\");\n186:   }\n187:   if (!config.git.worktreePrefix) {\n188:     throw new Error(\"config.git.worktreePrefix must be a non-empty string\");\n189:   }\n190:   if (config.defaults.maxConcurrent < 1) {\n191:     throw new Error(\"config.defaults.maxConcurrent must be >= 1\");\n192:   }\n193:   if (config.defaults.maxRetries < 0) {\n194:     throw new Error(\"config.defaults.maxRetries must be >= 0\");\n195:   }\n196: }\n197: \n198: /**\n199:  * Generate the default wombo.json content string (for `wombo init`).\n200:  */\n201: export function generateDefaultConfig(): string {\n202:   return JSON.stringify(DEFAULT_CONFIG, null, 2) + \"\\n\";\n203: }\n\n(End of file - total 203 lines)\n</content>","title":"src/config.ts","metadata":{"preview":"/**\n * config.ts — Load wombo.json, merge with defaults, validate, expose typed config.\n *\n * The config file lives at the target project root (the repo being orchestrated).\n * All values have sensible defaults so minimal config works out of the box.\n */\n\nimport { readFileSync, existsSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface WomboConfig {\n  /** Path to the features YAML file relative to project root */\n  featuresFile: string;\n  /** Base branch to create feature branches from */\n  baseBranch: string;\n  /** Build configuration */","truncated":false,"loaded":[]},"time":{"start":1773351513473,"end":1773351513479}}}}
