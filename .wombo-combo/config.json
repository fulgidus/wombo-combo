{
  "$schema": "../schemas/config.schema.json",
  "tasksDir": "tasks",
  "archiveDir": "archive",
  "baseBranch": "main",
  "build": {
    "command": "bun run build",
    "timeout": 300000,
    "artifactDir": "dist"
  },
  "install": {
    "command": "bun install",
    "timeout": 120000
  },
  "git": {
    "branchPrefix": "feature/",
    "worktreePrefix": "woco-",
    "remote": "origin",
    "mergeStrategy": "--no-ff"
  },
  "agent": {
    "bin": null,
    "name": "generalist-agent",
    "configFiles": [
      ".opencode/",
      "opencode.json",
      "AGENTS.md"
    ],
    "tmuxPrefix": "woco",
    "multiplexer": "auto"
  },
  "portless": {
    "enabled": true,
    "bin": null,
    "proxyPort": 1355,
    "https": false
  },
  "backup": {
    "maxBackups": 5
  },
  "defaults": {
    "maxConcurrent": 10,
    "maxRetries": 5
  },
  "browser": {
    "enabled": false,
    "bin": null,
    "headless": true,
    "testCommand": null,
    "launchTimeout": 30000,
    "testTimeout": 60000,
    "defaultViewport": {
      "width": 1280,
      "height": 720
    }
  },
  "agentRegistry": {
    "mode": "auto",
    "source": "msitarzewski/agency-agents",
    "cacheDir": "agents-cache"
  }
}
