{"type":"tool_use","timestamp":1773481726996,"sessionID":"ses_314408df1ffewl9iPH4Mn42Qn5","part":{"id":"prt_cebbf9326001qpgCqrOFOFO9no","sessionID":"ses_314408df1ffewl9iPH4Mn42Qn5","messageID":"msg_cebbf86380010utAAKAqCHbQQh","type":"tool","callID":"toolu_vrtx_01QDm8wWAB7xdEt95bbjfcJd","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/token-parse/src/lib/monitor.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/token-parse/src/lib/monitor.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * monitor.ts — Parse JSON events from agent and detect completion/failure.\n3:  *\n4:  * Responsibilities:\n5:  *   - Parse newline-delimited JSON events from agent stdout\n6:  *   - Detect session completion (agent finished)\n7:  *   - Detect session ID from events\n8:  *   - Detect errors and failures\n9:  *   - Write per-agent raw log files for diagnostics\n10:  *   - Maintain per-agent parsed activity log for TUI preview\n11:  */\n12: \n13: import type { ChildProcess } from \"node:child_process\";\n14: import { isProcessRunning } from \"./launcher.js\";\n15: import { mkdirSync, appendFileSync, existsSync } from \"node:fs\";\n16: import { resolve } from \"node:path\";\n17: \n18: // ---------------------------------------------------------------------------\n19: // Log directory name (configurable would be overkill here)\n20: // ---------------------------------------------------------------------------\n21: \n22: const LOG_DIR_NAME = \".wombo-combo/logs\";\n23: \n24: // ---------------------------------------------------------------------------\n25: // Types — OpenCode JSON Events\n26: // ---------------------------------------------------------------------------\n27: \n28: export interface OpenCodeEvent {\n29:   type: string;\n30:   sessionID?: string;\n31:   timestamp?: number;\n32:   part?: {\n33:     type?: string;\n34:     tool?: string;\n35:     callID?: string;\n36:     text?: string;\n37:     reason?: string;\n38:     cost?: number;\n39:     tokens?: {\n40:       total: number;\n41:       input: number;\n42:       output: number;\n43:       reasoning: number;\n44:     };\n45:     state?: {\n46:       status?: string;\n47:       input?: Record<string, any>;\n48:       output?: string;\n49:       error?: string;\n50:     };\n51:   };\n52:   [key: string]: any;\n53: }\n54: \n55: // ---------------------------------------------------------------------------\n56: // Event Parser\n57: // ---------------------------------------------------------------------------\n58: \n59: export interface ParsedOutput {\n60:   sessionId: string | null;\n61:   completed: boolean;\n62:   errored: boolean;\n63:   lastError: string | null;\n64:   events: OpenCodeEvent[];\n65: }\n66: \n67: export function parseEvents(rawOutput: string): ParsedOutput {\n68:   const result: ParsedOutput = {\n69:     sessionId: null,\n70:     completed: false,\n71:     errored: false,\n72:     lastError: null,\n73:     events: [],\n74:   };\n75: \n76:   const lines = rawOutput.split(\"\\n\").filter((l) => l.trim());\n77: \n78:   for (const line of lines) {\n79:     try {\n80:       const event = JSON.parse(line) as OpenCodeEvent;\n81:       result.events.push(event);\n82: \n83:       if (event.sessionID && !result.sessionId) {\n84:         result.sessionId = event.sessionID;\n85:       }\n86: \n87:       if (\n88:         event.type === \"step_finish\" &&\n89:         event.part?.reason === \"stop\"\n90:       ) {\n91:         result.completed = true;\n92:       }\n93: \n94:       if (\n95:         event.type === \"tool_use\" &&\n96:         event.part?.state?.status === \"error\"\n97:       ) {\n98:         result.errored = true;\n99:         result.lastError = event.part.state.error ?? \"unknown tool error\";\n100:       }\n101:     } catch {\n102:       // Not valid JSON — skip\n103:     }\n104:   }\n105: \n106:   return result;\n107: }\n108: \n109: // ---------------------------------------------------------------------------\n110: // Activity Extraction\n111: // ---------------------------------------------------------------------------\n112: \n113: function shortPath(fullPath: string | undefined, maxLen: number = 30): string {\n114:   if (!fullPath) return \"\";\n115:   const parts = fullPath.replace(/^\\/+/, \"\").split(\"/\");\n116:   const short =\n117:     parts.length > 1\n118:       ? parts.slice(-2).join(\"/\")\n119:       : parts[parts.length - 1];\n120:   if (short.length <= maxLen) return short;\n121:   const fname = parts[parts.length - 1];\n122:   return fname.length <= maxLen ? fname : fname.slice(0, maxLen - 1) + \"\\u2026\";\n123: }\n124: \n125: function shortCmd(cmd: string | undefined, maxLen: number = 30): string {\n126:   if (!cmd) return \"\";\n127:   const first = cmd.split(\"\\n\")[0].trim();\n128:   if (first.length <= maxLen) return first;\n129:   return first.slice(0, maxLen - 1) + \"\\u2026\";\n130: }\n131: \n132: /**\n133:  * Map an event to a human-readable activity string.\n134:  */\n135: export function extractActivity(event: OpenCodeEvent): string | null {\n136:   switch (event.type) {\n137:     case \"step_start\":\n138:       return \"thinking\\u2026\";\n139: \n140:     case \"tool_use\": {\n141:       const toolName = (event.part?.tool ?? \"\").toLowerCase();\n142:       const input = event.part?.state?.input ?? {};\n143:       const status = event.part?.state?.status ?? \"\";\n144: \n145:       if (status === \"error\") {\n146:         return `${toolName}: error`;\n147:       }\n148: \n149:       switch (toolName) {\n150:         case \"read\":\n151:           return `reading ${shortPath(input.filePath ?? input.path)}`;\n152:         case \"write\":\n153:           return `writing ${shortPath(input.filePath ?? input.path)}`;\n154:         case \"edit\":\n155:           return `editing ${shortPath(input.filePath ?? input.path)}`;\n156:         case \"bash\":\n157:         case \"command\":\n158:         case \"terminal\": {\n159:           const cmd = input.command ?? input.cmd ?? \"\";\n160:           // Detect HITL ask script invocation\n161:           if (cmd.includes(\"hitl-ask\")) {\n162:             return \"waiting for human…\";\n163:           }\n164:           return `$ ${shortCmd(cmd)}`;\n165:         }\n166:         case \"glob\":\n167:           return `finding: ${shortPath(input.pattern)}`;\n168:         case \"grep\":\n169:         case \"search\":\n170:           return `searching: ${(input.pattern ?? \"\").slice(0, 25)}`;\n171:         case \"task\":\n172:           return \"delegating task\\u2026\";\n173:         case \"webfetch\":\n174:         case \"web_fetch\":\n175:           return \"fetching URL\\u2026\";\n176:         case \"todowrite\":\n177:         case \"todo_write\":\n178:           return \"planning\\u2026\";\n179:         case \"question\":\n180:           return \"asking question\\u2026\";\n181:         case \"jcodemunch_index_folder\":\n182:         case \"jcodemunch_index_repo\":\n183:           return \"indexing code\\u2026\";\n184:         case \"jcodemunch_search_symbols\":\n185:         case \"jcodemunch_search_text\":\n186:           return \"searching symbols\\u2026\";\n187:         case \"jcodemunch_get_file_outline\":\n188:           return `outlining ${shortPath(input.file_path)}`;\n189:         case \"jcodemunch_get_symbol\":\n190:         case \"jcodemunch_get_symbols\":\n191:           return \"reading symbol\\u2026\";\n192:         default:\n193:           return `tool: ${toolName}`;\n194:       }\n195:     }\n196: \n197:     case \"text\":\n198:       return \"responding\\u2026\";\n199: \n200:     case \"step_finish\":\n201:       if (event.part?.reason === \"stop\") return \"done\";\n202:       if (event.part?.reason === \"tool-calls\") return null;\n203:       return null;\n204: \n205:     default:\n206:       return null;\n207:   }\n208: }\n209: \n210: /**\n211:  * Format an event into a human-readable log line for the activity stream.\n212:  */\n213: export function formatEventForLog(event: OpenCodeEvent): string | null {\n214:   switch (event.type) {\n215:     case \"step_start\":\n216:       return \"-- step started\";\n217: \n218:     case \"tool_use\": {\n219:       const toolName = event.part?.tool ?? \"unknown\";\n220:       const input = event.part?.state?.input ?? {};\n221:       const status = event.part?.state?.status ?? \"\";\n222:       const output = event.part?.state?.output ?? \"\";\n223:       const error = event.part?.state?.error ?? \"\";\n224: \n225:       let line = `>> ${toolName}`;\n226:       switch (toolName.toLowerCase()) {\n227:         case \"read\":\n228:           line = `>> read ${shortPath(input.filePath ?? input.path, 50)}`;\n229:           break;\n230:         case \"write\":\n231:           line = `>> write ${shortPath(input.filePath ?? input.path, 50)}`;\n232:           break;\n233:         case \"edit\":\n234:           line = `>> edit ${shortPath(input.filePath ?? input.path, 50)}`;\n235:           break;\n236:         case \"bash\":\n237:         case \"command\":\n238:           line = `>> $ ${shortCmd(input.command ?? input.cmd, 60)}`;\n239:           break;\n240:         case \"glob\":\n241:           line = `>> glob ${input.pattern ?? \"\"}`;\n242:           break;\n243:         case \"grep\":\n244:           line = `>> grep \"${(input.pattern ?? \"\").slice(0, 30)}\"`;\n245:           break;\n246:         case \"task\":\n247:           line = `>> task: ${(input.description ?? input.prompt ?? \"\").slice(0, 50)}`;\n248:           break;\n249:       }\n250: \n251:       if (status === \"completed\" && output) {\n252:         const preview = output.split(\"\\n\")[0].slice(0, 80);\n253:         return `${line}\\n   ${preview}${output.length > 80 ? \"\\u2026\" : \"\"}`;\n254:       }\n255:       if (status === \"error\" && error) {\n256:         return `${line}\\n!! ${error.slice(0, 100)}`;\n257:       }\n258:       return line;\n259:     }\n260: \n261:     case \"text\": {\n262:       const text = event.part?.text ?? \"\";\n263:       if (!text.trim()) return null;\n264:       const firstLine = text.split(\"\\n\").find((l: string) => l.trim())?.trim() ?? \"\";\n265:       if (firstLine.length === 0) return null;\n266:       return `   ${firstLine.slice(0, 120)}${firstLine.length > 120 ? \"\\u2026\" : \"\"}`;\n267:     }\n268: \n269:     case \"step_finish\": {\n270:       const reason = event.part?.reason ?? \"\";\n271:       const tokens = event.part?.tokens;\n272:       if (reason === \"stop\") {\n273:         const tokStr = tokens\n274:           ? ` (${tokens.input}in/${tokens.output}out)`\n275:           : \"\";\n276:         return `-- done${tokStr}`;\n277:       }\n278:       return null;\n279:     }\n280: \n281:     default:\n282:       return null;\n283:   }\n284: }\n285: \n286: // ---------------------------------------------------------------------------\n287: // Per-agent Activity Log (in-memory ring buffer for TUI)\n288: // ---------------------------------------------------------------------------\n289: \n290: export interface ActivityEntry {\n291:   timestamp: string;\n292:   text: string;\n293: }\n294: \n295: const MAX_ACTIVITY_LINES = 500;\n296: \n297: // ---------------------------------------------------------------------------\n298: // Process Monitor\n299: // ---------------------------------------------------------------------------\n300: \n301: export interface MonitorCallbacks {\n302:   onSessionId?: (featureId: string, sessionId: string) => void;\n303:   onComplete?: (featureId: string) => void;\n304:   onError?: (featureId: string, error: string) => void;\n305:   onOutput?: (featureId: string, data: string) => void;\n306:   onActivity?: (featureId: string, activity: string) => void;\n307:   /** Called when an agent asks a human question via HITL */\n308:   onQuestion?: (featureId: string, questionText: string) => void;\n309: }\n310: \n311: interface MonitoredProcess {\n312:   featureId: string;\n313:   process: ChildProcess;\n314:   stdout: string;\n315:   stderr: string;\n316:   sessionId: string | null;\n317:   done: boolean;\n318:   lineBuffer: string;\n319:   sawFinalStop: boolean;\n320: }\n321: \n322: /**\n323:  * Monitor a set of headless agent processes.\n324:  * Collects stdout, parses events, and calls callbacks on state changes.\n325:  */\n326: export class ProcessMonitor {\n327:   private processes: Map<string, MonitoredProcess> = new Map();\n328:   private callbacks: MonitorCallbacks;\n329:   private logDir: string;\n330:   /** Per-agent activity log for TUI preview pane */\n331:   public activityLogs: Map<string, ActivityEntry[]> = new Map();\n332: \n333:   constructor(projectRoot: string, callbacks: MonitorCallbacks = {}) {\n334:     this.callbacks = callbacks;\n335:     this.logDir = resolve(projectRoot, LOG_DIR_NAME);\n336:     if (!existsSync(this.logDir)) {\n337:       mkdirSync(this.logDir, { recursive: true });\n338:     }\n339:   }\n340: \n341:   private pushActivity(featureId: string, text: string): void {\n342:     if (!this.activityLogs.has(featureId)) {\n343:       this.activityLogs.set(featureId, []);\n344:     }\n345:     const log = this.activityLogs.get(featureId)!;\n346:     for (const line of text.split(\"\\n\")) {\n347:       log.push({ timestamp: new Date().toISOString().slice(11, 19), text: line });\n348:     }\n349:     if (log.length > MAX_ACTIVITY_LINES) {\n350:       log.splice(0, log.length - MAX_ACTIVITY_LINES);\n351:     }\n352:   }\n353: \n354:   private writeLog(featureId: string, data: string): void {\n355:     try {\n356:       const logFile = resolve(this.logDir, `${featureId}.log`);\n357:       appendFileSync(logFile, data);\n358:     } catch {\n359:       // Non-critical\n360:     }\n361:   }\n362: \n363:   getActivityLog(featureId: string): ActivityEntry[] {\n364:     return this.activityLogs.get(featureId) ?? [];\n365:   }\n366: \n367:   addProcess(featureId: string, child: ChildProcess): void {\n368:     const monitored: MonitoredProcess = {\n369:       featureId,\n370:       process: child,\n371:       stdout: \"\",\n372:       stderr: \"\",\n373:       sessionId: null,\n374:       done: false,\n375:       lineBuffer: \"\",\n376:       sawFinalStop: false,\n377:     };\n378: \n379:     this.pushActivity(featureId, \"-- agent process started\");\n380:     this.writeLog(featureId, `[wombo] Process started at ${new Date().toISOString()}\\n`);\n381: \n382:     child.stdout?.on(\"data\", (data: Buffer) => {\n383:       const chunk = data.toString();\n384:       monitored.stdout += chunk;\n385:       this.callbacks.onOutput?.(featureId, chunk);\n386:       this.writeLog(featureId, chunk);\n387: \n388:       monitored.lineBuffer += chunk;\n389:       const lines = monitored.lineBuffer.split(\"\\n\");\n390:       monitored.lineBuffer = lines.pop() ?? \"\";\n391: \n392:       for (const line of lines) {\n393:         const trimmed = line.trim();\n394:         if (!trimmed) continue;\n395:         try {\n396:           const event = JSON.parse(trimmed) as OpenCodeEvent;\n397: \n398:           if (!monitored.sessionId && event.sessionID) {\n399:             monitored.sessionId = event.sessionID;\n400:             this.callbacks.onSessionId?.(featureId, event.sessionID);\n401:             this.pushActivity(featureId, `-- session: ${event.sessionID}`);\n402:           }\n403: \n404:           const activity = extractActivity(event);\n405:           if (activity) {\n406:             this.callbacks.onActivity?.(featureId, activity);\n407:           }\n408: \n409:           const logLine = formatEventForLog(event);\n410:           if (logLine) {\n411:             this.pushActivity(featureId, logLine);\n412:           }\n413: \n414:           if (\n415:             event.type === \"step_finish\" &&\n416:             event.part?.reason === \"stop\"\n417:           ) {\n418:             monitored.sawFinalStop = true;\n419:           }\n420:         } catch {\n421:           if (trimmed.length > 0 && trimmed.length < 500) {\n422:             this.pushActivity(featureId, `[raw] ${trimmed.slice(0, 120)}`);\n423:           }\n424:         }\n425:       }\n426:     });\n427: \n428:     child.stderr?.on(\"data\", (data: Buffer) => {\n429:       const chunk = data.toString();\n430:       monitored.stderr += chunk;\n431:       this.writeLog(featureId, `[stderr] ${chunk}`);\n432:       const lines = chunk.split(\"\\n\").filter((l) => l.trim());\n433:       for (const line of lines) {\n434:         this.pushActivity(featureId, `[stderr] ${line.trim().slice(0, 120)}`);\n435:       }\n436:     });\n437: \n438:     child.on(\"exit\", (code) => {\n439:       monitored.done = true;\n440:       this.pushActivity(featureId, `-- process exited (code ${code})`);\n441:       this.writeLog(featureId, `\\n[wombo] Process exited with code ${code} at ${new Date().toISOString()}\\n`);\n442: \n443:       if (code === 0 || monitored.sawFinalStop) {\n444:         this.callbacks.onComplete?.(featureId);\n445:       } else {\n446:         const error =\n447:           monitored.stderr.slice(-2000) ||\n448:           `Process exited with code ${code}`;\n449:         this.callbacks.onError?.(featureId, error);\n450:       }\n451:     });\n452: \n453:     child.on(\"error\", (err) => {\n454:       monitored.done = true;\n455:       this.pushActivity(featureId, `!! process error: ${err.message}`);\n456:       this.writeLog(featureId, `\\n[wombo] Process error: ${err.message}\\n`);\n457:       this.callbacks.onError?.(featureId, err.message);\n458:     });\n459: \n460:     this.processes.set(featureId, monitored);\n461:   }\n462: \n463:   getSessionId(featureId: string): string | null {\n464:     return this.processes.get(featureId)?.sessionId ?? null;\n465:   }\n466: \n467:   getOutput(featureId: string): string {\n468:     return this.processes.get(featureId)?.stdout ?? \"\";\n469:   }\n470: \n471:   isRunning(featureId: string): boolean {\n472:     const m = this.processes.get(featureId);\n473:     if (!m) return false;\n474:     if (m.done) return false;\n475:     return isProcessRunning(m.process.pid!);\n476:   }\n477: \n478:   allDone(): boolean {\n479:     for (const m of this.processes.values()) {\n480:       if (!m.done) return false;\n481:     }\n482:     return true;\n483:   }\n484: \n485:   activeCount(): number {\n486:     let count = 0;\n487:     for (const m of this.processes.values()) {\n488:       if (!m.done) count++;\n489:     }\n490:     return count;\n491:   }\n492: \n493:   remove(featureId: string): void {\n494:     const m = this.processes.get(featureId);\n495:     if (m && !m.done) {\n496:       try {\n497:         m.process.kill(\"SIGTERM\");\n498:       } catch {}\n499:     }\n500:     this.processes.delete(featureId);\n501:   }\n502: \n503:   killAll(): void {\n504:     for (const id of this.processes.keys()) {\n505:       this.remove(id);\n506:     }\n507:   }\n508: \n509:   waitAll(pollIntervalMs: number = 1000): Promise<void> {\n510:     return new Promise((resolve) => {\n511:       const check = () => {\n512:         if (this.allDone()) {\n513:           resolve();\n514:         } else {\n515:           setTimeout(check, pollIntervalMs);\n516:         }\n517:       };\n518:       check();\n519:     });\n520:   }\n521: }\n\n(End of file - total 521 lines)\n</content>","title":"src/lib/monitor.ts","metadata":{"preview":"/**\n * monitor.ts — Parse JSON events from agent and detect completion/failure.\n *\n * Responsibilities:\n *   - Parse newline-delimited JSON events from agent stdout\n *   - Detect session completion (agent finished)\n *   - Detect session ID from events\n *   - Detect errors and failures\n *   - Write per-agent raw log files for diagnostics\n *   - Maintain per-agent parsed activity log for TUI preview\n */\n\nimport type { ChildProcess } from \"node:child_process\";\nimport { isProcessRunning } from \"./launcher.js\";\nimport { mkdirSync, appendFileSync, existsSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\n\n// ---------------------------------------------------------------------------\n// Log directory name (configurable would be overkill here)\n// ---------------------------------------------------------------------------","truncated":false,"loaded":[]},"time":{"start":1773481726993,"end":1773481726996}}}}
