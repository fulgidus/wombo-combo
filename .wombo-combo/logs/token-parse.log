{"type":"tool_use","timestamp":1773481727584,"sessionID":"ses_314408df1ffewl9iPH4Mn42Qn5","part":{"id":"prt_cebbf947b001SdaHAFhSrB2YP0","sessionID":"ses_314408df1ffewl9iPH4Mn42Qn5","messageID":"msg_cebbf86380010utAAKAqCHbQQh","type":"tool","callID":"toolu_vrtx_01Ube66EuzqmQtc2rjjyKUXv","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/token-parse/src/lib/launcher.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/token-parse/src/lib/launcher.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * launcher.ts — Process spawning and terminal multiplexer session management.\n3:  *\n4:  * Responsibilities:\n5:  *   - Launch agent in headless mode (agent run --format json)\n6:  *   - Launch agent in interactive mode (dmux/tmux session with TUI)\n7:  *   - Resume sessions for auto-retry\n8:  *   - Manage multiplexer sessions (create, list, kill)\n9:  *\n10:  * Supports both dmux (preferred) and tmux (fallback) via the multiplexer\n11:  * abstraction layer. The active backend is determined by config.agent.multiplexer.\n12:  */\n13: \n14: import { spawn, execSync, type ChildProcess } from \"node:child_process\";\n15: import { writeFileSync, unlinkSync } from \"node:fs\";\n16: import type { WomboConfig } from \"../config.js\";\n17: import { resolveAgentBin } from \"../config.js\";\n18: import {\n19:   detectMultiplexer,\n20:   muxNewSession,\n21:   muxHasSession,\n22:   muxKillSession,\n23:   muxListSessions,\n24:   muxGetPanePid,\n25:   muxLoadBuffer,\n26:   muxPasteBuffer,\n27:   muxSendKeys,\n28:   muxDisplayName,\n29:   type MultiplexerInfo,\n30: } from \"./multiplexer.js\";\n31: import { portlessEnv } from \"./portless.js\";\n32: import { hitlDir } from \"./hitl-channel.js\";\n33: import { resolve, dirname } from \"node:path\";\n34: \n35: // ---------------------------------------------------------------------------\n36: // Types\n37: // ---------------------------------------------------------------------------\n38: \n39: export interface LaunchResult {\n40:   pid: number;\n41:   process: ChildProcess;\n42:   sessionId?: string;\n43: }\n44: \n45: export interface LaunchOptions {\n46:   worktreePath: string;\n47:   featureId: string;\n48:   prompt: string;\n49:   model?: string;\n50:   interactive?: boolean;\n51:   config: WomboConfig;\n52:   /** Override the agent name (for specialized agents from the registry) */\n53:   agentName?: string;\n54:   /** HITL mode for this agent (from quest or config) */\n55:   hitlMode?: string;\n56:   /** Project root (for HITL directory path) */\n57:   projectRoot?: string;\n58: }\n59: \n60: export interface RetryOptions {\n61:   worktreePath: string;\n62:   featureId: string;\n63:   sessionId: string;\n64:   buildErrors: string;\n65:   model?: string;\n66:   interactive?: boolean;\n67:   config: WomboConfig;\n68:   /** HITL mode for this agent (from quest or config) */\n69:   hitlMode?: string;\n70:   /** Project root (for HITL directory path) */\n71:   projectRoot?: string;\n72: }\n73: \n74: // ---------------------------------------------------------------------------\n75: // Helpers\n76: // ---------------------------------------------------------------------------\n77: \n78: function muxSessionName(featureId: string, config: WomboConfig): string {\n79:   return `${config.agent.tmuxPrefix}-${featureId}`;\n80: }\n81: \n82: /**\n83:  * Get the multiplexer info for this config.\n84:  * Caches detection per-process.\n85:  */\n86: function getMux(config: WomboConfig): MultiplexerInfo {\n87:   return detectMultiplexer(config.agent.multiplexer);\n88: }\n89: \n90: function runSilent(cmd: string): string {\n91:   try {\n92:     return execSync(cmd, { encoding: \"utf-8\", stdio: \"pipe\" }).trim();\n93:   } catch {\n94:     return \"\";\n95:   }\n96: }\n97: \n98: /**\n99:  * Build environment variables for an agent process.\n100:  * Merges process.env with OPENCODE_DIR, portless env vars, and HITL env vars.\n101:  */\n102: function agentEnv(\n103:   worktreePath: string,\n104:   featureId: string,\n105:   config: WomboConfig,\n106:   hitlMode?: string,\n107:   projectRoot?: string\n108: ): Record<string, string | undefined> {\n109:   const env: Record<string, string | undefined> = {\n110:     ...process.env,\n111:     OPENCODE_DIR: worktreePath,\n112:     ...portlessEnv(featureId, config),\n113:   };\n114: \n115:   // HITL environment — always set so the hitl-ask script is available,\n116:   // but the prompt controls whether the agent actually uses it.\n117:   if (projectRoot) {\n118:     env.WOMBO_HITL_DIR = hitlDir(projectRoot);\n119:     env.WOMBO_AGENT_ID = featureId;\n120:     env.WOMBO_HITL_MODE = hitlMode ?? \"yolo\";\n121:     // Path to the hitl-ask script (relative to this module)\n122:     // In development: src/lib/hitl-ask.ts\n123:     // In production (bundled): same dir as this file\n124:     const hitlAskPath = resolve(import.meta.dir, \"hitl-ask.ts\");\n125:     env.WOMBO_HITL_ASK = hitlAskPath;\n126:   }\n127: \n128:   return env;\n129: }\n130: \n131: // ---------------------------------------------------------------------------\n132: // Headless Launch\n133: // ---------------------------------------------------------------------------\n134: \n135: /**\n136:  * Launch agent in headless mode with JSON output.\n137:  */\n138: export function launchHeadless(opts: LaunchOptions): LaunchResult {\n139:   const agentBin = resolveAgentBin(opts.config);\n140: \n141:   const args = [\n142:     \"run\",\n143:     \"--format\", \"json\",\n144:     \"--agent\", opts.agentName ?? opts.config.agent.name,\n145:     \"--dir\", opts.worktreePath,\n146:     \"--title\", `woco: ${opts.featureId}`,\n147:   ];\n148: \n149:   if (opts.model) {\n150:     args.push(\"--model\", opts.model);\n151:   }\n152: \n153:   args.push(opts.prompt);\n154: \n155:   const child = spawn(agentBin, args, {\n156:     stdio: [\"pipe\", \"pipe\", \"pipe\"],\n157:     detached: false,\n158:     env: agentEnv(opts.worktreePath, opts.featureId, opts.config, opts.hitlMode, opts.projectRoot),\n159:   });\n160: \n161:   // Close stdin so agent starts processing immediately\n162:   child.stdin?.end();\n163: \n164:   return {\n165:     pid: child.pid!,\n166:     process: child,\n167:   };\n168: }\n169: \n170: /**\n171:  * Resume a headless session with a retry message (build errors).\n172:  */\n173: export function retryHeadless(opts: RetryOptions): LaunchResult {\n174:   const agentBin = resolveAgentBin(opts.config);\n175: \n176:   const retryMessage = `The build failed. Please fix the following errors and run \\`${opts.config.build.command}\\` again:\\n\\n\\`\\`\\`\\n${opts.buildErrors}\\n\\`\\`\\`\\n\\nFix all errors, then verify the build passes.`;\n177: \n178:   const args = [\n179:     \"run\",\n180:     \"--format\", \"json\",\n181:     \"--session\", opts.sessionId,\n182:     \"--continue\",\n183:     \"--dir\", opts.worktreePath,\n184:   ];\n185: \n186:   if (opts.model) {\n187:     args.push(\"--model\", opts.model);\n188:   }\n189: \n190:   args.push(retryMessage);\n191: \n192:   const child = spawn(agentBin, args, {\n193:     stdio: [\"pipe\", \"pipe\", \"pipe\"],\n194:     detached: false,\n195:     env: agentEnv(opts.worktreePath, opts.featureId, opts.config, opts.hitlMode, opts.projectRoot),\n196:   });\n197: \n198:   child.stdin?.end();\n199: \n200:   return {\n201:     pid: child.pid!,\n202:     process: child,\n203:   };\n204: }\n205: \n206: // ---------------------------------------------------------------------------\n207: // Conflict Resolution Launch\n208: // ---------------------------------------------------------------------------\n209: \n210: export interface ConflictResolverOptions {\n211:   worktreePath: string;\n212:   featureId: string;\n213:   prompt: string;\n214:   model?: string;\n215:   config: WomboConfig;\n216:   /** Override the agent name for conflict resolution (default: merge-resolver-agent) */\n217:   agentName?: string;\n218: }\n219: \n220: /**\n221:  * Launch a headless agent to resolve merge conflicts.\n222:  *\n223:  * This is similar to `launchHeadless`, but the prompt is a conflict-resolution\n224:  * prompt generated by `generateConflictResolutionPrompt()`. The agent runs in\n225:  * the feature worktree where `git merge <baseBranch>` has already been run,\n226:  * leaving conflict markers in the working tree.\n227:  *\n228:  * By default uses the specialized \"merge-resolver-agent\" definition, which\n229:  * has minimal context and is focused solely on conflict resolution. Falls back\n230:  * to the generalist agent if no merge-resolver-agent is available.\n231:  */\n232: export function launchConflictResolver(opts: ConflictResolverOptions): LaunchResult {\n233:   const agentBin = resolveAgentBin(opts.config);\n234: \n235:   // Use the specialized merge-resolver agent by default\n236:   const agentName = opts.agentName ?? \"merge-resolver-agent\";\n237: \n238:   const args = [\n239:     \"run\",\n240:     \"--format\", \"json\",\n241:     \"--agent\", agentName,\n242:     \"--dir\", opts.worktreePath,\n243:     \"--title\", `woco: conflict-resolve ${opts.featureId}`,\n244:   ];\n245: \n246:   if (opts.model) {\n247:     args.push(\"--model\", opts.model);\n248:   }\n249: \n250:   args.push(opts.prompt);\n251: \n252:   const child = spawn(agentBin, args, {\n253:     stdio: [\"pipe\", \"pipe\", \"pipe\"],\n254:     detached: false,\n255:     env: agentEnv(opts.worktreePath, opts.featureId, opts.config),\n256:   });\n257: \n258:   child.stdin?.end();\n259: \n260:   return {\n261:     pid: child.pid!,\n262:     process: child,\n263:   };\n264: }\n265: \n266: // ---------------------------------------------------------------------------\n267: // Interactive (multiplexer) Launch\n268: // ---------------------------------------------------------------------------\n269: \n270: /**\n271:  * Launch agent in a terminal multiplexer session (dmux or tmux) for interactive use.\n272:  */\n273: export function launchInteractive(opts: LaunchOptions): LaunchResult {\n274:   const agentBin = resolveAgentBin(opts.config);\n275:   const mux = getMux(opts.config);\n276:   const sessionName = muxSessionName(opts.featureId, opts.config);\n277: \n278:   // Kill existing session if any\n279:   killMuxSession(opts.featureId, opts.config);\n280: \n281:   // Build the agent command to run inside the multiplexer\n282:   // Include portless env vars so any server started in the session\n283:   // is routed through the portless proxy\n284:   const pEnv = portlessEnv(opts.featureId, opts.config);\n285:   const envPrefix = Object.entries(pEnv)\n286:     .map(([k, v]) => `${k}=${JSON.stringify(v)}`)\n287:     .join(\" \");\n288: \n289:   const ocArgs = [\n290:     agentBin,\n291:     \"--dir\", JSON.stringify(opts.worktreePath),\n292:   ];\n293: \n294:   // Pass agent name if specified (specialized agent from registry or per-task override)\n295:   if (opts.agentName) {\n296:     ocArgs.push(\"--agent\", JSON.stringify(opts.agentName));\n297:   }\n298: \n299:   if (opts.model) {\n300:     ocArgs.push(\"--model\", JSON.stringify(opts.model));\n301:   }\n302: \n303:   const muxCmd = envPrefix ? `${envPrefix} ${ocArgs.join(\" \")}` : ocArgs.join(\" \");\n304: \n305:   // Create a detached session running the agent\n306:   muxNewSession(mux, sessionName, opts.worktreePath, muxCmd);\n307: \n308:   // Send the prompt as initial message after a brief delay\n309:   setTimeout(() => {\n310:     try {\n311:       const tmpFile = `/tmp/woco-prompt-${opts.featureId}.txt`;\n312:       writeFileSync(tmpFile, opts.prompt);\n313:       muxLoadBuffer(mux, tmpFile);\n314:       muxPasteBuffer(mux, sessionName);\n315:       muxSendKeys(mux, sessionName, \"Enter\");\n316:       try { unlinkSync(tmpFile); } catch {}\n317:     } catch {\n318:       // If prompt sending fails, user can type manually\n319:     }\n320:   }, 3000);\n321: \n322:   // Get the PID of the pane process\n323:   const panePid = muxGetPanePid(mux, sessionName);\n324: \n325:   return {\n326:     pid: panePid,\n327:     process: null as any, // No direct process handle in multiplexer mode\n328:   };\n329: }\n330: \n331: /**\n332:  * Resume an interactive session with retry message.\n333:  */\n334: export function retryInteractive(opts: RetryOptions): LaunchResult {\n335:   const mux = getMux(opts.config);\n336:   const sessionName = muxSessionName(opts.featureId, opts.config);\n337: \n338:   const exists = muxSessionExists(opts.featureId, opts.config);\n339: \n340:   if (exists) {\n341:     const retryMsg = `The build failed. Fix these errors:\\n${opts.buildErrors}`;\n342:     const tmpFile = `/tmp/woco-retry-${opts.featureId}.txt`;\n343:     writeFileSync(tmpFile, retryMsg);\n344:     muxLoadBuffer(mux, tmpFile);\n345:     muxPasteBuffer(mux, sessionName);\n346:     muxSendKeys(mux, sessionName, \"Enter\");\n347:     try { unlinkSync(tmpFile); } catch {}\n348: \n349:     const panePid = muxGetPanePid(mux, sessionName);\n350: \n351:     return {\n352:       pid: panePid,\n353:       process: null as any,\n354:     };\n355:   }\n356: \n357:   // Session doesn't exist — launch a new interactive session\n358:   return launchInteractive({\n359:     worktreePath: opts.worktreePath,\n360:     featureId: opts.featureId,\n361:     prompt: `Continue from session ${opts.sessionId}. The build failed:\\n${opts.buildErrors}\\n\\nFix all errors and verify the build passes.`,\n362:     model: opts.model,\n363:     interactive: true,\n364:     config: opts.config,\n365:   });\n366: }\n367: \n368: // ---------------------------------------------------------------------------\n369: // Multiplexer Session Management\n370: // ---------------------------------------------------------------------------\n371: \n372: /**\n373:  * Check if a multiplexer session exists for a feature.\n374:  */\n375: export function muxSessionExists(\n376:   featureId: string,\n377:   config: WomboConfig\n378: ): boolean {\n379:   const mux = getMux(config);\n380:   const sessionName = muxSessionName(featureId, config);\n381:   return muxHasSession(mux, sessionName);\n382: }\n383: \n384: /**\n385:  * Kill a multiplexer session for a feature.\n386:  */\n387: export function killMuxSession(\n388:   featureId: string,\n389:   config: WomboConfig\n390: ): void {\n391:   const mux = getMux(config);\n392:   const sessionName = muxSessionName(featureId, config);\n393:   muxKillSession(mux, sessionName);\n394: }\n395: \n396: /**\n397:  * List all woco-related multiplexer sessions.\n398:  */\n399: export function listMuxSessions(config: WomboConfig): string[] {\n400:   const mux = getMux(config);\n401:   const sessions = muxListSessions(mux);\n402:   return sessions.filter((s) => s.startsWith(config.agent.tmuxPrefix + \"-\"));\n403: }\n404: \n405: /**\n406:  * Kill all woco-related multiplexer sessions.\n407:  */\n408: export function killAllMuxSessions(config: WomboConfig): number {\n409:   const mux = getMux(config);\n410:   const sessions = listMuxSessions(config);\n411:   for (const s of sessions) {\n412:     muxKillSession(mux, s);\n413:   }\n414:   return sessions.length;\n415: }\n416: \n417: /**\n418:  * Get the display name of the active multiplexer backend.\n419:  */\n420: export function getMultiplexerName(config: WomboConfig): string {\n421:   try {\n422:     const mux = getMux(config);\n423:     return muxDisplayName(mux);\n424:   } catch {\n425:     return \"tmux/dmux\";\n426:   }\n427: }\n428: \n429: // ---------------------------------------------------------------------------\n430: // Backward Compatibility Aliases\n431: // ---------------------------------------------------------------------------\n432: \n433: /** @deprecated Use muxSessionExists instead */\n434: export const tmuxSessionExists = muxSessionExists;\n435: /** @deprecated Use killMuxSession instead */\n436: export const killTmuxSession = killMuxSession;\n437: /** @deprecated Use listMuxSessions instead */\n438: export const listTmuxSessions = listMuxSessions;\n439: /** @deprecated Use killAllMuxSessions instead */\n440: export const killAllTmuxSessions = killAllMuxSessions;\n441: \n442: /**\n443:  * Check if a process is still running by PID.\n444:  */\n445: export function isProcessRunning(pid: number): boolean {\n446:   if (!pid || pid <= 0) return false;\n447:   try {\n448:     process.kill(pid, 0);\n449:     return true;\n450:   } catch {\n451:     return false;\n452:   }\n453: }\n\n(End of file - total 453 lines)\n</content>","title":"src/lib/launcher.ts","metadata":{"preview":"/**\n * launcher.ts — Process spawning and terminal multiplexer session management.\n *\n * Responsibilities:\n *   - Launch agent in headless mode (agent run --format json)\n *   - Launch agent in interactive mode (dmux/tmux session with TUI)\n *   - Resume sessions for auto-retry\n *   - Manage multiplexer sessions (create, list, kill)\n *\n * Supports both dmux (preferred) and tmux (fallback) via the multiplexer\n * abstraction layer. The active backend is determined by config.agent.multiplexer.\n */\n\nimport { spawn, execSync, type ChildProcess } from \"node:child_process\";\nimport { writeFileSync, unlinkSync } from \"node:fs\";\nimport type { WomboConfig } from \"../config.js\";\nimport { resolveAgentBin } from \"../config.js\";\nimport {\n  detectMultiplexer,\n  muxNewSession,","truncated":false,"loaded":[]},"time":{"start":1773481727579,"end":1773481727583}}}}
