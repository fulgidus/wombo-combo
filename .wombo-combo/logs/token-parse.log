:{\"status\":\"completed\",\"input\":{\"filePath\":\"/home/fulgidus/Documents/wombo-cli-bugs/src/lib/features.ts\"},\"output\":\"<path>/home/fulgidus/Documents/wombo-cli-bugs/src/lib/features.ts</path>\\n<type>file</type>\\n<content>1: /**\\n2:  * features.ts — Parse features YAML and provide feature selection/filtering.\\n3:  *\\n4:  * Responsibilities:\\n5:  *   - Load and parse the features file with full type safety\\n6:  *   - Parse ISO 8601 durations into comparable minutes\\n7:  *   - Filter features by status, priority, difficulty, dependency readiness\\n8:  *   - Select features by various strategies (top-priority, quickest-wins, etc.)\\n9:  *   - Resolve dependency graphs to determine which features are ready to start\\n10:  *   - Write-back capability for feature management commands\\n11:  */\\n12: \\n13: import { readFileSync, writeFileSync, existsSync } from \\\"node:fs\\\";\\n14: import { resolve, dirname, join } from \\\"node:path\\\";\\n15: import { parse as parseYaml, stringify as stringifyYaml } from \\\"yaml\\\";\\n16: import { createInterface } from \\\"node:readline\\\";\\n17: import type { WomboConfig } from \\\"../config.js\\\";\\n18: \\n19: // ---------------------------------------------------------------------------\\n20: // Template path (resolved relative to this source file)\\n21: // ---------------------------------------------------------------------------\\n22: \\n23: export const FEATURES_TEMPLATE_PATH = join(dirname(import.meta.dir), \\\"templates\\\", \\\".features.yml\\\");\\n24: \\n25: // ---------------------------------------------------------------------------\\n26: // Types\\n27: // ---------------------------------------------------------------------------\\n28: \\n29: export type FeatureStatus =\\n30:   | \\\"backlog\\\"\\n31:   | \\\"planned\\\"\\n32:   | \\\"in_progress\\\"\\n33:   | \\\"blocked\\\"\\n34:   | \\\"in_review\\\"\\n35:   | \\\"done\\\"\\n36:   | \\\"cancelled\\\";\\n37: \\n38: export type Priority = \\\"critical\\\" | \\\"high\\\" | \\\"medium\\\" | \\\"low\\\" | \\\"wishlist\\\";\\n39: \\n40: export type Difficulty = \\\"trivial\\\" | \\\"easy\\\" | \\\"medium\\\" | \\\"hard\\\" | \\\"very_hard\\\";\\n41: \\n42: export interface Subtask {\\n43:   id: string;\\n44:   title: string;\\n45:   description: string;\\n46:   status: FeatureStatus;\\n47:   completion: number;\\n48:   difficulty: Difficulty;\\n49:   priority: Priority;\\n50:   depends_on: string[];\\n51:   effort: string;\\n52:   started_at: string | null;\\n53:   ended_at: string | null;\\n54:   constraints: string[];\\n55:   forbidden: string[];\\n56:   references: string[];\\n57:   notes: string[];\\n58:   subtasks: Subtask[];\\n59: }\\n60: \\n61: export interface Feature {\\n62:   id: string;\\n63:   title: string;\\n64:   description: string;\\n65:   status: FeatureStatus;\\n66:   completion: number;\\n67:   difficulty: Difficulty;\\n68:   priority: Priority;\\n69:   depends_on: string[];\\n70:   effort: string;\\n71:   started_at: string | null;\\n72:   ended_at: string | null;\\n73:   constraints: string[];\\n74:   forbidden: string[];\\n75:   references: string[];\\n76:   notes: string[];\\n77:   subtasks: Subtask[];\\n78: }\\n79: \\n80: export interface FeaturesFile {\\n81:   version: string;\\n82:   meta: {\\n83:     created_at: string;\\n84:     updated_at: string;\\n85:     project: string;\\n86:     generator: string;\\n87:     maintainer: string;\\n88:   };\\n89:   features: Feature[];\\n90:   archive: Feature[];\\n91: }\\n92: \\n93: // Priority ordering (lower = more important)\\n94: const PRIORITY_ORDER: Record<Priority, number> = {\\n95:   critical: 0,\\n96:   high: 1,\\n97:   medium: 2,\\n98:   low: 3,\\n99:   wishlist: 4,\\n100: };\\n101: \\n102: // Difficulty ordering (lower = easier)\\n103: const DIFFICULTY_ORDER: Record<Difficulty, number> = {\\n104:   trivial: 0,\\n105:   easy: 1,\\n106:   medium: 2,\\n107:   hard: 3,\\n108:   very_hard: 4,\\n109: };\\n110: \\n111: // ---------------------------------------------------------------------------\\n112: // ISO 8601 Duration Parser\\n113: // ---------------------------------------------------------------------------\\n114: \\n115: /**\\n116:  * Parse an ISO 8601 duration string into total minutes.\\n117:  * Supports: P[nD][T[nH][nM][nS]]\\n118:  * Examples: PT1H -> 60, PT30M -> 30, P1D -> 1440, P2DT4H -> 3360, PT1H30M -> 90\\n119:  */\\n120: export function parseDurationMinutes(iso: string): number {\\n121:   const match = iso.match(\\n122:     /^P(?:(\\\\d+)D)?(?:T(?:(\\\\d+)H)?(?:(\\\\d+)M)?(?:(\\\\d+)S)?)?$/\\n123:   );\\n124:   if (!match) return Infinity; // unparseable -> sort to end\\n125:   const days = parseInt(match[1] || \\\"0\\\", 10);\\n126:   const hours = parseInt(match[2] || \\\"0\\\", 10);\\n127:   const minutes = parseInt(match[3] || \\\"0\\\", 10);\\n128:   const seconds = parseInt(match[4] || \\\"0\\\", 10);\\n129:   return days * 24 * 60 + hours * 60 + minutes + Math.ceil(seconds / 60);\\n130: }\\n131: \\n132: /**\\n133:  * Format minutes into a human-readable string.\\n134:  */\\n135: export function formatDuration(minutes: number): string {\\n136:   if (minutes === Infinity) return \\\"unknown\\\";\\n137:   if (minutes < 60) return `${minutes}m`;\\n138:   const h = Math.floor(minutes / 60);\\n139:   const m = minutes % 60;\\n140:   if (h >= 24) {\\n141:     const d = Math.floor(h / 24);\\n142:     const rh = h % 24;\\n143:     if (rh === 0 && m === 0) return `${d}d`;\\n144:     if (m === 0) return `${d}d ${rh}h`;\\n145:     return `${d}d ${rh}h ${m}m`;\\n146:   }\\n147:   return m === 0 ? `${h}h` : `${h}h ${m}m`;\\n148: }\\n149: \\n150: // ---------------------------------------------------------------------------\\n151: // Features File Existence Guard\\n152: // ---------------------------------------------------------------------------\\n153: \\n154: /**\\n155:  * Prompt the user with a yes/no question via stdin.\\n156:  */\\n157: function promptYesNo(question: string): Promise<boolean> {\\n158:   const rl = createInterface({ input: process.stdin, output: process.stdout });\\n159:   return new Promise((resolve) => {\\n160:     rl.question(question, (answer) => {\\n161:       rl.close();\\n162:       resolve(answer.trim().toLowerCase().startsWith(\\\"y\\\"));\\n163:     });\\n164:   });\\n165: }\\n166: \\n167: /**\\n168:  * Ensure the features file exists before any command that needs it.\\n169:  * If the file is missing, prompt the user to generate one from the template.\\n170:  */\\n171: export async function ensureFeaturesFile(\\n172:   projectRoot: string,\\n173:   config: WomboConfig\\n174: ): Promise<void> {\\n175:   const filePath = resolve(projectRoot, config.featuresFile);\\n176: \\n177:   if (existsSync(filePath)) return;\\n178: \\n179:   console.log(`\\\\nFeatures file not found: ${config.featuresFile}`);\\n180: \\n181:   const generate = await promptYesNo(\\n182:     \\\"Generate a new features file from template? (y/N): \\\"\\n183:   );\\n184: \\n185:   if (!generate) {\\n186:     console.error(\\n187:       `Cannot proceed without a features file. Create one manually or run again and accept the prompt.`\\n188:     );\\n189:     process.exit(1);\\n190:   }\\n191: \\n192:   // Read template, update timestamps, write to project root\\n193:   const template = readFileSync(FEATURES_TEMPLATE_PATH, \\\"utf-8\\\");\\n194:   const now = new Date().toISOString();\\n195:   const content = template\\n196:     .replace(/created_at:\\\\s*\\\".*?\\\"/, `created_at: \\\"${now}\\\"`)\\n197:     .replace(/updated_at:\\\\s*\\\".*?\\\"/, `updated_at: \\\"${now}\\\"`);\\n198: \\n199:   writeFileSync(filePath, content, \\\"utf-8\\\");\\n200:   console.log(`Created ${config.featuresFile} from template.\\\\n`);\\n201: }\\n202: \\n203: // ---------------------------------------------------------------------------\\n204: // Loader\\n205: // ---------------------------------------------------------------------------\\n206: \\n207: /**\\n208:  * Load and parse the features YAML file from the project root.\\n209:  * Uses config.featuresFile for the file path.\\n210:  */\\n211: export function loadFeatures(\\n212:   projectRoot: string,\\n213:   config: WomboConfig\\n214: ): FeaturesFile {\\n215:   const filePath = resolve(projectRoot, config.featuresFile);\\n216:   const raw = readFileSync(filePath, \\\"utf-8\\\");\\n217:   const parsed = parseYaml(raw) as FeaturesFile;\\n218: \\n219:   // Normalize: ensure top-level arrays are never null/undefined (YAML parses\\n220:   // empty keys as null).\\n221:   parsed.features = parsed.features ?? [];\\n222:   parsed.archive = parsed.archive ?? [];\\n223: \\n224:   for (const f of [...parsed.features, ...parsed.archive]) {\\n225:     normalizeFeature(f);\\n226:   }\\n227: \\n228:   return parsed;\\n229: }\\n230: \\n231: /**\\n232:  * Save the features file back to disk (for management commands).\\n233:  */\\n234: export function saveFeatures(\\n235:   projectRoot: string,\\n236:   config: WomboConfig,\\n237:   data: FeaturesFile\\n238: ): void {\\n239:   const filePath = resolve(projectRoot, config.featuresFile);\\n240:   data.meta.updated_at = new Date().toISOString();\\n241:   const yaml = stringifyYaml(data, {\\n242:     lineWidth: 120,\\n243:     defaultKeyType: \\\"PLAIN\\\",\\n244:     defaultStringType: \\\"PLAIN\\\",\\n245:   });\\n246:   writeFileSync(filePath, yaml, \\\"utf-8\\\");\\n247: }\\n248: \\n249: function normalizeFeature(f: Feature | Subtask): void {\\n250:   f.depends_on = f.depends_on ?? [];\\n251:   f.constraints = f.constraints ?? [];\\n252:   f.forbidden = f.forbidden ?? [];\\n253:   f.references = f.references ?? [];\\n254:   f.notes = f.notes ?? [];\\n255:   f.subtasks = f.subtasks ?? [];\\n256:   for (const s of f.subtasks) {\\n257:     normalizeFeature(s);\\n258:   }\\n259: }\\n260: \\n261: // ---------------------------------------------------------------------------\\n262: // Dependency Resolution\\n263: // ---------------------------------------------------------------------------\\n264: \\n265: /**\\n266:  * Get all feature IDs that are done (status === \\\"done\\\" or completion === 100).\\n267:  */\\n268: function getDoneIds(features: Feature[], archive: Feature[]): Set<string> {\\n269:   const done = new Set<string>();\\n270:   const collectDone = (items: (Feature | Subtask)[]) => {\\n271:     for (const item of items) {\\n272:       if (item.status === \\\"done\\\" || item.completion === 100) {\\n273:         done.add(item.id);\\n274:       }\\n275:       if (item.subtasks?.length) {\\n276:         collectDone(item.subtasks);\\n277:       }\\n278:     }\\n279:   };\\n280:   collectDone(features);\\n281:   collectDone(archive);\\n282:   return done;\\n283: }\\n284: \\n285: /**\\n286:  * Check if a feature's dependencies are all satisfied.\\n287:  */\\n288: export function areDependenciesMet(\\n289:   feature: Feature,\\n290:   doneIds: Set<string>\\n291: ): boolean {\\n292:   return feature.depends_on.every((dep) => doneIds.has(dep));\\n293: }\\n294: \\n295: /**\\n296:  * Get all features that are ready to start (backlog + deps met).\\n297:  */\\n298: export function getReadyFeatures(data: FeaturesFile): Feature[] {\\n299:   const doneIds = getDoneIds(data.features, data.archive);\\n300:   return data.features.filter(\\n301:     (f) =>\\n302:       f.status === \\\"backlog\\\" &&\\n303:       f.completion === 0 &&\\n304:       areDependenciesMet(f, doneIds)\\n305:   );\\n306: }\\n307: \\n308: /**\\n309:  * Get done IDs (exported for use in selection error messages).\\n310:  */\\n311: export function getDoneFeatureIds(data: FeaturesFile): Set<string> {\\n312:   return getDoneIds(data.features, data.archive);\\n313: }\\n314: \\n315: // ---------------------------------------------------------------------------\\n316: // Selection Strategies\\n317: // ---------------------------------------------------------------------------\\n318: \\n319: export interface SelectionOptions {\\n320:   /** Select top N by priority (highest priority first, then lowest effort) */\\n321:   topPriority?: number;\\n322:   /** Select N quickest wins (lowest effort first) */\\n323:   quickestWins?: number;\\n324:   /** Select all features matching this priority level */\\n325:   priority?: Priority;\\n326:   /** Select all features matching this difficulty level */\\n327:   difficulty?: Difficulty;\\n328:   /** Select specific feature IDs (comma-separated) */\\n329:   featureIds?: string[];\\n330:   /** Select all ready features */\\n331:   allReady?: boolean;\\n332: }\\n333: \\n334: /**\\n335:  * Select features based on the given strategy.\\n336:  * Always filters to only ready features (backlog + deps met) first.\\n337:  */\\n338: export function selectFeatures(\\n339:   data: FeaturesFile,\\n340:   options: SelectionOptions\\n341: ): Feature[] {\\n342:   const ready = getReadyFeatures(data);\\n343: \\n344:   if (options.allReady) {\\n345:     return sortByPriorityThenEffort(ready);\\n346:   }\\n347: \\n348:   if (options.featureIds?.length) {\\n349:     const idSet = new Set(options.featureIds);\\n350:     const selected = ready.filter((f) => idSet.has(f.id));\\n351:     const missing = options.featureIds.filter(\\n352:       (id) => !selected.find((f) => f.id === id)\\n353:     );\\n354:     if (missing.length) {\\n355:       const allIds = data.features.map((f) => f.id);\\n356:       const doneIds = getDoneIds(data.features, data.archive);\\n357:       for (const m of missing) {\\n358:         if (!allIds.includes(m)) {\\n359:           console.error(`  Feature \\\"${m}\\\" does not exist in the features file`);\\n360:         } else {\\n361:           const feat = data.features.find((f) => f.id === m)!;\\n362:           console.error(\\n363:             `  Feature \\\"${m}\\\" is not ready (status: ${feat.status}, deps met: ${areDependenciesMet(feat, doneIds)})`\\n364:           );\\n365:         }\\n366:       }\\n367:     }\\n368:     return sortByPriorityThenEffort(selected);\\n369:   }\\n370: \\n371:   if (options.priority) {\\n372:     return sortByPriorityThenEffort(\\n373:       ready.filter((f) => f.priority === options.priority)\\n374:     );\\n375:   }\\n376: \\n377:   if (options.difficulty) {\\n378:     return sortByEffort(ready.filter((f) => f.difficulty === options.difficulty));\\n379:   }\\n380: \\n381:   if (options.topPriority) {\\n382:     return sortByPriorityThenEffort(ready).slice(0, options.topPriority);\\n383:   }\\n384: \\n385:   if (options.quickestWins) {\\n386:     return sortByEffort(ready).slice(0, options.quickestWins);\\n387:   }\\n388: \\n389:   // Default: return all ready, sorted by priority\\n390:   return sortByPriorityThenEffort(ready);\\n391: }\\n392: \\n393: // ---------------------------------------------------------------------------\\n394: // Sorting Helpers\\n395: // ---------------------------------------------------------------------------\\n396: \\n397: function sortByPriorityThenEffort(features: Feature[]): Feature[] {\\n398:   return [...features].sort((a, b) => {\\n399:     const pDiff = PRIORITY_ORDER[a.priority] - PRIORITY_ORDER[b.priority];\\n400:     if (pDiff !== 0) return pDiff;\\n401:     return parseDurationMinutes(a.effort) - parseDurationMinutes(b.effort);\\n402:   });\\n403: }\\n404: \\n405: function sortByEffort(features: Feature[]): Feature[] {\\n406:   return [...features].sort(\\n407:     (a, b) => parseDurationMinutes(a.effort) - parseDurationMinutes(b.effort)\\n408:   );\\n409: }\\n410: \\n411: // ---------------------------------------------------------------------------\\n412: // Utility Exports\\n413: // ---------------------------------------------------------------------------\\n414: \\n415: export { PRIORITY_ORDER, DIFFICULTY_ORDER };\\n416: \\n417: /**\\n418:  * Get a compact summary of a feature for display.\\n419:  */\\n420: export function featureSummary(f: Feature): string {\\n421:   const effort = formatDuration(parseDurationMinutes(f.effort));\\n422:   return `[${f.priority}/${f.difficulty}] ${f.id} -- ${f.title} (${effort})`;\\n423: }\\n424: \\n425: /**\\n426:  * Recursively search a list of features (and their subtasks) for a matching ID.\\n427:  */\\n428: function findInList(features: Feature[], id: string): Feature | undefined {\\n429:   for (const f of features) {\\n430:     if (f.id === id) return f;\\n431:     if (f.subtasks?.length) {\\n432:       const found = findInList(f.subtasks, id);\\n433:       if (found) return found;\\n434:     }\\n435:   }\\n436:   return undefined;\\n437: }\\n438: \\n439: /**\\n440:  * Find a feature or subtask by ID across active features, their subtasks\\n441:  * (recursively), and the archive list.\\n442:  */\\n443: export function findFeatureById(\\n444:   data: FeaturesFile,\\n445:   id: string\\n446: ): Feature | undefined {\\n447:   return (\\n448:     findInList(data.features, id) ??\\n449:     (data.archive ? findInList(data.archive, id) : undefined)\\n450:   );\\n451: }\\n452: \\n453: /**\\n454:  * Create a blank feature with all required fields initialized.\\n455:  */\\n456: export function createBlankFeature(\\n457:   id: string,\\n458:   title: string,\\n459:   description: string = \\\"\\\",\\n460:   opts?: {\\n461:     priority?: Priority;\\n462:     difficulty?: Difficulty;\\n463:     effort?: string;\\n464:   }\\n465: ): Feature {\\n466:   return {\\n467:     id,\\n468:     title,\\n469:     description,\\n470:     status: \\\"backlog\\\",\\n471:     completion: 0,\\n472:     difficulty: opts?.difficulty ?? \\\"medium\\\",\\n473:     priority: opts?.priority ?? \\\"medium\\\",\\n474:     depends_on: [],\\n475:     effort: opts?.effort ?? \\\"PT1H\\\",\\n476:     started_at: null,\\n477:     ended_at: null,\\n478:     constraints: [],\\n479:     forbidden: [],\\n480:     references: [],\\n481:     notes: [],\\n482:     subtasks: [],\\n483:   };\\n484: }\\n485: \\n486: /**\\n487:  * Get all feature IDs (active + archive), useful for validation.\\n488:  */\\n489: export function allFeatureIds(data: FeaturesFile): string[] {\\n490:   const ids: string[] = [];\\n491:   const collect = (items: (Feature | Subtask)[]) => {\\n492:     for (const item of items) {\\n493:       ids.push(item.id);\\n494:       if (item.subtasks?.length) collect(item.subtasks);\\n495:     }\\n496:   };\\n497:   collect(data.features);\\n498:   collect(data.archive ?? []);\\n499:   return ids;\\n500: }\\n\\n(End of file - total 500 lines)\\n</content>\",\"title\":\"src/lib/features.ts\",\"metadata\":{\"preview\":\"/**\\n * features.ts — Parse features YAML and provide feature selection/filtering.\\n *\\n * Responsibilities:\\n *   - Load and parse the features file with full type safety\\n *   - Parse ISO 8601 durations into comparable minutes\\n *   - Filter features by status, priority, difficulty, dependency readiness\\n *   - Select features by various strategies (top-priority, quickest-wins, etc.)\\n *   - Resolve dependency graphs to determine which features are ready to start\\n *   - Write-back capability for feature management commands\\n */\\n\\nimport { readFileSync, writeFileSync, existsSync } from \\\"node:fs\\\";\\nimport { resolve, dirname, join } from \\\"node:path\\\";\\nimport { parse as parseYaml, stringify as stringifyYaml } from \\\"yaml\\\";\\nimport { createInterface } from \\\"node:readline\\\";\\nimport type { WomboConfig } from \\\"../config.js\\\";\\n\\n// ---------------------------------------------------------------------------\\n// Template path (resolved relative to this source file)\",\"truncated\":false,\"loaded\":[]},\"time\":{\"start\":1773245117142,\"end\":1773245117146}}}}\n{\"type\":\"text\",\"timestamp\":1773245117690,\"sessionID\":\"ses_3225b056affeIKEEihnMYwMnTu\",\"part\":{\"id\":\"prt_cdda52ee00013ONyyGR440DnGs\",\"sessionID\":\"ses_3225b056affeIKEEihnMYwMnTu\",\"messageID\":\"msg_cdda522ac001iuBve2qJO4g3C3\",\"type\":\"text\",\"text\":\"Now let me read the key files I need to modify:\",\"time\":{\"start\":1773245117689,\"end\":1773245117689}}}\n{\"type\":\"tool_use\",\"timestamp\":1773245117692,\"sessionID\":\"ses_3225b056affeIKEEihnMYwMnTu\",\"part\":{\"id\":\"prt_cdda532d7001P5gw8FXNLb2Q5m\",\"sessionID\":\"ses_3225b056affeIKEEihnMYwMnTu\",\"messageID\":\"msg_cdda522ac001iuBve2qJO4g3C3\",\"type\":\"tool\",\"callID\":\"toolu_01PfTzCPwU4muGz9U4b1EU5Z\",\"tool\":\"read\",\"state\":{\"status\":\"completed\",\"input\":{\"filePath\":\"/home/fulgidus/Documents/wombo-cli-bugs/src/lib/output.ts\"},\"output\":\"<path>/home/fulgidus/Documents/wombo-cli-bugs/src/lib/output.ts</path>\\n<type>file</type>\\n<content>1: /**\\n2:  * output.ts — Shared output helpers for agent-ready CLI.\\n3:  *\\n4:  * Provides a centralized way for commands to emit structured data that\\n5:  * renders as human-readable text on TTY or as JSON when --output json\\n6:  * is specified (or when stdout is not a TTY).\\n7:  *\\n8:  * Usage in commands:\\n9:  *   import { output, OutputFormat } from \\\"../lib/output.js\\\";\\n10:  *\\n11:  *   // At the end of a command:\\n12:  *   output(format, data);           // emits JSON or human text\\n13:  *   outputError(format, message);   // emits error in the right format\\n14:  */\\n15: \\n16: // ---------------------------------------------------------------------------\\n17: // Types\\n18: // ---------------------------------------------------------------------------\\n19: \\n20: export type OutputFormat = \\\"text\\\" | \\\"json\\\";\\n21: \\n22: // ---------------------------------------------------------------------------\\n23: // Helpers\\n24: // ---------------------------------------------------------------------------\\n25: \\n26: /**\\n27:  * Determine the output format. Priority:\\n28:  *   1. Explicit --output flag value\\n29:  *   2. WOMBO_OUTPUT env var (for agent pipelines)\\n30:  *   3. Default to \\\"text\\\"\\n31:  *\\n32:  * Note: We intentionally do NOT auto-detect based on TTY. Many legitimate\\n33:  * use cases (bun dev, piped to less/grep, CI) have non-TTY stdout but still\\n34:  * want human output. Agents should explicitly pass --output json or set\\n35:  * WOMBO_OUTPUT=json.\\n36:  */\\n37: export function resolveOutputFormat(explicit?: string): OutputFormat {\\n38:   if (explicit === \\\"json\\\") return \\\"json\\\";\\n39:   if (explicit === \\\"text\\\") return \\\"text\\\";\\n40:   // Check env var for agent pipelines\\n41:   const env = process.env.WOMBO_OUTPUT;\\n42:   if (env === \\\"json\\\") return \\\"json\\\";\\n43:   return \\\"text\\\";\\n44: }\\n45: \\n46: /**\\n47:  * Emit structured data. In JSON mode, outputs a single JSON line to stdout.\\n48:  * In text mode, calls the provided textRenderer callback.\\n49:  */\\n50: export function output(\\n51:   format: OutputFormat,\\n52:   data: unknown,\\n53:   textRenderer: () => void\\n54: ): void {\\n55:   if (format === \\\"json\\\") {\\n56:     console.log(JSON.stringify(data));\\n57:   } else {\\n58:     textRenderer();\\n59:   }\\n60: }\\n61: \\n62: /**\\n63:  * Emit an error. In JSON mode, outputs {\\\"error\\\": message} to stderr.\\n64:  * In text mode, outputs the message to stderr normally.\\n65:  */\\n66: export function outputError(format: OutputFormat, message: string, exitCode: number = 1): never {\\n67:   if (format === \\\"json\\\") {\\n68:     console.error(JSON.stringify({ error: message }));\\n69:   } else {\\n70:     console.error(message);\\n71:   }\\n72:   process.exit(exitCode);\\n73: }\\n74: \\n75: /**\\n76:  * Emit a success/info message. In JSON mode, outputs {\\\"message\\\": msg, ...extra}.\\n77:  * In text mode, outputs the message to stdout normally.\\n78:  */\\n79: export function outputMessage(\\n80:   format: OutputFormat,\\n81:   message: string,\\n82:   extra?: Record<string, unknown>\\n83: ): void {\\n84:   if (format === \\\"json\\\") {\\n85:     console.log(JSON.stringify({ message, ...extra }));\\n86:   } else {\\n87:     console.log(message);\\n88:   }\\n89: }\\n90: \\n91: // ---------------------------------------------------------------------------\\n92: // Field filtering for compact output (--fields)\\n93: // ---------------------------------------------------------------------------\\n94: \\n95: /**\\n96:  * Filter an object to only include the specified fields.\\n97:  * If fields is undefined/empty, returns the object unchanged.\\n98:  */\\n99: export function filterFields<T extends Record<string, unknown>>(\\n100:   obj: T,\\n101:   fields?: string[]\\n102: ): Partial<T> {\\n103:   if (!fields || fields.length === 0) return obj;\\n104:   const result: Partial<T> = {};\\n105:   for (const field of fields) {\\n106:     if (field in obj) {\\n107:       (result as any)[field] = (obj as any)[field];\\n108:     }\\n109:   }\\n110:   return result;\\n111: }\\n112: \\n113: /**\\n114:  * Filter an array of objects to only include specified fields per object.\\n115:  * If fields is undefined/empty, returns the array unchanged.\\n116:  */\\n117: export function filterFieldsArray<T extends Record<string, unknown>>(\\n118:   arr: T[],\\n119:   fields?: string[]\\n120: ): Partial<T>[] {\\n121:   if (!fields || fields.length === 0) return arr;\\n122:   return arr.map((obj) => filterFields(obj, fields));\\n123: }\\n124: \\n125: /**\\n126:  * Render a compact text table from an array of objects with selected fields.\\n127:  * Used for text-mode --fields output.\\n128:  */\\n129: export function renderCompactTable(\\n130:   items: Record<string, unknown>[],\\n131:   fields: string[]\\n132: ): void {\\n133:   if (items.length === 0) return;\\n134: \\n135:   // Calculate column widths\\n136:   const widths: Record<string, number> = {};\\n137:   for (const field of fields) {\\n138:     widths[field] = field.length;\\n139:     for (const item of items) {\\n140:       const val = String(item[field] ?? \\\"\\\");\\n141:       widths[field] = Math.max(widths[field], val.length);\\n142:     }\\n143:   }\\n144: \\n145:   // Header\\n146:   const header = fields.map((f) => f.padEnd(widths[f])).join(\\\"  \\\");\\n147:   console.log(header);\\n148:   console.log(fields.map((f) => \\\"─\\\".repeat(widths[f])).join(\\\"  \\\"));\\n149: \\n150:   // Rows\\n151:   for (const item of items) {\\n152:     const row = fields.map((f) => String(item[f] ?? \\\"\\\").padEnd(widths[f])).join(\\\"  \\\");\\n153:     console.log(row);\\n154:   }\\n155: }\\n\\n(End of file - total 155 lines)\\n</content>\",\"title\":\"src/lib/output.ts\",\"metadata\":{\"preview\":\"/**\\n * output.ts — Shared output helpers for agent-ready CLI.\\n *\\n * Provides a centralized way for commands to emit structured data that\\n * renders as human-readable text on TTY or as JSON when --output json\\n * is specified (or when stdout is not a TTY).\\n *\\n * Usage in commands:\\n *   import { output, OutputFormat } from \\\"../lib/output.js\\\";\\n *\\n *   // At the end of a command:\\n *   output(format, data);           // emits JSON or human text\\n *   outputError(format, message);   // emits error in the right format\\n */\\n\\n// ---------------------------------------------------------------------------\\n// Types\\n// ---------------------------------------------------------------------------\\n\\nexport type OutputFormat = \\\"text\\\" | \\\"json\\\";\",\"truncated\":false,\"loaded\":[]},\"time\":{\"start\":1773245117688,\"end\":1773245117691}}}}\n{\"type\":\"step_finish\",\"timestamp\":1773245117705,\"sessionID\":\"ses_3225b056affeIKEEihnMYwMnTu\",\"part\":{\"id\":\"prt_cdda534fc00164waW2b5Lkw5ry\",\"sessionID\":\"ses_3225b056affeIKEEihnMYwMnTu\",\"messageID\":\"msg_cdda522ac001iuBve2qJO4g3C3\",\"type\":\"step-finish\",\"reason\":\"tool-calls\",\"snapshot\":\"4c8bafd2260c7d3ee29d0f4ac9e5445032a47a49\",\"cost\":0,\"tokens\":{\"total\":21672,\"input\":513,\"output\":202,\"reasoning\":0,\"cache\":{\"read\":20957,\"write\":0}}}}\n{\"type\":\"step_start\",\"timestamp\":1773245121476,\"sessionID\":\"ses_3225b056affeIKEEihnMYwMnTu\",\"part\":{\"id\":\"prt_cdda543c3001J5YxtmX8TutUns\",\"sessionID\":\"ses_3225b056affeIKEEihnMYwMnTu\",\"messageID\":\"msg_cdda53521001UuGUukGjwCgh80\",\"type\":\"step-start\",\"snapshot\":\"4c8bafd2260c7d3ee29d0f4ac9e5445032a47a49\"}}\n{\"type\":\"tool_use\",\"timestamp\":1773245122780,\"sessionID\":\"ses_3225b056affeIKEEihnMYwMnTu\",\"part\":{\"id\":\"prt_cdda54678001i92uq3vf1oLDpW\",\"sessionID\":\"ses_3225b056affeIKEEihnMYwMnTu\",\"messageID\":\"msg_cdda53521001UuGUukGjwCgh80\",\"type\":\"tool\",\"callID\":\"toolu_01WtDWk29TgAZn3N1TQbnTAQ\",\"tool\":\"read\",\"state\":{\"status\":\"completed\",\"input\":{\"filePath\":\"/home/fulgidus/Documents/wombo-cli-bugs/src/commands/features/add.ts\"},\"output\":\"<path>/home/fulgidus/Documents/wombo-cli-bugs/src/commands/features/add.ts</path>\\n<type>file</type>\\n<content>1: /**\\n2:  * features/add.ts — Add a new feature to the features file.\\n3:  *\\n4:  * Usage:\\n5:  *   wombo features add <id> --title \\\"Feature Title\\\" [--description \\\"...\\\"]\\n6:  *                      [--priority medium] [--difficulty easy] [--effort PT2H]\\n7:  *                      [--depends-on \\\"feat1,feat2\\\"]\\n8:  */\\n9: \\n10: import type { WomboConfig } from \\\"../../config.js\\\";\\n11: import {\\n12:   loadFeatures,\\n13:   saveFeatures,\\n14:   createBlankFeature,\\n15:   allFeatureIds,\\n16:   type Priority,\\n17:   type Difficulty,\\n18: } from \\\"../../lib/features.js\\\";\\n19: import { outputError, outputMessage, type OutputFormat } from \\\"../../lib/output.js\\\";\\n20: \\n21: // ---------------------------------------------------------------------------\\n22: // Types\\n23: // ---------------------------------------------------------------------------\\n24: \\n25: export interface FeaturesAddOptions {\\n26:   projectRoot: string;\\n27:   config: WomboConfig;\\n28:   id: string;\\n29:   title: string;\\n30:   description?: string;\\n31:   priority?: Priority;\\n32:   difficulty?: Difficulty;\\n33:   effort?: string;\\n34:   dependsOn?: string[];\\n35:   outputFmt?: OutputFormat;\\n36:   dryRun?: boolean;\\n37: }\\n38: \\n39: // ---------------------------------------------------------------------------\\n40: // Command\\n41: // ---------------------------------------------------------------------------\\n42: \\n43: export async function cmdFeaturesAdd(opts: FeaturesAddOptions): Promise<void> {\\n44:   const { projectRoot, config } = opts;\\n45:   const fmt = opts.outputFmt ?? \\\"text\\\";\\n46: \\n47:   if (!opts.id) {\\n48:     outputError(fmt, \\\"Usage: wombo features add <id> --title \\\\\\\"Feature Title\\\\\\\"\\\");\\n49:     return;\\n50:   }\\n51: \\n52:   if (!opts.title) {\\n53:     outputError(fmt, \\\"--title is required when adding a feature.\\\");\\n54:     return;\\n55:   }\\n56: \\n57:   const data = loadFeatures(projectRoot, config);\\n58: \\n59:   // Check for duplicate ID\\n60:   const existingIds = allFeatureIds(data);\\n61:   if (existingIds.includes(opts.id)) {\\n62:     outputError(fmt, `Feature ID \\\"${opts.id}\\\" already exists.`);\\n63:     return;\\n64:   }\\n65: \\n66:   // Validate depends_on references\\n67:   if (opts.dependsOn?.length) {\\n68:     for (const dep of opts.dependsOn) {\\n69:       if (!existingIds.includes(dep)) {\\n70:         outputError(fmt, `Dependency \\\"${dep}\\\" does not exist in the features file.`);\\n71:         return;\\n72:       }\\n73:     }\\n74:   }\\n75: \\n76:   // Create the feature\\n77:   const feature = createBlankFeature(opts.id, opts.title, opts.description ?? \\\"\\\", {\\n78:     priority: opts.priority,\\n79:     difficulty: opts.difficulty,\\n80:     effort: opts.effort,\\n81:   });\\n82: \\n83:   // Set dependencies\\n84:   if (opts.dependsOn?.length) {\\n85:     feature.depends_on = opts.dependsOn;\\n86:   }\\n87: \\n88:   // Dry-run: show what would be added without writing\\n89:   if (opts.dryRun) {\\n90:     outputMessage(fmt, `[dry-run] Would add feature: ${opts.id} — ${opts.title}`, {\\n91:       dry_run: true,\\n92:       id: feature.id,\\n93:       title: feature.title,\\n94:       priority: feature.priority,\\n95:       difficulty: feature.difficulty,\\n96:       effort: feature.effort,\\n97:       depends_on: feature.depends_on,\\n98:     });\\n99:     return;\\n100:   }\\n101: \\n102:   // Append to features list\\n103:   data.features.push(feature);\\n104:   saveFeatures(projectRoot, config, data);\\n105: \\n106:   outputMessage(fmt, `Added feature: ${opts.id} — ${opts.title}`, {\\n107:     id: feature.id,\\n108:     title: feature.title,\\n109:     priority: feature.priority,\\n110:     difficulty: feature.difficulty,\\n111:     effort: feature.effort,\\n112:     depends_on: feature.depends_on,\\n113:   });\\n114: \\n115:   if (fmt === \\\"text\\\") {\\n116:     console.log(`  priority: ${feature.priority}, difficulty: ${feature.difficulty}, effort: ${feature.effort}`);\\n117:     if (feature.depends_on.length > 0) {\\n118:       console.log(`  depends on: ${feature.depends_on.join(\\\", \\\")}`);\\n119:     }\\n120:   }\\n121: }\\n\\n(End of file - total 121 lines)\\n</content>\",\"title\":\"src/commands/features/add.ts\",\"metadata\":{\"preview\":\"/**\\n * features/add.ts — Add a new feature to the features file.\\n *\\n * Usage:\\n *   wombo features add <id> --title \\\"Feature Title\\\" [--description \\\"...\\\"]\\n *                      [--priority medium] [--difficulty easy] [--effort PT2H]\\n *                      [--depends-on \\\"feat1,feat2\\\"]\\n */\\n\\nimport type { WomboConfig } from \\\"../../config.js\\\";\\nimport {\\n  loadFeatures,\\n  saveFeatures,\\n  createBlankFeature,\\n  allFeatureIds,\\n  type Priority,\\n  type Difficulty,\\n} from \\\"../../lib/features.js\\\";\\nimport { outputError, outputMessage, type OutputFormat } from \\\"../../lib/output.js\\\";\\n\",\"truncated\":false,\"loaded\":[]},\"time\":{\"start\":1773245122776,\"end\":1773245122779}}}}\n{\"type\":\"tool_use\",\"timestamp\":1773245123199,\"sessionID\":\"ses_3225b056affeIKEEihnMYwMnTu\",\"part\":{\"id\":\"prt_cdda548d9001dTGQS5789GLkcO\",\"sessionID\":\"ses_3225b056affeIKEEihnMYwMnTu\",\"messageID\":\"msg_cdda53521001UuGUukGjwCgh80\",\"type\":\"tool\",\"callID\":\"toolu_0191iRdRZfng6iEvgZ26ju9H\",\"tool\":\"read\",\"state\":{\"status\":\"completed\",\"input\":{\"filePath\":\"/home/fulgidus/Documents/wombo-cli-bugs/src/commands/features/archive.ts\"},\"output\":\"<path>/home/fulgidus/Documents/wombo-cli-bugs/src/commands/features/archive.ts</path>\\n<type>file</type>\\n<content>1: /**\\n2:  * features/archive.ts — Move done/cancelled features to the archive section.\\n3:  *\\n4:  * Usage:\\n5:  *   wombo features archive              # archive all done + cancelled\\n6:  *   wombo features archive <feature-id> # archive a specific feature\\n7:  *   wombo features archive --dry-run    # show what would be archived\\n8:  */\\n9: \\n10: import type { WomboConfig } from \\\"../../config.js\\\";\\n11: import {\\n12:   loadFeatures,\\n13:   saveFeatures,\\n14:   findFeatureById,\\n15:   type Feature,\\n16: } from \\\"../../lib/features.js\\\";\\n17: \\n18: // ---------------------------------------------------------------------------\\n19: // Types\\n20: // ---------------------------------------------------------------------------\\n21: \\n22: export interface FeaturesArchiveOptions {\\n23:   projectRoot: string;\\n24:   config: WomboConfig;\\n25:   featureId?: string;\\n26:   dryRun?: boolean;\\n27: }\\n28: \\n29: // ---------------------------------------------------------------------------\\n30: // Command\\n31: // ---------------------------------------------------------------------------\\n32: \\n33: export async function cmdFeaturesArchive(opts: FeaturesArchiveOptions): Promise<void> {\\n34:   const { projectRoot, config } = opts;\\n35: \\n36:   const data = loadFeatures(projectRoot, config);\\n37: \\n38:   // Ensure archive array exists\\n39:   if (!data.archive) {\\n40:     data.archive = [];\\n41:   }\\n42: \\n43:   let toArchive: Feature[];\\n44: \\n45:   if (opts.featureId) {\\n46:     // Archive a specific feature\\n47:     const idx = data.features.findIndex((f) => f.id === opts.featureId);\\n48:     if (idx === -1) {\\n49:       // Check if already in archive\\n50:       if (data.archive.find((f) => f.id === opts.featureId)) {\\n51:         console.log(`Feature \\\"${opts.featureId}\\\" is already in the archive.`);\\n52:         return;\\n53:       }\\n54:       console.error(`Feature \\\"${opts.featureId}\\\" not found.`);\\n55:       process.exit(1);\\n56:       return;\\n57:     }\\n58:     toArchive = [data.features[idx]];\\n59:   } else {\\n60:     // Archive all done + cancelled features\\n61:     toArchive = data.features.filter(\\n62:       (f) => f.status === \\\"done\\\" || f.status === \\\"cancelled\\\"\\n63:     );\\n64:   }\\n65: \\n66:   if (toArchive.length === 0) {\\n67:     console.log(\\\"No features to archive.\\\");\\n68:     return;\\n69:   }\\n70: \\n71:   if (opts.dryRun) {\\n72:     console.log(`\\\\nWould archive ${toArchive.length} feature(s):\\\\n`);\\n73:     for (const f of toArchive) {\\n74:       console.log(`  ${f.id} — ${f.title} (${f.status})`);\\n75:     }\\n76:     return;\\n77:   }\\n78: \\n79:   // Move features from active to archive\\n80:   const archiveIds = new Set(toArchive.map((f) => f.id));\\n81:   data.features = data.features.filter((f) => !archiveIds.has(f.id));\\n82:   data.archive.push(...toArchive);\\n83: \\n84:   saveFeatures(projectRoot, config, data);\\n85: \\n86:   console.log(`\\\\nArchived ${toArchive.length} feature(s):`);\\n87:   for (const f of toArchive) {\\n88:     console.log(`  ${f.id} — ${f.title} (${f.status})`);\\n89:   }\\n90: }\\n\\n(End of file - total 90 lines)\\n</content>\",\"title\":\"src/commands/features/archive.ts\",\"metadata\":{\"preview\":\"/**\\n * features/archive.ts — Move done/cancelled features to the archive section.\\n *\\n * Usage:\\n *   wombo features archive              # archive all done + cancelled\\n *   wombo features archi