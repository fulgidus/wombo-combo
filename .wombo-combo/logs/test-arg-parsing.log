{"type":"tool_use","timestamp":1773435232293,"sessionID":"ses_3170615c1ffe6qPm6NgPYs8fxK","part":{"id":"prt_ce8fa1c1f001UhsHLS1A0VB3j5","sessionID":"ses_3170615c1ffe6qPm6NgPYs8fxK","messageID":"msg_ce8fa110d001Kpulkz0vZ5aBY4","type":"tool","callID":"toolu_vrtx_01VaUqSDHCxoHdFGAEMZjhux","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-test-arg-parsing/tests/arg-parsing.test.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-test-arg-parsing/tests/arg-parsing.test.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * arg-parsing.test.ts — Unit tests for CLI argument parsing.\n3:  *\n4:  * Coverage:\n5:  *   - Basic command parsing\n6:  *   - Features subcommand routing\n7:  *   - Flag parsing (boolean flags, value flags)\n8:  *   - Trailing flags after positional args\n9:  *   - Missing values for value-expecting flags\n10:  *   - Flag collisions and priority\n11:  *   - Positional argument handling (featureId, title)\n12:  *   - Edge cases: empty args, unknown flags, repeated flags\n13:  */\n14: \n15: import { describe, test, expect } from \"bun:test\";\n16: import { parseArgs } from \"../src/index.js\";\n17: \n18: // Helper to simulate argv from CLI input. We need to prepend \"bun\" and \"script\"\n19: // since parseArgs does argv.slice(2).\n20: function argv(...args: string[]): string[] {\n21:   return [\"bun\", \"script.ts\", ...args];\n22: }\n23: \n24: // ---------------------------------------------------------------------------\n25: // Basic command parsing\n26: // ---------------------------------------------------------------------------\n27: \n28: describe(\"parseArgs — basic commands\", () => {\n29:   test(\"parses help command\", () => {\n30:     const result = parseArgs(argv(\"help\"));\n31:     expect(result.command).toBe(\"help\");\n32:   });\n33: \n34:   test(\"defaults to help when no args given\", () => {\n35:     const result = parseArgs(argv());\n36:     expect(result.command).toBe(\"help\");\n37:   });\n38: \n39:   test(\"parses launch command\", () => {\n40:     const result = parseArgs(argv(\"launch\"));\n41:     expect(result.command).toBe(\"launch\");\n42:   });\n43: \n44:   test(\"parses status command\", () => {\n45:     const result = parseArgs(argv(\"status\"));\n46:     expect(result.command).toBe(\"status\");\n47:   });\n48: \n49:   test(\"parses cleanup command\", () => {\n50:     const result = parseArgs(argv(\"cleanup\"));\n51:     expect(result.command).toBe(\"cleanup\");\n52:   });\n53: \n54:   test(\"parses --version as command\", () => {\n55:     const result = parseArgs(argv(\"--version\"));\n56:     expect(result.command).toBe(\"--version\");\n57:   });\n58: \n59:   test(\"parses -V as command\", () => {\n60:     const result = parseArgs(argv(\"-V\"));\n61:     expect(result.command).toBe(\"-V\");\n62:   });\n63: });\n64: \n65: // ---------------------------------------------------------------------------\n66: // Features subcommand routing\n67: // ---------------------------------------------------------------------------\n68: \n69: describe(\"parseArgs — features subcommands\", () => {\n70:   test(\"defaults features subcommand to list\", () => {\n71:     const result = parseArgs(argv(\"features\"));\n72:     expect(result.command).toBe(\"features\");\n73:     expect(result.subcommand).toBe(\"list\");\n74:   });\n75: \n76:   test(\"parses features list\", () => {\n77:     const result = parseArgs(argv(\"features\", \"list\"));\n78:     expect(result.command).toBe(\"features\");\n79:     expect(result.subcommand).toBe(\"list\");\n80:   });\n81: \n82:   test(\"parses features add with positional args\", () => {\n83:     const result = parseArgs(argv(\"features\", \"add\", \"my-feat\", \"My Feature Title\"));\n84:     expect(result.command).toBe(\"features\");\n85:     expect(result.subcommand).toBe(\"add\");\n86:     expect(result.featureId).toBe(\"my-feat\");\n87:     expect(result.title).toBe(\"My Feature Title\");\n88:   });\n89: \n90:   test(\"parses features set-status with positional args\", () => {\n91:     const result = parseArgs(argv(\"features\", \"set-status\", \"my-feat\", \"done\"));\n92:     expect(result.command).toBe(\"features\");\n93:     expect(result.subcommand).toBe(\"set-status\");\n94:     expect(result.featureId).toBe(\"my-feat\");\n95:     expect(result.title).toBe(\"done\"); // title holds second positional\n96:   });\n97: \n98:   test(\"parses features show with feature ID\", () => {\n99:     const result = parseArgs(argv(\"features\", \"show\", \"my-feat\"));\n100:     expect(result.command).toBe(\"features\");\n101:     expect(result.subcommand).toBe(\"show\");\n102:     expect(result.featureId).toBe(\"my-feat\");\n103:   });\n104: \n105:   test(\"parses features check\", () => {\n106:     const result = parseArgs(argv(\"features\", \"check\"));\n107:     expect(result.command).toBe(\"features\");\n108:     expect(result.subcommand).toBe(\"check\");\n109:   });\n110: \n111:   test(\"parses features archive with --dry-run\", () => {\n112:     const result = parseArgs(argv(\"features\", \"archive\", \"--dry-run\"));\n113:     expect(result.command).toBe(\"features\");\n114:     expect(result.subcommand).toBe(\"archive\");\n115:     expect(result.dryRun).toBe(true);\n116:   });\n117: \n118:   test(\"parses features graph with options\", () => {\n119:     const result = parseArgs(argv(\"features\", \"graph\", \"--ascii\", \"--subtasks\"));\n120:     expect(result.command).toBe(\"features\");\n121:     expect(result.subcommand).toBe(\"graph\");\n122:     expect(result.ascii).toBe(true);\n123:     expect(result.graphSubtasks).toBe(true);\n124:   });\n125: });\n126: \n127: // ---------------------------------------------------------------------------\n128: // Selection options (launch)\n129: // ---------------------------------------------------------------------------\n130: \n131: describe(\"parseArgs — selection options\", () => {\n132:   test(\"parses --top-priority N\", () => {\n133:     const result = parseArgs(argv(\"launch\", \"--top-priority\", \"3\"));\n134:     expect(result.topPriority).toBe(3);\n135:   });\n136: \n137:   test(\"parses --quickest-wins N\", () => {\n138:     const result = parseArgs(argv(\"launch\", \"--quickest-wins\", \"5\"));\n139:     expect(result.quickestWins).toBe(5);\n140:   });\n141: \n142:   test(\"parses --priority level\", () => {\n143:     const result = parseArgs(argv(\"launch\", \"--priority\", \"high\"));\n144:     expect(result.priority).toBe(\"high\");\n145:   });\n146: \n147:   test(\"parses --difficulty level\", () => {\n148:     const result = parseArgs(argv(\"launch\", \"--difficulty\", \"easy\"));\n149:     expect(result.difficulty).toBe(\"easy\");\n150:   });\n151: \n152:   test(\"parses --features as comma-separated list\", () => {\n153:     const result = parseArgs(argv(\"launch\", \"--features\", \"feat-a,feat-b,feat-c\"));\n154:     expect(result.features).toEqual([\"feat-a\", \"feat-b\", \"feat-c\"]);\n155:   });\n156: \n157:   test(\"trims whitespace in --features list\", () => {\n158:     const result = parseArgs(argv(\"launch\", \"--features\", \"feat-a, feat-b , feat-c\"));\n159:     expect(result.features).toEqual([\"feat-a\", \"feat-b\", \"feat-c\"]);\n160:   });\n161: \n162:   test(\"parses --all-ready boolean flag\", () => {\n163:     const result = parseArgs(argv(\"launch\", \"--all-ready\"));\n164:     expect(result.allReady).toBe(true);\n165:   });\n166: });\n167: \n168: // ---------------------------------------------------------------------------\n169: // Launch / runtime options\n170: // ---------------------------------------------------------------------------\n171: \n172: describe(\"parseArgs — runtime options\", () => {\n173:   test(\"parses --max-concurrent N\", () => {\n174:     const result = parseArgs(argv(\"launch\", \"--max-concurrent\", \"4\"));\n175:     expect(result.maxConcurrent).toBe(4);\n176:   });\n177: \n178:   test(\"parses --model\", () => {\n179:     const result = parseArgs(argv(\"launch\", \"--model\", \"anthropic/claude-sonnet-4-20250514\"));\n180:     expect(result.model).toBe(\"anthropic/claude-sonnet-4-20250514\");\n181:   });\n182: \n183:   test(\"parses -m as alias for --model\", () => {\n184:     const result = parseArgs(argv(\"launch\", \"-m\", \"gpt-4\"));\n185:     expect(result.model).toBe(\"gpt-4\");\n186:   });\n187: \n188:   test(\"parses --interactive boolean flag\", () => {\n189:     const result = parseArgs(argv(\"launch\", \"--interactive\"));\n190:     expect(result.interactive).toBe(true);\n191:   });\n192: \n193:   test(\"parses --dry-run boolean flag\", () => {\n194:     const result = parseArgs(argv(\"launch\", \"--dry-run\"));\n195:     expect(result.dryRun).toBe(true);\n196:   });\n197: \n198:   test(\"parses --no-tui boolean flag\", () => {\n199:     const result = parseArgs(argv(\"launch\", \"--no-tui\"));\n200:     expect(result.noTui).toBe(true);\n201:   });\n202: \n203:   test(\"parses --auto-push boolean flag\", () => {\n204:     const result = parseArgs(argv(\"launch\", \"--auto-push\"));\n205:     expect(result.autoPush).toBe(true);\n206:   });\n207: \n208:   test(\"parses --base-branch\", () => {\n209:     const result = parseArgs(argv(\"launch\", \"--base-branch\", \"develop\"));\n210:     expect(result.baseBranch).toBe(\"develop\");\n211:   });\n212: \n213:   test(\"parses --max-retries\", () => {\n214:     const result = parseArgs(argv(\"launch\", \"--max-retries\", \"5\"));\n215:     expect(result.maxRetries).toBe(5);\n216:   });\n217: });\n218: \n219: // ---------------------------------------------------------------------------\n220: // General flags\n221: // ---------------------------------------------------------------------------\n222: \n223: describe(\"parseArgs — general flags\", () => {\n224:   test(\"parses --force\", () => {\n225:     const result = parseArgs(argv(\"init\", \"--force\"));\n226:     expect(result.force).toBe(true);\n227:   });\n228: \n229:   test(\"parses --output json\", () => {\n230:     const result = parseArgs(argv(\"features\", \"list\", \"--output\", \"json\"));\n231:     expect(result.outputFmt).toBe(\"json\");\n232:   });\n233: \n234:   test(\"parses -o as alias for --output\", () => {\n235:     const result = parseArgs(argv(\"features\", \"list\", \"-o\", \"json\"));\n236:     expect(result.outputFmt).toBe(\"json\");\n237:   });\n238: \n239:   test(\"parses --check\", () => {\n240:     const result = parseArgs(argv(\"upgrade\", \"--check\"));\n241:     expect(result.checkOnly).toBe(true);\n242:   });\n243: });\n244: \n245: // ---------------------------------------------------------------------------\n246: // Default values\n247: // ---------------------------------------------------------------------------\n248: \n249: describe(\"parseArgs — default values\", () => {\n250:   test(\"interactive defaults to false\", () => {\n251:     const result = parseArgs(argv(\"launch\"));\n252:     expect(result.interactive).toBe(false);\n253:   });\n254: \n255:   test(\"dryRun defaults to false\", () => {\n256:     const result = parseArgs(argv(\"launch\"));\n257:     expect(result.dryRun).toBe(false);\n258:   });\n259: \n260:   test(\"noTui defaults to false\", () => {\n261:     const result = parseArgs(argv(\"launch\"));\n262:     expect(result.noTui).toBe(false);\n263:   });\n264: \n265:   test(\"autoPush defaults to false\", () => {\n266:     const result = parseArgs(argv(\"launch\"));\n267:     expect(result.autoPush).toBe(false);\n268:   });\n269: \n270:   test(\"force defaults to false\", () => {\n271:     const result = parseArgs(argv(\"init\"));\n272:     expect(result.force).toBe(false);\n273:   });\n274: \n275:   test(\"checkOnly defaults to false\", () => {\n276:     const result = parseArgs(argv(\"upgrade\"));\n277:     expect(result.checkOnly).toBe(false);\n278:   });\n279: \n280:   test(\"output format defaults to text\", () => {\n281:     const result = parseArgs(argv(\"features\", \"list\"));\n282:     expect(result.outputFmt).toBe(\"text\");\n283:   });\n284: });\n285: \n286: // ---------------------------------------------------------------------------\n287: // Edge cases: trailing flags, multiple flags, complex combinations\n288: // ---------------------------------------------------------------------------\n289: \n290: describe(\"parseArgs — edge cases\", () => {\n291:   test(\"handles multiple selection options combined\", () => {\n292:     const result = parseArgs(argv(\n293:       \"launch\",\n294:       \"--priority\", \"high\",\n295:       \"--max-concurrent\", \"2\",\n296:       \"--dry-run\",\n297:       \"--no-tui\"\n298:     ));\n299:     expect(result.command).toBe(\"launch\");\n300:     expect(result.priority).toBe(\"high\");\n301:     expect(result.maxConcurrent).toBe(2);\n302:     expect(result.dryRun).toBe(true);\n303:     expect(result.noTui).toBe(true);\n304:   });\n305: \n306:   test(\"handles positional args before flags\", () => {\n307:     const result = parseArgs(argv(\"retry\", \"my-feature\", \"--dry-run\"));\n308:     expect(result.command).toBe(\"retry\");\n309:     expect(result.featureId).toBe(\"my-feature\");\n310:     expect(result.dryRun).toBe(true);\n311:   });\n312: \n313:   test(\"handles features add with interleaved flags\", () => {\n314:     const result = parseArgs(argv(\n315:       \"features\", \"add\", \"new-feat\", \"New Feature\",\n316:       \"--priority\", \"critical\",\n317:       \"--difficulty\", \"hard\",\n318:       \"--effort\", \"P2D\",\n319:       \"--desc\", \"A detailed description\"\n320:     ));\n321:     expect(result.command).toBe(\"features\");\n322:     expect(result.subcommand).toBe(\"add\");\n323:     expect(result.featureId).toBe(\"new-feat\");\n324:     expect(result.title).toBe(\"New Feature\");\n325:     expect(result.priority).toBe(\"critical\");\n326:     expect(result.difficulty).toBe(\"hard\");\n327:     expect(result.effort).toBe(\"P2D\");\n328:     expect(result.description).toBe(\"A detailed description\");\n329:   });\n330: \n331:   test(\"handles --depends-on comma-separated list\", () => {\n332:     const result = parseArgs(argv(\n333:       \"features\", \"add\", \"new-feat\", \"New Feature\",\n334:       \"--depends-on\", \"feat-a,feat-b\"\n335:     ));\n336:     expect(result.dependsOn).toEqual([\"feat-a\", \"feat-b\"]);\n337:   });\n338: \n339:   test(\"handles --fields comma-separated list\", () => {\n340:     const result = parseArgs(argv(\n341:       \"features\", \"list\",\n342:       \"--fields\", \"id,status,priority\"\n343:     ));\n344:     expect(result.fields).toEqual([\"id\", \"status\", \"priority\"]);\n345:   });\n346: \n347:   test(\"unknown flags starting with -- are silently ignored\", () => {\n348:     const result = parseArgs(argv(\"launch\", \"--unknown-flag\", \"--dry-run\"));\n349:     expect(result.dryRun).toBe(true);\n350:     // Unknown flags don't crash, they're just ignored\n351:   });\n352: \n353:   test(\"unknown positional args after featureId and title are ignored\", () => {\n354:     const result = parseArgs(argv(\"features\", \"add\", \"id\", \"title\", \"extra-arg\"));\n355:     expect(result.featureId).toBe(\"id\");\n356:     expect(result.title).toBe(\"title\");\n357:   });\n358: \n359:   test(\"parses --status for features list filtering\", () => {\n360:     const result = parseArgs(argv(\"features\", \"list\", \"--status\", \"in_progress\"));\n361:     expect(result.status).toBe(\"in_progress\");\n362:   });\n363: \n364:   test(\"parses --ready for features list\", () => {\n365:     const result = parseArgs(argv(\"features\", \"list\", \"--ready\"));\n366:     expect(result.ready).toBe(true);\n367:   });\n368: \n369:   test(\"parses --include-archive for features list\", () => {\n370:     const result = parseArgs(argv(\"features\", \"list\", \"--include-archive\"));\n371:     expect(result.includeArchive).toBe(true);\n372:   });\n373: \n374:   test(\"parses --mermaid for features graph\", () => {\n375:     const result = parseArgs(argv(\"features\", \"graph\", \"--mermaid\"));\n376:     expect(result.mermaidRaw).toBe(true);\n377:   });\n378: \n379:   test(\"handles verify with optional feature ID\", () => {\n380:     const withId = parseArgs(argv(\"verify\", \"my-feature\"));\n381:     expect(withId.command).toBe(\"verify\");\n382:     expect(withId.featureId).toBe(\"my-feature\");\n383: \n384:     const withoutId = parseArgs(argv(\"verify\"));\n385:     expect(withoutId.command).toBe(\"verify\");\n386:     expect(withoutId.featureId).toBeUndefined();\n387:   });\n388: \n389:   test(\"handles merge with optional feature ID and flags\", () => {\n390:     const result = parseArgs(argv(\"merge\", \"my-feature\", \"--auto-push\", \"--dry-run\"));\n391:     expect(result.command).toBe(\"merge\");\n392:     expect(result.featureId).toBe(\"my-feature\");\n393:     expect(result.autoPush).toBe(true);\n394:     expect(result.dryRun).toBe(true);\n395:   });\n396: \n397:   test(\"NaN when --top-priority value is not a number\", () => {\n398:     const result = parseArgs(argv(\"launch\", \"--top-priority\", \"abc\"));\n399:     expect(result.topPriority).toBeNaN();\n400:   });\n401: \n402:   test(\"handles describe command with compound names\", () => {\n403:     const result = parseArgs(argv(\"describe\", \"features\", \"add\"));\n404:     expect(result.command).toBe(\"describe\");\n405:     expect(result.featureId).toBe(\"features\");\n406:     expect(result.title).toBe(\"add\");\n407:   });\n408: \n409:   test(\"handles upgrade with --version flag\", () => {\n410:     const result = parseArgs(argv(\"upgrade\", \"--version\", \"v0.1.0\"));\n411:     expect(result.command).toBe(\"upgrade\");\n412:     expect(result.version).toBe(\"v0.1.0\");\n413:   });\n414: });\n\n(End of file - total 414 lines)\n</content>","title":"tests/arg-parsing.test.ts","metadata":{"preview":"/**\n * arg-parsing.test.ts — Unit tests for CLI argument parsing.\n *\n * Coverage:\n *   - Basic command parsing\n *   - Features subcommand routing\n *   - Flag parsing (boolean flags, value flags)\n *   - Trailing flags after positional args\n *   - Missing values for value-expecting flags\n *   - Flag collisions and priority\n *   - Positional argument handling (featureId, title)\n *   - Edge cases: empty args, unknown flags, repeated flags\n */\n\nimport { describe, test, expect } from \"bun:test\";\nimport { parseArgs } from \"../src/index.js\";\n\n// Helper to simulate argv from CLI input. We need to prepend \"bun\" and \"script\"\n// since parseArgs does argv.slice(2).\nfunction argv(...args: string[]): string[] {","truncated":false,"loaded":[]},"time":{"start":1773435232289,"end":1773435232292}}}}
