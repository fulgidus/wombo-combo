{"type":"tool_use","timestamp":1773435232824,"sessionID":"ses_3170615c1ffe6qPm6NgPYs8fxK","part":{"id":"prt_ce8fa2098001waZxWvsC4g1VWU","sessionID":"ses_3170615c1ffe6qPm6NgPYs8fxK","messageID":"msg_ce8fa110d001Kpulkz0vZ5aBY4","type":"tool","callID":"toolu_vrtx_01QgPycAtnWxKALqoGRm8XeM","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-test-arg-parsing/tests/features.test.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-test-arg-parsing/tests/features.test.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * features.test.ts — Unit tests for tasks YAML parsing, validation,\n3:  * duration parsing, and dependency resolution.\n4:  *\n5:  * Coverage:\n6:  *   - loadFeatures with null tasks, empty arrays, valid data\n7:  *   - parseDurationMinutes for ISO 8601 durations\n8:  *   - formatDuration for human-readable output\n9:  *   - Dependency resolution (areDependenciesMet, getReadyFeatures)\n10:  *   - normalizeTask defaults\n11:  *   - createBlankFeature\n12:  *   - findFeatureById (recursive search)\n13:  *   - selectFeatures strategies\n14:  *   - YAML schema edge cases\n15:  */\n16: \n17: import { describe, test, expect, beforeEach, afterEach } from \"bun:test\";\n18: import { mkdtempSync, writeFileSync, rmSync, mkdirSync } from \"node:fs\";\n19: import { join } from \"node:path\";\n20: import { tmpdir } from \"node:os\";\n21: import type { WomboConfig } from \"../src/config.js\";\n22: import {\n23:   loadFeatures,\n24:   parseDurationMinutes,\n25:   formatDuration,\n26:   areDependenciesMet,\n27:   getReadyFeatures,\n28:   getDoneFeatureIds,\n29:   selectFeatures,\n30:   createBlankFeature,\n31:   findFeatureById,\n32:   allFeatureIds,\n33:   featureSummary,\n34:   PRIORITY_ORDER,\n35:   DIFFICULTY_ORDER,\n36: } from \"../src/lib/tasks.js\";\n37: import type {\n38:   Feature,\n39:   FeaturesFile,\n40:   Subtask,\n41:   Priority,\n42:   Difficulty,\n43: } from \"../src/lib/tasks.js\";\n44: \n45: // ---------------------------------------------------------------------------\n46: // Helpers\n47: // ---------------------------------------------------------------------------\n48: \n49: function makeConfig(overrides?: Partial<WomboConfig>): WomboConfig {\n50:   return {\n51:     tasksDir: \"tasks\",\n52:     archiveDir: \"archive\",\n53:     baseBranch: \"main\",\n54:     build: { command: \"bun run build\", timeout: 300_000, artifactDir: \"dist\" },\n55:     install: { command: \"bun install\", timeout: 120_000 },\n56:     git: {\n57:       branchPrefix: \"feature/\",\n58:       worktreePrefix: \"wombo-\",\n59:       remote: \"origin\",\n60:       mergeStrategy: \"--no-ff\",\n61:     },\n62:     agent: {\n63:       bin: null,\n64:       name: \"generalist-agent\",\n65:       configFiles: [],\n66:       tmuxPrefix: \"wombo\",\n67:       multiplexer: \"auto\",\n68:     },\n69:     portless: {\n70:       enabled: true,\n71:       bin: null,\n72:       proxyPort: 1355,\n73:       https: false,\n74:     },\n75:     backup: { maxBackups: 5 },\n76:     defaults: { maxConcurrent: 6, maxRetries: 2 },\n77:     browser: {\n78:       enabled: false,\n79:       bin: null,\n80:       headless: true,\n81:       testCommand: null,\n82:       launchTimeout: 30_000,\n83:       testTimeout: 60_000,\n84:       defaultViewport: { width: 1280, height: 720 },\n85:     },\n86:     agentRegistry: {\n87:       mode: \"auto\",\n88:       source: \"msitarzewski/agency-agents\",\n89:       cacheDir: \"agents-cache\",\n90:     },\n91:     ...overrides,\n92:   };\n93: }\n94: \n95: function makeFeature(overrides?: Partial<Feature>): Feature {\n96:   return {\n97:     id: \"test-feature\",\n98:     title: \"Test Feature\",\n99:     description: \"A test feature\",\n100:     status: \"backlog\",\n101:     completion: 0,\n102:     difficulty: \"medium\",\n103:     priority: \"medium\",\n104:     depends_on: [],\n105:     effort: \"PT1H\",\n106:     started_at: null,\n107:     ended_at: null,\n108:     constraints: [],\n109:     forbidden: [],\n110:     references: [],\n111:     notes: [],\n112:     subtasks: [],\n113:     ...overrides,\n114:   };\n115: }\n116: \n117: function makeFeaturesFile(\n118:   tasks: Feature[] = [],\n119:   archive: Feature[] = []\n120: ): FeaturesFile {\n121:   return {\n122:     version: \"1\",\n123:     meta: {\n124:       created_at: \"2025-01-01T00:00:00Z\",\n125:       updated_at: \"2025-01-01T00:00:00Z\",\n126:       project: \"test-project\",\n127:       generator: \"test\",\n128:       maintainer: \"tester\",\n129:     },\n130:     tasks,\n131:     archive,\n132:   };\n133: }\n134: \n135: /**\n136:  * Write a YAML string to the .wombo-combo/tasks.yml inside the given tmpDir.\n137:  * Also creates the .wombo-combo directory.\n138:  */\n139: function writeTasksYaml(dir: string, yaml: string): void {\n140:   mkdirSync(join(dir, \".wombo-combo\"), { recursive: true });\n141:   writeFileSync(join(dir, \".wombo-combo\", \"tasks.yml\"), yaml);\n142: }\n143: \n144: /**\n145:  * Write archive YAML to .wombo-combo/archive.yml.\n146:  */\n147: function writeArchiveYaml(dir: string, yaml: string): void {\n148:   mkdirSync(join(dir, \".wombo-combo\"), { recursive: true });\n149:   writeFileSync(join(dir, \".wombo-combo\", \"archive.yml\"), yaml);\n150: }\n151: \n152: let tmpDir: string;\n153: \n154: beforeEach(() => {\n155:   tmpDir = mkdtempSync(join(tmpdir(), \"wombo-test-features-\"));\n156: });\n157: \n158: afterEach(() => {\n159:   rmSync(tmpDir, { recursive: true, force: true });\n160: });\n161: \n162: // ---------------------------------------------------------------------------\n163: // ISO 8601 Duration Parsing\n164: // ---------------------------------------------------------------------------\n165: \n166: describe(\"parseDurationMinutes\", () => {\n167:   test(\"parses hours only\", () => {\n168:     expect(parseDurationMinutes(\"PT1H\")).toBe(60);\n169:     expect(parseDurationMinutes(\"PT2H\")).toBe(120);\n170:     expect(parseDurationMinutes(\"PT0H\")).toBe(0);\n171:   });\n172: \n173:   test(\"parses minutes only\", () => {\n174:     expect(parseDurationMinutes(\"PT30M\")).toBe(30);\n175:     expect(parseDurationMinutes(\"PT1M\")).toBe(1);\n176:     expect(parseDurationMinutes(\"PT90M\")).toBe(90);\n177:   });\n178: \n179:   test(\"parses days only\", () => {\n180:     expect(parseDurationMinutes(\"P1D\")).toBe(1440);\n181:     expect(parseDurationMinutes(\"P2D\")).toBe(2880);\n182:   });\n183: \n184:   test(\"parses combined durations\", () => {\n185:     expect(parseDurationMinutes(\"PT1H30M\")).toBe(90);\n186:     expect(parseDurationMinutes(\"P1DT4H\")).toBe(1680);\n187:     expect(parseDurationMinutes(\"P2DT4H\")).toBe(3120);\n188:     expect(parseDurationMinutes(\"P1DT2H30M\")).toBe(1590);\n189:   });\n190: \n191:   test(\"parses seconds (rounds up to minutes)\", () => {\n192:     expect(parseDurationMinutes(\"PT30S\")).toBe(1); // ceil(30/60) = 1\n193:     expect(parseDurationMinutes(\"PT60S\")).toBe(1); // ceil(60/60) = 1\n194:     expect(parseDurationMinutes(\"PT61S\")).toBe(2); // ceil(61/60) = 2\n195:     expect(parseDurationMinutes(\"PT1H30S\")).toBe(61); // 60 + ceil(30/60)\n196:   });\n197: \n198:   test(\"returns Infinity for unparseable strings\", () => {\n199:     expect(parseDurationMinutes(\"\")).toBe(Infinity);\n200:     expect(parseDurationMinutes(\"invalid\")).toBe(Infinity);\n201:     expect(parseDurationMinutes(\"1H\")).toBe(Infinity); // missing P\n202:     expect(parseDurationMinutes(\"hello world\")).toBe(Infinity);\n203:   });\n204: \n205:   test(\"handles edge case: PT alone parses as zero duration\", () => {\n206:     // \"PT\" matches the regex: P with T but all time groups are optional\n207:     expect(parseDurationMinutes(\"PT\")).toBe(0);\n208:   });\n209: \n210:   test(\"handles P alone (zero duration)\", () => {\n211:     // P with no components - the regex should handle this\n212:     const result = parseDurationMinutes(\"P\");\n213:     // P alone matches /^P(?:(\\d+)D)?(?:T(?:(\\d+)H)?(?:(\\d+)M)?(?:(\\d+)S)?)?$/\n214:     // All groups are undefined, defaults to 0\n215:     expect(result).toBe(0);\n216:   });\n217: });\n218: \n219: // ---------------------------------------------------------------------------\n220: // Duration Formatting\n221: // ---------------------------------------------------------------------------\n222: \n223: describe(\"formatDuration\", () => {\n224:   test(\"formats minutes only\", () => {\n225:     expect(formatDuration(30)).toBe(\"30m\");\n226:     expect(formatDuration(1)).toBe(\"1m\");\n227:     expect(formatDuration(59)).toBe(\"59m\");\n228:   });\n229: \n230:   test(\"formats hours only\", () => {\n231:     expect(formatDuration(60)).toBe(\"1h\");\n232:     expect(formatDuration(120)).toBe(\"2h\");\n233:   });\n234: \n235:   test(\"formats hours and minutes\", () => {\n236:     expect(formatDuration(90)).toBe(\"1h 30m\");\n237:     expect(formatDuration(150)).toBe(\"2h 30m\");\n238:   });\n239: \n240:   test(\"formats days\", () => {\n241:     expect(formatDuration(1440)).toBe(\"1d\");\n242:     expect(formatDuration(2880)).toBe(\"2d\");\n243:   });\n244: \n245:   test(\"formats days and hours\", () => {\n246:     expect(formatDuration(1500)).toBe(\"1d 1h\");\n247:     expect(formatDuration(1560)).toBe(\"1d 2h\");\n248:   });\n249: \n250:   test(\"formats days, hours, and minutes\", () => {\n251:     expect(formatDuration(1530)).toBe(\"1d 1h 30m\");\n252:   });\n253: \n254:   test(\"formats Infinity as unknown\", () => {\n255:     expect(formatDuration(Infinity)).toBe(\"unknown\");\n256:   });\n257: \n258:   test(\"formats zero\", () => {\n259:     expect(formatDuration(0)).toBe(\"0m\");\n260:   });\n261: });\n262: \n263: // ---------------------------------------------------------------------------\n264: // loadFeatures — YAML parsing edge cases\n265: // ---------------------------------------------------------------------------\n266: \n267: describe(\"loadFeatures\", () => {\n268:   const config = makeConfig();\n269: \n270:   test(\"loads valid tasks file\", () => {\n271:     const yaml = `\n272: version: \"1\"\n273: meta:\n274:   created_at: \"2025-01-01T00:00:00Z\"\n275:   updated_at: \"2025-01-01T00:00:00Z\"\n276:   project: test\n277:   generator: test\n278:   maintainer: tester\n279: tasks:\n280:   - id: feat-a\n281:     title: Feature A\n282:     description: Description of A\n283:     status: backlog\n284:     completion: 0\n285:     difficulty: medium\n286:     priority: high\n287:     depends_on: []\n288:     effort: PT2H\n289:     started_at: null\n290:     ended_at: null\n291:     constraints: []\n292:     forbidden: []\n293:     references: []\n294:     notes: []\n295:     subtasks: []\n296: `;\n297:     writeTasksYaml(tmpDir, yaml);\n298:     const data = loadFeatures(tmpDir, config);\n299:     expect(data.tasks).toHaveLength(1);\n300:     expect(data.tasks[0].id).toBe(\"feat-a\");\n301:     expect(data.tasks[0].priority).toBe(\"high\");\n302:     expect(data.archive).toHaveLength(0);\n303:   });\n304: \n305:   test(\"handles null tasks (empty YAML key)\", () => {\n306:     const yaml = `\n307: version: \"1\"\n308: meta:\n309:   created_at: \"2025-01-01T00:00:00Z\"\n310:   updated_at: \"2025-01-01T00:00:00Z\"\n311:   project: test\n312:   generator: test\n313:   maintainer: tester\n314: tasks:\n315: `;\n316:     writeTasksYaml(tmpDir, yaml);\n317:     const data = loadFeatures(tmpDir, config);\n318:     expect(data.tasks).toBeArray();\n319:     expect(data.tasks).toHaveLength(0);\n320:     expect(data.archive).toBeArray();\n321:     expect(data.archive).toHaveLength(0);\n322:   });\n323: \n324:   test(\"handles tasks with null depends_on and arrays\", () => {\n325:     const yaml = `\n326: version: \"1\"\n327: meta:\n328:   created_at: \"2025-01-01T00:00:00Z\"\n329:   updated_at: \"2025-01-01T00:00:00Z\"\n330:   project: test\n331:   generator: test\n332:   maintainer: tester\n333: tasks:\n334:   - id: feat-a\n335:     title: Feature A\n336:     description: \"\"\n337:     status: backlog\n338:     completion: 0\n339:     difficulty: medium\n340:     priority: medium\n341:     effort: PT1H\n342:     started_at: null\n343:     ended_at: null\n344: `;\n345:     writeTasksYaml(tmpDir, yaml);\n346:     const data = loadFeatures(tmpDir, config);\n347:     expect(data.tasks).toHaveLength(1);\n348:     // normalizeTask should default null arrays to []\n349:     const f = data.tasks[0];\n350:     expect(f.depends_on).toBeArray();\n351:     expect(f.depends_on).toHaveLength(0);\n352:     expect(f.constraints).toBeArray();\n353:     expect(f.forbidden).toBeArray();\n354:     expect(f.references).toBeArray();\n355:     expect(f.notes).toBeArray();\n356:     expect(f.subtasks).toBeArray();\n357:   });\n358: \n359:   test(\"handles nested subtasks normalization\", () => {\n360:     const yaml = `\n361: version: \"1\"\n362: meta:\n363:   created_at: \"2025-01-01T00:00:00Z\"\n364:   updated_at: \"2025-01-01T00:00:00Z\"\n365:   project: test\n366:   generator: test\n367:   maintainer: tester\n368: tasks:\n369:   - id: feat-a\n370:     title: Feature A\n371:     description: \"\"\n372:     status: backlog\n373:     completion: 0\n374:     difficulty: medium\n375:     priority: medium\n376:     effort: PT1H\n377:     started_at: null\n378:     ended_at: null\n379:     subtasks:\n380:       - id: sub-1\n381:         title: Subtask 1\n382:         description: \"\"\n383:         status: backlog\n384:         completion: 0\n385:         difficulty: easy\n386:         priority: medium\n387:         effort: PT30M\n388:         started_at: null\n389:         ended_at: null\n390: `;\n391:     writeTasksYaml(tmpDir, yaml);\n392:     const data = loadFeatures(tmpDir, config);\n393:     const subtask = data.tasks[0].subtasks[0];\n394:     expect(subtask.id).toBe(\"sub-1\");\n395:     expect(subtask.depends_on).toBeArray();\n396:     expect(subtask.constraints).toBeArray();\n397:     expect(subtask.subtasks).toBeArray();\n398:   });\n399: \n400:   test(\"throws on corrupted YAML\", () => {\n401:     writeTasksYaml(tmpDir, \"{{{{not valid yaml::::\");\n402:     expect(() => loadFeatures(tmpDir, config)).toThrow();\n403:   });\n404: \n405:   test(\"throws on missing file\", () => {\n406:     expect(() => loadFeatures(\"/nonexistent/path\", config)).toThrow();\n407:   });\n408: \n409:   test(\"handles custom tasks file path\", () => {\n410:     const customConfig = makeConfig({ tasksFile: \"custom-tasks.yml\" });\n411:     const yaml = `\n412: version: \"1\"\n413: meta:\n414:   created_at: \"2025-01-01T00:00:00Z\"\n415:   updated_at: \"2025-01-01T00:00:00Z\"\n416:   project: test\n417:   generator: test\n418:   maintainer: tester\n419: tasks: []\n420: `;\n421:     mkdirSync(join(tmpDir, \".wombo-combo\"), { recursive: true });\n422:     writeFileSync(join(tmpDir, \".wombo-combo\", \"custom-tasks.yml\"), yaml);\n423:     const data = loadFeatures(tmpDir, customConfig);\n424:     expect(data.tasks).toHaveLength(0);\n425:   });\n426: \n427:   test(\"supports legacy 'features' YAML key\", () => {\n428:     const yaml = `\n429: version: \"1\"\n430: meta:\n431:   created_at: \"2025-01-01T00:00:00Z\"\n432:   updated_at: \"2025-01-01T00:00:00Z\"\n433:   project: test\n434:   generator: test\n435:   maintainer: tester\n436: features:\n437:   - id: legacy-feat\n438:     title: Legacy Feature\n439:     description: Loaded via features key\n440:     status: backlog\n441:     completion: 0\n442:     difficulty: medium\n443:     priority: medium\n444:     depends_on: []\n445:     effort: PT1H\n446:     started_at: null\n447:     ended_at: null\n448:     constraints: []\n449:     forbidden: []\n450:     references: []\n451:     notes: []\n452:     subtasks: []\n453: `;\n454:     writeTasksYaml(tmpDir, yaml);\n455:     const data = loadFeatures(tmpDir, config);\n456:     expect(data.tasks).toHaveLength(1);\n457:     expect(data.tasks[0].id).toBe(\"legacy-feat\");\n458:   });\n459: });\n460: \n461: // ---------------------------------------------------------------------------\n462: // Dependency Resolution\n463: // ---------------------------------------------------------------------------\n464: \n465: describe(\"areDependenciesMet\", () => {\n466:   test(\"returns true when feature has no dependencies\", () => {\n467:     const feature = makeFeature({ depends_on: [] });\n468:     const doneIds = new Set<string>();\n469:     expect(areDependenciesMet(feature, doneIds)).toBe(true);\n470:   });\n471: \n472:   test(\"returns true when all dependencies are done\", () => {\n473:     const feature = makeFeature({ depends_on: [\"dep-a\", \"dep-b\"] });\n474:     const doneIds = new Set([\"dep-a\", \"dep-b\", \"dep-c\"]);\n475:     expect(areDependenciesMet(feature, doneIds)).toBe(true);\n476:   });\n477: \n478:   test(\"returns false when some dependencies are not done\", () => {\n479:     const feature = makeFeature({ depends_on: [\"dep-a\", \"dep-b\"] });\n480:     const doneIds = new Set([\"dep-a\"]);\n481:     expect(areDependenciesMet(feature, doneIds)).toBe(false);\n482:   });\n483: \n484:   test(\"returns false when no dependencies are done\", () => {\n485:     const feature = makeFeature({ depends_on: [\"dep-a\", \"dep-b\"] });\n486:     const doneIds = new Set<string>();\n487:     expect(areDependenciesMet(feature, doneIds)).toBe(false);\n488:   });\n489: });\n490: \n491: describe(\"getDoneFeatureIds\", () => {\n492:   test(\"identifies features with done status\", () => {\n493:     const data = makeFeaturesFile([\n494:       makeFeature({ id: \"feat-done\", status: \"done\", completion: 100 }),\n495:       makeFeature({ id: \"feat-wip\", status: \"in_progress\", completion: 50 }),\n496:     ]);\n497:     const doneIds = getDoneFeatureIds(data);\n498:     expect(doneIds.has(\"feat-done\")).toBe(true);\n499:     expect(doneIds.has(\"feat-wip\")).toBe(false);\n500:   });\n501: \n502:   test(\"identifies features with 100% completion as done\", () => {\n503:     const data = makeFeaturesFile([\n504:       makeFeature({\n505:         id: \"feat-complete\",\n506:         status: \"in_review\",\n507:         completion: 100,\n508:       }),\n509:     ]);\n510:     const doneIds = getDoneFeatureIds(data);\n511:     expect(doneIds.has(\"feat-complete\")).toBe(true);\n512:   });\n513: \n514:   test(\"includes archived features as done\", () => {\n515:     const data = makeFeaturesFile(\n516:       [],\n517:       [makeFeature({ id: \"archived-feat\", status: \"done\", completion: 100 })]\n518:     );\n519:     const doneIds = getDoneFeatureIds(data);\n520:     expect(doneIds.has(\"archived-feat\")).toBe(true);\n521:   });\n522: \n523:   test(\"includes done subtasks\", () => {\n524:     const data = makeFeaturesFile([\n525:       makeFeature({\n526:         id: \"parent\",\n527:         status: \"in_progress\",\n528:         subtasks: [\n529:           {\n530:             id: \"sub-done\",\n531:             title: \"Done sub\",\n532:             description: \"\",\n533:             status: \"done\",\n534:             completion: 100,\n535:             difficulty: \"easy\",\n536:             priority: \"medium\",\n537:             depends_on: [],\n538:             effort: \"PT30M\",\n539:             started_at: null,\n540:             ended_at: null,\n541:             constraints: [],\n542:             forbidden: [],\n543:             references: [],\n544:             notes: [],\n545:             subtasks: [],\n546:           },\n547:         ],\n548:       }),\n549:     ]);\n550:     const doneIds = getDoneFeatureIds(data);\n551:     expect(doneIds.has(\"sub-done\")).toBe(true);\n552:     expect(doneIds.has(\"parent\")).toBe(false);\n553:   });\n554: });\n555: \n556: describe(\"getReadyFeatures\", () => {\n557:   test(\"returns backlog features with deps met\", () => {\n558:     const data = makeFeaturesFile([\n559:       makeFeature({ id: \"ready\", status: \"backlog\", depends_on: [] }),\n560:       makeFeature({\n561:         id: \"blocked\",\n562:         status: \"backlog\",\n563:         depends_on: [\"not-done\"],\n564:       }),\n565:       makeFeature({ id: \"in-progress\", status: \"in_progress\" }),\n566:     ]);\n567:     const ready = getReadyFeatures(data);\n568:     expect(ready).toHaveLength(1);\n569:     expect(ready[0].id).toBe(\"ready\");\n570:   });\n571: \n572:   test(\"considers archived deps as met\", () => {\n573:     const data = makeFeaturesFile(\n574:       [\n575:         makeFeature({\n576:           id: \"waiting\",\n577:           status: \"backlog\",\n578:           depends_on: [\"archived-dep\"],\n579:         }),\n580:       ],\n581:       [\n582:         makeFeature({\n583:           id: \"archived-dep\",\n584:           status: \"done\",\n585:           completion: 100,\n586:         }),\n587:       ]\n588:     );\n589:     const ready = getReadyFeatures(data);\n590:     expect(ready).toHaveLength(1);\n591:     expect(ready[0].id).toBe(\"waiting\");\n592:   });\n593: \n594:   test(\"excludes features with non-zero completion\", () => {\n595:     const data = makeFeaturesFile([\n596:       makeFeature({ id: \"partial\", status: \"backlog\", completion: 50 }),\n597:     ]);\n598:     const ready = getReadyFeatures(data);\n599:     expect(ready).toHaveLength(0);\n600:   });\n601: \n602:   test(\"returns empty array when no features are ready\", () => {\n603:     const data = makeFeaturesFile([\n604:       makeFeature({\n605:         id: \"blocked\",\n606:         status: \"backlog\",\n607:         depends_on: [\"missing\"],\n608:       }),\n609:     ]);\n610:     const ready = getReadyFeatures(data);\n611:     expect(ready).toHaveLength(0);\n612:   });\n613: });\n614: \n615: // ---------------------------------------------------------------------------\n616: // selectFeatures strategies\n617: // ---------------------------------------------------------------------------\n618: \n619: describe(\"selectFeatures\", () => {\n620:   const highPriority = makeFeature({\n621:     id: \"high-pri\",\n622:     priority: \"high\",\n623:     effort: \"PT2H\",\n624:   });\n625:   const criticalSmall = makeFeature({\n626:     id: \"critical-small\",\n627:     priority: \"critical\",\n628:     effort: \"PT30M\",\n629:   });\n630:   const mediumLong = makeFeature({\n631:     id: \"medium-long\",\n632:     priority: \"medium\",\n633:     effort: \"P1D\",\n634:   });\n635:   const lowQuick = makeFeature({\n636:     id: \"low-quick\",\n637:     priority: \"low\",\n638:     effort: \"PT15M\",\n639:     difficulty: \"easy\",\n640:   });\n641: \n642:   const data = makeFeaturesFile([highPriority, criticalSmall, mediumLong, lowQuick]);\n643: \n644:   test(\"allReady returns all ready features sorted by priority\", () => {\n645:     const selected = selectFeatures(data, { allReady: true });\n646:     expect(selected).toHaveLength(4);\n647:     expect(selected[0].id).toBe(\"critical-small\");\n648:     expect(selected[1].id).toBe(\"high-pri\");\n649:   });\n650: \n651:   test(\"topPriority selects top N by priority\", () => {\n652:     const selected = selectFeatures(data, { topPriority: 2 });\n653:     expect(selected).toHaveLength(2);\n654:     expect(selected[0].id).toBe(\"critical-small\");\n655:     expect(selected[1].id).toBe(\"high-pri\");\n656:   });\n657: \n658:   test(\"quickestWins selects N lowest effort\", () => {\n659:     const selected = selectFeatures(data, { quickestWins: 2 });\n660:     expect(selected).toHaveLength(2);\n661:     // Sorted by effort: 15m, 30m, 2h, 1d\n662:     expect(selected[0].id).toBe(\"low-quick\");\n663:     expect(selected[1].id).toBe(\"critical-small\");\n664:   });\n665: \n666:   test(\"priority filter selects matching priority\", () => {\n667:     const selected = selectFeatures(data, { priority: \"high\" });\n668:     expect(selected).toHaveLength(1);\n669:     expect(selected[0].id).toBe(\"high-pri\");\n670:   });\n671: \n672:   test(\"difficulty filter selects matching difficulty\", () => {\n673:     const selected = selectFeatures(data, { difficulty: \"easy\" });\n674:     expect(selected).toHaveLength(1);\n675:     expect(selected[0].id).toBe(\"low-quick\");\n676:   });\n677: \n678:   test(\"featureIds selects specific features (backward compat)\", () => {\n679:     const selected = selectFeatures(data, {\n680:       featureIds: [\"high-pri\", \"low-quick\"],\n681:     });\n682:     expect(selected).toHaveLength(2);\n683:   });\n684: \n685:   test(\"featureIds with nonexistent IDs still returns valid ones\", () => {\n686:     const selected = selectFeatures(data, {\n687:       featureIds: [\"high-pri\", \"nonexistent\"],\n688:     });\n689:     expect(selected).toHaveLength(1);\n690:     expect(selected[0].id).toBe(\"high-pri\");\n691:   });\n692: \n693:   test(\"default returns all ready sorted by priority\", () => {\n694:     const selected = selectFeatures(data, {});\n695:     expect(selected).toHaveLength(4);\n696:     expect(selected[0].id).toBe(\"critical-small\");\n697:   });\n698: });\n699: \n700: // ---------------------------------------------------------------------------\n701: // createBlankFeature\n702: // ---------------------------------------------------------------------------\n703: \n704: describe(\"createBlankFeature\", () => {\n705:   test(\"creates feature with default values\", () => {\n706:     const f = createBlankFeature(\"my-feat\", \"My Feature\");\n707:     expect(f.id).toBe(\"my-feat\");\n708:     expect(f.title).toBe(\"My Feature\");\n709:     expect(f.status).toBe(\"backlog\");\n710:     expect(f.completion).toBe(0);\n711:     expect(f.difficulty).toBe(\"medium\");\n712:     expect(f.priority).toBe(\"medium\");\n713:     expect(f.effort).toBe(\"PT1H\");\n714:     expect(f.depends_on).toEqual([]);\n715:     expect(f.subtasks).toEqual([]);\n716:   });\n717: \n718:   test(\"creates feature with custom options\", () => {\n719:     const f = createBlankFeature(\"my-feat\", \"My Feature\", \"Description\", {\n720:       priority: \"critical\",\n721:       difficulty: \"hard\",\n722:       effort: \"P2D\",\n723:     });\n724:     expect(f.priority).toBe(\"critical\");\n725:     expect(f.difficulty).toBe(\"hard\");\n726:     expect(f.effort).toBe(\"P2D\");\n727:     expect(f.description).toBe(\"Description\");\n728:   });\n729: });\n730: \n731: // ---------------------------------------------------------------------------\n732: // findFeatureById\n733: // ---------------------------------------------------------------------------\n734: \n735: describe(\"findFeatureById\", () => {\n736:   test(\"finds top-level feature\", () => {\n737:     const data = makeFeaturesFile([makeFeature({ id: \"target\" })]);\n738:     const found = findFeatureById(data, \"target\");\n739:     expect(found).toBeDefined();\n740:     expect(found!.id).toBe(\"target\");\n741:   });\n742: \n743:   test(\"finds feature in archive\", () => {\n744:     const data = makeFeaturesFile(\n745:       [],\n746:       [makeFeature({ id: \"archived\" })]\n747:     );\n748:     const found = findFeatureById(data, \"archived\");\n749:     expect(found).toBeDefined();\n750:     expect(found!.id).toBe(\"archived\");\n751:   });\n752: \n753:   test(\"finds nested subtask\", () => {\n754:     const data = makeFeaturesFile([\n755:       makeFeature({\n756:         id: \"parent\",\n757:         subtasks: [\n758:           {\n759:             id: \"nested-sub\",\n760:             title: \"Nested\",\n761:             description: \"\",\n762:             status: \"backlog\",\n763:             completion: 0,\n764:             difficulty: \"easy\",\n765:             priority: \"medium\",\n766:             depends_on: [],\n767:             effort: \"PT30M\",\n768:             started_at: null,\n769:             ended_at: null,\n770:             constraints: [],\n771:             forbidden: [],\n772:             references: [],\n773:             notes: [],\n774:             subtasks: [],\n775:           },\n776:         ],\n777:       }),\n778:     ]);\n779:     const found = findFeatureById(data, \"nested-sub\");\n780:     expect(found).toBeDefined();\n781:     expect(found!.id).toBe(\"nested-sub\");\n782:   });\n783: \n784:   test(\"returns undefined for nonexistent ID\", () => {\n785:     const data = makeFeaturesFile([makeFeature({ id: \"exists\" })]);\n786:     const found = findFeatureById(data, \"nonexistent\");\n787:     expect(found).toBeUndefined();\n788:   });\n789: });\n790: \n791: // ---------------------------------------------------------------------------\n792: // allFeatureIds\n793: // ---------------------------------------------------------------------------\n794: \n795: describe(\"allFeatureIds\", () => {\n796:   test(\"collects all IDs including subtasks and archive\", () => {\n797:     const data = makeFeaturesFile(\n798:       [\n799:         makeFeature({\n800:           id: \"feat-a\",\n801:           subtasks: [\n802:             {\n803:               id: \"sub-1\",\n804:               title: \"Sub\",\n805:               description: \"\",\n806:               status: \"backlog\",\n807:               completion: 0,\n808:               difficulty: \"easy\",\n809:               priority: \"medium\",\n810:               depends_on: [],\n811:               effort: \"PT30M\",\n812:               started_at: null,\n813:               ended_at: null,\n814:               constraints: [],\n815:               forbidden: [],\n816:               references: [],\n817:               notes: [],\n818:               subtasks: [],\n819:             },\n820:           ],\n821:         }),\n822:       ],\n823:       [makeFeature({ id: \"archived\" })]\n824:     );\n825:     const ids = allFeatureIds(data);\n826:     expect(ids).toContain(\"feat-a\");\n827:     expect(ids).toContain(\"sub-1\");\n828:     expect(ids).toContain(\"archived\");\n829:   });\n830: });\n831: \n832: // ---------------------------------------------------------------------------\n833: // featureSummary\n834: // ---------------------------------------------------------------------------\n835: \n836: describe(\"featureSummary\", () => {\n837:   test(\"produces formatted summary string\", () => {\n838:     const f = makeFeature({\n839:       id: \"auth-flow\",\n840:       title: \"Auth Flow\",\n841:       priority: \"high\",\n842:       difficulty: \"medium\",\n843:       effort: \"PT2H\",\n844:     });\n845:     const summary = featureSummary(f);\n846:     expect(summary).toContain(\"[high/medium]\");\n847:     expect(summary).toContain(\"auth-flow\");\n848:     expect(summary).toContain(\"Auth Flow\");\n849:     expect(summary).toContain(\"2h\");\n850:   });\n851: });\n852: \n853: // ---------------------------------------------------------------------------\n854: // Priority and Difficulty orderings\n855: // ---------------------------------------------------------------------------\n856: \n857: describe(\"PRIORITY_ORDER\", () => {\n858:   test(\"critical < high < medium < low < wishlist\", () => {\n859:     expect(PRIORITY_ORDER.critical).toBeLessThan(PRIORITY_ORDER.high);\n860:     expect(PRIORITY_ORDER.high).toBeLessThan(PRIORITY_ORDER.medium);\n861:     expect(PRIORITY_ORDER.medium).toBeLessThan(PRIORITY_ORDER.low);\n862:     expect(PRIORITY_ORDER.low).toBeLessThan(PRIORITY_ORDER.wishlist);\n863:   });\n864: });\n865: \n866: describe(\"DIFFICULTY_ORDER\", () => {\n867:   test(\"trivial < easy < medium < hard < very_hard\", () => {\n868:     expect(DIFFICULTY_ORDER.trivial).toBeLessThan(DIFFICULTY_ORDER.easy);\n869:     expect(DIFFICULTY_ORDER.easy).toBeLessThan(DIFFICULTY_ORDER.medium);\n870:     expect(DIFFICULTY_ORDER.medium).toBeLessThan(DIFFICULTY_ORDER.hard);\n871:     expect(DIFFICULTY_ORDER.hard).toBeLessThan(DIFFICULTY_ORDER.very_hard);\n872:   });\n873: });\n\n(End of file - total 873 lines)\n</content>","title":"tests/features.test.ts","metadata":{"preview":"/**\n * features.test.ts — Unit tests for tasks YAML parsing, validation,\n * duration parsing, and dependency resolution.\n *\n * Coverage:\n *   - loadFeatures with null tasks, empty arrays, valid data\n *   - parseDurationMinutes for ISO 8601 durations\n *   - formatDuration for human-readable output\n *   - Dependency resolution (areDependenciesMet, getReadyFeatures)\n *   - normalizeTask defaults\n *   - createBlankFeature\n *   - findFeatureById (recursive search)\n *   - selectFeatures strategies\n *   - YAML schema edge cases\n */\n\nimport { describe, test, expect, beforeEach, afterEach } from \"bun:test\";\nimport { mkdtempSync, writeFileSync, rmSync, mkdirSync } from \"node:fs\";\nimport { join } from \"node:path\";\nimport { tmpdir } from \"node:os\";","truncated":false,"loaded":[]},"time":{"start":1773435232810,"end":1773435232821}}}}
