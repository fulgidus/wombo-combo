{"type":"tool_use","timestamp":1773435365106,"sessionID":"ses_3170615c1ffe6qPm6NgPYs8fxK","part":{"id":"prt_ce8fc25590015Ieu8Uo8Qdinq9","sessionID":"ses_3170615c1ffe6qPm6NgPYs8fxK","messageID":"msg_ce8fc194c001SNHuymHWgUt0N5","type":"tool","callID":"toolu_vrtx_01AeFhkrxUBiTkkFiKvpAjeL","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-test-arg-parsing/tests/arg-parsing.test.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-test-arg-parsing/tests/arg-parsing.test.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * arg-parsing.test.ts — Unit tests for CLI argument parsing.\n3:  *\n4:  * Coverage:\n5:  *   - Basic command parsing\n6:  *   - Features subcommand routing\n7:  *   - Flag parsing (boolean flags, value flags)\n8:  *   - Trailing flags after positional args\n9:  *   - Missing values for value-expecting flags\n10:  *   - Flag collisions and priority\n11:  *   - Positional argument handling (featureId, title)\n12:  *   - Edge cases: empty args, unknown flags, repeated flags\n13:  */\n14: \n15: import { describe, test, expect } from \"bun:test\";\n16: import { parseArgs } from \"../src/index.js\";\n17: \n18: // Helper to simulate argv from CLI input. We need to prepend \"bun\" and \"script\"\n19: // since parseArgs does argv.slice(2).\n20: function argv(...args: string[]): string[] {\n21:   return [\"bun\", \"script.ts\", ...args];\n22: }\n23: \n24: // ---------------------------------------------------------------------------\n25: // Basic command parsing\n26: // ---------------------------------------------------------------------------\n27: \n28: describe(\"parseArgs — basic commands\", () => {\n29:   test(\"parses help command\", () => {\n30:     const result = parseArgs(argv(\"help\"));\n31:     expect(result.command).toBe(\"help\");\n32:   });\n33: \n34:   test(\"defaults to help when no args given\", () => {\n35:     const result = parseArgs(argv());\n36:     expect(result.command).toBe(\"help\");\n37:   });\n38: \n39:   test(\"parses launch command\", () => {\n40:     const result = parseArgs(argv(\"launch\"));\n41:     expect(result.command).toBe(\"launch\");\n42:   });\n43: \n44:   test(\"parses status command\", () => {\n45:     const result = parseArgs(argv(\"status\"));\n46:     expect(result.command).toBe(\"status\");\n47:   });\n48: \n49:   test(\"parses cleanup command\", () => {\n50:     const result = parseArgs(argv(\"cleanup\"));\n51:     expect(result.command).toBe(\"cleanup\");\n52:   });\n53: \n54:   test(\"parses --version as command\", () => {\n55:     const result = parseArgs(argv(\"--version\"));\n56:     expect(result.command).toBe(\"--version\");\n57:   });\n58: \n59:   test(\"parses -V as command\", () => {\n60:     const result = parseArgs(argv(\"-V\"));\n61:     expect(result.command).toBe(\"-V\");\n62:   });\n63: });\n64: \n65: // ---------------------------------------------------------------------------\n66: // Features subcommand routing\n67: // ---------------------------------------------------------------------------\n68: \n69: describe(\"parseArgs — tasks subcommands\", () => {\n70:   test(\"defaults tasks subcommand to list\", () => {\n71:     const result = parseArgs(argv(\"tasks\"));\n72:     expect(result.command).toBe(\"tasks\");\n73:     expect(result.subcommand).toBe(\"list\");\n74:   });\n75: \n76:   test(\"parses tasks list\", () => {\n77:     const result = parseArgs(argv(\"tasks\", \"list\"));\n78:     expect(result.command).toBe(\"tasks\");\n79:     expect(result.subcommand).toBe(\"list\");\n80:   });\n81: \n82:   test(\"parses tasks add with positional args\", () => {\n83:     const result = parseArgs(argv(\"tasks\", \"add\", \"my-feat\", \"My Feature Title\"));\n84:     expect(result.command).toBe(\"tasks\");\n85:     expect(result.subcommand).toBe(\"add\");\n86:     expect(result.featureId).toBe(\"my-feat\");\n87:     expect(result.title).toBe(\"My Feature Title\");\n88:   });\n89: \n90:   test(\"parses tasks set-status with positional args\", () => {\n91:     const result = parseArgs(argv(\"tasks\", \"set-status\", \"my-feat\", \"done\"));\n92:     expect(result.command).toBe(\"tasks\");\n93:     expect(result.subcommand).toBe(\"set-status\");\n94:     expect(result.featureId).toBe(\"my-feat\");\n95:     expect(result.title).toBe(\"done\"); // title holds second positional\n96:   });\n97: \n98:   test(\"parses tasks show with feature ID\", () => {\n99:     const result = parseArgs(argv(\"tasks\", \"show\", \"my-feat\"));\n100:     expect(result.command).toBe(\"tasks\");\n101:     expect(result.subcommand).toBe(\"show\");\n102:     expect(result.featureId).toBe(\"my-feat\");\n103:   });\n104: \n105:   test(\"parses tasks check\", () => {\n106:     const result = parseArgs(argv(\"tasks\", \"check\"));\n107:     expect(result.command).toBe(\"tasks\");\n108:     expect(result.subcommand).toBe(\"check\");\n109:   });\n110: \n111:   test(\"parses tasks archive with --dry-run\", () => {\n112:     const result = parseArgs(argv(\"tasks\", \"archive\", \"--dry-run\"));\n113:     expect(result.command).toBe(\"tasks\");\n114:     expect(result.subcommand).toBe(\"archive\");\n115:     expect(result.dryRun).toBe(true);\n116:   });\n117: \n118:   test(\"parses tasks graph with options\", () => {\n119:     const result = parseArgs(argv(\"tasks\", \"graph\", \"--ascii\", \"--subtasks\"));\n120:     expect(result.command).toBe(\"tasks\");\n121:     expect(result.subcommand).toBe(\"graph\");\n122:     expect(result.ascii).toBe(true);\n123:     expect(result.graphSubtasks).toBe(true);\n124:   });\n125: \n126:   test(\"features alias resolves to tasks command\", () => {\n127:     const result = parseArgs(argv(\"features\"));\n128:     expect(result.command).toBe(\"tasks\");\n129:     expect(result.subcommand).toBe(\"list\");\n130:   });\n131: \n132:   test(\"features alias with subcommand resolves correctly\", () => {\n133:     const result = parseArgs(argv(\"features\", \"add\", \"my-feat\", \"My Title\"));\n134:     expect(result.command).toBe(\"tasks\");\n135:     expect(result.subcommand).toBe(\"add\");\n136:     expect(result.featureId).toBe(\"my-feat\");\n137:     expect(result.title).toBe(\"My Title\");\n138:   });\n139: });\n140: \n141: // ---------------------------------------------------------------------------\n142: // Selection options (launch)\n143: // ---------------------------------------------------------------------------\n144: \n145: describe(\"parseArgs — selection options\", () => {\n146:   test(\"parses --top-priority N\", () => {\n147:     const result = parseArgs(argv(\"launch\", \"--top-priority\", \"3\"));\n148:     expect(result.topPriority).toBe(3);\n149:   });\n150: \n151:   test(\"parses --quickest-wins N\", () => {\n152:     const result = parseArgs(argv(\"launch\", \"--quickest-wins\", \"5\"));\n153:     expect(result.quickestWins).toBe(5);\n154:   });\n155: \n156:   test(\"parses --priority level\", () => {\n157:     const result = parseArgs(argv(\"launch\", \"--priority\", \"high\"));\n158:     expect(result.priority).toBe(\"high\");\n159:   });\n160: \n161:   test(\"parses --difficulty level\", () => {\n162:     const result = parseArgs(argv(\"launch\", \"--difficulty\", \"easy\"));\n163:     expect(result.difficulty).toBe(\"easy\");\n164:   });\n165: \n166:   test(\"parses --features as comma-separated list (stored in tasks)\", () => {\n167:     const result = parseArgs(argv(\"launch\", \"--features\", \"feat-a,feat-b,feat-c\"));\n168:     expect(result.tasks).toEqual([\"feat-a\", \"feat-b\", \"feat-c\"]);\n169:   });\n170: \n171:   test(\"parses --tasks as comma-separated list\", () => {\n172:     const result = parseArgs(argv(\"launch\", \"--tasks\", \"feat-a,feat-b,feat-c\"));\n173:     expect(result.tasks).toEqual([\"feat-a\", \"feat-b\", \"feat-c\"]);\n174:   });\n175: \n176:   test(\"trims whitespace in --features list\", () => {\n177:     const result = parseArgs(argv(\"launch\", \"--features\", \"feat-a, feat-b , feat-c\"));\n178:     expect(result.tasks).toEqual([\"feat-a\", \"feat-b\", \"feat-c\"]);\n179:   });\n180: \n181:   test(\"parses --all-ready boolean flag\", () => {\n182:     const result = parseArgs(argv(\"launch\", \"--all-ready\"));\n183:     expect(result.allReady).toBe(true);\n184:   });\n185: });\n186: \n187: // ---------------------------------------------------------------------------\n188: // Launch / runtime options\n189: // ---------------------------------------------------------------------------\n190: \n191: describe(\"parseArgs — runtime options\", () => {\n192:   test(\"parses --max-concurrent N\", () => {\n193:     const result = parseArgs(argv(\"launch\", \"--max-concurrent\", \"4\"));\n194:     expect(result.maxConcurrent).toBe(4);\n195:   });\n196: \n197:   test(\"parses --model\", () => {\n198:     const result = parseArgs(argv(\"launch\", \"--model\", \"anthropic/claude-sonnet-4-20250514\"));\n199:     expect(result.model).toBe(\"anthropic/claude-sonnet-4-20250514\");\n200:   });\n201: \n202:   test(\"parses -m as alias for --model\", () => {\n203:     const result = parseArgs(argv(\"launch\", \"-m\", \"gpt-4\"));\n204:     expect(result.model).toBe(\"gpt-4\");\n205:   });\n206: \n207:   test(\"parses --interactive boolean flag\", () => {\n208:     const result = parseArgs(argv(\"launch\", \"--interactive\"));\n209:     expect(result.interactive).toBe(true);\n210:   });\n211: \n212:   test(\"parses --dry-run boolean flag\", () => {\n213:     const result = parseArgs(argv(\"launch\", \"--dry-run\"));\n214:     expect(result.dryRun).toBe(true);\n215:   });\n216: \n217:   test(\"parses --no-tui boolean flag\", () => {\n218:     const result = parseArgs(argv(\"launch\", \"--no-tui\"));\n219:     expect(result.noTui).toBe(true);\n220:   });\n221: \n222:   test(\"parses --auto-push boolean flag\", () => {\n223:     const result = parseArgs(argv(\"launch\", \"--auto-push\"));\n224:     expect(result.autoPush).toBe(true);\n225:   });\n226: \n227:   test(\"parses --base-branch\", () => {\n228:     const result = parseArgs(argv(\"launch\", \"--base-branch\", \"develop\"));\n229:     expect(result.baseBranch).toBe(\"develop\");\n230:   });\n231: \n232:   test(\"parses --max-retries\", () => {\n233:     const result = parseArgs(argv(\"launch\", \"--max-retries\", \"5\"));\n234:     expect(result.maxRetries).toBe(5);\n235:   });\n236: });\n237: \n238: // ---------------------------------------------------------------------------\n239: // General flags\n240: // ---------------------------------------------------------------------------\n241: \n242: describe(\"parseArgs — general flags\", () => {\n243:   test(\"parses --force\", () => {\n244:     const result = parseArgs(argv(\"init\", \"--force\"));\n245:     expect(result.force).toBe(true);\n246:   });\n247: \n248:   test(\"parses --output json\", () => {\n249:     const result = parseArgs(argv(\"features\", \"list\", \"--output\", \"json\"));\n250:     expect(result.outputFmt).toBe(\"json\");\n251:   });\n252: \n253:   test(\"parses -o as alias for --output\", () => {\n254:     const result = parseArgs(argv(\"features\", \"list\", \"-o\", \"json\"));\n255:     expect(result.outputFmt).toBe(\"json\");\n256:   });\n257: \n258:   test(\"parses --check\", () => {\n259:     const result = parseArgs(argv(\"upgrade\", \"--check\"));\n260:     expect(result.checkOnly).toBe(true);\n261:   });\n262: });\n263: \n264: // ---------------------------------------------------------------------------\n265: // Default values\n266: // ---------------------------------------------------------------------------\n267: \n268: describe(\"parseArgs — default values\", () => {\n269:   test(\"interactive defaults to false\", () => {\n270:     const result = parseArgs(argv(\"launch\"));\n271:     expect(result.interactive).toBe(false);\n272:   });\n273: \n274:   test(\"dryRun defaults to false\", () => {\n275:     const result = parseArgs(argv(\"launch\"));\n276:     expect(result.dryRun).toBe(false);\n277:   });\n278: \n279:   test(\"noTui defaults to false\", () => {\n280:     const result = parseArgs(argv(\"launch\"));\n281:     expect(result.noTui).toBe(false);\n282:   });\n283: \n284:   test(\"autoPush defaults to false\", () => {\n285:     const result = parseArgs(argv(\"launch\"));\n286:     expect(result.autoPush).toBe(false);\n287:   });\n288: \n289:   test(\"force defaults to false\", () => {\n290:     const result = parseArgs(argv(\"init\"));\n291:     expect(result.force).toBe(false);\n292:   });\n293: \n294:   test(\"checkOnly defaults to false\", () => {\n295:     const result = parseArgs(argv(\"upgrade\"));\n296:     expect(result.checkOnly).toBe(false);\n297:   });\n298: \n299:   test(\"output format defaults to text\", () => {\n300:     const result = parseArgs(argv(\"features\", \"list\"));\n301:     expect(result.outputFmt).toBe(\"text\");\n302:   });\n303: });\n304: \n305: // ---------------------------------------------------------------------------\n306: // Edge cases: trailing flags, multiple flags, complex combinations\n307: // ---------------------------------------------------------------------------\n308: \n309: describe(\"parseArgs — edge cases\", () => {\n310:   test(\"handles multiple selection options combined\", () => {\n311:     const result = parseArgs(argv(\n312:       \"launch\",\n313:       \"--priority\", \"high\",\n314:       \"--max-concurrent\", \"2\",\n315:       \"--dry-run\",\n316:       \"--no-tui\"\n317:     ));\n318:     expect(result.command).toBe(\"launch\");\n319:     expect(result.priority).toBe(\"high\");\n320:     expect(result.maxConcurrent).toBe(2);\n321:     expect(result.dryRun).toBe(true);\n322:     expect(result.noTui).toBe(true);\n323:   });\n324: \n325:   test(\"handles positional args before flags\", () => {\n326:     const result = parseArgs(argv(\"retry\", \"my-feature\", \"--dry-run\"));\n327:     expect(result.command).toBe(\"retry\");\n328:     expect(result.featureId).toBe(\"my-feature\");\n329:     expect(result.dryRun).toBe(true);\n330:   });\n331: \n332:   test(\"handles tasks add with interleaved flags\", () => {\n333:     const result = parseArgs(argv(\n334:       \"tasks\", \"add\", \"new-feat\", \"New Feature\",\n335:       \"--priority\", \"critical\",\n336:       \"--difficulty\", \"hard\",\n337:       \"--effort\", \"P2D\",\n338:       \"--desc\", \"A detailed description\"\n339:     ));\n340:     expect(result.command).toBe(\"tasks\");\n341:     expect(result.subcommand).toBe(\"add\");\n342:     expect(result.featureId).toBe(\"new-feat\");\n343:     expect(result.title).toBe(\"New Feature\");\n344:     expect(result.priority).toBe(\"critical\");\n345:     expect(result.difficulty).toBe(\"hard\");\n346:     expect(result.effort).toBe(\"P2D\");\n347:     expect(result.description).toBe(\"A detailed description\");\n348:   });\n349: \n350:   test(\"handles --depends-on comma-separated list\", () => {\n351:     const result = parseArgs(argv(\n352:       \"features\", \"add\", \"new-feat\", \"New Feature\",\n353:       \"--depends-on\", \"feat-a,feat-b\"\n354:     ));\n355:     expect(result.dependsOn).toEqual([\"feat-a\", \"feat-b\"]);\n356:   });\n357: \n358:   test(\"handles --fields comma-separated list\", () => {\n359:     const result = parseArgs(argv(\n360:       \"features\", \"list\",\n361:       \"--fields\", \"id,status,priority\"\n362:     ));\n363:     expect(result.fields).toEqual([\"id\", \"status\", \"priority\"]);\n364:   });\n365: \n366:   test(\"unknown flags starting with -- are silently ignored\", () => {\n367:     const result = parseArgs(argv(\"launch\", \"--unknown-flag\", \"--dry-run\"));\n368:     expect(result.dryRun).toBe(true);\n369:     // Unknown flags don't crash, they're just ignored\n370:   });\n371: \n372:   test(\"unknown positional args after featureId and title are ignored\", () => {\n373:     const result = parseArgs(argv(\"features\", \"add\", \"id\", \"title\", \"extra-arg\"));\n374:     expect(result.featureId).toBe(\"id\");\n375:     expect(result.title).toBe(\"title\");\n376:   });\n377: \n378:   test(\"parses --status for features list filtering\", () => {\n379:     const result = parseArgs(argv(\"features\", \"list\", \"--status\", \"in_progress\"));\n380:     expect(result.status).toBe(\"in_progress\");\n381:   });\n382: \n383:   test(\"parses --ready for features list\", () => {\n384:     const result = parseArgs(argv(\"features\", \"list\", \"--ready\"));\n385:     expect(result.ready).toBe(true);\n386:   });\n387: \n388:   test(\"parses --include-archive for features list\", () => {\n389:     const result = parseArgs(argv(\"features\", \"list\", \"--include-archive\"));\n390:     expect(result.includeArchive).toBe(true);\n391:   });\n392: \n393:   test(\"parses --mermaid for features graph\", () => {\n394:     const result = parseArgs(argv(\"features\", \"graph\", \"--mermaid\"));\n395:     expect(result.mermaidRaw).toBe(true);\n396:   });\n397: \n398:   test(\"handles verify with optional feature ID\", () => {\n399:     const withId = parseArgs(argv(\"verify\", \"my-feature\"));\n400:     expect(withId.command).toBe(\"verify\");\n401:     expect(withId.featureId).toBe(\"my-feature\");\n402: \n403:     const withoutId = parseArgs(argv(\"verify\"));\n404:     expect(withoutId.command).toBe(\"verify\");\n405:     expect(withoutId.featureId).toBeUndefined();\n406:   });\n407: \n408:   test(\"handles merge with optional feature ID and flags\", () => {\n409:     const result = parseArgs(argv(\"merge\", \"my-feature\", \"--auto-push\", \"--dry-run\"));\n410:     expect(result.command).toBe(\"merge\");\n411:     expect(result.featureId).toBe(\"my-feature\");\n412:     expect(result.autoPush).toBe(true);\n413:     expect(result.dryRun).toBe(true);\n414:   });\n415: \n416:   test(\"NaN when --top-priority value is not a number\", () => {\n417:     const result = parseArgs(argv(\"launch\", \"--top-priority\", \"abc\"));\n418:     expect(result.topPriority).toBeNaN();\n419:   });\n420: \n421:   test(\"handles describe command with compound names\", () => {\n422:     const result = parseArgs(argv(\"describe\", \"features\", \"add\"));\n423:     expect(result.command).toBe(\"describe\");\n424:     expect(result.featureId).toBe(\"features\");\n425:     expect(result.title).toBe(\"add\");\n426:   });\n427: \n428:   test(\"handles upgrade with --tag flag\", () => {\n429:     const result = parseArgs(argv(\"upgrade\", \"--tag\", \"v0.1.0\"));\n430:     expect(result.command).toBe(\"upgrade\");\n431:     expect(result.tag).toBe(\"v0.1.0\");\n432:   });\n433: });\n\n(End of file - total 433 lines)\n</content>","title":"tests/arg-parsing.test.ts","metadata":{"preview":"/**\n * arg-parsing.test.ts — Unit tests for CLI argument parsing.\n *\n * Coverage:\n *   - Basic command parsing\n *   - Features subcommand routing\n *   - Flag parsing (boolean flags, value flags)\n *   - Trailing flags after positional args\n *   - Missing values for value-expecting flags\n *   - Flag collisions and priority\n *   - Positional argument handling (featureId, title)\n *   - Edge cases: empty args, unknown flags, repeated flags\n */\n\nimport { describe, test, expect } from \"bun:test\";\nimport { parseArgs } from \"../src/index.js\";\n\n// Helper to simulate argv from CLI input. We need to prepend \"bun\" and \"script\"\n// since parseArgs does argv.slice(2).\nfunction argv(...args: string[]): string[] {","truncated":false,"loaded":[]},"time":{"start":1773435365103,"end":1773435365105}}}}
