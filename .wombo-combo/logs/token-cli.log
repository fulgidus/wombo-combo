{"type":"tool_use","timestamp":1773483377100,"sessionID":"ses_314277d05ffehFsuzTPHpcve3c","part":{"id":"prt_cebd8bfc5001oBx1JXo8D2tFaj","sessionID":"ses_314277d05ffehFsuzTPHpcve3c","messageID":"msg_cebd8b04e001wvLO8betCaQuDk","type":"tool","callID":"toolu_vrtx_01Lck8Di1DregTTkkLFtDmiz","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/token-cli/src/commands/history.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/token-cli/src/commands/history.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * history.ts — View wave history and summaries.\n3:  *\n4:  * Usage:\n5:  *   woco history                    List all past waves\n6:  *   woco history <wave-id>          Show details of a specific wave\n7:  *   woco history --output json      Output as JSON\n8:  *\n9:  * Wave history is stored in .wombo-combo/history/<wave-id>.json and survives\n10:  * `woco cleanup`. Records are auto-exported when a wave completes.\n11:  */\n12: \n13: import type { WomboConfig } from \"../config.js\";\n14: import {\n15:   listHistory,\n16:   loadHistory,\n17:   type WaveHistoryRecord,\n18: } from \"../lib/history.js\";\n19: import { output, outputError, type OutputFormat } from \"../lib/output.js\";\n20: import { renderHistoryList, renderHistoryDetail } from \"../lib/toon.js\";\n21: \n22: // ---------------------------------------------------------------------------\n23: // Types\n24: // ---------------------------------------------------------------------------\n25: \n26: export interface HistoryCommandOptions {\n27:   projectRoot: string;\n28:   config: WomboConfig;\n29:   /** Specific wave ID to show details for */\n30:   waveId?: string;\n31:   /** Output format */\n32:   outputFmt: OutputFormat;\n33: }\n34: \n35: // ---------------------------------------------------------------------------\n36: // Formatting Helpers\n37: // ---------------------------------------------------------------------------\n38: \n39: const RESET = \"\\x1b[0m\";\n40: const BOLD = \"\\x1b[1m\";\n41: const DIM = \"\\x1b[2m\";\n42: const FG = {\n43:   red: \"\\x1b[31m\",\n44:   green: \"\\x1b[32m\",\n45:   yellow: \"\\x1b[33m\",\n46:   blue: \"\\x1b[34m\",\n47:   magenta: \"\\x1b[35m\",\n48:   cyan: \"\\x1b[36m\",\n49:   gray: \"\\x1b[90m\",\n50: };\n51: \n52: function pad(text: string, width: number): string {\n53:   if (text.length >= width) return text.slice(0, width);\n54:   return text + \" \".repeat(width - text.length);\n55: }\n56: \n57: function padLeft(text: string, width: number): string {\n58:   if (text.length >= width) return text.slice(0, width);\n59:   return \" \".repeat(width - text.length) + text;\n60: }\n61: \n62: function formatDurationMs(ms: number | null): string {\n63:   if (ms === null || ms === 0) return \"-\";\n64:   const seconds = Math.floor(ms / 1000);\n65:   if (seconds < 60) return `${seconds}s`;\n66:   const minutes = Math.floor(seconds / 60);\n67:   if (minutes < 60) return `${minutes}m ${seconds % 60}s`;\n68:   const hours = Math.floor(minutes / 60);\n69:   return `${hours}h ${minutes % 60}m`;\n70: }\n71: \n72: function formatDate(iso: string): string {\n73:   try {\n74:     const d = new Date(iso);\n75:     return d.toLocaleDateString(\"en-US\", {\n76:       year: \"numeric\",\n77:       month: \"short\",\n78:       day: \"numeric\",\n79:       hour: \"2-digit\",\n80:       minute: \"2-digit\",\n81:     });\n82:   } catch {\n83:     return iso;\n84:   }\n85: }\n86: \n87: function statusColor(status: string): string {\n88:   switch (status) {\n89:     case \"merged\":\n90:       return FG.magenta;\n91:     case \"verified\":\n92:       return FG.green;\n93:     case \"failed\":\n94:       return FG.red;\n95:     case \"completed\":\n96:       return FG.yellow;\n97:     default:\n98:       return FG.gray;\n99:   }\n100: }\n101: \n102: // ---------------------------------------------------------------------------\n103: // List All Waves\n104: // ---------------------------------------------------------------------------\n105: \n106: function renderWaveList(records: WaveHistoryRecord[]): void {\n107:   if (records.length === 0) {\n108:     console.log(\"\\nNo wave history found.\");\n109:     console.log(\"History is auto-exported when a wave completes.\\n\");\n110:     return;\n111:   }\n112: \n113:   console.log(\"\");\n114:   console.log(`${BOLD}Wave History (${records.length} wave(s)):${RESET}`);\n115:   console.log(\"\");\n116: \n117:   const header = [\n118:     pad(\"Wave ID\", 24),\n119:     pad(\"Date\", 22),\n120:     padLeft(\"Total\", 6),\n121:     padLeft(\"OK\", 4),\n122:     padLeft(\"Fail\", 5),\n123:     padLeft(\"Merged\", 7),\n124:     padLeft(\"Retries\", 8),\n125:     padLeft(\"Duration\", 10),\n126:   ].join(\" \");\n127: \n128:   console.log(`${BOLD}${header}${RESET}`);\n129:   console.log(\"-\".repeat(90));\n130: \n131:   for (const rec of records) {\n132:     const s = rec.summary;\n133:     const okColor = s.succeeded === s.total ? FG.green : FG.yellow;\n134:     const failColor = s.failed > 0 ? FG.red : FG.gray;\n135: \n136:     const row = [\n137:       pad(rec.wave_id, 24),\n138:       pad(formatDate(rec.started_at), 22),\n139:       padLeft(String(s.total), 6),\n140:       `${okColor}${padLeft(String(s.succeeded), 4)}${RESET}`,\n141:       `${failColor}${padLeft(String(s.failed), 5)}${RESET}`,\n142:       padLeft(String(s.merged), 7),\n143:       padLeft(String(s.total_retries), 8),\n144:       padLeft(formatDurationMs(s.total_duration_ms), 10),\n145:     ].join(\" \");\n146: \n147:     console.log(row);\n148:   }\n149: \n150:   console.log(\"\");\n151:   console.log(`${DIM}Use 'woco history <wave-id>' for details.${RESET}`);\n152:   console.log(\"\");\n153: }\n154: \n155: // ---------------------------------------------------------------------------\n156: // Show Single Wave Details\n157: // ---------------------------------------------------------------------------\n158: \n159: function renderWaveDetails(rec: WaveHistoryRecord): void {\n160:   console.log(\"\");\n161:   console.log(`${BOLD}Wave: ${rec.wave_id}${RESET}`);\n162:   console.log(`${DIM}Base: ${rec.base_branch} | Concurrency: ${rec.max_concurrent} | Mode: ${rec.interactive ? \"interactive\" : \"headless\"}${RESET}`);\n163:   if (rec.model) {\n164:     console.log(`${DIM}Model: ${rec.model}${RESET}`);\n165:   }\n166:   console.log(`${DIM}Started: ${formatDate(rec.started_at)} | Exported: ${formatDate(rec.exported_at)}${RESET}`);\n167:   console.log(\"\");\n168: \n169:   // Summary\n170:   const s = rec.summary;\n171:   console.log(`${BOLD}Summary:${RESET}`);\n172:   console.log(`  Total agents:    ${s.total}`);\n173:   console.log(`  Succeeded:       ${FG.green}${s.succeeded}${RESET}`);\n174:   console.log(`  Failed:          ${s.failed > 0 ? FG.red : FG.gray}${s.failed}${RESET}`);\n175:   console.log(`  Merged:          ${FG.magenta}${s.merged}${RESET}`);\n176:   console.log(`  Verified:        ${FG.green}${s.verified}${RESET}`);\n177:   console.log(`  Total retries:   ${s.total_retries}`);\n178:   console.log(`  Total duration:  ${formatDurationMs(s.total_duration_ms)}`);\n179:   console.log(\"\");\n180: \n181:   // Agent table\n182:   console.log(`${BOLD}Agents:${RESET}`);\n183:   console.log(\"\");\n184: \n185:   const header = [\n186:     pad(\"Feature\", 30),\n187:     pad(\"Status\", 12),\n188:     padLeft(\"Retries\", 8),\n189:     padLeft(\"Duration\", 10),\n190:     pad(\"Build\", 6),\n191:     pad(\"Conflict\", 9),\n192:     pad(\"Error\", 30),\n193:   ].join(\" \");\n194: \n195:   console.log(`${BOLD}${header}${RESET}`);\n196:   console.log(\"-\".repeat(109));\n197: \n198:   for (const agent of rec.agents) {\n199:     const color = statusColor(agent.status);\n200:     const buildStr = agent.build_passed === true\n201:       ? `${FG.green}pass${RESET}`\n202:       : agent.build_passed === false\n203:         ? `${FG.red}fail${RESET}`\n204:         : `${FG.gray}-${RESET}`;\n205:     const conflictStr = agent.had_merge_conflict\n206:       ? `${FG.yellow}yes${RESET}`\n207:       : `${FG.gray}no${RESET}`;\n208:     const errorStr = agent.error\n209:       ? agent.error.split(\"\\n\")[0].slice(0, 28)\n210:       : \"-\";\n211: \n212:     const row = [\n213:       pad(agent.feature_id, 30),\n214:       `${color}${pad(agent.status, 12)}${RESET}`,\n215:       padLeft(\n216:         agent.retries > 0 ? `${agent.retries}/${agent.max_retries}` : \"-\",\n217:         8\n218:       ),\n219:       padLeft(formatDurationMs(agent.duration_ms), 10),\n220:       pad(buildStr, 6),\n221:       pad(conflictStr, 9),\n222:       pad(errorStr, 30),\n223:     ].join(\" \");\n224: \n225:     console.log(row);\n226:   }\n227: \n228:   console.log(\"\");\n229: }\n230: \n231: // ---------------------------------------------------------------------------\n232: // Command\n233: // ---------------------------------------------------------------------------\n234: \n235: export async function cmdHistory(opts: HistoryCommandOptions): Promise<void> {\n236:   const { projectRoot, outputFmt } = opts;\n237: \n238:   if (opts.waveId) {\n239:     // Show details for a specific wave\n240:     const record = loadHistory(projectRoot, opts.waveId);\n241:     if (!record) {\n242:       outputError(\n243:         outputFmt,\n244:         `Wave history not found: ${opts.waveId}. Use 'woco history' to list available waves.`\n245:       );\n246:       return; // unreachable — helps TypeScript narrow\n247:     }\n248: \n249:     output(outputFmt, record, () => {\n250:       renderWaveDetails(record);\n251:     }, () => {\n252:       // TOON renderer\n253:       console.log(renderHistoryDetail(record));\n254:     });\n255:   } else {\n256:     // List all waves\n257:     const records = listHistory(projectRoot);\n258: \n259:     output(outputFmt, records, () => {\n260:       renderWaveList(records);\n261:     }, () => {\n262:       // TOON renderer\n263:       console.log(renderHistoryList(records));\n264:     });\n265:   }\n266: }\n\n(End of file - total 266 lines)\n</content>","title":"src/commands/history.ts","metadata":{"preview":"/**\n * history.ts — View wave history and summaries.\n *\n * Usage:\n *   woco history                    List all past waves\n *   woco history <wave-id>          Show details of a specific wave\n *   woco history --output json      Output as JSON\n *\n * Wave history is stored in .wombo-combo/history/<wave-id>.json and survives\n * `woco cleanup`. Records are auto-exported when a wave completes.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport {\n  listHistory,\n  loadHistory,\n  type WaveHistoryRecord,\n} from \"../lib/history.js\";\nimport { output, outputError, type OutputFormat } from \"../lib/output.js\";\nimport { renderHistoryList, renderHistoryDetail } from \"../lib/toon.js\";","truncated":false,"loaded":[]},"time":{"start":1773483377096,"end":1773483377099}}}}
