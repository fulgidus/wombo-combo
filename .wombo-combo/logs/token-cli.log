{"type":"tool_use","timestamp":1773483387386,"sessionID":"ses_314277d05ffehFsuzTPHpcve3c","part":{"id":"prt_cebd8e6160015XSi8OERgAVtUk","sessionID":"ses_314277d05ffehFsuzTPHpcve3c","messageID":"msg_cebd8d7de0016Mo0SVToJ5dOfs","type":"tool","callID":"toolu_vrtx_01H1BjfWoTUPSmj7NqNJFaMC","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/token-cli/src/commands/completion.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/token-cli/src/commands/completion.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * completion.ts — Shell completion script generator for wombo-combo.\n3:  *\n4:  * Generates native completion scripts for bash, zsh, and fish.\n5:  *\n6:  * Install:\n7:  *   eval \"$(woco completion bash)\"                          # add to ~/.bashrc\n8:  *   eval \"$(woco completion zsh)\"                           # add to ~/.zshrc\n9:  *   woco completion fish | source                           # fish\n10:  *   woco completion fish > ~/.config/fish/completions/woco.fish  # persist\n11:  */\n12: \n13: import { basename } from \"node:path\";\n14: \n15: // ---------------------------------------------------------------------------\n16: // Public API\n17: // ---------------------------------------------------------------------------\n18: \n19: export function cmdCompletion({ shell }: { shell?: string }): void {\n20:   const resolved = shell ?? detectShell();\n21: \n22:   switch (resolved) {\n23:     case \"bash\":\n24:       process.stdout.write(bashScript());\n25:       break;\n26:     case \"zsh\":\n27:       process.stdout.write(zshScript());\n28:       break;\n29:     case \"fish\":\n30:       process.stdout.write(fishScript());\n31:       break;\n32:     default:\n33:       console.error(`Unsupported shell: \"${resolved}\"`);\n34:       console.error(\"Supported shells: bash, zsh, fish\");\n35:       console.error(\"\");\n36:       console.error(\"Install completions:\");\n37:       console.error('  eval \"$(woco completion bash)\"    # Bash: add to ~/.bashrc');\n38:       console.error('  eval \"$(woco completion zsh)\"     # Zsh:  add to ~/.zshrc');\n39:       console.error(\"  woco completion fish | source     # Fish\");\n40:       process.exit(1);\n41:   }\n42: }\n43: \n44: // ---------------------------------------------------------------------------\n45: // Shell detection\n46: // ---------------------------------------------------------------------------\n47: \n48: function detectShell(): string {\n49:   const shellPath = process.env.SHELL || \"\";\n50:   const name = basename(shellPath);\n51:   if (name === \"bash\" || name === \"zsh\" || name === \"fish\") return name;\n52:   return \"bash\"; // safe default\n53: }\n54: \n55: // ---------------------------------------------------------------------------\n56: // Bash completion\n57: // ---------------------------------------------------------------------------\n58: \n59: function bashScript(): string {\n60:   return `# woco (wombo-combo) bash completion\n61: # Generated by: woco completion bash\n62: # Install: eval \"$(woco completion bash)\"  — add to ~/.bashrc\n63: \n64: _woco_completions() {\n65:     local cur prev cmd subcmd i j\n66:     cur=\"\\${COMP_WORDS[COMP_CWORD]}\"\n67:     prev=\"\\${COMP_WORDS[COMP_CWORD-1]}\"\n68:     cmd=\"\"\n69:     subcmd=\"\"\n70: \n71:     # Find the main command (first non-flag arg after woco)\n72:     for ((i=1; i < COMP_CWORD; i++)); do\n73:         if [[ \"\\${COMP_WORDS[i]}\" != -* ]]; then\n74:             cmd=\"\\${COMP_WORDS[i]}\"\n75:             break\n76:         fi\n77:     done\n78: \n79:     # Resolve top-level aliases\n80:     case \"$cmd\" in\n81:         i) cmd=\"init\" ;; l) cmd=\"launch\" ;; r) cmd=\"resume\" ;;\n82:         s) cmd=\"status\" ;; v) cmd=\"verify\" ;; m) cmd=\"merge\" ;;\n83:         re) cmd=\"retry\" ;; a) cmd=\"abort\" ;; c) cmd=\"cleanup\" ;;\n84:         h) cmd=\"history\" ;; lo) cmd=\"logs\" ;; t|features) cmd=\"tasks\" ;;\n85:         u) cmd=\"upgrade\" ;; d) cmd=\"describe\" ;; comp) cmd=\"completion\" ;;\n86:     esac\n87: \n88:     # Flag value completions (context-independent)\n89:     case \"$prev\" in\n90:         --priority)\n91:             COMPREPLY=($(compgen -W \"critical high medium low wishlist\" -- \"$cur\")); return ;;\n92:         --difficulty)\n93:             COMPREPLY=($(compgen -W \"trivial easy medium hard very_hard\" -- \"$cur\")); return ;;\n94:         --status)\n95:             COMPREPLY=($(compgen -W \"backlog planned in_progress blocked in_review done cancelled\" -- \"$cur\")); return ;;\n96:         --output|-o)\n97:             COMPREPLY=($(compgen -W \"text json toon\" -- \"$cur\")); return ;;\n98:         --model|-m|--top-priority|--quickest-wins|--max-concurrent|--max-retries|--tail|--base-branch|--tag|--release|--tasks|--features|--fields|--desc|--description|--effort|--depends-on|--title)\n99:             return ;;  # free-form / numeric — no completions, let readline handle it\n100:     esac\n101: \n102:     # No command yet → complete commands\n103:     if [[ -z \"$cmd\" ]]; then\n104:         COMPREPLY=($(compgen -W \"init i launch l resume r status s verify v merge m retry re abort a cleanup c history h logs lo tasks t upgrade u describe d completion comp version help\" -- \"$cur\"))\n105:         return\n106:     fi\n107: \n108:     # tasks / t → subcommands\n109:     if [[ \"$cmd\" == \"tasks\" ]]; then\n110:         # Find the subcommand\n111:         for ((j=i+1; j < COMP_CWORD; j++)); do\n112:             if [[ \"\\${COMP_WORDS[j]}\" != -* ]]; then\n113:                 subcmd=\"\\${COMP_WORDS[j]}\"\n114:                 break\n115:             fi\n116:         done\n117: \n118:         # Resolve subcommand aliases\n119:         case \"$subcmd\" in\n120:             ls) subcmd=\"list\" ;; a) subcmd=\"add\" ;; ss) subcmd=\"set-status\" ;;\n121:             sp) subcmd=\"set-priority\" ;; sd) subcmd=\"set-difficulty\" ;;\n122:             ch|validate) subcmd=\"check\" ;; ar) subcmd=\"archive\" ;;\n123:             sh) subcmd=\"show\" ;; g) subcmd=\"graph\" ;;\n124:         esac\n125: \n126:         # No subcommand yet → complete subcommands\n127:         if [[ -z \"$subcmd\" ]]; then\n128:             COMPREPLY=($(compgen -W \"list ls add a set-status ss set-priority sp set-difficulty sd check ch validate archive ar show sh graph g help\" -- \"$cur\"))\n129:             return\n130:         fi\n131: \n132:         # Flags per tasks subcommand\n133:         case \"$subcmd\" in\n134:             list)\n135:                 COMPREPLY=($(compgen -W \"--status --priority --difficulty --ready --include-archive --output -o --fields\" -- \"$cur\")) ;;\n136:             add)\n137:                 COMPREPLY=($(compgen -W \"--desc --description --priority --difficulty --effort --depends-on --dry-run --output -o\" -- \"$cur\")) ;;\n138:             set-status|set-priority|set-difficulty)\n139:                 COMPREPLY=($(compgen -W \"--output -o --dry-run\" -- \"$cur\")) ;;\n140:             archive)\n141:                 COMPREPLY=($(compgen -W \"--dry-run --output -o\" -- \"$cur\")) ;;\n142:             show)\n143:                 COMPREPLY=($(compgen -W \"--output -o --fields\" -- \"$cur\")) ;;\n144:             graph)\n145:                 COMPREPLY=($(compgen -W \"--ascii --mermaid --subtasks --status --output -o\" -- \"$cur\")) ;;\n146:         esac\n147:         return\n148:     fi\n149: \n150:     # completion → shell names\n151:     if [[ \"$cmd\" == \"completion\" ]]; then\n152:         COMPREPLY=($(compgen -W \"bash zsh fish\" -- \"$cur\"))\n153:         return\n154:     fi\n155: \n156:     # describe → command names (for introspection)\n157:     if [[ \"$cmd\" == \"describe\" ]]; then\n158:         COMPREPLY=($(compgen -W \"init launch resume status verify merge retry abort cleanup history logs tasks upgrade describe completion version help\" -- \"$cur\"))\n159:         return\n160:     fi\n161: \n162:     # Flags per top-level command\n163:     case \"$cmd\" in\n164:         init)\n165:             COMPREPLY=($(compgen -W \"--force\" -- \"$cur\")) ;;\n166:         launch)\n167:             COMPREPLY=($(compgen -W \"--top-priority --quickest-wins --priority --difficulty --tasks --features --all-ready --max-concurrent --model -m --interactive --no-tui --auto-push --base-branch --max-retries --browser --dry-run --output -o --force\" -- \"$cur\")) ;;\n168:         resume)\n169:             COMPREPLY=($(compgen -W \"--max-concurrent --model -m --interactive --no-tui --auto-push --base-branch --max-retries\" -- \"$cur\")) ;;\n170:         status)\n171:             COMPREPLY=($(compgen -W \"--output -o\" -- \"$cur\")) ;;\n172:         verify)\n173:             COMPREPLY=($(compgen -W \"--model -m --max-retries --browser\" -- \"$cur\")) ;;\n174:         merge)\n175:             COMPREPLY=($(compgen -W \"--auto-push --dry-run --model -m\" -- \"$cur\")) ;;\n176:         retry)\n177:             COMPREPLY=($(compgen -W \"--model -m --interactive --dry-run\" -- \"$cur\")) ;;\n178:         abort)\n179:             COMPREPLY=($(compgen -W \"--requeue --output -o\" -- \"$cur\")) ;;\n180:         cleanup)\n181:             COMPREPLY=($(compgen -W \"--dry-run\" -- \"$cur\")) ;;\n182:         history)\n183:             COMPREPLY=($(compgen -W \"--output -o\" -- \"$cur\")) ;;\n184:         logs)\n185:             COMPREPLY=($(compgen -W \"--tail --follow -f --output -o\" -- \"$cur\")) ;;\n186:         upgrade)\n187:             COMPREPLY=($(compgen -W \"--check --tag --release --force\" -- \"$cur\")) ;;\n188:     esac\n189: }\n190: \n191: complete -o default -F _woco_completions woco\n192: `;\n193: }\n194: \n195: // ---------------------------------------------------------------------------\n196: // Zsh completion\n197: // ---------------------------------------------------------------------------\n198: \n199: function zshScript(): string {\n200:   return `#compdef woco\n201: # woco (wombo-combo) zsh completion\n202: # Generated by: woco completion zsh\n203: # Install: eval \"$(woco completion zsh)\"  — add to ~/.zshrc\n204: \n205: _woco() {\n206:     local cmd subcmd\n207: \n208:     # Position 2 → completing the main command\n209:     if (( CURRENT == 2 )); then\n210:         local -a cmds\n211:         cmds=(\n212:             'init:Generate .wombo-combo/config.json (i)'\n213:             'i:→ init'\n214:             'launch:Launch a wave of agents (l)'\n215:             'l:→ launch'\n216:             'resume:Resume a stopped wave (r)'\n217:             'r:→ resume'\n218:             'status:Show wave status (s)'\n219:             's:→ status'\n220:             'verify:Run build verification (v)'\n221:             'v:→ verify'\n222:             'merge:Merge verified branches (m)'\n223:             'm:→ merge'\n224:             'retry:Retry a failed agent (re)'\n225:             're:→ retry'\n226:             'abort:Kill a running agent (a)'\n227:             'a:→ abort'\n228:             'cleanup:Remove worktrees and sessions (c)'\n229:             'c:→ cleanup'\n230:             'history:List/view past waves (h)'\n231:             'h:→ history'\n232:             'logs:Pretty-print agent logs (lo)'\n233:             'lo:→ logs'\n234:             'tasks:Manage tasks file (t)'\n235:             't:→ tasks'\n236:             'upgrade:Check for updates (u)'\n237:             'u:→ upgrade'\n238:             'describe:Emit JSON schema (d)'\n239:             'd:→ describe'\n240:             'completion:Generate shell completions (comp)'\n241:             'comp:→ completion'\n242:             'version:Print version'\n243:             'help:Show help'\n244:         )\n245:         _describe 'command' cmds\n246:         return\n247:     fi\n248: \n249:     cmd=\"\\${words[2]}\"\n250: \n251:     # Resolve top-level aliases\n252:     case \"$cmd\" in\n253:         i) cmd=init ;; l) cmd=launch ;; r) cmd=resume ;;\n254:         s) cmd=status ;; v) cmd=verify ;; m) cmd=merge ;;\n255:         re) cmd=retry ;; a) cmd=abort ;; c) cmd=cleanup ;;\n256:         h) cmd=history ;; lo) cmd=logs ;; t|features) cmd=tasks ;;\n257:         u) cmd=upgrade ;; d) cmd=describe ;; comp) cmd=completion ;;\n258:     esac\n259: \n260:     # Flag value completions\n261:     case \"\\${words[CURRENT-1]}\" in\n262:         --priority)    compadd critical high medium low wishlist; return ;;\n263:         --difficulty)  compadd trivial easy medium hard very_hard; return ;;\n264:         --status)      compadd backlog planned in_progress blocked in_review done cancelled; return ;;\n265:         --output|-o)   compadd text json toon; return ;;\n266:     esac\n267: \n268:     # tasks → subcommands\n269:     if [[ \"$cmd\" == \"tasks\" ]]; then\n270:         if (( CURRENT == 3 )); then\n271:             local -a subcmds\n272:             subcmds=(\n273:                 'list:List tasks (ls)'\n274:                 'ls:→ list'\n275:                 'add:Add a new task (a)'\n276:                 'a:→ add'\n277:                 'set-status:Change task status (ss)'\n278:                 'ss:→ set-status'\n279:                 'set-priority:Change task priority (sp)'\n280:                 'sp:→ set-priority'\n281:                 'set-difficulty:Change task difficulty (sd)'\n282:                 'sd:→ set-difficulty'\n283:                 'check:Validate tasks file (ch)'\n284:                 'ch:→ check'\n285:                 'validate:→ check'\n286:                 'archive:Move done/cancelled to archive (ar)'\n287:                 'ar:→ archive'\n288:                 'show:Show task details (sh)'\n289:                 'sh:→ show'\n290:                 'graph:Visualize dependency graph (g)'\n291:                 'g:→ graph'\n292:                 'help:Show help'\n293:             )\n294:             _describe 'subcommand' subcmds\n295:             return\n296:         fi\n297: \n298:         subcmd=\"\\${words[3]}\"\n299:         case \"$subcmd\" in\n300:             ls) subcmd=list ;; a) subcmd=add ;; ss) subcmd=set-status ;;\n301:             sp) subcmd=set-priority ;; sd) subcmd=set-difficulty ;;\n302:             ch|validate) subcmd=check ;; ar) subcmd=archive ;;\n303:             sh) subcmd=show ;; g) subcmd=graph ;;\n304:         esac\n305: \n306:         case \"$subcmd\" in\n307:             list)\n308:                 compadd -- --status --priority --difficulty --ready --include-archive --output -o --fields ;;\n309:             add)\n310:                 compadd -- --desc --description --priority --difficulty --effort --depends-on --dry-run --output -o ;;\n311:             set-status|set-priority|set-difficulty)\n312:                 compadd -- --output -o --dry-run ;;\n313:             archive)\n314:                 compadd -- --dry-run --output -o ;;\n315:             show)\n316:                 compadd -- --output -o --fields ;;\n317:             graph)\n318:                 compadd -- --ascii --mermaid --subtasks --status --output -o ;;\n319:         esac\n320:         return\n321:     fi\n322: \n323:     # completion → shell names\n324:     if [[ \"$cmd\" == \"completion\" ]]; then\n325:         if (( CURRENT == 3 )); then\n326:             compadd bash zsh fish\n327:         fi\n328:         return\n329:     fi\n330: \n331:     # describe → command names\n332:     if [[ \"$cmd\" == \"describe\" ]]; then\n333:         compadd -- init launch resume status verify merge retry abort cleanup history logs tasks upgrade describe completion version help\n334:         return\n335:     fi\n336: \n337:     # Flags per command\n338:     case \"$cmd\" in\n339:         init)     compadd -- --force ;;\n340:         launch)   compadd -- --top-priority --quickest-wins --priority --difficulty --tasks --features --all-ready --max-concurrent --model -m --interactive --no-tui --auto-push --base-branch --max-retries --browser --dry-run --output -o --force ;;\n341:         resume)   compadd -- --max-concurrent --model -m --interactive --no-tui --auto-push --base-branch --max-retries ;;\n342:         status)   compadd -- --output -o ;;\n343:         verify)   compadd -- --model -m --max-retries --browser ;;\n344:         merge)    compadd -- --auto-push --dry-run --model -m ;;\n345:         retry)    compadd -- --model -m --interactive --dry-run ;;\n346:         abort)    compadd -- --requeue --output -o ;;\n347:         cleanup)  compadd -- --dry-run ;;\n348:         history)  compadd -- --output -o ;;\n349:         logs)     compadd -- --tail --follow -f --output -o ;;\n350:         upgrade)  compadd -- --check --tag --release --force ;;\n351:     esac\n352: }\n353: \n354: compdef _woco woco\n355: `;\n356: }\n357: \n358: // ---------------------------------------------------------------------------\n359: // Fish completion\n360: // ---------------------------------------------------------------------------\n361: \n362: function fishScript(): string {\n363:   return `# woco (wombo-combo) fish completion\n364: # Generated by: woco completion fish\n365: # Install: woco completion fish | source\n366: # Persist: woco completion fish > ~/.config/fish/completions/woco.fish\n367: \n368: # Helper: true when the tasks/t/features subcommand has a specific sub-subcommand\n369: function __woco_tasks_subcmd\n370:     set -l tokens (commandline -opc)\n371:     if test (count $tokens) -ge 3\n372:         switch $tokens[2]\n373:             case tasks t features\n374:                 for sub in $argv\n375:                     if test \"$tokens[3]\" = \"$sub\"\n376:                         return 0\n377:                     end\n378:                 end\n379:         end\n380:     end\n381:     return 1\n382: end\n383: \n384: # Helper: true when we need a tasks subcommand (exactly: woco tasks <cursor>)\n385: function __woco_needs_tasks_subcmd\n386:     set -l tokens (commandline -opc)\n387:     if test (count $tokens) -eq 2\n388:         switch $tokens[2]\n389:             case tasks t features\n390:                 return 0\n391:         end\n392:     end\n393:     return 1\n394: end\n395: \n396: # Disable file completions by default\n397: for cmd in woco\n398:     complete -c $cmd -f\n399: \n400:     # --- Top-level commands ---\n401:     complete -c $cmd -n '__fish_use_subcommand' -a 'init'       -d 'Generate config'\n402:     complete -c $cmd -n '__fish_use_subcommand' -a 'i'          -d '→ init'\n403:     complete -c $cmd -n '__fish_use_subcommand' -a 'launch'     -d 'Launch agents'\n404:     complete -c $cmd -n '__fish_use_subcommand' -a 'l'          -d '→ launch'\n405:     complete -c $cmd -n '__fish_use_subcommand' -a 'resume'     -d 'Resume wave'\n406:     complete -c $cmd -n '__fish_use_subcommand' -a 'r'          -d '→ resume'\n407:     complete -c $cmd -n '__fish_use_subcommand' -a 'status'     -d 'Show wave status'\n408:     complete -c $cmd -n '__fish_use_subcommand' -a 's'          -d '→ status'\n409:     complete -c $cmd -n '__fish_use_subcommand' -a 'verify'     -d 'Build verification'\n410:     complete -c $cmd -n '__fish_use_subcommand' -a 'v'          -d '→ verify'\n411:     complete -c $cmd -n '__fish_use_subcommand' -a 'merge'      -d 'Merge branches'\n412:     complete -c $cmd -n '__fish_use_subcommand' -a 'm'          -d '→ merge'\n413:     complete -c $cmd -n '__fish_use_subcommand' -a 'retry'      -d 'Retry failed agent'\n414:     complete -c $cmd -n '__fish_use_subcommand' -a 're'         -d '→ retry'\n415:     complete -c $cmd -n '__fish_use_subcommand' -a 'abort'      -d 'Kill running agent'\n416:     complete -c $cmd -n '__fish_use_subcommand' -a 'a'          -d '→ abort'\n417:     complete -c $cmd -n '__fish_use_subcommand' -a 'cleanup'    -d 'Remove worktrees'\n418:     complete -c $cmd -n '__fish_use_subcommand' -a 'c'          -d '→ cleanup'\n419:     complete -c $cmd -n '__fish_use_subcommand' -a 'history'    -d 'View past waves'\n420:     complete -c $cmd -n '__fish_use_subcommand' -a 'h'          -d '→ history'\n421:     complete -c $cmd -n '__fish_use_subcommand' -a 'logs'       -d 'Agent logs'\n422:     complete -c $cmd -n '__fish_use_subcommand' -a 'lo'         -d '→ logs'\n423:     complete -c $cmd -n '__fish_use_subcommand' -a 'tasks'      -d 'Manage tasks'\n424:     complete -c $cmd -n '__fish_use_subcommand' -a 't'          -d '→ tasks'\n425:     complete -c $cmd -n '__fish_use_subcommand' -a 'upgrade'    -d 'Check for updates'\n426:     complete -c $cmd -n '__fish_use_subcommand' -a 'u'          -d '→ upgrade'\n427:     complete -c $cmd -n '__fish_use_subcommand' -a 'describe'   -d 'Emit JSON schema'\n428:     complete -c $cmd -n '__fish_use_subcommand' -a 'd'          -d '→ describe'\n429:     complete -c $cmd -n '__fish_use_subcommand' -a 'completion' -d 'Shell completions'\n430:     complete -c $cmd -n '__fish_use_subcommand' -a 'comp'       -d '→ completion'\n431:     complete -c $cmd -n '__fish_use_subcommand' -a 'version'    -d 'Print version'\n432:     complete -c $cmd -n '__fish_use_subcommand' -a 'help'       -d 'Show help'\n433: \n434:     # --- tasks subcommands ---\n435:     complete -c $cmd -n '__woco_needs_tasks_subcmd' -a 'list'           -d 'List tasks'\n436:     complete -c $cmd -n '__woco_needs_tasks_subcmd' -a 'ls'             -d '→ list'\n437:     complete -c $cmd -n '__woco_needs_tasks_subcmd' -a 'add'            -d 'Add task'\n438:     complete -c $cmd -n '__woco_needs_tasks_subcmd' -a 'a'              -d '→ add'\n439:     complete -c $cmd -n '__woco_needs_tasks_subcmd' -a 'set-status'     -d 'Change status'\n440:     complete -c $cmd -n '__woco_needs_tasks_subcmd' -a 'ss'             -d '→ set-status'\n441:     complete -c $cmd -n '__woco_needs_tasks_subcmd' -a 'set-priority'   -d 'Change priority'\n442:     complete -c $cmd -n '__woco_needs_tasks_subcmd' -a 'sp'             -d '→ set-priority'\n443:     complete -c $cmd -n '__woco_needs_tasks_subcmd' -a 'set-difficulty' -d 'Change difficulty'\n444:     complete -c $cmd -n '__woco_needs_task