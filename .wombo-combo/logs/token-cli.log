{"type":"tool_use","timestamp":1773483663485,"sessionID":"ses_314277d05ffehFsuzTPHpcve3c","part":{"id":"prt_cebdd1bf9001GjMQYe443n4ZuB","sessionID":"ses_314277d05ffehFsuzTPHpcve3c","messageID":"msg_cebdd1287001e0dvGibWaXd87P","type":"tool","callID":"toolu_vrtx_01SDENMNQsS7vHxdX74U99eB","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/token-cli/src/commands/completion.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/token-cli/src/commands/completion.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * completion.ts — Shell completion script generator for wombo-combo.\n3:  *\n4:  * Generates native completion scripts for bash, zsh, and fish.\n5:  *\n6:  * Install:\n7:  *   eval \"$(woco completion bash)\"                          # add to ~/.bashrc\n8:  *   eval \"$(woco completion zsh)\"                           # add to ~/.zshrc\n9:  *   woco completion fish | source                           # fish\n10:  *   woco completion fish > ~/.config/fish/completions/woco.fish  # persist\n11:  */\n12: \n13: import { basename } from \"node:path\";\n14: \n15: // ---------------------------------------------------------------------------\n16: // Public API\n17: // ---------------------------------------------------------------------------\n18: \n19: export function cmdCompletion({ shell }: { shell?: string }): void {\n20:   const resolved = shell ?? detectShell();\n21: \n22:   switch (resolved) {\n23:     case \"bash\":\n24:       process.stdout.write(bashScript());\n25:       break;\n26:     case \"zsh\":\n27:       process.stdout.write(zshScript());\n28:       break;\n29:     case \"fish\":\n30:       process.stdout.write(fishScript());\n31:       break;\n32:     default:\n33:       console.error(`Unsupported shell: \"${resolved}\"`);\n34:       console.error(\"Supported shells: bash, zsh, fish\");\n35:       console.error(\"\");\n36:       console.error(\"Install completions:\");\n37:       console.error('  eval \"$(woco completion bash)\"    # Bash: add to ~/.bashrc');\n38:       console.error('  eval \"$(woco completion zsh)\"     # Zsh:  add to ~/.zshrc');\n39:       console.error(\"  woco completion fish | source     # Fish\");\n40:       process.exit(1);\n41:   }\n42: }\n43: \n44: // ---------------------------------------------------------------------------\n45: // Shell detection\n46: // ---------------------------------------------------------------------------\n47: \n48: function detectShell(): string {\n49:   const shellPath = process.env.SHELL || \"\";\n50:   const name = basename(shellPath);\n51:   if (name === \"bash\" || name === \"zsh\" || name === \"fish\") return name;\n52:   return \"bash\"; // safe default\n53: }\n54: \n55: // ---------------------------------------------------------------------------\n56: // Bash completion\n57: // ---------------------------------------------------------------------------\n58: \n59: function bashScript(): string {\n60:   return `# woco (wombo-combo) bash completion\n61: # Generated by: woco completion bash\n62: # Install: eval \"$(woco completion bash)\"  — add to ~/.bashrc\n63: \n64: _woco_completions() {\n65:     local cur prev cmd subcmd i j\n66:     cur=\"\\${COMP_WORDS[COMP_CWORD]}\"\n67:     prev=\"\\${COMP_WORDS[COMP_CWORD-1]}\"\n68:     cmd=\"\"\n69:     subcmd=\"\"\n70: \n71:     # Find the main command (first non-flag arg after woco)\n72:     for ((i=1; i < COMP_CWORD; i++)); do\n73:         if [[ \"\\${COMP_WORDS[i]}\" != -* ]]; then\n74:             cmd=\"\\${COMP_WORDS[i]}\"\n75:             break\n76:         fi\n77:     done\n78: \n79:     # Resolve top-level aliases\n80:     case \"$cmd\" in\n81:         i) cmd=\"init\" ;; l) cmd=\"launch\" ;; r) cmd=\"resume\" ;;\n82:         s) cmd=\"status\" ;; v) cmd=\"verify\" ;; m) cmd=\"merge\" ;;\n83:         re) cmd=\"retry\" ;; a) cmd=\"abort\" ;; c) cmd=\"cleanup\" ;;\n84:         h) cmd=\"history\" ;; lo) cmd=\"logs\" ;; t|features) cmd=\"tasks\" ;;\n85:         u) cmd=\"upgrade\" ;; d) cmd=\"describe\" ;; comp) cmd=\"completion\" ;;\n86:         us) cmd=\"usage\" ;;\n87:     esac\n88: \n89:     # Flag value completions (context-independent)\n90:     case \"$prev\" in\n91:         --priority)\n92:             COMPREPLY=($(compgen -W \"critical high medium low wishlist\" -- \"$cur\")); return ;;\n93:         --difficulty)\n94:             COMPREPLY=($(compgen -W \"trivial easy medium hard very_hard\" -- \"$cur\")); return ;;\n95:         --status)\n96:             COMPREPLY=($(compgen -W \"backlog planned in_progress blocked in_review done cancelled\" -- \"$cur\")); return ;;\n97:         --output|-o)\n98:             COMPREPLY=($(compgen -W \"text json toon\" -- \"$cur\")); return ;;\n99:         --by)\n100:             COMPREPLY=($(compgen -W \"task quest model provider harness\" -- \"$cur\")); return ;;\n101:         --format)\n102:             COMPREPLY=($(compgen -W \"table json\" -- \"$cur\")); return ;;\n103:         --model|-m|--top-priority|--quickest-wins|--max-concurrent|--max-retries|--tail|--base-branch|--tag|--release|--tasks|--features|--fields|--desc|--description|--effort|--depends-on|--title|--since|--until)\n104:             return ;;  # free-form / numeric — no completions, let readline handle it\n105:     esac\n106: \n107:     # No command yet → complete commands\n108:     if [[ -z \"$cmd\" ]]; then\n109:         COMPREPLY=($(compgen -W \"init i launch l resume r status s verify v merge m retry re abort a cleanup c history h logs lo tasks t usage us upgrade u describe d completion comp version help\" -- \"$cur\"))\n110:         return\n111:     fi\n112: \n113:     # tasks / t → subcommands\n114:     if [[ \"$cmd\" == \"tasks\" ]]; then\n115:         # Find the subcommand\n116:         for ((j=i+1; j < COMP_CWORD; j++)); do\n117:             if [[ \"\\${COMP_WORDS[j]}\" != -* ]]; then\n118:                 subcmd=\"\\${COMP_WORDS[j]}\"\n119:                 break\n120:             fi\n121:         done\n122: \n123:         # Resolve subcommand aliases\n124:         case \"$subcmd\" in\n125:             ls) subcmd=\"list\" ;; a) subcmd=\"add\" ;; ss) subcmd=\"set-status\" ;;\n126:             sp) subcmd=\"set-priority\" ;; sd) subcmd=\"set-difficulty\" ;;\n127:             ch|validate) subcmd=\"check\" ;; ar) subcmd=\"archive\" ;;\n128:             sh) subcmd=\"show\" ;; g) subcmd=\"graph\" ;;\n129:         esac\n130: \n131:         # No subcommand yet → complete subcommands\n132:         if [[ -z \"$subcmd\" ]]; then\n133:             COMPREPLY=($(compgen -W \"list ls add a set-status ss set-priority sp set-difficulty sd check ch validate archive ar show sh graph g help\" -- \"$cur\"))\n134:             return\n135:         fi\n136: \n137:         # Flags per tasks subcommand\n138:         case \"$subcmd\" in\n139:             list)\n140:                 COMPREPLY=($(compgen -W \"--status --priority --difficulty --ready --include-archive --output -o --fields\" -- \"$cur\")) ;;\n141:             add)\n142:                 COMPREPLY=($(compgen -W \"--desc --description --priority --difficulty --effort --depends-on --dry-run --output -o\" -- \"$cur\")) ;;\n143:             set-status|set-priority|set-difficulty)\n144:                 COMPREPLY=($(compgen -W \"--output -o --dry-run\" -- \"$cur\")) ;;\n145:             archive)\n146:                 COMPREPLY=($(compgen -W \"--dry-run --output -o\" -- \"$cur\")) ;;\n147:             show)\n148:                 COMPREPLY=($(compgen -W \"--output -o --fields\" -- \"$cur\")) ;;\n149:             graph)\n150:                 COMPREPLY=($(compgen -W \"--ascii --mermaid --subtasks --status --output -o\" -- \"$cur\")) ;;\n151:         esac\n152:         return\n153:     fi\n154: \n155:     # completion → shell names\n156:     if [[ \"$cmd\" == \"completion\" ]]; then\n157:         COMPREPLY=($(compgen -W \"bash zsh fish\" -- \"$cur\"))\n158:         return\n159:     fi\n160: \n161:     # describe → command names (for introspection)\n162:     if [[ \"$cmd\" == \"describe\" ]]; then\n163:         COMPREPLY=($(compgen -W \"init launch resume status verify merge retry abort cleanup history usage logs tasks upgrade describe completion version help\" -- \"$cur\"))\n164:         return\n165:     fi\n166: \n167:     # Flags per top-level command\n168:     case \"$cmd\" in\n169:         init)\n170:             COMPREPLY=($(compgen -W \"--force\" -- \"$cur\")) ;;\n171:         launch)\n172:             COMPREPLY=($(compgen -W \"--top-priority --quickest-wins --priority --difficulty --tasks --features --all-ready --max-concurrent --model -m --interactive --no-tui --auto-push --base-branch --max-retries --browser --dry-run --output -o --force\" -- \"$cur\")) ;;\n173:         resume)\n174:             COMPREPLY=($(compgen -W \"--max-concurrent --model -m --interactive --no-tui --auto-push --base-branch --max-retries\" -- \"$cur\")) ;;\n175:         status)\n176:             COMPREPLY=($(compgen -W \"--output -o\" -- \"$cur\")) ;;\n177:         verify)\n178:             COMPREPLY=($(compgen -W \"--model -m --max-retries --browser\" -- \"$cur\")) ;;\n179:         merge)\n180:             COMPREPLY=($(compgen -W \"--auto-push --dry-run --model -m\" -- \"$cur\")) ;;\n181:         retry)\n182:             COMPREPLY=($(compgen -W \"--model -m --interactive --dry-run\" -- \"$cur\")) ;;\n183:         abort)\n184:             COMPREPLY=($(compgen -W \"--requeue --output -o\" -- \"$cur\")) ;;\n185:         cleanup)\n186:             COMPREPLY=($(compgen -W \"--dry-run\" -- \"$cur\")) ;;\n187:         history)\n188:             COMPREPLY=($(compgen -W \"--output -o\" -- \"$cur\")) ;;\n189:         usage)\n190:             COMPREPLY=($(compgen -W \"--by --since --until --format --output -o\" -- \"$cur\")) ;;\n191:         logs)\n192:             COMPREPLY=($(compgen -W \"--tail --follow -f --output -o\" -- \"$cur\")) ;;\n193:         upgrade)\n194:             COMPREPLY=($(compgen -W \"--check --tag --release --force\" -- \"$cur\")) ;;\n195:     esac\n196: }\n197: \n198: complete -o default -F _woco_completions woco\n199: `;\n200: }\n201: \n202: // ---------------------------------------------------------------------------\n203: // Zsh completion\n204: // ---------------------------------------------------------------------------\n205: \n206: function zshScript(): string {\n207:   return `#compdef woco\n208: # woco (wombo-combo) zsh completion\n209: # Generated by: woco completion zsh\n210: # Install: eval \"$(woco completion zsh)\"  — add to ~/.zshrc\n211: \n212: _woco() {\n213:     local cmd subcmd\n214: \n215:     # Position 2 → completing the main command\n216:     if (( CURRENT == 2 )); then\n217:         local -a cmds\n218:         cmds=(\n219:             'init:Generate .wombo-combo/config.json (i)'\n220:             'i:→ init'\n221:             'launch:Launch a wave of agents (l)'\n222:             'l:→ launch'\n223:             'resume:Resume a stopped wave (r)'\n224:             'r:→ resume'\n225:             'status:Show wave status (s)'\n226:             's:→ status'\n227:             'verify:Run build verification (v)'\n228:             'v:→ verify'\n229:             'merge:Merge verified branches (m)'\n230:             'm:→ merge'\n231:             'retry:Retry a failed agent (re)'\n232:             're:→ retry'\n233:             'abort:Kill a running agent (a)'\n234:             'a:→ abort'\n235:             'cleanup:Remove worktrees and sessions (c)'\n236:             'c:→ cleanup'\n237:             'history:List/view past waves (h)'\n238:             'h:→ history'\n239:             'logs:Pretty-print agent logs (lo)'\n240:             'lo:→ logs'\n241:             'tasks:Manage tasks file (t)'\n242:             't:→ tasks'\n243:             'upgrade:Check for updates (u)'\n244:             'u:→ upgrade'\n245:             'describe:Emit JSON schema (d)'\n246:             'd:→ describe'\n247:             'completion:Generate shell completions (comp)'\n248:             'comp:→ completion'\n249:             'version:Print version'\n250:             'help:Show help'\n251:         )\n252:         _describe 'command' cmds\n253:         return\n254:     fi\n255: \n256:     cmd=\"\\${words[2]}\"\n257: \n258:     # Resolve top-level aliases\n259:     case \"$cmd\" in\n260:         i) cmd=init ;; l) cmd=launch ;; r) cmd=resume ;;\n261:         s) cmd=status ;; v) cmd=verify ;; m) cmd=merge ;;\n262:         re) cmd=retry ;; a) cmd=abort ;; c) cmd=cleanup ;;\n263:         h) cmd=history ;; lo) cmd=logs ;; t|features) cmd=tasks ;;\n264:         u) cmd=upgrade ;; d) cmd=describe ;; comp) cmd=completion ;;\n265:     esac\n266: \n267:     # Flag value completions\n268:     case \"\\${words[CURRENT-1]}\" in\n269:         --priority)    compadd critical high medium low wishlist; return ;;\n270:         --difficulty)  compadd trivial easy medium hard very_hard; return ;;\n271:         --status)      compadd backlog planned in_progress blocked in_review done cancelled; return ;;\n272:         --output|-o)   compadd text json toon; return ;;\n273:     esac\n274: \n275:     # tasks → subcommands\n276:     if [[ \"$cmd\" == \"tasks\" ]]; then\n277:         if (( CURRENT == 3 )); then\n278:             local -a subcmds\n279:             subcmds=(\n280:                 'list:List tasks (ls)'\n281:                 'ls:→ list'\n282:                 'add:Add a new task (a)'\n283:                 'a:→ add'\n284:                 'set-status:Change task status (ss)'\n285:                 'ss:→ set-status'\n286:                 'set-priority:Change task priority (sp)'\n287:                 'sp:→ set-priority'\n288:                 'set-difficulty:Change task difficulty (sd)'\n289:                 'sd:→ set-difficulty'\n290:                 'check:Validate tasks file (ch)'\n291:                 'ch:→ check'\n292:                 'validate:→ check'\n293:                 'archive:Move done/cancelled to archive (ar)'\n294:                 'ar:→ archive'\n295:                 'show:Show task details (sh)'\n296:                 'sh:→ show'\n297:                 'graph:Visualize dependency graph (g)'\n298:                 'g:→ graph'\n299:                 'help:Show help'\n300:             )\n301:             _describe 'subcommand' subcmds\n302:             return\n303:         fi\n304: \n305:         subcmd=\"\\${words[3]}\"\n306:         case \"$subcmd\" in\n307:             ls) subcmd=list ;; a) subcmd=add ;; ss) subcmd=set-status ;;\n308:             sp) subcmd=set-priority ;; sd) subcmd=set-difficulty ;;\n309:             ch|validate) subcmd=check ;; ar) subcmd=archive ;;\n310:             sh) subcmd=show ;; g) subcmd=graph ;;\n311:         esac\n312: \n313:         case \"$subcmd\" in\n314:             list)\n315:                 compadd -- --status --priority --difficulty --ready --include-archive --output -o --fields ;;\n316:             add)\n317:                 compadd -- --desc --description --priority --difficulty --effort --depends-on --dry-run --output -o ;;\n318:             set-status|set-priority|set-difficulty)\n319:                 compadd -- --output -o --dry-run ;;\n320:             archive)\n321:                 compadd -- --dry-run --output -o ;;\n322:             show)\n323:                 compadd -- --output -o --fields ;;\n324:             graph)\n325:                 compadd -- --ascii --mermaid --subtasks --status --output -o ;;\n326:         esac\n327:         return\n328:     fi\n329: \n330:     # completion → shell names\n331:     if [[ \"$cmd\" == \"completion\" ]]; then\n332:         if (( CURRENT == 3 )); then\n333:             compadd bash zsh fish\n334:         fi\n335:         return\n336:     fi\n337: \n338:     # describe → command names\n339:     if [[ \"$cmd\" == \"describe\" ]]; then\n340:         compadd -- init launch resume status verify merge retry abort cleanup history logs tasks upgrade describe completion version help\n341:         return\n342:     fi\n343: \n344:     # Flags per command\n345:     case \"$cmd\" in\n346:         init)     compadd -- --force ;;\n347:         launch)   compadd -- --top-priority --quickest-wins --priority --difficulty --tasks --features --all-ready --max-concurrent --model -m --interactive --no-tui --auto-push --base-branch --max-retries --browser --dry-run --output -o --force ;;\n348:         resume)   compadd -- --max-concurrent --model -m --interactive --no-tui --auto-push --base-branch --max-retries ;;\n349:         status)   compadd -- --output -o ;;\n350:         verify)   compadd -- --model -m --max-retries --browser ;;\n351:         merge)    compadd -- --auto-push --dry-run --model -m ;;\n352:         retry)    compadd -- --model -m --interactive --dry-run ;;\n353:         abort)    compadd -- --requeue --output -o ;;\n354:         cleanup)  compadd -- --dry-run ;;\n355:         history)  compadd -- --output -o ;;\n356:         logs)     compadd -- --tail --follow -f --output -o ;;\n357:         upgrade)  compadd -- --check --tag --release --force ;;\n358:     esac\n359: }\n360: \n361: compdef _woco woco\n362: `;\n363: }\n364: \n365: // ---------------------------------------------------------------------------\n366: // Fish completion\n367: // ---------------------------------------------------------------------------\n368: \n369: function fishScript(): string {\n370:   return `# woco (wombo-combo) fish completion\n371: # Generated by: woco completion fish\n372: # Install: woco completion fish | source\n373: # Persist: woco completion fish > ~/.config/fish/completions/woco.fish\n374: \n375: # Helper: true when the tasks/t/features subcommand has a specific sub-subcommand\n376: function __woco_tasks_subcmd\n377:     set -l tokens (commandline -opc)\n378:     if test (count $tokens) -ge 3\n379:         switch $tokens[2]\n380:             case tasks t features\n381:                 for sub in $argv\n382:                     if test \"$tokens[3]\" = \"$sub\"\n383:      