{"type":"tool_use","timestamp":1773483376075,"sessionID":"ses_314277d05ffehFsuzTPHpcve3c","part":{"id":"prt_cebd8bc75001VtQ3wdfEOSDmAZ","sessionID":"ses_314277d05ffehFsuzTPHpcve3c","messageID":"msg_cebd8b04e001wvLO8betCaQuDk","type":"tool","callID":"toolu_vrtx_01X7sGQWDJ9HQWi4EJBBRC2p","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/token-cli/src/lib/token-usage.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/token-cli/src/lib/token-usage.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * token-usage.ts — Persist and aggregate token usage data.\n3:  *\n4:  * Responsibilities:\n5:  *   - Append UsageRecords to .wombo-combo/usage.jsonl (one JSON object per line)\n6:  *   - Load all records from the JSONL file\n7:  *   - Aggregate: groupBy(field), filterByDateRange(since, until), totalUsage()\n8:  *   - Create a UsageStore that wires into TokenCollector's onUsage callback\n9:  *\n10:  * The JSONL format is append-only and human-readable. Each line is a complete\n11:  * JSON object representing one UsageRecord (one step_finish event). This makes\n12:  * it safe for concurrent writes (append is atomic on most filesystems for\n13:  * small writes) and easy to process with standard unix tools (grep, jq, etc.).\n14:  */\n15: \n16: import { existsSync, mkdirSync, readFileSync, appendFileSync } from \"node:fs\";\n17: import { resolve, dirname } from \"node:path\";\n18: import { WOMBO_DIR } from \"../config.js\";\n19: import type { UsageRecord } from \"./token-collector.js\";\n20: \n21: // ---------------------------------------------------------------------------\n22: // Constants\n23: // ---------------------------------------------------------------------------\n24: \n25: /** Path to the usage JSONL file relative to project root */\n26: const USAGE_FILE = `${WOMBO_DIR}/usage.jsonl`;\n27: \n28: // ---------------------------------------------------------------------------\n29: // Persistence — Append\n30: // ---------------------------------------------------------------------------\n31: \n32: /**\n33:  * Append a single UsageRecord to the usage.jsonl file.\n34:  *\n35:  * Creates the .wombo-combo/ directory and the file if they don't exist.\n36:  * Each record is written as a single JSON line terminated by a newline.\n37:  *\n38:  * @param projectRoot  The project root directory\n39:  * @param record       The UsageRecord to persist\n40:  */\n41: export function appendUsageRecord(\n42:   projectRoot: string,\n43:   record: UsageRecord\n44: ): void {\n45:   const filePath = resolve(projectRoot, USAGE_FILE);\n46:   const dir = dirname(filePath);\n47: \n48:   if (!existsSync(dir)) {\n49:     mkdirSync(dir, { recursive: true });\n50:   }\n51: \n52:   const line = JSON.stringify(record) + \"\\n\";\n53:   appendFileSync(filePath, line, \"utf-8\");\n54: }\n55: \n56: // ---------------------------------------------------------------------------\n57: // Persistence — Load\n58: // ---------------------------------------------------------------------------\n59: \n60: /**\n61:  * Load all UsageRecords from the usage.jsonl file.\n62:  *\n63:  * Skips malformed lines silently (defensive against partial writes or\n64:  * corruption). Returns an empty array if the file doesn't exist.\n65:  *\n66:  * @param projectRoot  The project root directory\n67:  * @returns Array of UsageRecords in chronological order\n68:  */\n69: export function loadUsageRecords(projectRoot: string): UsageRecord[] {\n70:   const filePath = resolve(projectRoot, USAGE_FILE);\n71: \n72:   if (!existsSync(filePath)) return [];\n73: \n74:   const raw = readFileSync(filePath, \"utf-8\");\n75:   const records: UsageRecord[] = [];\n76: \n77:   for (const line of raw.split(\"\\n\")) {\n78:     const trimmed = line.trim();\n79:     if (!trimmed) continue;\n80: \n81:     try {\n82:       const record = JSON.parse(trimmed) as UsageRecord;\n83:       // Basic validation: must have task_id and timestamp\n84:       if (record.task_id && record.timestamp) {\n85:         records.push(record);\n86:       }\n87:     } catch {\n88:       // Skip malformed lines\n89:     }\n90:   }\n91: \n92:   return records;\n93: }\n94: \n95: // ---------------------------------------------------------------------------\n96: // Aggregation — Total Usage\n97: // ---------------------------------------------------------------------------\n98: \n99: /** Aggregated totals across a set of usage records */\n100: export interface UsageTotals {\n101:   /** Total input tokens */\n102:   input_tokens: number;\n103:   /** Total output tokens */\n104:   output_tokens: number;\n105:   /** Total cache read tokens */\n106:   cache_read: number;\n107:   /** Total cache write tokens */\n108:   cache_write: number;\n109:   /** Total reasoning tokens */\n110:   reasoning_tokens: number;\n111:   /** Grand total tokens */\n112:   total_tokens: number;\n113:   /** Total cost */\n114:   total_cost: number;\n115:   /** Number of records (steps) */\n116:   record_count: number;\n117: }\n118: \n119: /**\n120:  * Compute total usage across a set of records.\n121:  *\n122:  * @param records  The records to sum\n123:  * @returns Aggregated totals\n124:  */\n125: export function totalUsage(records: UsageRecord[]): UsageTotals {\n126:   return {\n127:     input_tokens: records.reduce((sum, r) => sum + r.input_tokens, 0),\n128:     output_tokens: records.reduce((sum, r) => sum + r.output_tokens, 0),\n129:     cache_read: records.reduce((sum, r) => sum + r.cache_read, 0),\n130:     cache_write: records.reduce((sum, r) => sum + r.cache_write, 0),\n131:     reasoning_tokens: records.reduce((sum, r) => sum + r.reasoning_tokens, 0),\n132:     total_tokens: records.reduce((sum, r) => sum + r.total_tokens, 0),\n133:     total_cost: records.reduce((sum, r) => sum + r.cost, 0),\n134:     record_count: records.length,\n135:   };\n136: }\n137: \n138: // ---------------------------------------------------------------------------\n139: // Aggregation — Filter by Date Range\n140: // ---------------------------------------------------------------------------\n141: \n142: /**\n143:  * Filter records to those within a date range.\n144:  *\n145:  * Both `since` and `until` are inclusive. If either is omitted, that side\n146:  * of the range is unbounded.\n147:  *\n148:  * @param records  The records to filter\n149:  * @param since    Start of range (ISO 8601 string or Date). Inclusive.\n150:  * @param until    End of range (ISO 8601 string or Date). Inclusive.\n151:  * @returns Filtered records\n152:  */\n153: export function filterByDateRange(\n154:   records: UsageRecord[],\n155:   since?: string | Date,\n156:   until?: string | Date\n157: ): UsageRecord[] {\n158:   const sinceMs = since ? new Date(since).getTime() : -Infinity;\n159:   const untilMs = until ? new Date(until).getTime() : Infinity;\n160: \n161:   if (isNaN(sinceMs) && since) {\n162:     throw new Error(`Invalid 'since' date: ${since}`);\n163:   }\n164:   if (isNaN(untilMs) && until) {\n165:     throw new Error(`Invalid 'until' date: ${until}`);\n166:   }\n167: \n168:   return records.filter((r) => {\n169:     const ts = new Date(r.timestamp).getTime();\n170:     if (isNaN(ts)) return false;\n171:     return ts >= sinceMs && ts <= untilMs;\n172:   });\n173: }\n174: \n175: // ---------------------------------------------------------------------------\n176: // Aggregation — Group By\n177: // ---------------------------------------------------------------------------\n178: \n179: /** Fields that can be used as groupBy keys */\n180: export type GroupableField =\n181:   | \"task_id\"\n182:   | \"quest_id\"\n183:   | \"model\"\n184:   | \"provider\"\n185:   | \"harness\";\n186: \n187: /**\n188:  * Group records by a specified field and compute totals for each group.\n189:  *\n190:  * The grouping key is the string value of the specified field. Null values\n191:  * are grouped under the key \"(unknown)\".\n192:  *\n193:  * @param records  The records to group\n194:  * @param field    The field to group by\n195:  * @returns Map from group key to aggregated totals\n196:  */\n197: export function groupBy(\n198:   records: UsageRecord[],\n199:   field: GroupableField\n200: ): Map<string, UsageTotals> {\n201:   const groups = new Map<string, UsageRecord[]>();\n202: \n203:   for (const record of records) {\n204:     const key = String(record[field] ?? \"(unknown)\");\n205:     if (!groups.has(key)) {\n206:       groups.set(key, []);\n207:     }\n208:     groups.get(key)!.push(record);\n209:   }\n210: \n211:   const result = new Map<string, UsageTotals>();\n212:   for (const [key, groupRecords] of groups) {\n213:     result.set(key, totalUsage(groupRecords));\n214:   }\n215: \n216:   return result;\n217: }\n218: \n219: // ---------------------------------------------------------------------------\n220: // UsageStore — High-level persistence wrapper\n221: // ---------------------------------------------------------------------------\n222: \n223: /**\n224:  * UsageStore provides a high-level interface for persisting token usage data.\n225:  *\n226:  * It is designed to be used as the onUsage callback for TokenCollector, so that\n227:  * every parsed UsageRecord is immediately persisted to the JSONL file.\n228:  *\n229:  * Usage:\n230:  *   const store = new UsageStore(projectRoot);\n231:  *\n232:  *   // Wire into TokenCollector\n233:  *   const collector = new TokenCollector((record) => {\n234:  *     store.append(record);\n235:  *   });\n236:  *\n237:  *   // Or wire into ProcessMonitor callbacks\n238:  *   const monitor = new ProcessMonitor(projectRoot, {\n239:  *     onUsage: (_featureId, record) => store.append(record),\n240:  *   });\n241:  *\n242:  *   // Query historical data\n243:  *   const allRecords = store.load();\n244:  *   const totals = store.totalUsage();\n245:  *   const byModel = store.groupBy(\"model\");\n246:  *   const lastWeek = store.filterByDateRange(weekAgo, now);\n247:  */\n248: export class UsageStore {\n249:   private projectRoot: string;\n250: \n251:   constructor(projectRoot: string) {\n252:     this.projectRoot = projectRoot;\n253:   }\n254: \n255:   /**\n256:    * Append a single UsageRecord to the JSONL file.\n257:    * This is the primary write method — designed to be called from\n258:    * TokenCollector's onUsage callback.\n259:    */\n260:   append(record: UsageRecord): void {\n261:     appendUsageRecord(this.projectRoot, record);\n262:   }\n263: \n264:   /**\n265:    * Load all usage records from the JSONL file.\n266:    */\n267:   load(): UsageRecord[] {\n268:     return loadUsageRecords(this.projectRoot);\n269:   }\n270: \n271:   /**\n272:    * Compute total usage across all persisted records.\n273:    */\n274:   totalUsage(): UsageTotals {\n275:     return totalUsage(this.load());\n276:   }\n277: \n278:   /**\n279:    * Filter persisted records by date range and return totals.\n280:    */\n281:   filterByDateRange(\n282:     since?: string | Date,\n283:     until?: string | Date\n284:   ): UsageRecord[] {\n285:     return filterByDateRange(this.load(), since, until);\n286:   }\n287: \n288:   /**\n289:    * Group persisted records by a field and compute per-group totals.\n290:    */\n291:   groupBy(field: GroupableField): Map<string, UsageTotals> {\n292:     return groupBy(this.load(), field);\n293:   }\n294: }\n\n(End of file - total 294 lines)\n</content>","title":"src/lib/token-usage.ts","metadata":{"preview":"/**\n * token-usage.ts — Persist and aggregate token usage data.\n *\n * Responsibilities:\n *   - Append UsageRecords to .wombo-combo/usage.jsonl (one JSON object per line)\n *   - Load all records from the JSONL file\n *   - Aggregate: groupBy(field), filterByDateRange(since, until), totalUsage()\n *   - Create a UsageStore that wires into TokenCollector's onUsage callback\n *\n * The JSONL format is append-only and human-readable. Each line is a complete\n * JSON object representing one UsageRecord (one step_finish event). This makes\n * it safe for concurrent writes (append is atomic on most filesystems for\n * small writes) and easy to process with standard unix tools (grep, jq, etc.).\n */\n\nimport { existsSync, mkdirSync, readFileSync, appendFileSync } from \"node:fs\";\nimport { resolve, dirname } from \"node:path\";\nimport { WOMBO_DIR } from \"../config.js\";\nimport type { UsageRecord } from \"./token-collector.js\";\n","truncated":false,"loaded":[]},"time":{"start":1773483376072,"end":1773483376075}}}}
{"type":"tool_use","timestamp":1773483376583,"sessionID":"ses_314277d05ffehFsuzTPHpcve3c","part":{"id":"prt_cebd8bdc9001V8gxpWo2oUS4qW","sessionID":"ses_314277d05ffehFsuzTPHpcve3c","messageID":"msg_cebd8b04e001wvLO8betCaQuDk","type":"tool","callID":"toolu_vrtx_01AGUNeT5fJNnzA61TuAWVjo","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/token-cli/src/lib/token-collector.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/token-cli/src/lib/token-collector.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * token-collector.ts — Parse and collect token usage data from agent events.\n3:  *\n4:  * Responsibilities:\n5:  *   - Define the UsageRecord type for structured token usage data\n6:  *   - Parse step_finish events to extract per-step token counts\n7:  *   - Accumulate usage records per agent (task_id)\n8:  *   - Emit parsed records via callback (storage is handled elsewhere)\n9:  *\n10:  * OpenCode emits step_finish events with this token structure:\n11:  *   {\n12:  *     type: \"step_finish\",\n13:  *     part: {\n14:  *       reason: \"tool-calls\" | \"stop\",\n15:  *       cost: number,\n16:  *       tokens: {\n17:  *         total: number,\n18:  *         input: number,\n19:  *         output: number,\n20:  *         reasoning: number,\n21:  *         cache: { read: number, write: number }\n22:  *       }\n23:  *     }\n24:  *   }\n25:  */\n26: \n27: import type { OpenCodeEvent } from \"./monitor.js\";\n28: \n29: // ---------------------------------------------------------------------------\n30: // Types\n31: // ---------------------------------------------------------------------------\n32: \n33: /**\n34:  * A single token usage record extracted from an agent's step_finish event.\n35:  *\n36:  * Each record represents one step's token consumption. Multiple records\n37:  * are emitted per agent session (one per step_finish event).\n38:  */\n39: export interface UsageRecord {\n40:   /** The task/feature ID this usage belongs to */\n41:   task_id: string;\n42:   /** Optional quest ID if the agent is working within a quest */\n43:   quest_id: string | null;\n44:   /** Model identifier (e.g. \"claude-sonnet-4-20250514\") — from launch context */\n45:   model: string | null;\n46:   /** Provider name (e.g. \"anthropic\", \"openai\") — from launch context */\n47:   provider: string | null;\n48:   /** Agent harness name (e.g. \"opencode\") — from launch context */\n49:   harness: string | null;\n50:   /** Input tokens consumed in this step */\n51:   input_tokens: number;\n52:   /** Output tokens generated in this step */\n53:   output_tokens: number;\n54:   /** Tokens read from cache in this step */\n55:   cache_read: number;\n56:   /** Tokens written to cache in this step */\n57:   cache_write: number;\n58:   /** Reasoning tokens used in this step (e.g. for o1-style models) */\n59:   reasoning_tokens: number;\n60:   /** Total tokens for this step (input + output + reasoning) */\n61:   total_tokens: number;\n62:   /** Cost reported by the agent harness (may be 0 if not available) */\n63:   cost: number;\n64:   /** Whether this was the final step (reason === \"stop\") */\n65:   is_final_step: boolean;\n66:   /** ISO 8601 timestamp when this usage was recorded */\n67:   timestamp: string;\n68: }\n69: \n70: /**\n71:  * Aggregated usage summary for a single agent session.\n72:  */\n73: export interface UsageSummary {\n74:   /** The task/feature ID */\n75:   task_id: string;\n76:   /** Total input tokens across all steps */\n77:   total_input: number;\n78:   /** Total output tokens across all steps */\n79:   total_output: number;\n80:   /** Total cache read tokens across all steps */\n81:   total_cache_read: number;\n82:   /** Total cache write tokens across all steps */\n83:   total_cache_write: number;\n84:   /** Total reasoning tokens across all steps */\n85:   total_reasoning: number;\n86:   /** Grand total tokens across all steps */\n87:   total_tokens: number;\n88:   /** Total cost across all steps */\n89:   total_cost: number;\n90:   /** Number of steps recorded */\n91:   step_count: number;\n92: }\n93: \n94: // ---------------------------------------------------------------------------\n95: // Parsing\n96: // ---------------------------------------------------------------------------\n97: \n98: /**\n99:  * Check if an OpenCode event is a step_finish with token data.\n100:  */\n101: export function isTokenEvent(event: OpenCodeEvent): boolean {\n102:   return (\n103:     event.type === \"step_finish\" &&\n104:     event.part?.tokens != null &&\n105:     typeof event.part.tokens.input === \"number\"\n106:   );\n107: }\n108: \n109: /**\n110:  * Extract a UsageRecord from a step_finish event.\n111:  *\n112:  * Returns null if the event doesn't contain valid token data.\n113:  *\n114:  * @param event     The OpenCode JSON event (must be type \"step_finish\")\n115:  * @param taskId    The task/feature ID this agent is working on\n116:  * @param context   Optional context from the launch environment\n117:  */\n118: export function parseUsageFromEvent(\n119:   event: OpenCodeEvent,\n120:   taskId: string,\n121:   context?: {\n122:     quest_id?: string | null;\n123:     model?: string | null;\n124:     provider?: string | null;\n125:     harness?: string | null;\n126:   }\n127: ): UsageRecord | null {\n128:   if (!isTokenEvent(event)) return null;\n129: \n130:   const tokens = event.part!.tokens!;\n131:   const cache = tokens.cache ?? { read: 0, write: 0 };\n132: \n133:   return {\n134:     task_id: taskId,\n135:     quest_id: context?.quest_id ?? null,\n136:     model: context?.model ?? null,\n137:     provider: context?.provider ?? null,\n138:     harness: context?.harness ?? \"opencode\",\n139:     input_tokens: tokens.input,\n140:     output_tokens: tokens.output,\n141:     cache_read: cache.read,\n142:     cache_write: cache.write,\n143:     reasoning_tokens: tokens.reasoning ?? 0,\n144:     total_tokens: tokens.total,\n145:     cost: event.part?.cost ?? 0,\n146:     is_final_step: event.part?.reason === \"stop\",\n147:     timestamp: new Date(event.timestamp ?? Date.now()).toISOString(),\n148:   };\n149: }\n150: \n151: // ---------------------------------------------------------------------------\n152: // Collector\n153: // ---------------------------------------------------------------------------\n154: \n155: /** Callback invoked when a new usage record is parsed */\n156: export type UsageCallback = (record: UsageRecord) => void;\n157: \n158: /**\n159:  * TokenCollector accumulates usage records for multiple agents.\n160:  *\n161:  * Usage:\n162:  *   const collector = new TokenCollector((record) => {\n163:  *     console.log(\"Usage:\", record);\n164:  *   });\n165:  *\n166:  *   // Register context for an agent before it starts\n167:  *   collector.registerAgent(\"my-feature\", {\n168:  *     quest_id: \"quest-1\",\n169:  *     model: \"claude-sonnet-4-20250514\",\n170:  *   });\n171:  *\n172:  *   // Feed events as they arrive\n173:  *   collector.ingestEvent(\"my-feature\", event);\n174:  *\n175:  *   // Get aggregated summary\n176:  *   const summary = collector.getSummary(\"my-feature\");\n177:  */\n178: export class TokenCollector {\n179:   /** Per-agent usage records */\n180:   private records: Map<string, UsageRecord[]> = new Map();\n181: \n182:   /** Per-agent context (model, provider, quest, etc.) */\n183:   private contexts: Map<\n184:     string,\n185:     {\n186:       quest_id?: string | null;\n187:       model?: string | null;\n188:       provider?: string | null;\n189:       harness?: string | null;\n190:     }\n191:   > = new Map();\n192: \n193:   /** Callback invoked for each new usage record */\n194:   private onUsage: UsageCallback | null;\n195: \n196:   constructor(onUsage?: UsageCallback) {\n197:     this.onUsage = onUsage ?? null;\n198:   }\n199: \n200:   /**\n201:    * Register context for an agent before events start flowing.\n202:    * This context (model, provider, quest_id) is attached to every\n203:    * UsageRecord emitted for this agent.\n204:    */\n205:   registerAgent(\n206:     taskId: string,\n207:     context?: {\n208:       quest_id?: string | null;\n209:       model?: string | null;\n210:       provider?: string | null;\n211:       harness?: string | null;\n212:     }\n213:   ): void {\n214:     this.contexts.set(taskId, context ?? {});\n215:     if (!this.records.has(taskId)) {\n216:       this.records.set(taskId, []);\n217:     }\n218:   }\n219: \n220:   /**\n221:    * Feed an OpenCode event for a specific agent.\n222:    * If the event is a step_finish with token data, a UsageRecord\n223:    * is created and the onUsage callback is invoked.\n224:    *\n225:    * @returns The parsed UsageRecord, or null if the event had no token data\n226:    */\n227:   ingestEvent(taskId: string, event: OpenCodeEvent): UsageRecord | null {\n228:     if (!isTokenEvent(event)) return null;\n229: \n230:     const context = this.contexts.get(taskId);\n231:     const record = parseUsageFromEvent(event, taskId, context);\n232:     if (!record) return null;\n233: \n234:     if (!this.records.has(taskId)) {\n235:       this.records.set(taskId, []);\n236:     }\n237:     this.records.get(taskId)!.push(record);\n238: \n239:     this.onUsage?.(record);\n240: \n241:     return record;\n242:   }\n243: \n244:   /**\n245:    * Get all usage records for an agent.\n246:    */\n247:   getRecords(taskId: string): UsageRecord[] {\n248:     return this.records.get(taskId) ?? [];\n249:   }\n250: \n251:   /**\n252:    * Get all usage records across all agents.\n253:    */\n254:   getAllRecords(): UsageRecord[] {\n255:     const all: UsageRecord[] = [];\n256:     for (const records of this.records.values()) {\n257:       all.push(...records);\n258:     }\n259:     return all;\n260:   }\n261: \n262:   /**\n263:    * Get an aggregated usage summary for an agent.\n264:    * Returns null if no records exist for the agent.\n265:    */\n266:   getSummary(taskId: string): UsageSummary | null {\n267:     const records = this.records.get(taskId);\n268:     if (!records || records.length === 0) return null;\n269: \n270:     return {\n271:       task_id: taskId,\n272:       total_input: records.reduce((sum, r) => sum + r.input_tokens, 0),\n273:       total_output: records.reduce((sum, r) => sum + r.output_tokens, 0),\n274:       total_cache_read: records.reduce((sum, r) => sum + r.cache_read, 0),\n275:       total_cache_write: records.reduce((sum, r) => sum + r.cache_write, 0),\n276:       total_reasoning: records.reduce((sum, r) => sum + r.reasoning_tokens, 0),\n277:       total_tokens: records.reduce((sum, r) => sum + r.total_tokens, 0),\n278:       total_cost: records.reduce((sum, r) => sum + r.cost, 0),\n279:       step_count: records.length,\n280:     };\n281:   }\n282: \n283:   /**\n284:    * Get aggregated summaries for all tracked agents.\n285:    */\n286:   getAllSummaries(): UsageSummary[] {\n287:     const summaries: UsageSummary[] = [];\n288:     for (const taskId of this.records.keys()) {\n289:       const summary = this.getSummary(taskId);\n290:       if (summary) summaries.push(summary);\n291:     }\n292:     return summaries;\n293:   }\n294: \n295:   /**\n296:    * Remove all records for an agent (e.g. after archiving).\n297:    */\n298:   clear(taskId: string): void {\n299:     this.records.delete(taskId);\n300:     this.contexts.delete(taskId);\n301:   }\n302: \n303:   /**\n304:    * Remove all records for all agents.\n305:    */\n306:   clearAll(): void {\n307:     this.records.clear();\n308:     this.contexts.clear();\n309:   }\n310: }\n\n(End of file - total 310 lines)\n</content>","title":"src/lib/token-collector.ts","metadata":{"preview":"/**\n * token-collector.ts — Parse and collect token usage data from agent events.\n *\n * Responsibilities:\n *   - Define the UsageRecord type for structured token usage data\n *   - Parse step_finish events to extract per-step token counts\n *   - Accumulate usage records per agent (task_id)\n *   - Emit parsed records via callback (storage is handled elsewhere)\n *\n * OpenCode emits step_finish events with this token structure:\n *   {\n *     type: \"step_finish\",\n *     part: {\n *       reason: \"tool-calls\" | \"stop\",\n *       cost: number,\n *       tokens: {\n *         total: number,\n *         input: number,\n *         output: number,\n *         reasoning: number,","truncated":false,"loaded":[]},"time":{"start":1773483376579,"end":1773483376582}}}}
