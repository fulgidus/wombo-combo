ne 84:   /** Total reasoning tokens across all steps */\n  Line 86:   /** Grand total tokens across all steps */\n  Line 87:   total_tokens: number;\n  Line 99:  * Check if an OpenCode event is a step_finish with token data.\n  Line 104:     event.part?.tokens != null &&\n  Line 105:     typeof event.part.tokens.input === \"number\"\n  Line 112:  * Returns null if the event doesn't contain valid token data.\n  Line 130:   const tokens = event.part!.tokens!;\n  Line 131:   const cache = tokens.cache ?? { read: 0, write: 0 };\n  Line 139:     input_tokens: tokens.input,\n  Line 140:     output_tokens: tokens.output,\n  Line 143:     reasoning_tokens: tokens.reasoning ?? 0,\n  Line 144:     total_tokens: tokens.total,\n  Line 222:    * If the event is a step_finish with token data, a UsageRecord\n  Line 225:    * @returns The parsed UsageRecord, or null if the event had no token data\n  Line 272:       total_input: records.reduce((sum, r) => sum + r.input_tokens, 0),\n  Line 273:       total_output: records.reduce((sum, r) => sum + r.output_tokens, 0),\n  Line 276:       total_reasoning: records.reduce((sum, r) => sum + r.reasoning_tokens, 0),\n  Line 277:       total_tokens: records.reduce((sum, r) => sum + r.total_tokens, 0),\n\n/home/fulgidus/Documents/wombo-combo-worktrees/token-cli/src/lib/prompt.ts:\n  Line 96:   // Constraints (compressed to reduce tokens)\n  Line 108:   // Forbidden (compressed to reduce tokens)\n\n/home/fulgidus/Documents/wombo-combo-worktrees/token-cli/src/lib/monitor.ts:\n  Line 44: import { TokenCollector, type UsageRecord } from \"./token-collector.js\";\n  Line 45: import { UsageStore } from \"./token-usage.js\";\n  Line 68:     tokens?: {\n  Line 304:       const tokens = event.part?.tokens;\n  Line 307:         if (tokens) {\n  Line 308:           const parts = [`${tokens.input}in`, `${tokens.output}out`];\n  Line 309:           if (tokens.cache?.read) parts.push(`${tokens.cache.read}cache`);\n  Line 345:   /** Called when token usage data is parsed from a step_finish event */\n  Line 375:   public tokenCollector: TokenCollector;\n  Line 386:     this.tokenCollector = new TokenCollector((record) => {\n  Line 472:           // Extract token usage from step_finish events\n  Line 473:           this.tokenCollector.ingestEvent(featureId, event);\n  Line 715: // Re-exports from token-collector for convenience\n  Line 718: export { TokenCollector, type UsageRecord } from \"./token-collector.js\";\n  Line 719: export type { UsageSummary, UsageCallback } from \"./token-collector.js\";\n  Line 722: // Re-exports from token-usage for convenience\n  Line 725: export { UsageStore, appendUsageRecord, loadUsageRecords, totalUsage, filterByDateRange, groupBy } from \"./token-usage.js\";\n  Line 726: export type { UsageTotals, GroupableField } from \"./token-usage.js\";\n\n/home/fulgidus/Documents/wombo-combo-worktrees/token-cli/src/lib/prompt-compress.ts:\n  Line 4:  * Reduces token count in agent prompts without losing semantic content:\n  Line 11:  * measurably reducing token usage for large prompts.\n  Line 222:  * Abbreviate common constraint patterns to reduce token count.\n  Line 346:  * Estimate token count for a string. Uses a simple heuristic:\n  Line 347:  * ~4 characters per token for English text / code.\n  Line 348:  * This is approximate — actual tokenizer counts may vary by ±15%.\n  Line 351:   // GPT/Claude tokenizers average ~4 chars per token for mixed code/text","title":"token","metadata":{"matches":97,"truncated":false},"time":{"start":1773483372461,"end":1773483372473}}}}
