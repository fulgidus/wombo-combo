;\n42:   /** ISO 8601 timestamp when the agent finished */\n43:   completed_at: string | null;\n44:   /** Duration in milliseconds (computed from started_at → completed_at) */\n45:   duration_ms: number | null;\n46:   /** Error message if failed */\n47:   error: string | null;\n48:   /** Whether the agent encountered merge conflicts */\n49:   had_merge_conflict: boolean;\n50:   /** Build output summary (only for failed builds) */\n51:   build_output: string | null;\n52: }\n53: \n54: export interface WaveHistoryRecord {\n55:   /** Unique wave identifier */\n56:   wave_id: string;\n57:   /** Base branch used for this wave */\n58:   base_branch: string;\n59:   /** ISO 8601 timestamp when the wave started */\n60:   started_at: string;\n61:   /** ISO 8601 timestamp when the history was exported */\n62:   exported_at: string;\n63:   /** Model used (if any) */\n64:   model: string | null;\n65:   /** Max concurrency setting */\n66:   max_concurrent: number;\n67:   /** Whether the wave ran in interactive mode */\n68:   interactive: boolean;\n69:   /** Summary statistics */\n70:   summary: {\n71:     total: number;\n72:     succeeded: number;\n73:     failed: number;\n74:     merged: number;\n75:     verified: number;\n76:     total_retries: number;\n77:     total_duration_ms: number;\n78:   };\n79:   /** Per-agent results */\n80:   agents: AgentHistoryRecord[];\n\n(Showing lines 1-80 of 273. Use offset=81 to continue.)\n</content>","title":"src/lib/history.ts","metadata":{"preview":"/**\n * history.ts — Wave history persistence.\n *\n * Responsibilities:\n *   - Define the shape of wave history records\n *   - Save wave history to .wombo-combo/history/<wave-id>.json\n *   - Load individual history records\n *   - List all saved history records\n *   - Export wave state to history on completion\n *\n * History records survive `woco cleanup` because they are stored\n * separately from .wombo-combo/state.json. The .wombo-combo/history/\n * directory is gitignored.\n */\n\nimpor