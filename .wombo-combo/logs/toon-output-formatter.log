{"type":"tool_use","timestamp":1773435859863,"sessionID":"ses_316fcbbc9ffe0U7d2IN0Q9PcrR","part":{"id":"prt_ce903b0da001MgHtyt5IvQSqFD","sessionID":"ses_316fcbbc9ffe0U7d2IN0Q9PcrR","messageID":"msg_ce903a623001IQ1aiBEgLPbi54","type":"tool","callID":"toolu_vrtx_01VUP4T9bwYjxYeFeC5zzFxK","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-toon-output-formatter/src/commands/tasks/list.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-toon-output-formatter/src/commands/tasks/list.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tasks/list.ts — List and filter tasks from the tasks file.\n3:  *\n4:  * Usage:\n5:  *   woco tasks list                     # list all tasks\n6:  *   woco tasks list --status backlog    # filter by status\n7:  *   woco tasks list --priority high     # filter by priority\n8:  *   woco tasks list --ready             # show only ready tasks\n9:  *   woco tasks list --archive           # include archived tasks\n10:  */\n11: \n12: import type { WomboConfig } from \"../../config.js\";\n13: import {\n14:   loadFeatures,\n15:   getReadyFeatures,\n16:   featureSummary,\n17:   formatDuration,\n18:   parseDurationMinutes,\n19:   type Feature,\n20:   type FeatureStatus,\n21:   type Priority,\n22:   type Difficulty,\n23:   type FeaturesFile,\n24: } from \"../../lib/tasks.js\";\n25: import { output, filterFieldsArray, renderCompactTable, type OutputFormat } from \"../../lib/output.js\";\n26: \n27: // ---------------------------------------------------------------------------\n28: // Types\n29: // ---------------------------------------------------------------------------\n30: \n31: export interface TasksListOptions {\n32:   projectRoot: string;\n33:   config: WomboConfig;\n34:   status?: FeatureStatus;\n35:   priority?: Priority;\n36:   difficulty?: Difficulty;\n37:   ready?: boolean;\n38:   includeArchive?: boolean;\n39:   outputFmt?: OutputFormat;\n40:   fields?: string[];\n41: }\n42: \n43: // ---------------------------------------------------------------------------\n44: // ANSI Helpers\n45: // ---------------------------------------------------------------------------\n46: \n47: const RESET = \"\\x1b[0m\";\n48: const BOLD = \"\\x1b[1m\";\n49: const DIM = \"\\x1b[2m\";\n50: \n51: const STATUS_COLOR: Record<FeatureStatus, string> = {\n52:   backlog: \"\\x1b[37m\",     // white\n53:   planned: \"\\x1b[36m\",     // cyan\n54:   in_progress: \"\\x1b[34m\", // blue\n55:   blocked: \"\\x1b[31m\",     // red\n56:   in_review: \"\\x1b[33m\",   // yellow\n57:   done: \"\\x1b[32m\",        // green\n58:   cancelled: \"\\x1b[90m\",   // gray\n59: };\n60: \n61: // ---------------------------------------------------------------------------\n62: // Command\n63: // ---------------------------------------------------------------------------\n64: \n65: export async function cmdTasksList(opts: TasksListOptions): Promise<void> {\n66:   const { projectRoot, config } = opts;\n67:   const data = loadFeatures(projectRoot, config);\n68: \n69:   let features: Feature[] = [...data.tasks];\n70: \n71:   // Include archive if requested\n72:   if (opts.includeArchive && data.archive?.length) {\n73:     features = [...features, ...data.archive];\n74:   }\n75: \n76:   // Filter by status\n77:   if (opts.status) {\n78:     features = features.filter((f) => f.status === opts.status);\n79:   }\n80: \n81:   // Filter by priority\n82:   if (opts.priority) {\n83:     features = features.filter((f) => f.priority === opts.priority);\n84:   }\n85: \n86:   // Filter by difficulty\n87:   if (opts.difficulty) {\n88:     features = features.filter((f) => f.difficulty === opts.difficulty);\n89:   }\n90: \n91:   // Filter to ready-only\n92:   if (opts.ready) {\n93:     const readyFeatures = getReadyFeatures(data);\n94:     const readyIds = new Set(readyFeatures.map((f) => f.id));\n95:     features = features.filter((f) => readyIds.has(f.id));\n96:   }\n97: \n98:   if (features.length === 0) {\n99:     output(opts.outputFmt ?? \"text\", { features: [], total: 0, effort: \"0m\" }, () => {\n100:       console.log(\"No tasks match the given filters.\");\n101:     });\n102:     return;\n103:   }\n104: \n105:   // Group by status for display\n106:   const byStatus = new Map<FeatureStatus, Feature[]>();\n107:   for (const f of features) {\n108:     const list = byStatus.get(f.status) ?? [];\n109:     list.push(f);\n110:     byStatus.set(f.status, list);\n111:   }\n112: \n113:   // Display\n114:   const totalEffort = features.reduce(\n115:     (sum, f) => sum + parseDurationMinutes(f.effort),\n116:     0\n117:   );\n118: \n119:   const fmt = opts.outputFmt ?? \"text\";\n120: \n121:   // Build the structured data for each feature\n122:   const featureData = features.map((f) => ({\n123:     id: f.id,\n124:     title: f.title,\n125:     status: f.status,\n126:     priority: f.priority,\n127:     difficulty: f.difficulty,\n128:     effort: f.effort,\n129:     completion: f.completion,\n130:     depends_on: f.depends_on,\n131:   }));\n132: \n133:   // If --fields is specified, use compact output mode\n134:   if (opts.fields?.length) {\n135:     const filtered = filterFieldsArray(featureData, opts.fields);\n136:     output(\n137:       fmt,\n138:       { features: filtered, total: features.length, effort: formatDuration(totalEffort) },\n139:       () => {\n140:         renderCompactTable(\n141:           featureData as Record<string, unknown>[],\n142:           opts.fields!\n143:         );\n144:       }\n145:     );\n146:     return;\n147:   }\n148: \n149:   output(\n150:     fmt,\n151:     {\n152:       features: featureData,\n153:       total: features.length,\n154:       effort: formatDuration(totalEffort),\n155:     },\n156:     () => {\n157:       console.log(`\\n${BOLD}Tasks (${features.length} total, ~${formatDuration(totalEffort)} effort)${RESET}\\n`);\n158: \n159:       const statusOrder: FeatureStatus[] = [\n160:         \"in_progress\",\n161:         \"planned\",\n162:         \"backlog\",\n163:         \"blocked\",\n164:         \"in_review\",\n165:         \"done\",\n166:         \"cancelled\",\n167:       ];\n168: \n169:       for (const status of statusOrder) {\n170:         const group = byStatus.get(status);\n171:         if (!group?.length) continue;\n172: \n173:         const color = STATUS_COLOR[status] ?? \"\";\n174:         console.log(`  ${color}${BOLD}${status.toUpperCase()}${RESET} (${group.length})`);\n175: \n176:         for (const f of group) {\n177:           const effort = formatDuration(parseDurationMinutes(f.effort));\n178:           const deps = f.depends_on.length > 0 ? ` ${DIM}deps: ${f.depends_on.join(\", \")}${RESET}` : \"\";\n179:           const completion = f.completion > 0 ? ` ${DIM}${f.completion}%${RESET}` : \"\";\n180:           console.log(\n181:             `    ${color}${f.id}${RESET} — ${f.title} [${f.priority}/${f.difficulty}] (${effort})${completion}${deps}`\n182:           );\n183:         }\n184:         console.log(\"\");\n185:       }\n186:     }\n187:   );\n188: }\n\n(End of file - total 188 lines)\n</content>","title":"src/commands/tasks/list.ts","metadata":{"preview":"/**\n * tasks/list.ts — List and filter tasks from the tasks file.\n *\n * Usage:\n *   woco tasks list                     # list all tasks\n *   woco tasks list --status backlog    # filter by status\n *   woco tasks list --priority high     # filter by priority\n *   woco tasks list --ready             # show only ready tasks\n *   woco tasks list --archive           # include archived tasks\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  getReadyFeatures,\n  featureSummary,\n  formatDuration,\n  parseDurationMinutes,\n  type Feature,\n  type FeatureStatus,","truncated":false,"loaded":[]},"time":{"start":1773435859859,"end":1773435859862}}}}
{"type":"tool_use","timestamp":1773435860369,"sessionID":"ses_316fcbbc9ffe0U7d2IN0Q9PcrR","part":{"id":"prt_ce903b394001BXgxceb50Y29wp","sessionID":"ses_316fcbbc9ffe0U7d2IN0Q9PcrR","messageID":"msg_ce903a623001IQ1aiBEgLPbi54","type":"tool","callID":"toolu_vrtx_0127NWcRo4KHfoaAJZriQa81","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-toon-output-formatter/src/commands/tasks/show.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-toon-output-formatter/src/commands/tasks/show.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tasks/show.ts — Show detailed information about a specific task.\n3:  *\n4:  * Usage:\n5:  *   woco tasks show <task-id>\n6:  */\n7: \n8: import type { WomboConfig } from \"../../config.js\";\n9: import {\n10:   loadFeatures,\n11:   findFeatureById,\n12:   formatDuration,\n13:   parseDurationMinutes,\n14:   areDependenciesMet,\n15:   getDoneFeatureIds,\n16:   type Feature,\n17:   type Subtask,\n18: } from \"../../lib/tasks.js\";\n19: import { output, outputError, filterFields, type OutputFormat } from \"../../lib/output.js\";\n20: \n21: // ---------------------------------------------------------------------------\n22: // Types\n23: // ---------------------------------------------------------------------------\n24: \n25: export interface TasksShowOptions {\n26:   projectRoot: string;\n27:   config: WomboConfig;\n28:   featureId: string;\n29:   outputFmt?: OutputFormat;\n30:   fields?: string[];\n31: }\n32: \n33: // ---------------------------------------------------------------------------\n34: // ANSI Helpers\n35: // ---------------------------------------------------------------------------\n36: \n37: const RESET = \"\\x1b[0m\";\n38: const BOLD = \"\\x1b[1m\";\n39: const DIM = \"\\x1b[2m\";\n40: const GREEN = \"\\x1b[32m\";\n41: const RED = \"\\x1b[31m\";\n42: const YELLOW = \"\\x1b[33m\";\n43: const CYAN = \"\\x1b[36m\";\n44: \n45: // ---------------------------------------------------------------------------\n46: // Display Helpers\n47: // ---------------------------------------------------------------------------\n48: \n49: function statusColor(status: string): string {\n50:   switch (status) {\n51:     case \"done\": return GREEN;\n52:     case \"in_progress\": return CYAN;\n53:     case \"blocked\":\n54:     case \"failed\": return RED;\n55:     case \"cancelled\": return DIM;\n56:     default: return \"\";\n57:   }\n58: }\n59: \n60: function renderSubtask(st: Subtask, indent: number): void {\n61:   const pad = \"  \".repeat(indent);\n62:   const color = statusColor(st.status);\n63:   const effort = formatDuration(parseDurationMinutes(st.effort));\n64:   const completionStr = st.completion > 0 ? ` (${st.completion}%)` : \"\";\n65:   console.log(\n66:     `${pad}${color}[${st.status}]${RESET} ${st.id} — ${st.title} [${st.priority}/${st.difficulty}] (${effort})${completionStr}`\n67:   );\n68:   if (st.subtasks?.length) {\n69:     for (const sub of st.subtasks) {\n70:       renderSubtask(sub, indent + 1);\n71:     }\n72:   }\n73: }\n74: \n75: // ---------------------------------------------------------------------------\n76: // Command\n77: // ---------------------------------------------------------------------------\n78: \n79: export async function cmdTasksShow(opts: TasksShowOptions): Promise<void> {\n80:   const { projectRoot, config } = opts;\n81:   const fmt = opts.outputFmt ?? \"text\";\n82: \n83:   if (!opts.featureId) {\n84:     outputError(fmt, \"Usage: woco tasks show <task-id>\");\n85:     return;\n86:   }\n87: \n88:   const data = loadFeatures(projectRoot, config);\n89:   const feature = findFeatureById(data, opts.featureId);\n90: \n91:   if (!feature) {\n92:     outputError(fmt, `Task \"${opts.featureId}\" not found.`);\n93:     return;\n94:   }\n95: \n96:   const doneIds = getDoneFeatureIds(data);\n97:   const depsMet = areDependenciesMet(feature, doneIds);\n98:   const effort = formatDuration(parseDurationMinutes(feature.effort));\n99: \n100:   const fullData = {\n101:     ...feature,\n102:     deps_met: depsMet,\n103:     effort_formatted: effort,\n104:   };\n105: \n106:   // If --fields is specified, emit only those fields\n107:   if (opts.fields?.length) {\n108:     const filtered = filterFields(fullData as Record<string, unknown>, opts.fields);\n109:     output(fmt, filtered, () => {\n110:       for (const [key, val] of Object.entries(filtered)) {\n111:         const display = Array.isArray(val) ? val.join(\", \") : String(val ?? \"\");\n112:         console.log(`${key}: ${display}`);\n113:       }\n114:     });\n115:     return;\n116:   }\n117: \n118:   output(\n119:     fmt,\n120:     fullData,\n121:     () => {\n122:       console.log(`\\n${BOLD}Task: ${feature.title}${RESET}`);\n123:       console.log(`  ID:          ${feature.id}`);\n124:       console.log(`  Status:      ${statusColor(feature.status)}${feature.status}${RESET}`);\n125:       console.log(`  Priority:    ${feature.priority}`);\n126:       console.log(`  Difficulty:  ${feature.difficulty}`);\n127:       console.log(`  Effort:      ${effort}`);\n128:       console.log(`  Completion:  ${feature.completion}%`);\n129:       console.log(`  Deps met:    ${depsMet ? `${GREEN}yes${RESET}` : `${RED}no${RESET}`}`);\n130: \n131:       if (feature.started_at) {\n132:         console.log(`  Started:     ${feature.started_at}`);\n133:       }\n134:       if (feature.ended_at) {\n135:         console.log(`  Ended:       ${feature.ended_at}`);\n136:       }\n137: \n138:       if (feature.description) {\n139:         console.log(`\\n  ${BOLD}Description:${RESET}`);\n140:         for (const line of feature.description.split(\"\\n\")) {\n141:           console.log(`    ${line}`);\n142:         }\n143:       }\n144: \n145:       if (feature.depends_on.length > 0) {\n146:         console.log(`\\n  ${BOLD}Dependencies:${RESET}`);\n147:         for (const dep of feature.depends_on) {\n148:           const met = doneIds.has(dep);\n149:           const icon = met ? `${GREEN}✓${RESET}` : `${RED}✗${RESET}`;\n150:           console.log(`    ${icon} ${dep}`);\n151:         }\n152:       }\n153: \n154:       if (feature.constraints.length > 0) {\n155:         console.log(`\\n  ${BOLD}Constraints:${RESET}`);\n156:         for (const c of feature.constraints) {\n157:           console.log(`    - ${c}`);\n158:         }\n159:       }\n160: \n161:       if (feature.forbidden.length > 0) {\n162:         console.log(`\\n  ${BOLD}Forbidden:${RESET}`);\n163:         for (const f of feature.forbidden) {\n164:           console.log(`    - ${RED}${f}${RESET}`);\n165:         }\n166:       }\n167: \n168:       if (feature.references.length > 0) {\n169:         console.log(`\\n  ${BOLD}References:${RESET}`);\n170:         for (const r of feature.references) {\n171:           console.log(`    - ${DIM}${r}${RESET}`);\n172:         }\n173:       }\n174: \n175:       if (feature.notes.length > 0) {\n176:         console.log(`\\n  ${BOLD}Notes:${RESET}`);\n177:         for (const n of feature.notes) {\n178:           console.log(`    - ${n}`);\n179:         }\n180:       }\n181: \n182:       if (feature.subtasks.length > 0) {\n183:         console.log(`\\n  ${BOLD}Subtasks (${feature.subtasks.length}):${RESET}`);\n184:         for (const st of feature.subtasks) {\n185:           renderSubtask(st, 2);\n186:         }\n187:       }\n188: \n189:       console.log(\"\");\n190:     }\n191:   );\n192: }\n\n(End of file - total 192 lines)\n</content>","title":"src/commands/tasks/show.ts","metadata":{"preview":"/**\n * tasks/show.ts — Show detailed information about a specific task.\n *\n * Usage:\n *   woco tasks show <task-id>\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  findFeatureById,\n  formatDuration,\n  parseDurationMinutes,\n  areDependenciesMet,\n  getDoneFeatureIds,\n  type Feature,\n  type Subtask,\n} from \"../../lib/tasks.js\";\nimport { output, outputError, filterFields, type OutputFormat } from \"../../lib/output.js\";\n","truncated":false,"loaded":[]},"time":{"start":1773435860366,"end":1773435860368}}}}
{"type":"tool_use","timestamp":1773435860940,"sessionID":"ses_316fcbbc9ffe0U7d2IN0Q9PcrR","part":{"id":"prt_ce903b58f001jhPZ8TssqxRLAC","sessionID":"ses_316fcbbc9ffe0U7d2IN0Q9PcrR","messageID":"msg_ce903a623001IQ1aiBEgLPbi54","type":"tool","callID":"toolu_vrtx_01FZYD3Q5Z55Do1jBQFC1Lr5","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-toon-output-formatter/src/commands/status.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-toon-output-formatter/src/commands/status.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * status.ts — Show the status of the current wave.\n3:  *\n4:  * Usage:\n5:  *   woco status                  # human-readable dashboard\n6:  *   woco status --output json    # structured JSON for programmatic access\n7:  *\n8:  * Loads the wave state, checks for dead processes, and prints a dashboard\n9:  * or emits structured JSON with wave metadata, agent states, timing info,\n10:  * and summary statistics.\n11:  */\n12: \n13: import type { WomboConfig } from \"../config.js\";\n14: import { loadState, saveState, updateAgent, agentCounts, isWaveComplete } from \"../lib/state.js\";\n15: import type { WaveState, AgentState, AgentStatus } from \"../lib/state.js\";\n16: import { isProcessRunning } from \"../lib/launcher.js\";\n17: import { branchHasChanges } from \"../lib/worktree.js\";\n18: import { printDashboard } from \"../lib/ui.js\";\n19: import { output, outputMessage, type OutputFormat } from \"../lib/output.js\";\n20: \n21: export interface StatusOptions {\n22:   projectRoot: string;\n23:   config: WomboConfig;\n24:   outputFmt?: OutputFormat;\n25: }\n26: \n27: // ---------------------------------------------------------------------------\n28: // JSON Output Builder\n29: // ---------------------------------------------------------------------------\n30: \n31: /**\n32:  * Compute elapsed time in milliseconds from a start ISO timestamp to now.\n33:  */\n34: function elapsedMs(startedAt: string | null): number | null {\n35:   if (!startedAt) return null;\n36:   return Date.now() - new Date(startedAt).getTime();\n37: }\n38: \n39: /**\n40:  * Format milliseconds as a human-readable duration string (e.g. \"2h15m\", \"3m\").\n41:  */\n42: function formatElapsed(ms: number | null): string | null {\n43:   if (ms === null) return null;\n44:   const mins = Math.floor(ms / 60000);\n45:   if (mins < 60) return `${mins}m`;\n46:   const hours = Math.floor(mins / 60);\n47:   const remMins = mins % 60;\n48:   return `${hours}h${remMins}m`;\n49: }\n50: \n51: /**\n52:  * Build the structured JSON representation of an agent's state.\n53:  */\n54: function agentToJson(agent: AgentState): Record<string, unknown> {\n55:   const elapsed = elapsedMs(agent.started_at);\n56:   return {\n57:     feature_id: agent.feature_id,\n58:     branch: agent.branch,\n59:     worktree: agent.worktree,\n60:     status: agent.status,\n61:     pid: agent.pid,\n62:     retries: agent.retries,\n63:     max_retries: agent.max_retries,\n64:     started_at: agent.started_at,\n65:     completed_at: agent.completed_at,\n66:     elapsed_ms: elapsed,\n67:     elapsed_formatted: formatElapsed(elapsed),\n68:     build_passed: agent.build_passed,\n69:     error: agent.error,\n70:     activity: agent.activity,\n71:     activity_updated_at: agent.activity_updated_at,\n72:     effort_estimate_ms: agent.effort_estimate_ms,\n73:   };\n74: }\n75: \n76: /**\n77:  * Build the full structured JSON for the wave status.\n78:  * Schema:\n79:  *   {\n80:  *     wave_id: string,\n81:  *     base_branch: string,\n82:  *     started_at: string (ISO 8601),\n83:  *     updated_at: string (ISO 8601),\n84:  *     elapsed_ms: number,\n85:  *     elapsed_formatted: string,\n86:  *     max_concurrent: number,\n87:  *     model: string | null,\n88:  *     interactive: boolean,\n89:  *     is_complete: boolean,\n90:  *     agents: Agent[],\n91:  *     summary: { total, queued, installing, running, completed, verified, failed, merged, retry, resolving_conflict }\n92:  *   }\n93:  */\n94: function buildStatusJson(state: WaveState): Record<string, unknown> {\n95:   const counts = agentCounts(state);\n96:   const waveElapsed = elapsedMs(state.started_at);\n97: \n98:   return {\n99:     wave_id: state.wave_id,\n100:     base_branch: state.base_branch,\n101:     started_at: state.started_at,\n102:     updated_at: state.updated_at,\n103:     elapsed_ms: waveElapsed,\n104:     elapsed_formatted: formatElapsed(waveElapsed),\n105:     max_concurrent: state.max_concurrent,\n106:     model: state.model,\n107:     interactive: state.interactive,\n108:     is_complete: isWaveComplete(state),\n109:     agents: state.agents.map(agentToJson),\n110:     summary: {\n111:       total: state.agents.length,\n112:       ...counts,\n113:     },\n114:   };\n115: }\n116: \n117: // ---------------------------------------------------------------------------\n118: // Command\n119: // ---------------------------------------------------------------------------\n120: \n121: export async function cmdStatus(opts: StatusOptions): Promise<void> {\n122:   const fmt = opts.outputFmt ?? \"text\";\n123:   const state = loadState(opts.projectRoot);\n124: \n125:   if (!state) {\n126:     outputMessage(fmt, \"No active wave. Use 'woco launch' to start one.\", {\n127:       wave_id: null,\n128:       agents: [],\n129:       summary: { total: 0 },\n130:     });\n131:     return;\n132:   }\n133: \n134:   // Update running agent status from process state\n135:   for (const agent of state.agents) {\n136:     if (agent.status === \"running\" && agent.pid) {\n137:       if (!isProcessRunning(agent.pid)) {\n138:         // Check if the agent actually made any commits before marking completed\n139:         if (branchHasChanges(opts.projectRoot, agent.branch, state.base_branch)) {\n140:           updateAgent(state, agent.feature_id, {\n141:             status: \"completed\",\n142:             completed_at: new Date().toISOString(),\n143:           });\n144:         } else {\n145:           // Agent died without producing any code — mark as failed, not completed\n146:           updateAgent(state, agent.feature_id, {\n147:             status: \"failed\",\n148:             error: \"Agent process exited without making any commits\",\n149:             completed_at: new Date().toISOString(),\n150:           });\n151:         }\n152:       }\n153:     }\n154:   }\n155: \n156:   // Repair pass: re-check agents marked \"completed\" but never verified.\n157:   // Catches agents falsely promoted to completed by older versions of status.ts\n158:   // that didn't check branchHasChanges.\n159:   for (const agent of state.agents) {\n160:     if (agent.status === \"completed\" && agent.build_passed === null) {\n161:       if (!branchHasChanges(opts.projectRoot, agent.branch, state.base_branch)) {\n162:         updateAgent(state, agent.feature_id, {\n163:           status: \"failed\",\n164:           error: \"Agent process exited without making any commits\",\n165:         });\n166:       }\n167:     }\n168:   }\n169:   saveState(opts.projectRoot, state);\n170: \n171:   output(fmt, buildStatusJson(state), () => {\n172:     printDashboard(state);\n173:   });\n174: }\n\n(End of file - total 174 lines)\n</content>","title":"src/commands/status.ts","metadata":{"preview":"/**\n * status.ts — Show the status of the current wave.\n *\n * Usage:\n *   woco status                  # human-readable dashboard\n *   woco status --output json    # structured JSON for programmatic access\n *\n * Loads the wave state, checks for dead processes, and prints a dashboard\n * or emits structured JSON with wave metadata, agent states, timing info,\n * and summary statistics.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport { loadState, saveState, updateAgent, agentCounts, isWaveComplete } from \"../lib/state.js\";\nimport type { WaveState, AgentState, AgentStatus } from \"../lib/state.js\";\nimport { isProcessRunning } from \"../lib/launcher.js\";\nimport { branchHasChanges } from \"../lib/worktree.js\";\nimport { printDashboard } from \"../lib/ui.js\";\nimport { output, outputMessage, type OutputFormat } from \"../lib/output.js\";\n","truncated":false,"loaded":[]},"time":{"start":1773435860937,"end":1773435860939}}}}
{"type":"tool_use","timestamp":1773435861212,"sessionID":"ses_316fcbbc9ffe0U7d2IN0Q9PcrR","part":{"id":"prt_ce903b7ca0010Dfu8t2e6t5Bqr","sessionID":"ses_316fcbbc9ffe0U7d2IN0Q9PcrR","messageID":"msg_ce903a623001IQ1aiBEgLPbi54","type":"tool","callID":"toolu_vrtx_01HtdZ5EE77rk4xscEHzxvjs","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-toon-output-formatter/src/commands/verify.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-toon-output-formatter/src/commands/verify.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * verify.ts — Run build verification on completed agents.\n3:  *\n4:  * Usage: woco verify [feature-id] [--browser]\n5:  *\n6:  * Runs the build command in each completed agent's worktree. If a specific\n7:  * feature-id is given, verifies only that agent. Otherwise verifies all\n8:  * agents with status \"completed\".\n9:  *\n10:  * When --browser is passed (or browser.enabled is true in config), also\n11:  * runs browser-based verification after the build passes.\n12:  */\n13: \n14: import type { WomboConfig } from \"../config.js\";\n15: import { loadFeatures, type Feature } from \"../lib/tasks.js\";\n16: import { loadState, saveState } from \"../lib/state.js\";\n17: import { printDashboard } from \"../lib/ui.js\";\n18: import { handleBuildVerification } from \"./launch.js\";\n19: \n20: // ---------------------------------------------------------------------------\n21: // Types\n22: // ---------------------------------------------------------------------------\n23: \n24: export interface VerifyCommandOptions {\n25:   projectRoot: string;\n26:   config: WomboConfig;\n27:   featureId?: string;\n28:   model?: string;\n29:   maxRetries?: number;\n30:   /** Enable browser verification (overrides config.browser.enabled) */\n31:   browserVerify?: boolean;\n32: }\n33: \n34: // ---------------------------------------------------------------------------\n35: // Command\n36: // ---------------------------------------------------------------------------\n37: \n38: export async function cmdVerify(opts: VerifyCommandOptions): Promise<void> {\n39:   const { projectRoot, config } = opts;\n40: \n41:   // Apply browser verification override if --browser flag was passed\n42:   if (opts.browserVerify !== undefined) {\n43:     config.browser.enabled = opts.browserVerify;\n44:   }\n45: \n46:   const state = loadState(projectRoot);\n47:   if (!state) {\n48:     console.log(\"No active wave.\");\n49:     return;\n50:   }\n51: \n52:   const toVerify = opts.featureId\n53:     ? state.agents.filter((a) => a.feature_id === opts.featureId)\n54:     : state.agents.filter((a) => a.status === \"completed\");\n55: \n56:   if (toVerify.length === 0) {\n57:     console.log(\"No agents to verify.\");\n58:     return;\n59:   }\n60: \n61:   console.log(`\\nVerifying ${toVerify.length} agent(s)...\\n`);\n62: \n63:   const data = loadFeatures(projectRoot, config);\n64: \n65:   for (const agent of toVerify) {\n66:     const feature = data.tasks.find((f: Feature) => f.id === agent.feature_id);\n67:     if (!feature) continue;\n68: \n69:     await handleBuildVerification(projectRoot, state, agent, feature, config, opts.model);\n70:   }\n71: \n72:   printDashboard(state);\n73: }\n\n(End of file - total 73 lines)\n</content>","title":"src/commands/verify.ts","metadata":{"preview":"/**\n * verify.ts — Run build verification on completed agents.\n *\n * Usage: woco verify [feature-id] [--browser]\n *\n * Runs the build command in each completed agent's worktree. If a specific\n * feature-id is given, verifies only that agent. Otherwise verifies all\n * agents with status \"completed\".\n *\n * When --browser is passed (or browser.enabled is true in config), also\n * runs browser-based verification after the build passes.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport { loadFeatures, type Feature } from \"../lib/tasks.js\";\nimport { loadState, saveState } from \"../lib/state.js\";\nimport { printDashboard } from \"../lib/ui.js\";\nimport { handleBuildVerification } from \"./launch.js\";\n\n// ---------------------------------------------------------------------------","truncated":false,"loaded":[]},"time":{"start":1773435861210,"end":1773435861212}}}}
