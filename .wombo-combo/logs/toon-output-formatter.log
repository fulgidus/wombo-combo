{"type":"tool_use","timestamp":1773436088293,"sessionID":"ses_316fcbbc9ffe0U7d2IN0Q9PcrR","part":{"id":"prt_ce9072ef2001XB6jLrPTB7rWNq","sessionID":"ses_316fcbbc9ffe0U7d2IN0Q9PcrR","messageID":"msg_ce9072394001zuEoWz66L3tx1Y","type":"tool","callID":"toolu_vrtx_011M4azxiS8EcazRBUaquAZh","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-toon-output-formatter/src/commands/logs.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-toon-output-formatter/src/commands/logs.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * logs.ts — Pretty-print agent logs from .wombo-combo/logs/<feature-id>.log.\n3:  *\n4:  * Usage:\n5:  *   woco logs <feature-id>\n6:  *   woco logs <feature-id> --tail 50\n7:  *   woco logs <feature-id> --follow\n8:  *   woco logs <feature-id> --output json\n9:  *\n10:  * Reads the log file written by ProcessMonitor during headless agent runs\n11:  * and displays it with timestamps and activity annotations. Supports\n12:  * --tail N to show last N lines and --follow to stream new output.\n13:  */\n14: \n15: import { resolve } from \"node:path\";\n16: import { existsSync, readFileSync, statSync, openSync, readSync, closeSync } from \"node:fs\";\n17: import { output, outputError, type OutputFormat } from \"../lib/output.js\";\n18: \n19: // ---------------------------------------------------------------------------\n20: // Constants\n21: // ---------------------------------------------------------------------------\n22: \n23: const LOG_DIR_NAME = \".wombo-combo/logs\";\n24: \n25: // ---------------------------------------------------------------------------\n26: // Types\n27: // ---------------------------------------------------------------------------\n28: \n29: export interface LogsCommandOptions {\n30:   projectRoot: string;\n31:   featureId: string;\n32:   /** Show only the last N lines */\n33:   tail?: number;\n34:   /** Stream new output as it arrives (like tail -f) */\n35:   follow?: boolean;\n36:   /** Output format */\n37:   outputFmt: OutputFormat;\n38: }\n39: \n40: interface LogLine {\n41:   lineNumber: number;\n42:   content: string;\n43: }\n44: \n45: // ---------------------------------------------------------------------------\n46: // Helpers\n47: // ---------------------------------------------------------------------------\n48: \n49: /**\n50:  * Read all lines from a log file, optionally returning only the last N.\n51:  */\n52: function readLogLines(logPath: string, tail?: number): LogLine[] {\n53:   const raw = readFileSync(logPath, \"utf-8\");\n54:   const allLines = raw.split(\"\\n\");\n55: \n56:   // Remove trailing empty line from split (if file ends with \\n)\n57:   if (allLines.length > 0 && allLines[allLines.length - 1] === \"\") {\n58:     allLines.pop();\n59:   }\n60: \n61:   let lines: LogLine[] = allLines.map((content, idx) => ({\n62:     lineNumber: idx + 1,\n63:     content,\n64:   }));\n65: \n66:   if (tail !== undefined && tail > 0 && lines.length > tail) {\n67:     lines = lines.slice(-tail);\n68:   }\n69: \n70:   return lines;\n71: }\n72: \n73: /**\n74:  * Colorize a log line for terminal output.\n75:  * Detects common patterns: timestamps, errors, warnings, tool calls, etc.\n76:  */\n77: function colorize(line: string): string {\n78:   // Error lines\n79:   if (/\\b(error|fatal|fail(ed)?|exception)\\b/i.test(line)) {\n80:     return `\\x1b[31m${line}\\x1b[0m`;\n81:   }\n82:   // Warning lines\n83:   if (/\\b(warn(ing)?|deprecated)\\b/i.test(line)) {\n84:     return `\\x1b[33m${line}\\x1b[0m`;\n85:   }\n86:   // Success / done lines\n87:   if (/\\b(success|done|passed|completed|merged)\\b/i.test(line)) {\n88:     return `\\x1b[32m${line}\\x1b[0m`;\n89:   }\n90:   // Activity annotations from ProcessMonitor (timestamps like HH:MM:SS)\n91:   if (/^\\d{2}:\\d{2}:\\d{2}\\s/.test(line)) {\n92:     const tsEnd = 8;\n93:     return `\\x1b[36m${line.slice(0, tsEnd)}\\x1b[0m${line.slice(tsEnd)}`;\n94:   }\n95:   return line;\n96: }\n97: \n98: /**\n99:  * Render log lines in text mode with pretty-printing.\n100:  */\n101: function renderText(lines: LogLine[], featureId: string, logPath: string): void {\n102:   if (lines.length === 0) {\n103:     console.log(`\\x1b[33mLog file is empty: ${logPath}\\x1b[0m`);\n104:     return;\n105:   }\n106: \n107:   console.log(`\\x1b[1m--- Logs for ${featureId} ---\\x1b[0m`);\n108:   console.log(`\\x1b[2mFile: ${logPath}\\x1b[0m`);\n109:   console.log(`\\x1b[2mLines: ${lines[0].lineNumber}–${lines[lines.length - 1].lineNumber}\\x1b[0m`);\n110:   console.log();\n111: \n112:   for (const line of lines) {\n113:     console.log(colorize(line.content));\n114:   }\n115: }\n116: \n117: /**\n118:  * Render log lines in JSON mode.\n119:  */\n120: function renderJson(lines: LogLine[], featureId: string, logPath: string): void {\n121:   const data = {\n122:     feature_id: featureId,\n123:     log_file: logPath,\n124:     line_count: lines.length,\n125:     first_line: lines.length > 0 ? lines[0].lineNumber : null,\n126:     last_line: lines.length > 0 ? lines[lines.length - 1].lineNumber : null,\n127:     lines: lines.map((l) => l.content),\n128:   };\n129:   console.log(JSON.stringify(data));\n130: }\n131: \n132: /**\n133:  * Follow a log file, printing new content as it appears (like tail -f).\n134:  * Runs until the process is interrupted.\n135:  */\n136: async function followLog(\n137:   logPath: string,\n138:   featureId: string,\n139:   outputFmt: OutputFormat,\n140:   tail?: number\n141: ): Promise<void> {\n142:   // First, print existing content (or tail)\n143:   if (existsSync(logPath)) {\n144:     const lines = readLogLines(logPath, tail);\n145:     if (outputFmt === \"json\") {\n146:       // In follow + json mode, emit each new batch as a JSON line\n147:       for (const line of lines) {\n148:         console.log(JSON.stringify({ feature_id: featureId, line: line.content, line_number: line.lineNumber }));\n149:       }\n150:     } else {\n151:       console.log(`\\x1b[1m--- Following logs for ${featureId} (Ctrl+C to stop) ---\\x1b[0m`);\n152:       console.log(`\\x1b[2mFile: ${logPath}\\x1b[0m`);\n153:       console.log();\n154:       for (const line of lines) {\n155:         console.log(colorize(line.content));\n156:       }\n157:     }\n158:   } else {\n159:     if (outputFmt === \"text\") {\n160:       console.log(`\\x1b[1m--- Following logs for ${featureId} (Ctrl+C to stop) ---\\x1b[0m`);\n161:       console.log(`\\x1b[33mWaiting for log file to appear...\\x1b[0m`);\n162:     }\n163:   }\n164: \n165:   // Now poll for new content\n166:   let offset = 0;\n167:   try {\n168:     if (existsSync(logPath)) {\n169:       const stat = statSync(logPath);\n170:       offset = stat.size;\n171:     }\n172:   } catch {\n173:     // File may not exist yet — we'll start from 0\n174:   }\n175: \n176:   const POLL_INTERVAL = 250; // ms\n177:   let lineNumber = 0;\n178:   if (existsSync(logPath)) {\n179:     const raw = readFileSync(logPath, \"utf-8\");\n180:     lineNumber = raw.split(\"\\n\").length - 1;\n181:   }\n182: \n183:   let buffer = \"\";\n184: \n185:   // Keep running until SIGINT\n186:   const running = { value: true };\n187:   const cleanup = () => {\n188:     running.value = false;\n189:   };\n190:   process.on(\"SIGINT\", cleanup);\n191:   process.on(\"SIGTERM\", cleanup);\n192: \n193:   try {\n194:     while (running.value) {\n195:       await new Promise((r) => setTimeout(r, POLL_INTERVAL));\n196: \n197:       if (!existsSync(logPath)) continue;\n198: \n199:       let currentSize: number;\n200:       try {\n201:         const stat = statSync(logPath);\n202:         currentSize = stat.size;\n203:       } catch {\n204:         continue;\n205:       }\n206: \n207:       if (currentSize <= offset) continue;\n208: \n209:       // Read new bytes\n210:       const bytesToRead = currentSize - offset;\n211:       const buf = Buffer.alloc(bytesToRead);\n212:       let fd: number | null = null;\n213:       try {\n214:         fd = openSync(logPath, \"r\");\n215:         readSync(fd, buf, 0, bytesToRead, offset);\n216:       } catch {\n217:         continue;\n218:       } finally {\n219:         if (fd !== null) closeSync(fd);\n220:       }\n221: \n222:       offset = currentSize;\n223:       buffer += buf.toString(\"utf-8\");\n224: \n225:       // Process complete lines\n226:       const parts = buffer.split(\"\\n\");\n227:       // Keep the last incomplete part in the buffer\n228:       buffer = parts.pop() ?? \"\";\n229: \n230:       for (const part of parts) {\n231:         lineNumber++;\n232:         if (outputFmt === \"json\") {\n233:           console.log(JSON.stringify({ feature_id: featureId, line: part, line_number: lineNumber }));\n234:         } else {\n235:           console.log(colorize(part));\n236:         }\n237:       }\n238:     }\n239:   } finally {\n240:     process.removeListener(\"SIGINT\", cleanup);\n241:     process.removeListener(\"SIGTERM\", cleanup);\n242:   }\n243: \n244:   if (outputFmt === \"text\") {\n245:     console.log(`\\n\\x1b[2m--- Stopped following ${featureId} ---\\x1b[0m`);\n246:   }\n247: }\n248: \n249: // ---------------------------------------------------------------------------\n250: // Command\n251: // ---------------------------------------------------------------------------\n252: \n253: export async function cmdLogs(opts: LogsCommandOptions): Promise<void> {\n254:   const { projectRoot, featureId, tail, follow, outputFmt } = opts;\n255: \n256:   const logPath = resolve(projectRoot, LOG_DIR_NAME, `${featureId}.log`);\n257: \n258:   // If following, we don't require the file to exist yet (it may be created)\n259:   if (follow) {\n260:     await followLog(logPath, featureId, outputFmt, tail);\n261:     return;\n262:   }\n263: \n264:   // For non-follow mode, the file must exist\n265:   if (!existsSync(logPath)) {\n266:     outputError(\n267:       outputFmt,\n268:       `Log file not found: ${logPath}\\n` +\n269:         `No logs exist for feature \"${featureId}\". ` +\n270:         `Logs are created when agents run in headless mode.\\n` +\n271:         `Hint: Check .wombo-combo/logs/ for available log files, or run 'woco launch' first.`\n272:     );\n273:   }\n274: \n275:   const lines = readLogLines(logPath, tail);\n276: \n277:   output(outputFmt, {\n278:     feature_id: featureId,\n279:     log_file: logPath,\n280:     line_count: lines.length,\n281:     first_line: lines.length > 0 ? lines[0].lineNumber : null,\n282:     last_line: lines.length > 0 ? lines[lines.length - 1].lineNumber : null,\n283:     lines: lines.map((l) => l.content),\n284:   }, () => {\n285:     renderText(lines, featureId, logPath);\n286:   });\n287: }\n\n(End of file - total 287 lines)\n</content>","title":"src/commands/logs.ts","metadata":{"preview":"/**\n * logs.ts — Pretty-print agent logs from .wombo-combo/logs/<feature-id>.log.\n *\n * Usage:\n *   woco logs <feature-id>\n *   woco logs <feature-id> --tail 50\n *   woco logs <feature-id> --follow\n *   woco logs <feature-id> --output json\n *\n * Reads the log file written by ProcessMonitor during headless agent runs\n * and displays it with timestamps and activity annotations. Supports\n * --tail N to show last N lines and --follow to stream new output.\n */\n\nimport { resolve } from \"node:path\";\nimport { existsSync, readFileSync, statSync, openSync, readSync, closeSync } from \"node:fs\";\nimport { output, outputError, type OutputFormat } from \"../lib/output.js\";\n\n// ---------------------------------------------------------------------------\n// Constants","truncated":false,"loaded":[]},"time":{"start":1773436088289,"end":1773436088292}}}}
{"type":"tool_use","timestamp":1773436088880,"sessionID":"ses_316fcbbc9ffe0U7d2IN0Q9PcrR","part":{"id":"prt_ce9072fe2001l1XbQ7cB4Hqbzf","sessionID":"ses_316fcbbc9ffe0U7d2IN0Q9PcrR","messageID":"msg_ce9072394001zuEoWz66L3tx1Y","type":"tool","callID":"toolu_vrtx_01RrshYe9PvdaD2NwoRnpxZg","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-toon-output-formatter/src/commands/abort.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-toon-output-formatter/src/commands/abort.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * abort.ts — Kill a single running agent without nuking the entire wave.\n3:  *\n4:  * Usage: woco abort <feature-id> [--requeue] [--output json]\n5:  *\n6:  * Kills the multiplexer session (if any) and the agent process, then updates\n7:  * wave state to mark the agent as \"failed\" (default) or \"queued\"\n8:  * (if --requeue is passed, returning it to the queue for retry).\n9:  */\n10: \n11: import type { WomboConfig } from \"../config.js\";\n12: import {\n13:   loadState,\n14:   saveState,\n15:   updateAgent,\n16:   type AgentState,\n17: } from \"../lib/state.js\";\n18: import {\n19:   killMuxSession,\n20:   getMultiplexerName,\n21:   isProcessRunning,\n22: } from \"../lib/launcher.js\";\n23: import { output, outputError, type OutputFormat } from \"../lib/output.js\";\n24: \n25: // ---------------------------------------------------------------------------\n26: // Types\n27: // ---------------------------------------------------------------------------\n28: \n29: export interface AbortCommandOptions {\n30:   projectRoot: string;\n31:   config: WomboConfig;\n32:   featureId: string;\n33:   /** Return the feature to \"queued\" instead of marking it \"failed\" */\n34:   requeue?: boolean;\n35:   outputFmt: OutputFormat;\n36: }\n37: \n38: // ---------------------------------------------------------------------------\n39: // Command\n40: // ---------------------------------------------------------------------------\n41: \n42: export async function cmdAbort(opts: AbortCommandOptions): Promise<void> {\n43:   const { projectRoot, config, featureId, outputFmt } = opts;\n44: \n45:   // Load wave state\n46:   const state = loadState(projectRoot);\n47:   if (!state) {\n48:     outputError(outputFmt, \"No active wave. Nothing to abort.\");\n49:   }\n50: \n51:   // Find the agent\n52:   const agent = state.agents.find((a: AgentState) => a.feature_id === featureId);\n53:   if (!agent) {\n54:     outputError(\n55:       outputFmt,\n56:       `Agent not found for feature: ${featureId}. Use 'woco status' to see active agents.`\n57:     );\n58:   }\n59: \n60:   // Only abort agents that are actually active (running, installing, queued, resolving_conflict)\n61:   const abortable = new Set([\"running\", \"installing\", \"queued\", \"resolving_conflict\"]);\n62:   if (!abortable.has(agent.status)) {\n63:     outputError(\n64:       outputFmt,\n65:       `Agent ${featureId} is not in an abortable state (current: ${agent.status}). ` +\n66:         `Only running, installing, queued, or resolving_conflict agents can be aborted.`\n67:     );\n68:   }\n69: \n70:   // 1. Kill the multiplexer session (if any)\n71:   let muxKilled = false;\n72:   try {\n73:     killMuxSession(featureId, config);\n74:     muxKilled = true;\n75:   } catch {\n76:     // Session may not exist — that's fine\n77:   }\n78: \n79:   // 2. Kill the process by PID (if any and still running)\n80:   let processKilled = false;\n81:   if (agent.pid && isProcessRunning(agent.pid)) {\n82:     try {\n83:       process.kill(agent.pid, \"SIGTERM\");\n84:       processKilled = true;\n85:     } catch {\n86:       // Process may have already exited\n87:     }\n88:   }\n89: \n90:   // 3. Update wave state\n91:   const newStatus = opts.requeue ? \"queued\" : \"failed\";\n92:   const updates: Partial<AgentState> = {\n93:     status: newStatus as AgentState[\"status\"],\n94:     error: opts.requeue ? null : \"Aborted by user\",\n95:     completed_at: opts.requeue ? null : new Date().toISOString(),\n96:   };\n97: \n98:   // If requeuing, reset retry-related fields so the agent gets a fresh start\n99:   if (opts.requeue) {\n100:     updates.retries = 0;\n101:     updates.build_passed = null;\n102:     updates.build_output = null;\n103:     updates.started_at = null;\n104:     updates.completed_at = null;\n105:     updates.activity = null;\n106:     updates.activity_updated_at = null;\n107:   }\n108: \n109:   updateAgent(state, featureId, updates);\n110:   saveState(projectRoot, state);\n111: \n112:   // 4. Output result\n113:   const muxName = getMultiplexerName(config);\n114:   const result = {\n115:     feature_id: featureId,\n116:     previous_status: agent.status,\n117:     new_status: newStatus,\n118:     mux_killed: muxKilled,\n119:     process_killed: processKilled,\n120:     requeued: !!opts.requeue,\n121:   };\n122: \n123:   output(outputFmt, result, () => {\n124:     console.log(`\\nAborted agent: ${featureId}`);\n125:     console.log(`  Previous status: ${agent.status}`);\n126:     console.log(`  New status: ${newStatus}`);\n127:     if (muxKilled) console.log(`  Killed ${muxName} session: ${config.agent.tmuxPrefix}-${featureId}`);\n128:     if (processKilled) console.log(`  Killed process: PID ${agent.pid}`);\n129:     if (opts.requeue) {\n130:       console.log(`  Feature returned to queue for retry.`);\n131:     } else {\n132:       console.log(`  Feature marked as failed.`);\n133:     }\n134:   });\n135: }\n\n(End of file - total 135 lines)\n</content>","title":"src/commands/abort.ts","metadata":{"preview":"/**\n * abort.ts — Kill a single running agent without nuking the entire wave.\n *\n * Usage: woco abort <feature-id> [--requeue] [--output json]\n *\n * Kills the multiplexer session (if any) and the agent process, then updates\n * wave state to mark the agent as \"failed\" (default) or \"queued\"\n * (if --requeue is passed, returning it to the queue for retry).\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport {\n  loadState,\n  saveState,\n  updateAgent,\n  type AgentState,\n} from \"../lib/state.js\";\nimport {\n  killMuxSession,\n  getMultiplexerName,","truncated":false,"loaded":[]},"time":{"start":1773436088877,"end":1773436088880}}}}
{"type":"text","timestamp":1773436089084,"sessionID":"ses_316fcbbc9ffe0U7d2IN0Q9PcrR","part":{"id":"prt_ce9072b2d002obmZVdLcPAzhfm","sessionID":"ses_316fcbbc9ffe0U7d2IN0Q9PcrR","messageID":"msg_ce9072394001zuEoWz66L3tx1Y","type":"text","text":"Now let me also check the other files that use `output()` - `logs.ts`, `abort.ts`, `graph.ts`:","time":{"start":1773436089084,"end":1773436089084}}}
{"type":"tool_use","timestamp":1773436089087,"sessionID":"ses_316fcbbc9ffe0U7d2IN0Q9PcrR","part":{"id":"prt_ce907322e001Tmo324W6BJmihe","sessionID":"ses_316fcbbc9ffe0U7d2IN0Q9PcrR","messageID":"msg_ce9072394001zuEoWz66L3tx1Y","type":"tool","callID":"toolu_vrtx_01CGoeBXBVhbK5nvz1zJ9oHh","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-toon-output-formatter/src/commands/tasks/graph.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-toon-output-formatter/src/commands/tasks/graph.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tasks/graph.ts — Visualize the task dependency graph.\n3:  *\n4:  * Usage:\n5:  *   woco tasks graph                     # show full dependency graph\n6:  *   woco tasks graph --status backlog    # filter by status\n7:  *   woco tasks graph --ascii             # ASCII-only rendering\n8:  *   woco tasks graph --output json       # emit mermaid source as JSON\n9:  *   woco tasks graph --mermaid           # emit raw mermaid source text\n10:  *   woco tasks graph --subtasks          # include subtask-level nodes\n11:  *\n12:  * Builds a Mermaid flowchart from the tasks dependency graph and renders\n13:  * it as a Unicode box diagram in the terminal using mermaidtui.\n14:  */\n15: \n16: import type { WomboConfig } from \"../../config.js\";\n17: import {\n18:   loadFeatures,\n19:   type Feature,\n20:   type Subtask,\n21:   type FeatureStatus,\n22:   type FeaturesFile,\n23: } from \"../../lib/tasks.js\";\n24: import { output, type OutputFormat } from \"../../lib/output.js\";\n25: \n26: // mermaidtui has no type declarations — import the JS module directly\n27: // @ts-ignore — no .d.ts published\n28: import { renderMermaidToTui } from \"mermaidtui\";\n29: \n30: // ---------------------------------------------------------------------------\n31: // Types\n32: // ---------------------------------------------------------------------------\n33: \n34: export interface TasksGraphOptions {\n35:   projectRoot: string;\n36:   config: WomboConfig;\n37:   status?: FeatureStatus;\n38:   ascii?: boolean;\n39:   mermaid?: boolean;\n40:   subtasks?: boolean;\n41:   outputFmt?: OutputFormat;\n42: }\n43: \n44: // ---------------------------------------------------------------------------\n45: // Status styling for Mermaid classDef\n46: // ---------------------------------------------------------------------------\n47: \n48: // Short status badge for node labels\n49: const STATUS_BADGE: Record<FeatureStatus, string> = {\n50:   backlog: \"BL\",\n51:   planned: \"PL\",\n52:   in_progress: \"IP\",\n53:   blocked: \"BK\",\n54:   in_review: \"IR\",\n55:   done: \"DN\",\n56:   cancelled: \"XX\",\n57: };\n58: \n59: // ---------------------------------------------------------------------------\n60: // Mermaid generation\n61: // ---------------------------------------------------------------------------\n62: \n63: /**\n64:  * Sanitize a string for use inside Mermaid labels.\n65:  * Mermaid uses square brackets for labels — we need to escape them.\n66:  */\n67: function sanitizeLabel(s: string): string {\n68:   return s\n69:     .replace(/\"/g, \"'\")\n70:     .replace(/\\[/g, \"(\")\n71:     .replace(/\\]/g, \")\")\n72:     .replace(/\\n/g, \" \")\n73:     .slice(0, 40); // keep labels short for terminal rendering\n74: }\n75: \n76: /**\n77:  * Generate a safe Mermaid node ID from a feature/subtask ID.\n78:  * Mermaid IDs can't start with numbers and some chars are reserved.\n79:  */\n80: function nodeId(id: string): string {\n81:   return `n_${id.replace(/-/g, \"_\")}`;\n82: }\n83: \n84: /**\n85:  * Collect all node IDs that exist in the graph (for filtering dangling deps).\n86:  */\n87: function collectAllIds(\n88:   features: Feature[],\n89:   includeSubtasks: boolean\n90: ): Set<string> {\n91:   const ids = new Set<string>();\n92:   for (const f of features) {\n93:     ids.add(f.id);\n94:     if (includeSubtasks) {\n95:       collectSubtaskIds(f.subtasks, ids);\n96:     }\n97:   }\n98:   return ids;\n99: }\n100: \n101: function collectSubtaskIds(subtasks: Subtask[], ids: Set<string>): void {\n102:   for (const st of subtasks) {\n103:     ids.add(st.id);\n104:     collectSubtaskIds(st.subtasks, ids);\n105:   }\n106: }\n107: \n108: /**\n109:  * Build the Mermaid flowchart source from the features file.\n110:  * Only includes nodes that participate in at least one dependency edge.\n111:  * Orphan nodes (no deps and nothing depends on them) are excluded from\n112:  * the visual graph and returned separately for a compact summary.\n113:  */\n114: function buildMermaidSource(\n115:   data: FeaturesFile,\n116:   opts: { status?: FeatureStatus; subtasks?: boolean }\n117: ): { source: string; nodeCount: number; edgeCount: number; orphanCount: number; orphans: { id: string; title: string; status: FeatureStatus }[] } {\n118:   let features = [...data.tasks];\n119: \n120:   // Filter by status if requested\n121:   if (opts.status) {\n122:     features = features.filter((f) => f.status === opts.status);\n123:   }\n124: \n125:   if (features.length === 0) {\n126:     return { source: \"\", nodeCount: 0, edgeCount: 0, orphanCount: 0, orphans: [] };\n127:   }\n128: \n129:   const allIds = collectAllIds(features, !!opts.subtasks);\n130: \n131:   // --- First pass: collect all edges to determine connected nodes ---\n132:   const connectedIds = new Set<string>();\n133:   const edges: { from: string; to: string }[] = [];\n134: \n135:   for (const f of features) {\n136:     // Feature-level dependency edges\n137:     for (const dep of f.depends_on) {\n138:       if (allIds.has(dep)) {\n139:         edges.push({ from: dep, to: f.id });\n140:         connectedIds.add(dep);\n141:         connectedIds.add(f.id);\n142:       }\n143:     }\n144: \n145:     // Subtask edges (parent->child + subtask depends_on)\n146:     if (opts.subtasks && f.subtasks.length > 0) {\n147:       collectSubtaskEdges(f.subtasks, f.id, allIds, edges, connectedIds);\n148:     }\n149:   }\n150: \n151:   // If there are no edges at all, every feature is an orphan\n152:   if (edges.length === 0) {\n153:     const orphans = features.map((f) => ({ id: f.id, title: f.title, status: f.status }));\n154:     return { source: \"\", nodeCount: 0, edgeCount: 0, orphanCount: orphans.length, orphans };\n155:   }\n156: \n157:   // --- Second pass: emit only connected nodes and edges ---\n158:   const lines: string[] = [\"flowchart LR\"];\n159:   let nodeCount = 0;\n160:   const emittedNodes = new Set<string>();\n161:   const orphans: { id: string; title: string; status: FeatureStatus }[] = [];\n162: \n163:   // Helper to emit a node if it's connected and not yet emitted\n164:   const emitNode = (id: string, label: string) => {\n165:     if (!emittedNodes.has(id)) {\n166:       lines.push(`    ${nodeId(id)}[${label}]`);\n167:       emittedNodes.add(id);\n168:       nodeCount++;\n169:     }\n170:   };\n171: \n172:   for (const f of features) {\n173:     if (connectedIds.has(f.id)) {\n174:       const badge = STATUS_BADGE[f.status];\n175:       emitNode(f.id, `${badge} ${sanitizeLabel(f.title)}`);\n176:     } else if (!opts.subtasks || f.subtasks.length === 0) {\n177:       // Feature has no deps and nothing depends on it — it's an orphan\n178:       orphans.push({ id: f.id, title: f.title, status: f.status });\n179:     }\n180: \n181:     // Emit connected subtask nodes\n182:     if (opts.subtasks && f.subtasks.length > 0) {\n183:       emitConnectedSubtasks(f.subtasks, connectedIds, emittedNodes, emitNode, orphans);\n184:     }\n185:   }\n186: \n187:   // Emit all edges\n188:   for (const edge of edges) {\n189:     lines.push(`    ${nodeId(edge.from)} --> ${nodeId(edge.to)}`);\n190:   }\n191: \n192:   return {\n193:     source: lines.join(\"\\n\"),\n194:     nodeCount,\n195:     edgeCount: edges.length,\n196:     orphanCount: orphans.length,\n197:     orphans,\n198:   };\n199: }\n200: \n201: /**\n202:  * Recursively collect edges from subtasks (parent->child links + depends_on edges).\n203:  */\n204: function collectSubtaskEdges(\n205:   subtasks: Subtask[],\n206:   parentId: string,\n207:   allIds: Set<string>,\n208:   edges: { from: string; to: string }[],\n209:   connectedIds: Set<string>\n210: ): void {\n211:   for (const st of subtasks) {\n212:     // Parent -> subtask link always creates an edge\n213:     edges.push({ from: parentId, to: st.id });\n214:     connectedIds.add(parentId);\n215:     connectedIds.add(st.id);\n216: \n217:     // Subtask's own dependencies\n218:     for (const dep of st.depends_on) {\n219:       if (allIds.has(dep)) {\n220:         edges.push({ from: dep, to: st.id });\n221:         connectedIds.add(dep);\n222:         connectedIds.add(st.id);\n223:       }\n224:     }\n225: \n226:     // Recurse into nested subtasks\n227:     if (st.subtasks.length > 0) {\n228:       collectSubtaskEdges(st.subtasks, st.id, allIds, edges, connectedIds);\n229:     }\n230:   }\n231: }\n232: \n233: /**\n234:  * Emit subtask nodes that are connected, collect orphans.\n235:  */\n236: function emitConnectedSubtasks(\n237:   subtasks: Subtask[],\n238:   connectedIds: Set<string>,\n239:   emittedNodes: Set<string>,\n240:   emitNode: (id: string, label: string) => void,\n241:   orphans: { id: string; title: string; status: FeatureStatus }[]\n242: ): void {\n243:   for (const st of subtasks) {\n244:     if (connectedIds.has(st.id)) {\n245:       const badge = STATUS_BADGE[st.status];\n246:       emitNode(st.id, `${badge} ${sanitizeLabel(st.title)}`);\n247:     } else {\n248:       orphans.push({ id: st.id, title: st.title, status: st.status });\n249:     }\n250: \n251:     if (st.subtasks.length > 0) {\n252:       emitConnectedSubtasks(st.subtasks, connectedIds, emittedNodes, emitNode, orphans);\n253:     }\n254:   }\n255: }\n256: \n257: // ---------------------------------------------------------------------------\n258: // Text rendering helpers\n259: // ---------------------------------------------------------------------------\n260: \n261: const RESET = \"\\x1b[0m\";\n262: const BOLD = \"\\x1b[1m\";\n263: const DIM = \"\\x1b[2m\";\n264: const RED = \"\\x1b[31m\";\n265: const YELLOW = \"\\x1b[33m\";\n266: const GREEN = \"\\x1b[32m\";\n267: const CYAN = \"\\x1b[36m\";\n268: \n269: /**\n270:  * Print a legend explaining the status badges used in the graph.\n271:  */\n272: function printLegend(features: Feature[]): void {\n273:   const statuses = new Set<FeatureStatus>();\n274:   for (const f of features) {\n275:     statuses.add(f.status);\n276:   }\n277: \n278:   console.log(`\\n${BOLD}Legend:${RESET}`);\n279:   const legendItems: string[] = [];\n280:   for (const [status, badge] of Object.entries(STATUS_BADGE)) {\n281:     if (statuses.has(status as FeatureStatus)) {\n282:       legendItems.push(`  ${badge} = ${status}`);\n283:     }\n284:   }\n285:   console.log(legendItems.join(\"  |\"));\n286: }\n287: \n288: /**\n289:  * Detect potential issues in the dependency graph and print warnings.\n290:  */\n291: function printDiagnostics(data: FeaturesFile, includeSubtasks: boolean): void {\n292:   const allIds = collectAllIds(data.tasks, includeSubtasks);\n293:   const issues: string[] = [];\n294: \n295:   // Check for dangling dependencies (pointing to non-existent IDs)\n296:   for (const f of data.tasks) {\n297:     for (const dep of f.depends_on) {\n298:       if (!allIds.has(dep)) {\n299:         issues.push(`${YELLOW}WARNING${RESET}: ${f.id} depends on \"${dep}\" which does not exist`);\n300:       }\n301:     }\n302:     if (includeSubtasks) {\n303:       checkSubtaskDeps(f.subtasks, allIds, issues);\n304:     }\n305:   }\n306: \n307:   // Check for circular dependencies (simple DFS)\n308:   const circularPaths = detectCycles(data.tasks, includeSubtasks);\n309:   for (const cycle of circularPaths) {\n310:     issues.push(`${RED}CYCLE${RESET}: ${cycle.join(\" -> \")}`);\n311:   }\n312: \n313:   // Check for blocked features whose blockers are done\n314:   for (const f of data.tasks) {\n315:     if (f.status === \"blocked\") {\n316:       const allDepsDone = f.depends_on.every((dep: string) => {\n317:         const depFeature = data.tasks.find((ff: Feature) => ff.id === dep);\n318:         return depFeature?.status === \"done\";\n319:       });\n320:       if (allDepsDone && f.depends_on.length > 0) {\n321:         issues.push(\n322:           `${CYAN}INFO${RESET}: ${f.id} is marked \"blocked\" but all its dependencies are done`\n323:         );\n324:       }\n325:     }\n326:   }\n327: \n328:   if (issues.length > 0) {\n329:     console.log(`\\n${BOLD}Diagnostics (${issues.length} issue${issues.length > 1 ? \"s\" : \"\"}):${RESET}`);\n330:     for (const issue of issues) {\n331:       console.log(`  ${issue}`);\n332:     }\n333:   }\n334: }\n335: \n336: function checkSubtaskDeps(\n337:   subtasks: Subtask[],\n338:   allIds: Set<string>,\n339:   issues: string[]\n340: ): void {\n341:   for (const st of subtasks) {\n342:     for (const dep of st.depends_on) {\n343:       if (!allIds.has(dep)) {\n344:         issues.push(\n345:           `${YELLOW}WARNING${RESET}: subtask ${st.id} depends on \"${dep}\" which does not exist`\n346:         );\n347:       }\n348:     }\n349:     checkSubtaskDeps(st.subtasks, allIds, issues);\n350:   }\n351: }\n352: \n353: /**\n354:  * Detect circular dependencies using DFS.\n355:  * Returns arrays of ID paths that form cycles.\n356:  */\n357: function detectCycles(\n358:   features: Feature[],\n359:   includeSubtasks: boolean\n360: ): string[][] {\n361:   // Build adjacency list: dep -> [dependents]\n362:   const adj = new Map<string, string[]>();\n363:   const allItems = new Map<string, { depends_on: string[] }>();\n364: \n365:   for (const f of features) {\n366:     allItems.set(f.id, f);\n367:     if (includeSubtasks) {\n368:       collectSubtaskItems(f.subtasks, allItems);\n369:     }\n370:   }\n371: \n372:   for (const [id, item] of allItems) {\n373:     for (const dep of item.depends_on) {\n374:       if (!adj.has(id)) adj.set(id, []);\n375:       adj.get(id)!.push(dep);\n376:     }\n377:   }\n378: \n379:   const visited = new Set<string>();\n380:   const inStack = new Set<string>();\n381:   const cycles: string[][] = [];\n382: \n383:   function dfs(node: string, path: string[]): void {\n384:     if (inStack.has(node)) {\n385:       // Found a cycle — extract it\n386:       const cycleStart = path.indexOf(node);\n387:       cycles.push([...path.slice(cycleStart), node]);\n388:       return;\n389:     }\n390:     if (visited.has(node)) return;\n391: \n392:     visited.add(node);\n393:     inStack.add(node);\n394:     path.push(node);\n395: \n396:     for (const neighbor of adj.get(node) ?? []) {\n397:       dfs(neighbor, path);\n398:     }\n399: \n400:     path.pop();\n401:     inStack.delete(node);\n402:   }\n403: \n404:   for (const id of allItems.keys()) {\n405:     if (!visited.has(id)) {\n406:       dfs(id, []);\n407:     }\n408:   }\n409: \n410:   return cycles;\n411: }\n412: \n413: function collectSubtaskItems(\n414:   subtasks: Subtask[],\n415:   map: Map<string, { depends_on: string[] }>\n416: ): void {\n417:   for (const st of subtasks) {\n418:     map.set(st.id, st);\n419:     collectSubtaskItems(st.subtasks, map);\n420:   }\n421: }\n422: \n423: // ---------------------------------------------------------------------------\n424: // Command\n425: // ---------------------------------------------------------------------------\n426: \n427: export async function cmdTasksGraph(opts: TasksGraphOptions): Promise<void> {\n428:   const { projectRoot, config } = opts;\n429:   const data = loadFeatures(projectRoot, config);\n430:   const fmt = opts.outputFmt ?? \"text\";\n431: \n432:   const { source, nodeCount, edgeCount, orphanCount, orphans } = buildMermaidSource(data, {\n433:     status: opts.status,\n434:     subtasks: opts.subtasks,\n435:   });\n436: \n437:   if (nodeCount === 0 && orphanCount === 0) {\n438:     output(fmt, { graph: null, nodes: 0, edges: 0, message: \"No tasks to graph\" }, () => {\n439:       console.log(\"No tasks to graph.\");\n440:     });\n441:     return;\n442:   }\n443: \n444:   // --mermaid: emit raw mermaid source\n445:   if (opts.mermaid) {\n446:     output(fmt, { mermaid: source || null, nodes: nodeCount, edges: edgeCount, orphans }, () => {\n447:       if (source) {\n448:         console.log(source);\n449:       }\n450:       if (orphans.length > 0) {\n451:         console.log(`\\n# ${orphans.length} orphan(s) with no dependency relationships:`);\n452:         for (const o of orphans) {\n453:           console.log(`# ${STATUS_BADGE[o.status]} ${o.id}: ${o.title}`);\n454:         }\n455:       }\n456:     });\n457:     return;\n458:   }\n459: \n460:   // --output json: emit structured data\n461:   if (fmt === \"json\") {\n462:     const rendered = source ? renderMermaidToTui(source, { ascii: true }) as string : null;\n463:     console.log(\n464:       JSON.stringify({\n465:         mermaid: source || null,\n466:         rendered,\n467:         nodes: nodeCount,\n468:         edges: edgeCount,\n469:         orphan_count: orphanCount,\n470:         orphans,\n471:       })\n472:     );\n473:     return;\n474:   }\n475: \n476:   // Default: render the graph in the terminal\n477:   console.log(`\\n${BOLD}Task Dependency Graph${RESET}`);\n478: \n479:   if (nodeCount > 0 && source) {\n480:     const rendered = renderMermaidToTui(source, { ascii: !!opts.ascii }) as string;\n481:     console.log(`${DIM}${nodeCount} nodes, ${edgeCount} edges${RESET}\\n`);\n482:     console.log(rendered);\n483:   } else {\n484:     console.log(`${DIM}No dependency relationships found.${RESET}`);\n485:   }\n486: \n487:   // Print orphan summary\n488:   if (orphans.length > 0) {\n489:     console.log(`\\n${BOLD}Standalone tasks${RESET} ${DIM}(${orphans.length} with no dependencies):${RESET}`);\n490:     for (const o of orphans) {\n491:       const badge = STATUS_BADGE[o.status];\n492:       console.log(`  ${DIM}${badge}${RESET} ${o.id} ${DIM}— ${o.title}${RESET}`);\n493:     }\n494:   }\n495: \n496:   // Print legend and diagnostics\n497:   printLegend(data.tasks);\n498:   printDiagnostics(data, !!opts.subtasks);\n499:   console.log(\"\");\n500: }\n\n(End of file - total 500 lines)\n</content>","title":"src/commands/tasks/graph.ts","metadata":{"preview":"/**\n * tasks/graph.ts — Visualize the task dependency graph.\n *\n * Usage:\n *   woco tasks graph                     # show full dependency graph\n *   woco tasks graph --status backlog    # filter by status\n *   woco tasks graph --ascii             # ASCII-only rendering\n *   woco tasks graph --output json       # emit mermaid source as JSON\n *   woco tasks graph --mermaid           # emit raw mermaid source text\n *   woco tasks graph --subtasks          # include subtask-level nodes\n *\n * Builds a Mermaid flowchart from the tasks dependency graph and renders\n * it as a Unicode box diagram in the terminal using mermaidtui.\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  type Feature,\n  type Subtask,","truncated":false,"loaded":[]},"time":{"start":1773436089083,"end":1773436089086}}}}
