{"type":"tool_use","timestamp":1773435849796,"sessionID":"ses_316fcbbc9ffe0U7d2IN0Q9PcrR","part":{"id":"prt_ce903868f0012t3VxE5a5mqc36","sessionID":"ses_316fcbbc9ffe0U7d2IN0Q9PcrR","messageID":"msg_ce9037ca1001SM5xgYt2X3W4N4","type":"tool","callID":"toolu_vrtx_01K3bPH1wxAGqXZ6741gYrAj","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-toon-output-formatter/src/lib/state.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-toon-output-formatter/src/lib/state.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * state.ts — Persistent wave state management.\n3:  *\n4:  * Responsibilities:\n5:  *   - Define the shape of .wombo-combo/state.json\n6:  *   - Read/write state atomically\n7:  *   - Generate wave IDs\n8:  *   - Update individual agent state within a wave\n9:  */\n10: \n11: import { readFileSync, writeFileSync, existsSync, renameSync, mkdirSync } from \"node:fs\";\n12: import { resolve } from \"node:path\";\n13: import { WOMBO_DIR } from \"../config.js\";\n14: \n15: // ---------------------------------------------------------------------------\n16: // Types\n17: // ---------------------------------------------------------------------------\n18: \n19: export type AgentStatus =\n20:   | \"queued\"\n21:   | \"installing\"\n22:   | \"running\"\n23:   | \"completed\"\n24:   | \"verified\"\n25:   | \"failed\"\n26:   | \"merged\"\n27:   | \"retry\"\n28:   | \"resolving_conflict\";\n29: \n30: export interface AgentState {\n31:   feature_id: string;\n32:   branch: string;\n33:   worktree: string;\n34:   session_id: string | null;\n35:   pid: number | null;\n36:   status: AgentStatus;\n37:   activity: string | null;\n38:   activity_updated_at: string | null;\n39:   retries: number;\n40:   max_retries: number;\n41:   started_at: string | null;\n42:   completed_at: string | null;\n43:   build_passed: boolean | null;\n44:   build_output: string | null;\n45:   error: string | null;\n46:   /** Estimated effort in milliseconds (from feature's ISO 8601 duration) */\n47:   effort_estimate_ms: number | null;\n48:   /** Stream index this agent belongs to (for dependency-aware scheduling) */\n49:   stream_index: number | null;\n50:   /** IDs of features this agent depends on (within the current wave) */\n51:   depends_on: string[];\n52:   /** IDs of features that depend on this agent (within the current wave) */\n53:   depended_on_by: string[];\n54:   /**\n55:    * Override agent name for this specific agent (from registry).\n56:    * When set, uses this agent definition instead of the default generalist.\n57:    * e.g. \"engineering-frontend-developer\"\n58:    */\n59:   agent_name: string | null;\n60:   /**\n61:    * The agent_type from the task (e.g. \"engineering/engineering-frontend-developer\").\n62:    * Stored for informational purposes and to support resume with re-fetch.\n63:    */\n64:   agent_type: string | null;\n65: }\n66: \n67: export interface WaveState {\n68:   wave_id: string;\n69:   base_branch: string;\n70:   started_at: string;\n71:   updated_at: string;\n72:   max_concurrent: number;\n73:   model: string | null;\n74:   interactive: boolean;\n75:   agents: AgentState[];\n76:   /** Dependency-aware scheduling plan (null if no dependencies exist) */\n77:   schedule_plan: SerializedSchedulePlan | null;\n78: }\n79: \n80: /**\n81:  * Serialized schedule plan stored in wave state JSON.\n82:  * Uses plain arrays instead of the rich SchedulePlan type for JSON compatibility.\n83:  */\n84: export interface SerializedSchedulePlan {\n85:   /** Streams: each is a list of feature IDs to execute sequentially */\n86:   streams: string[][];\n87:   /** Merge gates: features that must wait for multiple deps from different streams */\n88:   merge_gates: Array<{ feature_id: string; wait_for: string[] }>;\n89:   /** Topological order of all features */\n90:   topological_order: string[];\n91: }\n92: \n93: // ---------------------------------------------------------------------------\n94: // Constants\n95: // ---------------------------------------------------------------------------\n96: \n97: const STATE_FILE = \".wombo-combo/state.json\";\n98: \n99: // ---------------------------------------------------------------------------\n100: // Wave ID Generation\n101: // ---------------------------------------------------------------------------\n102: \n103: /**\n104:  * Generate a unique wave ID based on current timestamp.\n105:  * Format: wave-YYYY-MM-DD-NNN\n106:  */\n107: export function generateWaveId(): string {\n108:   const now = new Date();\n109:   const date = now.toISOString().slice(0, 10);\n110:   const seq = String(now.getHours() * 60 + now.getMinutes()).padStart(3, \"0\");\n111:   return `wave-${date}-${seq}`;\n112: }\n113: \n114: // ---------------------------------------------------------------------------\n115: // State Path\n116: // ---------------------------------------------------------------------------\n117: \n118: function statePath(projectRoot: string): string {\n119:   return resolve(projectRoot, STATE_FILE);\n120: }\n121: \n122: // ---------------------------------------------------------------------------\n123: // Read State\n124: // ---------------------------------------------------------------------------\n125: \n126: /**\n127:  * Load the current wave state from disk. Returns null if no state file exists.\n128:  */\n129: export function loadState(projectRoot: string): WaveState | null {\n130:   const p = statePath(projectRoot);\n131:   if (!existsSync(p)) return null;\n132:   try {\n133:     const raw = readFileSync(p, \"utf-8\");\n134:     return JSON.parse(raw) as WaveState;\n135:   } catch {\n136:     return null;\n137:   }\n138: }\n139: \n140: // ---------------------------------------------------------------------------\n141: // Write State\n142: // ---------------------------------------------------------------------------\n143: \n144: /**\n145:  * Save wave state to disk atomically (write to tmp then rename).\n146:  */\n147: export function saveState(projectRoot: string, state: WaveState): void {\n148:   const dir = resolve(projectRoot, WOMBO_DIR);\n149:   if (!existsSync(dir)) mkdirSync(dir, { recursive: true });\n150:   state.updated_at = new Date().toISOString();\n151:   const p = statePath(projectRoot);\n152:   const tmp = p + \".tmp\";\n153:   writeFileSync(tmp, JSON.stringify(state, null, 2) + \"\\n\", \"utf-8\");\n154:   renameSync(tmp, p);\n155: }\n156: \n157: // ---------------------------------------------------------------------------\n158: // State Mutations\n159: // ---------------------------------------------------------------------------\n160: \n161: /**\n162:  * Create a fresh wave state.\n163:  */\n164: export function createWaveState(opts: {\n165:   baseBranch: string;\n166:   maxConcurrent: number;\n167:   model: string | null;\n168:   interactive: boolean;\n169: }): WaveState {\n170:   return {\n171:     wave_id: generateWaveId(),\n172:     base_branch: opts.baseBranch,\n173:     started_at: new Date().toISOString(),\n174:     updated_at: new Date().toISOString(),\n175:     max_concurrent: opts.maxConcurrent,\n176:     model: opts.model,\n177:     interactive: opts.interactive,\n178:     agents: [],\n179:     schedule_plan: null,\n180:   };\n181: }\n182: \n183: /**\n184:  * Create an initial agent state for a feature.\n185:  */\n186: export function createAgentState(\n187:   featureId: string,\n188:   branch: string,\n189:   worktreePath: string,\n190:   maxRetries: number = 2\n191: ): AgentState {\n192:   return {\n193:     feature_id: featureId,\n194:     branch,\n195:     worktree: worktreePath,\n196:     session_id: null,\n197:     pid: null,\n198:     status: \"queued\",\n199:     activity: null,\n200:     activity_updated_at: null,\n201:     retries: 0,\n202:     max_retries: maxRetries,\n203:     started_at: null,\n204:     completed_at: null,\n205:     build_passed: null,\n206:     build_output: null,\n207:     error: null,\n208:     effort_estimate_ms: null,\n209:     stream_index: null,\n210:     depends_on: [],\n211:     depended_on_by: [],\n212:     agent_name: null,\n213:     agent_type: null,\n214:   };\n215: }\n216: \n217: /**\n218:  * Find an agent state by feature ID.\n219:  */\n220: export function getAgent(\n221:   state: WaveState,\n222:   featureId: string\n223: ): AgentState | undefined {\n224:   return state.agents.find((a) => a.feature_id === featureId);\n225: }\n226: \n227: /**\n228:  * Update an agent's state fields.\n229:  */\n230: export function updateAgent(\n231:   state: WaveState,\n232:   featureId: string,\n233:   updates: Partial<AgentState>\n234: ): void {\n235:   const agent = state.agents.find((a) => a.feature_id === featureId);\n236:   if (!agent) throw new Error(`Agent not found for feature: ${featureId}`);\n237:   Object.assign(agent, updates);\n238: }\n239: \n240: /**\n241:  * Get counts of agents by status.\n242:  */\n243: export function agentCounts(state: WaveState): Record<AgentStatus, number> {\n244:   const counts: Record<AgentStatus, number> = {\n245:     queued: 0,\n246:     installing: 0,\n247:     running: 0,\n248:     completed: 0,\n249:     verified: 0,\n250:     failed: 0,\n251:     merged: 0,\n252:     retry: 0,\n253:     resolving_conflict: 0,\n254:   };\n255:   for (const a of state.agents) {\n256:     counts[a.status]++;\n257:   }\n258:   return counts;\n259: }\n260: \n261: /**\n262:  * Get agents that are currently running or installing.\n263:  */\n264: export function activeAgents(state: WaveState): AgentState[] {\n265:   return state.agents.filter(\n266:     (a) => a.status === \"running\" || a.status === \"installing\" || a.status === \"resolving_conflict\"\n267:   );\n268: }\n269: \n270: /**\n271:  * Get agents that are queued and ready to be launched.\n272:  */\n273: export function queuedAgents(state: WaveState): AgentState[] {\n274:   return state.agents.filter((a) => a.status === \"queued\");\n275: }\n276: \n277: /**\n278:  * Check if the wave is fully complete (no queued, installing, running, or retry agents).\n279:  */\n280: export function isWaveComplete(state: WaveState): boolean {\n281:   return state.agents.every(\n282:     (a) =>\n283:       a.status === \"completed\" ||\n284:       a.status === \"verified\" ||\n285:       a.status === \"failed\" ||\n286:       a.status === \"merged\"\n287:   );\n288: }\n289: \n290: // ---------------------------------------------------------------------------\n291: // Dependency-Aware Helpers\n292: // ---------------------------------------------------------------------------\n293: \n294: /**\n295:  * Terminal statuses that count as \"dependency satisfied\" for downstream features.\n296:  * A dependency is satisfied when it has been verified or merged.\n297:  */\n298: const DEP_SATISFIED_STATUSES: Set<AgentStatus> = new Set([\"verified\", \"merged\"]);\n299: \n300: /**\n301:  * Check if an agent's dependencies within the wave are all satisfied.\n302:  * Dependencies are satisfied when their agents reach \"verified\" or \"merged\" status.\n303:  *\n304:  * If the agent has no depends_on entries, it's always ready.\n305:  */\n306: export function areAgentDepsReady(\n307:   state: WaveState,\n308:   agent: AgentState\n309: ): boolean {\n310:   if (agent.depends_on.length === 0) return true;\n311: \n312:   for (const depId of agent.depends_on) {\n313:     const depAgent = state.agents.find((a) => a.feature_id === depId);\n314:     if (depAgent && !DEP_SATISFIED_STATUSES.has(depAgent.status)) {\n315:       return false;\n316:     }\n317:     // If depAgent doesn't exist in this wave, the dep is external — assumed satisfied\n318:   }\n319:   return true;\n320: }\n321: \n322: /**\n323:  * Get queued agents whose dependencies are all satisfied.\n324:  * This is the dependency-aware replacement for plain queuedAgents().\n325:  */\n326: export function readyToLaunchAgents(state: WaveState): AgentState[] {\n327:   return state.agents.filter(\n328:     (a) => a.status === \"queued\" && areAgentDepsReady(state, a)\n329:   );\n330: }\n331: \n332: /**\n333:  * Get all agents that are downstream (depend on) a given feature, directly or transitively.\n334:  * Used for failure cascading — when a feature fails, cancel all downstream.\n335:  */\n336: export function getDownstreamAgents(\n337:   state: WaveState,\n338:   featureId: string\n339: ): AgentState[] {\n340:   const visited = new Set<string>();\n341:   const result: AgentState[] = [];\n342: \n343:   function collect(id: string): void {\n344:     const agent = state.agents.find((a) => a.feature_id === id);\n345:     if (!agent) return;\n346: \n347:     for (const downstreamId of agent.depended_on_by) {\n348:       if (visited.has(downstreamId)) continue;\n349:       visited.add(downstreamId);\n350: \n351:       const downstream = state.agents.find((a) => a.feature_id === downstreamId);\n352:       if (downstream) {\n353:         result.push(downstream);\n354:         collect(downstreamId);\n355:       }\n356:     }\n357:   }\n358: \n359:   collect(featureId);\n360:   return result;\n361: }\n362: \n363: /**\n364:  * Cancel all downstream agents when an upstream dependency fails.\n365:  * Sets status to \"failed\" with an error explaining the dependency failure.\n366:  * Returns the list of cancelled agent IDs.\n367:  */\n368: export function cancelDownstream(\n369:   state: WaveState,\n370:   failedFeatureId: string\n371: ): string[] {\n372:   const downstream = getDownstreamAgents(state, failedFeatureId);\n373:   const cancelled: string[] = [];\n374: \n375:   for (const agent of downstream) {\n376:     // Only cancel agents that haven't already reached a terminal state\n377:     if (\n378:       agent.status === \"queued\" ||\n379:       agent.status === \"installing\" ||\n380:       agent.status === \"running\" ||\n381:       agent.status === \"retry\"\n382:     ) {\n383:       updateAgent(state, agent.feature_id, {\n384:         status: \"failed\",\n385:         error: `Dependency \"${failedFeatureId}\" failed — downstream cancelled`,\n386:         activity: null,\n387:         completed_at: new Date().toISOString(),\n388:       });\n389:       cancelled.push(agent.feature_id);\n390:     }\n391:   }\n392: \n393:   return cancelled;\n394: }\n\n(End of file - total 394 lines)\n</content>","title":"src/lib/state.ts","metadata":{"preview":"/**\n * state.ts — Persistent wave state management.\n *\n * Responsibilities:\n *   - Define the shape of .wombo-combo/state.json\n *   - Read/write state atomically\n *   - Generate wave IDs\n *   - Update individual agent state within a wave\n */\n\nimport { readFileSync, writeFileSync, existsSync, renameSync, mkdirSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\nimport { WOMBO_DIR } from \"../config.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type AgentStatus =\n  | \"queued\"","truncated":false,"loaded":[]},"time":{"start":1773435849768,"end":1773435849791}}}}
