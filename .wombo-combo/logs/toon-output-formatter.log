sage":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":973,"character":6},"end":{"line":973,"character":12}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"}],"/home/fulgidus/Documents/wt-wombo-toon-output-formatter/src/lib/history.ts":[{"range":{"start":{"line":23,"character":18},"end":{"line":23,"character":26}},"message":"'basename' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"},{"range":{"start":{"line":24,"character":25},"end":{"line":24,"character":35}},"message":"'AgentState' is declared but never used.","severity":4,"code":6196,"source":"typescript"}],"/home/fulgidus/Documents/wt-wombo-toon-output-formatter/src/lib/verifier.ts":[],"/home/fulgidus/Documents/wt-wombo-toon-output-formatter/src/lib/toon.ts":[{"range":{"start":{"line":20,"character":14},"end":{"line":20,"character":24}},"message":"'AgentState' is declared but never used.","severity":4,"code":6196,"source":"typescript"},{"range":{"start":{"line":21,"character":14},"end":{"line":21,"character":32}},"message":"'AgentHistoryRecord' is declared but never used.","severity":4,"code":6196,"source":"typescript"}]},"diff":"Index: /home/fulgidus/Documents/wt-wombo-toon-output-formatter/src/commands/tasks/show.ts\n===================================================================\n--- /home/fulgidus/Documents/wt-wombo-toon-output-formatter/src/commands/tasks/show.ts\n+++ /home/fulgidus/Documents/wt-wombo-toon-output-formatter/src/commands/tasks/show.ts\n@@ -111,8 +111,11 @@\n     for (const [key, val] of Object.entries(filtered)) {\n       const display = Array.isArray(val) ? val.join(\", \") : String(val ?? \"\");\n       console.log(`${key}: ${display}`);\n     }\n+  }, () => {\n+    // TOON: --fields ignored, emit full task in compact format\n+    console.log(renderTaskShow(feature, depsMet));\n   });\n   return;\n }\n \n","filediff":{"file":"/home/fulgidus/Documents/wt-wombo-toon-output-formatter/src/commands/tasks/show.ts","before":"/**\n * tasks/show.ts — Show detailed information about a specific task.\n *\n * Usage:\n *   woco tasks show <task-id>\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  findFeatureById,\n  formatDuration,\n  parseDurationMinutes,\n  areDependenciesMet,\n  getDoneFeatureIds,\n  type Feature,\n  type Subtask,\n} from \"../../lib/tasks.js\";\nimport { output, outputError, filterFields, type OutputFormat } from \"../../lib/output.js\";\nimport { renderTaskShow } from \"../../lib/toon.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface TasksShowOptions {\n  projectRoot: string;\n  config: WomboConfig;\n  featureId: string;\n  outputFmt?: OutputFormat;\n  fields?: string[];\n}\n\n// ---------------------------------------------------------------------------\n// ANSI Helpers\n// ---------------------------------------------------------------------------\n\nconst RESET = \"\\x1b[0m\";\nconst BOLD = \"\\x1b[1m\";\nconst DIM = \"\\x1b[2m\";\nconst GREEN = \"\\x1b[32m\";\nconst RED = \"\\x1b[31m\";\nconst YELLOW = \"\\x1b[33m\";\nconst CYAN = \"\\x1b[36m\";\n\n// ---------------------------------------------------------------------------\n// Display Helpers\n// ---------------------------------------------------------------------------\n\nfunction statusColor(status: string): string {\n  switch (status) {\n    case \"done\": return GREEN;\n    case \"in_progress\": return CYAN;\n    case \"blocked\":\n    case \"failed\": return RED;\n    case \"cancelled\": return DIM;\n    default: return \"\";\n  }\n}\n\nfunction renderSubtask(st: Subtask, indent: number): void {\n  const pad = \"  \".repeat(indent);\n  const color = statusColor(st.status);\n  const effort = formatDuration(parseDurationMinutes(st.effort));\n  const completionStr = st.completion > 0 ? ` (${st.completion}%)` : \"\";\n  console.log(\n    `${pad}${color}[${st.status}]${RESET} ${st.id} — ${st.title} [${st.priority}/${st.difficulty}] (${effort})${completionStr}`\n  );\n  if (st.subtasks?.length) {\n    for (const sub of st.subtasks) {\n      renderSubtask(sub, indent + 1);\n    }\n  }\n}\n\n// ---------------------------------------------------------------------------\n// Command\n// ---------------------------------------------------------------------------\n\nexport async function cmdTasksShow(opts: TasksShowOptions): Promise<void> {\n  const { projectRoot, config } = opts;\n  const fmt = opts.outputFmt ?? \"text\";\n\n  if (!opts.featureId) {\n    outputError(fmt, \"Usage: woco tasks show <task-id>\");\n    return;\n  }\n\n  const data = loadFeatures(projectRoot, config);\n  const feature = findFeatureById(data, opts.featureId);\n\n  if (!feature) {\n    outputError(fmt, `Task \"${opts.featureId}\" not found.`);\n    return;\n  }\n\n  const doneIds = getDoneFeatureIds(data);\n  const depsMet = areDependenciesMet(feature, doneIds);\n  const effort = formatDuration(parseDurationMinutes(feature.effort));\n\n  const fullData = {\n    ...feature,\n    deps_met: depsMet,\n    effort_formatted: effort,\n  };\n\n  // If --fields is specified, emit only those fields\n  if (opts.fields?.length) {\n    const filtered = filterFields(fullData as Record<string, unknown>, opts.fields);\n    output(fmt, filtered, () => {\n      for (const [key, val] of Object.entries(filtered)) {\n        const display = Array.isArray(val) ? val.join(\", \") : String(val ?? \"\");\n        console.log(`${key}: ${display}`);\n      }\n    });\n    return;\n  }\n\n  output(\n    fmt,\n    fullData,\n    () => {\n      console.log(`\\n${BOLD}Task: ${feature.title}${RESET}`);\n      console.log(`  ID:          ${feature.id}`);\n      console.log(`  Status:      ${statusColor(feature.status)}${feature.status}${RESET}`);\n      console.log(`  Priority:    ${feature.priority}`);\n      console.log(`  Difficulty:  ${feature.difficulty}`);\n      console.log(`  Effort:      ${effort}`);\n      console.log(`  Completion:  ${feature.completion}%`);\n      console.log(`  Deps met:    ${depsMet ? `${GREEN}yes${RESET}` : `${RED}no${RESET}`}`);\n\n      if (feature.started_at) {\n        console.log(`  Started:     ${feature.started_at}`);\n      }\n      if (feature.ended_at) {\n        console.log(`  Ended:       ${feature.ended_at}`);\n      }\n\n      if (feature.description) {\n        console.log(`\\n  ${BOLD}Description:${RESET}`);\n        for (const line of feature.description.split(\"\\n\")) {\n          console.log(`    ${line}`);\n        }\n      }\n\n      if (feature.depends_on.length > 0) {\n        console.log(`\\n  ${BOLD}Dependencies:${RESET}`);\n        for (const dep of feature.depends_on) {\n          const met = doneIds.has(dep);\n          const icon = met ? `${GREEN}✓${RESET}` : `${RED}✗${RESET}`;\n          console.log(`    ${icon} ${dep}`);\n        }\n      }\n\n      if (feature.constraints.length > 0) {\n        console.log(`\\n  ${BOLD}Constraints:${RESET}`);\n        for (const c of feature.constraints) {\n          console.log(`    - ${c}`);\n        }\n      }\n\n      if (feature.forbidden.length > 0) {\n        console.log(`\\n  ${BOLD}Forbidden:${RESET}`);\n        for (const f of feature.forbidden) {\n          console.log(`    - ${RED}${f}${RESET}`);\n        }\n      }\n\n      if (feature.references.length > 0) {\n        console.log(`\\n  ${BOLD}References:${RESET}`);\n        for (const r of feature.references) {\n          console.log(`    - ${DIM}${r}${RESET}`);\n        }\n      }\n\n      if (feature.notes.length > 0) {\n        console.log(`\\n  ${BOLD}Notes:${RESET}`);\n        for (const n of feature.notes) {\n          console.log(`    - ${n}`);\n        }\n      }\n\n      if (feature.subtasks.length > 0) {\n        console.log(`\\n  ${BOLD}Subtasks (${feature.subtasks.length}):${RESET}`);\n        for (const st of feature.subtasks) {\n          renderSubtask(st, 2);\n        }\n      }\n\n      console.log(\"\");\n    }\n  );\n}\n","after":"/**\n * tasks/show.ts — Show detailed information about a specific task.\n *\n * Usage:\n *   woco tasks show <task-id>\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  findFeatureById,\n  formatDuration,\n  parseDurationMinutes,\n  areDependenciesMet,\n  getDoneFeatureIds,\n  type Feature,\n  type Subtask,\n} from \"../../lib/tasks.js\";\nimport { output, outputError, filterFields, type OutputFormat } from \"../../lib/output.js\";\nimport { renderTaskShow } from \"../../lib/toon.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface TasksShowOptions {\n  projectRoot: string;\n  config: WomboConfig;\n  featureId: string;\n  outputFmt?: OutputFormat;\n  fields?: string[];\n}\n\n// ---------------------------------------------------------------------------\n// ANSI Helpers\n// ---------------------------------------------------------------------------\n\nconst RESET = \"\\x1b[0m\";\nconst BOLD = \"\\x1b[1m\";\nconst DIM = \"\\x1b[2m\";\nconst GREEN = \"\\x1b[32m\";\nconst RED = \"\\x1b[31m\";\nconst YELLOW = \"\\x1b[33m\";\nconst CYAN = \"\\x1b[36m\";\n\n// ---------------------------------------------------------------------------\n// Display Helpers\n// ---------------------------------------------------------------------------\n\nfunction statusColor(status: string): string {\n  switch (status) {\n    case \"done\": return GREEN;\n    case \"in_progress\": return CYAN;\n    case \"blocked\":\n    case \"failed\": return RED;\n    case \"cancelled\": return DIM;\n    default: return \"\";\n  }\n}\n\nfunction renderSubtask(st: Subtask, indent: number): void {\n  const pad = \"  \".repeat(indent);\n  const color = statusColor(st.status);\n  const effort = formatDuration(parseDurationMinutes(st.effort));\n  const completionStr = st.completion > 0 ? ` (${st.completion}%)` : \"\";\n  console.log(\n    `${pad}${color}[${st.status}]${RESET} ${st.id} — ${st.title} [${st.priority}/${st.difficulty}] (${effort})${completionStr}`\n  );\n  if (st.subtasks?.length) {\n    for (const sub of st.subtasks) {\n      renderSubtask(sub, indent + 1);\n    }\n  }\n}\n\n// ---------------------------------------------------------------------------\n// Command\n// ---------------------------------------------------------------------------\n\nexport async function cmdTasksShow(opts: TasksShowOptions): Promise<void> {\n  const { projectRoot, config } = opts;\n  const fmt = opts.outputFmt ?? \"text\";\n\n  if (!opts.featureId) {\n    outputError(fmt, \"Usage: woco tasks show <task-id>\");\n    return;\n  }\n\n  const data = loadFeatures(projectRoot, config);\n  const feature = findFeatureById(data, opts.featureId);\n\n  if (!feature) {\n    outputError(fmt, `Task \"${opts.featureId}\" not found.`);\n    return;\n  }\n\n  const doneIds = getDoneFeatureIds(data);\n  const depsMet = areDependenciesMet(feature, doneIds);\n  const effort = formatDuration(parseDurationMinutes(feature.effort));\n\n  const fullData = {\n    ...feature,\n    deps_met: depsMet,\n    effort_formatted: effort,\n  };\n\n  // If --fields is specified, emit only those fields\n  if (opts.fields?.length) {\n    const filtered = filterFields(fullData as Record<string, unknown>, opts.fields);\n    output(fmt, filtered, () => {\n      for (const [key, val] of Object.entries(filtered)) {\n        const display = Array.isArray(val) ? val.join(\", \") : String(val ?? \"\");\n        console.log(`${key}: ${display}`);\n      }\n    }, () => {\n      // TOON: --fields ignored, emit full task in compact format\n      console.log(renderTaskShow(feature, depsMet));\n    });\n    return;\n  }\n\n  output(\n    fmt,\n    fullData,\n    () => {\n      console.log(`\\n${BOLD}Task: ${feature.title}${RESET}`);\n      console.log(`  ID:          ${feature.id}`);\n      console.log(`  Status:      ${statusColor(feature.status)}${feature.status}${RESET}`);\n      console.log(`  Priority:    ${feature.priority}`);\n      console.log(`  Difficulty:  ${feature.difficulty}`);\n      console.log(`  Effort:      ${effort}`);\n      console.log(`  Completion:  ${feature.completion}%`);\n      console.log(`  Deps met:    ${depsMet ? `${GREEN}yes${RESET}` : `${RED}no${RESET}`}`);\n\n      if (feature.started_at) {\n        console.log(`  Started:     ${feature.started_at}`);\n      }\n      if (feature.ended_at) {\n        console.log(`  Ended:       ${feature.ended_at}`);\n      }\n\n      if (feature.description) {\n        console.log(`\\n  ${BOLD}Description:${RESET}`);\n        for (const line of feature.description.split(\"\\n\")) {\n          console.log(`    ${line}`);\n        }\n      }\n\n      if (feature.depends_on.length > 0) {\n        console.log(`\\n  ${BOLD}Dependencies:${RESET}`);\n        for (const dep of feature.depends_on) {\n          const met = doneIds.has(dep);\n          const icon = met ? `${GREEN}✓${RESET}` : `${RED}✗${RESET}`;\n          console.log(`    ${icon} ${dep}`);\n        }\n      }\n\n      if (feature.constraints.length > 0) {\n        console.log(`\\n  ${BOLD}Constraints:${RESET}`);\n        for (const c of feature.constraints) {\n          console.log(`    - ${c}`);\n        }\n      }\n\n      if (feature.forbidden.length > 0) {\n        console.log(`\\n  ${BOLD}Forbidden:${RESET}`);\n        for (const f of feature.forbidden) {\n          console.log(`    - ${RED}${f}${RESET}`);\n        }\n      }\n\n      if (feature.references.length > 0) {\n        console.log(`\\n  ${BOLD}References:${RESET}`);\n        for (const r of feature.references) {\n          console.log(`    - ${DIM}${r}${RESET}`);\n        }\n      }\n\n      if (feature.notes.length > 0) {\n        console.log(`\\n  ${