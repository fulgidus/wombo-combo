{"type":"tool_use","timestamp":1773433365547,"sessionID":"ses_31723c351ffe6G54611rxN573V","part":{"id":"prt_ce8dda33f001PWKGTbqBoBWJKH","sessionID":"ses_31723c351ffe6G54611rxN573V","messageID":"msg_ce8dd990b001sMliAewv61Ssva","type":"tool","callID":"toolu_vrtx_01WYnTBduaerZ2DRFjnRRoVD","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-json-features-check/src/commands/tasks/check.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-json-features-check/src/commands/tasks/check.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tasks/check.ts — Validate the tasks file for schema issues, broken deps, and orphans.\n3:  *\n4:  * Usage:\n5:  *   woco tasks check\n6:  *\n7:  * Checks:\n8:  *   - Required fields present on every task\n9:  *   - No duplicate IDs\n10:  *   - All depends_on references point to existing tasks\n11:  *   - No circular dependencies\n12:  *   - No orphaned subtasks (subtask IDs unique)\n13:  *   - Priority/difficulty values are valid enums\n14:  *   - Effort strings are parseable ISO 8601 durations\n15:  */\n16: \n17: import type { WomboConfig } from \"../../config.js\";\n18: import {\n19:   loadFeatures,\n20:   allFeatureIds,\n21:   parseDurationMinutes,\n22:   type Feature,\n23:   type Subtask,\n24:   type FeaturesFile,\n25: } from \"../../lib/tasks.js\";\n26: import {\n27:   VALID_STATUSES,\n28:   VALID_PRIORITIES,\n29:   VALID_DIFFICULTIES,\n30: } from \"../../lib/task-schema.js\";\n31: import { output, type OutputFormat } from \"../../lib/output.js\";\n32: \n33: // ---------------------------------------------------------------------------\n34: // Types\n35: // ---------------------------------------------------------------------------\n36: \n37: export interface TasksCheckOptions {\n38:   projectRoot: string;\n39:   config: WomboConfig;\n40:   outputFmt?: OutputFormat;\n41: }\n42: \n43: interface CheckResult {\n44:   errors: string[];\n45:   warnings: string[];\n46: }\n47: \n48: // ---------------------------------------------------------------------------\n49: // Validation (enums imported from task-schema.ts — single source of truth)\n50: // ---------------------------------------------------------------------------\n51: \n52: function collectAllItems(data: FeaturesFile): (Feature | Subtask)[] {\n53:   const items: (Feature | Subtask)[] = [];\n54:   const collect = (list: (Feature | Subtask)[]) => {\n55:     for (const item of list) {\n56:       items.push(item);\n57:       if (item.subtasks?.length) collect(item.subtasks);\n58:     }\n59:   };\n60:   collect(data.tasks ?? []);\n61:   collect(data.archive ?? []);\n62:   return items;\n63: }\n64: \n65: function checkTasks(data: FeaturesFile): CheckResult {\n66:   const errors: string[] = [];\n67:   const warnings: string[] = [];\n68:   const allItems = collectAllItems(data);\n69:   const allIds = allItems.map((i) => i.id);\n70:   const idSet = new Set<string>();\n71: \n72:   // Check for duplicates\n73:   for (const id of allIds) {\n74:     if (idSet.has(id)) {\n75:       errors.push(`Duplicate ID: \"${id}\"`);\n76:     }\n77:     idSet.add(id);\n78:   }\n79: \n80:   // Check each item\n81:   for (const item of allItems) {\n82:     const prefix = `[${item.id}]`;\n83: \n84:     // Required fields\n85:     if (!item.id) errors.push(`${prefix} Missing required field: id`);\n86:     if (!item.title) errors.push(`${prefix} Missing required field: title`);\n87:     if (!item.status) errors.push(`${prefix} Missing required field: status`);\n88: \n89:     // Validate enum values\n90:     if (item.status && !(VALID_STATUSES as readonly string[]).includes(item.status)) {\n91:       errors.push(`${prefix} Invalid status: \"${item.status}\"`);\n92:     }\n93:     if (item.priority && !(VALID_PRIORITIES as readonly string[]).includes(item.priority)) {\n94:       errors.push(`${prefix} Invalid priority: \"${item.priority}\"`);\n95:     }\n96:     if (item.difficulty && !(VALID_DIFFICULTIES as readonly string[]).includes(item.difficulty)) {\n97:       errors.push(`${prefix} Invalid difficulty: \"${item.difficulty}\"`);\n98:     }\n99: \n100:     // Validate effort\n101:     if (item.effort) {\n102:       const minutes = parseDurationMinutes(item.effort);\n103:       if (minutes === Infinity) {\n104:         warnings.push(`${prefix} Unparseable effort duration: \"${item.effort}\"`);\n105:       }\n106:     }\n107: \n108:     // Check depends_on references\n109:     if (item.depends_on?.length) {\n110:       for (const dep of item.depends_on) {\n111:         if (!idSet.has(dep)) {\n112:           errors.push(`${prefix} Broken dependency: \"${dep}\" does not exist`);\n113:         }\n114:       }\n115:     }\n116:   }\n117: \n118:   // Check for circular dependencies (simple DFS)\n119:   const visited = new Set<string>();\n120:   const visiting = new Set<string>();\n121:   const depMap = new Map<string, string[]>();\n122:   for (const item of allItems) {\n123:     depMap.set(item.id, item.depends_on ?? []);\n124:   }\n125: \n126:   function hasCycle(id: string): boolean {\n127:     if (visiting.has(id)) return true;\n128:     if (visited.has(id)) return false;\n129:     visiting.add(id);\n130:     for (const dep of depMap.get(id) ?? []) {\n131:       if (hasCycle(dep)) {\n132:         errors.push(`Circular dependency detected involving: \"${id}\" → \"${dep}\"`);\n133:         return true;\n134:       }\n135:     }\n136:     visiting.delete(id);\n137:     visited.add(id);\n138:     return false;\n139:   }\n140: \n141:   for (const id of idSet) {\n142:     hasCycle(id);\n143:   }\n144: \n145:   // Warn about features with no effort estimate\n146:   for (const item of allItems) {\n147:     if (!item.effort || item.effort === \"PT0S\") {\n148:       warnings.push(`[${item.id}] No effort estimate`);\n149:     }\n150:   }\n151: \n152:   return { errors, warnings };\n153: }\n154: \n155: // ---------------------------------------------------------------------------\n156: // Command\n157: // ---------------------------------------------------------------------------\n158: \n159: export async function cmdTasksCheck(opts: TasksCheckOptions): Promise<void> {\n160:   const { projectRoot, config } = opts;\n161:   const fmt = opts.outputFmt ?? \"text\";\n162: \n163:   const data = loadFeatures(projectRoot, config);\n164:   const result = checkTasks(data);\n165: \n166:   const allItems = collectAllItems(data);\n167:   const issues = [\n168:     ...result.errors.map((msg) => ({ level: \"error\" as const, message: msg })),\n169:     ...result.warnings.map((msg) => ({ level: \"warning\" as const, message: msg })),\n170:   ];\n171:   const ok = result.errors.length === 0;\n172: \n173:   output(\n174:     fmt,\n175:     {\n176:       ok,\n177:       issues,\n178:       items_checked: allItems.length,\n179:     },\n180:     () => {\n181:       console.log(`\\nChecking ${config.tasksDir}/ (${allItems.length} items)...\\n`);\n182: \n183:       if (result.errors.length === 0 && result.warnings.length === 0) {\n184:         console.log(\"  All checks passed. No issues found.\");\n185:         return;\n186:       }\n187: \n188:       if (result.errors.length > 0) {\n189:         console.log(`  ERRORS (${result.errors.length}):`);\n190:         for (const e of result.errors) {\n191:           console.log(`    \\x1b[31m✗\\x1b[0m ${e}`);\n192:         }\n193:         console.log(\"\");\n194:       }\n195: \n196:       if (result.warnings.length > 0) {\n197:         console.log(`  WARNINGS (${result.warnings.length}):`);\n198:         for (const w of result.warnings) {\n199:           console.log(`    \\x1b[33m⚠\\x1b[0m ${w}`);\n200:         }\n201:         console.log(\"\");\n202:       }\n203:     }\n204:   );\n205: \n206:   if (result.errors.length > 0) {\n207:     process.exit(1);\n208:   }\n209: }\n\n(End of file - total 209 lines)\n</content>","title":"src/commands/tasks/check.ts","metadata":{"preview":"/**\n * tasks/check.ts — Validate the tasks file for schema issues, broken deps, and orphans.\n *\n * Usage:\n *   woco tasks check\n *\n * Checks:\n *   - Required fields present on every task\n *   - No duplicate IDs\n *   - All depends_on references point to existing tasks\n *   - No circular dependencies\n *   - No orphaned subtasks (subtask IDs unique)\n *   - Priority/difficulty values are valid enums\n *   - Effort strings are parseable ISO 8601 durations\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  allFeatureIds,","truncated":false,"loaded":[]},"time":{"start":1773433365539,"end":1773433365545}}}}
