{"type":"tool_use","timestamp":1773433287944,"sessionID":"ses_31723c351ffe6G54611rxN573V","part":{"id":"prt_ce8dc72af001EQHGV6h8eW9aHw","sessionID":"ses_31723c351ffe6G54611rxN573V","messageID":"msg_ce8dc5f90001YlxGKCoodB1auR","type":"tool","callID":"toolu_vrtx_015QhjhoLCrEnGdETJsDt8XV","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-json-features-check/src/index.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-json-features-check/src/index.ts</path>\n<type>file</type>\n<content>1: #!/usr/bin/env bun\n2: /**\n3:  * index.ts — CLI entry point for the wombo-combo agent orchestration system.\n4:  *\n5:  * Every command has a short alias (e.g., woco i = woco init, woco t ls = woco tasks list).\n6:  *\n7:  * Usage:\n8:  *   woco init                                         (alias: i)\n9:  *   woco launch --top-priority 3                      (alias: l)\n10:  *   woco launch --quickest-wins 5\n11:  *   woco launch --priority high\n12:  *   woco launch --difficulty easy\n13:  *   woco launch --tasks \"feat-a,feat-b\"\n14:  *   woco launch --all-ready\n15:  *   woco launch ... --max-concurrent 3 --model \"anthropic/claude-sonnet-4-20250514\"\n16:  *   woco launch ... --interactive\n17:  *   woco resume                                       (alias: r)\n18:  *   woco status                                       (alias: s)\n19:  *   woco verify [feature-id]                          (alias: v)\n20:  *   woco merge [feature-id]                           (alias: m)\n21:  *   woco retry <feature-id>                           (alias: re)\n22:  *   woco abort <feature-id> [--requeue] [--output json]  (alias: a)\n23:  *   woco logs <feature-id> [--tail N] [--follow]      (alias: lo)\n24:  *   woco cleanup                                      (alias: c)\n25:  *   woco history [wave-id] [--output json]            (alias: h)\n26:  *   woco tasks list [--status <s>] [--priority <p>]   (alias: t ls)\n27:  *   woco tasks add <id> <title> [options]             (alias: t a)\n28:  *   woco tasks set-status <task-id> <status>          (alias: t ss)\n29:  *   woco tasks set-priority <task-id> <priority>      (alias: t sp)\n30:  *   woco tasks set-difficulty <task-id> <difficulty>   (alias: t sd)\n31:  *   woco tasks check                                  (alias: t ch)\n32:  *   woco tasks archive [task-id] [--dry-run]          (alias: t ar)\n33:  *   woco tasks show <task-id>                         (alias: t sh)\n34:  *   woco tasks graph [--ascii] [--mermaid]            (alias: t g)\n35:  *   woco completion <bash|zsh|fish>                   (alias: comp)\n36:  *   woco help\n37:  *   woco version\n38:  *   woco -v\n39:  */\n40: \n41: import { resolve } from \"node:path\";\n42: import { existsSync, readFileSync } from \"node:fs\";\n43: import { loadConfig, validateConfig } from \"./config.js\";\n44: import { loadState, saveState } from \"./lib/state.js\";\n45: \n46: // ---------------------------------------------------------------------------\n47: // Dev-mode guard: warn if running the global binary inside the wombo-combo repo\n48: // ---------------------------------------------------------------------------\n49: \n50: function checkDevModeGuard(): void {\n51:   const cwd = process.cwd();\n52:   const pkgPath = resolve(cwd, \"package.json\");\n53: \n54:   // Are we inside the wombo-combo repo?\n55:   if (!existsSync(pkgPath)) return;\n56: \n57:   let pkgName: string | undefined;\n58:   try {\n59:     const raw = readFileSync(pkgPath, \"utf-8\");\n60:     pkgName = JSON.parse(raw).name;\n61:   } catch {\n62:     return;\n63:   }\n64:   if (pkgName !== \"wombo-combo\") return;\n65: \n66:   // We're in the wombo-combo repo. Is the source being run from a different location?\n67:   // import.meta.dir = directory of THIS file (index.ts). If it's under cwd,\n68:   // we're running local source (bun dev). If it's elsewhere (e.g. ~/.bun/install),\n69:   // we're running the globally installed binary.\n70:   const sourceDir = resolve(import.meta.dir);\n71:   const projectSrc = resolve(cwd, \"src\");\n72: \n73:   if (!sourceDir.startsWith(projectSrc)) {\n74:     console.warn(\n75:       \"\\x1b[33m[WARNING]\\x1b[0m You are running the globally installed woco binary \" +\n76:       \"inside the wombo-combo repo.\\n\" +\n77:       \"  Use \\x1b[1mbun dev <command>\\x1b[0m instead to run from local source.\\n\" +\n78:       \"  See AGENTS.md for details.\\n\"\n79:     );\n80:   }\n81: }\n82: \n83: import { cmdInit } from \"./commands/init.js\";\n84: import { cmdLaunch } from \"./commands/launch.js\";\n85: import { cmdResume } from \"./commands/resume.js\";\n86: import { cmdStatus } from \"./commands/status.js\";\n87: import { cmdVerify } from \"./commands/verify.js\";\n88: import { cmdMerge } from \"./commands/merge.js\";\n89: import { cmdRetry } from \"./commands/retry.js\";\n90: import { cmdCleanup } from \"./commands/cleanup.js\";\n91: import { cmdAbort } from \"./commands/abort.js\";\n92: import { cmdLogs } from \"./commands/logs.js\";\n93: import { cmdUpgrade } from \"./commands/upgrade.js\";\n94: import { cmdHistory } from \"./commands/history.js\";\n95: import { cmdCompletion } from \"./commands/completion.js\";\n96: import { cmdTasksList } from \"./commands/tasks/list.js\";\n97: import { cmdTasksAdd } from \"./commands/tasks/add.js\";\n98: import { cmdTasksSetStatus } from \"./commands/tasks/set-status.js\";\n99: import { cmdTasksSetPriority } from \"./commands/tasks/set-priority.js\";\n100: import { cmdTasksSetDifficulty } from \"./commands/tasks/set-difficulty.js\";\n101: import { cmdTasksCheck } from \"./commands/tasks/check.js\";\n102: import { cmdTasksArchive } from \"./commands/tasks/archive.js\";\n103: import { cmdTasksShow } from \"./commands/tasks/show.js\";\n104: import { cmdTasksGraph } from \"./commands/tasks/graph.js\";\n105: \n106: import { ensureTasksFile } from \"./lib/tasks.js\";\n107: import type { Priority, Difficulty, FeatureStatus } from \"./lib/tasks.js\";\n108: import { resolveOutputFormat, type OutputFormat } from \"./lib/output.js\";\n109: import { validateId, validateText, validateBranchName, validateDuration, assertValid } from \"./lib/validate.js\";\n110: import { findCommandDef, commandToSchema, allCommandSchemas } from \"./lib/schema.js\";\n111: \n112: // ---------------------------------------------------------------------------\n113: // Types\n114: // ---------------------------------------------------------------------------\n115: \n116: export interface CLIArgs {\n117:   command: string;\n118:   subcommand?: string;\n119:   // Selection options (launch)\n120:   topPriority?: number;\n121:   quickestWins?: number;\n122:   priority?: Priority;\n123:   difficulty?: Difficulty;\n124:   tasks?: string[];\n125:   allReady?: boolean;\n126:   // Launch / runtime options\n127:   maxConcurrent?: number;\n128:   model?: string;\n129:   interactive: boolean;\n130:   dryRun: boolean;\n131:   baseBranch?: string;\n132:   maxRetries?: number;\n133:   noTui: boolean;\n134:   autoPush: boolean;\n135:   // Abort options\n136:   requeue: boolean;\n137:   // General\n138:   featureId?: string;\n139:   force: boolean;\n140:   // Output format\n141:   outputFmt: OutputFormat;\n142:   // Upgrade options\n143:   checkOnly: boolean;\n144:   tag?: string;\n145:   // Features subcommand extras\n146:   status?: string;\n147:   ready?: boolean;\n148:   includeArchive?: boolean;\n149:   title?: string;\n150:   description?: string;\n151:   effort?: string;\n152:   dependsOn?: string[];\n153:   // Logs options\n154:   tail?: number;\n155:   follow?: boolean;\n156:   // Compact output\n157:   fields?: string[];\n158:   // Graph options\n159:   ascii?: boolean;\n160:   mermaidRaw?: boolean;\n161:   graphSubtasks?: boolean;\n162:   // Browser verification\n163:   browser?: boolean;\n164: }\n165: \n166: // ---------------------------------------------------------------------------\n167: // Command & Subcommand Aliases\n168: // ---------------------------------------------------------------------------\n169: \n170: /** Map of short aliases → canonical top-level command names. */\n171: export const COMMAND_ALIASES: Record<string, string> = {\n172:   i: \"init\",\n173:   l: \"launch\",\n174:   r: \"resume\",\n175:   s: \"status\",\n176:   v: \"verify\",\n177:   m: \"merge\",\n178:   re: \"retry\",\n179:   a: \"abort\",\n180:   c: \"cleanup\",\n181:   h: \"history\",\n182:   lo: \"logs\",\n183:   t: \"tasks\",\n184:   features: \"tasks\", // backward-compat full-word alias\n185:   u: \"upgrade\",\n186:   d: \"describe\",\n187:   comp: \"completion\",\n188: };\n189: \n190: /** Map of short aliases → canonical tasks subcommand names. */\n191: export const SUBCOMMAND_ALIASES: Record<string, string> = {\n192:   ls: \"list\",\n193:   a: \"add\",\n194:   ss: \"set-status\",\n195:   sp: \"set-priority\",\n196:   sd: \"set-difficulty\",\n197:   ch: \"check\",\n198:   validate: \"check\", // backward-compat full-word alias\n199:   ar: \"archive\",\n200:   sh: \"show\",\n201:   g: \"graph\",\n202: };\n203: \n204: // ---------------------------------------------------------------------------\n205: // Arg Parsing\n206: // ---------------------------------------------------------------------------\n207: \n208: export function parseArgs(argv: string[]): CLIArgs {\n209:   const args = argv.slice(2); // skip 'bun' and script path\n210:   const result: CLIArgs = {\n211:     command: args[0] || \"help\",\n212:     interactive: false,\n213:     dryRun: false,\n214:     noTui: false,\n215:     autoPush: false,\n216:     requeue: false,\n217:     force: false,\n218:     checkOnly: false,\n219:     outputFmt: resolveOutputFormat(undefined), // auto-detect until --output overrides\n220:   };\n221: \n222:   // Resolve top-level command alias (e.g., \"i\" → \"init\", \"t\" → \"tasks\")\n223:   result.command = COMMAND_ALIASES[result.command] ?? result.command;\n224: \n225:   // If the command is \"tasks\", treat the second positional as the subcommand\n226:   let startIdx = 1;\n227:   if (result.command === \"tasks\") {\n228:     result.subcommand = args[1] || \"list\";\n229:     // Resolve subcommand alias (e.g., \"ls\" → \"list\", \"ss\" → \"set-status\")\n230:     result.subcommand = SUBCOMMAND_ALIASES[result.subcommand] ?? result.subcommand;\n231:     startIdx = 2;\n232:   }\n233: \n234:   for (let i = startIdx; i < args.length; i++) {\n235:     const arg = args[i];\n236: \n237:     // Helper: consume the next argument, or exit with a clear error\n238:     function requireValue(flag: string): string {\n239:       if (i + 1 >= args.length) {\n240:         console.error(`Flag ${flag} requires a value.`);\n241:         process.exit(1);\n242:       }\n243:       return args[++i];\n244:     }\n245: \n246:     switch (arg) {\n247:       // --- Selection options ---\n248:       case \"--top-priority\":\n249:         result.topPriority = parseInt(requireValue(arg), 10);\n250:         break;\n251:       case \"--quickest-wins\":\n252:         result.quickestWins = parseInt(requireValue(arg), 10);\n253:         break;\n254:       case \"--priority\":\n255:         result.priority = requireValue(arg) as Priority;\n256:         break;\n257:       case \"--difficulty\":\n258:         result.difficulty = requireValue(arg) as Difficulty;\n259:         break;\n260:       case \"--tasks\":\n261:       case \"--features\": // backward-compat alias\n262:         result.tasks = requireValue(arg).split(\",\").map((s) => s.trim());\n263:         break;\n264:       case \"--all-ready\":\n265:         result.allReady = true;\n266:         break;\n267: \n268:       // --- Launch / runtime options ---\n269:       case \"--max-concurrent\":\n270:         result.maxConcurrent = parseInt(requireValue(arg), 10);\n271:         break;\n272:       case \"--model\":\n273:       case \"-m\":\n274:         result.model = requireValue(arg);\n275:         break;\n276:       case \"--interactive\":\n277:         result.interactive = true;\n278:         break;\n279:       case \"--dry-run\":\n280:         result.dryRun = true;\n281:         break;\n282:       case \"--no-tui\":\n283:         result.noTui = true;\n284:         break;\n285:       case \"--auto-push\":\n286:         result.autoPush = true;\n287:         break;\n288:       case \"--requeue\":\n289:         result.requeue = true;\n290:         break;\n291:       case \"--base-branch\":\n292:         result.baseBranch = requireValue(arg);\n293:         break;\n294:       case \"--max-retries\":\n295:         result.maxRetries = parseInt(requireValue(arg), 10);\n296:         break;\n297: \n298:       // --- General flags ---\n299:       case \"--force\":\n300:         result.force = true;\n301:         break;\n302:       case \"--check\":\n303:         result.checkOnly = true;\n304:         break;\n305:       case \"--tag\":\n306:       case \"--release\":\n307:         result.tag = requireValue(arg);\n308:         break;\n309:       case \"--output\":\n310:       case \"-o\":\n311:         result.outputFmt = resolveOutputFormat(requireValue(arg));\n312:         break;\n313: \n314:       // --- Tasks subcommand options ---\n315:       case \"--status\":\n316:         result.status = requireValue(arg);\n317:         break;\n318:       case \"--ready\":\n319:         result.ready = true;\n320:         break;\n321:       case \"--include-archive\":\n322:         result.includeArchive = true;\n323:         break;\n324:       case \"--title\":\n325:         result.title = requireValue(arg);\n326:         break;\n327:       case \"--description\":\n328:       case \"--desc\":\n329:         result.description = requireValue(arg);\n330:         break;\n331:       case \"--effort\":\n332:         result.effort = requireValue(arg);\n333:         break;\n334:       case \"--depends-on\":\n335:         result.dependsOn = requireValue(arg).split(\",\").map((s) => s.trim());\n336:         break;\n337:       case \"--fields\":\n338:         result.fields = requireValue(arg).split(\",\").map((s) => s.trim());\n339:         break;\n340: \n341:       // --- Graph options ---\n342:       case \"--ascii\":\n343:         result.ascii = true;\n344:         break;\n345:       case \"--mermaid\":\n346:         result.mermaidRaw = true;\n347:         break;\n348:       case \"--subtasks\":\n349:         result.graphSubtasks = true;\n350:         break;\n351: \n352:       // --- Logs options ---\n353:       case \"--tail\":\n354:         result.tail = parseInt(args[++i], 10);\n355:         break;\n356:       case \"--follow\":\n357:       case \"-f\":\n358:         result.follow = true;\n359:         break;\n360: \n361:       // --- Browser verification ---\n362:       case \"--browser\":\n363:         result.browser = true;\n364:         break;\n365: \n366:       // --- Positional (feature-id, title for add, etc.) ---\n367:       default:\n368:         if (!arg.startsWith(\"-\")) {\n369:           if (!result.featureId) {\n370:             result.featureId = arg;\n371:           } else if (!result.title) {\n372:             result.title = arg;\n373:           }\n374:         }\n375:         break;\n376:     }\n377:   }\n378: \n379:   return result;\n380: }\n381: \n382: // ---------------------------------------------------------------------------\n383: // Help\n384: // ---------------------------------------------------------------------------\n385: \n386: function cmdHelp(): void {\n387:   console.log(`\n388: wombo-combo — AI Agent Orchestration System\n389: \n390:   WOMBO COMBO! Parallel feature development with AI agents.\n391: \n392: Commands:                        (alias)\n393:   init                           (i)     Generate .wombo-combo/config.json in the current project\n394:   launch                         (l)     Launch a wave of agents to implement features\n395:   resume                         (r)     Resume a previously stopped wave\n396:   status                         (s)     Show the status of the current wave\n397:   verify                         (v)     Run build verification on completed agents\n398:   merge                          (m)     Merge verified branches into the base branch\n399:   retry                          (re)    Retry a failed agent\n400:   abort                          (a)     Kill a single running agent (--requeue to return to queue)\n401:   logs                           (lo)    Pretty-print agent logs for a feature\n402:   cleanup                        (c)     Remove all wave worktrees and multiplexer sessions\n403:   history                        (h)     List/view past wave results (stored in .wombo-combo/history/)\n404:   tasks                          (t)     Manage tasks file (see below; 'features' also accepted)\n405:   upgrade                        (u)     Check for updates and upgrade wombo-combo\n406:   describe                       (d)     Emit JSON schema of a command (for AI agents)\n407:   completion                     (comp)  Generate shell completions (bash, zsh, fish)\n408:   version                                Print version and exit\n409:   help                                   Show this help\n410: \n411: Tasks Subcommands:               (alias)\n412:   tasks list                     (ls)    List tasks (--status, --priority, --difficulty, --ready, --include-archive)\n413:   tasks add <id> <title>         (a)     Add a new task (--desc, --priority, --difficulty, --effort, --depends-on)\n414:   tasks set-status <id> <s>      (ss)    Change a task's status\n415:   tasks set-priority <id> <p>    (sp)    Change a task's priority (critical/high/medium/low/wishlist)\n416:   tasks set-difficulty <id> <d>  (sd)    Change a task's difficulty (trivial/easy/medium/hard/very_hard)\n417:   tasks check                    (ch)    Validate tasks file (schema, deps, duplicates, cycles)\n418:   tasks archive [id]             (ar)    Move done/cancelled to archive (--dry-run)\n419:   tasks show <id>                (sh)    Show task details\n420:   tasks graph                    (g)     Visualize dependency graph (--ascii, --mermaid, --subtasks)\n421: \n422: Selection Options (for launch):\n423:   --top-priority N         Select top N tasks by priority\n424:   --quickest-wins N        Select N tasks with lowest effort\n425:   --priority <level>       Filter by priority (critical/high/medium/low/wishlist)\n426:   --difficulty <level>     Filter by difficulty (trivial/easy/medium/hard/very_hard)\n427:   --tasks \"id1,id2\"        Select specific tasks by ID (--features also accepted)\n428:   --all-ready              Select all tasks whose dependencies are met\n429: \n430: Launch Options:\n431:   --max-concurrent N       Max agents running in parallel (default: from config)\n432:   --model <model>          Model to use (e.g., \"anthropic/claude-sonnet-4-20250514\")\n433:   --interactive            Use multiplexer (dmux/tmux) TUI mode instead of headless\n434:   --no-tui                 Headless mode without neo-blessed TUI (periodic console dashboard)\n435:   --auto-push              Push base branch to remote after all merges complete\n436:   --dry-run                Show what would be launched without launching\n437:   --base-branch <branch>   Base branch (default: from config)\n438:   --max-retries N          Max retries per agent (default: from config)\n439:   --browser                Enable browser-based verification (run after build passes)\n440: \n441: General:\n442:   --force                  Force overwrite (e.g., for init) / skip prompts (e.g., for upgrade)\n443:   --output <fmt>           Output format: text (default on TTY) or json (default when piped)\n444:   -o <fmt>                 Alias for --output\n445:   --dry-run                Show what would happen without performing the action\n446:   --fields <list>          Comma-separated fields to include (e.g., id,status,priority)\n447: \n448: Upgrade Options:\n449:   --check                  Only check for updates, don't install\n450:   --tag <tag>              Install a specific version (e.g., v0.1.0)\n451: \n452: Logs Options:\n453:   --tail N                 Show only the last N lines\n454:   --follow, -f             Stream new output as it arrives (like tail -f)\n455: \n456: Aliases (every command has a short form):\n457:   woco i                         woco init\n458:   woco l --all-ready             woco launch --all-ready\n459:   woco t ls                      woco tasks list\n460:   woco t a my-task \"Title\"       woco tasks add my-task \"Title\"\n461:   woco t ss my-task done         woco tasks set-status my-task done\n462: \n463: Shell Completion:\n464:   eval \"$(woco completion bash)\"    # Bash: add to ~/.bashrc\n465:   eval \"$(woco completion zsh)\"     # Zsh:  add to ~/.zshrc\n466:   woco completion fish | source     # Fish (or save to ~/.config/fish/completions/woco.fish)\n467: \n468: Examples:\n469:   woco init\n470:   woco launch --quickest-wins 3\n471:   woco launch --priority high --interactive\n472:   woco launch --tasks \"auth-flow,search-api\" --max-concurrent 2\n473:   woco resume\n474:   woco status\n475:   woco verify\n476:   woco merge\n477:   woco retry auth-flow\n478:   woco abort auth-flow\n479:   woco abort auth-flow --requeue\n480:   woco abort auth-flow --output json\n481:   woco logs auth-flow\n482:   woco logs auth-flow --tail 50\n483:   woco logs auth-flow --follow\n484:   woco logs auth-flow --output json\n485:   woco cleanup\n486:   woco tasks list --status ready --priority high\n487:   woco tasks list --fields id,status,priority --output json\n488:   woco tasks add my-task \"My Cool Task\" --priority high --difficulty easy\n489:   woco tasks set-status my-task in-progress\n490:   woco tasks check\n491:   woco tasks archive --dry-run\n492:   woco tasks show my-task\n493:   woco history\n494:   woco history wave-2026-03-12-420\n495:   woco history --output json\n496:   woco describe                           # list all commands as JSON\n497:   woco describe launch                    # describe a specific command\n498:   woco describe tasks add                 # describe a subcommand\n499: `);\n500: }\n501: \n502: // ---------------------------------------------------------------------------\n503: // Main\n504: // ---------------------------------------------------------------------------\n505: \n506: async function main(): Promise<void> {\n507:   checkDevModeGuard();\n508: \n509:   const PROJECT_ROOT = resolve(process.cwd());\n510:   const args = parseArgs(process.argv);\n511: \n512:   // -----------------------------------------------------------------------\n513:   // Input validation at the CLI boundary\n514:   // -----------------------------------------------------------------------\n515:   if (args.featureId) {\n516:     assertValid(validateId(args.featureId, \"feature ID\"));\n517:   }\n518:   if (args.title) {\n519:     assertValid(validateText(args.title, \"title\"));\n520:   }\n521:   if (args.description) {\n522:     assertValid(validateText(args.description, \"description\"));\n523:   }\n524:   if (args.baseBranch) {\n525:     assertValid(validateBranchName(args.baseBranch, \"base branch\"));\n526:   }\n527:   if (args.effort) {\n528:     assertValid(validateDuration(args.effort, \"effort\"));\n529:   }\n530:   if (args.tasks) {\n531:     for (const fid of args.tasks) {\n532:       assertValid(validateId(fid, \"task ID in --tasks\"));\n533:     }\n534:   }\n535:   if (args.dependsOn) {\n536:     for (const dep of args.dependsOn) {\n537:       assertValid(validateId(dep, \"dependency ID in --depends-on\"));\n538:     }\n539:   }\n540: \n541:   // Commands that don't need config loading\n542:   if (args.command === \"version\" || args.command === \"-v\" || args.command === \"-V\") {\n543:     const pkgPath = resolve(import.meta.dir, \"..\", \"package.json\");\n544:     const pkgFile = Bun.file(pkgPath);\n545:     try {\n546:       const pkg = await pkgFile.json();\n547:       console.log(`wombo-combo ${pkg.version ?? \"(unknown version)\"}`);\n548:     } catch {\n549:       console.log(\"wombo-combo (unknown version)\");\n550:     }\n551:     return;\n552:   }\n553: \n554:   if (args.command === \"help\" || args.command === \"--help\" || args.command === \"-h\") {\n555:     cmdHelp();\n556:     return;\n557:   }\n558: \n559:   if (args.command === \"describe\") {\n560:     // Schema introspection: `woco describe [command]`\n561:     if (!args.featureId) {\n562:       // No command specified — list all commands\n563:       console.log(JSON.stringify(allCommandSchemas(), null, 2));\n564:     } else {\n565:       // Describe a specific command. Handle compound names: \"features list\"\n566:       const cmdName = args.title\n567:         ? `${args.featureId} ${args.title}`\n568:         : args.featureId;\n569:       const def = findCommandDef(cmdName);\n570:       if (!def) {\n571:         console.error(`Unknown command: \"${cmdName}\"`);\n572:         console.error(\"Run 'woco describe' to list all commands.\");\n573:         process.exit(1);\n574:         return;\n575:       }\n576:       console.log(JSON.stringify(commandToSchema(def), null, 2));\n577:     }\n578:     return;\n579:   }\n580: \n581:   if (args.command === \"init\") {\n582:     await cmdInit({ projectRoot: PROJECT_ROOT, force: args.force });\n583:     return;\n584:   }\n585: \n586:   if (args.command === \"upgrade\") {\n587:     await cmdUpgrade({\n588:       force: args.force,\n589:       tag: args.tag,\n590:       checkOnly: args.checkOnly,\n591:     });\n592:     return;\n593:   }\n594: \n595:   if (args.command === \"completion\") {\n596:     cmdCompletion({ shell: args.featureId }); // first positional = shell name\n597:     return;\n598:   }\n599: \n600:   if (args.command === \"logs\") {\n601:     if (!args.featureId) {\n602:       console.error(\"Usage: woco logs <feature-id> [--tail N] [--follow] [--output json]\");\n603:       process.exit(1);\n604:       return;\n605:     }\n606:     await cmdLogs({\n607:       projectRoot: PROJECT_ROOT,\n608:       featureId: args.featureId,\n609:       tail: args.tail,\n610:       follow: args.follow,\n611:       outputFmt: args.outputFmt,\n612:     });\n613:     return;\n614:   }\n615: \n616:   // Everything else requires config\n617:   const config = loadConfig(PROJECT_ROOT);\n618:   validateConfig(config);\n619: \n620:   // Commands that operate on the tasks file — ensure it exists first\n621:   const needsTasksFile = new Set([\"launch\", \"resume\", \"verify\", \"retry\", \"tasks\"]);\n622:   if (needsTasksFile.has(args.command)) {\n623:     await ensureTasksFile(PROJECT_ROOT, config);\n624:   }\n625: \n626:   switch (args.command) {\n627:     case \"launch\":\n628:       // Apply browser verification override if --browser flag was passed\n629:       if (args.browser !== undefined) {\n630:         config.browser.enabled = args.browser;\n631:       }\n632:       await cmdLaunch({\n633:         projectRoot: PROJECT_ROOT,\n634:         config,\n635:         topPriority: args.topPriority,\n636:         quickestWins: args.quickestWins,\n637:         priority: args.priority,\n638:         difficulty: args.difficulty,\n639:         features: args.tasks,\n640:         allReady: args.allReady,\n641:         maxConcurrent: args.maxConcurrent ?? config.defaults.maxConcurrent,\n642:         model: args.model,\n643:         interactive: args.interactive,\n644:         dryRun: args.dryRun,\n645:         baseBranch: args.baseBranch ?? config.baseBranch,\n646:         maxRetries: args.maxRetries ?? config.defaults.maxRetries,\n647:         noTui: args.noTui,\n648:         autoPush: args.autoPush,\n649:         outputFmt: args.outputFmt,\n650:       });\n651:       break;\n652: \n653:     case \"resume\":\n654:       await cmdResume({\n655:         projectRoot: PROJECT_ROOT,\n656:         config,\n657:         maxConcurrent: args.maxConcurrent,\n658:         model: args.model,\n659:         interactive: args.interactive,\n660:         noTui: args.noTui,\n661:         autoPush: args.autoPush,\n662:         baseBranch: args.baseBranch,\n663:         maxRetries: args.maxRetries,\n664:       });\n665:       break;\n666: \n667:     case \"status\":\n668:       await cmdStatus({ projectRoot: PROJECT_ROOT, config, outputFmt: args.outputFmt });\n669:       break;\n670: \n671:     case \"verify\":\n672:       await cmdVerify({\n673:         projectRoot: PROJECT_ROOT,\n674:         config,\n675:         featureId: args.featureId,\n676:         model: args.model,\n677:         maxRetries: args.maxRetries,\n678:         browserVerify: args.browser,\n679:       });\n680:       break;\n681: \n682:     case \"merge\":\n683:       await cmdMerge({\n684:         projectRoot: PROJECT_ROOT,\n685:         config,\n686:         featureId: args.featureId,\n687:         autoPush: args.autoPush,\n688:         dryRun: args.dryRun,\n689:         model: args.model,\n690:       });\n691:       break;\n692: \n693:     case \"retry\": {\n694:       if (!args.featureId) {\n695:         console.error(\"Usage: woco retry <feature-id>\");\n696:         process.exit(1);\n697:         return;\n698:       }\n699:       await cmdRetry({\n700:         projectRoot: PROJECT_ROOT,\n701:         config,\n702:         featureId: args.featureId,\n703:         model: args.model,\n704:         interactive: args.interactive,\n705:         dryRun: args.dryRun,\n706:       });\n707:       break;\n708:     }\n709: \n710:     case \"cleanup\":\n711:       await cmdCleanup({ projectRoot: PROJECT_ROOT, config, dryRun: args.dryRun });\n712:       break;\n713: \n714:     case \"history\":\n715:       await cmdHistory({\n716:         projectRoot: PROJECT_ROOT,\n717:         config,\n718:         waveId: args.featureId,\n719:         outputFmt: args.outputFmt,\n720:       });\n721:       break;\n722: \n723:     case \"abort\": {\n724:       if (!args.featureId) {\n725:         console.error(\"Usage: woco abort <feature-id> [--requeue] [--output json]\");\n726:         process.exit(1);\n727:         return;\n728:       }\n729:       await cmdAbort({\n730:         projectRoot: PROJECT_ROOT,\n731:         config,\n732:         featureId: args.featureId,\n733:         requeue: args.requeue,\n734:         outputFmt: args.outputFmt,\n735:       });\n736:       break;\n737:     }\n738: \n739:     case \"tasks\":\n740:       await handleTasksSubcommand(args, PROJECT_ROOT, config);\n741:       break;\n742: \n743:     default:\n744:       console.error(`Unknown command: ${args.command}`);\n745:       cmdHelp();\n746:       process.exit(1);\n747:       return;\n748:   }\n749: }\n750: \n751: // ---------------------------------------------------------------------------\n752: // Tasks Subcommand Router\n753: // ---------------------------------------------------------------------------\n754: \n755: async function handleTasksSubcommand(\n756:   args: CLIArgs,\n757:   projectRoot: string,\n758:   config: import(\"./config.js\").WomboConfig\n759: ): Promise<void> {\n760:   switch (args.subcommand) {\n761:     case \"list\":\n762:       await cmdTasksList({\n763:         projectRoot,\n764:         config,\n765:         status: args.status as FeatureStatus | undefined,\n766:         priority: args.priority,\n767:         difficulty: args.difficulty,\n768:         ready: args.ready,\n769:         includeArchive: args.includeArchive,\n770:         outputFmt: args.outputFmt,\n771:         fields: args.fields,\n772:       });\n773:       break;\n774: \n775:     case \"add\": {\n776:       if (!args.featureId || !args.title) {\n777:         console.error(\"Usage: woco tasks add <id> <title> [--desc <desc>] [--priority <p>] [--difficulty <d>] [--effort <e>] [--depends-on <ids>]\");\n778:         process.exit(1);\n779:         return;\n780:       }\n781:       await cmdTasksAdd({\n782:         projectRoot,\n783:         config,\n784:         id: args.featureId,\n785:         title: args.title,\n786:         description: args.description,\n787:         priority: args.priority,\n788:         difficulty: args.difficulty,\n789:         effort: args.effort,\n790:         dependsOn: args.dependsOn,\n791:         outputFmt: args.outputFmt,\n792:         dryRun: args.dryRun,\n793:       });\n794:       break;\n795:     }\n796: \n797:     case \"set-status\": {\n798:       if (!args.featureId || !args.title) {\n799:         // title holds the second positional arg (the status value)\n800:         // If not provided via positional, check --status flag\n801:         const newStatus = args.title || args.status;\n802:         if (!args.featureId || !newStatus) {\n803:           console.error(\"Usage: woco tasks set-status <task-id> <status>\");\n804:           process.exit(1);\n805:           return;\n806:         }\n807:         await cmdTasksSetStatus({\n808:           projectRoot,\n809:           config,\n810:           featureId: args.featureId,\n811:           newStatus,\n812:           outputFmt: args.outputFmt,\n813:           dryRun: args.dryRun,\n814:         });\n815:       } else {\n816:         await cmdTasksSetStatus({\n817:           projectRoot,\n818:           config,\n819:           featureId: args.featureId,\n820:           newStatus: args.title, // second positional = new status\n821:           outputFmt: args.outputFmt,\n822:           dryRun: args.dryRun,\n823:         });\n824:       }\n825:       break;\n826:     }\n827: \n828:     case \"set-priority\": {\n829:       if (!args.featureId || !args.title) {\n830:         // title holds the second positional arg (the priority value)\n831:         // If not provided via positional, check --priority flag\n832:         const newPriority = args.title || (args.priority as string | undefined);\n833:         if (!args.featureId || !newPriority) {\n834:           console.error(\"Usage: woco tasks set-priority <task-id> <priority>\");\n835:           process.exit(1);\n836:           return;\n837:         }\n838:         await cmdTasksSetPriority({\n839:           projectRoot,\n840:           config,\n841:           featureId: args.featureId,\n842:           newPriority,\n843:           outputFmt: args.outputFmt,\n844:           dryRun: args.dryRun,\n845:         });\n846:       } else {\n847:         await cmdTasksSetPriority({\n848:           projectRoot,\n849:           config,\n850:           featureId: args.featureId,\n851:           newPriority: args.title, // second positional = new priority\n852:           outputFmt: args.outputFmt,\n853:           dryRun: args.dryRun,\n854:         });\n855:       }\n856:       break;\n857:     }\n858: \n859:     case \"set-difficulty\": {\n860:       if (!args.featureId || !args.title) {\n861:         // title holds the second positional arg (the difficulty value)\n862:         // If not provided via positional, check --difficulty flag\n863:         const newDifficulty = args.title || (args.difficulty as string | undefined);\n864:         if (!args.featureId || !newDifficulty) {\n865:           console.error(\"Usage: woco tasks set-difficulty <task-id> <difficulty>\");\n866:           process.exit(1);\n867:           return;\n868:         }\n869:         await cmdTasksSetDifficulty({\n870:           projectRoot,\n871:           config,\n872:           featureId: args.featureId,\n873:           newDifficulty,\n874:           outputFmt: args.outputFmt,\n875:           dryRun: args.dryRun,\n876:         });\n877:       } else {\n878:         await cmdTasksSetDifficulty({\n879:           projectRoot,\n880:           config,\n881:           featureId: args.featureId,\n882:           newDifficulty: args.title, // second positional = new difficulty\n883:           outputFmt: args.outputFmt,\n884:           dryRun: args.dryRun,\n885:         });\n886:       }\n887:       break;\n888:     }\n889: \n890:     case \"check\":\n891:       await cmdTasksCheck({ projectRoot, config });\n892:       break;\n893: \n894:     case \"archive\":\n895:       a