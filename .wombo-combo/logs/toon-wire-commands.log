{"type":"tool_use","timestamp":1773437448466,"sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","part":{"id":"prt_ce91beca9001e4n0gRUK3ZGx90","sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","messageID":"msg_ce91bdf85001tydxXpQ6m4jZxZ","type":"tool","callID":"toolu_vrtx_01BgXBgFeYwKt4UbxoZDeiSD","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/retry.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/retry.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * retry.ts — Retry a specific failed agent.\n3:  *\n4:  * Usage: woco retry <feature-id> [--interactive] [--model <model>] [--output json]\n5:  *\n6:  * Resets the agent's retry count and re-launches it. Can launch in either\n7:  * headless mode (default) or interactive (dmux/tmux) mode.\n8:  */\n9: \n10: import type { WomboConfig } from \"../config.js\";\n11: import { loadFeatures, type Feature } from \"../lib/tasks.js\";\n12: import {\n13:   loadState,\n14:   saveState,\n15:   updateAgent,\n16: } from \"../lib/state.js\";\n17: import { worktreeReady } from \"../lib/worktree.js\";\n18: import { generatePrompt } from \"../lib/prompt.js\";\n19: import { launchInteractive, getMultiplexerName } from \"../lib/launcher.js\";\n20: import { ProcessMonitor } from \"../lib/monitor.js\";\n21: import { launchSingleHeadless } from \"./launch.js\";\n22: import { output, outputError, outputMessage, type OutputFormat } from \"../lib/output.js\";\n23: \n24: // ---------------------------------------------------------------------------\n25: // Types\n26: // ---------------------------------------------------------------------------\n27: \n28: export interface RetryCommandOptions {\n29:   projectRoot: string;\n30:   config: WomboConfig;\n31:   featureId: string;\n32:   model?: string;\n33:   interactive: boolean;\n34:   dryRun?: boolean;\n35:   outputFmt?: OutputFormat;\n36: }\n37: \n38: // ---------------------------------------------------------------------------\n39: // Command\n40: // ---------------------------------------------------------------------------\n41: \n42: export async function cmdRetry(opts: RetryCommandOptions): Promise<void> {\n43:   const { projectRoot, config } = opts;\n44:   const fmt = opts.outputFmt ?? \"text\";\n45: \n46:   if (!opts.featureId) {\n47:     outputError(fmt, \"Usage: woco retry <feature-id>\");\n48:     return; // unreachable — outputError calls process.exit\n49:   }\n50: \n51:   const state = loadState(projectRoot);\n52:   if (!state) {\n53:     outputMessage(fmt, \"No active wave.\", { wave_id: null });\n54:     return;\n55:   }\n56: \n57:   const agent = state.agents.find((a) => a.feature_id === opts.featureId);\n58:   if (!agent) {\n59:     outputError(fmt, `Agent not found for feature: ${opts.featureId}`);\n60:     return; // unreachable\n61:   }\n62: \n63:   if (agent.status !== \"failed\") {\n64:     outputError(\n65:       fmt,\n66:       `Agent ${opts.featureId} is not in failed state (current: ${agent.status})`\n67:     );\n68:     return; // unreachable\n69:   }\n70: \n71:   // Dry-run: show what would be retried without doing it\n72:   if (opts.dryRun) {\n73:     const dryRunResult = {\n74:       dry_run: true,\n75:       feature_id: opts.featureId,\n76:       current_status: agent.status,\n77:       retries_so_far: agent.retries,\n78:       worktree: agent.worktree,\n79:       mode: opts.interactive ? \"interactive\" : \"headless\",\n80:       model: opts.model ?? null,\n81:     };\n82: \n83:     output(fmt, dryRunResult, () => {\n84:       console.log(`\\n[dry-run] Would retry agent: ${opts.featureId}`);\n85:       console.log(`  Current status: ${agent.status}`);\n86:       console.log(`  Retries so far: ${agent.retries}`);\n87:       console.log(`  Worktree: ${agent.worktree}`);\n88:       console.log(`  Mode: ${opts.interactive ? \"interactive (multiplexer)\" : \"headless\"}`);\n89:       if (opts.model) console.log(`  Model: ${opts.model}`);\n90:     });\n91:     return;\n92:   }\n93: \n94:   // Reset retry count and re-run\n95:   updateAgent(state, agent.feature_id, {\n96:     status: \"queued\",\n97:     retries: 0,\n98:     error: null,\n99:     build_passed: null,\n100:     build_output: null,\n101:     completed_at: null,\n102:   });\n103:   saveState(projectRoot, state);\n104: \n105:   const data = loadFeatures(projectRoot, config);\n106:   const feature = data.tasks.find((f: Feature) => f.id === opts.featureId);\n107:   if (!feature) {\n108:     outputError(fmt, `Feature ${opts.featureId} not found in ${config.tasksDir}`);\n109:     return; // unreachable\n110:   }\n111: \n112:   if (opts.interactive) {\n113:     const prompt = generatePrompt(feature, state.base_branch, config);\n114:     launchInteractive({\n115:       worktreePath: agent.worktree,\n116:       featureId: feature.id,\n117:       prompt,\n118:       model: opts.model,\n119:       interactive: true,\n120:       config,\n121:     });\n122: \n123:     updateAgent(state, agent.feature_id, {\n124:       status: \"running\",\n125:       started_at: new Date().toISOString(),\n126:     });\n127:     saveState(projectRoot, state);\n128:     const muxName = getMultiplexerName(config);\n129: \n130:     output(fmt, {\n131:       feature_id: opts.featureId,\n132:       mode: \"interactive\",\n133:       status: \"running\",\n134:       mux_session: `${config.agent.tmuxPrefix}-${opts.featureId}`,\n135:     }, () => {\n136:       console.log(`Retrying ${opts.featureId} in ${muxName} session ${config.agent.tmuxPrefix}-${opts.featureId}`);\n137:     });\n138:   } else {\n139:     const monitor = new ProcessMonitor(projectRoot);\n140:     await launchSingleHeadless(projectRoot, state, agent, feature, monitor, config, opts.model);\n141: \n142:     // Re-read agent after launch to get PID\n143:     const updatedAgent = state.agents.find((a) => a.feature_id === opts.featureId);\n144: \n145:     output(fmt, {\n146:       feature_id: opts.featureId,\n147:       mode: \"headless\",\n148:       status: updatedAgent?.status ?? \"running\",\n149:       pid: updatedAgent?.pid ?? null,\n150:     }, () => {\n151:       console.log(`Retrying ${opts.featureId} in headless mode`);\n152:     });\n153:   }\n154: }\n\n(End of file - total 154 lines)\n</content>","title":"src/commands/retry.ts","metadata":{"preview":"/**\n * retry.ts — Retry a specific failed agent.\n *\n * Usage: woco retry <feature-id> [--interactive] [--model <model>] [--output json]\n *\n * Resets the agent's retry count and re-launches it. Can launch in either\n * headless mode (default) or interactive (dmux/tmux) mode.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport { loadFeatures, type Feature } from \"../lib/tasks.js\";\nimport {\n  loadState,\n  saveState,\n  updateAgent,\n} from \"../lib/state.js\";\nimport { worktreeReady } from \"../lib/worktree.js\";\nimport { generatePrompt } from \"../lib/prompt.js\";\nimport { launchInteractive, getMultiplexerName } from \"../lib/launcher.js\";\nimport { ProcessMonitor } from \"../lib/monitor.js\";","truncated":false,"loaded":[]},"time":{"start":1773437448464,"end":1773437448466}}}}
{"type":"tool_use","timestamp":1773437448979,"sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","part":{"id":"prt_ce91bf179001dQmclqTH9z71W7","sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","messageID":"msg_ce91bdf85001tydxXpQ6m4jZxZ","type":"tool","callID":"toolu_vrtx_014TKeBJ8BfKw5csgpqoAsPS","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/resume.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/resume.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * resume.ts — Resume a previously stopped wave.\n3:  *\n4:  * Usage: woco resume [options] [--output json]\n5:  *\n6:  * Restores from .wombo-combo/state.json:\n7:  *   - Agents in \"running\"/\"installing\" whose PID is dead → re-check or re-launch\n8:  *   - Agents in \"queued\" → launch them\n9:  *   - Agents in terminal states (verified/failed/merged) → leave alone\n10:  */\n11: \n12: import type { WomboConfig } from \"../config.js\";\n13: import type { Feature } from \"../lib/tasks.js\";\n14: import { loadFeatures } from \"../lib/tasks.js\";\n15: import {\n16:   loadState,\n17:   saveState,\n18:   updateAgent,\n19:   queuedAgents,\n20:   readyToLaunchAgents,\n21:   cancelDownstream,\n22:   isWaveComplete,\n23:   type WaveState,\n24:   type AgentState,\n25: } from \"../lib/state.js\";\n26: import {\n27:   createWorktree,\n28:   installDeps,\n29:   worktreeReady,\n30:   worktreeExists,\n31:   branchHasChanges,\n32:   removeWorktree,\n33:   log as wtLog,\n34: } from \"../lib/worktree.js\";\n35: import { generatePrompt } from \"../lib/prompt.js\";\n36: import {\n37:   launchInteractive,\n38:   isProcessRunning,\n39:   getMultiplexerName,\n40: } from \"../lib/launcher.js\";\n41: import { ProcessMonitor } from \"../lib/monitor.js\";\n42: import { pushBaseBranch } from \"../lib/merger.js\";\n43: import { runBuild } from \"../lib/verifier.js\";\n44: import { printDashboard, printAgentUpdate } from \"../lib/ui.js\";\n45: import { WomboTUI } from \"../lib/tui.js\";\n46: import {\n47:   launchSingleHeadless,\n48:   handleBuildVerification,\n49:   handleRetry,\n50:   launchNextQueued,\n51:   launchAllReady,\n52:   markFeatureDone,\n53:   attemptMerge,\n54:   dumpFailedAgentLogs,\n55: } from \"./launch.js\";\n56: import {\n57:   detectMultiplexer,\n58:   muxAttachCommand,\n59: } from \"../lib/multiplexer.js\";\n60: import { exportWaveHistory } from \"../lib/history.js\";\n61: import { outputError, outputMessage, type OutputFormat } from \"../lib/output.js\";\n62: \n63: // ---------------------------------------------------------------------------\n64: // Types\n65: // ---------------------------------------------------------------------------\n66: \n67: export interface ResumeCommandOptions {\n68:   projectRoot: string;\n69:   config: WomboConfig;\n70:   maxConcurrent?: number;\n71:   model?: string;\n72:   interactive: boolean;\n73:   noTui: boolean;\n74:   autoPush: boolean;\n75:   baseBranch?: string;\n76:   maxRetries?: number;\n77:   outputFmt?: OutputFormat;\n78: }\n79: \n80: // ---------------------------------------------------------------------------\n81: // Command\n82: // ---------------------------------------------------------------------------\n83: \n84: export async function cmdResume(opts: ResumeCommandOptions): Promise<void> {\n85:   const { projectRoot, config } = opts;\n86:   const fmt = opts.outputFmt ?? \"text\";\n87: \n88:   const state = loadState(projectRoot);\n89:   if (!state) {\n90:     outputError(fmt, \"No wave state found. Use 'woco launch' to start a new wave.\");\n91:     return; // unreachable — outputError calls process.exit\n92:   }\n93: \n94:   if (fmt === \"text\") {\n95:     console.log(`\\n--- wombo-combo: Resume ${state.wave_id} ---\\n`);\n96:   }\n97: \n98:   // Load feature data for prompt generation\n99:   const data = loadFeatures(projectRoot, config);\n100:   const featureMap = new Map(data.tasks.map((f: Feature) => [f.id, f]));\n101: \n102:   // Triage agents by current state\n103:   let toRelaunch: AgentState[] = [];\n104:   let toVerify: AgentState[] = [];\n105: \n106:   for (const agent of state.agents) {\n107:     switch (agent.status) {\n108:       case \"running\":\n109:       case \"installing\":\n110:       case \"retry\":\n111:       case \"resolving_conflict\":\n112:         // Was in-flight when we stopped — check if PID is still alive\n113:         if (agent.pid && isProcessRunning(agent.pid)) {\n114:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: still running (PID ${agent.pid}), leaving alone`);\n115:         } else {\n116:           // Process is dead — check if worktree exists with meaningful changes.\n117:           // Use worktreeExists (not worktreeReady) because node_modules may be\n118:           // missing — the worktree still has code that should be verified.\n119:           if (worktreeExists(agent.worktree) && branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n120:             // Worktree exists AND branch has commits — try build verification\n121:             if (fmt === \"text\") console.log(`  ${agent.feature_id}: process dead, worktree has changes — will verify build`);\n122:             toVerify.push(agent);\n123:           } else {\n124:             // No worktree, or worktree exists but branch has no commits (agent did nothing)\n125:             const reason = worktreeExists(agent.worktree)\n126:               ? \"worktree exists but no code changes\"\n127:               : \"no worktree\";\n128:             if (fmt === \"text\") console.log(`  ${agent.feature_id}: process dead, ${reason} — will re-launch`);\n129:             updateAgent(state, agent.feature_id, {\n130:               status: \"queued\",\n131:               pid: null,\n132:               activity: null,\n133:               session_id: null,\n134:             });\n135:             toRelaunch.push(agent);\n136:           }\n137:         }\n138:         break;\n139: \n140:       case \"queued\":\n141:         if (fmt === \"text\") console.log(`  ${agent.feature_id}: queued — will launch`);\n142:         toRelaunch.push(agent);\n143:         break;\n144: \n145:       case \"completed\":\n146:         // Completed but not verified — verify\n147:         if (fmt === \"text\") console.log(`  ${agent.feature_id}: completed — will verify build`);\n148:         toVerify.push(agent);\n149:         break;\n150: \n151:       case \"verified\":\n152:         // Build passed but NOT yet merged — need to attempt merge (+ conflict resolution)\n153:         if (fmt === \"text\") console.log(`  ${agent.feature_id}: verified — will attempt merge`);\n154:         toVerify.push(agent);\n155:         break;\n156: \n157:       case \"merged\":\n158:         if (fmt === \"text\") console.log(`  ${agent.feature_id}: merged — marking feature as done`);\n159:         markFeatureDone(projectRoot, agent.feature_id, config, state.base_branch);\n160:         try {\n161:           removeWorktree(projectRoot, agent.worktree, true);\n162:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: worktree and branch removed`);\n163:         } catch {\n164:           // Already cleaned — not critical\n165:         }\n166:         break;\n167: \n168:       case \"failed\":\n169:         // If the worktree exists with code changes and retries remain,\n170:         // attempt build verification rather than discarding the work.\n171:         if (agent.retries < agent.max_retries &&\n172:             worktreeExists(agent.worktree) &&\n173:             branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n174:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: failed but has work (retry ${agent.retries}/${agent.max_retries}) — will verify build`);\n175:           // Clear stale error and mark as completed so handleBuildVerification\n176:           // processes it correctly (it expects a non-failed agent)\n177:           updateAgent(state, agent.feature_id, {\n178:             status: \"completed\",\n179:             error: null,\n180:             build_passed: null,\n181:             build_output: null,\n182:             completed_at: new Date().toISOString(),\n183:           });\n184:           toVerify.push(agent);\n185:         } else if (agent.retries < agent.max_retries) {\n186:           // No worktree or no changes — re-launch from scratch\n187:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: failed, no salvageable work (retry ${agent.retries}/${agent.max_retries}) — will re-launch`);\n188:           updateAgent(state, agent.feature_id, {\n189:             status: \"queued\",\n190:             pid: null,\n191:             error: null,\n192:             build_passed: null,\n193:             build_output: null,\n194:             activity: null,\n195:             session_id: null,\n196:             completed_at: null,\n197:           });\n198:           toRelaunch.push(agent);\n199:         } else {\n200:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: failed — max retries reached (use 'woco retry' to reset)`);\n201:         }\n202:         break;\n203:     }\n204:   }\n205: \n206:   saveState(projectRoot, state);\n207: \n208:   // ---------------------------------------------------------------------------\n209:   // Phase 1: Parallel build verification\n210:   // Each agent's worktree is independent, so dep install + build can run\n211:   // concurrently. Merges must remain sequential (they mutate the project root).\n212:   // ---------------------------------------------------------------------------\n213:   if (toVerify.length > 0) {\n214:     if (fmt === \"text\") console.log(`\\nVerifying ${toVerify.length} agent(s) in parallel...\\n`);\n215: \n216:     const verifyResults = await Promise.all(\n217:       toVerify.map(async (agent): Promise<{ agent: AgentState; needsMerge: boolean }> => {\n218:         const feature = featureMap.get(agent.feature_id);\n219:         if (!feature) return { agent, needsMerge: false };\n220: \n221:         // Already verified — skip build, go straight to merge\n222:         if (agent.status === \"verified\") {\n223:           printAgentUpdate(agent, \"already verified — queued for merge\");\n224:           return { agent, needsMerge: true };\n225:         }\n226: \n227:         printAgentUpdate(agent, \"verifying build...\");\n228: \n229:         // Ensure deps are installed — worktree may exist without node_modules\n230:         // (e.g., failed agents whose setup was interrupted)\n231:         if (!worktreeReady(agent.worktree) && worktreeExists(agent.worktree)) {\n232:           try {\n233:             printAgentUpdate(agent, \"installing deps...\");\n234:             await installDeps(agent.worktree, agent.feature_id, config);\n235:           } catch (depErr: any) {\n236:             printAgentUpdate(agent, `dep install failed: ${depErr.message}`);\n237:             updateAgent(state, agent.feature_id, {\n238:               status: \"failed\",\n239:               error: `Dependency install failed: ${depErr.message}`,\n240:               retries: agent.retries + 1,\n241:               completed_at: new Date().toISOString(),\n242:             });\n243:             saveState(projectRoot, state);\n244:             return { agent, needsMerge: false };\n245:           }\n246:         }\n247: \n248:         try {\n249:           const buildResult = await runBuild(agent.worktree, config);\n250:           if (buildResult.passed) {\n251:             updateAgent(state, agent.feature_id, {\n252:               status: \"verified\",\n253:               build_passed: true,\n254:               build_output: null,\n255:             });\n256:             saveState(projectRoot, state);\n257:             printAgentUpdate(agent, `BUILD PASSED (${Math.round(buildResult.durationMs / 1000)}s)`);\n258:             return { agent, needsMerge: true };\n259:           } else {\n260:             // Build failed\n261:             if (agent.retries < agent.max_retries) {\n262:               updateAgent(state, agent.feature_id, {\n263:                 status: \"retry\",\n264:                 retries: agent.retries + 1,\n265:                 build_passed: false,\n266:                 build_output: buildResult.errorSummary,\n267:               });\n268:               saveState(projectRoot, state);\n269:               printAgentUpdate(agent, `BUILD FAILED — will retry (${agent.retries + 1}/${agent.max_retries})`);\n270:             } else {\n271:               updateAgent(state, agent.feature_id, {\n272:                 status: \"failed\",\n273:                 build_passed: false,\n274:                 build_output: buildResult.errorSummary,\n275:                 error: `Build failed after ${agent.max_retries} retries`,\n276:                 completed_at: new Date().toISOString(),\n277:               });\n278:               saveState(projectRoot, state);\n279:               printAgentUpdate(agent, \"BUILD FAILED — max retries reached\");\n280:             }\n281:             return { agent, needsMerge: false };\n282:           }\n283:         } catch (err: any) {\n284:           printAgentUpdate(agent, `verify error: ${err.message}`);\n285:           updateAgent(state, agent.feature_id, {\n286:             status: \"failed\",\n287:             error: `Build verification error: ${err.message}`,\n288:             completed_at: new Date().toISOString(),\n289:           });\n290:           saveState(projectRoot, state);\n291:           return { agent, needsMerge: false };\n292:         }\n293:       })\n294:     );\n295: \n296:     saveState(projectRoot, state);\n297: \n298:     // -------------------------------------------------------------------------\n299:     // Phase 2: Sequential merge for verified agents\n300:     // Merges must be sequential because they operate on the project root.\n301:     // -------------------------------------------------------------------------\n302:     const toMerge = verifyResults.filter((r) => r.needsMerge);\n303:     if (toMerge.length > 0) {\n304:       if (fmt === \"text\") console.log(`\\nMerging ${toMerge.length} verified agent(s)...\\n`);\n305:       for (const { agent } of toMerge) {\n306:         const feature = featureMap.get(agent.feature_id);\n307:         if (!feature) continue;\n308:         try {\n309:           await attemptMerge(projectRoot, state, agent, feature, config, opts.model);\n310:         } catch (err: any) {\n311:           printAgentUpdate(agent, `merge error: ${err.message}`);\n312:         }\n313:       }\n314:     }\n315: \n316:     // Collect agents that need re-launching from verify results\n317:     for (const { agent } of verifyResults) {\n318:       if (agent.status === \"retry\" || agent.status === \"running\") {\n319:         toRelaunch.push(agent);\n320:       }\n321:     }\n322:   }\n323: \n324:   // Re-launch agents\n325:   const maxConcurrent = opts.maxConcurrent ?? state.max_concurrent;\n326:   const toLaunchNow = toRelaunch.slice(0, maxConcurrent);\n327:   if (toLaunchNow.length === 0) {\n328:     outputMessage(fmt, \"No agents need (re)launching.\", {\n329:       wave_id: state.wave_id,\n330:       triage: {\n331:         to_verify: toVerify.length,\n332:         to_relaunch: 0,\n333:       },\n334:       agents: state.agents.map((a) => ({\n335:         feature_id: a.feature_id,\n336:         status: a.status,\n337:         build_passed: a.build_passed,\n338:         error: a.error,\n339:       })),\n340:     });\n341:     if (fmt === \"text\") printDashboard(state);\n342:     return;\n343:   }\n344: \n345:   if (fmt === \"text\") {\n346:     console.log(`\\nRe-launching ${toLaunchNow.length} agent(s)...\\n`);\n347:     printDashboard(state);\n348:   }\n349:   const model = opts.model ?? state.model ?? undefined;\n350: \n351:   if (opts.interactive) {\n352:     // Interactive resume\n353:     await Promise.all(\n354:       toLaunchNow.map(async (agent) => {\n355:         const feature = featureMap.get(agent.feature_id);\n356:         if (!feature) return;\n357: \n358:         updateAgent(state, agent.feature_id, {\n359:           status: \"installing\",\n360:           started_at: new Date().toISOString(),\n361:           activity: \"resuming...\",\n362:         });\n363:         saveState(projectRoot, state);\n364: \n365:         try {\n366:           if (!worktreeReady(agent.worktree)) {\n367:             await createWorktree(projectRoot, agent.feature_id, state.base_branch, config);\n368:             await installDeps(agent.worktree, agent.feature_id, config);\n369:           }\n370: \n371:           const prompt = generatePrompt(feature, state.base_branch, config);\n372:           const result = launchInteractive({\n373:             worktreePath: agent.worktree,\n374:             featureId: feature.id,\n375:             prompt,\n376:             model,\n377:             interactive: true,\n378:             config,\n379:           });\n380: \n381:           const muxName = getMultiplexerName(config);\n382:           updateAgent(state, agent.feature_id, {\n383:             status: \"running\",\n384:             pid: result.pid,\n385:             activity: `${muxName} session active`,\n386:           });\n387:           saveState(projectRoot, state);\n388:         } catch (err: any) {\n389:           updateAgent(state, agent.feature_id, {\n390:             status: \"failed\",\n391:             error: err.message,\n392:             activity: null,\n393:             completed_at: new Date().toISOString(),\n394:           });\n395:           saveState(projectRoot, state);\n396:         }\n397:       })\n398:     );\n399: \n400:     if (fmt === \"text\") {\n401:       printDashboard(state);\n402:       const mux = detectMultiplexer(config.agent.multiplexer);\n403:       console.log(`\\nResume complete. Use '${muxAttachCommand(mux, `${config.agent.tmuxPrefix}-<id>`)}' to check sessions.`);\n404:     }\n405:   } else {\n406:     // Headless resume — re-enter monitoring loop\n407:     const monitor = new ProcessMonitor(projectRoot, {\n408:       onSessionId: (featureId, sessionId) => {\n409:         updateAgent(state, featureId, { session_id: sessionId });\n410:         saveState(projectRoot, state);\n411:       },\n412:       onComplete: (featureId) => {\n413:         updateAgent(state, featureId, {\n414:           status: \"completed\",\n415:           completed_at: new Date().toISOString(),\n416:           activity: \"done\",\n417:         });\n418:         saveState(projectRoot, state);\n419:         wtLog(featureId, \"agent completed — verifying build...\");\n420: \n421:         const agent = state.agents.find((a) => a.feature_id === featureId)!;\n422:         const feature = featureMap.get(featureId)!;\n423:         handleBuildVerification(projectRoot, state, agent, feature, config, model, monitor)\n424:           .then(() => launchAllReady(projectRoot, state, featureMap, monitor, config, model))\n425:           .catch((err) => {\n426:             wtLog(featureId, `BUILD VERIFICATION UNHANDLED ERROR: ${err.message}`);\n427:             launchAllReady(projectRoot, state, featureMap, monitor, config, model);\n428:           });\n429:       },\n430:       onError: (featureId, error) => {\n431:         const agent = state.agents.find((a) => a.feature_id === featureId)!;\n432:         if (agent.retries < agent.max_retries) {\n433:           updateAgent(state, featureId, {\n434:             status: \"retry\",\n435:             retries: agent.retries + 1,\n436:             error,\n437:             activity: \"retrying...\",\n438:           });\n439:           saveState(projectRoot, state);\n440:           handleRetry(projectRoot, state, agent, monitor, config, model);\n441:         } else {\n442:           updateAgent(state, featureId, {\n443:             status: \"failed\",\n444:             error,\n445:             activity: null,\n446:             completed_at: new Date().toISOString(),\n447:           });\n448:           saveState(projectRoot, state);\n449: \n450:           // Cascade failure to downstream agents\n451:           const cancelled = cancelDownstream(state, featureId);\n452:           if (cancelled.length > 0) {\n453:             wtLog(featureId, `downstream cancelled: ${cancelled.join(\", \")}`);\n454:             saveState(projectRoot, state);\n455:           }\n456:         }\n457:         launchAllReady(projectRoot, state, featureMap, monitor, config, model);\n458:       },\n459:       onActivity: (featureId, activity) => {\n460:         updateAgent(state, featureId, {\n461:           activity,\n462:           activity_updated_at: new Date().toISOString(),\n463:         });\n464:       },\n465:     });\n466: \n467:     // Handle graceful shutdown\n468:     const tuiRef = { current: null as WomboTUI | null };\n469:     process.on(\"SIGINT\", () => {\n470:       if (tuiRef.current) tuiRef.current.stop();\n471:       for (const agent of state.agents) {\n472:         if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n473:           updateAgent(state, agent.feature_id, {\n474:             activity: \"interrupted\",\n475:           });\n476:         }\n477:       }\n478:       monitor.killAll();\n479:       saveState(projectRoot, state);\n480:       if (fmt === \"text\") console.log(\"\\nState saved. Use 'woco resume' to continue.\");\n481:       process.exit(0);\n482:     });\n483: \n484:     await Promise.all(\n485:       toLaunchNow.map((agent) => {\n486:         const feature = featureMap.get(agent.feature_id);\n487:         if (!feature) return Promise.resolve();\n488:         return launchSingleHeadless(projectRoot, state, agent, feature, monitor, config, model);\n489:       })\n490:     );\n491: \n492:     // Start TUI dashboard (or skip if --no-tui)\n493:     if (!opts.noTui) {\n494:       tuiRef.current = new WomboTUI({\n495:         state,\n496:         monitor,\n497:         projectRoot,\n498:         interactive: false,\n499:         config,\n500:         onQuit: () => {\n501:           for (const agent of state.agents) {\n502:             if (agent.status === \"running\") {\n503:               updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n504:             }\n505:           }\n506:           monitor.killAll();\n507:           saveState(projectRoot, state);\n508:           if (fmt === \"text\") console.log(\"State saved. Use 'woco resume' to continue.\");\n509:           process.exit(0);\n510:         },\n511:         onRetry: (featureId: string) => {\n512:           const agent = state.agents.find((a) => a.feature_id === featureId);\n513:           if (!agent) return;\n514:           if (agent.status !== \"failed\" && agent.status !== \"retry\") return;\n515: \n516:           // Reset retries if exhausted, give it one more shot\n517:           if (agent.retries >= agent.max_retries) {\n518:             updateAgent(state, featureId, { max_retries: agent.retries + 1 });\n519:           }\n520: \n521:           wtLog(featureId, `manual retry requested from TUI — resetting to queued`);\n522:           updateAgent(state, featureId, {\n523:             status: \"queued\",\n524:             error: null,\n525:             activity: \"waiting for relaunch (manual retry)...\",\n526:           });\n527:           saveState(projectRoot, state);\n528:         },\n529:       });\n530:       tuiRef.current.start();\n531:     } else {\n532:       if (fmt === \"text\") console.log(\"(--no-tui mode, dashboard prints every 15s)\\n\");\n533:       printDashboard(state);\n534:     }\n535: \n536:     // Monitoring loop\n537:     const POLL_INTERVAL = 5000;\n538:     let dashboardCounter = 0;\n539:     while (!isWaveComplete(state)) {\n540:       await new Promise((r) => setTimeout(r, POLL_INTERVAL));\n541: \n542:       for (const agent of state.agents) {\n543:         if (\n544:           (agent.status === \"running\" || agent.status === \"resolving_conflict\") &&\n545:           agent.pid &&\n546:           !isProcessRunning(agent.pid) &&\n547:           !monitor.isRunning(agent.feature_id)\n548:         ) {\n549:           if (agent.status === \"resolving_conflict\") {\n550:             // Conflict resolver died unexpectedly — mark as failed\n551:             updateAgent(state, agent.feature_id, {\n552:               status: \"failed\",\n553:               error: \"Conflict resolver process died unexpectedly\",\n554:               activity: null,\n555:               completed_at: new Date().toISOString(),\n556:             });\n557:             saveState(projectRoot, state);\n558:             wtLog(agent.feature_id, \"conflict resolver died — marked failed\");\n559: \n560:             // Cascade failure to downstream agents\n561:             const cancelled = cancelDownstream(state, agent.feature_id);\n562:             if (cancelled.length > 0) {\n563:               wtLog(agent.feature_id, `downstream cancelled: ${cancelled.join(\", \")}`);\n564:               saveState(projectRoot, state);\n565:             }\n566: \n567:             launchAllReady(projectRoot, state, featureMap, monitor, config, model);\n568:             continue;\n569:           }\n570:           // Check if the agent actually made any commits\n571:           if (!branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n572:             // Agent died without producing any code — mark as failed\n573:             updateAgent(state, agent.feature_id, {\n574:               status: \"failed\",\n575:               error: \"Agent process exited without making any commits\",\n576:               activity: null,\n577:               completed_at: new Date().toISOString(),\n578:             });\n579:             saveState(projectRoot, state);\n580:             wtLog(agent.feature_id, \"process died with no code changes — marked failed\");\n581: \n582:             // Cascade failure to downstream agents\n583:             const cancelled = cancelDownstream(state, agent.feature_id);\n584:             if (cancelled.length > 0) {\n585:               wtLog(agent.feature_id, `downstream cancelled: ${cancelled.join(\", \")}`);\n586:               saveState(projectRoot, state);\n587:             }\n588:           } else {\n589:             updateAgent(state, agent.feature_id, {\n590:               status: \"completed\",\n591:               completed_at: new Date().toISOString(),\n592:               activity: \"done\",\n593:             });\n594:             saveState(projectRoot, state);\n595:             const feature = featureMap.get(agent.feature_id)!;\n596:             try {\n597:               await handleBuildVerification(projectRoot, state, agent, feature, config, model, monitor);\n598:             } catch (err: any) {\n599:               wtLog(agent.feature_id, `POLL VERIFY ERROR: ${err.message}`);\n600:             }\n601:           }\n602:           launchAllReady(projectRoot, state, featureMap, monitor, config, model);\n603:         }\n604:       }\n605: \n606:       saveState(projectRoot, state);\n607:       if (tuiRef.current) {\n608:         tuiRef.current.updateState(state);\n609:       } else if (opts.noTui) {\n610:         dashboardCounter++;\n611:         if (dashboardCounter % 3 === 0) {\n612:           printDashboard(state);\n613:         }\n614:       }\n615:     }\n616: \n617:     // Wave complete — keep TUI open for post-mortem browsing\n618:     if (tuiRef.current) {\n619:       tuiRef.current.updateState(state);\n620:       tuiRef.current.markWaveComplete();\n621:       await tuiRef.current.waitForQuit();\n622:     }\n623: \n624:     if (fmt === \"text\") {\n625:       printDashboard(state);\n626: \n627:       // Dump full logs for failed agents (post-mortem)\n628:       dumpFailedAgentLogs(projectRoot, state);\n629:     }\n630: \n631:     // Auto-export wave history\n632:     try {\n633:       const historyPath = exportWaveHistory(projectRoot, state);\n634:       if (fmt === \"text\") console.log(`Wave history exported to ${historyPath}`);\n635:     } catch (err: any) {\n636:       if (fmt === \"text\") console.error(`Warning: failed to export wave history: ${err.message}`);\n637:     }\n638: \n639:     // Auto-push base branch if requested\n640:     if (opts.autoPush) {\n641:       await pushBaseBranch(projectRoot, state.base_branch, config);\n642:     }\n643: \n644:     if (fmt === \"text\") console.log(\"Wave complete.\");\n645:   }\n646: }\n\n(End of file - total 646 lines)\n</content>","title":"src/commands/resume.ts","metadata":{"preview":"/**\n * resume.ts — Resume a previously stopped wave.\n *\n * Usage: woco resume [options] [--output json]\n *\n * Restores from .wombo-combo/state.json:\n *   - Agents in \"running\"/\"installing\" whose PID is dead → re-check or re-launch\n *   - Agents in \"queued\" → launch them\n *   - Agents in terminal states (verified/failed/merged) → leave alone\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport type { Feature } from \"../lib/tasks.js\";\nimport { loadFeatures } from \"../lib/tasks.js\";\nimport {\n  loadState,\n  saveState,\n  updateAgent,\n  queuedAgents,\n  readyToLaunchAgents,","truncated":false,"loaded":[]},"time":{"start":1773437448976,"end":1773437448978}}}}
{"type":"tool_use","timestamp":1773437449597,"sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","part":{"id":"prt_ce91bf3db001lN0DFVQ2IdMdcA","sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","messageID":"msg_ce91bdf85001tydxXpQ6m4jZxZ","type":"tool","callID":"toolu_vrtx_01TrKYEQ8A6zUzuy2oPAbCwT","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/logs.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/logs.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * logs.ts — Pretty-print agent logs from .wombo-combo/logs/<feature-id>.log.\n3:  *\n4:  * Usage:\n5:  *   woco logs <feature-id>\n6:  *   woco logs <feature-id> --tail 50\n7:  *   woco logs <feature-id> --follow\n8:  *   woco logs <feature-id> --output json\n9:  *\n10:  * Reads the log file written by ProcessMonitor during headless agent runs\n11:  * and displays it with timestamps and activity annotations. Supports\n12:  * --tail N to show last N lines and --follow to stream new output.\n13:  */\n14: \n15: import { resolve } from \"node:path\";\n16: import { existsSync, readFileSync, statSync, openSync, readSync, closeSync } from \"node:fs\";\n17: import { output, outputError, type OutputFormat } from \"../lib/output.js\";\n18: \n19: // ---------------------------------------------------------------------------\n20: // Constants\n21: // ---------------------------------------------------------------------------\n22: \n23: const LOG_DIR_NAME = \".wombo-combo/logs\";\n24: \n25: // ---------------------------------------------------------------------------\n26: // Types\n27: // ---------------------------------------------------------------------------\n28: \n29: export interface LogsCommandOptions {\n30:   projectRoot: string;\n31:   featureId: string;\n32:   /** Show only the last N lines */\n33:   tail?: number;\n34:   /** Stream new output as it arrives (like tail -f) */\n35:   follow?: boolean;\n36:   /** Output format */\n37:   outputFmt: OutputFormat;\n38: }\n39: \n40: interface LogLine {\n41:   lineNumber: number;\n42:   content: string;\n43: }\n44: \n45: // ---------------------------------------------------------------------------\n46: // Helpers\n47: // ---------------------------------------------------------------------------\n48: \n49: /**\n50:  * Read all lines from a log file, optionally returning only the last N.\n51:  */\n52: function readLogLines(logPath: string, tail?: number): LogLine[] {\n53:   const raw = readFileSync(logPath, \"utf-8\");\n54:   const allLines = raw.split(\"\\n\");\n55: \n56:   // Remove trailing empty line from split (if file ends with \\n)\n57:   if (allLines.length > 0 && allLines[allLines.length - 1] === \"\") {\n58:     allLines.pop();\n59:   }\n60: \n61:   let lines: LogLine[] = allLines.map((content, idx) => ({\n62:     lineNumber: idx + 1,\n63:     content,\n64:   }));\n65: \n66:   if (tail !== undefined && tail > 0 && lines.length > tail) {\n67:     lines = lines.slice(-tail);\n68:   }\n69: \n70:   return lines;\n71: }\n72: \n73: /**\n74:  * Colorize a log line for terminal output.\n75:  * Detects common patterns: timestamps, errors, warnings, tool calls, etc.\n76:  */\n77: function colorize(line: string): string {\n78:   // Error lines\n79:   if (/\\b(error|fatal|fail(ed)?|exception)\\b/i.test(line)) {\n80:     return `\\x1b[31m${line}\\x1b[0m`;\n81:   }\n82:   // Warning lines\n83:   if (/\\b(warn(ing)?|deprecated)\\b/i.test(line)) {\n84:     return `\\x1b[33m${line}\\x1b[0m`;\n85:   }\n86:   // Success / done lines\n87:   if (/\\b(success|done|passed|completed|merged)\\b/i.test(line)) {\n88:     return `\\x1b[32m${line}\\x1b[0m`;\n89:   }\n90:   // Activity annotations from ProcessMonitor (timestamps like HH:MM:SS)\n91:   if (/^\\d{2}:\\d{2}:\\d{2}\\s/.test(line)) {\n92:     const tsEnd = 8;\n93:     return `\\x1b[36m${line.slice(0, tsEnd)}\\x1b[0m${line.slice(tsEnd)}`;\n94:   }\n95:   return line;\n96: }\n97: \n98: /**\n99:  * Render log lines in text mode with pretty-printing.\n100:  */\n101: function renderText(lines: LogLine[], featureId: string, logPath: string): void {\n102:   if (lines.length === 0) {\n103:     console.log(`\\x1b[33mLog file is empty: ${logPath}\\x1b[0m`);\n104:     return;\n105:   }\n106: \n107:   console.log(`\\x1b[1m--- Logs for ${featureId} ---\\x1b[0m`);\n108:   console.log(`\\x1b[2mFile: ${logPath}\\x1b[0m`);\n109:   console.log(`\\x1b[2mLines: ${lines[0].lineNumber}–${lines[lines.length - 1].lineNumber}\\x1b[0m`);\n110:   console.log();\n111: \n112:   for (const line of lines) {\n113:     console.log(colorize(line.content));\n114:   }\n115: }\n116: \n117: /**\n118:  * Render log lines in JSON mode.\n119:  */\n120: function renderJson(lines: LogLine[], featureId: string, logPath: string): void {\n121:   const data = {\n122:     feature_id: featureId,\n123:     log_file: logPath,\n124:     line_count: lines.length,\n125:     first_line: lines.length > 0 ? lines[0].lineNumber : null,\n126:     last_line: lines.length > 0 ? lines[lines.length - 1].lineNumber : null,\n127:     lines: lines.map((l) => l.content),\n128:   };\n129:   console.log(JSON.stringify(data));\n130: }\n131: \n132: /**\n133:  * Follow a log file, printing new content as it appears (like tail -f).\n134:  * Runs until the process is interrupted.\n135:  */\n136: async function followLog(\n137:   logPath: string,\n138:   featureId: string,\n139:   outputFmt: OutputFormat,\n140:   tail?: number\n141: ): Promise<void> {\n142:   // First, print existing content (or tail)\n143:   if (existsSync(logPath)) {\n144:     const lines = readLogLines(logPath, tail);\n145:     if (outputFmt === \"json\") {\n146:       // In follow + json mode, emit each new batch as a JSON line\n147:       for (const line of lines) {\n148:         console.log(JSON.stringify({ feature_id: featureId, line: line.content, line_number: line.lineNumber }));\n149:       }\n150:     } else {\n151:       console.log(`\\x1b[1m--- Following logs for ${featureId} (Ctrl+C to stop) ---\\x1b[0m`);\n152:       console.log(`\\x1b[2mFile: ${logPath}\\x1b[0m`);\n153:       console.log();\n154:       for (const line of lines) {\n155:         console.log(colorize(line.content));\n156:       }\n157:     }\n158:   } else {\n159:     if (outputFmt === \"text\") {\n160:       console.log(`\\x1b[1m--- Following logs for ${featureId} (Ctrl+C to stop) ---\\x1b[0m`);\n161:       console.log(`\\x1b[33mWaiting for log file to appear...\\x1b[0m`);\n162:     }\n163:   }\n164: \n165:   // Now poll for new content\n166:   let offset = 0;\n167:   try {\n168:     if (existsSync(logPath)) {\n169:       const stat = statSync(logPath);\n170:       offset = stat.size;\n171:     }\n172:   } catch {\n173:     // File may not exist yet — we'll start from 0\n174:   }\n175: \n176:   const POLL_INTERVAL = 250; // ms\n177:   let lineNumber = 0;\n178:   if (existsSync(logPath)) {\n179:     const raw = readFileSync(logPath, \"utf-8\");\n180:     lineNumber = raw.split(\"\\n\").length - 1;\n181:   }\n182: \n183:   let buffer = \"\";\n184: \n185:   // Keep running until SIGINT\n186:   const running = { value: true };\n187:   const cleanup = () => {\n188:     running.value = false;\n189:   };\n190:   process.on(\"SIGINT\", cleanup);\n191:   process.on(\"SIGTERM\", cleanup);\n192: \n193:   try {\n194:     while (running.value) {\n195:       await new Promise((r) => setTimeout(r, POLL_INTERVAL));\n196: \n197:       if (!existsSync(logPath)) continue;\n198: \n199:       let currentSize: number;\n200:       try {\n201:         const stat = statSync(logPath);\n202:         currentSize = stat.size;\n203:       } catch {\n204:         continue;\n205:       }\n206: \n207:       if (currentSize <= offset) continue;\n208: \n209:       // Read new bytes\n210:       const bytesToRead = currentSize - offset;\n211:       const buf = Buffer.alloc(bytesToRead);\n212:       let fd: number | null = null;\n213:       try {\n214:         fd = openSync(logPath, \"r\");\n215:         readSync(fd, buf, 0, bytesToRead, offset);\n216:       } catch {\n217:         continue;\n218:       } finally {\n219:         if (fd !== null) closeSync(fd);\n220:       }\n221: \n222:       offset = currentSize;\n223:       buffer += buf.toString(\"utf-8\");\n224: \n225:       // Process complete lines\n226:       const parts = buffer.split(\"\\n\");\n227:       // Keep the last incomplete part in the buffer\n228:       buffer = parts.pop() ?? \"\";\n229: \n230:       for (const part of parts) {\n231:         lineNumber++;\n232:         if (outputFmt === \"json\") {\n233:           console.log(JSON.stringify({ feature_id: featureId, line: part, line_number: lineNumber }));\n234:         } else {\n235:           console.log(colorize(part));\n236:         }\n237:       }\n238:     }\n239:   } finally {\n240:     process.removeListener(\"SIGINT\", cleanup);\n241:     process.removeListener(\"SIGTERM\", cleanup);\n242:   }\n243: \n244:   if (outputFmt === \"text\") {\n245:     console.log(`\\n\\x1b[2m--- Stopped following ${featureId} ---\\x1b[0m`);\n246:   }\n247: }\n248: \n249: // ---------------------------------------------------------------------------\n250: // Command\n251: // ---------------------------------------------------------------------------\n252: \n253: export async function cmdLogs(opts: LogsCommandOptions): Promise<void> {\n254:   const { projectRoot, featureId, tail, follow, outputFmt } = opts;\n255: \n256:   const logPath = resolve(projectRoot, LOG_DIR_NAME, `${featureId}.log`);\n257: \n258:   // If following, we don't require the file to exist yet (it may be created)\n259:   if (follow) {\n260:     await followLog(logPath, featureId, outputFmt, tail);\n261:     return;\n262:   }\n263: \n264:   // For non-follow mode, the file must exist\n265:   if (!existsSync(logPath)) {\n266:     outputError(\n267:       outputFmt,\n268:       `Log file not found: ${logPath}\\n` +\n269:         `No logs exist for feature \"${featureId}\". ` +\n270:         `Logs are created when agents run in headless mode.\\n` +\n271:         `Hint: Check .wombo-combo/logs/ for available log files, or run 'woco launch' first.`\n272:     );\n273:   }\n274: \n275:   const lines = readLogLines(logPath, tail);\n276: \n277:   output(outputFmt, {\n278:     feature_id: featureId,\n279:     log_file: logPath,\n280:     line_count: lines.length,\n281:     first_line: lines.length > 0 ? lines[0].lineNumber : null,\n282:     last_line: lines.length > 0 ? lines[lines.length - 1].lineNumber : null,\n283:     lines: lines.map((l) => l.content),\n284:   }, () => {\n285:     renderText(lines, featureId, logPath);\n286:   });\n287: }\n\n(End of file - total 287 lines)\n</content>","title":"src/commands/logs.ts","metadata":{"preview":"/**\n * logs.ts — Pretty-print agent logs from .wombo-combo/logs/<feature-id>.log.\n *\n * Usage:\n *   woco logs <feature-id>\n *   woco logs <feature-id> --tail 50\n *   woco logs <feature-id> --follow\n *   woco logs <feature-id> --output json\n *\n * Reads the log file written by ProcessMonitor during headless agent runs\n * and displays it with timestamps and activity annotations. Supports\n * --tail N to show last N lines and --follow to stream new output.\n */\n\nimport { resolve } from \"node:path\";\nimport { existsSync, readFileSync, statSync, openSync, readSync, closeSync } from \"node:fs\";\nimport { output, outputError, type OutputFormat } from \"../lib/output.js\";\n\n// ---------------------------------------------------------------------------\n// Constants","truncated":false,"loaded":[]},"time":{"start":1773437449594,"end":1773437449596}}}}
{"type":"tool_use","timestamp":1773437450057,"sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","part":{"id":"prt_ce91bf57b001vEdYvj4eK7K1bs","sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","messageID":"msg_ce91bdf85001tydxXpQ6m4jZxZ","type":"tool","callID":"toolu_vrtx_01U1B3QNpabHv8WERRPoogrc","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/tasks/list.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/tasks/list.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tasks/list.ts — List and filter tasks from the tasks file.\n3:  *\n4:  * Usage:\n5:  *   woco tasks list                     # list all tasks\n6:  *   woco tasks list --status backlog    # filter by status\n7:  *   woco tasks list --priority high     # filter by priority\n8:  *   woco tasks list --ready             # show only ready tasks\n9:  *   woco tasks list --archive           # include archived tasks\n10:  */\n11: \n12: import type { WomboConfig } from \"../../config.js\";\n13: import {\n14:   loadFeatures,\n15:   getReadyFeatures,\n16:   featureSummary,\n17:   formatDuration,\n18:   parseDurationMinutes,\n19:   type Feature,\n20:   type FeatureStatus,\n21:   type Priority,\n22:   type Difficulty,\n23:   type FeaturesFile,\n24: } from \"../../lib/tasks.js\";\n25: import { output, filterFieldsArray, renderCompactTable, type OutputFormat } from \"../../lib/output.js\";\n26: import { renderTasksList } from \"../../lib/toon.js\";\n27: \n28: // ---------------------------------------------------------------------------\n29: // Types\n30: // ---------------------------------------------------------------------------\n31: \n32: export interface TasksListOptions {\n33:   projectRoot: string;\n34:   config: WomboConfig;\n35:   status?: FeatureStatus;\n36:   priority?: Priority;\n37:   difficulty?: Difficulty;\n38:   ready?: boolean;\n39:   includeArchive?: boolean;\n40:   outputFmt?: OutputFormat;\n41:   fields?: string[];\n42: }\n43: \n44: // ---------------------------------------------------------------------------\n45: // ANSI Helpers\n46: // ---------------------------------------------------------------------------\n47: \n48: const RESET = \"\\x1b[0m\";\n49: const BOLD = \"\\x1b[1m\";\n50: const DIM = \"\\x1b[2m\";\n51: \n52: const STATUS_COLOR: Record<FeatureStatus, string> = {\n53:   backlog: \"\\x1b[37m\",     // white\n54:   planned: \"\\x1b[36m\",     // cyan\n55:   in_progress: \"\\x1b[34m\", // blue\n56:   blocked: \"\\x1b[31m\",     // red\n57:   in_review: \"\\x1b[33m\",   // yellow\n58:   done: \"\\x1b[32m\",        // green\n59:   cancelled: \"\\x1b[90m\",   // gray\n60: };\n61: \n62: // ---------------------------------------------------------------------------\n63: // Command\n64: // ---------------------------------------------------------------------------\n65: \n66: export async function cmdTasksList(opts: TasksListOptions): Promise<void> {\n67:   const { projectRoot, config } = opts;\n68:   const data = loadFeatures(projectRoot, config);\n69: \n70:   let features: Feature[] = [...data.tasks];\n71: \n72:   // Include archive if requested\n73:   if (opts.includeArchive && data.archive?.length) {\n74:     features = [...features, ...data.archive];\n75:   }\n76: \n77:   // Filter by status\n78:   if (opts.status) {\n79:     features = features.filter((f) => f.status === opts.status);\n80:   }\n81: \n82:   // Filter by priority\n83:   if (opts.priority) {\n84:     features = features.filter((f) => f.priority === opts.priority);\n85:   }\n86: \n87:   // Filter by difficulty\n88:   if (opts.difficulty) {\n89:     features = features.filter((f) => f.difficulty === opts.difficulty);\n90:   }\n91: \n92:   // Filter to ready-only\n93:   if (opts.ready) {\n94:     const readyFeatures = getReadyFeatures(data);\n95:     const readyIds = new Set(readyFeatures.map((f) => f.id));\n96:     features = features.filter((f) => readyIds.has(f.id));\n97:   }\n98: \n99:   if (features.length === 0) {\n100:     output(opts.outputFmt ?? \"text\", { features: [], total: 0, effort: \"0m\" }, () => {\n101:       console.log(\"No tasks match the given filters.\");\n102:     }, () => {\n103:       // TOON: emit empty result\n104:       console.log(renderTasksList([]));\n105:     });\n106:     return;\n107:   }\n108: \n109:   // Group by status for display\n110:   const byStatus = new Map<FeatureStatus, Feature[]>();\n111:   for (const f of features) {\n112:     const list = byStatus.get(f.status) ?? [];\n113:     list.push(f);\n114:     byStatus.set(f.status, list);\n115:   }\n116: \n117:   // Display\n118:   const totalEffort = features.reduce(\n119:     (sum, f) => sum + parseDurationMinutes(f.effort),\n120:     0\n121:   );\n122: \n123:   const fmt = opts.outputFmt ?? \"text\";\n124: \n125:   // Build the structured data for each feature\n126:   const featureData = features.map((f) => ({\n127:     id: f.id,\n128:     title: f.title,\n129:     status: f.status,\n130:     priority: f.priority,\n131:     difficulty: f.difficulty,\n132:     effort: f.effort,\n133:     completion: f.completion,\n134:     depends_on: f.depends_on,\n135:   }));\n136: \n137:   // If --fields is specified, use compact output mode\n138:   if (opts.fields?.length) {\n139:     const filtered = filterFieldsArray(featureData, opts.fields);\n140:     output(\n141:       fmt,\n142:       { features: filtered, total: features.length, effort: formatDuration(totalEffort) },\n143:       () => {\n144:         renderCompactTable(\n145:           featureData as Record<string, unknown>[],\n146:           opts.fields!\n147:         );\n148:       },\n149:       () => {\n150:         // TOON: --fields is ignored; emit all fields in compact format\n151:         console.log(renderTasksList(featureData));\n152:       }\n153:     );\n154:     return;\n155:   }\n156: \n157:   output(\n158:     fmt,\n159:     {\n160:       features: featureData,\n161:       total: features.length,\n162:       effort: formatDuration(totalEffort),\n163:     },\n164:     () => {\n165:       console.log(`\\n${BOLD}Tasks (${features.length} total, ~${formatDuration(totalEffort)} effort)${RESET}\\n`);\n166: \n167:       const statusOrder: FeatureStatus[] = [\n168:         \"in_progress\",\n169:         \"planned\",\n170:         \"backlog\",\n171:         \"blocked\",\n172:         \"in_review\",\n173:         \"done\",\n174:         \"cancelled\",\n175:       ];\n176: \n177:       for (const status of statusOrder) {\n178:         const group = byStatus.get(status);\n179:         if (!group?.length) continue;\n180: \n181:         const color = STATUS_COLOR[status] ?? \"\";\n182:         console.log(`  ${color}${BOLD}${status.toUpperCase()}${RESET} (${group.length})`);\n183: \n184:         for (const f of group) {\n185:           const effort = formatDuration(parseDurationMinutes(f.effort));\n186:           const deps = f.depends_on.length > 0 ? ` ${DIM}deps: ${f.depends_on.join(\", \")}${RESET}` : \"\";\n187:           const completion = f.completion > 0 ? ` ${DIM}${f.completion}%${RESET}` : \"\";\n188:           console.log(\n189:             `    ${color}${f.id}${RESET} — ${f.title} [${f.priority}/${f.difficulty}] (${effort})${completion}${deps}`\n190:           );\n191:         }\n192:         console.log(\"\");\n193:       }\n194:     },\n195:     () => {\n196:       // TOON renderer\n197:       console.log(renderTasksList(featureData));\n198:     }\n199:   );\n200: }\n\n(End of file - total 200 lines)\n</content>","title":"src/commands/tasks/list.ts","metadata":{"preview":"/**\n * tasks/list.ts — List and filter tasks from the tasks file.\n *\n * Usage:\n *   woco tasks list                     # list all tasks\n *   woco tasks list --status backlog    # filter by status\n *   woco tasks list --priority high     # filter by priority\n *   woco tasks list --ready             # show only ready tasks\n *   woco tasks list --archive           # include archived tasks\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  getReadyFeatures,\n  featureSummary,\n  formatDuration,\n  parseDurationMinutes,\n  type Feature,\n  type FeatureStatus,","truncated":false,"loaded":[]},"time":{"start":1773437450053,"end":1773437450056}}}}
{"type":"tool_use","timestamp":1773437450616,"sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","part":{"id":"prt_ce91bf746001QGWRpdyu2pVoc8","sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","messageID":"msg_ce91bdf85001tydxXpQ6m4jZxZ","type":"tool","callID":"toolu_vrtx_01VeGyjZeEGRu1PjS6iVUvQL","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/tasks/show.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/tasks/show.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tasks/show.ts — Show detailed information about a specific task.\n3:  *\n4:  * Usage:\n5:  *   woco tasks show <task-id>\n6:  */\n7: \n8: import type { WomboConfig } from \"../../config.js\";\n9: import {\n10:   loadFeatures,\n11:   findFeatureById,\n12:   formatDuration,\n13:   parseDurationMinutes,\n14:   areDependenciesMet,\n15:   getDoneFeatureIds,\n16:   type Feature,\n17:   type Subtask,\n18: } from \"../../lib/tasks.js\";\n19: import { output, outputError, filterFields, type OutputFormat } from \"../../lib/output.js\";\n20: import { renderTaskShow } from \"../../lib/toon.js\";\n21: \n22: // ---------------------------------------------------------------------------\n23: // Types\n24: // ---------------------------------------------------------------------------\n25: \n26: export interface TasksShowOptions {\n27:   projectRoot: string;\n28:   config: WomboConfig;\n29:   featureId: string;\n30:   outputFmt?: OutputFormat;\n31:   fields?: string[];\n32: }\n33: \n34: // ---------------------------------------------------------------------------\n35: // ANSI Helpers\n36: // ---------------------------------------------------------------------------\n37: \n38: const RESET = \"\\x1b[0m\";\n39: const BOLD = \"\\x1b[1m\";\n40: const DIM = \"\\x1b[2m\";\n41: const GREEN = \"\\x1b[32m\";\n42: const RED = \"\\x1b[31m\";\n43: const YELLOW = \"\\x1b[33m\";\n44: const CYAN = \"\\x1b[36m\";\n45: \n46: // ---------------------------------------------------------------------------\n47: // Display Helpers\n48: // ---------------------------------------------------------------------------\n49: \n50: function statusColor(status: string): string {\n51:   switch (status) {\n52:     case \"done\": return GREEN;\n53:     case \"in_progress\": return CYAN;\n54:     case \"blocked\":\n55:     case \"failed\": return RED;\n56:     case \"cancelled\": return DIM;\n57:     default: return \"\";\n58:   }\n59: }\n60: \n61: function renderSubtask(st: Subtask, indent: number): void {\n62:   const pad = \"  \".repeat(indent);\n63:   const color = statusColor(st.status);\n64:   const effort = formatDuration(parseDurationMinutes(st.effort));\n65:   const completionStr = st.completion > 0 ? ` (${st.completion}%)` : \"\";\n66:   console.log(\n67:     `${pad}${color}[${st.status}]${RESET} ${st.id} — ${st.title} [${st.priority}/${st.difficulty}] (${effort})${completionStr}`\n68:   );\n69:   if (st.subtasks?.length) {\n70:     for (const sub of st.subtasks) {\n71:       renderSubtask(sub, indent + 1);\n72:     }\n73:   }\n74: }\n75: \n76: // ---------------------------------------------------------------------------\n77: // Command\n78: // ---------------------------------------------------------------------------\n79: \n80: export async function cmdTasksShow(opts: TasksShowOptions): Promise<void> {\n81:   const { projectRoot, config } = opts;\n82:   const fmt = opts.outputFmt ?? \"text\";\n83: \n84:   if (!opts.featureId) {\n85:     outputError(fmt, \"Usage: woco tasks show <task-id>\");\n86:     return;\n87:   }\n88: \n89:   const data = loadFeatures(projectRoot, config);\n90:   const feature = findFeatureById(data, opts.featureId);\n91: \n92:   if (!feature) {\n93:     outputError(fmt, `Task \"${opts.featureId}\" not found.`);\n94:     return;\n95:   }\n96: \n97:   const doneIds = getDoneFeatureIds(data);\n98:   const depsMet = areDependenciesMet(feature, doneIds);\n99:   const effort = formatDuration(parseDurationMinutes(feature.effort));\n100: \n101:   const fullData = {\n102:     ...feature,\n103:     deps_met: depsMet,\n104:     effort_formatted: effort,\n105:   };\n106: \n107:   // If --fields is specified, emit only those fields\n108:   if (opts.fields?.length) {\n109:     const filtered = filterFields(fullData as Record<string, unknown>, opts.fields);\n110:     output(fmt, filtered, () => {\n111:       for (const [key, val] of Object.entries(filtered)) {\n112:         const display = Array.isArray(val) ? val.join(\", \") : String(val ?? \"\");\n113:         console.log(`${key}: ${display}`);\n114:       }\n115:     }, () => {\n116:       // TOON: --fields ignored, emit full task in compact format\n117:       console.log(renderTaskShow(feature, depsMet));\n118:     });\n119:     return;\n120:   }\n121: \n122:   output(\n123:     fmt,\n124:     fullData,\n125:     () => {\n126:       console.log(`\\n${BOLD}Task: ${feature.title}${RESET}`);\n127:       console.log(`  ID:          ${feature.id}`);\n128:       console.log(`  Status:      ${statusColor(feature.status)}${feature.status}${RESET}`);\n129:       console.log(`  Priority:    ${feature.priority}`);\n130:       console.log(`  Difficulty:  ${feature.difficulty}`);\n131:       console.log(`  Effort:      ${effort}`);\n132:       console.log(`  Completion:  ${feature.completion}%`);\n133:       console.log(`  Deps met:    ${depsMet ? `${GREEN}yes${RESET}` : `${RED}no${RESET}`}`);\n134: \n135:       if (feature.started_at) {\n136:         console.log(`  Started:     ${feature.started_at}`);\n137:       }\n138:       if (feature.ended_at) {\n139:         console.log(`  Ended:       ${feature.ended_at}`);\n140:       }\n141: \n142:       if (feature.description) {\n143:         console.log(`\\n  ${BOLD}Description:${RESET}`);\n144:         for (const line of feature.description.split(\"\\n\")) {\n145:           console.log(`    ${line}`);\n146:         }\n147:       }\n148: \n149:       if (feature.depends_on.length > 0) {\n150:         console.log(`\\n  ${BOLD}Dependencies:${RESET}`);\n151:         for (const dep of feature.depends_on) {\n152:           const met = doneIds.has(dep);\n153:           const icon = met ? `${GREEN}✓${RESET}` : `${RED}✗${RESET}`;\n154:           console.log(`    ${icon} ${dep}`);\n155:         }\n156:       }\n157: \n158:       if (feature.constraints.length > 0) {\n159:         console.log(`\\n  ${BOLD}Constraints:${RESET}`);\n160:         for (const c of feature.constraints) {\n161:           console.log(`    - ${c}`);\n162:         }\n163:       }\n164: \n165:       if (feature.forbidden.length > 0) {\n166:         console.log(`\\n  ${BOLD}Forbidden:${RESET}`);\n167:         for (const f of feature.forbidden) {\n168:           console.log(`    - ${RED}${f}${RESET}`);\n169:         }\n170:       }\n171: \n172:       if (feature.references.length > 0) {\n173:         console.log(`\\n  ${BOLD}References:${RESET}`);\n174:         for (const r of feature.references) {\n175:           console.log(`    - ${DIM}${r}${RESET}`);\n176:         }\n177:       }\n178: \n179:       if (feature.notes.length > 0) {\n180:         console.log(`\\n  ${BOLD}Notes:${RESET}`);\n181:         for (const n of feature.notes) {\n182:           console.log(`    - ${n}`);\n183:         }\n184:       }\n185: \n186:       if (feature.subtasks.length > 0) {\n187:         console.log(`\\n  ${BOLD}Subtasks (${feature.subtasks.length}):${RESET}`);\n188:         for (const st of feature.subtasks) {\n189:           renderSubtask(st, 2);\n190:         }\n191:       }\n192: \n193:       console.log(\"\");\n194:     },\n195:     () => {\n196:       // TOON renderer\n197:       console.log(renderTaskShow(feature, depsMet));\n198:     }\n199:   );\n200: }\n\n(End of file - total 200 lines)\n</content>","title":"src/commands/tasks/show.ts","metadata":{"preview":"/**\n * tasks/show.ts — Show detailed information about a specific task.\n *\n * Usage:\n *   woco tasks show <task-id>\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  findFeatureById,\n  formatDuration,\n  parseDurationMinutes,\n  areDependenciesMet,\n  getDoneFeatureIds,\n  type Feature,\n  type Subtask,\n} from \"../../lib/tasks.js\";\nimport { output, outputError, filterFields, type OutputFormat } from \"../../lib/output.js\";\nimport { renderTaskShow } from \"../../lib/toon.js\";","truncated":false,"loaded":[]},"time":{"start":1773437450613,"end":1773437450616}}}}
