{"type":"tool_use","timestamp":1773437530083,"sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","part":{"id":"prt_ce91d2cb000119hgXYvmukMYkz","sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","messageID":"msg_ce91d22b8001iw4vg4OR3yKbly","type":"tool","callID":"toolu_vrtx_01B3AsH2PTAnxsw4zHtoXNQ9","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/logs.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/logs.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * logs.ts — Pretty-print agent logs from .wombo-combo/logs/<feature-id>.log.\n3:  *\n4:  * Usage:\n5:  *   woco logs <feature-id>\n6:  *   woco logs <feature-id> --tail 50\n7:  *   woco logs <feature-id> --follow\n8:  *   woco logs <feature-id> --output json\n9:  *\n10:  * Reads the log file written by ProcessMonitor during headless agent runs\n11:  * and displays it with timestamps and activity annotations. Supports\n12:  * --tail N to show last N lines and --follow to stream new output.\n13:  */\n14: \n15: import { resolve } from \"node:path\";\n16: import { existsSync, readFileSync, statSync, openSync, readSync, closeSync } from \"node:fs\";\n17: import { output, outputError, type OutputFormat } from \"../lib/output.js\";\n18: \n19: // ---------------------------------------------------------------------------\n20: // Constants\n21: // ---------------------------------------------------------------------------\n22: \n23: const LOG_DIR_NAME = \".wombo-combo/logs\";\n24: \n25: // ---------------------------------------------------------------------------\n26: // Types\n27: // ---------------------------------------------------------------------------\n28: \n29: export interface LogsCommandOptions {\n30:   projectRoot: string;\n31:   featureId: string;\n32:   /** Show only the last N lines */\n33:   tail?: number;\n34:   /** Stream new output as it arrives (like tail -f) */\n35:   follow?: boolean;\n36:   /** Output format */\n37:   outputFmt: OutputFormat;\n38: }\n39: \n40: interface LogLine {\n41:   lineNumber: number;\n42:   content: string;\n43: }\n44: \n45: // ---------------------------------------------------------------------------\n46: // Helpers\n47: // ---------------------------------------------------------------------------\n48: \n49: /**\n50:  * Read all lines from a log file, optionally returning only the last N.\n51:  */\n52: function readLogLines(logPath: string, tail?: number): LogLine[] {\n53:   const raw = readFileSync(logPath, \"utf-8\");\n54:   const allLines = raw.split(\"\\n\");\n55: \n56:   // Remove trailing empty line from split (if file ends with \\n)\n57:   if (allLines.length > 0 && allLines[allLines.length - 1] === \"\") {\n58:     allLines.pop();\n59:   }\n60: \n61:   let lines: LogLine[] = allLines.map((content, idx) => ({\n62:     lineNumber: idx + 1,\n63:     content,\n64:   }));\n65: \n66:   if (tail !== undefined && tail > 0 && lines.length > tail) {\n67:     lines = lines.slice(-tail);\n68:   }\n69: \n70:   return lines;\n71: }\n72: \n73: /**\n74:  * Colorize a log line for terminal output.\n75:  * Detects common patterns: timestamps, errors, warnings, tool calls, etc.\n76:  */\n77: function colorize(line: string): string {\n78:   // Error lines\n79:   if (/\\b(error|fatal|fail(ed)?|exception)\\b/i.test(line)) {\n80:     return `\\x1b[31m${line}\\x1b[0m`;\n81:   }\n82:   // Warning lines\n83:   if (/\\b(warn(ing)?|deprecated)\\b/i.test(line)) {\n84:     return `\\x1b[33m${line}\\x1b[0m`;\n85:   }\n86:   // Success / done lines\n87:   if (/\\b(success|done|passed|completed|merged)\\b/i.test(line)) {\n88:     return `\\x1b[32m${line}\\x1b[0m`;\n89:   }\n90:   // Activity annotations from ProcessMonitor (timestamps like HH:MM:SS)\n91:   if (/^\\d{2}:\\d{2}:\\d{2}\\s/.test(line)) {\n92:     const tsEnd = 8;\n93:     return `\\x1b[36m${line.slice(0, tsEnd)}\\x1b[0m${line.slice(tsEnd)}`;\n94:   }\n95:   return line;\n96: }\n97: \n98: /**\n99:  * Render log lines in text mode with pretty-printing.\n100:  */\n101: function renderText(lines: LogLine[], featureId: string, logPath: string): void {\n102:   if (lines.length === 0) {\n103:     console.log(`\\x1b[33mLog file is empty: ${logPath}\\x1b[0m`);\n104:     return;\n105:   }\n106: \n107:   console.log(`\\x1b[1m--- Logs for ${featureId} ---\\x1b[0m`);\n108:   console.log(`\\x1b[2mFile: ${logPath}\\x1b[0m`);\n109:   console.log(`\\x1b[2mLines: ${lines[0].lineNumber}–${lines[lines.length - 1].lineNumber}\\x1b[0m`);\n110:   console.log();\n111: \n112:   for (const line of lines) {\n113:     console.log(colorize(line.content));\n114:   }\n115: }\n116: \n117: /**\n118:  * Render log lines in JSON mode.\n119:  */\n120: function renderJson(lines: LogLine[], featureId: string, logPath: string): void {\n121:   const data = {\n122:     feature_id: featureId,\n123:     log_file: logPath,\n124:     line_count: lines.length,\n125:     first_line: lines.length > 0 ? lines[0].lineNumber : null,\n126:     last_line: lines.length > 0 ? lines[lines.length - 1].lineNumber : null,\n127:     lines: lines.map((l) => l.content),\n128:   };\n129:   console.log(JSON.stringify(data));\n130: }\n131: \n132: /**\n133:  * Follow a log file, printing new content as it appears (like tail -f).\n134:  * Runs until the process is interrupted.\n135:  */\n136: async function followLog(\n137:   logPath: string,\n138:   featureId: string,\n139:   outputFmt: OutputFormat,\n140:   tail?: number\n141: ): Promise<void> {\n142:   // First, print existing content (or tail)\n143:   if (existsSync(logPath)) {\n144:     const lines = readLogLines(logPath, tail);\n145:     if (outputFmt === \"json\") {\n146:       // In follow + json mode, emit each new batch as a JSON line\n147:       for (const line of lines) {\n148:         console.log(JSON.stringify({ feature_id: featureId, line: line.content, line_number: line.lineNumber }));\n149:       }\n150:     } else {\n151:       console.log(`\\x1b[1m--- Following logs for ${featureId} (Ctrl+C to stop) ---\\x1b[0m`);\n152:       console.log(`\\x1b[2mFile: ${logPath}\\x1b[0m`);\n153:       console.log();\n154:       for (const line of lines) {\n155:         console.log(colorize(line.content));\n156:       }\n157:     }\n158:   } else {\n159:     if (outputFmt === \"text\") {\n160:       console.log(`\\x1b[1m--- Following logs for ${featureId} (Ctrl+C to stop) ---\\x1b[0m`);\n161:       console.log(`\\x1b[33mWaiting for log file to appear...\\x1b[0m`);\n162:     }\n163:   }\n164: \n165:   // Now poll for new content\n166:   let offset = 0;\n167:   try {\n168:     if (existsSync(logPath)) {\n169:       const stat = statSync(logPath);\n170:       offset = stat.size;\n171:     }\n172:   } catch {\n173:     // File may not exist yet — we'll start from 0\n174:   }\n175: \n176:   const POLL_INTERVAL = 250; // ms\n177:   let lineNumber = 0;\n178:   if (existsSync(logPath)) {\n179:     const raw = readFileSync(logPath, \"utf-8\");\n180:     lineNumber = raw.split(\"\\n\").length - 1;\n181:   }\n182: \n183:   let buffer = \"\";\n184: \n185:   // Keep running until SIGINT\n186:   const running = { value: true };\n187:   const cleanup = () => {\n188:     running.value = false;\n189:   };\n190:   process.on(\"SIGINT\", cleanup);\n191:   process.on(\"SIGTERM\", cleanup);\n192: \n193:   try {\n194:     while (running.value) {\n195:       await new Promise((r) => setTimeout(r, POLL_INTERVAL));\n196: \n197:       if (!existsSync(logPath)) continue;\n198: \n199:       let currentSize: number;\n200:       try {\n201:         const stat = statSync(logPath);\n202:         currentSize = stat.size;\n203:       } catch {\n204:         continue;\n205:       }\n206: \n207:       if (currentSize <= offset) continue;\n208: \n209:       // Read new bytes\n210:       const bytesToRead = currentSize - offset;\n211:       const buf = Buffer.alloc(bytesToRead);\n212:       let fd: number | null = null;\n213:       try {\n214:         fd = openSync(logPath, \"r\");\n215:         readSync(fd, buf, 0, bytesToRead, offset);\n216:       } catch {\n217:         continue;\n218:       } finally {\n219:         if (fd !== null) closeSync(fd);\n220:       }\n221: \n222:       offset = currentSize;\n223:       buffer += buf.toString(\"utf-8\");\n224: \n225:       // Process complete lines\n226:       const parts = buffer.split(\"\\n\");\n227:       // Keep the last incomplete part in the buffer\n228:       buffer = parts.pop() ?? \"\";\n229: \n230:       for (const part of parts) {\n231:         lineNumber++;\n232:         if (outputFmt === \"json\") {\n233:           console.log(JSON.stringify({ feature_id: featureId, line: part, line_number: lineNumber }));\n234:         } else {\n235:           console.log(colorize(part));\n236:         }\n237:       }\n238:     }\n239:   } finally {\n240:     process.removeListener(\"SIGINT\", cleanup);\n241:     process.removeListener(\"SIGTERM\", cleanup);\n242:   }\n243: \n244:   if (outputFmt === \"text\") {\n245:     console.log(`\\n\\x1b[2m--- Stopped following ${featureId} ---\\x1b[0m`);\n246:   }\n247: }\n248: \n249: // ---------------------------------------------------------------------------\n250: // Command\n251: // ---------------------------------------------------------------------------\n252: \n253: export async function cmdLogs(opts: LogsCommandOptions): Promise<void> {\n254:   const { projectRoot, featureId, tail, follow, outputFmt } = opts;\n255: \n256:   const logPath = resolve(projectRoot, LOG_DIR_NAME, `${featureId}.log`);\n257: \n258:   // If following, we don't require the file to exist yet (it may be created)\n259:   if (follow) {\n260:     await followLog(logPath, featureId, outputFmt, tail);\n261:     return;\n262:   }\n263: \n264:   // For non-follow mode, the file must exist\n265:   if (!existsSync(logPath)) {\n266:     outputError(\n267:       outputFmt,\n268:       `Log file not found: ${logPath}\\n` +\n269:         `No logs exist for feature \"${featureId}\". ` +\n270:         `Logs are created when agents run in headless mode.\\n` +\n271:         `Hint: Check .wombo-combo/logs/ for available log files, or run 'woco launch' first.`\n272:     );\n273:   }\n274: \n275:   const lines = readLogLines(logPath, tail);\n276: \n277:   output(outputFmt, {\n278:     feature_id: featureId,\n279:     log_file: logPath,\n280:     line_count: lines.length,\n281:     first_line: lines.length > 0 ? lines[0].lineNumber : null,\n282:     last_line: lines.length > 0 ? lines[lines.length - 1].lineNumber : null,\n283:     lines: lines.map((l) => l.content),\n284:   }, () => {\n285:     renderText(lines, featureId, logPath);\n286:   });\n287: }\n\n(End of file - total 287 lines)\n</content>","title":"src/commands/logs.ts","metadata":{"preview":"/**\n * logs.ts — Pretty-print agent logs from .wombo-combo/logs/<feature-id>.log.\n *\n * Usage:\n *   woco logs <feature-id>\n *   woco logs <feature-id> --tail 50\n *   woco logs <feature-id> --follow\n *   woco logs <feature-id> --output json\n *\n * Reads the log file written by ProcessMonitor during headless agent runs\n * and displays it with timestamps and activity annotations. Supports\n * --tail N to show last N lines and --follow to stream new output.\n */\n\nimport { resolve } from \"node:path\";\nimport { existsSync, readFileSync, statSync, openSync, readSync, closeSync } from \"node:fs\";\nimport { output, outputError, type OutputFormat } from \"../lib/output.js\";\n\n// ---------------------------------------------------------------------------\n// Constants","truncated":false,"loaded":[]},"time":{"start":1773437530079,"end":1773437530082}}}}
