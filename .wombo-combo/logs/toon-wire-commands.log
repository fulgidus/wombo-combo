{"type":"tool_use","timestamp":1773437537434,"sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","part":{"id":"prt_ce91d48f8001zgMD1MInkWEhIN","sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","messageID":"msg_ce91d3e5a001q9ayH8KVjQcBT1","type":"tool","callID":"toolu_vrtx_016bNXfSXooo5cZGTJdbqJBh","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/lib/schema.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/lib/schema.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * schema.ts — Declarative command/flag registry for schema introspection.\n3:  *\n4:  * Every command and flag is described in a single registry. This registry is\n5:  * the source of truth for:\n6:  *   1. `woco describe <command>` — emits a JSON schema of accepted args\n7:  *   2. Future help text generation\n8:  *\n9:  * The registry is NOT used for actual arg parsing (that's still the hand-rolled\n10:  * switch in index.ts), but the two must stay in sync. If they drift, `woco\n11:  * tasks check` should eventually catch it.\n12:  */\n13: \n14: import { readFileSync } from \"node:fs\";\n15: import { resolve } from \"node:path\";\n16: import { VALID_STATUSES, VALID_PRIORITIES, VALID_DIFFICULTIES } from \"./task-schema.js\";\n17: \n18: // ---------------------------------------------------------------------------\n19: // Dynamic version reader\n20: // ---------------------------------------------------------------------------\n21: \n22: function getVersion(): string {\n23:   try {\n24:     const pkgPath = resolve(import.meta.dir, \"../../package.json\");\n25:     const raw = readFileSync(pkgPath, \"utf-8\");\n26:     return JSON.parse(raw).version as string;\n27:   } catch {\n28:     return \"unknown\";\n29:   }\n30: }\n31: \n32: // ---------------------------------------------------------------------------\n33: // Types\n34: // ---------------------------------------------------------------------------\n35: \n36: export interface FlagDef {\n37:   /** Primary flag name, e.g. \"--dry-run\" */\n38:   name: string;\n39:   /** Short alias, e.g. \"-o\" */\n40:   alias?: string;\n41:   /** Description shown in help / schema */\n42:   description: string;\n43:   /** Type of the value: \"boolean\" flags take no value, others consume next arg */\n44:   type: \"string\" | \"number\" | \"boolean\" | \"string[]\";\n45:   /** Default value (undefined = required or absent) */\n46:   default?: unknown;\n47:   /** For enum-like flags, the set of allowed values */\n48:   enum?: readonly string[];\n49:   /** If true, this flag is required */\n50:   required?: boolean;\n51: }\n52: \n53: export interface PositionalDef {\n54:   /** Name used in usage strings, e.g. \"feature-id\" */\n55:   name: string;\n56:   description: string;\n57:   required?: boolean;\n58: }\n59: \n60: export interface CommandDef {\n61:   /** Command name as typed by the user, e.g. \"launch\" or \"features list\" */\n62:   name: string;\n63:   /** One-line summary */\n64:   summary: string;\n65:   /** Longer description */\n66:   description?: string;\n67:   /** Positional arguments */\n68:   positionals: PositionalDef[];\n69:   /** Named flags */\n70:   flags: FlagDef[];\n71:   /** Whether this command mutates state (used for dry-run indication) */\n72:   mutating: boolean;\n73:   /** Whether this command supports --dry-run */\n74:   supportsDryRun: boolean;\n75:   /** Subcommands (for \"tasks\" parent) */\n76:   subcommands?: CommandDef[];\n77: }\n78: \n79: // ---------------------------------------------------------------------------\n80: // Global flags (available on every command)\n81: // ---------------------------------------------------------------------------\n82: \n83: const GLOBAL_FLAGS: FlagDef[] = [\n84:   {\n85:     name: \"--output\",\n86:     alias: \"-o\",\n87:     description: \"Output format: text (default) or json\",\n88:     type: \"string\",\n89:     default: \"text\",\n90:     enum: [\"text\", \"json\", \"toon\"],\n91:   },\n92:   {\n93:     name: \"--force\",\n94:     description: \"Force overwrite / skip safety prompts\",\n95:     type: \"boolean\",\n96:     default: false,\n97:   },\n98: ];\n99: \n100: // ---------------------------------------------------------------------------\n101: // Command Registry\n102: // ---------------------------------------------------------------------------\n103: \n104: export const COMMAND_REGISTRY: CommandDef[] = [\n105:   // --- init ---------------------------------------------------------------\n106:   {\n107:     name: \"init\",\n108:     summary: \"Generate .wombo-combo/config.json in the current project\",\n109:     description:\n110:       \"Interactive guided setup that walks through every config section. \" +\n111:       \"Creates .wombo-combo/config.json and .wombo-combo/tasks.yml from template.\",\n112:     positionals: [],\n113:     flags: [\n114:       {\n115:         name: \"--force\",\n116:         description: \"Overwrite existing config files\",\n117:         type: \"boolean\",\n118:         default: false,\n119:       },\n120:       {\n121:         name: \"--dry-run\",\n122:         description: \"Show what would be created without writing files\",\n123:         type: \"boolean\",\n124:         default: false,\n125:       },\n126:     ],\n127:     mutating: true,\n128:     supportsDryRun: true,\n129:   },\n130: \n131:   // --- launch -------------------------------------------------------------\n132:   {\n133:     name: \"launch\",\n134:     summary: \"Launch a wave of agents to implement features\",\n135:     description:\n136:       \"Select features from the tasks file, create worktrees, and spawn agents. \" +\n137:       \"Supports multiple selection strategies.\",\n138:     positionals: [],\n139:     flags: [\n140:       { name: \"--top-priority\", description: \"Select top N features by priority\", type: \"number\" },\n141:       { name: \"--quickest-wins\", description: \"Select N features with lowest effort\", type: \"number\" },\n142:       { name: \"--priority\", description: \"Filter by priority level\", type: \"string\", enum: VALID_PRIORITIES },\n143:       { name: \"--difficulty\", description: \"Filter by difficulty level\", type: \"string\", enum: VALID_DIFFICULTIES },\n144:       { name: \"--features\", description: \"Select specific features by comma-separated IDs (alias for --tasks)\", type: \"string\" },\n145:       { name: \"--tasks\", description: \"Select specific tasks by comma-separated IDs\", type: \"string\" },\n146:       { name: \"--all-ready\", description: \"Select all features whose dependencies are met\", type: \"boolean\", default: false },\n147:       { name: \"--max-concurrent\", description: \"Max agents running in parallel\", type: \"number\" },\n148:       { name: \"--model\", alias: \"-m\", description: \"Model to use (e.g., anthropic/claude-sonnet-4-20250514)\", type: \"string\" },\n149:       { name: \"--interactive\", description: \"Use multiplexer (dmux/tmux) TUI mode instead of headless\", type: \"boolean\", default: false },\n150:       { name: \"--no-tui\", description: \"Headless mode without neo-blessed TUI\", type: \"boolean\", default: false },\n151:       { name: \"--auto-push\", description: \"Push base branch to remote after all merges\", type: \"boolean\", default: false },\n152:       { name: \"--dry-run\", description: \"Show what would be launched without launching\", type: \"boolean\", default: false },\n153:       { name: \"--base-branch\", description: \"Base branch (default: from config)\", type: \"string\" },\n154:       { name: \"--max-retries\", description: \"Max retries per agent\", type: \"number\" },\n155:       { name: \"--browser\", description: \"Enable browser-based verification after build passes\", type: \"boolean\", default: false },\n156:       { name: \"--skip-tests\", description: \"Skip running tests during TDD verification\", type: \"boolean\", default: false },\n157:       { name: \"--strict-tdd\", description: \"Strict TDD mode: fail verification if new files are missing tests\", type: \"boolean\", default: false },\n158:     ],\n159:     mutating: true,\n160:     supportsDryRun: true,\n161:   },\n162: \n163:   // --- resume -------------------------------------------------------------\n164:   {\n165:     name: \"resume\",\n166:     summary: \"Resume a previously stopped wave\",\n167:     positionals: [],\n168:     flags: [\n169:       { name: \"--max-concurrent\", description: \"Max agents running in parallel\", type: \"number\" },\n170:       { name: \"--model\", alias: \"-m\", description: \"Model to use\", type: \"string\" },\n171:       { name: \"--interactive\", description: \"Use multiplexer (dmux/tmux) TUI mode\", type: \"boolean\", default: false },\n172:       { name: \"--no-tui\", description: \"Headless mode without neo-blessed TUI\", type: \"boolean\", default: false },\n173:       { name: \"--auto-push\", description: \"Push base branch to remote after merges\", type: \"boolean\", default: false },\n174:       { name: \"--base-branch\", description: \"Base branch override\", type: \"string\" },\n175:       { name: \"--max-retries\", description: \"Max retries per agent\", type: \"number\" },\n176:     ],\n177:     mutating: true,\n178:     supportsDryRun: false,\n179:   },\n180: \n181:   // --- status -------------------------------------------------------------\n182:   {\n183:     name: \"status\",\n184:     summary: \"Show the status of the current wave\",\n185:     positionals: [],\n186:     flags: [],\n187:     mutating: false,\n188:     supportsDryRun: false,\n189:   },\n190: \n191:   // --- verify -------------------------------------------------------------\n192:   {\n193:     name: \"verify\",\n194:     summary: \"Run build verification on completed agents\",\n195:     positionals: [\n196:       { name: \"feature-id\", description: \"Specific feature to verify (optional)\", required: false },\n197:     ],\n198:     flags: [\n199:       { name: \"--model\", alias: \"-m\", description: \"Model to use for verification\", type: \"string\" },\n200:       { name: \"--max-retries\", description: \"Max retries\", type: \"number\" },\n201:       { name: \"--browser\", description: \"Enable browser-based verification after build passes\", type: \"boolean\", default: false },\n202:       { name: \"--skip-tests\", description: \"Skip running tests during TDD verification\", type: \"boolean\", default: false },\n203:       { name: \"--strict-tdd\", description: \"Strict TDD mode: fail verification if new files are missing tests\", type: \"boolean\", default: false },\n204:     ],\n205:     mutating: true,\n206:     supportsDryRun: false,\n207:   },\n208: \n209:   // --- merge --------------------------------------------------------------\n210:   {\n211:     name: \"merge\",\n212:     summary: \"Merge verified branches into the base branch\",\n213:     positionals: [\n214:       { name: \"feature-id\", description: \"Specific feature to merge (optional)\", required: false },\n215:     ],\n216:     flags: [\n217:       { name: \"--auto-push\", description: \"Push base branch to remote after merge\", type: \"boolean\", default: false },\n218:       { name: \"--dry-run\", description: \"Show what would be merged without merging\", type: \"boolean\", default: false },\n219:     ],\n220:     mutating: true,\n221:     supportsDryRun: true,\n222:   },\n223: \n224:   // --- retry --------------------------------------------------------------\n225:   {\n226:     name: \"retry\",\n227:     summary: \"Retry a failed agent\",\n228:     positionals: [\n229:       { name: \"feature-id\", description: \"Feature ID of the failed agent\", required: true },\n230:     ],\n231:     flags: [\n232:       { name: \"--model\", alias: \"-m\", description: \"Model to use\", type: \"string\" },\n233:       { name: \"--interactive\", description: \"Use multiplexer (dmux/tmux) TUI mode\", type: \"boolean\", default: false },\n234:       { name: \"--dry-run\", description: \"Show what would be retried without retrying\", type: \"boolean\", default: false },\n235:     ],\n236:     mutating: true,\n237:     supportsDryRun: true,\n238:   },\n239: \n240:   // --- cleanup ------------------------------------------------------------\n241:   {\n242:     name: \"cleanup\",\n243:     summary: \"Remove all wave worktrees and multiplexer sessions\",\n244:     description: \"Kills multiplexer sessions, removes worktrees, removes state and log files.\",\n245:     positionals: [],\n246:     flags: [\n247:       { name: \"--dry-run\", description: \"Show what would be cleaned up without removing\", type: \"boolean\", default: false },\n248:     ],\n249:     mutating: true,\n250:     supportsDryRun: true,\n251:   },\n252: \n253:   // --- history ------------------------------------------------------------\n254:   {\n255:     name: \"history\",\n256:     summary: \"List/view past wave results from .wombo-combo/history/\",\n257:     description:\n258:       \"Wave history is auto-exported when a wave completes. Records are stored \" +\n259:       \"separately from .wombo-combo/state.json and survive cleanup. Use without arguments \" +\n260:       \"to list all waves, or pass a wave ID to see detailed results.\",\n261:     positionals: [\n262:       { name: \"wave-id\", description: \"Specific wave ID to show details for (optional)\", required: false },\n263:     ],\n264:     flags: [],\n265:     mutating: false,\n266:     supportsDryRun: false,\n267:   },\n268: \n269:   // --- abort --------------------------------------------------------------\n270:   {\n271:     name: \"abort\",\n272:     summary: \"Kill a single running agent without affecting the rest of the wave\",\n273:     description:\n274:       \"Kills the multiplexer session and agent process for a specific feature, then \" +\n275:       \"marks the agent as failed. Use --requeue to return the feature to the \" +\n276:       \"queue instead of marking it failed.\",\n277:     positionals: [\n278:       { name: \"feature-id\", description: \"Feature ID of the agent to abort\", required: true },\n279:     ],\n280:     flags: [\n281:       { name: \"--requeue\", description: \"Return the feature to queued instead of marking it failed\", type: \"boolean\", default: false },\n282:     ],\n283:     mutating: true,\n284:     supportsDryRun: false,\n285:   },\n286: \n287:   // --- upgrade ------------------------------------------------------------\n288:   {\n289:     name: \"upgrade\",\n290:     summary: \"Check for updates and upgrade wombo\",\n291:     positionals: [],\n292:     flags: [\n293:       { name: \"--check\", description: \"Only check for updates, don't install\", type: \"boolean\", default: false },\n294:       { name: \"--tag\", alias: \"--release\", description: \"Install a specific version (e.g., v0.1.0)\", type: \"string\" },\n295:       { name: \"--force\", description: \"Force reinstall even if up to date\", type: \"boolean\", default: false },\n296:     ],\n297:     mutating: true,\n298:     supportsDryRun: false,\n299:   },\n300: \n301:   // --- logs ---------------------------------------------------------------\n302:   {\n303:     name: \"logs\",\n304:     summary: \"Pretty-print agent logs from .wombo-combo/logs/<feature-id>.log\",\n305:     description:\n306:       \"Reads log files written by agents during headless runs and displays \" +\n307:       \"them with colorized output. Supports tailing and following.\",\n308:     positionals: [\n309:       { name: \"feature-id\", description: \"Feature ID whose logs to display\", required: true },\n310:     ],\n311:     flags: [\n312:       { name: \"--tail\", description: \"Show only the last N lines\", type: \"number\" },\n313:       { name: \"--follow\", alias: \"-f\", description: \"Stream new output as it arrives (like tail -f)\", type: \"boolean\", default: false },\n314:     ],\n315:     mutating: false,\n316:     supportsDryRun: false,\n317:   },\n318: \n319:   // --- tasks (parent with subcommands) — also accepts \"features\" as alias ---\n320:   {\n321:     name: \"tasks\",\n322:     summary: \"Manage tasks file\",\n323:     positionals: [],\n324:     flags: [],\n325:     mutating: false,\n326:     supportsDryRun: false,\n327:     subcommands: [\n328:       {\n329:         name: \"tasks list\",\n330:         summary: \"List tasks with optional filtering\",\n331:         positionals: [],\n332:         flags: [\n333:           { name: \"--status\", description: \"Filter by status\", type: \"string\", enum: VALID_STATUSES },\n334:           { name: \"--priority\", description: \"Filter by priority\", type: \"string\", enum: VALID_PRIORITIES },\n335:           { name: \"--difficulty\", description: \"Filter by difficulty\", type: \"string\", enum: VALID_DIFFICULTIES },\n336:           { name: \"--ready\", description: \"Show only ready tasks (backlog + deps met)\", type: \"boolean\", default: false },\n337:           { name: \"--include-archive\", description: \"Include archived tasks\", type: \"boolean\", default: false },\n338:           { name: \"--fields\", description: \"Comma-separated list of fields to include in output\", type: \"string\" },\n339:         ],\n340:         mutating: false,\n341:         supportsDryRun: false,\n342:       },\n343:       {\n344:         name: \"tasks add\",\n345:         summary: \"Add a new task\",\n346:         positionals: [\n347:           { name: \"id\", description: \"Task ID (kebab-case)\", required: true },\n348:           { name: \"title\", description: \"Task title\", required: true },\n349:         ],\n350:         flags: [\n351:           { name: \"--description\", alias: \"--desc\", description: \"Task description\", type: \"string\" },\n352:           { name: \"--priority\", description: \"Priority level\", type: \"string\", default: \"medium\", enum: VALID_PRIORITIES },\n353:           { name: \"--difficulty\", description: \"Difficulty level\", type: \"string\", default: \"medium\", enum: VALID_DIFFICULTIES },\n354:           { name: \"--effort\", description: \"Effort estimate (ISO 8601 duration, e.g. PT2H)\", type: \"string\", default: \"PT1H\" },\n355:           { name: \"--depends-on\", description: \"Comma-separated dependency IDs\", type: \"string\" },\n356:           { name: \"--dry-run\", description: \"Show what would be added without writing\", type: \"boolean\", default: false },\n357:         ],\n358:         mutating: true,\n359:         supportsDryRun: true,\n360:       },\n361:       {\n362:         name: \"tasks set-status\",\n363:         summary: \"Change a task's status\",\n364:         positionals: [\n365:           { name: \"task-id\", description: \"Task ID to update\", required: true },\n366:           { name: \"status\", description: \"New status value\", required: true },\n367:         ],\n368:         flags: [\n369:           { name: \"--dry-run\", description: \"Show what would change without writing\", type: \"boolean\", default: false },\n370:         ],\n371:         mutating: true,\n372:         supportsDryRun: true,\n373:       },\n374:       {\n375:         name: \"tasks set-priority\",\n376:         summary: \"Change a task's priority\",\n377:         positionals: [\n378:           { name: \"task-id\", description: \"Task ID to update\", required: true },\n379:           { name: \"priority\", description: \"New priority value\", required: true },\n380:         ],\n381:         flags: [\n382:           { name: \"--dry-run\", description: \"Show what would change without writing\", type: \"boolean\", default: false },\n383:         ],\n384:         mutating: true,\n385:         supportsDryRun: true,\n386:       },\n387:       {\n388:         name: \"tasks set-difficulty\",\n389:         summary: \"Change a task's difficulty\",\n390:         positionals: [\n391:           { name: \"task-id\", description: \"Task ID to update\", required: true },\n392:           { name: \"difficulty\", description: \"New difficulty value\", required: true },\n393:         ],\n394:         flags: [\n395:           { name: \"--dry-run\", description: \"Show what would change without writing\", type: \"boolean\", default: false },\n396:         ],\n397:         mutating: true,\n398:         supportsDryRun: true,\n399:       },\n400:       {\n401:         name: \"tasks check\",\n402:         summary: \"Validate tasks file (schema, deps, duplicates, cycles)\",\n403:         positionals: [],\n404:         flags: [\n405:           { name: \"--output\", description: \"Output format: text (default) or json\", type: \"string\", default: \"text\" },\n406:         ],\n407:         mutating: false,\n408:         supportsDryRun: false,\n409:       },\n410:       {\n411:         name: \"tasks archive\",\n412:         summary: \"Move done/cancelled tasks to archive section\",\n413:         positionals: [\n414:           { name: \"task-id\", description: \"Specific task to archive (optional)\", required: false },\n415:         ],\n416:         flags: [\n417:           { name: \"--dry-run\", description: \"Show what would be archived without moving\", type: \"boolean\", default: false },\n418:         ],\n419:         mutating: true,\n420:         supportsDryRun: true,\n421:       },\n422:       {\n423:         name: \"tasks show\",\n424:         summary: \"Show detailed information about a specific task\",\n425:         positionals: [\n426:           { name: \"task-id\", description: \"Task ID to display\", required: true },\n427:         ],\n428:         flags: [\n429:           { name: \"--fields\", description: \"Comma-separated list of fields to include in output\", type: \"string\" },\n430:         ],\n431:         mutating: false,\n432:         supportsDryRun: false,\n433:       },\n434:       {\n435:         name: \"tasks graph\",\n436:         summary: \"Visualize the task dependency graph as a terminal diagram\",\n437:         description:\n438:           \"Builds a Mermaid flowchart from the tasks dependency graph and renders \" +\n439:           \"it as a Unicode box diagram. Shows dependency edges, status badges, orphan \" +\n440:           \"detection, dangling dependency warnings, and cycle detection.\",\n441:         positionals: [],\n442:         flags: [\n443:           { name: \"--status\", description: \"Filter graph to tasks with this status\", type: \"string\", enum: VALID_STATUSES },\n444:           { name: \"--ascii\", description: \"Use ASCII-only rendering (no Unicode box chars)\", type: \"boolean\", default: false },\n445:           { name: \"--mermaid\", description: \"Emit raw Mermaid source instead of rendered graph\", type: \"boolean\", default: false },\n446:           { name: \"--subtasks\", description: \"Include subtask-level nodes in the graph\", type: \"boolean\", default: false },\n447:         ],\n448:         mutating: false,\n449:         supportsDryRun: false,\n450:       },\n451:     ],\n452:   },\n453: \n454:   // --- help ---------------------------------------------------------------\n455:   {\n456:     name: \"help\",\n457:     summary: \"Show help text\",\n458:     positionals: [],\n459:     flags: [],\n460:     mutating: false,\n461:     supportsDryRun: false,\n462:   },\n463: \n464:   // --- version -----------------------------------------------------------\n465:   {\n466:     name: \"version\",\n467:     summary: \"Print version and exit (also: -v, -V)\",\n468:     positionals: [],\n469:     flags: [],\n470:     mutating: false,\n471:     supportsDryRun: false,\n472:   },\n473: \n474:   // --- describe -----------------------------------------------------------\n475:   {\n476:     name: \"describe\",\n477:     summary: \"Emit JSON schema of a command's arguments and flags\",\n478:     description:\n479:       \"Machine-readable introspection for AI agents. Outputs the accepted \" +\n480:       \"positionals, flags, types, defaults, and constraints for a command.\",\n481:     positionals: [\n482:       { name: \"command\", description: \"Command to describe (e.g. 'launch', 'features add')\", required: false },\n483:     ],\n484:     flags: [],\n485:     mutating: false,\n486:     supportsDryRun: false,\n487:   },\n488: ];\n489: \n490: // ---------------------------------------------------------------------------\n491: // Lookup helpers\n492: // ---------------------------------------------------------------------------\n493: \n494: /**\n495:  * Find a command definition by name. Supports compound names like \"tasks list\".\n496:  * Also supports \"features\" as a backward-compat alias for \"tasks\".\n497:  */\n498: export function findCommandDef(name: string): CommandDef | undefined {\n499:   // Normalize \"features\" -> \"tasks\" for backward compatibility\n500:   const normalized = name.replace(/^features(\\s|$)/, \"tasks$1\");\n501: \n502:   // Try direct match first\n503:   const direct = COMMAND_REGISTRY.find((c) => c.name === normalized);\n504:   if (direct) return direct;\n505: \n506:   // Try compound: \"tasks list\" -> look in tasks subcommands\n507:   const parts = normalized.split(/\\s+/);\n508:   if (parts.length === 2) {\n509:     const parent = COMMAND_REGISTRY.find((c) => c.name === parts[0]);\n510:     if (parent?.subcommands) {\n511:       return parent.subcommands.find((sc) => sc.name === normalized || sc.name === parts[1]);\n512:     }\n513:   }\n514: \n515:   return undefined;\n516: }\n517: \n518: /**\n519:  * Produce the JSON schema object for a command, suitable for agent consumption.\n520:  */\n521: export function commandToSchema(cmd: CommandDef): Record<string, unknown> {\n522:   const schema: Record<string, unknown> = {\n523:     command: cmd.name,\n524:     summary: cmd.summary,\n525:     mutating: cmd.mutating,\n526:     supports_dry_run: cmd.supportsDryRun,\n527:   };\n528: \n529:   if (cmd.description) {\n530:     schema.description = cmd.description;\n531:   }\n532: \n533:   if (cmd.positionals.length > 0) {\n534:     schema.positionals = cmd.positionals.map((p) => ({\n535:       name: p.name,\n536:       description: p.description,\n537:       required: p.required ?? false,\n538:     }));\n539:   }\n540: \n541:   const allFlags = [...cmd.flags, ...GLOBAL_FLAGS];\n542:   schema.flags = allFlags.map((f) => {\n543:     const entry: Record<string, unknown> = {\n544:       name: f.name,\n545:       type: f.type,\n546:       description: f.description,\n547:     };\n548:     if (f.alias) entry.alias = f.alias;\n549:     if (f.default !== undefined) entry.default = f.default;\n550:     if (f.enum) entry.enum = f.enum;\n551:     if (f.required) entry.required = true;\n552:     return entry;\n553:   });\n554: \n555:   if (cmd.subcommands?.length) {\n556:     schema.subcommands = cmd.subcommands.map((sc) => sc.name);\n557:   }\n558: \n559:   return schema;\n560: }\n561: \n562: /**\n563:  * Produce a listing of all commands (for `woco describe` with no args).\n564:  */\n565: export function allCommandSchemas(): Record<string, unknown> {\n566:   const commands: Record<string, unknown>[] = [];\n567: \n568:   for (const cmd of COMMAND_REGISTRY) {\n569:     const entry: Record<string, unknown> = {\n570:       name: cmd.name,\n571:       summary: cmd.summary,\n572:       mutating: cmd.mutating,\n573:       supports_dry_run: cmd.supportsDryRun,\n574:     };\n575:     if (cmd.subcommands) {\n576:       entry.subcommands = cmd.subcommands.map((sc) => ({\n577:         name: sc.name,\n578:         summary: sc.summary,\n579:         mutating: sc.mutating,\n580:         supports_dry_run: sc.supportsDryRun,\n581:       }));\n582:     }\n583:     commands.push(entry);\n584:   }\n585: \n586:   return {\n587:     tool: \"wombo-combo\",\n588:     version: getVersion(),\n589:     global_flags: GLOBAL_FLAGS.map((f) => ({\n590:       name: f.name,\n591:       alias: f.alias,\n592:       type: f.type,\n593:       description: f.description,\n594:       default: f.default,\n595:     })),\n596:     commands,\n597:   };\n598: }\n\n(End of file - total 598 lines)\n</content>","title":"src/lib/schema.ts","metadata":{"preview":"/**\n * schema.ts — Declarative command/flag registry for schema introspection.\n *\n * Every command and flag is described in a single registry. This registry is\n * the source of truth for:\n *   1. `woco describe <command>` — emits a JSON schema of accepted args\n *   2. Future help text generation\n *\n * The registry is NOT used for actual arg parsing (that's still the hand-rolled\n * switch in index.ts), but the two must stay in sync. If they drift, `woco\n * tasks check` should eventually catch it.\n */\n\nimport { readFileSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\nimport { VALID_STATUSES, VALID_PRIORITIES, VALID_DIFFICULTIES } from \"./task-schema.js\";\n\n// ---------------------------------------------------------------------------\n// Dynamic version reader\n// ---------------------------------------------------------------------------","truncated":false,"loaded":[]},"time":{"start":1773437537430,"end":1773437537433}}}}
