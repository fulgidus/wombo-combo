{"type":"tool_use","timestamp":1773437517280,"sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","part":{"id":"prt_ce91cfa20001vtGw141SyHlxKV","sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","messageID":"msg_ce91cf250001bUzrxC0yPNRnDy","type":"tool","callID":"toolu_vrtx_01RTmeYH9sUWpUgK9bY3jnrp","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/cleanup.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/cleanup.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * cleanup.ts — Remove all wave-related resources.\n3:  *\n4:  * Usage: woco cleanup\n5:  *\n6:  * Kills multiplexer sessions (dmux/tmux), removes worktrees, removes state and log files.\n7:  *\n8:  * NOTE: .wombo-combo/history/ is intentionally NOT removed by cleanup.\n9:  * Wave history records are meant to survive cleanup for retrospective\n10:  * analysis. See src/lib/history.ts.\n11:  */\n12: \n13: import { existsSync, unlinkSync, rmSync } from \"node:fs\";\n14: import { execSync } from \"node:child_process\";\n15: import { resolve } from \"node:path\";\n16: import type { WomboConfig } from \"../config.js\";\n17: import { WOMBO_DIR } from \"../config.js\";\n18: import { killAllMuxSessions, getMultiplexerName } from \"../lib/launcher.js\";\n19: import { cleanupAllWorktrees, listWomboWorktrees } from \"../lib/worktree.js\";\n20: import {\n21:   detectMultiplexer,\n22:   muxListSessions,\n23: } from \"../lib/multiplexer.js\";\n24: import { output, outputMessage, type OutputFormat } from \"../lib/output.js\";\n25: \n26: export interface CleanupOptions {\n27:   projectRoot: string;\n28:   config: WomboConfig;\n29:   dryRun?: boolean;\n30:   outputFmt?: OutputFormat;\n31: }\n32: \n33: export async function cmdCleanup(opts: CleanupOptions): Promise<void> {\n34:   const { projectRoot, config } = opts;\n35:   const fmt = opts.outputFmt ?? \"text\";\n36: \n37:   // Dry-run: show what would be cleaned up without doing it\n38:   if (opts.dryRun) {\n39:     // List multiplexer sessions that would be killed\n40:     const muxName = getMultiplexerName(config);\n41:     let matchingSessions: string[] = [];\n42:     try {\n43:       const mux = detectMultiplexer(config.agent.multiplexer);\n44:       const sessions = muxListSessions(mux);\n45:       const prefix = config.agent.tmuxPrefix;\n46:       matchingSessions = sessions.filter((s) => s.startsWith(prefix));\n47:     } catch {\n48:       // no mux server running\n49:     }\n50: \n51:     // List worktrees that would be removed (using safe filtering)\n52:     let matchingWorktrees: { path: string }[] = [];\n53:     try {\n54:       matchingWorktrees = listWomboWorktrees(projectRoot, config);\n55:     } catch {\n56:       // no worktrees\n57:     }\n58: \n59:     const statePath = resolve(projectRoot, WOMBO_DIR, \"state.json\");\n60:     const logDir = resolve(projectRoot, WOMBO_DIR, \"logs\");\n61:     const filesToRemove: string[] = [];\n62:     if (existsSync(statePath)) filesToRemove.push(\".wombo-combo/state.json\");\n63:     if (existsSync(logDir)) filesToRemove.push(\".wombo-combo/logs/\");\n64: \n65:     const dryRunResult = {\n66:       dry_run: true,\n67:       mux_sessions: matchingSessions,\n68:       mux_sessions_count: matchingSessions.length,\n69:       worktrees: matchingWorktrees.map((wt) => wt.path),\n70:       worktrees_count: matchingWorktrees.length,\n71:       files_to_remove: filesToRemove,\n72:     };\n73: \n74:     output(fmt, dryRunResult, () => {\n75:       console.log(\"\\n[dry-run] Would perform the following cleanup:\\n\");\n76:       console.log(`  ${muxName} sessions to kill: ${matchingSessions.length}`);\n77:       for (const s of matchingSessions) {\n78:         console.log(`    ${s}`);\n79:       }\n80:       console.log(`  worktrees to remove: ${matchingWorktrees.length}`);\n81:       for (const wt of matchingWorktrees) {\n82:         console.log(`    ${wt.path}`);\n83:       }\n84:       for (const f of filesToRemove) {\n85:         console.log(`  Would remove: ${f}`);\n86:       }\n87:     });\n88: \n89:     return;\n90:   }\n91: \n92:   // Kill multiplexer sessions\n93:   const muxName = getMultiplexerName(config);\n94:   const killed = killAllMuxSessions(config);\n95: \n96:   // Remove worktrees\n97:   const removed = cleanupAllWorktrees(projectRoot, config);\n98: \n99:   // List remaining feature branches\n100:   let remainingBranches: string[] = [];\n101:   try {\n102:     const branchPattern = `\"${config.git.branchPrefix}*\"`;\n103:     const branchesRaw = execSync(`git branch --list ${branchPattern}`, {\n104:       cwd: projectRoot,\n105:       encoding: \"utf-8\",\n106:     }).trim();\n107:     if (branchesRaw) {\n108:       remainingBranches = branchesRaw.split(\"\\n\").map((b) => b.trim());\n109:     }\n110:   } catch {}\n111: \n112:   // Remove state file\n113:   const statePath = resolve(projectRoot, WOMBO_DIR, \"state.json\");\n114:   const stateRemoved = existsSync(statePath);\n115:   if (stateRemoved) {\n116:     unlinkSync(statePath);\n117:   }\n118: \n119:   // Remove log directory\n120:   const logDir = resolve(projectRoot, WOMBO_DIR, \"logs\");\n121:   const logsRemoved = existsSync(logDir);\n122:   if (logsRemoved) {\n123:     rmSync(logDir, { recursive: true, force: true });\n124:   }\n125: \n126:   // Check if history is preserved\n127:   const historyDir = resolve(projectRoot, WOMBO_DIR, \"history\");\n128:   const historyPreserved = existsSync(historyDir);\n129: \n130:   const result = {\n131:     mux_sessions_killed: killed,\n132:     worktrees_removed: removed,\n133:     state_removed: stateRemoved,\n134:     logs_removed: logsRemoved,\n135:     remaining_branches: remainingBranches,\n136:     history_preserved: historyPreserved,\n137:   };\n138: \n139:   output(fmt, result, () => {\n140:     console.log(\"\\n--- wombo-combo: Cleanup ---\\n\");\n141:     console.log(`Killed ${killed} ${muxName} session(s)`);\n142:     console.log(`Removed ${removed} worktree(s)`);\n143: \n144:     if (remainingBranches.length > 0) {\n145:       console.log(`\\nRemaining feature branches:\\n${remainingBranches.map((b) => `  ${b}`).join(\"\\n\")}`);\n146:       console.log('Use \"git branch -D <branch>\" to remove manually.');\n147:     }\n148: \n149:     if (stateRemoved) console.log(\"Removed .wombo-combo/state.json\");\n150:     if (logsRemoved) console.log(\"Removed .wombo-combo/logs/\");\n151: \n152:     console.log(\"\\nCleanup complete.\");\n153: \n154:     if (historyPreserved) {\n155:       console.log(\"Note: .wombo-combo/history/ is preserved. Use 'woco history' to view past waves.\");\n156:     }\n157:   });\n158: }\n\n(End of file - total 158 lines)\n</content>","title":"src/commands/cleanup.ts","metadata":{"preview":"/**\n * cleanup.ts — Remove all wave-related resources.\n *\n * Usage: woco cleanup\n *\n * Kills multiplexer sessions (dmux/tmux), removes worktrees, removes state and log files.\n *\n * NOTE: .wombo-combo/history/ is intentionally NOT removed by cleanup.\n * Wave history records are meant to survive cleanup for retrospective\n * analysis. See src/lib/history.ts.\n */\n\nimport { existsSync, unlinkSync, rmSync } from \"node:fs\";\nimport { execSync } from \"node:child_process\";\nimport { resolve } from \"node:path\";\nimport type { WomboConfig } from \"../config.js\";\nimport { WOMBO_DIR } from \"../config.js\";\nimport { killAllMuxSessions, getMultiplexerName } from \"../lib/launcher.js\";\nimport { cleanupAllWorktrees, listWomboWorktrees } from \"../lib/worktree.js\";\nimport {","truncated":false,"loaded":[]},"time":{"start":1773437517277,"end":1773437517279}}}}
