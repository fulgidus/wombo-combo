{"type":"tool_use","timestamp":1773437526601,"sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","part":{"id":"prt_ce91d1f0f002citdkiaMOcY2jY","sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","messageID":"msg_ce91d158f00143yns0GMRW9tab","type":"tool","callID":"toolu_vrtx_01BkuY73xzEpUw9Lm2NL1GFY","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/retry.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/retry.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * retry.ts — Retry a specific failed agent.\n3:  *\n4:  * Usage: woco retry <feature-id> [--interactive] [--model <model>] [--output json]\n5:  *\n6:  * Resets the agent's retry count and re-launches it. Can launch in either\n7:  * headless mode (default) or interactive (dmux/tmux) mode.\n8:  */\n9: \n10: import type { WomboConfig } from \"../config.js\";\n11: import { loadFeatures, type Feature } from \"../lib/tasks.js\";\n12: import {\n13:   loadState,\n14:   saveState,\n15:   updateAgent,\n16: } from \"../lib/state.js\";\n17: import { worktreeReady } from \"../lib/worktree.js\";\n18: import { generatePrompt } from \"../lib/prompt.js\";\n19: import { launchInteractive, getMultiplexerName } from \"../lib/launcher.js\";\n20: import { ProcessMonitor } from \"../lib/monitor.js\";\n21: import { launchSingleHeadless } from \"./launch.js\";\n22: import { output, outputError, outputMessage, type OutputFormat } from \"../lib/output.js\";\n23: \n24: // ---------------------------------------------------------------------------\n25: // Types\n26: // ---------------------------------------------------------------------------\n27: \n28: export interface RetryCommandOptions {\n29:   projectRoot: string;\n30:   config: WomboConfig;\n31:   featureId: string;\n32:   model?: string;\n33:   interactive: boolean;\n34:   dryRun?: boolean;\n35:   outputFmt?: OutputFormat;\n36: }\n37: \n38: // ---------------------------------------------------------------------------\n39: // Command\n40: // ---------------------------------------------------------------------------\n41: \n42: export async function cmdRetry(opts: RetryCommandOptions): Promise<void> {\n43:   const { projectRoot, config } = opts;\n44:   const fmt = opts.outputFmt ?? \"text\";\n45: \n46:   if (!opts.featureId) {\n47:     outputError(fmt, \"Usage: woco retry <feature-id>\");\n48:     return; // unreachable — outputError calls process.exit\n49:   }\n50: \n51:   const state = loadState(projectRoot);\n52:   if (!state) {\n53:     outputMessage(fmt, \"No active wave.\", { wave_id: null });\n54:     return;\n55:   }\n56: \n57:   const agent = state.agents.find((a) => a.feature_id === opts.featureId);\n58:   if (!agent) {\n59:     outputError(fmt, `Agent not found for feature: ${opts.featureId}`);\n60:     return; // unreachable\n61:   }\n62: \n63:   if (agent.status !== \"failed\") {\n64:     outputError(\n65:       fmt,\n66:       `Agent ${opts.featureId} is not in failed state (current: ${agent.status})`\n67:     );\n68:     return; // unreachable\n69:   }\n70: \n71:   // Dry-run: show what would be retried without doing it\n72:   if (opts.dryRun) {\n73:     const dryRunResult = {\n74:       dry_run: true,\n75:       feature_id: opts.featureId,\n76:       current_status: agent.status,\n77:       retries_so_far: agent.retries,\n78:       worktree: agent.worktree,\n79:       mode: opts.interactive ? \"interactive\" : \"headless\",\n80:       model: opts.model ?? null,\n81:     };\n82: \n83:     output(fmt, dryRunResult, () => {\n84:       console.log(`\\n[dry-run] Would retry agent: ${opts.featureId}`);\n85:       console.log(`  Current status: ${agent.status}`);\n86:       console.log(`  Retries so far: ${agent.retries}`);\n87:       console.log(`  Worktree: ${agent.worktree}`);\n88:       console.log(`  Mode: ${opts.interactive ? \"interactive (multiplexer)\" : \"headless\"}`);\n89:       if (opts.model) console.log(`  Model: ${opts.model}`);\n90:     });\n91:     return;\n92:   }\n93: \n94:   // Reset retry count and re-run\n95:   updateAgent(state, agent.feature_id, {\n96:     status: \"queued\",\n97:     retries: 0,\n98:     error: null,\n99:     build_passed: null,\n100:     build_output: null,\n101:     completed_at: null,\n102:   });\n103:   saveState(projectRoot, state);\n104: \n105:   const data = loadFeatures(projectRoot, config);\n106:   const feature = data.tasks.find((f: Feature) => f.id === opts.featureId);\n107:   if (!feature) {\n108:     outputError(fmt, `Feature ${opts.featureId} not found in ${config.tasksDir}`);\n109:     return; // unreachable\n110:   }\n111: \n112:   if (opts.interactive) {\n113:     const prompt = generatePrompt(feature, state.base_branch, config);\n114:     launchInteractive({\n115:       worktreePath: agent.worktree,\n116:       featureId: feature.id,\n117:       prompt,\n118:       model: opts.model,\n119:       interactive: true,\n120:       config,\n121:     });\n122: \n123:     updateAgent(state, agent.feature_id, {\n124:       status: \"running\",\n125:       started_at: new Date().toISOString(),\n126:     });\n127:     saveState(projectRoot, state);\n128:     const muxName = getMultiplexerName(config);\n129: \n130:     output(fmt, {\n131:       feature_id: opts.featureId,\n132:       mode: \"interactive\",\n133:       status: \"running\",\n134:       mux_session: `${config.agent.tmuxPrefix}-${opts.featureId}`,\n135:     }, () => {\n136:       console.log(`Retrying ${opts.featureId} in ${muxName} session ${config.agent.tmuxPrefix}-${opts.featureId}`);\n137:     });\n138:   } else {\n139:     const monitor = new ProcessMonitor(projectRoot);\n140:     await launchSingleHeadless(projectRoot, state, agent, feature, monitor, config, opts.model);\n141: \n142:     // Re-read agent after launch to get PID\n143:     const updatedAgent = state.agents.find((a) => a.feature_id === opts.featureId);\n144: \n145:     output(fmt, {\n146:       feature_id: opts.featureId,\n147:       mode: \"headless\",\n148:       status: updatedAgent?.status ?? \"running\",\n149:       pid: updatedAgent?.pid ?? null,\n150:     }, () => {\n151:       console.log(`Retrying ${opts.featureId} in headless mode`);\n152:     });\n153:   }\n154: }\n\n(End of file - total 154 lines)\n</content>","title":"src/commands/retry.ts","metadata":{"preview":"/**\n * retry.ts — Retry a specific failed agent.\n *\n * Usage: woco retry <feature-id> [--interactive] [--model <model>] [--output json]\n *\n * Resets the agent's retry count and re-launches it. Can launch in either\n * headless mode (default) or interactive (dmux/tmux) mode.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport { loadFeatures, type Feature } from \"../lib/tasks.js\";\nimport {\n  loadState,\n  saveState,\n  updateAgent,\n} from \"../lib/state.js\";\nimport { worktreeReady } from \"../lib/worktree.js\";\nimport { generatePrompt } from \"../lib/prompt.js\";\nimport { launchInteractive, getMultiplexerName } from \"../lib/launcher.js\";\nimport { ProcessMonitor } from \"../lib/monitor.js\";","truncated":false,"loaded":[]},"time":{"start":1773437526597,"end":1773437526600}}}}
