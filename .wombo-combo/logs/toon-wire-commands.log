{"type":"tool_use","timestamp":1773437523324,"sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","part":{"id":"prt_ce91d12a9001DpnQqHvsuh1U4W","sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","messageID":"msg_ce91d098a0018W72G29yu443uj","type":"tool","callID":"toolu_vrtx_016HxXBn1iLCbPw199GftUjL","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/merge.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/merge.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * merge.ts — Merge verified branches into the base branch.\n3:  *\n4:  * Usage: woco merge [feature-id] [--output json]\n5:  *\n6:  * Merges all verified agents (or a specific one) into the base branch.\n7:  * Uses the full merge pipeline including pre-flight conflict detection,\n8:  * automatic conflict resolution, and configurable retry attempts.\n9:  */\n10: \n11: import type { WomboConfig } from \"../config.js\";\n12: import {\n13:   loadState,\n14: } from \"../lib/state.js\";\n15: import { pushBaseBranch } from \"../lib/merger.js\";\n16: import type { Feature } from \"../lib/tasks.js\";\n17: import { loadFeatures } from \"../lib/tasks.js\";\n18: import { printDashboard, printAgentUpdate } from \"../lib/ui.js\";\n19: import { attemptMerge } from \"./launch.js\";\n20: import { output, outputMessage, type OutputFormat } from \"../lib/output.js\";\n21: \n22: // ---------------------------------------------------------------------------\n23: // Types\n24: // ---------------------------------------------------------------------------\n25: \n26: export interface MergeCommandOptions {\n27:   projectRoot: string;\n28:   config: WomboConfig;\n29:   featureId?: string;\n30:   autoPush?: boolean;\n31:   dryRun?: boolean;\n32:   model?: string;\n33:   outputFmt?: OutputFormat;\n34: }\n35: \n36: // ---------------------------------------------------------------------------\n37: // Command\n38: // ---------------------------------------------------------------------------\n39: \n40: export async function cmdMerge(opts: MergeCommandOptions): Promise<void> {\n41:   const { projectRoot, config } = opts;\n42:   const fmt = opts.outputFmt ?? \"text\";\n43: \n44:   const state = loadState(projectRoot);\n45:   if (!state) {\n46:     outputMessage(fmt, \"No active wave.\", {\n47:       wave_id: null,\n48:       agents: [],\n49:       merged: 0,\n50:     });\n51:     return;\n52:   }\n53: \n54:   const toMerge = opts.featureId\n55:     ? state.agents.filter(\n56:         (a) => a.feature_id === opts.featureId && a.status === \"verified\"\n57:       )\n58:     : state.agents.filter((a) => a.status === \"verified\");\n59: \n60:   if (toMerge.length === 0) {\n61:     outputMessage(fmt, \"No verified agents to merge.\", {\n62:       wave_id: state.wave_id,\n63:       agents: [],\n64:       merged: 0,\n65:     });\n66:     return;\n67:   }\n68: \n69:   // Dry-run: show what would be merged without merging\n70:   if (opts.dryRun) {\n71:     const dryRunResult = {\n72:       dry_run: true,\n73:       wave_id: state.wave_id,\n74:       base_branch: state.base_branch,\n75:       count: toMerge.length,\n76:       agents: toMerge.map((a) => ({\n77:         feature_id: a.feature_id,\n78:         branch: a.branch,\n79:       })),\n80:       auto_push: !!opts.autoPush,\n81:     };\n82: \n83:     output(fmt, dryRunResult, () => {\n84:       console.log(`\\n[dry-run] Would merge ${toMerge.length} branch(es):\\n`);\n85:       for (const agent of toMerge) {\n86:         console.log(`  ${agent.feature_id} — branch: ${agent.branch}`);\n87:       }\n88:       if (opts.autoPush) {\n89:         console.log(`\\n  Would push ${state.base_branch} to remote after merge.`);\n90:       }\n91:     });\n92:     return;\n93:   }\n94: \n95:   // Load features for conflict resolution prompt generation.\n96:   // Build a flat map of all feature/subtask IDs so we can look up any agent.\n97:   const data = loadFeatures(projectRoot, config);\n98:   const featureMap = new Map<string, Feature>();\n99:   function indexFeatures(items: Feature[]) {\n100:     for (const f of items) {\n101:       featureMap.set(f.id, f);\n102:       if (f.subtasks) {\n103:         indexFeatures(f.subtasks as unknown as Feature[]);\n104:       }\n105:     }\n106:   }\n107:   indexFeatures(data.tasks);\n108:   indexFeatures(data.archive);\n109: \n110:   if (fmt === \"text\") {\n111:     console.log(`\\nMerging ${toMerge.length} branch(es)...\\n`);\n112:   }\n113: \n114:   for (const agent of toMerge) {\n115:     const feature = featureMap.get(agent.feature_id);\n116:     if (!feature) {\n117:       if (fmt === \"text\") {\n118:         printAgentUpdate(agent, `SKIP — feature \"${agent.feature_id}\" not found in features file`);\n119:       }\n120:       continue;\n121:     }\n122: \n123:     // Use the full merge pipeline (pre-flight, conflict resolution, retry)\n124:     await attemptMerge(projectRoot, state, agent, feature, config, opts.model);\n125:   }\n126: \n127:   // Auto-push if requested\n128:   if (opts.autoPush) {\n129:     const anyMerged = state.agents.some((a) => a.status === \"merged\");\n130:     if (anyMerged) {\n131:       await pushBaseBranch(projectRoot, state.base_branch, config);\n132:     }\n133:   }\n134: \n135:   // Collect results for JSON output\n136:   const results = toMerge.map((agent) => {\n137:     const updatedAgent = state.agents.find((a) => a.feature_id === agent.feature_id);\n138:     return {\n139:       feature_id: agent.feature_id,\n140:       branch: agent.branch,\n141:       status: updatedAgent?.status ?? agent.status,\n142:       error: updatedAgent?.error ?? agent.error,\n143:     };\n144:   });\n145: \n146:   output(fmt, {\n147:     wave_id: state.wave_id,\n148:     base_branch: state.base_branch,\n149:     merged: results.filter((r) => r.status === \"merged\").length,\n150:     failed: results.filter((r) => r.status === \"failed\").length,\n151:     agents: results,\n152:   }, () => {\n153:     printDashboard(state);\n154:   });\n155: }\n\n(End of file - total 155 lines)\n</content>","title":"src/commands/merge.ts","metadata":{"preview":"/**\n * merge.ts — Merge verified branches into the base branch.\n *\n * Usage: woco merge [feature-id] [--output json]\n *\n * Merges all verified agents (or a specific one) into the base branch.\n * Uses the full merge pipeline including pre-flight conflict detection,\n * automatic conflict resolution, and configurable retry attempts.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport {\n  loadState,\n} from \"../lib/state.js\";\nimport { pushBaseBranch } from \"../lib/merger.js\";\nimport type { Feature } from \"../lib/tasks.js\";\nimport { loadFeatures } from \"../lib/tasks.js\";\nimport { printDashboard, printAgentUpdate } from \"../lib/ui.js\";\nimport { attemptMerge } from \"./launch.js\";\nimport { output, outputMessage, type OutputFormat } from \"../lib/output.js\";","truncated":false,"loaded":[]},"time":{"start":1773437523320,"end":1773437523323}}}}
