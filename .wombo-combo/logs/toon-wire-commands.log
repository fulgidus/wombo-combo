{\n          \"path\": \"src/lib/format-converter.ts\",\n          \"type\": \"file\",\n          \"language\": \"typescript\",\n          \"symbol_count\": 11\n        },\n        {\n          \"path\": \"src/lib/history.ts\",\n          \"type\": \"file\",\n          \"language\": \"typescript\",\n          \"symbol_count\": 10\n        },\n        {\n          \"path\": \"src/lib/launcher.ts\",\n          \"type\": \"file\",\n          \"language\": \"typescript\",\n          \"symbol_count\": 19\n        },\n        {\n          \"path\": \"src/lib/merger.ts\",\n          \"type\": \"file\",\n          \"language\": \"typescript\",\n          \"symbol_count\": 11\n        },\n        {\n          \"path\": \"src/lib/monitor.ts\",\n          \"type\": \"file\",\n          \"language\": \"typescript\",\n          \"symbol_count\": 25\n        },\n        {\n          \"path\": \"src/lib/multiplexer.ts\",\n          \"type\": \"file\",\n          \"language\": \"typescript\",\n          \"symbol_count\": 19\n        },\n        {\n          \"path\": \"src/lib/output.ts\",\n          \"type\": \"file\",\n          \"language\": \"typescript\",\n          \"symbol_count\": 8\n        },\n        {\n          \"path\": \"src/lib/portless.ts\",\n          \"type\": \"file\",\n          \"language\": \"typescript\",\n          \"symbol_count\": 9\n        },\n        {\n          \"path\": \"src/lib/preflight.ts\",\n          \"type\": \"file\",\n          \"language\": \"typescript\",\n          \"symbol_count\": 6\n        },\n        {\n          \"path\": \"src/lib/prompt.ts\",\n          \"type\": \"file\",\n          \"language\": \"typescript\",\n          \"symbol_count\": 3\n        },\n        {\n          \"path\": \"src/lib/schema.ts\",\n          \"type\": \"file\",\n          \"language\": \"typescript\",\n          \"symbol_count\": 7\n        },\n        {\n          \"path\": \"src/lib/state.ts\",\n          \"type\": \"file\",\n          \"language\": \"typescript\",\n          \"symbol_count\": 21\n        },\n        {\n          \"path\": \"src/lib/task-schema.ts\",\n          \"type\": \"file\",\n          \"language\": \"typescript\",\n          \"symbol_count\": 4\n        },\n        {\n          \"path\": \"src/lib/task-store.ts\",\n          \"type\": \"file\",\n          \"language\": \"typescript\",\n          \"symbol_count\": 32\n        },\n        {\n          \"path\": \"src/lib/tasks.ts\",\n          \"type\": \"file\",\n          \"language\": \"typescript\",\n          \"symbol_count\": 42\n        },\n        {\n          \"path\": \"src/lib/tdd-verifier.ts\",\n          \"type\": \"file\",\n          \"language\": \"typescript\",\n          \"symbol_count\": 6\n        },\n        {\n          \"path\": \"src/lib/templates.ts\",\n          \"type\": \"file\",\n          \"language\": \"typescript\",\n          \"symbol_count\": 8\n        },\n        {\n          \"path\": \"src/lib/test-detection.ts\",\n          \"type\": \"file\",\n          \"language\": \"typescript\",\n          \"symbol_count\": 15\n        },\n        {\n          \"path\": \"src/lib/test-runner.ts\",\n          \"type\": \"file\",\n          \"language\": \"typescript\",\n          \"symbol_count\": 6\n        },\n        {\n          \"path\": \"src/lib/toon-spec.ts\",\n          \"type\": \"file\",\n          \"language\": \"typescript\",\n          \"symbol_count\": 12\n        },\n        {\n          \"path\": \"src/lib/toon.ts\",\n          \"type\": \"file\",\n          \"language\": \"typescript\",\n          \"symbol_count\": 13\n        },\n        {\n          \"path\": \"src/lib/tui.ts\",\n          \"type\": \"file\",\n          \"language\": \"typescript\",\n          \"symbol_count\": 26\n        },\n        {\n          \"path\": \"src/lib/ui.ts\",\n          \"type\": \"file\",\n          \"language\": \"typescript\",\n          \"symbol_count\": 10\n        },\n        {\n          \"path\": \"src/