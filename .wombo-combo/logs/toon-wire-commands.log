{"type":"tool_use","timestamp":1773437433216,"sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","part":{"id":"prt_ce91bb238001iajMipnwV12pr9","sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","messageID":"msg_ce91ba42f001bwOtzgA7XCew6s","type":"tool","callID":"toolu_vrtx_01VJZDeo6bvEY1unvsxPe5CC","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/lib/output.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/lib/output.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * output.ts — Shared output helpers for agent-ready CLI.\n3:  *\n4:  * Provides a centralized way for commands to emit structured data that\n5:  * renders as human-readable text on TTY, as JSON when --output json\n6:  * is specified, or as compact TOON notation when --output toon is used.\n7:  *\n8:  * Usage in commands:\n9:  *   import { output, OutputFormat } from \"../lib/output.js\";\n10:  *\n11:  *   // At the end of a command:\n12:  *   output(format, data, textRenderer, toonRenderer);  // emits JSON, text, or TOON\n13:  *   outputError(format, message);                      // emits error in the right format\n14:  */\n15: \n16: import { renderGeneric } from \"./toon.js\";\n17: \n18: // ---------------------------------------------------------------------------\n19: // Types\n20: // ---------------------------------------------------------------------------\n21: \n22: export type OutputFormat = \"text\" | \"json\" | \"toon\";\n23: \n24: // ---------------------------------------------------------------------------\n25: // Helpers\n26: // ---------------------------------------------------------------------------\n27: \n28: /**\n29:  * Determine the output format. Priority:\n30:  *   1. Explicit --output flag value\n31:  *   2. WOMBO_OUTPUT env var (for agent pipelines)\n32:  *   3. Default to \"text\"\n33:  *\n34:  * Note: We intentionally do NOT auto-detect based on TTY. Many legitimate\n35:  * use cases (bun dev, piped to less/grep, CI) have non-TTY stdout but still\n36:  * want human output. Agents should explicitly pass --output json or set\n37:  * WOMBO_OUTPUT=json.\n38:  */\n39: export function resolveOutputFormat(explicit?: string): OutputFormat {\n40:   if (explicit === \"json\") return \"json\";\n41:   if (explicit === \"toon\") return \"toon\";\n42:   if (explicit === \"text\") return \"text\";\n43:   // Check env var for agent pipelines\n44:   const env = process.env.WOMBO_OUTPUT;\n45:   if (env === \"json\") return \"json\";\n46:   if (env === \"toon\") return \"toon\";\n47:   return \"text\";\n48: }\n49: \n50: /**\n51:  * Emit structured data.\n52:  *   - JSON mode: outputs a single JSON line to stdout\n53:  *   - TOON mode: calls toonRenderer if provided, otherwise uses generic TOON formatter\n54:  *   - Text mode: calls textRenderer\n55:  */\n56: export function output(\n57:   format: OutputFormat,\n58:   data: unknown,\n59:   textRenderer: () => void,\n60:   toonRenderer?: () => void\n61: ): void {\n62:   if (format === \"json\") {\n63:     console.log(JSON.stringify(data));\n64:   } else if (format === \"toon\") {\n65:     if (toonRenderer) {\n66:       toonRenderer();\n67:     } else {\n68:       // Generic fallback: convert structured data to TOON\n69:       console.log(renderGeneric(data));\n70:     }\n71:   } else {\n72:     textRenderer();\n73:   }\n74: }\n75: \n76: /**\n77:  * Emit an error. In JSON mode, outputs {\"error\": message} to stderr.\n78:  * In TOON mode, outputs \"#ERROR message\" to stderr.\n79:  * In text mode, outputs the message to stderr normally.\n80:  */\n81: export function outputError(format: OutputFormat, message: string, exitCode: number = 1): never {\n82:   if (format === \"json\") {\n83:     console.error(JSON.stringify({ error: message }));\n84:   } else if (format === \"toon\") {\n85:     console.error(`#ERROR ${message}`);\n86:   } else {\n87:     console.error(message);\n88:   }\n89:   process.exit(exitCode);\n90: }\n91: \n92: /**\n93:  * Emit a success/info message. In JSON mode, outputs {\"message\": msg, ...extra}.\n94:  * In TOON mode, outputs \"#MSG message\" to stdout.\n95:  * In text mode, outputs the message to stdout normally.\n96:  */\n97: export function outputMessage(\n98:   format: OutputFormat,\n99:   message: string,\n100:   extra?: Record<string, unknown>\n101: ): void {\n102:   if (format === \"json\") {\n103:     console.log(JSON.stringify({ message, ...extra }));\n104:   } else if (format === \"toon\") {\n105:     console.log(`#MSG ${message}`);\n106:   } else {\n107:     console.log(message);\n108:   }\n109: }\n110: \n111: // ---------------------------------------------------------------------------\n112: // Field filtering for compact output (--fields)\n113: // ---------------------------------------------------------------------------\n114: \n115: /**\n116:  * Filter an object to only include the specified fields.\n117:  * If fields is undefined/empty, returns the object unchanged.\n118:  */\n119: export function filterFields<T extends Record<string, unknown>>(\n120:   obj: T,\n121:   fields?: string[]\n122: ): Partial<T> {\n123:   if (!fields || fields.length === 0) return obj;\n124:   const result: Partial<T> = {};\n125:   for (const field of fields) {\n126:     if (field in obj) {\n127:       (result as any)[field] = (obj as any)[field];\n128:     }\n129:   }\n130:   return result;\n131: }\n132: \n133: /**\n134:  * Filter an array of objects to only include specified fields per object.\n135:  * If fields is undefined/empty, returns the array unchanged.\n136:  */\n137: export function filterFieldsArray<T extends Record<string, unknown>>(\n138:   arr: T[],\n139:   fields?: string[]\n140: ): Partial<T>[] {\n141:   if (!fields || fields.length === 0) return arr;\n142:   return arr.map((obj) => filterFields(obj, fields));\n143: }\n144: \n145: /**\n146:  * Render a compact text table from an array of objects with selected fields.\n147:  * Used for text-mode --fields output.\n148:  */\n149: export function renderCompactTable(\n150:   items: Record<string, unknown>[],\n151:   fields: string[]\n152: ): void {\n153:   if (items.length === 0) return;\n154: \n155:   // Calculate column widths\n156:   const widths: Record<string, number> = {};\n157:   for (const field of fields) {\n158:     widths[field] = field.length;\n159:     for (const item of items) {\n160:       const val = String(item[field] ?? \"\");\n161:       widths[field] = Math.max(widths[field], val.length);\n162:     }\n163:   }\n164: \n165:   // Header\n166:   const header = fields.map((f) => f.padEnd(widths[f])).join(\"  \");\n167:   console.log(header);\n168:   console.log(fields.map((f) => \"─\".repeat(widths[f])).join(\"  \"));\n169: \n170:   // Rows\n171:   for (const item of items) {\n172:     const row = fields.map((f) => String(item[f] ?? \"\").padEnd(widths[f])).join(\"  \");\n173:     console.log(row);\n174:   }\n175: }\n\n(End of file - total 175 lines)\n</content>","title":"src/lib/output.ts","metadata":{"preview":"/**\n * output.ts — Shared output helpers for agent-ready CLI.\n *\n * Provides a centralized way for commands to emit structured data that\n * renders as human-readable text on TTY, as JSON when --output json\n * is specified, or as compact TOON notation when --output toon is used.\n *\n * Usage in commands:\n *   import { output, OutputFormat } from \"../lib/output.js\";\n *\n *   // At the end of a command:\n *   output(format, data, textRenderer, toonRenderer);  // emits JSON, text, or TOON\n *   outputError(format, message);                      // emits error in the right format\n */\n\nimport { renderGeneric } from \"./toon.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------","truncated":false,"loaded":[]},"time":{"start":1773437433213,"end":1773437433216}}}}
{"type":"tool_use","timestamp":1773437433636,"sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","part":{"id":"prt_ce91bb57e001eDnA8X0lBW6lpl","sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","messageID":"msg_ce91ba42f001bwOtzgA7XCew6s","type":"tool","callID":"toolu_vrtx_019MZZ83ybMJfyKRnCPiS1Jx","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/lib/toon.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/lib/toon.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * toon.ts -- Token-Optimized Output Notation (TOON) formatter module.\n3:  *\n4:  * Converts structured command results into compact, pipe-delimited TOON\n5:  * notation. Reduces token count by 60%+ vs JSON for equivalent data.\n6:  *\n7:  * Format:\n8:  *   - Delimiter: pipe (|)\n9:  *   - First line: #FIELDS header listing field names\n10:  *   - One record per line, positional fields\n11:  *   - Status codes: BL/PL/IP/BK/IR/DN/CN\n12:  *   - Priority codes: C/H/M/L/W\n13:  *   - Difficulty codes: T/E/M/H/V\n14:  *   - Duration: compact (30m, 2h, 1d4h)\n15:  *   - Boolean: 1/0\n16:  *   - Null/missing: empty field (||)\n17:  *   - Arrays: comma-separated within a field\n18:  */\n19: \n20: import type { Task, TaskStatus, Priority, Difficulty } from \"./tasks.js\";\n21: import type { AgentState, WaveState } from \"./state.js\";\n22: import type { AgentHistoryRecord, WaveHistoryRecord } from \"./history.js\";\n23: import {\n24:   TOON_STATUS_ENCODE,\n25:   TOON_PRIORITY_ENCODE,\n26:   TOON_DIFFICULTY_ENCODE,\n27:   encodeDuration,\n28:   encodeBool,\n29:   encodeNullable,\n30:   encodeArray,\n31: } from \"./toon-spec.js\";\n32: \n33: // ---------------------------------------------------------------------------\n34: // Generic Helpers\n35: // ---------------------------------------------------------------------------\n36: \n37: /**\n38:  * Join fields with pipe delimiter.\n39:  */\n40: function row(...fields: (string | number | null | undefined)[]): string {\n41:   return fields.map((f) => (f === null || f === undefined ? \"\" : String(f))).join(\"|\");\n42: }\n43: \n44: /**\n45:  * Emit a #FIELDS header line.\n46:  */\n47: function fieldsHeader(names: string[]): string {\n48:   return `#FIELDS ${names.join(\"|\")}`;\n49: }\n50: \n51: /**\n52:  * Encode a status code, falling back to raw value if unknown.\n53:  */\n54: function encodeStatus(status: TaskStatus | string): string {\n55:   return (TOON_STATUS_ENCODE as Record<string, string>)[status] ?? status;\n56: }\n57: \n58: /**\n59:  * Encode a priority code, falling back to raw value if unknown.\n60:  */\n61: function encodePriority(priority: Priority | string): string {\n62:   return (TOON_PRIORITY_ENCODE as Record<string, string>)[priority] ?? priority;\n63: }\n64: \n65: /**\n66:  * Encode a difficulty code, falling back to raw value if unknown.\n67:  */\n68: function encodeDifficulty(difficulty: Difficulty | string): string {\n69:   return (TOON_DIFFICULTY_ENCODE as Record<string, string>)[difficulty] ?? difficulty;\n70: }\n71: \n72: // ---------------------------------------------------------------------------\n73: // Tasks List Renderer\n74: // ---------------------------------------------------------------------------\n75: \n76: /**\n77:  * Render a task list in TOON format.\n78:  *\n79:  * Fields: id|status|priority|difficulty|effort|completion|deps_met|depends_on|title\n80:  *\n81:  * Example:\n82:  *   #FIELDS id|status|priority|difficulty|effort|completion|deps_met|depends_on|title\n83:  *   auth-flow|BL|H|E|2h|0|1||Add authentication flow\n84:  *   search-api|IP|C|M|4h|35|0|auth-flow|Implement search API\n85:  */\n86: export function renderTasksList(\n87:   tasks: Array<{\n88:     id: string;\n89:     title: string;\n90:     status: string;\n91:     priority: string;\n92:     difficulty: string;\n93:     effort: string;\n94:     completion: number;\n95:     depends_on: string[];\n96:   }>,\n97:   depsMetMap?: Map<string, boolean>\n98: ): string {\n99:   const header = fieldsHeader([\n100:     \"id\", \"status\", \"priority\", \"difficulty\", \"effort\",\n101:     \"completion\", \"deps_met\", \"depends_on\", \"title\",\n102:   ]);\n103: \n104:   const lines = [header];\n105: \n106:   for (const t of tasks) {\n107:     const depsMet = depsMetMap?.get(t.id) ?? true;\n108:     lines.push(row(\n109:       t.id,\n110:       encodeStatus(t.status),\n111:       encodePriority(t.priority),\n112:       encodeDifficulty(t.difficulty),\n113:       encodeDuration(t.effort),\n114:       t.completion,\n115:       encodeBool(depsMet),\n116:       encodeArray(t.depends_on),\n117:       t.title,\n118:     ));\n119:   }\n120: \n121:   return lines.join(\"\\n\");\n122: }\n123: \n124: // ---------------------------------------------------------------------------\n125: // Tasks Show Renderer\n126: // ---------------------------------------------------------------------------\n127: \n128: /**\n129:  * Render a single task detail in TOON key:value format.\n130:  *\n131:  * Uses abbreviated keys, one per line.\n132:  * Example:\n133:  *   id:auth-flow\n134:  *   st:BL\n135:  *   pr:H\n136:  *   df:E\n137:  *   ef:2h\n138:  *   cp:35\n139:  *   dm:1\n140:  *   dp:dep-a,dep-b\n141:  *   sa:2026-03-10T08:00:00Z\n142:  *   ea:\n143:  *   ti:Add authentication flow\n144:  *   ds:Description text here\n145:  *   cn:Must use TypeScript\n146:  *   fb:No external deps\n147:  *   rf:https://example.com\n148:  *   nt:Some note\n149:  *   sc:3\n150:  */\n151: export function renderTaskShow(\n152:   task: Task,\n153:   depsMet: boolean\n154: ): string {\n155:   const lines: string[] = [];\n156: \n157:   lines.push(`id:${task.id}`);\n158:   lines.push(`st:${encodeStatus(task.status)}`);\n159:   lines.push(`pr:${encodePriority(task.priority)}`);\n160:   lines.push(`df:${encodeDifficulty(task.difficulty)}`);\n161:   lines.push(`ef:${encodeDuration(task.effort)}`);\n162:   lines.push(`cp:${task.completion}`);\n163:   lines.push(`dm:${encodeBool(depsMet)}`);\n164:   lines.push(`dp:${encodeArray(task.depends_on)}`);\n165:   lines.push(`sa:${encodeNullable(task.started_at)}`);\n166:   lines.push(`ea:${encodeNullable(task.ended_at)}`);\n167:   lines.push(`ti:${task.title}`);\n168: \n169:   if (task.description) {\n170:     // Collapse multi-line descriptions to single line with \\n escape\n171:     lines.push(`ds:${task.description.replace(/\\n/g, \"\\\\n\")}`);\n172:   }\n173: \n174:   if (task.constraints.length > 0) {\n175:     lines.push(`cn:${encodeArray(task.constraints)}`);\n176:   }\n177: \n178:   if (task.forbidden.length > 0) {\n179:     lines.push(`fb:${encodeArray(task.forbidden)}`);\n180:   }\n181: \n182:   if (task.references.length > 0) {\n183:     lines.push(`rf:${encodeArray(task.references)}`);\n184:   }\n185: \n186:   if (task.notes.length > 0) {\n187:     lines.push(`nt:${encodeArray(task.notes)}`);\n188:   }\n189: \n190:   if (task.subtasks.length > 0) {\n191:     lines.push(`sc:${task.subtasks.length}`);\n192:     // Render subtasks as compact lines\n193:     for (const st of task.subtasks) {\n194:       lines.push(`  ${st.id}|${encodeStatus(st.status)}|${encodePriority(st.priority)}|${encodeDifficulty(st.difficulty)}|${encodeDuration(st.effort)}|${st.completion}|${st.title}`);\n195:     }\n196:   }\n197: \n198:   return lines.join(\"\\n\");\n199: }\n200: \n201: // ---------------------------------------------------------------------------\n202: // Status Renderer\n203: // ---------------------------------------------------------------------------\n204: \n205: /**\n206:  * Render wave status in TOON format.\n207:  *\n208:  * Fields: feature_id|agent_status|exit_code|retries|started_at\n209:  *\n210:  * Also emits a summary header line:\n211:  *   #WAVE wave_id|agent_count|active|completed|failed\n212:  */\n213: export function renderStatus(state: WaveState): string {\n214:   const lines: string[] = [];\n215: \n216:   // Summary line\n217:   const counts: Record<string, number> = {};\n218:   for (const a of state.agents) {\n219:     counts[a.status] = (counts[a.status] ?? 0) + 1;\n220:   }\n221: \n222:   const active = (counts[\"running\"] ?? 0) + (counts[\"installing\"] ?? 0) + (counts[\"resolving_conflict\"] ?? 0);\n223:   const completed = (counts[\"completed\"] ?? 0) + (counts[\"verified\"] ?? 0) + (counts[\"merged\"] ?? 0);\n224:   const failed = counts[\"failed\"] ?? 0;\n225: \n226:   lines.push(`#WAVE ${row(\n227:     state.wave_id,\n228:     state.agents.length,\n229:     active,\n230:     completed,\n231:     failed,\n232:   )}`);\n233: \n234:   // Agent detail lines\n235:   lines.push(fieldsHeader([\n236:     \"feature_id\", \"agent_status\", \"exit_code\", \"retries\", \"started_at\",\n237:   ]));\n238: \n239:   for (const a of state.agents) {\n240:     // Determine exit code: build_passed === true -> 0, false -> 1, null -> empty\n241:     const exitCode = a.build_passed === true ? \"0\" : a.build_passed === false ? \"1\" : \"\";\n242:     lines.push(row(\n243:       a.feature_id,\n244:       a.status,\n245:       exitCode,\n246:       a.retries,\n247:       encodeNullable(a.started_at),\n248:     ));\n249:   }\n250: \n251:   return lines.join(\"\\n\");\n252: }\n253: \n254: // ---------------------------------------------------------------------------\n255: // Verify Renderer\n256: // ---------------------------------------------------------------------------\n257: \n258: /**\n259:  * Render verification results in TOON format.\n260:  *\n261:  * Fields: feature_id|pass_fail|duration\n262:  */\n263: export function renderVerify(\n264:   results: Array<{ feature_id: string; passed: boolean; durationMs: number }>\n265: ): string {\n266:   const lines: string[] = [];\n267: \n268:   lines.push(fieldsHeader([\"feature_id\", \"pass_fail\", \"duration\"]));\n269: \n270:   for (const r of results) {\n271:     const durationSec = Math.round(r.durationMs / 1000);\n272:     const duration = durationSec >= 60\n273:       ? `${Math.floor(durationSec / 60)}m${durationSec % 60}s`\n274:       : `${durationSec}s`;\n275:     lines.push(row(\n276:       r.feature_id,\n277:       r.passed ? \"pass\" : \"fail\",\n278:       duration,\n279:     ));\n280:   }\n281: \n282:   return lines.join(\"\\n\");\n283: }\n284: \n285: // ---------------------------------------------------------------------------\n286: // History Renderer\n287: // ---------------------------------------------------------------------------\n288: \n289: /**\n290:  * Render history list in TOON format.\n291:  *\n292:  * Fields: wave_id|started_at|ended_at|total_agents|succeeded|failed\n293:  */\n294: export function renderHistoryList(records: WaveHistoryRecord[]): string {\n295:   const lines: string[] = [];\n296: \n297:   lines.push(fieldsHeader([\n298:     \"wave_id\", \"started_at\", \"ended_at\", \"total_agents\", \"succeeded\", \"failed\",\n299:   ]));\n300: \n301:   for (const rec of records) {\n302:     lines.push(row(\n303:       rec.wave_id,\n304:       rec.started_at,\n305:       rec.exported_at,\n306:       rec.summary.total,\n307:       rec.summary.succeeded,\n308:       rec.summary.failed,\n309:     ));\n310:   }\n311: \n312:   return lines.join(\"\\n\");\n313: }\n314: \n315: /**\n316:  * Render a single history record detail in TOON format.\n317:  *\n318:  * Emits a summary header then per-agent lines.\n319:  */\n320: export function renderHistoryDetail(rec: WaveHistoryRecord): string {\n321:   const lines: string[] = [];\n322: \n323:   // Summary\n324:   lines.push(`#WAVE ${row(\n325:     rec.wave_id,\n326:     rec.summary.total,\n327:     rec.summary.succeeded,\n328:     rec.summary.failed,\n329:     rec.summary.merged,\n330:   )}`);\n331: \n332:   // Agent details\n333:   lines.push(fieldsHeader([\n334:     \"feature_id\", \"status\", \"retries\", \"duration_ms\", \"build_passed\", \"error\",\n335:   ]));\n336: \n337:   for (const a of rec.agents) {\n338:     lines.push(row(\n339:       a.feature_id,\n340:       a.status,\n341:       a.retries,\n342:       a.duration_ms ?? \"\",\n343:       a.build_passed === null ? \"\" : encodeBool(a.build_passed),\n344:       encodeNullable(a.error?.split(\"\\n\")[0]?.slice(0, 60) ?? null),\n345:     ));\n346:   }\n347: \n348:   return lines.join(\"\\n\");\n349: }\n350: \n351: // ---------------------------------------------------------------------------\n352: // Tasks Check Renderer\n353: // ---------------------------------------------------------------------------\n354: \n355: /**\n356:  * Render task check results in TOON format.\n357:  *\n358:  * Fields: level|message\n359:  */\n360: export function renderTasksCheck(result: {\n361:   ok: boolean;\n362:   issues: Array<{ level: string; message: string }>;\n363:   items_checked: number;\n364: }): string {\n365:   const lines: string[] = [];\n366: \n367:   lines.push(`#CHECK ${row(\n368:     encodeBool(result.ok),\n369:     result.items_checked,\n370:     result.issues.length,\n371:   )}`);\n372: \n373:   if (result.issues.length > 0) {\n374:     lines.push(fieldsHeader([\"level\", \"message\"]));\n375:     for (const issue of result.issues) {\n376:       lines.push(row(\n377:         issue.level === \"error\" ? \"E\" : \"W\",\n378:         issue.message,\n379:       ));\n380:     }\n381:   }\n382: \n383:   return lines.join(\"\\n\");\n384: }\n385: \n386: // ---------------------------------------------------------------------------\n387: // Generic Fallback Renderer\n388: // ---------------------------------------------------------------------------\n389: \n390: /**\n391:  * Generic TOON renderer for data that doesn't have a specific formatter.\n392:  * Renders objects as key:value pairs, arrays as pipe-delimited rows.\n393:  */\n394: export function renderGeneric(data: unknown): string {\n395:   if (data === null || data === undefined) return \"\";\n396: \n397:   if (Array.isArray(data)) {\n398:     if (data.length === 0) return \"\";\n399:     // If array of objects, use first item's keys as fields\n400:     if (typeof data[0] === \"object\" && data[0] !== null) {\n401:       const keys = Object.keys(data[0] as Record<string, unknown>);\n402:       const lines = [fieldsHeader(keys)];\n403:       for (const item of data) {\n404:         const obj = item as Record<string, unknown>;\n405:         lines.push(row(...keys.map((k) => {\n406:           const v = obj[k];\n407:           if (Array.isArray(v)) return encodeArray(v.map(String));\n408:           if (typeof v === \"boolean\") return encodeBool(v);\n409:           if (v === null || v === undefined) return \"\";\n410:           return String(v);\n411:         })));\n412:       }\n413:       return lines.join(\"\\n\");\n414:     }\n415:     // Array of primitives\n416:     return data.map(String).join(\"\\n\");\n417:   }\n418: \n419:   if (typeof data === \"object\") {\n420:     const obj = data as Record<string, unknown>;\n421:     const lines: string[] = [];\n422:     for (const [key, val] of Object.entries(obj)) {\n423:       if (val === null || val === undefined) {\n424:         lines.push(`${key}:`);\n425:       } else if (Array.isArray(val)) {\n426:         lines.push(`${key}:${encodeArray(val.map(String))}`);\n427:       } else if (typeof val === \"boolean\") {\n428:         lines.push(`${key}:${encodeBool(val)}`);\n429:       } else if (typeof val === \"object\") {\n430:         // Nested object — flatten to key.subkey:value\n431:         for (const [sk, sv] of Object.entries(val as Record<string, unknown>)) {\n432:           lines.push(`${key}.${sk}:${sv === null || sv === undefined ? \"\" : String(sv)}`);\n433:         }\n434:       } else {\n435:         lines.push(`${key}:${String(val)}`);\n436:       }\n437:     }\n438:     return lines.join(\"\\n\");\n439:   }\n440: \n441:   return String(data);\n442: }\n\n(End of file - total 442 lines)\n</content>","title":"src/lib/toon.ts","metadata":{"preview":"/**\n * toon.ts -- Token-Optimized Output Notation (TOON) formatter module.\n *\n * Converts structured command results into compact, pipe-delimited TOON\n * notation. Reduces token count by 60%+ vs JSON for equivalent data.\n *\n * Format:\n *   - Delimiter: pipe (|)\n *   - First line: #FIELDS header listing field names\n *   - One record per line, positional fields\n *   - Status codes: BL/PL/IP/BK/IR/DN/CN\n *   - Priority codes: C/H/M/L/W\n *   - Difficulty codes: T/E/M/H/V\n *   - Duration: compact (30m, 2h, 1d4h)\n *   - Boolean: 1/0\n *   - Null/missing: empty field (||)\n *   - Arrays: comma-separated within a field\n */\n\nimport type { Task, TaskStatus, Priority, Difficulty } from \"./tasks.js\";","truncated":false,"loaded":[]},"time":{"start":1773437433617,"end":1773437433635}}}}
{"type":"tool_use","timestamp":1773437434336,"sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","part":{"id":"prt_ce91bb77e0018olVzMcISfMEm1","sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","messageID":"msg_ce91ba42f001bwOtzgA7XCew6s","type":"tool","callID":"toolu_vrtx_01RpKg8a7K8jwBN6UmFC27hN","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/lib/toon-spec.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/lib/toon-spec.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * toon-spec.ts — Token-Optimized Output Notation (TOON) format specification.\n3:  *\n4:  * TOON is a compact, pipe-delimited encoding designed for AI agent consumption.\n5:  * It minimizes token usage while remaining fully parseable. Agents call\n6:  * `woco describe --output toon` once per session to learn the format, then\n7:  * parse all subsequent TOON output without further context.\n8:  *\n9:  * Format rules:\n10:  *   - Delimiter: pipe character (|)\n11:  *   - Fields are positional (fixed order per command, no field names in output)\n12:  *   - Header line: optional #FIELDS comment listing field order\n13:  *   - Status codes: BL=backlog, PL=planned, IP=in_progress, BK=blocked, IR=in_review, DN=done, CN=cancelled\n14:  *   - Priority codes: C=critical, H=high, M=medium, L=low, W=wishlist\n15:  *   - Difficulty codes: T=trivial, E=easy, M=medium, H=hard, V=very_hard\n16:  *   - Duration: compact format (30m, 2h, 1d4h) instead of ISO 8601\n17:  *   - Boolean: 1/0 instead of true/false\n18:  *   - Null/missing: empty field (||)\n19:  *   - Arrays: comma-separated within a single field (no pipes)\n20:  */\n21: \n22: import type { TaskStatus, Priority, Difficulty } from \"./tasks.js\";\n23: \n24: // ---------------------------------------------------------------------------\n25: // Status Code Mappings\n26: // ---------------------------------------------------------------------------\n27: \n28: export const TOON_STATUS_ENCODE: Readonly<Record<TaskStatus, string>> = {\n29:   backlog: \"BL\",\n30:   planned: \"PL\",\n31:   in_progress: \"IP\",\n32:   blocked: \"BK\",\n33:   in_review: \"IR\",\n34:   done: \"DN\",\n35:   cancelled: \"CN\",\n36: };\n37: \n38: export const TOON_STATUS_DECODE: Readonly<Record<string, TaskStatus>> = {\n39:   BL: \"backlog\",\n40:   PL: \"planned\",\n41:   IP: \"in_progress\",\n42:   BK: \"blocked\",\n43:   IR: \"in_review\",\n44:   DN: \"done\",\n45:   CN: \"cancelled\",\n46: };\n47: \n48: // ---------------------------------------------------------------------------\n49: // Priority Code Mappings\n50: // ---------------------------------------------------------------------------\n51: \n52: export const TOON_PRIORITY_ENCODE: Readonly<Record<Priority, string>> = {\n53:   critical: \"C\",\n54:   high: \"H\",\n55:   medium: \"M\",\n56:   low: \"L\",\n57:   wishlist: \"W\",\n58: };\n59: \n60: export const TOON_PRIORITY_DECODE: Readonly<Record<string, Priority>> = {\n61:   C: \"critical\",\n62:   H: \"high\",\n63:   M: \"medium\",\n64:   L: \"low\",\n65:   W: \"wishlist\",\n66: };\n67: \n68: // ---------------------------------------------------------------------------\n69: // Difficulty Code Mappings\n70: // ---------------------------------------------------------------------------\n71: \n72: export const TOON_DIFFICULTY_ENCODE: Readonly<Record<Difficulty, string>> = {\n73:   trivial: \"T\",\n74:   easy: \"E\",\n75:   medium: \"M\",\n76:   hard: \"H\",\n77:   very_hard: \"V\",\n78: };\n79: \n80: export const TOON_DIFFICULTY_DECODE: Readonly<Record<string, Difficulty>> = {\n81:   T: \"trivial\",\n82:   E: \"easy\",\n83:   M: \"medium\",\n84:   H: \"hard\",\n85:   V: \"very_hard\",\n86: };\n87: \n88: // ---------------------------------------------------------------------------\n89: // Duration Encoding/Decoding\n90: // ---------------------------------------------------------------------------\n91: \n92: /**\n93:  * Convert an ISO 8601 duration to compact TOON format.\n94:  *\n95:  * Examples:\n96:  *   PT30M     -> 30m\n97:  *   PT2H      -> 2h\n98:  *   PT1H30M   -> 1h30m\n99:  *   P1D       -> 1d\n100:  *   P1DT4H    -> 1d4h\n101:  *   P2DT4H30M -> 2d4h30m\n102:  */\n103: export function encodeDuration(iso: string): string {\n104:   if (!iso) return \"\";\n105: \n106:   const match = iso.match(\n107:     /^P(?:(\\d+)Y)?(?:(\\d+)M)?(?:(\\d+)D)?(?:T(?:(\\d+)H)?(?:(\\d+)M)?(?:(\\d+)S)?)?$/\n108:   );\n109:   if (!match) return iso; // return raw if unparseable\n110: \n111:   const years = parseInt(match[1] || \"0\", 10);\n112:   const months = parseInt(match[2] || \"0\", 10);\n113:   const days = parseInt(match[3] || \"0\", 10) + years * 365 + months * 30;\n114:   const hours = parseInt(match[4] || \"0\", 10);\n115:   const minutes = parseInt(match[5] || \"0\", 10);\n116:   const seconds = parseInt(match[6] || \"0\", 10);\n117: \n118:   const parts: string[] = [];\n119:   if (days > 0) parts.push(`${days}d`);\n120:   if (hours > 0) parts.push(`${hours}h`);\n121:   if (minutes > 0) parts.push(`${minutes}m`);\n122:   if (seconds > 0) parts.push(`${seconds}s`);\n123: \n124:   return parts.length > 0 ? parts.join(\"\") : \"0m\";\n125: }\n126: \n127: /**\n128:  * Convert compact TOON duration back to ISO 8601.\n129:  *\n130:  * Examples:\n131:  *   30m    -> PT30M\n132:  *   2h     -> PT2H\n133:  *   1h30m  -> PT1H30M\n134:  *   1d     -> P1D\n135:  *   1d4h   -> P1DT4H\n136:  */\n137: export function decodeDuration(compact: string): string {\n138:   if (!compact) return \"\";\n139: \n140:   const dMatch = compact.match(/(\\d+)d/);\n141:   const hMatch = compact.match(/(\\d+)h/);\n142:   const mMatch = compact.match(/(\\d+)m/);\n143:   const sMatch = compact.match(/(\\d+)s/);\n144: \n145:   const days = dMatch ? parseInt(dMatch[1], 10) : 0;\n146:   const hours = hMatch ? parseInt(hMatch[1], 10) : 0;\n147:   const minutes = mMatch ? parseInt(mMatch[1], 10) : 0;\n148:   const seconds = sMatch ? parseInt(sMatch[1], 10) : 0;\n149: \n150:   let result = \"P\";\n151:   if (days > 0) result += `${days}D`;\n152: \n153:   const hasTime = hours > 0 || minutes > 0 || seconds > 0;\n154:   if (hasTime) {\n155:     result += \"T\";\n156:     if (hours > 0) result += `${hours}H`;\n157:     if (minutes > 0) result += `${minutes}M`;\n158:     if (seconds > 0) result += `${seconds}S`;\n159:   }\n160: \n161:   // If nothing was added, it's zero duration\n162:   if (result === \"P\") return \"PT0S\";\n163: \n164:   return result;\n165: }\n166: \n167: // ---------------------------------------------------------------------------\n168: // Boolean Encoding\n169: // ---------------------------------------------------------------------------\n170: \n171: export function encodeBool(value: boolean): string {\n172:   return value ? \"1\" : \"0\";\n173: }\n174: \n175: export function decodeBool(value: string): boolean {\n176:   return value === \"1\";\n177: }\n178: \n179: // ---------------------------------------------------------------------------\n180: // Null/Missing Encoding\n181: // ---------------------------------------------------------------------------\n182: \n183: export function encodeNullable(value: string | null | undefined): string {\n184:   return value ?? \"\";\n185: }\n186: \n187: // ---------------------------------------------------------------------------\n188: // Array Encoding (comma-separated within a single pipe-delimited field)\n189: // ---------------------------------------------------------------------------\n190: \n191: export function encodeArray(arr: string[] | null | undefined): string {\n192:   if (!arr || arr.length === 0) return \"\";\n193:   return arr.join(\",\");\n194: }\n195: \n196: export function decodeArray(value: string): string[] {\n197:   if (!value) return [];\n198:   return value.split(\",\").map((s) => s.trim()).filter(Boolean);\n199: }\n200: \n201: // ---------------------------------------------------------------------------\n202: // Field Definitions per Command\n203: // ---------------------------------------------------------------------------\n204: \n205: /**\n206:  * Describes a single field in a TOON record.\n207:  */\n208: export interface ToonFieldDef {\n209:   /** Field name (for the #FIELDS header) */\n210:   name: string;\n211:   /** Human-readable description */\n212:   description: string;\n213:   /** Data type (for documentation) */\n214:   type: \"string\" | \"status\" | \"priority\" | \"difficulty\" | \"duration\" | \"bool\" | \"number\" | \"array\" | \"datetime\";\n215: }\n216: \n217: /**\n218:  * Describes the TOON output format for a specific command.\n219:  */\n220: export interface ToonCommandSpec {\n221:   /** Command name (e.g. \"tasks list\", \"tasks show\") */\n222:   command: string;\n223:   /** Fields in positional order */\n224:   fields: ToonFieldDef[];\n225:   /** Optional example line */\n226:   example?: string;\n227: }\n228: \n229: // ---------------------------------------------------------------------------\n230: // Per-command field specs\n231: // ---------------------------------------------------------------------------\n232: \n233: export const TOON_COMMAND_SPECS: readonly ToonCommandSpec[] = [\n234:   {\n235:     command: \"tasks list\",\n236:     fields: [\n237:       { name: \"id\", description: \"Task identifier\", type: \"string\" },\n238:       { name: \"status\", description: \"Task status (BL/PL/IP/BK/IR/DN/CN)\", type: \"status\" },\n239:       { name: \"priority\", description: \"Priority level (C/H/M/L/W)\", type: \"priority\" },\n240:       { name: \"difficulty\", description: \"Difficulty level (T/E/M/H/V)\", type: \"difficulty\" },\n241:       { name: \"effort\", description: \"Effort estimate (compact: 30m, 2h, 1d4h)\", type: \"duration\" },\n242:       { name: \"completion\", description: \"Completion percentage (0-100)\", type: \"number\" },\n243:       { name: \"deps_met\", description: \"All dependencies satisfied (1/0)\", type: \"bool\" },\n244:       { name: \"depends_on\", description: \"Dependency IDs (comma-separated)\", type: \"array\" },\n245:       { name: \"title\", description: \"Task title\", type: \"string\" },\n246:     ],\n247:     example: \"#FIELDS id|status|priority|difficulty|effort|completion|deps_met|depends_on|title\\nauth-flow|BL|H|E|2h|0|1||Add authentication flow\\nsearch-api|IP|C|M|4h|35|0|auth-flow|Implement search API\",\n248:   },\n249:   {\n250:     command: \"tasks show\",\n251:     fields: [\n252:       { name: \"id\", description: \"Task identifier\", type: \"string\" },\n253:       { name: \"status\", description: \"Task status (BL/PL/IP/BK/IR/DN/CN)\", type: \"status\" },\n254:       { name: \"priority\", description: \"Priority level (C/H/M/L/W)\", type: \"priority\" },\n255:       { name: \"difficulty\", description: \"Difficulty level (T/E/M/H/V)\", type: \"difficulty\" },\n256:       { name: \"effort\", description: \"Effort estimate (compact)\", type: \"duration\" },\n257:       { name: \"completion\", description: \"Completion percentage (0-100)\", type: \"number\" },\n258:       { name: \"deps_met\", description: \"All dependencies satisfied (1/0)\", type: \"bool\" },\n259:       { name: \"depends_on\", description: \"Dependency IDs (comma-separated)\", type: \"array\" },\n260:       { name: \"started_at\", description: \"Start timestamp (ISO 8601 or empty)\", type: \"datetime\" },\n261:       { name: \"ended_at\", description: \"End timestamp (ISO 8601 or empty)\", type: \"datetime\" },\n262:       { name: \"title\", description: \"Task title\", type: \"string\" },\n263:     ],\n264:     example: \"#FIELDS id|status|priority|difficulty|effort|completion|deps_met|depends_on|started_at|ended_at|title\\nauth-flow|IP|H|E|2h|35|1||2026-03-10T08:00:00Z||Add authentication flow\",\n265:   },\n266:   {\n267:     command: \"status\",\n268:     fields: [\n269:       { name: \"feature_id\", description: \"Feature/task identifier\", type: \"string\" },\n270:       { name: \"agent_status\", description: \"Agent status (queued/running/done/failed/verified/merged)\", type: \"string\" },\n271:       { name: \"exit_code\", description: \"Process exit code (empty if still running)\", type: \"number\" },\n272:       { name: \"retries\", description: \"Number of retries so far\", type: \"number\" },\n273:       { name: \"started_at\", description: \"Agent start timestamp\", type: \"datetime\" },\n274:     ],\n275:     example: \"#FIELDS feature_id|agent_status|exit_code|retries|started_at\\nauth-flow|running||0|2026-03-10T08:00:00Z\\nsearch-api|done|0|1|2026-03-10T08:05:00Z\",\n276:   },\n277:   {\n278:     command: \"history\",\n279:     fields: [\n280:       { name: \"wave_id\", description: \"Wave identifier\", type: \"string\" },\n281:       { name: \"started_at\", description: \"Wave start timestamp\", type: \"datetime\" },\n282:       { name: \"ended_at\", description: \"Wave end timestamp\", type: \"datetime\" },\n283:       { name: \"total_agents\", description: \"Number of agents in the wave\", type: \"number\" },\n284:       { name: \"succeeded\", description: \"Number of agents that succeeded\", type: \"number\" },\n285:       { name: \"failed\", description: \"Number of agents that failed\", type: \"number\" },\n286:     ],\n287:     example: \"#FIELDS wave_id|started_at|ended_at|total_agents|succeeded|failed\\nwave-2026-03-10-001|2026-03-10T08:00:00Z|2026-03-10T09:30:00Z|5|4|1\",\n288:   },\n289: ] as const;\n290: \n291: // ---------------------------------------------------------------------------\n292: // Full TOON Specification (emitted by `woco describe --output toon`)\n293: // ---------------------------------------------------------------------------\n294: \n295: export interface ToonSpec {\n296:   format: \"TOON\";\n297:   version: string;\n298:   description: string;\n299:   delimiter: string;\n300:   rules: {\n301:     status_codes: string;\n302:     priority_codes: string;\n303:     difficulty_codes: string;\n304:     duration: string;\n305:     boolean: string;\n306:     null_missing: string;\n307:     arrays: string;\n308:     field_order: string;\n309:     header_line: string;\n310:   };\n311:   commands: ToonCommandSpec[];\n312: }\n313: \n314: /**\n315:  * Build the complete TOON specification object.\n316:  * This is the payload emitted by `woco describe --output toon`.\n317:  */\n318: export function buildToonSpec(version: string): ToonSpec {\n319:   return {\n320:     format: \"TOON\",\n321:     version,\n322:     description:\n323:       \"Token-Optimized Output Notation — compact pipe-delimited format for AI agent consumption. \" +\n324:       \"Call `woco describe --output toon` once per session to learn the format.\",\n325:     delimiter: \"|\",\n326:     rules: {\n327:       status_codes: \"BL=backlog PL=planned IP=in_progress BK=blocked IR=in_review DN=done CN=cancelled\",\n328:       priority_codes: \"C=critical H=high M=medium L=low W=wishlist\",\n329:       difficulty_codes: \"T=trivial E=easy M=medium H=hard V=very_hard\",\n330:       duration: \"Compact: 30m 2h 1d4h 2d4h30m (no spaces, no ISO prefix)\",\n331:       boolean: \"1=true 0=false\",\n332:       null_missing: \"Empty field between pipes (||)\",\n333:       arrays: \"Comma-separated within a single field (no pipes inside arrays)\",\n334:       field_order: \"Fixed positional per command. See 'commands' array for field order.\",\n335:       header_line: \"#FIELDS comment as first line lists field names in pipe-delimited order\",\n336:     },\n337:     commands: [...TOON_COMMAND_SPECS],\n338:   };\n339: }\n340: \n341: /**\n342:  * Emit the TOON legend as plain text — a compact, self-describing reference\n343:  * that an agent can cache and reuse for the rest of the session.\n344:  */\n345: export function renderToonLegend(version: string): string {\n346:   const lines: string[] = [];\n347: \n348:   lines.push(`# TOON v${version} — Token-Optimized Output Notation`);\n349:   lines.push(`# Delimiter: | (pipe)`);\n350:   lines.push(`# Status: BL=backlog PL=planned IP=in_progress BK=blocked IR=in_review DN=done CN=cancelled`);\n351:   lines.push(`# Priority: C=critical H=high M=medium L=low W=wishlist`);\n352:   lines.push(`# Difficulty: T=trivial E=easy M=medium H=hard V=very_hard`);\n353:   lines.push(`# Duration: compact (30m, 2h, 1d4h) — no ISO prefix`);\n354:   lines.push(`# Bool: 1/0  Null: empty (||)  Arrays: comma-separated`);\n355:   lines.push(`# First line per output: #FIELDS header with pipe-delimited field names`);\n356:   lines.push(`#`);\n357: \n358:   for (const spec of TOON_COMMAND_SPECS) {\n359:     const fieldNames = spec.fields.map((f) => f.name).join(\"|\");\n360:     lines.push(`# ${spec.command}: ${fieldNames}`);\n361:     if (spec.example) {\n362:       // Show only the data lines from the example (skip the #FIELDS line)\n363:       const exampleLines = spec.example.split(\"\\n\").filter((l) => !l.startsWith(\"#FIELDS\"));\n364:       if (exampleLines.length > 0) {\n365:         lines.push(`#   e.g. ${exampleLines[0]}`);\n366:       }\n367:     }\n368:   }\n369: \n370:   return lines.join(\"\\n\");\n371: }\n\n(End of file - total 371 lines)\n</content>","title":"src/lib/toon-spec.ts","metadata":{"preview":"/**\n * toon-spec.ts — Token-Optimized Output Notation (TOON) format specification.\n *\n * TOON is a compact, pipe-delimited encoding designed for AI agent consumption.\n * It minimizes token usage while remaining fully parseable. Agents call\n * `woco describe --output toon` once per session to learn the format, then\n * parse all subsequent TOON output without further context.\n *\n * Format rules:\n *   - Delimiter: pipe character (|)\n *   - Fields are positional (fixed order per command, no field names in output)\n *   - Header line: optional #FIELDS comment listing field order\n *   - Status codes: BL=backlog, PL=planned, IP=in_progress, BK=blocked, IR=in_review, DN=done, CN=cancelled\n *   - Priority codes: C=critical, H=high, M=medium, L=low, W=wishlist\n *   - Difficulty codes: T=trivial, E=easy, M=medium, H=hard, V=very_hard\n *   - Duration: compact format (30m, 2h, 1d4h) instead of ISO 8601\n *   - Boolean: 1/0 instead of true/false\n *   - Null/missing: empty field (||)\n *   - Arrays: comma-separated within a single field (no pipes)\n */","truncated":false,"loaded":[]},"time":{"start":1773437434332,"end":1773437434335}}}}
{"type":"tool_use","timestamp":1773437434548,"sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","part":{"id":"prt_ce91bb9dd0018hrWaeNCD5ItKq","sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","messageID":"msg_ce91ba42f001bwOtzgA7XCew6s","type":"tool","callID":"toolu_vrtx_01HTJkZx7GGSYpYDBR9FEDcy","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/lib/schema.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/lib/schema.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * schema.ts — Declarative command/flag registry for schema introspection.\n3:  *\n4:  * Every command and flag is described in a single registry. This registry is\n5:  * the source of truth for:\n6:  *   1. `woco describe <command>` — emits a JSON schema of accepted args\n7:  *   2. Future help text generation\n8:  *\n9:  * The registry is NOT used for actual arg parsing (that's still the hand-rolled\n10:  * switch in index.ts), but the two must stay in sync. If they drift, `woco\n11:  * tasks check` should eventually catch it.\n12:  */\n13: \n14: import { readFileSync } from \"node:fs\";\n15: import { resolve } from \"node:path\";\n16: import { VALID_STATUSES, VALID_PRIORITIES, VALID_DIFFICULTIES } from \"./task-schema.js\";\n17: \n18: // ---------------------------------------------------------------------------\n19: // Dynamic version reader\n20: // ---------------------------------------------------------------------------\n21: \n22: function getVersion(): string {\n23:   try {\n24:     const pkgPath = resolve(import.meta.dir, \"../../package.json\");\n25:     const raw = readFileSync(pkgPath, \"utf-8\");\n26:     return JSON.parse(raw).version as string;\n27:   } catch {\n28:     return \"unknown\";\n29:   }\n30: }\n31: \n32: // ---------------------------------------------------------------------------\n33: // Types\n34: // ---------------------------------------------------------------------------\n35: \n36: export interface FlagDef {\n37:   /** Primary flag name, e.g. \"--dry-run\" */\n38:   name: string;\n39:   /** Short alias, e.g. \"-o\" */\n40:   alias?: string;\n41:   /** Description shown in help / schema */\n42:   description: string;\n43:   /** Type of the value: \"boolean\" flags take no value, others consume next arg */\n44:   type: \"string\" | \"number\" | \"boolean\" | \"string[]\";\n45:   /** Default value (undefined = required or absent) */\n46:   default?: unknown;\n47:   /** For enum-like flags, the set of allowed values */\n48:   enum?: readonly string[];\n49:   /** If true, this flag is required */\n50:   required?: boolean;\n51: }\n52: \n53: export interface PositionalDef {\n54:   /** Name used in usage strings, e.g. \"feature-id\" */\n55:   name: string;\n56:   description: string;\n57:   required?: boolean;\n58: }\n59: \n60: export interface CommandDef {\n61:   /** Command name as typed by the user, e.g. \"launch\" or \"features list\" */\n62:   name: string;\n63:   /** One-line summary */\n64:   summary: string;\n65:   /** Longer description */\n66:   description?: string;\n67:   /** Positional arguments */\n68:   positionals: PositionalDef[];\n69:   /** Named flags */\n70:   flags: FlagDef[];\n71:   /** Whether this command mutates state (used for dry-run indication) */\n72:   mutating: boolean;\n73:   /** Whether this command supports --dry-run */\n74:   supportsDryRun: boolean;\n75:   /** Subcommands (for \"tasks\" parent) */\n76:   subcommands?: CommandDef[];\n77: }\n78: \n79: // ---------------------------------------------------------------------------\n80: // Global flags (available on every command)\n81: // ---------------------------------------------------------------------------\n82: \n83: const GLOBAL_FLAGS: FlagDef[] = [\n84:   {\n85:     name: \"--output\",\n86:     alias: \"-o\",\n87:     description: \"Output format: text (default) or json\",\n88:     type: \"string\",\n89:     default: \"text\",\n90:     enum: [\"text\", \"json\", \"toon\"],\n91:   },\n92:   {\n93:     name: \"--force\",\n94:     description: \"Force overwrite / skip safety prompts\",\n95:     type: \"boolean\",\n96:     default: false,\n97:   },\n98: ];\n99: \n100: // ---------------------------------------------------------------------------\n101: // Command Registry\n102: // ---------------------------------------------------------------------------\n103: \n104: export const COMMAND_REGISTRY: CommandDef[] = [\n105:   // --- init ---------------------------------------------------------------\n106:   {\n107:     name: \"init\",\n108:     summary: \"Generate .wombo-combo/config.json in the current project\",\n109:     description:\n110:       \"Interactive guided setup that walks through every config section. \" +\n111:       \"Creates .wombo-combo/config.json and .wombo-combo/tasks.yml from template.\",\n112:     positionals: [],\n113:     flags: [\n114:       {\n115:         name: \"--force\",\n116:         description: \"Overwrite existing config files\",\n117:         type: \"boolean\",\n118:         default: false,\n119:       },\n120:       {\n121:         name: \"--dry-run\",\n122:         description: \"Show what would be created without writing files\",\n123:         type: \"boolean\",\n124:         default: false,\n125:       },\n126:     ],\n127:     mutating: true,\n128:     supportsDryRun: true,\n129:   },\n130: \n131:   // --- launch -------------------------------------------------------------\n132:   {\n133:     name: \"launch\",\n134:     summary: \"Launch a wave of agents to implement features\",\n135:     description:\n136:       \"Select features from the tasks file, create worktrees, and spawn agents. \" +\n137:       \"Supports multiple selection strategies.\",\n138:     positionals: [],\n139:     flags: [\n140:       { name: \"--top-priority\", description: \"Select top N features by priority\", type: \"number\" },\n141:       { name: \"--quickest-wins\", description: \"Select N features with lowest effort\", type: \"number\" },\n142:       { name: \"--priority\", description: \"Filter by priority level\", type: \"string\", enum: VALID_PRIORITIES },\n143:       { name: \"--difficulty\", description: \"Filter by difficulty level\", type: \"string\", enum: VALID_DIFFICULTIES },\n144:       { name: \"--features\", description: \"Select specific features by comma-separated IDs (alias for --tasks)\", type: \"string\" },\n145:       { name: \"--tasks\", description: \"Select specific tasks by comma-separated IDs\", type: \"string\" },\n146:       { name: \"--all-ready\", description: \"Select all features whose dependencies are met\", type: \"boolean\", default: false },\n147:       { name: \"--max-concurrent\", description: \"Max agents running in parallel\", type: \"number\" },\n148:       { name: \"--model\", alias: \"-m\", description: \"Model to use (e.g., anthropic/claude-sonnet-4-20250514)\", type: \"string\" },\n149:       { name: \"--interactive\", description: \"Use multiplexer (dmux/tmux) TUI mode instead of headless\", type: \"boolean\", default: false },\n150:       { name: \"--no-tui\", description: \"Headless mode without neo-blessed TUI\", type: \"boolean\", default: false },\n151:       { name: \"--auto-push\", description: \"Push base branch to remote after all merges\", type: \"boolean\", default: false },\n152:       { name: \"--dry-run\", description: \"Show what would be launched without launching\", type: \"boolean\", default: false },\n153:       { name: \"--base-branch\", description: \"Base branch (default: from config)\", type: \"string\" },\n154:       { name: \"--max-retries\", description: \"Max retries per agent\", type: \"number\" },\n155:       { name: \"--browser\", description: \"Enable browser-based verification after build passes\", type: \"boolean\", default: false },\n156:       { name: \"--skip-tests\", description: \"Skip running tests during TDD verification\", type: \"boolean\", default: false },\n157:       { name: \"--strict-tdd\", description: \"Strict TDD mode: fail verification if new files are missing tests\", type: \"boolean\", default: false },\n158:     ],\n159:     mutating: true,\n160:     supportsDryRun: true,\n161:   },\n162: \n163:   // --- resume -------------------------------------------------------------\n164:   {\n165:     name: \"resume\",\n166:     summary: \"Resume a previously stopped wave\",\n167:     positionals: [],\n168:     flags: [\n169:       { name: \"--max-concurrent\", description: \"Max agents running in parallel\", type: \"number\" },\n170:       { name: \"--model\", alias: \"-m\", description: \"Model to use\", type: \"string\" },\n171:       { name: \"--interactive\", description: \"Use multiplexer (dmux/tmux) TUI mode\", type: \"boolean\", default: false },\n172:       { name: \"--no-tui\", description: \"Headless mode without neo-blessed TUI\", type: \"boolean\", default: false },\n173:       { name: \"--auto-push\", description: \"Push base branch to remote after merges\", type: \"boolean\", default: false },\n174:       { name: \"--base-branch\", description: \"Base branch override\", type: \"string\" },\n175:       { name: \"--max-retries\", description: \"Max retries per agent\", type: \"number\" },\n176:     ],\n177:     mutating: true,\n178:     supportsDryRun: false,\n179:   },\n180: \n181:   // --- status -------------------------------------------------------------\n182:   {\n183:     name: \"status\",\n184:     summary: \"Show the status of the current wave\",\n185:     positionals: [],\n186:     flags: [],\n187:     mutating: false,\n188:     supportsDryRun: false,\n189:   },\n190: \n191:   // --- verify -------------------------------------------------------------\n192:   {\n193:     name: \"verify\",\n194:     summary: \"Run build verification on completed agents\",\n195:     positionals: [\n196:       { name: \"feature-id\", description: \"Specific feature to verify (optional)\", required: false },\n197:     ],\n198:     flags: [\n199:       { name: \"--model\", alias: \"-m\", description: \"Model to use for verification\", type: \"string\" },\n200:       { name: \"--max-retries\", description: \"Max retries\", type: \"number\" },\n201:       { name: \"--browser\", description: \"Enable browser-based verification after build passes\", type: \"boolean\", default: false },\n202:       { name: \"--skip-tests\", description: \"Skip running tests during TDD verification\", type: \"boolean\", default: false },\n203:       { name: \"--strict-tdd\", description: \"Strict TDD mode: fail verification if new files are missing tests\", type: \"boolean\", default: false },\n204:     ],\n205:     mutating: true,\n206:     supportsDryRun: false,\n207:   },\n208: \n209:   // --- merge --------------------------------------------------------------\n210:   {\n211:     name: \"merge\",\n212:     summary: \"Merge verified branches into the base branch\",\n213:     positionals: [\n214:       { name: \"feature-id\", description: \"Specific feature to merge (optional)\", required: false },\n215:     ],\n216:     flags: [\n217:       { name: \"--auto-push\", description: \"Push base branch to remote after merge\", type: \"boolean\", default: false },\n218:       { name: \"--dry-run\", description: \"Show what would be merged without merging\", type: \"boolean\", default: false },\n219:     ],\n220:     mutating: true,\n221:     supportsDryRun: true,\n222:   },\n223: \n224:   // --- retry --------------------------------------------------------------\n225:   {\n226:     name: \"retry\",\n227:     summary: \"Retry a failed agent\",\n228:     positionals: [\n229:       { name: \"feature-id\", description: \"Feature ID of the failed agent\", required: true },\n230:     ],\n231:     flags: [\n232:       { name: \"--model\", alias: \"-m\", description: \"Model to use\", type: \"string\" },\n233:       { name: \"--interactive\", description: \"Use multiplexer (dmux/tmux) TUI mode\", type: \"boolean\", default: false },\n234:       { name: \"--dry-run\", description: \"Show what would be retried without retrying\", type: \"boolean\", default: false },\n235:     ],\n236:     mutating: true,\n237:     supportsDryRun: true,\n238:   },\n239: \n240:   // --- cleanup ------------------------------------------------------------\n241:   {\n242:     name: \"cleanup\",\n243:     summary: \"Remove all wave worktrees and multiplexer sessions\",\n244:     description: \"Kills multiplexer sessions, removes worktrees, removes state and log files.\",\n245:     positionals: [],\n246:     flags: [\n247:       { name: \"--dry-run\", description: \"Show what would be cleaned up without removing\", type: \"boolean\", default: false },\n248:     ],\n249:     mutating: true,\n250:     supportsDryRun: true,\n251:   },\n252: \n253:   // --- history ------------------------------------------------------------\n254:   {\n255:     name: \"history\",\n256:     summary: \"List/view past wave results from .wombo-combo/history/\",\n257:     description:\n258:       \"Wave history is auto-exported when a wave completes. Records are stored \" +\n259:       \"separately from .wombo-combo/state.json and survive cleanup. Use without arguments \" +\n260:       \"to list all waves, or pass a wave ID to see detailed results.\",\n261:     positionals: [\n262:       { name: \"wave-id\", description: \"Specific wave ID to show details for (optional)\", required: false },\n263:     ],\n264:     flags: [],\n265:     mutating: false,\n266:     supportsDryRun: false,\n267:   },\n268: \n269:   // --- abort --------------------------------------------------------------\n270:   {\n271:     name: \"abort\",\n272:     summary: \"Kill a single running agent without affecting the rest of the wave\",\n273:     description:\n274:       \"Kills the multiplexer session and agent process for a specific feature, then \" +\n275:       \"marks the agent as failed. Use --requeue to return the feature to the \" +\n276:       \"queue instead of marking it failed.\",\n277:     positionals: [\n278:       { name: \"feature-id\", description: \"Feature ID of the agent to abort\", required: true },\n279:     ],\n280:     flags: [\n281:       { name: \"--requeue\", description: \"Return the feature to queued instead of marking it failed\", type: \"boolean\", default: false },\n282:     ],\n283:     mutating: true,\n284:     supportsDryRun: false,\n285:   },\n286: \n287:   // --- upgrade ------------------------------------------------------------\n288:   {\n289:     name: \"upgrade\",\n290:     summary: \"Check for updates and upgrade wombo\",\n291:     positionals: [],\n292:     flags: [\n293:       { name: \"--check\", description: \"Only check for updates, don't install\", type: \"boolean\", default: false },\n294:       { name: \"--tag\", alias: \"--release\", description: \"Install a specific version (e.g., v0.1.0)\", type: \"string\" },\n295:       { name: \"--force\", description: \"Force reinstall even if up to date\", type: \"boolean\", default: false },\n296:     ],\n297:     mutating: true,\n298:     supportsDryRun: false,\n299:   },\n300: \n301:   // --- logs ---------------------------------------------------------------\n302:   {\n303:     name: \"logs\",\n304:     summary: \"Pretty-print agent logs from .wombo-combo/logs/<feature-id>.log\",\n305:     description:\n306:       \"Reads log files written by agents during headless runs and displays \" +\n307:       \"them with colorized output. Supports tailing and following.\",\n308:     positionals: [\n309:       { name: \"feature-id\", description: \"Feature ID whose logs to display\", required: true },\n310:     ],\n311:     flags: [\n312:       { name: \"--tail\", description: \"Show only the last N lines\", type: \"number\" },\n313:       { name: \"--follow\", alias: \"-f\", description: \"Stream new output as it arrives (like tail -f)\", type: \"boolean\", default: false },\n314:     ],\n315:     mutating: false,\n316:     supportsDryRun: false,\n317:   },\n318: \n319:   // --- tasks (parent with subcommands) — also accepts \"features\" as alias ---\n320:   {\n321:     name: \"tasks\",\n322:     summary: \"Manage tasks file\",\n323:     positionals: [],\n324:     flags: [],\n325:     mutating: false,\n326:     supportsDryRun: false,\n327:     subcommands: [\n328:       {\n329:         name: \"tasks list\",\n330:         summary: \"List tasks with optional filtering\",\n331:         positionals: [],\n332:         flags: [\n333:           { name: \"--status\", description: \"Filter by status\", type: \"string\", enum: VALID_STATUSES },\n334:           { name: \"--priority\", description: \"Filter by priority\", type: \"string\", enum: VALID_PRIORITIES },\n335:           { name: \"--difficulty\", description: \"Filter by difficulty\", type: \"string\", enum: VALID_DIFFICULTIES },\n336:           { name: \"--ready\", description: \"Show only ready tasks (backlog + deps met)\", type: \"boolean\", default: false },\n337:           { name: \"--include-archive\", description: \"Include archived tasks\", type: \"boolean\", default: false },\n338:           { name: \"--fields\", description: \"Comma-separated list of fields to include in output\", type: \"string\" },\n339:         ],\n340:         mutating: false,\n341:         supportsDryRun: false,\n342:       },\n343:       {\n344:         name: \"tasks add\",\n345:         summary: \"Add a new task\",\n346:         positionals: [\n347:           { name: \"id\", description: \"Task ID (kebab-case)\", required: true },\n348:           { name: \"title\", description: \"Task title\", required: true },\n349:         ],\n350:         flags: [\n351:           { name: \"--description\", alias: \"--desc\", description: \"Task description\", type: \"string\" },\n352:           { name: \"--priority\", description: \"Priority level\", type: \"string\", default: \"medium\", enum: VALID_PRIORITIES },\n353:           { name: \"--difficulty\", description: \"Difficulty level\", type: \"string\", default: \"medium\", enum: VALID_DIFFICULTIES },\n354:           { name: \"--effort\", description: \"Effort estimate (ISO 8601 duration, e.g. PT2H)\", type: \"string\", default: \"PT1H\" },\n355:           { name: \"--depends-on\", description: \"Comma-separated dependency IDs\", type: \"string\" },\n356:           { name: \"--dry-run\", description: \"Show what would be added without writing\", type: \"boolean\", default: false },\n357:         ],\n358:         mutating: true,\n359:         supportsDryRun: true,\n360:       },\n361:       {\n362:         name: \"tasks set-status\",\n363:         summary: \"Change a task's status\",\n364:         positionals: [\n365:           { name: \"task-id\", description: \"Task ID to update\", required: true },\n366:           { name: \"status\", description: \"New status value\", required: true },\n367:         ],\n368:         flags: [\n369:           { name: \"--dry-run\", description: \"Show what would change without writing\", type: \"boolean\", default: false },\n370:         ],\n371:         mutating: true,\n372:         supportsDryRun: true,\n373:       },\n374:       {\n375:         name: \"tasks set-priority\",\n376:         summary: \"Change a task's priority\",\n377:         positionals: [\n378:           { name: \"task-id\", description: \"Task ID to update\", required: true },\n379:           { name: \"priority\", description: \"New priority value\", required: true },\n380:         ],\n381:         flags: [\n382:           { name: \"--dry-run\", description: \"Show what would change without writing\", type: \"boolean\", default: false },\n383:         ],\n384:         mutating: true,\n385:         supportsDryRun: true,\n386:       },\n387:       {\n388:         name: \"tasks set-difficulty\",\n389:         summary: \"Change a task's difficulty\",\n390:         positionals: [\n391:           { name: \"task-id\", description: \"Task ID to update\", required: true },\n392:           { name: \"difficulty\", description: \"New difficulty value\", required: true },\n393:         ],\n394:         flags: [\n395:           { name: \"--dry-run\", description: \"Show what would change without writing\", type: \"boolean\", default: false },\n396:         ],\n397:         mutating: true,\n398:         supportsDryRun: true,\n399:       },\n400:       {\n401:         name: \"tasks check\",\n402:         summary: \"Validate tasks file (schema, deps, duplicates, cycles)\",\n403:         positionals: [],\n404:         flags: [\n405:           { name: \"--output\", description: \"Output format: text (default) or json\", type: \"string\", default: \"text\" },\n406:         ],\n407:         mutating: false,\n408:         supportsDryRun: false,\n409:       },\n410:       {\n411:         name: \"tasks archive\",\n412:         summary: \"Move done/cancelled tasks to archive section\",\n413:         positionals: [\n414:           { name: \"task-id\", description: \"Specific task to archive (optional)\", required: false },\n415:         ],\n416:         flags: [\n417:           { name: \"--dry-run\", description: \"Show what would be archived without moving\", type: \"boolean\", default: false },\n418:         ],\n419:         mutating: true,\n420:         supportsDryRun: true,\n421:       },\n422:       {\n423:         name: \"tasks show\",\n424:         summary: \"Show detailed information about a specific task\",\n425:         positionals: [\n426:           { name: \"task-id\", description: \"Task ID to display\", required: true },\n427:         ],\n428:         flags: [\n429:           { name: \"--fields\", description: \"Comma-separated list of fields to include in output\", type: \"string\" },\n430:         ],\n431:         mutating: false,\n432:         supportsDryRun: false,\n433:       },\n434:       {\n435:         name: \"tasks graph\",\n436:         summary: \"Visualize the task dependency graph as a terminal diagram\",\n437:         description:\n438:           \"Builds a Mermaid flowchart from the tasks dependency graph and renders \" +\n439:           \"it as a Unicode box diagram. Shows dependency edges, status badges, orphan \" +\n440:           \"detection, dangling dependency warnings, and cycle detection.\",\n441:         positionals: [],\n442:         flags: [\n443:           { name: \"--status\", description: \"Filter graph to tasks with this status\", type: \"string\", enum: VALID_STATUSES },\n444:           { name: \"--ascii\", description: \"Use ASCII-only rendering (no Unicode box chars)\", type: \"boolean\", default: false },\n445:           { name: \"--mermaid\", description: \"Emit raw Mermaid source instead of rendered graph\", type: \"boolean\", default: false },\n446:           { name: \"--subtasks\", description: \"Include subtask-level nodes in the graph\", type: \"boolean\", default: false },\n447:         ],\n448:         mutating: false,\n449:         supportsDryRun: false,\n450:       },\n451:     ],\n452:   },\n453: \n454:   // --- help ---------------------------------------------------------------\n455:   {\n456:     name: \"help\",\n457:     summary: \"Show help text\",\n458:     positionals: [],\n459:     flags: [],\n460:     mutating: false,\n461:     supportsDryRun: false,\n462:   },\n463: \n464:   // --- version -----------------------------------------------------------\n465:   {\n466:     name: \"version\",\n467:     summary: \"Print version and exit (also: -v, -V)\",\n468:     positionals: [],\n469:     flags: [],\n470:     mutating: false,\n471:     supportsDryRun: false,\n472:   },\n473: \n474:   // --- describe -----------------------------------------------------------\n475:   {\n476:     name: \"describe\",\n477:     summary: \"Emit JSON schema of a command's arguments and flags\",\n478:     description:\n479:       \"Machine-readable introspection for AI agents. Outputs the accepted \" +\n480:       \"positionals, flags, types, defaults, and constraints for a command.\",\n481:     positionals: [\n482:       { name: \"command\", description: \"Command to describe (e.g. 'launch', 'features add')\", required: false },\n483:     ],\n484:     flags: [],\n485:     mutating: false,\n486:     supportsDryRun: false,\n487:   },\n488: ];\n489: \n490: // ---------------------------------------------------------------------------\n491: // Lookup helpers\n492: // ---------------------------------------------------------------------------\n493: \n494: /**\n495:  * Find a command definition by name. Supports compound names like \"tasks list\".\n496:  * Also supports \"features\" as a backward-compat alias for \"tasks\".\n497:  */\n498: export function findCommandDef(name: string): CommandDef | undefined {\n499:   // Normalize \"features\" -> \"tasks\" for backward compatibility\n500:   const normalized = name.replace(/^features(\\s|$)/, \"tasks$1\");\n501: \n502:   // Try direct match first\n503:   const direct = COMMAND_REGISTRY.find((c) => c.name === normalized);\n504:   if (direct) return direct;\n505: \n506:   // Try compound: \"tasks list\" -> look in tasks subcommands\n507:   const parts = normalized.split(/\\s+/);\n508:   if (parts.length === 2) {\n509:     const parent = COMMAND_REGISTRY.find((c) => c.name === parts[0]);\n510:     if (parent?.subcommands) {\n511:       return parent.subcommands.find((sc) => sc.name === normalized || sc.name === parts[1]);\n512:     }\n513:   }\n514: \n515:   return undefined;\n516: }\n517: \n518: /**\n519:  * Produce the JSON schema object for a command, suitable for agent consumption.\n520:  */\n521: export function commandToSchema(cmd: CommandDef): Record<string, unknown> {\n522:   const schema: Record<string, unknown> = {\n523:     command: cmd.name,\n524:     summary: cmd.summary,\n525:     mutating: cmd.mutating,\n526:     supports_dry_run: cmd.supportsDryRun,\n527:   };\n528: \n529:   if (cmd.description) {\n530:     schema.description = cmd.description;\n531:   }\n532: \n533:   if (cmd.positionals.length > 0) {\n534:     schema.positionals = cmd.positionals.map((p) => ({\n535:       name: p.name,\n536:       description: p.description,\n537:       required: p.required ?? false,\n538:     }));\n539:   }\n540: \n541:   const allFlags = [...cmd.flags, ...GLOBAL_FLAGS];\n542:   schema.flags = allFlags.map((f) => {\n543:     const entry: Record<string, unknown> = {\n544:       name: f.name,\n545:       type: f.type,\n546:       description: f.description,\n547:     };\n548:     if (f.alias) entry.alias = f.alias;\n549:     if (f.default !== undefined) entry.default = f.default;\n550:     if (f.enum) entry.enum = f.enum;\n551:     if (f.required) entry.required = true;\n552:     return entry;\n553:   });\n554: \n555:   if (cmd.subcommands?.length) {\n556:     schema.subcommands = cmd.subcommands.map((sc) => sc.name);\n557:   }\n558: \n559:   return schema;\n560: }\n561: \n562: /**\n563:  * Produce a listing of all commands (for `woco describe` with no args).\n564:  */\n565: export function allCommandSchemas(): Record<string, unknown> {\n566:   const commands: Record<string, unknown>[] = [];\n567: \n568:   for (const cmd of COMMAND_REGISTRY) {\n569:     const entry: Record<string, unknown> = {\n570:       name: cmd.name,\n571:       summary: cmd.summary,\n572:       mutating: cmd.mutating,\n573:       supports_dry_run: cmd.supportsDryRun,\n574:     };\n575:     if (cmd.subcommands) {\n576:       entry.subcommands = cmd.subcommands.map((sc) => ({\n577:         name: sc.name,\n578:         summary: sc.summary,\n579:         mutating: sc.mutating,\n580:         supports_dry_run: sc.supportsDryRun,\n581:       }));\n582:     }\n583:     commands.push(entry);\n584:   }\n585: \n586:   return {\n587:     tool: \"wombo-combo\",\n588:     version: getVersion(),\n589:     global_flags: GLOBAL_FLAGS.map((f) => ({\n590:       name: f.name,\n591:       alias: f.alias,\n592:       type: f.type,\n593:       description: f.description,\n594:       default: f.default,\n595:     })),\n596:     commands,\n597:   };\n598: }\n\n(End of file - total 598 lines)\n</content>","title":"src/lib/schema.ts","metadata":{"preview":"/**\n * schema.ts — Declarative command/flag registry for schema introspection.\n *\n * Every command and flag is described in a single registry. This registry is\n * the source of truth for:\n *   1. `woco describe <command>` — emits a JSON schema of accepted args\n *   2. Future help text generation\n *\n * The registry is NOT used for actual arg parsing (that's still the hand-rolled\n * switch in index.ts), but the two must stay in sync. If they drift, `woco\n * tasks check` should eventually catch it.\n */\n\nimport { readFileSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\nimport { VALID_STATUSES, VALID_PRIORITIES, VALID_DIFFICULTIES } from \"./task-schema.js\";\n\n// ---------------------------------------------------------------------------\n// Dynamic version reader\n// ---------------------------------------------------------------------------","truncated":false,"loaded":[]},"time":{"start":1773437434543,"end":1773437434547}}}}
{"type":"tool_use","timestamp":1773437435893,"sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","part":{"id":"prt_ce91bbab0001aYO7SdxQBprh6G","sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","messageID":"msg_ce91ba42f001bwOtzgA7XCew6s","type":"tool","callID":"toolu_vrtx_01GzhMkZVK6pLrRdn2P7uEdf","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/index.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/index.ts</path>\n<type>file</type>\n<content>1: #!/usr/bin/env bun\n2: /**\n3:  * index.ts — CLI entry point for the wombo-combo agent orchestration system.\n4:  *\n5:  * Every command has a short alias (e.g., woco i = woco init, woco t ls = woco tasks list).\n6:  *\n7:  * Usage:\n8:  *   woco init                                         (alias: i)\n9:  *   woco launch --top-priority 3                      (alias: l)\n10:  *   woco launch --quickest-wins 5\n11:  *   woco launch --priority high\n12:  *   woco launch --difficulty easy\n13:  *   woco launch --tasks \"feat-a,feat-b\"\n14:  *   woco launch --all-ready\n15:  *   woco launch ... --max-concurrent 3 --model \"anthropic/claude-sonnet-4-20250514\"\n16:  *   woco launch ... --interactive\n17:  *   woco resume                                       (alias: r)\n18:  *   woco status                                       (alias: s)\n19:  *   woco verify [feature-id]                          (alias: v)\n20:  *   woco merge [feature-id]                           (alias: m)\n21:  *   woco retry <feature-id>                           (alias: re)\n22:  *   woco abort <feature-id> [--requeue] [--output json]  (alias: a)\n23:  *   woco logs <feature-id> [--tail N] [--follow]      (alias: lo)\n24:  *   woco cleanup                                      (alias: c)\n25:  *   woco history [wave-id] [--output json]            (alias: h)\n26:  *   woco tasks list [--status <s>] [--priority <p>]   (alias: t ls)\n27:  *   woco tasks add <id> <title> [options]             (alias: t a)\n28:  *   woco tasks set-status <task-id> <status>          (alias: t ss)\n29:  *   woco tasks set-priority <task-id> <priority>      (alias: t sp)\n30:  *   woco tasks set-difficulty <task-id> <difficulty>   (alias: t sd)\n31:  *   woco tasks check                                  (alias: t ch)\n32:  *   woco tasks archive [task-id] [--dry-run]          (alias: t ar)\n33:  *   woco tasks show <task-id>                         (alias: t sh)\n34:  *   woco tasks graph [--ascii] [--mermaid]            (alias: t g)\n35:  *   woco completion <bash|zsh|fish>                   (alias: comp)\n36:  *   woco help\n37:  *   woco version\n38:  *   woco -v\n39:  */\n40: \n41: import { resolve } from \"node:path\";\n42: import { existsSync, readFileSync } from \"node:fs\";\n43: import { loadConfig, validateConfig } from \"./config.js\";\n44: import { loadState, saveState } from \"./lib/state.js\";\n45: \n46: // ---------------------------------------------------------------------------\n47: // Dev-mode guard: warn if running the global binary inside the wombo-combo repo\n48: // ---------------------------------------------------------------------------\n49: \n50: function checkDevModeGuard(): void {\n51:   const cwd = process.cwd();\n52:   const pkgPath = resolve(cwd, \"package.json\");\n53: \n54:   // Are we inside the wombo-combo repo?\n55:   if (!existsSync(pkgPath)) return;\n56: \n57:   let pkgName: string | undefined;\n58:   try {\n59:     const raw = readFileSync(pkgPath, \"utf-8\");\n60:     pkgName = JSON.parse(raw).name;\n61:   } catch {\n62:     return;\n63:   }\n64:   if (pkgName !== \"wombo-combo\") return;\n65: \n66:   // We're in the wombo-combo repo. Is the source being run from a different location?\n67:   // import.meta.dir = directory of THIS file (index.ts). If it's under cwd,\n68:   // we're running local source (bun dev). If it's elsewhere (e.g. ~/.bun/install),\n69:   // we're running the globally installed binary.\n70:   const sourceDir = resolve(import.meta.dir);\n71:   const projectSrc = resolve(cwd, \"src\");\n72: \n73:   if (!sourceDir.startsWith(projectSrc)) {\n74:     console.warn(\n75:       \"\\x1b[33m[WARNING]\\x1b[0m You are running the globally installed woco binary \" +\n76:       \"inside the wombo-combo repo.\\n\" +\n77:       \"  Use \\x1b[1mbun dev <command>\\x1b[0m instead to run from local source.\\n\" +\n78:       \"  See AGENTS.md for details.\\n\"\n79:     );\n80:   }\n81: }\n82: \n83: import { cmdInit } from \"./commands/init.js\";\n84: import { cmdLaunch } from \"./commands/launch.js\";\n85: import { cmdResume } from \"./commands/resume.js\";\n86: import { cmdStatus } from \"./commands/status.js\";\n87: import { cmdVerify } from \"./commands/verify.js\";\n88: import { cmdMerge } from \"./commands/merge.js\";\n89: import { cmdRetry } from \"./commands/retry.js\";\n90: import { cmdCleanup } from \"./commands/cleanup.js\";\n91: import { cmdAbort } from \"./commands/abort.js\";\n92: import { cmdLogs } from \"./commands/logs.js\";\n93: import { cmdUpgrade } from \"./commands/upgrade.js\";\n94: import { cmdHistory } from \"./commands/history.js\";\n95: import { cmdCompletion } from \"./commands/completion.js\";\n96: import { cmdTasksList } from \"./commands/tasks/list.js\";\n97: import { cmdTasksAdd } from \"./commands/tasks/add.js\";\n98: import { cmdTasksSetStatus } from \"./commands/tasks/set-status.js\";\n99: import { cmdTasksSetPriority } from \"./commands/tasks/set-priority.js\";\n100: import { cmdTasksSetDifficulty } from \"./commands/tasks/set-difficulty.js\";\n101: import { cmdTasksCheck } from \"./commands/tasks/check.js\";\n102: import { cmdTasksArchive } from \"./commands/tasks/archive.js\";\n103: import { cmdTasksShow } from \"./commands/tasks/show.js\";\n104: import { cmdTasksGraph } from \"./commands/tasks/graph.js\";\n105: \n106: import { ensureTasksFile } from \"./lib/tasks.js\";\n107: import type { Priority, Difficulty, FeatureStatus } from \"./lib/tasks.js\";\n108: import { resolveOutputFormat, type OutputFormat } from \"./lib/output.js\";\n109: import { validateId, validateText, validateBranchName, validateDuration, assertValid } from \"./lib/validate.js\";\n110: import { findCommandDef, commandToSchema, allCommandSchemas } from \"./lib/schema.js\";\n111: import { buildToonSpec, renderToonLegend } from \"./lib/toon-spec.js\";\n112: \n113: // ---------------------------------------------------------------------------\n114: // Types\n115: // ---------------------------------------------------------------------------\n116: \n117: export interface CLIArgs {\n118:   command: string;\n119:   subcommand?: string;\n120:   // Selection options (launch)\n121:   topPriority?: number;\n122:   quickestWins?: number;\n123:   priority?: Priority;\n124:   difficulty?: Difficulty;\n125:   tasks?: string[];\n126:   allReady?: boolean;\n127:   // Launch / runtime options\n128:   maxConcurrent?: number;\n129:   model?: string;\n130:   interactive: boolean;\n131:   dryRun: boolean;\n132:   baseBranch?: string;\n133:   maxRetries?: number;\n134:   noTui: boolean;\n135:   autoPush: boolean;\n136:   // Abort options\n137:   requeue: boolean;\n138:   // General\n139:   featureId?: string;\n140:   force: boolean;\n141:   // Output format\n142:   outputFmt: OutputFormat;\n143:   // Upgrade options\n144:   checkOnly: boolean;\n145:   tag?: string;\n146:   // Features subcommand extras\n147:   status?: string;\n148:   ready?: boolean;\n149:   includeArchive?: boolean;\n150:   title?: string;\n151:   description?: string;\n152:   effort?: string;\n153:   dependsOn?: string[];\n154:   // Logs options\n155:   tail?: number;\n156:   follow?: boolean;\n157:   // Compact output\n158:   fields?: string[];\n159:   // Graph options\n160:   ascii?: boolean;\n161:   mermaidRaw?: boolean;\n162:   graphSubtasks?: boolean;\n163:   // Browser verification\n164:   browser?: boolean;\n165:   // TDD verification\n166:   skipTests?: boolean;\n167:   strictTdd?: boolean;\n168: }\n169: \n170: // ---------------------------------------------------------------------------\n171: // Command & Subcommand Aliases\n172: // ---------------------------------------------------------------------------\n173: \n174: /** Map of short aliases → canonical top-level command names. */\n175: export const COMMAND_ALIASES: Record<string, string> = {\n176:   i: \"init\",\n177:   l: \"launch\",\n178:   r: \"resume\",\n179:   s: \"status\",\n180:   v: \"verify\",\n181:   m: \"merge\",\n182:   re: \"retry\",\n183:   a: \"abort\",\n184:   c: \"cleanup\",\n185:   h: \"history\",\n186:   lo: \"logs\",\n187:   t: \"tasks\",\n188:   features: \"tasks\", // backward-compat full-word alias\n189:   u: \"upgrade\",\n190:   d: \"describe\",\n191:   comp: \"completion\",\n192: };\n193: \n194: /** Map of short aliases → canonical tasks subcommand names. */\n195: export const SUBCOMMAND_ALIASES: Record<string, string> = {\n196:   ls: \"list\",\n197:   a: \"add\",\n198:   ss: \"set-status\",\n199:   sp: \"set-priority\",\n200:   sd: \"set-difficulty\",\n201:   ch: \"check\",\n202:   validate: \"check\", // backward-compat full-word alias\n203:   ar: \"archive\",\n204:   sh: \"show\",\n205:   g: \"graph\",\n206: };\n207: \n208: // ---------------------------------------------------------------------------\n209: // Arg Parsing\n210: // ---------------------------------------------------------------------------\n211: \n212: export function parseArgs(argv: string[]): CLIArgs {\n213:   const args = argv.slice(2); // skip 'bun' and script path\n214:   const result: CLIArgs = {\n215:     command: args[0] || \"help\",\n216:     interactive: false,\n217:     dryRun: false,\n218:     noTui: false,\n219:     autoPush: false,\n220:     requeue: false,\n221:     force: false,\n222:     checkOnly: false,\n223:     outputFmt: resolveOutputFormat(undefined), // auto-detect until --output overrides\n224:   };\n225: \n226:   // Resolve top-level command alias (e.g., \"i\" → \"init\", \"t\" → \"tasks\")\n227:   result.command = COMMAND_ALIASES[result.command] ?? result.command;\n228: \n229:   // If the command is \"tasks\", treat the second positional as the subcommand\n230:   let startIdx = 1;\n231:   if (result.command === \"tasks\") {\n232:     result.subcommand = args[1] || \"list\";\n233:     // Resolve subcommand alias (e.g., \"ls\" → \"list\", \"ss\" → \"set-status\")\n234:     result.subcommand = SUBCOMMAND_ALIASES[result.subcommand] ?? result.subcommand;\n235:     startIdx = 2;\n236:   }\n237: \n238:   for (let i = startIdx; i < args.length; i++) {\n239:     const arg = args[i];\n240: \n241:     // Helper: consume the next argument, or exit with a clear error\n242:     function requireValue(flag: string): string {\n243:       if (i + 1 >= args.length) {\n244:         console.error(`Flag ${flag} requires a value.`);\n245:         process.exit(1);\n246:       }\n247:       return args[++i];\n248:     }\n249: \n250:     switch (arg) {\n251:       // --- Selection options ---\n252:       case \"--top-priority\":\n253:         result.topPriority = parseInt(requireValue(arg), 10);\n254:         break;\n255:       case \"--quickest-wins\":\n256:         result.quickestWins = parseInt(requireValue(arg), 10);\n257:         break;\n258:       case \"--priority\":\n259:         result.priority = requireValue(arg) as Priority;\n260:         break;\n261:       case \"--difficulty\":\n262:         result.difficulty = requireValue(arg) as Difficulty;\n263:         break;\n264:       case \"--tasks\":\n265:       case \"--features\": // backward-compat alias\n266:         result.tasks = requireValue(arg).split(\",\").map((s) => s.trim());\n267:         break;\n268:       case \"--all-ready\":\n269:         result.allReady = true;\n270:         break;\n271: \n272:       // --- Launch / runtime options ---\n273:       case \"--max-concurrent\":\n274:         result.maxConcurrent = parseInt(requireValue(arg), 10);\n275:         break;\n276:       case \"--model\":\n277:       case \"-m\":\n278:         result.model = requireValue(arg);\n279:         break;\n280:       case \"--interactive\":\n281:         result.interactive = true;\n282:         break;\n283:       case \"--dry-run\":\n284:         result.dryRun = true;\n285:         break;\n286:       case \"--no-tui\":\n287:         result.noTui = true;\n288:         break;\n289:       case \"--auto-push\":\n290:         result.autoPush = true;\n291:         break;\n292:       case \"--requeue\":\n293:         result.requeue = true;\n294:         break;\n295:       case \"--base-branch\":\n296:         result.baseBranch = requireValue(arg);\n297:         break;\n298:       case \"--max-retries\":\n299:         result.maxRetries = parseInt(requireValue(arg), 10);\n300:         break;\n301: \n302:       // --- General flags ---\n303:       case \"--force\":\n304:         result.force = true;\n305:         break;\n306:       case \"--check\":\n307:         result.checkOnly = true;\n308:         break;\n309:       case \"--tag\":\n310:       case \"--release\":\n311:         result.tag = requireValue(arg);\n312:         break;\n313:       case \"--output\":\n314:       case \"-o\":\n315:         result.outputFmt = resolveOutputFormat(requireValue(arg));\n316:         break;\n317: \n318:       // --- Tasks subcommand options ---\n319:       case \"--status\":\n320:         result.status = requireValue(arg);\n321:         break;\n322:       case \"--ready\":\n323:         result.ready = true;\n324:         break;\n325:       case \"--include-archive\":\n326:         result.includeArchive = true;\n327:         break;\n328:       case \"--title\":\n329:         result.title = requireValue(arg);\n330:         break;\n331:       case \"--description\":\n332:       case \"--desc\":\n333:         result.description = requireValue(arg);\n334:         break;\n335:       case \"--effort\":\n336:         result.effort = requireValue(arg);\n337:         break;\n338:       case \"--depends-on\":\n339:         result.dependsOn = requireValue(arg).split(\",\").map((s) => s.trim());\n340:         break;\n341:       case \"--fields\":\n342:         result.fields = requireValue(arg).split(\",\").map((s) => s.trim());\n343:         break;\n344: \n345:       // --- Graph options ---\n346:       case \"--ascii\":\n347:         result.ascii = true;\n348:         break;\n349:       case \"--mermaid\":\n350:         result.mermaidRaw = true;\n351:         break;\n352:       case \"--subtasks\":\n353:         result.graphSubtasks = true;\n354:         break;\n355: \n356:       // --- Logs options ---\n357:       case \"--tail\":\n358:         result.tail = parseInt(requireValue(arg), 10);\n359:         break;\n360:       case \"--follow\":\n361:       case \"-f\":\n362:         result.follow = true;\n363:         break;\n364: \n365:       // --- Browser verification ---\n366:       case \"--browser\":\n367:         result.browser = true;\n368:         break;\n369: \n370:       // --- TDD verification ---\n371:       case \"--skip-tests\":\n372:         result.skipTests = true;\n373:         break;\n374:       case \"--strict-tdd\":\n375:         result.strictTdd = true;\n376:         break;\n377: \n378:       // --- Positional (feature-id, title for add, etc.) ---\n379:       default:\n380:         if (!arg.startsWith(\"-\")) {\n381:           if (!result.featureId) {\n382:             result.featureId = arg;\n383:           } else if (!result.title) {\n384:             result.title = arg;\n385:           }\n386:         }\n387:         break;\n388:     }\n389:   }\n390: \n391:   return result;\n392: }\n393: \n394: // ---------------------------------------------------------------------------\n395: // Help\n396: // ---------------------------------------------------------------------------\n397: \n398: function cmdHelp(): void {\n399:   console.log(`\n400: wombo-combo — AI Agent Orchestration System\n401: \n402:   WOMBO COMBO! Parallel feature development with AI agents.\n403: \n404: Commands:                        (alias)\n405:   init                           (i)     Generate .wombo-combo/config.json in the current project\n406:   launch                         (l)     Launch a wave of agents to implement features\n407:   resume                         (r)     Resume a previously stopped wave\n408:   status                         (s)     Show the status of the current wave\n409:   verify                         (v)     Run build verification on completed agents\n410:   merge                          (m)     Merge verified branches into the base branch\n411:   retry                          (re)    Retry a failed agent\n412:   abort                          (a)     Kill a single running agent (--requeue to return to queue)\n413:   logs                           (lo)    Pretty-print agent logs for a feature\n414:   cleanup                        (c)     Remove all wave worktrees and multiplexer sessions\n415:   history                        (h)     List/view past wave results (stored in .wombo-combo/history/)\n416:   tasks                          (t)     Manage tasks file (see below; 'features' also accepted)\n417:   upgrade                        (u)     Check for updates and upgrade wombo-combo\n418:   describe                       (d)     Emit JSON schema of a command (for AI agents)\n419:   completion                     (comp)  Generate shell completions (bash, zsh, fish)\n420:   version                                Print version and exit\n421:   help                                   Show this help\n422: \n423: Tasks Subcommands:               (alias)\n424:   tasks list                     (ls)    List tasks (--status, --priority, --difficulty, --ready, --include-archive)\n425:   tasks add <id> <title>         (a)     Add a new task (--desc, --priority, --difficulty, --effort, --depends-on)\n426:   tasks set-status <id> <s>      (ss)    Change a task's status\n427:   tasks set-priority <id> <p>    (sp)    Change a task's priority (critical/high/medium/low/wishlist)\n428:   tasks set-difficulty <id> <d>  (sd)    Change a task's difficulty (trivial/easy/medium/hard/very_hard)\n429:   tasks check                    (ch)    Validate tasks file (schema, deps, duplicates, cycles)\n430:   tasks archive [id]             (ar)    Move done/cancelled to archive (--dry-run)\n431:   tasks show <id>                (sh)    Show task details\n432:   tasks graph                    (g)     Visualize dependency graph (--ascii, --mermaid, --subtasks)\n433: \n434: Selection Options (for launch):\n435:   --top-priority N         Select top N tasks by priority\n436:   --quickest-wins N        Select N tasks with lowest effort\n437:   --priority <level>       Filter by priority (critical/high/medium/low/wishlist)\n438:   --difficulty <level>     Filter by difficulty (trivial/easy/medium/hard/very_hard)\n439:   --tasks \"id1,id2\"        Select specific tasks by ID (--features also accepted)\n440:   --all-ready              Select all tasks whose dependencies are met\n441: \n442: Launch Options:\n443:   --max-concurrent N       Max agents running in parallel (default: from config)\n444:   --model <model>          Model to use (e.g., \"anthropic/claude-sonnet-4-20250514\")\n445:   --interactive            Use multiplexer (dmux/tmux) TUI mode instead of headless\n446:   --no-tui                 Headless mode without neo-blessed TUI (periodic console dashboard)\n447:   --auto-push              Push base branch to remote after all merges complete\n448:   --dry-run                Show what would be launched without launching\n449:   --base-branch <branch>   Base branch (default: from config)\n450:   --max-retries N          Max retries per agent (default: from config)\n451:   --browser                Enable browser-based verification (run after build passes)\n452:   --skip-tests             Skip running tests during TDD verification\n453:   --strict-tdd             Strict TDD: fail verification if new files are missing tests\n454: \n455: General:\n456:   --force                  Force overwrite (e.g., for init) / skip prompts (e.g., for upgrade)\n457:   --output <fmt>           Output format: text (default on TTY) or json (default when piped)\n458:   -o <fmt>                 Alias for --output\n459:   --dry-run                Show what would happen without performing the action\n460:   --fields <list>          Comma-separated fields to include (e.g., id,status,priority)\n461: \n462: Upgrade Options:\n463:   --check                  Only check for updates, don't install\n464:   --tag <tag>              Install a specific version (e.g., v0.1.0)\n465: \n466: Logs Options:\n467:   --tail N                 Show only the last N lines\n468:   --follow, -f             Stream new output as it arrives (like tail -f)\n469: \n470: Aliases (every command has a short form):\n471:   woco i                         woco init\n472:   woco l --all-ready             woco launch --all-ready\n473:   woco t ls                      woco tasks list\n474:   woco t a my-task \"Title\"       woco tasks add my-task \"Title\"\n475:   woco t ss my-task done         woco tasks set-status my-task done\n476: \n477: Shell Completion:\n478:   eval \"$(woco completion bash)\"    # Bash: add to ~/.bashrc\n479:   eval \"$(woco completion zsh)\"     # Zsh:  add to ~/.zshrc\n480:   woco completion fish | source     # Fish (or save to ~/.config/fish/completions/woco.fish)\n481: \n482: Examples:\n483:   woco init\n484:   woco launch --quickest-wins 3\n485:   woco launch --priority high --interactive\n486:   woco launch --tasks \"auth-flow,search-api\" --max-concurrent 2\n487:   woco resume\n488:   woco status\n489:   woco verify\n490:   woco merge\n491:   woco retry auth-flow\n492:   woco abort auth-flow\n493:   woco abort auth-flow --requeue\n494:   woco abort auth-flow --output json\n495:   woco logs auth-flow\n496:   woco logs auth-flow --tail 50\n497:   woco logs auth-flow --follow\n498:   woco logs auth-flow --output json\n499:   woco cleanup\n500:   woco tasks list --status ready --priority high\n501:   woco tasks list --fields id,status,priority --output json\n502:   woco tasks add my-task \"My Cool Task\" --priority high --difficulty easy\n503:   woco tasks set-status my-task in-progress\n504:   woco tasks check\n505:   woco tasks archive --dry-run\n506:   woco tasks show my-task\n507:   woco history\n508:   woco history wave-2026-03-12-420\n509:   woco history --output json\n510:   woco describe                           # list all commands as JSON\n511:   woco describe launch                    # describe a specific command\n512:   woco describe tasks add                 # describe a subcommand\n513: `);\n514: }\n515: \n516: // ---------------------------------------------------------------------------\n517: // Main\n518: // ---------------------------------------------------------------------------\n519: \n520: async function main(): Promise<void> {\n521:   checkDevModeGuard();\n522: \n523:   const PROJECT_ROOT = resolve(process.cwd());\n524:   const args = parseArgs(process.argv);\n525: \n526:   // -----------------------------------------------------------------------\n527:   // Input validation at the CLI boundary\n528:   // -----------------------------------------------------------------------\n529:   if (args.featureId) {\n530:     assertValid(validateId(args.featureId, \"feature ID\"));\n531:   }\n532:   if (args.title) {\n533:     assertValid(validateText(args.title, \"title\"));\n534:   }\n535:   if (args.description) {\n536:     assertValid(validateText(args.description, \"description\"));\n537:   }\n538:   if (args.baseBranch) {\n539:     assertValid(validateBranchName(args.baseBranch, \"base branch\"));\n540:   }\n541:   if (args.effort) {\n542:     assertValid(validateDuration(args.effort, \"effort\"));\n543:   }\n544:   if (args.tasks) {\n545:     for (const fid of args.tasks) {\n546:       assertValid(validateId(fid, \"task ID in --tasks\"));\n547:     }\n548:   }\n549:   if (args.dependsOn) {\n550:     for (const dep of args.dependsOn) {\n551:       assertValid(validateId(dep, \"dependency ID in --depends-on\"));\n552:     }\n553:   }\n554: \n555:   // Validate numeric args are not NaN\n556:   const numericArgs: [string, number | undefined][] = [\n557:     [\"--top-priority\", args.topPriority],\n558:     [\"--quickest-wins\", args.quickestWins],\n559:     [\"--max-concurrent\", args.maxConcurrent],\n560:     [\"--max-retries\", args.maxRetries],\n561:     [\"--tail\", args.tail],\n562:   ];\n563:   for (const [flag, value] of numericArgs) {\n564:     if (value !== undefined && isNaN(value)) {\n565:       console.error(`${flag} requires a numeric value.`);\n566:       process.exit(1);\n567:     }\n568:   }\n569: \n570:   // Commands that don't need config loading\n571:   if (args.command === \"version\" || args.command === \"-v\" || args.command === \"-V\") {\n572:     const pkgPath = resolve(import.meta.dir, \"..\", \"package.json\");\n573:     const pkgFile = Bun.file(pkgPath);\n574:     try {\n575:       const pkg = await pkgFile.json();\n576:       console.log(`wombo-combo ${pkg.version ?? \"(unknown version)\"}`);\n577:     } catch {\n578:       console.log(\"wombo-combo (unknown version)\");\n579:     }\n580:     return;\n581:   }\n582: \n583:   if (args.command === \"help\" || args.command === \"--help\" || args.command === \"-h\") {\n584:     cmdHelp();\n585:     return;\n586:   }\n587: \n588:   if (args.command === \"describe\") {\n589:     // Schema introspection: `woco describe [command]`\n590:     if (args.outputFmt === \"toon\") {\n591:       // Emit TOON format legend — self-describing, cacheable by agents\n592:       const pkgPath = resolve(import.meta.dir, \"..\", \"package.json\");\n593:       let version = \"unknown\";\n594:       try {\n595:         const pkg = await Bun.file(pkgPath).json();\n596:         version = pkg.version ?? \"unknown\";\n597:       } catch {}\n598: \n599:       if (!args.featureId) {\n600:         // Full TOON spec (legend + all commands)\n601:         console.log(renderToonLegend(version));\n602:       } else {\n603:         // JSON structure for the full spec (--output toon with a specific command\n604:         // still emits JSON since TOON is a line-oriented data format, not a schema format)\n605:         const spec = buildToonSpec(version);\n606:         const cmdName = args.title\n607:           ? `${args.featureId} ${args.title}`\n608:           : args.featureId;\n609:         const cmdSpec = spec.commands.find((c) => c.command === cmdName);\n610:         if (!cmdSpec) {\n611:           console.error(`Unknown command: \"${cmdName}\"`);\n612:           console.error(\"Run 'woco describe --output toon' to see the full TOON spec.\");\n613:           process.exit(1);\n614:           return;\n615:         }\n616:         console.log(JSON.stringify(cmdSpec, null, 2));\n617:       }\n618:       return;\n619:     }\n620: \n621:     if (!args.featureId) {\n622:       // No command specified — list all commands\n623:       console.log(JSON.stringify(allCommandSchemas(), null, 2));\n624:     } else {\n625:       // Describe a specific command. Handle compound names: \"features list\"\n626:       const cmdName = args.title\n627:         ? `${args.featureId} ${args.title}`\n628:         : args.featureId;\n629:       const def = findCommandDef(cmdName);\n630:       if (!def) {\n631:         console.error(`Unknown command: \"${cmdName}\"`);\n632:         console.error(\"Run 'woco describe' to list all commands.\");\n633:         process.exit(1);\n634:         return;\n635:       }\n636:       console.log(JSON.stringify(commandToSchema(def), null, 2));\n637:     }\n638:     return;\n639:   }\n640: \n641:   if (args.command === \"init\") {\n642:     await cmdInit({ projectRoot: PROJECT_ROOT, force: args.force });\n643:     return;\n644:   }\n645: \n646:   if (args.command === \"upgrade\") {\n647:     await cmdUpgrade({\n648:       force: args.force,\n649:       tag: args.tag,\n650:       checkOnly: args.checkOnly,\n651:     });\n652:     return;\n653:   }\n654: \n655:   if (args.command === \"completion\") {\n656:     cmdCompletion({ shell: args.featureId }); // first positional = shell name\n657:     return;\n658:   }\n659: \n660:   if (args.command === \"logs\") {\n661:     if (!args.featureId) {\n662:       console.error(\"Usage: woco logs <feature-id> [--tail N] [--follow] [--output json]\");\n663:       process.exit(1);\n664:       return;\n665:     }\n666:     await cmdLogs({\n667:       projectRoot: PROJECT_ROOT,\n668:       featureId: args.featureId,\n669:       tail: args.tail,\n670:       follow: args.follow,\n671:       outputFmt: args.outputFmt,\n672:     });\n673:     return;\n674:   }\n675: \n676:   // Everything else requires config\n677:   const config = loadConfig(PROJECT_ROOT);\n678:   validateConfig(config);\n679: \n680:   // Commands that operate on the tasks file — ensure it exists first\n681:   const needsTasksFile = new Set([\"launch\", \"resume\", \"verify\", \"retry\", \"tasks\"]);\n682:   if (needsTasksFile.has(args.command)) {\n683:     await ensureTasksFile(PROJECT_ROOT, config);\n684:   }\n685: \n686:   switch (args.command) {\n687:     case \"launch\":\n688:       // Apply browser verification override if --browser flag was passed\n689:       if (args.browser !== undefined) {\n690:         config.browser.enabled = args.browser;\n691:       }\n692:       await cmdLaunch({\n693:         projectRoot: PROJECT_ROOT,\n694:         config,\n695:         topPriority: args.topPriority,\n696:         quickestWins: args.quickestWins,\n697:         priority: args.priority,\n698:         difficulty: args.difficulty,\n699:         features: args.tasks,\n700:         allReady: args.allReady,\n701:         maxConcurrent: args.maxConcurrent ?? config.defaults.maxConcurrent,\n702:         model: args.model,\n703:         interactive: args.interactive,\n704:         dryRun: args.dryRun,\n705:         baseBranch: args.baseBranch ?? config.baseBranch,\n706:         maxRetries: args.maxRetries ?? config.defaults.maxRetries,\n707:         noTui: args.noTui,\n708:         autoPush: args.autoPush,\n709:         outputFmt: args.outputFmt,\n710:       });\n711:       break;\n712: \n713:     case \"resume\":\n714:       await cmdResume({\n715:         projectRoot: PROJECT_ROOT,\n716:         config,\n717:         maxConcurrent: args.maxConcurrent,\n718:         model: args.model,\n719:         interactive: args.interactive,\n720:         noTui: args.noTui,\n721:         autoPush: args.autoPush,\n722:         baseBranch: args.baseBranch,\n723:         maxRetries: args.maxRetries,\n724:         outputFmt: args.outputFmt,\n725:       });\n726:       break;\n727: \n728:     case \"status\":\n729:       await cmdStatus({ projectRoot: PROJECT_ROOT, config, outputFmt: args.outputFmt });\n730:       break;\n731: \n732:     case \"verify\":\n733:       await cmdVerify({\n734:         projectRoot: PROJECT_ROOT,\n735:         config,\n736:         featureId: args.featureId,\n737:         model: args.model,\n738:         maxRetries: args.maxRetries,\n739:         browserVerify: args.browser,\n740:         skipTests: args.skipTests,\n741:         strictTdd: args.strictTdd,\n742:         outputFmt: args.outputFmt,\n743:       });\n744:       break;\n745: \n746:     case \"merge\":\n747:       await cmdMerge({\n748:         projectRoot: PROJECT_ROOT,\n749:         config,\n750:         featureId: args.featureId,\n751:         autoPush: args.autoPush,\n752:         dryRun: args.dryRun,\n753:         model: args.model,\n754:         outputFmt: args.outputFmt,\n755:       });\n756:       break;\n757: \n758:     case \"retry\": {\n759:       if (!args.featureId) {\n760:         console.error(\"Usage: woco retry <feature-id>\");\n761:         process.exit(1);\n762:         return;\n763:       }\n764:       await cmdRetry({\n765:         projectRoot: PROJECT_ROOT,\n766:         config,\n767:         featureId: args.featureId,\n768:         model: args.model,\n769:         interactive: args.interactive,\n770:         dryRun: args.dryRun,\n771:         outputFmt: args.outputFmt,\n772:       });\n773:       break;\n774:     }\n775: \n776:     case \"cleanup\":\n777:       await cmdCleanup({ projectRoot: PROJECT_ROOT, config, dryRun: args.dryRun, outputFmt: args.outputFmt });\n778:       break;\n779: \n780:     case \"history\":\n781:       await cmdHistory({\n782:         projectRoot: PROJECT_ROOT,\n783:         config,\n784:         waveId: args.featureId,\n785:         outputFmt: args.outputFmt,\n786:       });\n787:       break;\n788: \n789:     case \"abort\": {\n790:       if (!args.featureId) {\n791:         console.error(\"Usage: woco abort <feature-id> [--requeue] [--output json]\");\n792:         process.exit(1);\n793:         return;\n794:       }\n795:       await cmdAbort({\n796:         projectRoot: PROJECT_ROOT,\n797:         config,\n798:         featureId: args.featureId,\n799:         requeue: args.requeue,\n800:         outputFmt: args.outputFmt,\n801:       });\n802:       break;\n803:     }\n804: \n805:     case \"tasks\":\n806:       await handleTasksSubcommand(args, PROJECT_ROOT, config);\n807:       break;\n808: \n809:     default:\n810:       console.error(`Unknown command: ${args.command}`);\n811:       cmdHelp();\n812:       process.exit(1);\n813:       return;\n814:   }\n815: }\n816: \n817: // ---------------------------------------------------------------------------\n818: // Tasks Subcommand Router\n819: // ---------------------------------------------------------------------------\n820: \n821: async function handleTasksSubcommand(\n822:   args: CLIArgs,\n823:   projectRoot: string,\n824:   config: import(\"./config.js\").WomboConfig\n825: ): Promise<void> {\n826:   switch (args.subcommand) {\n827:     case \"list\":\n828:       await cmdTasksList({\n829:         projectRoot,\n830:         config,\n831:         status: args.status as FeatureStatus | undefined,\n832:         priority: args.priority,\n833:         difficulty: args.difficulty,\n834:         ready: args.ready,\n835:         includeArchive: args.includeArchive,\n836:         outputFmt: args.outputFmt,\n837:         fields: args.fields,\n838:       });\n839:       break;\n840: \n841:     case \"add\": {\n842:       if (!args.featureId || !args.title) {\n843:         console.error(\"Usage: woco tasks add <id> <title> [--desc <desc>] [--priority <p>] [--difficulty <d>] [--effort <e>] [--depends-on <ids>]\");\n844:         process.exit(1);\n845:         return;\n846:       }\n847:       await cmdTasksAdd({\n848:         projectRoot,\n849:         config,\n850:         id: args.featureId,\n851:         title: args.title,\n852:         description: args.description,\n853:         priority: args.priority,\n854:         difficulty: args.difficulty,\n855:         effort: args.effort,\n856:         dependsOn: args.dependsOn,\n857:         outputFmt: args.outputFmt,\n858:         dryRun: args.dryRun,\n859:       });\n860:       break;\n861:     }\n862: \n863:     case \"set-status\": {\n864:       // The new status can come from the second positional (stored in args.title)\n865:       // or from the --status flag\n866:       const newStatus = args.title || args.status;\n867:       if (!args.featureId || !newStatus) {\n868:         console.error(\"Usage: woco tasks set-status <task-id> <status>\");\n869:         process.exit(1);\n870:         return;\n871:       }\n872:       await cmdTasksSetStatus({\n873:         projectRoot,\n874:         config,\n875:         featureId: args.featureId,\n876:         newStatus,\n877:         outputFmt: args.outputFmt,\n878:         dryRun: args.dryRun,\n879:       });\n880:       break;\n881:     }\n882: \n883:     case \"set-priority\": {\n884:       // The new priority can come from the second positional (stored in args.title)\n885:       // or from the --priority flag\n886:       const newPriority = args.title || (args.priority as string | undefined);\n887:       if (!args.featureId || !newPriority) {\n888:         console.error(\"Usage: woco tasks set-priority <task-id> <priority>\");\n889:         process.exit(1);\n890:         return;\n891:       }\n892:       await cmdTasksSetPriority({\n893:         projectRoot,\n894:         config,\n895:         featureId: args.featureId,\n896:         newPriority,\n897:         outputFmt: args.outputFmt,\n898:         dryRun: args.dryRun,\n899:       });\n900:       break;\n901:     }\n902: \n903:     case \"set-difficulty\": {\n904:       // The new difficulty can come from the second positional (stored in args.title)\n905:       // or from the --difficulty flag\n906:       const newDifficulty = args.title || (args.difficulty as string | undefined);\n907:       if (!args.featureId || !newDifficulty) {\n908:         console.error(\"Usage: woco tasks set-difficulty <task-id> <difficulty>\");\n909:         process.exit(1);\n910:         return;\n911:       }\n912:       await cmdTasksSetDifficulty({\n913:         projectRoot,\n914:         config,\n915:         featureId: args.featureId,\n916:         newDifficulty,\n917:         outputFmt: args.outputFmt,\n918:         dryRun: args.dryRun,\n919:       });\n920:       break;\n921:     }\n922: \n923:     case \"check\":\n924:       await cmdTasksCheck({ projectRoot, config, outputFmt: args.outputFmt });\n925:       break;\n926: \n927:     case \"archive\":\n928:       await cmdTasksArchive({\n929:         projectRoot,\n930:         config,\n931:         featureId: args.featureId,\n932:         dryRun: args.dryRun,\n933:         outputFmt: args.outputFmt,\n934:       });\n935:       break;\n936: \n937:     case \"show\": {\n938:       if (!args.featureId) {\n939:         console.error(\"Usage: woco tasks show <task-id>\");\n940:         process.exit(1);\n941:         return;\n942:       }\n943:       await cmdTasksShow({\n944:         projectRoot,\n945:         config,\n946:         featureId: args.featureId,\n947:         outputFmt: args.outputFmt,\n948:         fields: args.fields,\n949:       });\n950:       break;\n951:     }\n952: \n953:     case \"graph\":\n954:       await cmdTasksGraph({\n955:         projectRoot,\n956:         config,\n957:         status: args.status as FeatureStatus | undefined,\n958:         ascii: args.ascii,\n959:         mermaid: args.mermaidRaw,\n960:         subtasks: args.graphSubtasks,\n961:         outputFmt: args.outputFmt,\n962:       });\n963:       break;\n964: \n965:     case \"help\":\n966:     case \"--help\":\n967:     case \"-h\":\n968:       cmdHelp();\n969:       break;\n970: \n971:     default:\n972:       console.error(`Unknown tasks subcommand: ${args.subcommand}`);\n973:       console.error(\"Run 'woco tasks help' or 'woco help' for usage.\");\n974:       process.exit(1);\n975:       return;\n976:   }\n977: }\n978: \n979: // ---------------------------------------------------------------------------\n980: // Error Handlers & Entry\n981: // ---------------------------------------------------------------------------\n982: \n983: // Global error handlers — prevent silent crashes\n984: process.on(\"uncaughtException\", (err) => {\n985:   console.error(`\\n[FATAL] Uncaught exception: ${err.message}`);\n986:   console.error(err.stack);\n987:   try {\n988:     const state = loadState(process.cwd());\n989:     if (state) saveState(process.cwd(), state);\n990:   } catch {}\n991:   process.exit(1);\n992: });\n993: \n994: process.on(\"unhandledRejection\", (reason: any) => {\n995:   console.error(`\\n[FATAL] Unhandled rejection: ${reason?.message || reason}`);\n996:   if (reason?.stack) console.error(reason.stack);\n997:   try {\n998:     const state = loadState(process.cwd());\n999:     if (state) saveState(process.cwd(), state);\n1000:   } catch {}\n1001:   process.exit(1);\n1002: });\n1003: \n1004: main().catch((err) => {\n1005:   console.error(\"Fatal error:\", err.message);\n1006:   process.exit(1);\n1007: });\n\n(End of file - total 1007 lines)\n</content>","title":"src/index.ts","metadata":{"preview":"#!/usr/bin/env bun\n/**\n * index.ts — CLI entry point for the wombo-combo agent orchestration system.\n *\n * Every command has a short alias (e.g., woco i = woco init, woco t ls = woco tasks list).\n *\n * Usage:\n *   woco init                                         (alias: i)\n *   woco launch --top-priority 3                      (alias: l)\n *   woco launch --quickest-wins 5\n *   woco launch --priority high\n *   woco launch --difficulty easy\n *   woco launch --tasks \"feat-a,feat-b\"\n *   woco launch --all-ready\n *   woco launch ... --max-concurrent 3 --model \"anthropic/claude-sonnet-4-20250514\"\n *   woco launch ... --interactive\n *   woco resume                                       (alias: r)\n *   woco status                                       (alias: s)\n *   woco verify [feature-id]                          (alias: v)\n *   woco merge [feature-id]                           (alias: m)","truncated":false,"loaded":[]},"time":{"start":1773437435888,"end":1773437435891}}}}
