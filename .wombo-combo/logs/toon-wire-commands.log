t, config } = opts;\n42:   const fmt = opts.outputFmt ?? \"text\";\n43: \n44:   if (!opts.featureId || !opts.newPriority) {\n45:     outputError(fmt, `Usage: woco tasks set-priority <task-id> <priority>\\nValid priorities: ${VALID_PRIORITIES.join(\", \")}`);\n46:     return;\n47:   }\n48: \n49:   // Validate priority\n50:   if (!(VALID_PRIORITIES as readonly string[]).includes(opts.newPriority)) {\n51:     outputError(fmt, `Invalid priority: \"${opts.newPriority}\"\\nValid priorities: ${VALID_PRIORITIES.join(\", \")}`);\n52:     return;\n53:   }\n54: \n55:   const data = loadFeatures(projectRoot, config);\n56:   const feature = findFeatureById(data, opts.featureId);\n57: \n58:   if (!feature) {\n59:     outputError(fmt, `Task \"${opts.featureId}\" not found.`);\n60:     return;\n61:   }\n62: \n63:   const oldPriority = feature.priority;\n64:   const newPriority = opts.newPriority as Priority;\n65: \n66:   if (oldPriority === newPriority) {\n67:     outputMessage(fmt, `Task \"${opts.featureId}\" already has priority \"${newPriority}\".`, {\n68:       id: opts.featureId,\n69:       priority: newPriority,\n70:       changed: false,\n71:     });\n72:     return;\n73:   }\n74: \n75:   // Dry-run: show what would change without writing\n76:   if (opts.dryRun) {\n77:     outputMessage(fmt, `[dry-run] Would change \"${opts.featureId}\" priority: ${oldPriority} → ${newPriority}`, {\n78:       dry_run: true,\n79:       id: opts.featureId,\n80:       old_priority: oldPriority,\n81:       new_priority: newPriority,\n82:       changed: false,\n83:     });\n84:     return;\n85:   }\n86: \n87:   // Apply priority change\n88:   feature.priority = newPriority;\n89: \n90:   saveFeatures(projectRoot, config, data);\n91: \n92:   outputMessage(fmt, `Task \"${opts.featureId}\" priority: ${oldPriority} → ${newPriority}`, {\n93:     id: opts.featureId,\n94:     old_priority: oldPriority,\n95:     new_priority: newPriority,\n96:     changed: true,\n97:   });\n98: }\n\n(End of file - total 98 lines)\n</content>","title":"src/commands/tasks/set-priority.ts","metadata":{"preview":"/**\n * tasks/set-priority.ts — Change a task's priority.\n *\n * Usage:\n *   woco tasks set-priority <task-id> <priority>\n *\n * Valid priorities: critical, high, medium, low, wishlist\n *\n * Supports --output json and --dry-run.\n * Works on both top-level tasks and subtasks.\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  saveFeatures,\n  findFeatureById,\n  type Priority,\n} from \"../../lib/tasks.js\";\nimport { VALID_PRIORITIES } from \"../../lib/task-schema.js\";","truncated":false,"loaded":[]},"time":{"start":1773437457231,"end":1773437457233}}}}
{"type":"tool_use","timestamp":1773437457788,"sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","part":{"id":"prt_ce91c13500012n5hWir3q3Pa6k","sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","messageID":"msg_ce91bfb66001Q085JlGivl9xd8","type":"tool","callID":"toolu_vrtx_01AN8gzAGyt9tEFZ1sdHr8fR","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/tasks/set-difficulty.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/tasks/set-difficulty.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tasks/set-difficulty.ts — Change a task's difficulty.\n3:  *\n4:  * Usage:\n5:  *   woco tasks set-difficulty <task-id> <difficulty>\n6:  *\n7:  * Valid difficulties: trivial, easy, medium, hard, very_hard\n8:  *\n9:  * Supports --output json and --dry-run.\n10:  * Works on both top-level tasks and subtasks.\n11:  */\n12: \n13: import type { WomboConfig } from \"../../config.js\";\n14: import {\n15:   loadFeatures,\n16:   saveFeatures,\n17:   findFeatureById,\n18:   type Difficulty,\n19: } from \"../../lib/tasks.js\";\n20: import { VALID_DIFFICULTIES } from \"../../lib/task-schema.js\";\n21: import { outputError, outputMessage, type OutputFormat } from \"../../lib/output.js\";\n22: \n23: // ---------------------------------------------------------------------------\n24: // Types\n25: // ---------------------------------------------------------------------------\n26: \n27: export interface TasksSetDifficultyOptions {\n28:   projectRoot: string;\n29:   config: WomboConfig;\n30:   featureId: string;\n31:   newDifficulty: string;\n32:   outputFmt?: OutputFormat;\n33:   dryRun?: boolean;\n34: }\n35: \n36: // ---------------------------------------------------------------------------\n37: // Command\n38: // ---------------------------------------------------------------------------\n39: \n40: export async function cmdTasksSetDifficulty(opts: TasksSetDifficultyOptions): Promise<void> {\n41:   const { projectRoot, config } = opts;\n42:   const fmt = opts.outputFmt ?? \"text\";\n43: \n44:   if (!opts.featureId || !opts.newDifficulty) {\n45:     outputError(fmt, `Usage: woco tasks set-difficulty <task-id> <difficulty>\\nValid difficulties: ${VALID_DIFFICULTIES.join(\", \")}`);\n46:     return;\n47:   }\n48: \n49:   // Validate difficulty\n50:   if (!(VALID_DIFFICULTIES as readonly string[]).includes(opts.newDifficulty)) {\n51:     outputError(fmt, `Invalid difficulty: \"${opts.newDifficulty}\"\\nValid difficulties: ${VALID_DIFFICULTIES.join(\", \")}`);\n52:     return;\n53:   }\n54: \n55:   const data = loadFeatures(projectRoot, config);\n56:   const feature = findFeatureById(data, opts.featureId);\n57: \n58:   if (!feature) {\n59:     outputError(fmt, `Task \"${opts.featureId}\" not found.`);\n60:     return;\n61:   }\n62: \n63:   const oldDifficulty = feature.difficulty;\n64:   const newDifficulty = opts.newDifficulty as Difficulty;\n65: \n66:   if (oldDifficulty === newDifficulty) {\n67:     outputMessage(fmt, `Task \"${opts.featureId}\" already has difficulty \"${newDifficulty}\".`, {\n68:       id: opts.featureId,\n69:       difficulty: newDifficulty,\n70:       changed: false,\n71:     });\n72:     return;\n73:   }\n74: \n75:   // Dry-run: show what would change without writing\n76:   if (opts.dryRun) {\n77:     outputMessage(fmt, `[dry-run] Would change \"${opts.featureId}\" difficulty: ${oldDifficulty} → ${newDifficulty}`, {\n78:       dry_run: true,\n79:       id: opts.featureId,\n80:       old_difficulty: oldDifficulty,\n81:       new_difficulty: newDifficulty,\n82:       changed: false,\n83:     });\n84:     return;\n85:   }\n86: \n87:   // Apply difficulty change\n88:   feature.difficulty = newDifficulty;\n89: \n90:   saveFeatures(projectRoot, config, data);\n91: \n92:   outputMessage(fmt, `Task \"${opts.featureId}\" difficulty: ${oldDifficulty} → ${newDifficulty}`, {\n93:     id: opts.featureId,\n94:     old_difficulty: oldDifficulty,\n95:     new_difficulty: newDifficulty,\n96:     changed: true,\n97:   });\n98: }\n\n(End of file - total 98 lines)\n</content>","title":"src/commands/tasks/set-difficulty.ts","metadata":{"preview":"/**\n * tasks/set-difficulty.ts — Change a task's difficulty.\n *\n * Usage:\n *   woco tasks set-difficulty <task-id> <difficulty>\n *\n * Valid difficulties: trivial, easy, medium, hard, very_hard\n *\n * Supports --output json and --dry-run.\n * Works on both top-level tasks and subtasks.\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  saveFeatures,\n  findFeatureById,\n  type Difficulty,\n} from \"../../lib/tasks.js\";\nimport { VALID_DIFFICULTIES } from \"../../lib/task-schema.js\";","truncated":false,"loaded":[]},"time":{"start":1773437457786,"end":1773437457788}}}}
{"type":"tool_use","timestamp":1773437458287,"sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","part":{"id":"prt_ce91c1642001wd3S47WXWIVXbO","sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","messageID":"msg_ce91bfb66001Q085JlGivl9xd8","type":"tool","callID":"toolu_vrtx_01YaY3i94Y21qi71S3Qby13i","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/tasks/graph.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/tasks/graph.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tasks/graph.ts — Visualize the task dependency graph.\n3:  *\n4:  * Usage:\n5:  *   woco tasks graph                     # show full dependency graph\n6:  *   woco tasks graph --status backlog    # filter by status\n7:  *   woco tasks graph --ascii             # ASCII-only rendering\n8:  *   woco tasks graph --output json       # emit mermaid source as JSON\n9:  *   woco tasks graph --mermaid           # emit raw mermaid source text\n10:  *   woco tasks graph --subtasks          # include subtask-level nodes\n11:  *\n12:  * Builds a Mermaid flowchart from the tasks dependency graph and renders\n13:  * it as a Unicode box diagram in the terminal using mermaidtui.\n14:  */\n15: \n16: import type { WomboConfig } from \"../../config.js\";\n17: import {\n18:   loadFeatures,\n19:   type Feature,\n20:   type Subtask,\n21:   type FeatureStatus,\n22:   type FeaturesFile,\n23: } from \"../../lib/tasks.js\";\n24: import { output, type OutputFormat } from \"../../lib/output.js\";\n25: \n26: // mermaidtui has no type declarations — import the JS module directly\n27: // @ts-ignore — no .d.ts published\n28: import { renderMermaidToTui } from \"mermaidtui\";\n29: \n30: // ---------------------------------------------------------------------------\n31: // Types\n32: // ---------------------------------------------------------------------------\n33: \n34: export interface TasksGraphOptions {\n35:   projectRoot: string;\n36:   config: WomboConfig;\n37:   status?: FeatureStatus;\n38:   ascii?: boolean;\n39:   mermaid?: boolean;\n40:   subtasks?: boolean;\n41:   outputFmt?: OutputFormat;\n42: }\n43: \n44: // ---------------------------------------------------------------------------\n45: // Status styling for Mermaid classDef\n46: // ---------------------------------------------------------------------------\n47: \n48: // Short status badge for node labels\n49: const STATUS_BADGE: Record<FeatureStatus, string> = {\n50:   backlog: \"BL\",\n51:   planned: \"PL\",\n52:   in_progress: \"IP\",\n53:   blocked: \"BK\",\n54:   in_review: \"IR\",\n55:   done: \"DN\",\n56:   cancelled: \"XX\",\n57: };\n58: \n59: // ---------------------------------------------------------------------------\n60: // Mermaid generation\n61: // ---------------------------------------------------------------------------\n62: \n63: /**\n64:  * Sanitize a string for use inside Mermaid labels.\n65:  * Mermaid uses square brackets for labels — we need to escape them.\n66:  */\n67: function sanitizeLabel(s: string): string {\n68:   return s\n69:     .replace(/\"/g, \"'\")\n70:     .replace(/\\[/g, \"(\")\n71:     .replace(/\\]/g, \")\")\n72:     .replace(/\\n/g, \" \")\n73:     .slice(0, 40); // keep labels short for terminal rendering\n74: }\n75: \n76: /**\n77:  * Generate a safe Mermaid node ID from a feature/subtask ID.\n78:  * Mermaid IDs can't start with numbers and some chars are reserved.\n79:  */\n80: function nodeId(id: string): string {\n81:   return `n_${id.replace(/-/g, \"_\")}`;\n82: }\n83: \n84: /**\n85:  * Collect all node IDs that exist in the graph (for filtering dangling deps).\n86:  */\n87: function collectAllIds(\n88:   features: Feature[],\n89:   includeSubtasks: boolean\n90: ): Set<string> {\n91:   const ids = new Set<string>();\n92:   for (const f of features) {\n93:     ids.add(f.id);\n94:     if (includeSubtasks) {\n95:       collectSubtaskIds(f.subtasks, ids);\n96:     }\n97:   }\n98:   return ids;\n99: }\n100: \n101: function collectSubtaskIds(subtasks: Subtask[], ids: Set<string>): void {\n102:   for (const st of subtasks) {\n103:     ids.add(st.id);\n104:     collectSubtaskIds(st.subtasks, ids);\n105:   }\n106: }\n107: \n108: /**\n109:  * Build the Mermaid flowchart source from the features file.\n110:  * Only includes nodes that participate in at least one dependency edge.\n111:  * Orphan nodes (no deps and nothing depends on them) are excluded from\n112:  * the visual graph and returned separately for a compact summary.\n113:  */\n114: function buildMermaidSource(\n115:   data: FeaturesFile,\n116:   opts: { status?: FeatureStatus; subtasks?: boolean }\n117: ): { source: string; nodeCount: number; edgeCount: number; orphanCount: number; orphans: { id: string; title: string; status: FeatureStatus }[] } {\n118:   let features = [...data.tasks];\n119: \n120:   // Filter by status if requested\n121:   if (opts.status) {\n122:     features = features.filter((f) => f.status === opts.status);\n123:   }\n124: \n125:   if (features.length === 0) {\n126:     return { source: \"\", nodeCount: 0, edgeCount: 0, orphanCount: 0, orphans: [] };\n127:   }\n128: \n129:   const allIds = collectAllIds(features, !!opts.subtasks);\n130: \n131:   // --- First pass: collect all edges to determine connected nodes ---\n132:   const connectedIds = new Set<string>();\n133:   const edges: { from: string; to: string }[] = [];\n134: \n135:   for (const f of features) {\n136:     // Feature-level dependency edges\n137:     for (const dep of f.depends_on) {\n138:       if (allIds.has(dep)) {\n139:         edges.push({ from: dep, to: f.id });\n140:         connectedIds.add(dep);\n141:         connectedIds.add(f.id);\n142:       }\n143:     }\n144: \n145:     // Subtask edges (parent->child + subtask depends_on)\n146:     if (opts.subtasks && f.subtasks.length > 0) {\n147:       collectSubtaskEdges(f.subtasks, f.id, allIds, edges, connectedIds);\n148:     }\n149:   }\n150: \n151:   // If there are no edges at all, every feature is an orphan\n152:   if (edges.length === 0) {\n153:     const orphans = features.map((f) => ({ id: f.id, title: f.title, status: f.status }));\n154:     return { source: \"\", nodeCount: 0, edgeCount: 0, orphanCount: orphans.length, orphans };\n155:   }\n156: \n157:   // --- Second pass: emit only connected nodes and edges ---\n158:   const lines: string[] = [\"flowchart LR\"];\n159:   let nodeCount = 0;\n160:   const emittedNodes = new Set<string>();\n161:   const orphans: { id: string; title: string; status: FeatureStatus }[] = [];\n162: \n163:   // Helper to emit a node if it's connected and not yet emitted\n164:   const emitNode = (id: string, label: string) => {\n165:     if (!emittedNodes.has(id)) {\n166:       lines.push(`    ${nodeId(id)}[${label}]`);\n167:       emittedNodes.add(id);\n168:       nodeCount++;\n169:     }\n170:   };\n171: \n172:   for (const f of features) {\n173:     if (connectedIds.has(f.id)) {\n174:       const badge = STATUS_BADGE[f.status];\n175:       emitNode(f.id, `${badge} ${sanitizeLabel(f.title)}`);\n176:     } else if (!opts.subtasks || f.subtasks.length === 0) {\n177:       // Feature has no deps and nothing depends on it — it's an orphan\n178:       orphans.push({ id: f.id, title: f.title, status: f.status });\n179:     }\n180: \n181:     // Emit connected subtask nodes\n182:     if (opts.subtasks && f.subtasks.length > 0) {\n183:       emitConnectedSubtasks(f.subtasks, connectedIds, emittedNodes, emitNode, orphans);\n184:     }\n185:   }\n186: \n187:   // Emit all edges\n188:   for (const edge of edges) {\n189:     lines.push(`    ${nodeId(edge.from)} --> ${nodeId(edge.to)}`);\n190:   }\n191: \n192:   return {\n193:     source: lines.join(\"\\n\"),\n194:     nodeCount,\n195:     edgeCount: edges.length,\n196:     orphanCount: orphans.length,\n197:     orphans,\n198:   };\n199: }\n200: \n201: /**\n202:  * Recursively collect edges from subtasks (parent->child links + depends_on edges).\n203:  */\n204: function collectSubtaskEdges(\n205:   subtasks: Subtask[],\n206:   parentId: string,\n207:   allIds: Set<string>,\n208:   edges: { from: string; to: string }[],\n209:   connectedIds: Set<string>\n210: ): void {\n211:   for (const st of subtasks) {\n212:     // Parent -> subtask link always creates an edge\n213:     edges.push({ from: parentId, to: st.id });\n214:     connectedIds.add(parentId);\n215:     connectedIds.add(st.id);\n216: \n217:     // Subtask's own dependencies\n218:     for (const dep of st.depends_on) {\n219:       if (allIds.has(dep)) {\n220:         edges.push({ from: dep, to: st.id });\n221:         connectedIds.add(dep);\n222:         connectedIds.add(st.id);\n223:       }\n224:     }\n225: \n226:     // Recurse into nested subtasks\n227:     if (st.subtasks.length > 0) {\n228:       collectSubtaskEdges(st.subtasks, st.id, allIds, edges, connectedIds);\n229:     }\n230:   }\n231: }\n232: \n233: /**\n234:  * Emit subtask nodes that are connected, collect orphans.\n235:  */\n236: function emitConnectedSubtasks(\n237:   subtasks: Subtask[],\n238:   connectedIds: Set<string>,\n239:   emittedNodes: Set<string>,\n240:   emitNode: (id: string, label: string) => void,\n241:   orphans: { id: string; title: string; status: FeatureStatus }[]\n242: ): void {\n243:   for (const st of subtasks) {\n244:     if (connectedIds.has(st.id)) {\n245:       const badge = STATUS_BADGE[st.status];\n246:       emitNode(st.id, `${badge} ${sanitizeLabel(st.title)}`);\n247:     } else {\n248:       orphans.push({ id: st.id, title: st.title, status: st.status });\n249:     }\n250: \n251:     if (st.subtasks.length > 0) {\n252:       emitConnectedSubtasks(st.subtasks, connectedIds, emittedNodes, emitNode, orphans);\n253:     }\n254:   }\n255: }\n256: \n257: // ---------------------------------------------------------------------------\n258: // Text rendering helpers\n259: // ---------------------------------------------------------------------------\n260: \n261: const RESET = \"\\x1b[0m\";\n262: const BOLD = \"\\x1b[1m\";\n263: const DIM = \"\\x1b[2m\";\n264: const RED = \"\\x1b[31m\";\n265: const YELLOW = \"\\x1b[33m\";\n266: const GREEN = \"\\x1b[32m\";\n267: const CYAN = \"\\x1b[36m\";\n268: \n269: /**\n270:  * Print a legend explaining the status badges used in the graph.\n271:  */\n272: function printLegend(features: Feature[]): void {\n273:   const statuses = new Set<FeatureStatus>();\n274:   for (const f of features) {\n275:     statuses.add(f.status);\n276:   }\n277: \n278:   console.log(`\\n${BOLD}Legend:${RESET}`);\n279:   const legendItems: string[] = [];\n280:   for (const [status, badge] of Object.entries(STATUS_BADGE)) {\n281:     if (statuses.has(status as FeatureStatus)) {\n282:       legendItems.push(`  ${badge} = ${status}`);\n283:     }\n284:   }\n285:   console.log(legendItems.join(\"  |\"));\n286: }\n287: \n288: /**\n289:  * Detect potential issues in the dependency graph and print warnings.\n290:  */\n291: function printDiagnostics(data: FeaturesFile, includeSubtasks: boolean): void {\n292:   const allIds = collectAllIds(data.tasks, includeSubtasks);\n293:   const issues: string[] = [];\n294: \n295:   // Check for dangling dependencies (pointing to non-existent IDs)\n296:   for (const f of data.tasks) {\n297:     for (const dep of f.depends_on) {\n298:       if (!allIds.has(dep)) {\n299:         issues.push(`${YELLOW}WARNING${RESET}: ${f.id} depends on \"${dep}\" which does not exist`);\n300:       }\n301:     }\n302:     if (includeSubtasks) {\n303:       checkSubtaskDeps(f.subtasks, allIds, issues);\n304:     }\n305:   }\n306: \n307:   // Check for circular dependencies (simple DFS)\n308:   const circularPaths = detectCycles(data.tasks, includeSubtasks);\n309:   for (const cycle of circularPaths) {\n310:     issues.push(`${RED}CYCLE${RESET}: ${cycle.join(\" -> \")}`);\n311:   }\n312: \n313:   // Check for blocked features whose blockers are done\n314:   for (const f of data.tasks) {\n315:     if (f.status === \"blocked\") {\n316:       const allDepsDone = f.depends_on.every((dep: string) => {\n317:         const depFeature = data.tasks.find((ff: Feature) => ff.id === dep);\n318:         return depFeature?.status === \"done\";\n319:       });\n320:       if (allDepsDone && f.depends_on.length > 0) {\n321:         issues.push(\n322:           `${CYAN}INFO${RESET}: ${f.id} is marked \"blocked\" but all its dependencies are done`\n323:         );\n324:       }\n325:     }\n326:   }\n327: \n328:   if (issues.length > 0) {\n329:     console.log(`\\n${BOLD}Diagnostics (${issues.length} issue${issues.length > 1 ? \"s\" : \"\"}):${RESET}`);\n330:     for (const issue of issues) {\n331:       console.log(`  ${issue}`);\n332:     }\n333:   }\n334: }\n335: \n336: function checkSubtaskDeps(\n337:   subtasks: Subtask[],\n338:   allIds: Set<string>,\n339:   issues: string[]\n340: ): void {\n341:   for (const st of subtasks) {\n342:     for (const dep of st.depends_on) {\n343:       if (!allIds.has(dep)) {\n344:         issues.push(\n345:           `${YELLOW}WARNING${RESET}: subtask ${st.id} depends on \"${dep}\" which does not exist`\n346:         );\n347:       }\n348:     }\n349:     checkSubtaskDeps(st.subtasks, allIds, issues);\n350:   }\n351: }\n352: \n353: /**\n354:  * Detect circular dependencies using DFS.\n355:  * Returns arrays of ID paths that form cycles.\n356:  */\n357: function detectCycles(\n358:   features: Feature[],\n359:   includeSubtasks: boolean\n360: ): string[][] {\n361:   // Build adjacency list: dep -> [dependents]\n362:   const adj = new Map<string, string[]>();\n363:   const allItems = new Map<string, { depends_on: string[] }>();\n364: \n365:   for (const f of features) {\n366:     allItems.set(f.id, f);\n367:     if (includeSubtasks) {\n368:       collectSubtaskItems(f.subtasks, allItems);\n369:     }\n370:   }\n371: \n372:   for (const [id, item] of allItems) {\n373:     for (const dep of item.depends_on) {\n374:       if (!adj.has(id)) adj.set(id, []);\n375:       adj.get(id)!.push(dep);\n376:     }\n377:   }\n378: \n379:   const visited = new Set<string>();\n380:   const inStack = new Set<string>();\n381:   const cycles: string[][] = [];\n382: \n383:   function dfs(node: string, path: string[]): void {\n384:     if (inStack.has(node)) {\n385:       // Found a cycle — extract it\n386:       const cycleStart = path.indexOf(node);\n387:       cycles.push([...path.slice(cycleStart), node]);\n388:       return;\n389:     }\n390:     if (visited.has(node)) return;\n391: \n392:     visited.add(node);\n393:     inStack.add(node);\n394:     path.push(node);\n395: \n396:     for (const neighbor of adj.get(node) ?? []) {\n397:       dfs(neighbor, path);\n398:     }\n399: \n400:     path.pop();\n401:     inStack.delete(node);\n402:   }\n403: \n404:   for (const id of allItems.keys()) {\n405:     if (!visited.has(id)) {\n406:       dfs(id, []);\n407:     }\n408:   }\n409: \n410:   return cycles;\n411: }\n412: \n413: function collectSubtaskItems(\n414:   subtasks: Subtask[],\n415:   map: Map<string, { depends_on: string[] }>\n416: ): void {\n417:   for (const st of subtasks) {\n418:     map.set(st.id, st);\n419:     collectSubtaskItems(st.subtasks, map);\n420:   }\n421: }\n422: \n423: // ---------------------------------------------------------------------------\n424: // Command\n425: // ---------------------------------------------------------------------------\n426: \n427: export async function cmdTasksGraph(opts: TasksGraphOptions): Promise<void> {\n428:   const { projectRoot, config } = opts;\n429:   const data = loadFeatures(projectRoot, config);\n430:   const fmt = opts.outputFmt ?? \"text\";\n431: \n432:   const { source, nodeCount, edgeCount, orphanCount, orphans } = buildMermaidSource(data, {\n433:     status: opts.status,\n434:     subtasks: opts.subtasks,\n435:   });\n436: \n437:   if (nodeCount === 0 && orphanCount === 0) {\n438:     output(fmt, { graph: null, nodes: 0, edges: 0, message: \"No tasks to graph\" }, () => {\n439:       console.log(\"No tasks to graph.\");\n440:     });\n441:     return;\n442:   }\n443: \n444:   // --mermaid: emit raw mermaid source\n445:   if (opts.mermaid) {\n446:     output(fmt, { mermaid: source || null, nodes: nodeCount, edges: edgeCount, orphans }, () => {\n447:       if (source) {\n448:         console.log(source);\n449:       }\n450:       if (orphans.length > 0) {\n451:         console.log(`\\n# ${orphans.length} orphan(s) with no dependency relationships:`);\n452:         for (const o of orphans) {\n453:           console.log(`# ${STATUS_BADGE[o.status]} ${o.id}: ${o.title}`);\n454:         }\n455:       }\n456:     });\n457:     return;\n458:   }\n459: \n460:   // --output json: emit structured data\n461:   if (fmt === \"json\") {\n462:     const rendered = source ? renderMermaidToTui(source, { ascii: true }) as string : null;\n463:     console.log(\n464:       JSON.stringify({\n465:         mermaid: source || null,\n466:         rendered,\n467:         nodes: nodeCount,\n468:         edges: edgeCount,\n469:         orphan_count: orphanCount,\n470:         orphans,\n471:       })\n472:     );\n473:     return;\n474:   }\n475: \n476:   // Default: render the graph in the terminal\n477:   console.log(`\\n${BOLD}Task Dependency Graph${RESET}`);\n478: \n479:   if (nodeCount > 0 && source) {\n480:     const rendered = renderMermaidToTui(source, { ascii: !!opts.ascii }) as string;\n481:     console.log(`${DIM}${nodeCount} nodes, ${edgeCount} edges${RESET}\\n`);\n482:     console.log(rendered);\n483:   } else {\n484:     console.log(`${DIM}No dependency relationships found.${RESET}`);\n485:   }\n486: \n487:   // Print orphan summary\n488:   if (orphans.length > 0) {\n489:     console.log(`\\n${BOLD}Standalone tasks${RESET} ${DIM}(${orphans.length} with no dependencies):${RESET}`);\n490:     for (const o of orphans) {\n491:       const badge = STATUS_BADGE[o.status];\n492:       console.log(`  ${DIM}${badge}${RESET} ${o.id} ${DIM}— ${o.title}${RESET}`);\n493:     }\n494:   }\n495: \n496:   // Print legend and diagnostics\n497:   printLegend(data.tasks);\n498:   printDiagnostics(data, !!opts.subtasks);\n499:   console.log(\"\");\n500: }\n\n(End of file - total 500 lines)\n</content>","title":"src/commands/tasks/graph.ts","metadata":{"preview":"/**\n * tasks/graph.ts — Visualize the task dependency graph.\n *\n * Usage:\n *   woco tasks graph                     # show full dependency graph\n *   woco tasks graph --status backlog    # filter by status\n *   woco tasks graph --ascii             # ASCII-only rendering\n *   woco tasks graph --output json       # emit mermaid source as JSON\n *   woco tasks graph --mermaid           # emit raw mermaid source text\n *   woco tasks graph --subtasks          # include subtask-level nodes\n *\n * Builds a Mermaid flowchart from the tasks dependency graph and renders\n * it as a Unicode box diagram in the terminal using mermaidtui.\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  type Feature,\n  type Subtask,","truncated":false,"loaded":[]},"time":{"start":1773437458284,"end":1773437458286}}}}
