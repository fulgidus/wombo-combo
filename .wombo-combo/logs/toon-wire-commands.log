ver read.","severity":4,"code":6133,"source":"typescript"}],"/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/tasks/add.ts":[{"range":{"start":{"line":53,"character":4},"end":{"line":53,"character":10}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":58,"character":4},"end":{"line":58,"character":10}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":66,"character":6},"end":{"line":66,"character":12}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":74,"character":6},"end":{"line":74,"character":12}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":84,"character":4},"end":{"line":84,"character":10}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":92,"character":8},"end":{"line":92,"character":14}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"}],"/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/tasks/archive.ts":[{"range":{"start":{"line":60,"character":8},"end":{"line":60,"character":14}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"}],"/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/tasks/set-status.ts":[{"range":{"start":{"line":42,"character":4},"end":{"line":42,"character":10}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":48,"character":4},"end":{"line":48,"character":10}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":56,"character":4},"end":{"line":56,"character":10}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"}],"/home/fulgidus/Documents/wt-w