{"type":"tool_use","timestamp":1773437450994,"sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","part":{"id":"prt_ce91bf976001v8oFKl919gH0d0","sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","messageID":"msg_ce91bdf85001tydxXpQ6m4jZxZ","type":"tool","callID":"toolu_vrtx_016ASecJcf1oaKiyu4wqdtKn","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/tasks/check.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/tasks/check.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tasks/check.ts — Validate the tasks file for schema issues, broken deps, and orphans.\n3:  *\n4:  * Usage:\n5:  *   woco tasks check\n6:  *\n7:  * Checks:\n8:  *   - Required fields present on every task\n9:  *   - No duplicate IDs\n10:  *   - All depends_on references point to existing tasks\n11:  *   - No circular dependencies\n12:  *   - No orphaned subtasks (subtask IDs unique)\n13:  *   - Priority/difficulty values are valid enums\n14:  *   - Effort strings are parseable ISO 8601 durations\n15:  */\n16: \n17: import type { WomboConfig } from \"../../config.js\";\n18: import {\n19:   loadFeatures,\n20:   allFeatureIds,\n21:   parseDurationMinutes,\n22:   type Feature,\n23:   type Subtask,\n24:   type FeaturesFile,\n25: } from \"../../lib/tasks.js\";\n26: import {\n27:   VALID_STATUSES,\n28:   VALID_PRIORITIES,\n29:   VALID_DIFFICULTIES,\n30: } from \"../../lib/task-schema.js\";\n31: import { output, type OutputFormat } from \"../../lib/output.js\";\n32: import { renderTasksCheck } from \"../../lib/toon.js\";\n33: \n34: // ---------------------------------------------------------------------------\n35: // Types\n36: // ---------------------------------------------------------------------------\n37: \n38: export interface TasksCheckOptions {\n39:   projectRoot: string;\n40:   config: WomboConfig;\n41:   outputFmt?: OutputFormat;\n42: }\n43: \n44: interface CheckResult {\n45:   errors: string[];\n46:   warnings: string[];\n47: }\n48: \n49: // ---------------------------------------------------------------------------\n50: // Validation (enums imported from task-schema.ts — single source of truth)\n51: // ---------------------------------------------------------------------------\n52: \n53: function collectAllItems(data: FeaturesFile): (Feature | Subtask)[] {\n54:   const items: (Feature | Subtask)[] = [];\n55:   const collect = (list: (Feature | Subtask)[]) => {\n56:     for (const item of list) {\n57:       items.push(item);\n58:       if (item.subtasks?.length) collect(item.subtasks);\n59:     }\n60:   };\n61:   collect(data.tasks ?? []);\n62:   collect(data.archive ?? []);\n63:   return items;\n64: }\n65: \n66: function checkTasks(data: FeaturesFile): CheckResult {\n67:   const errors: string[] = [];\n68:   const warnings: string[] = [];\n69:   const allItems = collectAllItems(data);\n70:   const allIds = allItems.map((i) => i.id);\n71:   const idSet = new Set<string>();\n72: \n73:   // Check for duplicates\n74:   for (const id of allIds) {\n75:     if (idSet.has(id)) {\n76:       errors.push(`Duplicate ID: \"${id}\"`);\n77:     }\n78:     idSet.add(id);\n79:   }\n80: \n81:   // Check each item\n82:   for (const item of allItems) {\n83:     const prefix = `[${item.id}]`;\n84: \n85:     // Required fields\n86:     if (!item.id) errors.push(`${prefix} Missing required field: id`);\n87:     if (!item.title) errors.push(`${prefix} Missing required field: title`);\n88:     if (!item.status) errors.push(`${prefix} Missing required field: status`);\n89: \n90:     // Validate enum values\n91:     if (item.status && !(VALID_STATUSES as readonly string[]).includes(item.status)) {\n92:       errors.push(`${prefix} Invalid status: \"${item.status}\"`);\n93:     }\n94:     if (item.priority && !(VALID_PRIORITIES as readonly string[]).includes(item.priority)) {\n95:       errors.push(`${prefix} Invalid priority: \"${item.priority}\"`);\n96:     }\n97:     if (item.difficulty && !(VALID_DIFFICULTIES as readonly string[]).includes(item.difficulty)) {\n98:       errors.push(`${prefix} Invalid difficulty: \"${item.difficulty}\"`);\n99:     }\n100: \n101:     // Validate effort\n102:     if (item.effort) {\n103:       const minutes = parseDurationMinutes(item.effort);\n104:       if (minutes === Infinity) {\n105:         warnings.push(`${prefix} Unparseable effort duration: \"${item.effort}\"`);\n106:       }\n107:     }\n108: \n109:     // Check depends_on references\n110:     if (item.depends_on?.length) {\n111:       for (const dep of item.depends_on) {\n112:         if (!idSet.has(dep)) {\n113:           errors.push(`${prefix} Broken dependency: \"${dep}\" does not exist`);\n114:         }\n115:       }\n116:     }\n117:   }\n118: \n119:   // Check for circular dependencies (simple DFS)\n120:   const visited = new Set<string>();\n121:   const visiting = new Set<string>();\n122:   const depMap = new Map<string, string[]>();\n123:   for (const item of allItems) {\n124:     depMap.set(item.id, item.depends_on ?? []);\n125:   }\n126: \n127:   function hasCycle(id: string): boolean {\n128:     if (visiting.has(id)) return true;\n129:     if (visited.has(id)) return false;\n130:     visiting.add(id);\n131:     for (const dep of depMap.get(id) ?? []) {\n132:       if (hasCycle(dep)) {\n133:         errors.push(`Circular dependency detected involving: \"${id}\" → \"${dep}\"`);\n134:         return true;\n135:       }\n136:     }\n137:     visiting.delete(id);\n138:     visited.add(id);\n139:     return false;\n140:   }\n141: \n142:   for (const id of idSet) {\n143:     hasCycle(id);\n144:   }\n145: \n146:   // Warn about features with no effort estimate\n147:   for (const item of allItems) {\n148:     if (!item.effort || item.effort === \"PT0S\") {\n149:       warnings.push(`[${item.id}] No effort estimate`);\n150:     }\n151:   }\n152: \n153:   return { errors, warnings };\n154: }\n155: \n156: // ---------------------------------------------------------------------------\n157: // Command\n158: // ---------------------------------------------------------------------------\n159: \n160: export async function cmdTasksCheck(opts: TasksCheckOptions): Promise<void> {\n161:   const { projectRoot, config } = opts;\n162:   const fmt = opts.outputFmt ?? \"text\";\n163: \n164:   const data = loadFeatures(projectRoot, config);\n165:   const result = checkTasks(data);\n166: \n167:   const allItems = collectAllItems(data);\n168:   const issues = [\n169:     ...result.errors.map((msg) => ({ level: \"error\" as const, message: msg })),\n170:     ...result.warnings.map((msg) => ({ level: \"warning\" as const, message: msg })),\n171:   ];\n172:   const ok = result.errors.length === 0;\n173: \n174:   const checkData = {\n175:     ok,\n176:     issues,\n177:     items_checked: allItems.length,\n178:   };\n179: \n180:   output(\n181:     fmt,\n182:     checkData,\n183:     () => {\n184:       console.log(`\\nChecking ${config.tasksDir}/ (${allItems.length} items)...\\n`);\n185: \n186:       if (result.errors.length === 0 && result.warnings.length === 0) {\n187:         console.log(\"  All checks passed. No issues found.\");\n188:         return;\n189:       }\n190: \n191:       if (result.errors.length > 0) {\n192:         console.log(`  ERRORS (${result.errors.length}):`);\n193:         for (const e of result.errors) {\n194:           console.log(`    \\x1b[31m✗\\x1b[0m ${e}`);\n195:         }\n196:         console.log(\"\");\n197:       }\n198: \n199:       if (result.warnings.length > 0) {\n200:         console.log(`  WARNINGS (${result.warnings.length}):`);\n201:         for (const w of result.warnings) {\n202:           console.log(`    \\x1b[33m⚠\\x1b[0m ${w}`);\n203:         }\n204:         console.log(\"\");\n205:       }\n206:     },\n207:     () => {\n208:       // TOON renderer\n209:       console.log(renderTasksCheck(checkData));\n210:     }\n211:   );\n212: \n213:   if (result.errors.length > 0) {\n214:     process.exit(1);\n215:   }\n216: }\n\n(End of file - total 216 lines)\n</content>","title":"src/commands/tasks/check.ts","metadata":{"preview":"/**\n * tasks/check.ts — Validate the tasks file for schema issues, broken deps, and orphans.\n *\n * Usage:\n *   woco tasks check\n *\n * Checks:\n *   - Required fields present on every task\n *   - No duplicate IDs\n *   - All depends_on references point to existing tasks\n *   - No circular dependencies\n *   - No orphaned subtasks (subtask IDs unique)\n *   - Priority/difficulty values are valid enums\n *   - Effort strings are parseable ISO 8601 durations\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  allFeatureIds,","truncated":false,"loaded":[]},"time":{"start":1773437450989,"end":1773437450993}}}}
