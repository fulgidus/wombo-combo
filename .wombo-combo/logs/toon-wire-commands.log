{"type":"tool_use","timestamp":1773437520251,"sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","part":{"id":"prt_ce91d06a7001lPhFx2JIImy6Fc","sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","messageID":"msg_ce91cfdf2001i90vLI2WOKskxY","type":"tool","callID":"toolu_vrtx_0126DFi5eU542qCxXde1wnsk","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/verify.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/verify.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * verify.ts — Run build verification on completed agents.\n3:  *\n4:  * Usage: woco verify [feature-id] [--browser] [--skip-tests] [--strict-tdd] [--output json]\n5:  *\n6:  * Runs the build command in each completed agent's worktree. If a specific\n7:  * feature-id is given, verifies only that agent. Otherwise verifies all\n8:  * agents with status \"completed\".\n9:  *\n10:  * When --browser is passed (or browser.enabled is true in config), also\n11:  * runs browser-based verification after the build passes.\n12:  *\n13:  * When TDD is enabled (tdd.enabled in config), also runs tests and checks\n14:  * for test coverage of new files. Use --skip-tests to skip or --strict-tdd\n15:  * to fail on missing tests.\n16:  */\n17: \n18: import type { WomboConfig } from \"../config.js\";\n19: import { loadFeatures, type Feature } from \"../lib/tasks.js\";\n20: import { loadState } from \"../lib/state.js\";\n21: import { printDashboard } from \"../lib/ui.js\";\n22: import { handleBuildVerification } from \"./launch.js\";\n23: import { output, outputMessage, type OutputFormat } from \"../lib/output.js\";\n24: \n25: // ---------------------------------------------------------------------------\n26: // Types\n27: // ---------------------------------------------------------------------------\n28: \n29: export interface VerifyCommandOptions {\n30:   projectRoot: string;\n31:   config: WomboConfig;\n32:   featureId?: string;\n33:   model?: string;\n34:   maxRetries?: number;\n35:   /** Enable browser verification (overrides config.browser.enabled) */\n36:   browserVerify?: boolean;\n37:   /** Skip running tests during TDD verification */\n38:   skipTests?: boolean;\n39:   /** Strict TDD mode: fail verification if new files are missing tests */\n40:   strictTdd?: boolean;\n41:   outputFmt?: OutputFormat;\n42: }\n43: \n44: // ---------------------------------------------------------------------------\n45: // Command\n46: // ---------------------------------------------------------------------------\n47: \n48: export async function cmdVerify(opts: VerifyCommandOptions): Promise<void> {\n49:   const { projectRoot, config } = opts;\n50:   const fmt = opts.outputFmt ?? \"text\";\n51: \n52:   // Apply browser verification override if --browser flag was passed\n53:   if (opts.browserVerify !== undefined) {\n54:     config.browser.enabled = opts.browserVerify;\n55:   }\n56: \n57:   // Apply TDD overrides from CLI flags\n58:   if (opts.strictTdd !== undefined) {\n59:     config.tdd.strictTdd = opts.strictTdd;\n60:   }\n61: \n62:   const state = loadState(projectRoot);\n63:   if (!state) {\n64:     outputMessage(fmt, \"No active wave.\", {\n65:       wave_id: null,\n66:       agents: [],\n67:       verified: 0,\n68:     });\n69:     return;\n70:   }\n71: \n72:   const toVerify = opts.featureId\n73:     ? state.agents.filter((a) => a.feature_id === opts.featureId)\n74:     : state.agents.filter((a) => a.status === \"completed\");\n75: \n76:   if (toVerify.length === 0) {\n77:     outputMessage(fmt, \"No agents to verify.\", {\n78:       wave_id: state.wave_id,\n79:       agents: [],\n80:       verified: 0,\n81:     });\n82:     return;\n83:   }\n84: \n85:   if (fmt === \"text\") {\n86:     console.log(`\\nVerifying ${toVerify.length} agent(s)...\\n`);\n87:   }\n88: \n89:   const data = loadFeatures(projectRoot, config);\n90: \n91:   for (const agent of toVerify) {\n92:     const feature = data.tasks.find((f: Feature) => f.id === agent.feature_id);\n93:     if (!feature) continue;\n94: \n95:     await handleBuildVerification(\n96:       projectRoot,\n97:       state,\n98:       agent,\n99:       feature,\n100:       config,\n101:       opts.model,\n102:       undefined, // monitor\n103:       { skipTests: opts.skipTests, strictTdd: opts.strictTdd }\n104:     );\n105:   }\n106: \n107:   // Collect results for JSON output\n108:   const results = toVerify.map((agent) => {\n109:     // Re-read agent state after verification (it was mutated in place)\n110:     const updatedAgent = state.agents.find((a) => a.feature_id === agent.feature_id);\n111:     return {\n112:       feature_id: agent.feature_id,\n113:       branch: agent.branch,\n114:       status: updatedAgent?.status ?? agent.status,\n115:       build_passed: updatedAgent?.build_passed ?? agent.build_passed,\n116:       error: updatedAgent?.error ?? agent.error,\n117:     };\n118:   });\n119: \n120:   output(fmt, {\n121:     wave_id: state.wave_id,\n122:     verified: results.filter((r) => r.status === \"verified\").length,\n123:     failed: results.filter((r) => r.status === \"failed\").length,\n124:     agents: results,\n125:   }, () => {\n126:     printDashboard(state);\n127:   });\n128: }\n\n(End of file - total 128 lines)\n</content>","title":"src/commands/verify.ts","metadata":{"preview":"/**\n * verify.ts — Run build verification on completed agents.\n *\n * Usage: woco verify [feature-id] [--browser] [--skip-tests] [--strict-tdd] [--output json]\n *\n * Runs the build command in each completed agent's worktree. If a specific\n * feature-id is given, verifies only that agent. Otherwise verifies all\n * agents with status \"completed\".\n *\n * When --browser is passed (or browser.enabled is true in config), also\n * runs browser-based verification after the build passes.\n *\n * When TDD is enabled (tdd.enabled in config), also runs tests and checks\n * for test coverage of new files. Use --skip-tests to skip or --strict-tdd\n * to fail on missing tests.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport { loadFeatures, type Feature } from \"../lib/tasks.js\";\nimport { loadState } from \"../lib/state.js\";","truncated":false,"loaded":[]},"time":{"start":1773437520248,"end":1773437520250}}}}
