{"type":"tool_use","timestamp":1773437441181,"sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","part":{"id":"prt_ce91bd110001Ffa4TDhTCw4nTb","sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","messageID":"msg_ce91bc07c001ZkLD9a3R3A8KM7","type":"tool","callID":"toolu_vrtx_01KKQ2xdXZgkWfDX7XHKMCUf","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/status.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/status.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * status.ts — Show the status of the current wave.\n3:  *\n4:  * Usage:\n5:  *   woco status                  # human-readable dashboard\n6:  *   woco status --output json    # structured JSON for programmatic access\n7:  *\n8:  * Loads the wave state, checks for dead processes, and prints a dashboard\n9:  * or emits structured JSON with wave metadata, agent states, timing info,\n10:  * and summary statistics.\n11:  */\n12: \n13: import type { WomboConfig } from \"../config.js\";\n14: import { loadState, saveState, updateAgent, agentCounts, isWaveComplete } from \"../lib/state.js\";\n15: import type { WaveState, AgentState, AgentStatus } from \"../lib/state.js\";\n16: import { isProcessRunning } from \"../lib/launcher.js\";\n17: import { branchHasChanges } from \"../lib/worktree.js\";\n18: import { printDashboard } from \"../lib/ui.js\";\n19: import { output, outputMessage, type OutputFormat } from \"../lib/output.js\";\n20: import { renderStatus } from \"../lib/toon.js\";\n21: \n22: export interface StatusOptions {\n23:   projectRoot: string;\n24:   config: WomboConfig;\n25:   outputFmt?: OutputFormat;\n26: }\n27: \n28: // ---------------------------------------------------------------------------\n29: // JSON Output Builder\n30: // ---------------------------------------------------------------------------\n31: \n32: /**\n33:  * Compute elapsed time in milliseconds from a start ISO timestamp to now.\n34:  */\n35: function elapsedMs(startedAt: string | null): number | null {\n36:   if (!startedAt) return null;\n37:   return Date.now() - new Date(startedAt).getTime();\n38: }\n39: \n40: /**\n41:  * Format milliseconds as a human-readable duration string (e.g. \"2h15m\", \"3m\").\n42:  */\n43: function formatElapsed(ms: number | null): string | null {\n44:   if (ms === null) return null;\n45:   const mins = Math.floor(ms / 60000);\n46:   if (mins < 60) return `${mins}m`;\n47:   const hours = Math.floor(mins / 60);\n48:   const remMins = mins % 60;\n49:   return `${hours}h${remMins}m`;\n50: }\n51: \n52: /**\n53:  * Build the structured JSON representation of an agent's state.\n54:  */\n55: function agentToJson(agent: AgentState): Record<string, unknown> {\n56:   const elapsed = elapsedMs(agent.started_at);\n57:   return {\n58:     feature_id: agent.feature_id,\n59:     branch: agent.branch,\n60:     worktree: agent.worktree,\n61:     status: agent.status,\n62:     pid: agent.pid,\n63:     retries: agent.retries,\n64:     max_retries: agent.max_retries,\n65:     started_at: agent.started_at,\n66:     completed_at: agent.completed_at,\n67:     elapsed_ms: elapsed,\n68:     elapsed_formatted: formatElapsed(elapsed),\n69:     build_passed: agent.build_passed,\n70:     error: agent.error,\n71:     activity: agent.activity,\n72:     activity_updated_at: agent.activity_updated_at,\n73:     effort_estimate_ms: agent.effort_estimate_ms,\n74:   };\n75: }\n76: \n77: /**\n78:  * Build the full structured JSON for the wave status.\n79:  * Schema:\n80:  *   {\n81:  *     wave_id: string,\n82:  *     base_branch: string,\n83:  *     started_at: string (ISO 8601),\n84:  *     updated_at: string (ISO 8601),\n85:  *     elapsed_ms: number,\n86:  *     elapsed_formatted: string,\n87:  *     max_concurrent: number,\n88:  *     model: string | null,\n89:  *     interactive: boolean,\n90:  *     is_complete: boolean,\n91:  *     agents: Agent[],\n92:  *     summary: { total, queued, installing, running, completed, verified, failed, merged, retry, resolving_conflict }\n93:  *   }\n94:  */\n95: function buildStatusJson(state: WaveState): Record<string, unknown> {\n96:   const counts = agentCounts(state);\n97:   const waveElapsed = elapsedMs(state.started_at);\n98: \n99:   return {\n100:     wave_id: state.wave_id,\n101:     base_branch: state.base_branch,\n102:     started_at: state.started_at,\n103:     updated_at: state.updated_at,\n104:     elapsed_ms: waveElapsed,\n105:     elapsed_formatted: formatElapsed(waveElapsed),\n106:     max_concurrent: state.max_concurrent,\n107:     model: state.model,\n108:     interactive: state.interactive,\n109:     is_complete: isWaveComplete(state),\n110:     agents: state.agents.map(agentToJson),\n111:     summary: {\n112:       total: state.agents.length,\n113:       ...counts,\n114:     },\n115:   };\n116: }\n117: \n118: // ---------------------------------------------------------------------------\n119: // Command\n120: // ---------------------------------------------------------------------------\n121: \n122: export async function cmdStatus(opts: StatusOptions): Promise<void> {\n123:   const fmt = opts.outputFmt ?? \"text\";\n124:   const state = loadState(opts.projectRoot);\n125: \n126:   if (!state) {\n127:     outputMessage(fmt, \"No active wave. Use 'woco launch' to start one.\", {\n128:       wave_id: null,\n129:       agents: [],\n130:       summary: { total: 0 },\n131:     });\n132:     return;\n133:   }\n134: \n135:   // Update running agent status from process state\n136:   for (const agent of state.agents) {\n137:     if (agent.status === \"running\" && agent.pid) {\n138:       if (!isProcessRunning(agent.pid)) {\n139:         // Check if the agent actually made any commits before marking completed\n140:         if (branchHasChanges(opts.projectRoot, agent.branch, state.base_branch)) {\n141:           updateAgent(state, agent.feature_id, {\n142:             status: \"completed\",\n143:             completed_at: new Date().toISOString(),\n144:           });\n145:         } else {\n146:           // Agent died without producing any code — mark as failed, not completed\n147:           updateAgent(state, agent.feature_id, {\n148:             status: \"failed\",\n149:             error: \"Agent process exited without making any commits\",\n150:             completed_at: new Date().toISOString(),\n151:           });\n152:         }\n153:       }\n154:     }\n155:   }\n156: \n157:   // Repair pass: re-check agents marked \"completed\" but never verified.\n158:   // Catches agents falsely promoted to completed by older versions of status.ts\n159:   // that didn't check branchHasChanges.\n160:   for (const agent of state.agents) {\n161:     if (agent.status === \"completed\" && agent.build_passed === null) {\n162:       if (!branchHasChanges(opts.projectRoot, agent.branch, state.base_branch)) {\n163:         updateAgent(state, agent.feature_id, {\n164:           status: \"failed\",\n165:           error: \"Agent process exited without making any commits\",\n166:         });\n167:       }\n168:     }\n169:   }\n170:   saveState(opts.projectRoot, state);\n171: \n172:   output(fmt, buildStatusJson(state), () => {\n173:     printDashboard(state);\n174:   }, () => {\n175:     // TOON renderer\n176:     console.log(renderStatus(state));\n177:   });\n178: }\n\n(End of file - total 178 lines)\n</content>","title":"src/commands/status.ts","metadata":{"preview":"/**\n * status.ts — Show the status of the current wave.\n *\n * Usage:\n *   woco status                  # human-readable dashboard\n *   woco status --output json    # structured JSON for programmatic access\n *\n * Loads the wave state, checks for dead processes, and prints a dashboard\n * or emits structured JSON with wave metadata, agent states, timing info,\n * and summary statistics.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport { loadState, saveState, updateAgent, agentCounts, isWaveComplete } from \"../lib/state.js\";\nimport type { WaveState, AgentState, AgentStatus } from \"../lib/state.js\";\nimport { isProcessRunning } from \"../lib/launcher.js\";\nimport { branchHasChanges } from \"../lib/worktree.js\";\nimport { printDashboard } from \"../lib/ui.js\";\nimport { output, outputMessage, type OutputFormat } from \"../lib/output.js\";\nimport { renderStatus } from \"../lib/toon.js\";","truncated":false,"loaded":[]},"time":{"start":1773437441177,"end":1773437441180}}}}
{"type":"tool_use","timestamp":1773437441606,"sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","part":{"id":"prt_ce91bd49a001ejhOEKSwOdQb2g","sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","messageID":"msg_ce91bc07c001ZkLD9a3R3A8KM7","type":"tool","callID":"toolu_vrtx_01Tnw8fdHYpMP9UYemeJHDUb","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/history.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/history.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * history.ts — View wave history and summaries.\n3:  *\n4:  * Usage:\n5:  *   woco history                    List all past waves\n6:  *   woco history <wave-id>          Show details of a specific wave\n7:  *   woco history --output json      Output as JSON\n8:  *\n9:  * Wave history is stored in .wombo-combo/history/<wave-id>.json and survives\n10:  * `woco cleanup`. Records are auto-exported when a wave completes.\n11:  */\n12: \n13: import type { WomboConfig } from \"../config.js\";\n14: import {\n15:   listHistory,\n16:   loadHistory,\n17:   type WaveHistoryRecord,\n18: } from \"../lib/history.js\";\n19: import { output, outputError, type OutputFormat } from \"../lib/output.js\";\n20: import { renderHistoryList, renderHistoryDetail } from \"../lib/toon.js\";\n21: \n22: // ---------------------------------------------------------------------------\n23: // Types\n24: // ---------------------------------------------------------------------------\n25: \n26: export interface HistoryCommandOptions {\n27:   projectRoot: string;\n28:   config: WomboConfig;\n29:   /** Specific wave ID to show details for */\n30:   waveId?: string;\n31:   /** Output format */\n32:   outputFmt: OutputFormat;\n33: }\n34: \n35: // ---------------------------------------------------------------------------\n36: // Formatting Helpers\n37: // ---------------------------------------------------------------------------\n38: \n39: const RESET = \"\\x1b[0m\";\n40: const BOLD = \"\\x1b[1m\";\n41: const DIM = \"\\x1b[2m\";\n42: const FG = {\n43:   red: \"\\x1b[31m\",\n44:   green: \"\\x1b[32m\",\n45:   yellow: \"\\x1b[33m\",\n46:   blue: \"\\x1b[34m\",\n47:   magenta: \"\\x1b[35m\",\n48:   cyan: \"\\x1b[36m\",\n49:   gray: \"\\x1b[90m\",\n50: };\n51: \n52: function pad(text: string, width: number): string {\n53:   if (text.length >= width) return text.slice(0, width);\n54:   return text + \" \".repeat(width - text.length);\n55: }\n56: \n57: function padLeft(text: string, width: number): string {\n58:   if (text.length >= width) return text.slice(0, width);\n59:   return \" \".repeat(width - text.length) + text;\n60: }\n61: \n62: function formatDurationMs(ms: number | null): string {\n63:   if (ms === null || ms === 0) return \"-\";\n64:   const seconds = Math.floor(ms / 1000);\n65:   if (seconds < 60) return `${seconds}s`;\n66:   const minutes = Math.floor(seconds / 60);\n67:   if (minutes < 60) return `${minutes}m ${seconds % 60}s`;\n68:   const hours = Math.floor(minutes / 60);\n69:   return `${hours}h ${minutes % 60}m`;\n70: }\n71: \n72: function formatDate(iso: string): string {\n73:   try {\n74:     const d = new Date(iso);\n75:     return d.toLocaleDateString(\"en-US\", {\n76:       year: \"numeric\",\n77:       month: \"short\",\n78:       day: \"numeric\",\n79:       hour: \"2-digit\",\n80:       minute: \"2-digit\",\n81:     });\n82:   } catch {\n83:     return iso;\n84:   }\n85: }\n86: \n87: function statusColor(status: string): string {\n88:   switch (status) {\n89:     case \"merged\":\n90:       return FG.magenta;\n91:     case \"verified\":\n92:       return FG.green;\n93:     case \"failed\":\n94:       return FG.red;\n95:     case \"completed\":\n96:       return FG.yellow;\n97:     default:\n98:       return FG.gray;\n99:   }\n100: }\n101: \n102: // ---------------------------------------------------------------------------\n103: // List All Waves\n104: // ---------------------------------------------------------------------------\n105: \n106: function renderWaveList(records: WaveHistoryRecord[]): void {\n107:   if (records.length === 0) {\n108:     console.log(\"\\nNo wave history found.\");\n109:     console.log(\"History is auto-exported when a wave completes.\\n\");\n110:     return;\n111:   }\n112: \n113:   console.log(\"\");\n114:   console.log(`${BOLD}Wave History (${records.length} wave(s)):${RESET}`);\n115:   console.log(\"\");\n116: \n117:   const header = [\n118:     pad(\"Wave ID\", 24),\n119:     pad(\"Date\", 22),\n120:     padLeft(\"Total\", 6),\n121:     padLeft(\"OK\", 4),\n122:     padLeft(\"Fail\", 5),\n123:     padLeft(\"Merged\", 7),\n124:     padLeft(\"Retries\", 8),\n125:     padLeft(\"Duration\", 10),\n126:   ].join(\" \");\n127: \n128:   console.log(`${BOLD}${header}${RESET}`);\n129:   console.log(\"-\".repeat(90));\n130: \n131:   for (const rec of records) {\n132:     const s = rec.summary;\n133:     const okColor = s.succeeded === s.total ? FG.green : FG.yellow;\n134:     const failColor = s.failed > 0 ? FG.red : FG.gray;\n135: \n136:     const row = [\n137:       pad(rec.wave_id, 24),\n138:       pad(formatDate(rec.started_at), 22),\n139:       padLeft(String(s.total), 6),\n140:       `${okColor}${padLeft(String(s.succeeded), 4)}${RESET}`,\n141:       `${failColor}${padLeft(String(s.failed), 5)}${RESET}`,\n142:       padLeft(String(s.merged), 7),\n143:       padLeft(String(s.total_retries), 8),\n144:       padLeft(formatDurationMs(s.total_duration_ms), 10),\n145:     ].join(\" \");\n146: \n147:     console.log(row);\n148:   }\n149: \n150:   console.log(\"\");\n151:   console.log(`${DIM}Use 'woco history <wave-id>' for details.${RESET}`);\n152:   console.log(\"\");\n153: }\n154: \n155: // ---------------------------------------------------------------------------\n156: // Show Single Wave Details\n157: // ---------------------------------------------------------------------------\n158: \n159: function renderWaveDetails(rec: WaveHistoryRecord): void {\n160:   console.log(\"\");\n161:   console.log(`${BOLD}Wave: ${rec.wave_id}${RESET}`);\n162:   console.log(`${DIM}Base: ${rec.base_branch} | Concurrency: ${rec.max_concurrent} | Mode: ${rec.interactive ? \"interactive\" : \"headless\"}${RESET}`);\n163:   if (rec.model) {\n164:     console.log(`${DIM}Model: ${rec.model}${RESET}`);\n165:   }\n166:   console.log(`${DIM}Started: ${formatDate(rec.started_at)} | Exported: ${formatDate(rec.exported_at)}${RESET}`);\n167:   console.log(\"\");\n168: \n169:   // Summary\n170:   const s = rec.summary;\n171:   console.log(`${BOLD}Summary:${RESET}`);\n172:   console.log(`  Total agents:    ${s.total}`);\n173:   console.log(`  Succeeded:       ${FG.green}${s.succeeded}${RESET}`);\n174:   console.log(`  Failed:          ${s.failed > 0 ? FG.red : FG.gray}${s.failed}${RESET}`);\n175:   console.log(`  Merged:          ${FG.magenta}${s.merged}${RESET}`);\n176:   console.log(`  Verified:        ${FG.green}${s.verified}${RESET}`);\n177:   console.log(`  Total retries:   ${s.total_retries}`);\n178:   console.log(`  Total duration:  ${formatDurationMs(s.total_duration_ms)}`);\n179:   console.log(\"\");\n180: \n181:   // Agent table\n182:   console.log(`${BOLD}Agents:${RESET}`);\n183:   console.log(\"\");\n184: \n185:   const header = [\n186:     pad(\"Feature\", 30),\n187:     pad(\"Status\", 12),\n188:     padLeft(\"Retries\", 8),\n189:     padLeft(\"Duration\", 10),\n190:     pad(\"Build\", 6),\n191:     pad(\"Conflict\", 9),\n192:     pad(\"Error\", 30),\n193:   ].join(\" \");\n194: \n195:   console.log(`${BOLD}${header}${RESET}`);\n196:   console.log(\"-\".repeat(109));\n197: \n198:   for (const agent of rec.agents) {\n199:     const color = statusColor(agent.status);\n200:     const buildStr = agent.build_passed === true\n201:       ? `${FG.green}pass${RESET}`\n202:       : agent.build_passed === false\n203:         ? `${FG.red}fail${RESET}`\n204:         : `${FG.gray}-${RESET}`;\n205:     const conflictStr = agent.had_merge_conflict\n206:       ? `${FG.yellow}yes${RESET}`\n207:       : `${FG.gray}no${RESET}`;\n208:     const errorStr = agent.error\n209:       ? agent.error.split(\"\\n\")[0].slice(0, 28)\n210:       : \"-\";\n211: \n212:     const row = [\n213:       pad(agent.feature_id, 30),\n214:       `${color}${pad(agent.status, 12)}${RESET}`,\n215:       padLeft(\n216:         agent.retries > 0 ? `${agent.retries}/${agent.max_retries}` : \"-\",\n217:         8\n218:       ),\n219:       padLeft(formatDurationMs(agent.duration_ms), 10),\n220:       pad(buildStr, 6),\n221:       pad(conflictStr, 9),\n222:       pad(errorStr, 30),\n223:     ].join(\" \");\n224: \n225:     console.log(row);\n226:   }\n227: \n228:   console.log(\"\");\n229: }\n230: \n231: // ---------------------------------------------------------------------------\n232: // Command\n233: // ---------------------------------------------------------------------------\n234: \n235: export async function cmdHistory(opts: HistoryCommandOptions): Promise<void> {\n236:   const { projectRoot, outputFmt } = opts;\n237: \n238:   if (opts.waveId) {\n239:     // Show details for a specific wave\n240:     const record = loadHistory(projectRoot, opts.waveId);\n241:     if (!record) {\n242:       outputError(\n243:         outputFmt,\n244:         `Wave history not found: ${opts.waveId}. Use 'woco history' to list available waves.`\n245:       );\n246:       return; // unreachable — helps TypeScript narrow\n247:     }\n248: \n249:     output(outputFmt, record, () => {\n250:       renderWaveDetails(record);\n251:     }, () => {\n252:       // TOON renderer\n253:       console.log(renderHistoryDetail(record));\n254:     });\n255:   } else {\n256:     // List all waves\n257:     const records = listHistory(projectRoot);\n258: \n259:     output(outputFmt, records, () => {\n260:       renderWaveList(records);\n261:     }, () => {\n262:       // TOON renderer\n263:       console.log(renderHistoryList(records));\n264:     });\n265:   }\n266: }\n\n(End of file - total 266 lines)\n</content>","title":"src/commands/history.ts","metadata":{"preview":"/**\n * history.ts — View wave history and summaries.\n *\n * Usage:\n *   woco history                    List all past waves\n *   woco history <wave-id>          Show details of a specific wave\n *   woco history --output json      Output as JSON\n *\n * Wave history is stored in .wombo-combo/history/<wave-id>.json and survives\n * `woco cleanup`. Records are auto-exported when a wave completes.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport {\n  listHistory,\n  loadHistory,\n  type WaveHistoryRecord,\n} from \"../lib/history.js\";\nimport { output, outputError, type OutputFormat } from \"../lib/output.js\";\nimport { renderHistoryList, renderHistoryDetail } from \"../lib/toon.js\";","truncated":false,"loaded":[]},"time":{"start":1773437441603,"end":1773437441605}}}}
{"type":"tool_use","timestamp":1773437442024,"sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","part":{"id":"prt_ce91bd6ac001Ecs55x16xbFMso","sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","messageID":"msg_ce91bc07c001ZkLD9a3R3A8KM7","type":"tool","callID":"toolu_vrtx_01KMKUu6GkRUDGi7tv7bgueg","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/abort.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/abort.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * abort.ts — Kill a single running agent without nuking the entire wave.\n3:  *\n4:  * Usage: woco abort <feature-id> [--requeue] [--output json]\n5:  *\n6:  * Kills the multiplexer session (if any) and the agent process, then updates\n7:  * wave state to mark the agent as \"failed\" (default) or \"queued\"\n8:  * (if --requeue is passed, returning it to the queue for retry).\n9:  */\n10: \n11: import type { WomboConfig } from \"../config.js\";\n12: import {\n13:   loadState,\n14:   saveState,\n15:   updateAgent,\n16:   type AgentState,\n17: } from \"../lib/state.js\";\n18: import {\n19:   killMuxSession,\n20:   getMultiplexerName,\n21:   isProcessRunning,\n22: } from \"../lib/launcher.js\";\n23: import { output, outputError, type OutputFormat } from \"../lib/output.js\";\n24: \n25: // ---------------------------------------------------------------------------\n26: // Types\n27: // ---------------------------------------------------------------------------\n28: \n29: export interface AbortCommandOptions {\n30:   projectRoot: string;\n31:   config: WomboConfig;\n32:   featureId: string;\n33:   /** Return the feature to \"queued\" instead of marking it \"failed\" */\n34:   requeue?: boolean;\n35:   outputFmt: OutputFormat;\n36: }\n37: \n38: // ---------------------------------------------------------------------------\n39: // Command\n40: // ---------------------------------------------------------------------------\n41: \n42: export async function cmdAbort(opts: AbortCommandOptions): Promise<void> {\n43:   const { projectRoot, config, featureId, outputFmt } = opts;\n44: \n45:   // Load wave state\n46:   const state = loadState(projectRoot);\n47:   if (!state) {\n48:     outputError(outputFmt, \"No active wave. Nothing to abort.\");\n49:     return; // unreachable — helps TypeScript narrow\n50:   }\n51: \n52:   // Find the agent\n53:   const agent = state.agents.find((a: AgentState) => a.feature_id === featureId);\n54:   if (!agent) {\n55:     outputError(\n56:       outputFmt,\n57:       `Agent not found for feature: ${featureId}. Use 'woco status' to see active agents.`\n58:     );\n59:     return; // unreachable — helps TypeScript narrow\n60:   }\n61: \n62:   // Only abort agents that are actually active (running, installing, queued, resolving_conflict)\n63:   const abortable = new Set([\"running\", \"installing\", \"queued\", \"resolving_conflict\"]);\n64:   if (!abortable.has(agent.status)) {\n65:     outputError(\n66:       outputFmt,\n67:       `Agent ${featureId} is not in an abortable state (current: ${agent.status}). ` +\n68:         `Only running, installing, queued, or resolving_conflict agents can be aborted.`\n69:     );\n70:     return; // unreachable — helps TypeScript narrow\n71:   }\n72: \n73:   // 1. Kill the multiplexer session (if any)\n74:   let muxKilled = false;\n75:   try {\n76:     killMuxSession(featureId, config);\n77:     muxKilled = true;\n78:   } catch {\n79:     // Session may not exist — that's fine\n80:   }\n81: \n82:   // 2. Kill the process by PID (if any and still running)\n83:   let processKilled = false;\n84:   if (agent.pid && isProcessRunning(agent.pid)) {\n85:     try {\n86:       process.kill(agent.pid, \"SIGTERM\");\n87:       processKilled = true;\n88:     } catch {\n89:       // Process may have already exited\n90:     }\n91:   }\n92: \n93:   // 3. Update wave state\n94:   const newStatus = opts.requeue ? \"queued\" : \"failed\";\n95:   const updates: Partial<AgentState> = {\n96:     status: newStatus as AgentState[\"status\"],\n97:     error: opts.requeue ? null : \"Aborted by user\",\n98:     completed_at: opts.requeue ? null : new Date().toISOString(),\n99:   };\n100: \n101:   // If requeuing, reset retry-related fields so the agent gets a fresh start\n102:   if (opts.requeue) {\n103:     updates.retries = 0;\n104:     updates.build_passed = null;\n105:     updates.build_output = null;\n106:     updates.started_at = null;\n107:     updates.completed_at = null;\n108:     updates.activity = null;\n109:     updates.activity_updated_at = null;\n110:   }\n111: \n112:   updateAgent(state, featureId, updates);\n113:   saveState(projectRoot, state);\n114: \n115:   // 4. Output result\n116:   const muxName = getMultiplexerName(config);\n117:   const result = {\n118:     feature_id: featureId,\n119:     previous_status: agent.status,\n120:     new_status: newStatus,\n121:     mux_killed: muxKilled,\n122:     process_killed: processKilled,\n123:     requeued: !!opts.requeue,\n124:   };\n125: \n126:   output(outputFmt, result, () => {\n127:     console.log(`\\nAborted agent: ${featureId}`);\n128:     console.log(`  Previous status: ${agent.status}`);\n129:     console.log(`  New status: ${newStatus}`);\n130:     if (muxKilled) console.log(`  Killed ${muxName} session: ${config.agent.tmuxPrefix}-${featureId}`);\n131:     if (processKilled) console.log(`  Killed process: PID ${agent.pid}`);\n132:     if (opts.requeue) {\n133:       console.log(`  Feature returned to queue for retry.`);\n134:     } else {\n135:       console.log(`  Feature marked as failed.`);\n136:     }\n137:   });\n138: }\n\n(End of file - total 138 lines)\n</content>","title":"src/commands/abort.ts","metadata":{"preview":"/**\n * abort.ts — Kill a single running agent without nuking the entire wave.\n *\n * Usage: woco abort <feature-id> [--requeue] [--output json]\n *\n * Kills the multiplexer session (if any) and the agent process, then updates\n * wave state to mark the agent as \"failed\" (default) or \"queued\"\n * (if --requeue is passed, returning it to the queue for retry).\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport {\n  loadState,\n  saveState,\n  updateAgent,\n  type AgentState,\n} from \"../lib/state.js\";\nimport {\n  killMuxSession,\n  getMultiplexerName,","truncated":false,"loaded":[]},"time":{"start":1773437442022,"end":1773437442024}}}}
{"type":"tool_use","timestamp":1773437442632,"sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","part":{"id":"prt_ce91bd8a7001xRKBOi7mIj2Aui","sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","messageID":"msg_ce91bc07c001ZkLD9a3R3A8KM7","type":"tool","callID":"toolu_vrtx_01UpMCCrVPd4Anch87TQXMxV","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/cleanup.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/cleanup.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * cleanup.ts — Remove all wave-related resources.\n3:  *\n4:  * Usage: woco cleanup\n5:  *\n6:  * Kills multiplexer sessions (dmux/tmux), removes worktrees, removes state and log files.\n7:  *\n8:  * NOTE: .wombo-combo/history/ is intentionally NOT removed by cleanup.\n9:  * Wave history records are meant to survive cleanup for retrospective\n10:  * analysis. See src/lib/history.ts.\n11:  */\n12: \n13: import { existsSync, unlinkSync, rmSync } from \"node:fs\";\n14: import { execSync } from \"node:child_process\";\n15: import { resolve } from \"node:path\";\n16: import type { WomboConfig } from \"../config.js\";\n17: import { WOMBO_DIR } from \"../config.js\";\n18: import { killAllMuxSessions, getMultiplexerName } from \"../lib/launcher.js\";\n19: import { cleanupAllWorktrees, listWomboWorktrees } from \"../lib/worktree.js\";\n20: import {\n21:   detectMultiplexer,\n22:   muxListSessions,\n23: } from \"../lib/multiplexer.js\";\n24: import { output, outputMessage, type OutputFormat } from \"../lib/output.js\";\n25: \n26: export interface CleanupOptions {\n27:   projectRoot: string;\n28:   config: WomboConfig;\n29:   dryRun?: boolean;\n30:   outputFmt?: OutputFormat;\n31: }\n32: \n33: export async function cmdCleanup(opts: CleanupOptions): Promise<void> {\n34:   const { projectRoot, config } = opts;\n35:   const fmt = opts.outputFmt ?? \"text\";\n36: \n37:   // Dry-run: show what would be cleaned up without doing it\n38:   if (opts.dryRun) {\n39:     // List multiplexer sessions that would be killed\n40:     const muxName = getMultiplexerName(config);\n41:     let matchingSessions: string[] = [];\n42:     try {\n43:       const mux = detectMultiplexer(config.agent.multiplexer);\n44:       const sessions = muxListSessions(mux);\n45:       const prefix = config.agent.tmuxPrefix;\n46:       matchingSessions = sessions.filter((s) => s.startsWith(prefix));\n47:     } catch {\n48:       // no mux server running\n49:     }\n50: \n51:     // List worktrees that would be removed (using safe filtering)\n52:     let matchingWorktrees: { path: string }[] = [];\n53:     try {\n54:       matchingWorktrees = listWomboWorktrees(projectRoot, config);\n55:     } catch {\n56:       // no worktrees\n57:     }\n58: \n59:     const statePath = resolve(projectRoot, WOMBO_DIR, \"state.json\");\n60:     const logDir = resolve(projectRoot, WOMBO_DIR, \"logs\");\n61:     const filesToRemove: string[] = [];\n62:     if (existsSync(statePath)) filesToRemove.push(\".wombo-combo/state.json\");\n63:     if (existsSync(logDir)) filesToRemove.push(\".wombo-combo/logs/\");\n64: \n65:     const dryRunResult = {\n66:       dry_run: true,\n67:       mux_sessions: matchingSessions,\n68:       mux_sessions_count: matchingSessions.length,\n69:       worktrees: matchingWorktrees.map((wt) => wt.path),\n70:       worktrees_count: matchingWorktrees.length,\n71:       files_to_remove: filesToRemove,\n72:     };\n73: \n74:     output(fmt, dryRunResult, () => {\n75:       console.log(\"\\n[dry-run] Would perform the following cleanup:\\n\");\n76:       console.log(`  ${muxName} sessions to kill: ${matchingSessions.length}`);\n77:       for (const s of matchingSessions) {\n78:         console.log(`    ${s}`);\n79:       }\n80:       console.log(`  worktrees to remove: ${matchingWorktrees.length}`);\n81:       for (const wt of matchingWorktrees) {\n82:         console.log(`    ${wt.path}`);\n83:       }\n84:       for (const f of filesToRemove) {\n85:         console.log(`  Would remove: ${f}`);\n86:       }\n87:     });\n88: \n89:     return;\n90:   }\n91: \n92:   // Kill multiplexer sessions\n93:   const muxName = getMultiplexerName(config);\n94:   const killed = killAllMuxSessions(config);\n95: \n96:   // Remove worktrees\n97:   const removed = cleanupAllWorktrees(projectRoot, config);\n98: \n99:   // List remaining feature branches\n100:   let remainingBranches: string[] = [];\n101:   try {\n102:     const branchPattern = `\"${config.git.branchPrefix}*\"`;\n103:     const branchesRaw = execSync(`git branch --list ${branchPattern}`, {\n104:       cwd: projectRoot,\n105:       encoding: \"utf-8\",\n106:     }).trim();\n107:     if (branchesRaw) {\n108:       remainingBranches = branchesRaw.split(\"\\n\").map((b) => b.trim());\n109:     }\n110:   } catch {}\n111: \n112:   // Remove state file\n113:   const statePath = resolve(projectRoot, WOMBO_DIR, \"state.json\");\n114:   const stateRemoved = existsSync(statePath);\n115:   if (stateRemoved) {\n116:     unlinkSync(statePath);\n117:   }\n118: \n119:   // Remove log directory\n120:   const logDir = resolve(projectRoot, WOMBO_DIR, \"logs\");\n121:   const logsRemoved = existsSync(logDir);\n122:   if (logsRemoved) {\n123:     rmSync(logDir, { recursive: true, force: true });\n124:   }\n125: \n126:   // Check if history is preserved\n127:   const historyDir = resolve(projectRoot, WOMBO_DIR, \"history\");\n128:   const historyPreserved = existsSync(historyDir);\n129: \n130:   const result = {\n131:     mux_sessions_killed: killed,\n132:     worktrees_removed: removed,\n133:     state_removed: stateRemoved,\n134:     logs_removed: logsRemoved,\n135:     remaining_branches: remainingBranches,\n136:     history_preserved: historyPreserved,\n137:   };\n138: \n139:   output(fmt, result, () => {\n140:     console.log(\"\\n--- wombo-combo: Cleanup ---\\n\");\n141:     console.log(`Killed ${killed} ${muxName} session(s)`);\n142:     console.log(`Removed ${removed} worktree(s)`);\n143: \n144:     if (remainingBranches.length > 0) {\n145:       console.log(`\\nRemaining feature branches:\\n${remainingBranches.map((b) => `  ${b}`).join(\"\\n\")}`);\n146:       console.log('Use \"git branch -D <branch>\" to remove manually.');\n147:     }\n148: \n149:     if (stateRemoved) console.log(\"Removed .wombo-combo/state.json\");\n150:     if (logsRemoved) console.log(\"Removed .wombo-combo/logs/\");\n151: \n152:     console.log(\"\\nCleanup complete.\");\n153: \n154:     if (historyPreserved) {\n155:       console.log(\"Note: .wombo-combo/history/ is preserved. Use 'woco history' to view past waves.\");\n156:     }\n157:   });\n158: }\n\n(End of file - total 158 lines)\n</content>","title":"src/commands/cleanup.ts","metadata":{"preview":"/**\n * cleanup.ts — Remove all wave-related resources.\n *\n * Usage: woco cleanup\n *\n * Kills multiplexer sessions (dmux/tmux), removes worktrees, removes state and log files.\n *\n * NOTE: .wombo-combo/history/ is intentionally NOT removed by cleanup.\n * Wave history records are meant to survive cleanup for retrospective\n * analysis. See src/lib/history.ts.\n */\n\nimport { existsSync, unlinkSync, rmSync } from \"node:fs\";\nimport { execSync } from \"node:child_process\";\nimport { resolve } from \"node:path\";\nimport type { WomboConfig } from \"../config.js\";\nimport { WOMBO_DIR } from \"../config.js\";\nimport { killAllMuxSessions, getMultiplexerName } from \"../lib/launcher.js\";\nimport { cleanupAllWorktrees, listWomboWorktrees } from \"../lib/worktree.js\";\nimport {","truncated":false,"loaded":[]},"time":{"start":1773437442626,"end":1773437442631}}}}
{"type":"tool_use","timestamp":1773437443143,"sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","part":{"id":"prt_ce91bda43001aRgbxVH4r6thdW","sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","messageID":"msg_ce91bc07c001ZkLD9a3R3A8KM7","type":"tool","callID":"toolu_vrtx_01TYZysfazCEYCA2Rx3qQvjY","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/verify.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/verify.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * verify.ts — Run build verification on completed agents.\n3:  *\n4:  * Usage: woco verify [feature-id] [--browser] [--skip-tests] [--strict-tdd] [--output json]\n5:  *\n6:  * Runs the build command in each completed agent's worktree. If a specific\n7:  * feature-id is given, verifies only that agent. Otherwise verifies all\n8:  * agents with status \"completed\".\n9:  *\n10:  * When --browser is passed (or browser.enabled is true in config), also\n11:  * runs browser-based verification after the build passes.\n12:  *\n13:  * When TDD is enabled (tdd.enabled in config), also runs tests and checks\n14:  * for test coverage of new files. Use --skip-tests to skip or --strict-tdd\n15:  * to fail on missing tests.\n16:  */\n17: \n18: import type { WomboConfig } from \"../config.js\";\n19: import { loadFeatures, type Feature } from \"../lib/tasks.js\";\n20: import { loadState } from \"../lib/state.js\";\n21: import { printDashboard } from \"../lib/ui.js\";\n22: import { handleBuildVerification } from \"./launch.js\";\n23: import { output, outputMessage, type OutputFormat } from \"../lib/output.js\";\n24: \n25: // ---------------------------------------------------------------------------\n26: // Types\n27: // ---------------------------------------------------------------------------\n28: \n29: export interface VerifyCommandOptions {\n30:   projectRoot: string;\n31:   config: WomboConfig;\n32:   featureId?: string;\n33:   model?: string;\n34:   maxRetries?: number;\n35:   /** Enable browser verification (overrides config.browser.enabled) */\n36:   browserVerify?: boolean;\n37:   /** Skip running tests during TDD verification */\n38:   skipTests?: boolean;\n39:   /** Strict TDD mode: fail verification if new files are missing tests */\n40:   strictTdd?: boolean;\n41:   outputFmt?: OutputFormat;\n42: }\n43: \n44: // ---------------------------------------------------------------------------\n45: // Command\n46: // ---------------------------------------------------------------------------\n47: \n48: export async function cmdVerify(opts: VerifyCommandOptions): Promise<void> {\n49:   const { projectRoot, config } = opts;\n50:   const fmt = opts.outputFmt ?? \"text\";\n51: \n52:   // Apply browser verification override if --browser flag was passed\n53:   if (opts.browserVerify !== undefined) {\n54:     config.browser.enabled = opts.browserVerify;\n55:   }\n56: \n57:   // Apply TDD overrides from CLI flags\n58:   if (opts.strictTdd !== undefined) {\n59:     config.tdd.strictTdd = opts.strictTdd;\n60:   }\n61: \n62:   const state = loadState(projectRoot);\n63:   if (!state) {\n64:     outputMessage(fmt, \"No active wave.\", {\n65:       wave_id: null,\n66:       agents: [],\n67:       verified: 0,\n68:     });\n69:     return;\n70:   }\n71: \n72:   const toVerify = opts.featureId\n73:     ? state.agents.filter((a) => a.feature_id === opts.featureId)\n74:     : state.agents.filter((a) => a.status === \"completed\");\n75: \n76:   if (toVerify.length === 0) {\n77:     outputMessage(fmt, \"No agents to verify.\", {\n78:       wave_id: state.wave_id,\n79:       agents: [],\n80:       verified: 0,\n81:     });\n82:     return;\n83:   }\n84: \n85:   if (fmt === \"text\") {\n86:     console.log(`\\nVerifying ${toVerify.length} agent(s)...\\n`);\n87:   }\n88: \n89:   const data = loadFeatures(projectRoot, config);\n90: \n91:   for (const agent of toVerify) {\n92:     const feature = data.tasks.find((f: Feature) => f.id === agent.feature_id);\n93:     if (!feature) continue;\n94: \n95:     await handleBuildVerification(\n96:       projectRoot,\n97:       state,\n98:       agent,\n99:       feature,\n100:       config,\n101:       opts.model,\n102:       undefined, // monitor\n103:       { skipTests: opts.skipTests, strictTdd: opts.strictTdd }\n104:     );\n105:   }\n106: \n107:   // Collect results for JSON output\n108:   const results = toVerify.map((agent) => {\n109:     // Re-read agent state after verification (it was mutated in place)\n110:     const updatedAgent = state.agents.find((a) => a.feature_id === agent.feature_id);\n111:     return {\n112:       feature_id: agent.feature_id,\n113:       branch: agent.branch,\n114:       status: updatedAgent?.status ?? agent.status,\n115:       build_passed: updatedAgent?.build_passed ?? agent.build_passed,\n116:       error: updatedAgent?.error ?? agent.error,\n117:     };\n118:   });\n119: \n120:   output(fmt, {\n121:     wave_id: state.wave_id,\n122:     verified: results.filter((r) => r.status === \"verified\").length,\n123:     failed: results.filter((r) => r.status === \"failed\").length,\n124:     agents: results,\n125:   }, () => {\n126:     printDashboard(state);\n127:   });\n128: }\n\n(End of file - total 128 lines)\n</content>","title":"src/commands/verify.ts","metadata":{"preview":"/**\n * verify.ts — Run build verification on completed agents.\n *\n * Usage: woco verify [feature-id] [--browser] [--skip-tests] [--strict-tdd] [--output json]\n *\n * Runs the build command in each completed agent's worktree. If a specific\n * feature-id is given, verifies only that agent. Otherwise verifies all\n * agents with status \"completed\".\n *\n * When --browser is passed (or browser.enabled is true in config), also\n * runs browser-based verification after the build passes.\n *\n * When TDD is enabled (tdd.enabled in config), also runs tests and checks\n * for test coverage of new files. Use --skip-tests to skip or --strict-tdd\n * to fail on missing tests.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport { loadFeatures, type Feature } from \"../lib/tasks.js\";\nimport { loadState } from \"../lib/state.js\";","truncated":false,"loaded":[]},"time":{"start":1773437443139,"end":1773437443143}}}}
{"type":"tool_use","timestamp":1773437443362,"sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","part":{"id":"prt_ce91bdc45001FLhDg3XYP380kN","sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","messageID":"msg_ce91bc07c001ZkLD9a3R3A8KM7","type":"tool","callID":"toolu_vrtx_01WRGbStRhigXMqsdGuD2YAj","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/merge.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/merge.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * merge.ts — Merge verified branches into the base branch.\n3:  *\n4:  * Usage: woco merge [feature-id] [--output json]\n5:  *\n6:  * Merges all verified agents (or a specific one) into the base branch.\n7:  * Uses the full merge pipeline including pre-flight conflict detection,\n8:  * automatic conflict resolution, and configurable retry attempts.\n9:  */\n10: \n11: import type { WomboConfig } from \"../config.js\";\n12: import {\n13:   loadState,\n14: } from \"../lib/state.js\";\n15: import { pushBaseBranch } from \"../lib/merger.js\";\n16: import type { Feature } from \"../lib/tasks.js\";\n17: import { loadFeatures } from \"../lib/tasks.js\";\n18: import { printDashboard, printAgentUpdate } from \"../lib/ui.js\";\n19: import { attemptMerge } from \"./launch.js\";\n20: import { output, outputMessage, type OutputFormat } from \"../lib/output.js\";\n21: \n22: // ---------------------------------------------------------------------------\n23: // Types\n24: // ---------------------------------------------------------------------------\n25: \n26: export interface MergeCommandOptions {\n27:   projectRoot: string;\n28:   config: WomboConfig;\n29:   featureId?: string;\n30:   autoPush?: boolean;\n31:   dryRun?: boolean;\n32:   model?: string;\n33:   outputFmt?: OutputFormat;\n34: }\n35: \n36: // ---------------------------------------------------------------------------\n37: // Command\n38: // ---------------------------------------------------------------------------\n39: \n40: export async function cmdMerge(opts: MergeCommandOptions): Promise<void> {\n41:   const { projectRoot, config } = opts;\n42:   const fmt = opts.outputFmt ?? \"text\";\n43: \n44:   const state = loadState(projectRoot);\n45:   if (!state) {\n46:     outputMessage(fmt, \"No active wave.\", {\n47:       wave_id: null,\n48:       agents: [],\n49:       merged: 0,\n50:     });\n51:     return;\n52:   }\n53: \n54:   const toMerge = opts.featureId\n55:     ? state.agents.filter(\n56:         (a) => a.feature_id === opts.featureId && a.status === \"verified\"\n57:       )\n58:     : state.agents.filter((a) => a.status === \"verified\");\n59: \n60:   if (toMerge.length === 0) {\n61:     outputMessage(fmt, \"No verified agents to merge.\", {\n62:       wave_id: state.wave_id,\n63:       agents: [],\n64:       merged: 0,\n65:     });\n66:     return;\n67:   }\n68: \n69:   // Dry-run: show what would be merged without merging\n70:   if (opts.dryRun) {\n71:     const dryRunResult = {\n72:       dry_run: true,\n73:       wave_id: state.wave_id,\n74:       base_branch: state.base_branch,\n75:       count: toMerge.length,\n76:       agents: toMerge.map((a) => ({\n77:         feature_id: a.feature_id,\n78:         branch: a.branch,\n79:       })),\n80:       auto_push: !!opts.autoPush,\n81:     };\n82: \n83:     output(fmt, dryRunResult, () => {\n84:       console.log(`\\n[dry-run] Would merge ${toMerge.length} branch(es):\\n`);\n85:       for (const agent of toMerge) {\n86:         console.log(`  ${agent.feature_id} — branch: ${agent.branch}`);\n87:       }\n88:       if (opts.autoPush) {\n89:         console.log(`\\n  Would push ${state.base_branch} to remote after merge.`);\n90:       }\n91:     });\n92:     return;\n93:   }\n94: \n95:   // Load features for conflict resolution prompt generation.\n96:   // Build a flat map of all feature/subtask IDs so we can look up any agent.\n97:   const data = loadFeatures(projectRoot, config);\n98:   const featureMap = new Map<string, Feature>();\n99:   function indexFeatures(items: Feature[]) {\n100:     for (const f of items) {\n101:       featureMap.set(f.id, f);\n102:       if (f.subtasks) {\n103:         indexFeatures(f.subtasks as unknown as Feature[]);\n104:       }\n105:     }\n106:   }\n107:   indexFeatures(data.tasks);\n108:   indexFeatures(data.archive);\n109: \n110:   if (fmt === \"text\") {\n111:     console.log(`\\nMerging ${toMerge.length} branch(es)...\\n`);\n112:   }\n113: \n114:   for (const agent of toMerge) {\n115:     const feature = featureMap.get(agent.feature_id);\n116:     if (!feature) {\n117:       if (fmt === \"text\") {\n118:         printAgentUpdate(agent, `SKIP — feature \"${agent.feature_id}\" not found in features file`);\n119:       }\n120:       continue;\n121:     }\n122: \n123:     // Use the full merge pipeline (pre-flight, conflict resolution, retry)\n124:     await attemptMerge(projectRoot, state, agent, feature, config, opts.model);\n125:   }\n126: \n127:   // Auto-push if requested\n128:   if (opts.autoPush) {\n129:     const anyMerged = state.agents.some((a) => a.status === \"merged\");\n130:     if (anyMerged) {\n131:       await pushBaseBranch(projectRoot, state.base_branch, config);\n132:     }\n133:   }\n134: \n135:   // Collect results for JSON output\n136:   const results = toMerge.map((agent) => {\n137:     const updatedAgent = state.agents.find((a) => a.feature_id === agent.feature_id);\n138:     return {\n139:       feature_id: agent.feature_id,\n140:       branch: agent.branch,\n141:       status: updatedAgent?.status ?? agent.status,\n142:       error: updatedAgent?.error ?? agent.error,\n143:     };\n144:   });\n145: \n146:   output(fmt, {\n147:     wave_id: state.wave_id,\n148:     base_branch: state.base_branch,\n149:     merged: results.filter((r) => r.status === \"merged\").length,\n150:     failed: results.filter((r) => r.status === \"failed\").length,\n151:     agents: results,\n152:   }, () => {\n153:     printDashboard(state);\n154:   });\n155: }\n\n(End of file - total 155 lines)\n</content>","title":"src/commands/merge.ts","metadata":{"preview":"/**\n * merge.ts — Merge verified branches into the base branch.\n *\n * Usage: woco merge [feature-id] [--output json]\n *\n * Merges all verified agents (or a specific one) into the base branch.\n * Uses the full merge pipeline including pre-flight conflict detection,\n * automatic conflict resolution, and configurable retry attempts.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport {\n  loadState,\n} from \"../lib/state.js\";\nimport { pushBaseBranch } from \"../lib/merger.js\";\nimport type { Feature } from \"../lib/tasks.js\";\nimport { loadFeatures } from \"../lib/tasks.js\";\nimport { printDashboard, printAgentUpdate } from \"../lib/ui.js\";\nimport { attemptMerge } from \"./launch.js\";\nimport { output, outputMessage, type OutputFormat } from \"../lib/output.js\";","truncated":false,"loaded":[]},"time":{"start":1773437443358,"end":1773437443361}}}}
