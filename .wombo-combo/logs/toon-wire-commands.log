{"type":"tool_use","timestamp":1773437455738,"sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","part":{"id":"prt_ce91c09dc0017V57ZHOnMwoFe8","sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","messageID":"msg_ce91bfb66001Q085JlGivl9xd8","type":"tool","callID":"toolu_vrtx_01AgZ5L27koxxMrmeF2fnooX","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/tasks/add.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/tasks/add.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tasks/add.ts — Add a new task to the tasks file.\n3:  *\n4:  * Usage:\n5:  *   woco tasks add <id> --title \"Task Title\" [--description \"...\"]\n6:  *                   [--priority medium] [--difficulty easy] [--effort PT2H]\n7:  *                   [--depends-on \"task1,task2\"]\n8:  */\n9: \n10: import type { WomboConfig } from \"../../config.js\";\n11: import {\n12:   loadFeatures,\n13:   saveFeatures,\n14:   createBlankFeature,\n15:   allFeatureIds,\n16:   type Priority,\n17:   type Difficulty,\n18: } from \"../../lib/tasks.js\";\n19: import {\n20:   VALID_PRIORITIES,\n21:   VALID_DIFFICULTIES,\n22: } from \"../../lib/task-schema.js\";\n23: import { outputError, outputMessage, type OutputFormat } from \"../../lib/output.js\";\n24: import { validateEnum } from \"../../lib/validate.js\";\n25: \n26: // ---------------------------------------------------------------------------\n27: // Types\n28: // ---------------------------------------------------------------------------\n29: \n30: export interface TasksAddOptions {\n31:   projectRoot: string;\n32:   config: WomboConfig;\n33:   id: string;\n34:   title: string;\n35:   description?: string;\n36:   priority?: Priority;\n37:   difficulty?: Difficulty;\n38:   effort?: string;\n39:   dependsOn?: string[];\n40:   outputFmt?: OutputFormat;\n41:   dryRun?: boolean;\n42: }\n43: \n44: // ---------------------------------------------------------------------------\n45: // Command\n46: // ---------------------------------------------------------------------------\n47: \n48: export async function cmdTasksAdd(opts: TasksAddOptions): Promise<void> {\n49:   const { projectRoot, config } = opts;\n50:   const fmt = opts.outputFmt ?? \"text\";\n51: \n52:   if (!opts.id) {\n53:     outputError(fmt, \"Usage: woco tasks add <id> --title \\\"Task Title\\\"\");\n54:     return;\n55:   }\n56: \n57:   if (!opts.title) {\n58:     outputError(fmt, \"--title is required when adding a task.\");\n59:     return;\n60:   }\n61: \n62:   // Validate priority and difficulty enums (imported from task-schema.ts)\n63:   if (opts.priority) {\n64:     const pResult = validateEnum(opts.priority, VALID_PRIORITIES, \"--priority\");\n65:     if (!pResult.valid) {\n66:       outputError(fmt, pResult.error!);\n67:       return;\n68:     }\n69:   }\n70: \n71:   if (opts.difficulty) {\n72:     const dResult = validateEnum(opts.difficulty, VALID_DIFFICULTIES, \"--difficulty\");\n73:     if (!dResult.valid) {\n74:       outputError(fmt, dResult.error!);\n75:       return;\n76:     }\n77:   }\n78: \n79:   const data = loadFeatures(projectRoot, config);\n80: \n81:   // Check for duplicate ID\n82:   const existingIds = allFeatureIds(data);\n83:   if (existingIds.includes(opts.id)) {\n84:     outputError(fmt, `Task ID \"${opts.id}\" already exists.`);\n85:     return;\n86:   }\n87: \n88:   // Validate depends_on references\n89:   if (opts.dependsOn?.length) {\n90:     for (const dep of opts.dependsOn) {\n91:       if (!existingIds.includes(dep)) {\n92:         outputError(fmt, `Dependency \"${dep}\" does not exist in the tasks file.`);\n93:         return;\n94:       }\n95:     }\n96:   }\n97: \n98:   // Create the feature\n99:   const feature = createBlankFeature(opts.id, opts.title, opts.description ?? \"\", {\n100:     priority: opts.priority,\n101:     difficulty: opts.difficulty,\n102:     effort: opts.effort,\n103:   });\n104: \n105:   // Set dependencies\n106:   if (opts.dependsOn?.length) {\n107:     feature.depends_on = opts.dependsOn;\n108:   }\n109: \n110:   // Dry-run: show what would be added without writing\n111:   if (opts.dryRun) {\n112:     outputMessage(fmt, `[dry-run] Would add task: ${opts.id} — ${opts.title}`, {\n113:       dry_run: true,\n114:       id: feature.id,\n115:       title: feature.title,\n116:       priority: feature.priority,\n117:       difficulty: feature.difficulty,\n118:       effort: feature.effort,\n119:       depends_on: feature.depends_on,\n120:     });\n121:     return;\n122:   }\n123: \n124:   // Append to features list\n125:   data.tasks.push(feature);\n126:   saveFeatures(projectRoot, config, data);\n127: \n128:   outputMessage(fmt, `Added task: ${opts.id} — ${opts.title}`, {\n129:     id: feature.id,\n130:     title: feature.title,\n131:     priority: feature.priority,\n132:     difficulty: feature.difficulty,\n133:     effort: feature.effort,\n134:     depends_on: feature.depends_on,\n135:   });\n136: \n137:   if (fmt === \"text\") {\n138:     console.log(`  priority: ${feature.priority}, difficulty: ${feature.difficulty}, effort: ${feature.effort}`);\n139:     if (feature.depends_on.length > 0) {\n140:       console.log(`  depends on: ${feature.depends_on.join(\", \")}`);\n141:     }\n142:   }\n143: }\n\n(End of file - total 143 lines)\n</content>","title":"src/commands/tasks/add.ts","metadata":{"preview":"/**\n * tasks/add.ts — Add a new task to the tasks file.\n *\n * Usage:\n *   woco tasks add <id> --title \"Task Title\" [--description \"...\"]\n *                   [--priority medium] [--difficulty easy] [--effort PT2H]\n *                   [--depends-on \"task1,task2\"]\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  saveFeatures,\n  createBlankFeature,\n  allFeatureIds,\n  type Priority,\n  type Difficulty,\n} from \"../../lib/tasks.js\";\nimport {\n  VALID_PRIORITIES,","truncated":false,"loaded":[]},"time":{"start":1773437455735,"end":1773437455737}}}}
{"type":"tool_use","timestamp":1773437456329,"sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","part":{"id":"prt_ce91c0d780017MIKbDtw17BTgv","sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","messageID":"msg_ce91bfb66001Q085JlGivl9xd8","type":"tool","callID":"toolu_vrtx_016zGBZHf57wPxkKXRo8bbcy","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/tasks/archive.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/tasks/archive.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tasks/archive.ts — Move done/cancelled tasks to the archive section.\n3:  *\n4:  * Usage:\n5:  *   woco tasks archive              # archive all done + cancelled\n6:  *   woco tasks archive <task-id>    # archive a specific task\n7:  *   woco tasks archive --dry-run    # show what would be archived\n8:  */\n9: \n10: import type { WomboConfig } from \"../../config.js\";\n11: import {\n12:   loadFeatures,\n13:   saveFeatures,\n14:   type Feature,\n15: } from \"../../lib/tasks.js\";\n16: import { outputError, outputMessage, type OutputFormat } from \"../../lib/output.js\";\n17: \n18: // ---------------------------------------------------------------------------\n19: // Types\n20: // ---------------------------------------------------------------------------\n21: \n22: export interface TasksArchiveOptions {\n23:   projectRoot: string;\n24:   config: WomboConfig;\n25:   featureId?: string;\n26:   dryRun?: boolean;\n27:   outputFmt?: OutputFormat;\n28: }\n29: \n30: // ---------------------------------------------------------------------------\n31: // Command\n32: // ---------------------------------------------------------------------------\n33: \n34: export async function cmdTasksArchive(opts: TasksArchiveOptions): Promise<void> {\n35:   const fmt = opts.outputFmt ?? \"text\";\n36: \n37:   try {\n38:     const { projectRoot, config } = opts;\n39:     const data = loadFeatures(projectRoot, config);\n40: \n41:     // Ensure archive array exists\n42:     if (!data.archive) {\n43:       data.archive = [];\n44:     }\n45: \n46:     let toArchive: Feature[];\n47: \n48:     if (opts.featureId) {\n49:       // Archive a specific feature\n50:       const idx = data.tasks.findIndex((f: Feature) => f.id === opts.featureId);\n51:       if (idx === -1) {\n52:         // Check if already in archive\n53:         if (data.archive.find((f) => f.id === opts.featureId)) {\n54:           outputMessage(fmt, `Task \"${opts.featureId}\" is already in the archive.`, {\n55:             already_archived: true,\n56:             id: opts.featureId,\n57:           });\n58:           return;\n59:         }\n60:         outputError(fmt, `Task \"${opts.featureId}\" not found.`);\n61:         return;\n62:       }\n63:       toArchive = [data.tasks[idx]];\n64:     } else {\n65:       // Archive all done + cancelled features\n66:       toArchive = data.tasks.filter(\n67:         (f: Feature) => f.status === \"done\" || f.status === \"cancelled\"\n68:       );\n69:     }\n70: \n71:     if (toArchive.length === 0) {\n72:       outputMessage(fmt, \"No tasks to archive.\", { count: 0 });\n73:       return;\n74:     }\n75: \n76:     if (opts.dryRun) {\n77:       outputMessage(fmt, `Would archive ${toArchive.length} task(s)`, {\n78:         dry_run: true,\n79:         count: toArchive.length,\n80:         archived: toArchive.map((f) => ({ id: f.id, title: f.title, status: f.status })),\n81:       });\n82:       if (fmt === \"text\") {\n83:         console.log(\"\");\n84:         for (const f of toArchive) {\n85:           console.log(`  ${f.id} — ${f.title} (${f.status})`);\n86:         }\n87:       }\n88:       return;\n89:     }\n90: \n91:     // Move features from active to archive\n92:     const archiveIds = new Set(toArchive.map((f) => f.id));\n93:     data.tasks = data.tasks.filter((f: Feature) => !archiveIds.has(f.id));\n94:     data.archive.push(...toArchive);\n95: \n96:     saveFeatures(projectRoot, config, data);\n97: \n98:     outputMessage(fmt, `Archived ${toArchive.length} task(s)`, {\n99:       count: toArchive.length,\n100:       archived: toArchive.map((f) => ({ id: f.id, title: f.title, status: f.status })),\n101:     });\n102:     if (fmt === \"text\") {\n103:       for (const f of toArchive) {\n104:         console.log(`  ${f.id} — ${f.title} (${f.status})`);\n105:       }\n106:     }\n107:   } catch (err: unknown) {\n108:     const message = err instanceof Error ? err.message : String(err);\n109:     outputError(fmt, `Archive failed: ${message}`);\n110:   }\n111: }\n\n(End of file - total 111 lines)\n</content>","title":"src/commands/tasks/archive.ts","metadata":{"preview":"/**\n * tasks/archive.ts — Move done/cancelled tasks to the archive section.\n *\n * Usage:\n *   woco tasks archive              # archive all done + cancelled\n *   woco tasks archive <task-id>    # archive a specific task\n *   woco tasks archive --dry-run    # show what would be archived\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  saveFeatures,\n  type Feature,\n} from \"../../lib/tasks.js\";\nimport { outputError, outputMessage, type OutputFormat } from \"../../lib/output.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------","truncated":false,"loaded":[]},"time":{"start":1773437456326,"end":1773437456329}}}}
{"type":"tool_use","timestamp":1773437456972,"sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","part":{"id":"prt_ce91c0fc7001whaRA80SpIZL6p","sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","messageID":"msg_ce91bfb66001Q085JlGivl9xd8","type":"tool","callID":"toolu_vrtx_017bKCMckFjbzG3nBc9dAP96","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/tasks/set-status.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/tasks/set-status.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tasks/set-status.ts — Change a task's status.\n3:  *\n4:  * Usage:\n5:  *   woco tasks set-status <task-id> <new-status>\n6:  *\n7:  * Valid statuses: backlog, planned, in_progress, blocked, in_review, done, cancelled\n8:  */\n9: \n10: import type { WomboConfig } from \"../../config.js\";\n11: import {\n12:   loadFeatures,\n13:   saveFeatures,\n14:   findFeatureById,\n15:   type FeatureStatus,\n16: } from \"../../lib/tasks.js\";\n17: import { VALID_STATUSES } from \"../../lib/task-schema.js\";\n18: import { outputError, outputMessage, type OutputFormat } from \"../../lib/output.js\";\n19: \n20: // ---------------------------------------------------------------------------\n21: // Types\n22: // ---------------------------------------------------------------------------\n23: \n24: export interface TasksSetStatusOptions {\n25:   projectRoot: string;\n26:   config: WomboConfig;\n27:   featureId: string;\n28:   newStatus: string;\n29:   outputFmt?: OutputFormat;\n30:   dryRun?: boolean;\n31: }\n32: \n33: // ---------------------------------------------------------------------------\n34: // Command\n35: // ---------------------------------------------------------------------------\n36: \n37: export async function cmdTasksSetStatus(opts: TasksSetStatusOptions): Promise<void> {\n38:   const { projectRoot, config } = opts;\n39:   const fmt = opts.outputFmt ?? \"text\";\n40: \n41:   if (!opts.featureId || !opts.newStatus) {\n42:     outputError(fmt, `Usage: woco tasks set-status <task-id> <new-status>\\nValid statuses: ${VALID_STATUSES.join(\", \")}`);\n43:     return;\n44:   }\n45: \n46:   // Validate status\n47:   if (!(VALID_STATUSES as readonly string[]).includes(opts.newStatus)) {\n48:     outputError(fmt, `Invalid status: \"${opts.newStatus}\"\\nValid statuses: ${VALID_STATUSES.join(\", \")}`);\n49:     return;\n50:   }\n51: \n52:   const data = loadFeatures(projectRoot, config);\n53:   const feature = findFeatureById(data, opts.featureId);\n54: \n55:   if (!feature) {\n56:     outputError(fmt, `Task \"${opts.featureId}\" not found.`);\n57:     return;\n58:   }\n59: \n60:   const oldStatus = feature.status;\n61:   const newStatus = opts.newStatus as FeatureStatus;\n62: \n63:   if (oldStatus === newStatus) {\n64:     outputMessage(fmt, `Task \"${opts.featureId}\" is already in status \"${newStatus}\".`, {\n65:       id: opts.featureId,\n66:       status: newStatus,\n67:       changed: false,\n68:     });\n69:     return;\n70:   }\n71: \n72:   // Dry-run: show what would change without writing\n73:   if (opts.dryRun) {\n74:     outputMessage(fmt, `[dry-run] Would change \"${opts.featureId}\": ${oldStatus} → ${newStatus}`, {\n75:       dry_run: true,\n76:       id: opts.featureId,\n77:       old_status: oldStatus,\n78:       new_status: newStatus,\n79:       changed: false,\n80:     });\n81:     return;\n82:   }\n83: \n84:   // Apply status change\n85:   feature.status = newStatus;\n86: \n87:   // Set timestamps\n88:   if (newStatus === \"in_progress\" && !feature.started_at) {\n89:     feature.started_at = new Date().toISOString();\n90:   }\n91:   if (newStatus === \"done\" || newStatus === \"cancelled\") {\n92:     feature.ended_at = new Date().toISOString();\n93:     if (newStatus === \"done\") {\n94:       feature.completion = 100;\n95:     }\n96:   }\n97: \n98:   saveFeatures(projectRoot, config, data);\n99: \n100:   outputMessage(fmt, `Task \"${opts.featureId}\": ${oldStatus} → ${newStatus}`, {\n101:     id: opts.featureId,\n102:     old_status: oldStatus,\n103:     new_status: newStatus,\n104:     changed: true,\n105:   });\n106: }\n\n(End of file - total 106 lines)\n</content>","title":"src/commands/tasks/set-status.ts","metadata":{"preview":"/**\n * tasks/set-status.ts — Change a task's status.\n *\n * Usage:\n *   woco tasks set-status <task-id> <new-status>\n *\n * Valid statuses: backlog, planned, in_progress, blocked, in_review, done, cancelled\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  saveFeatures,\n  findFeatureById,\n  type FeatureStatus,\n} from \"../../lib/tasks.js\";\nimport { VALID_STATUSES } from \"../../lib/task-schema.js\";\nimport { outputError, outputMessage, type OutputFormat } from \"../../lib/output.js\";\n\n// ---------------------------------------------------------------------------","truncated":false,"loaded":[]},"time":{"start":1773437456968,"end":1773437456971}}}}
