{"type":"tool_use","timestamp":1773437514304,"sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","part":{"id":"prt_ce91cee38001qcv1oXF4j1E4mn","sessionID":"ses_316e48c38ffe75SZrvzMc1U3SN","messageID":"msg_ce91ce3c2001fPr7g1jsa0IAeQ","type":"tool","callID":"toolu_vrtx_01NBxXvHet51aQirP1RoYdwH","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/abort.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-toon-wire-commands/src/commands/abort.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * abort.ts — Kill a single running agent without nuking the entire wave.\n3:  *\n4:  * Usage: woco abort <feature-id> [--requeue] [--output json]\n5:  *\n6:  * Kills the multiplexer session (if any) and the agent process, then updates\n7:  * wave state to mark the agent as \"failed\" (default) or \"queued\"\n8:  * (if --requeue is passed, returning it to the queue for retry).\n9:  */\n10: \n11: import type { WomboConfig } from \"../config.js\";\n12: import {\n13:   loadState,\n14:   saveState,\n15:   updateAgent,\n16:   type AgentState,\n17: } from \"../lib/state.js\";\n18: import {\n19:   killMuxSession,\n20:   getMultiplexerName,\n21:   isProcessRunning,\n22: } from \"../lib/launcher.js\";\n23: import { output, outputError, type OutputFormat } from \"../lib/output.js\";\n24: \n25: // ---------------------------------------------------------------------------\n26: // Types\n27: // ---------------------------------------------------------------------------\n28: \n29: export interface AbortCommandOptions {\n30:   projectRoot: string;\n31:   config: WomboConfig;\n32:   featureId: string;\n33:   /** Return the feature to \"queued\" instead of marking it \"failed\" */\n34:   requeue?: boolean;\n35:   outputFmt: OutputFormat;\n36: }\n37: \n38: // ---------------------------------------------------------------------------\n39: // Command\n40: // ---------------------------------------------------------------------------\n41: \n42: export async function cmdAbort(opts: AbortCommandOptions): Promise<void> {\n43:   const { projectRoot, config, featureId, outputFmt } = opts;\n44: \n45:   // Load wave state\n46:   const state = loadState(projectRoot);\n47:   if (!state) {\n48:     outputError(outputFmt, \"No active wave. Nothing to abort.\");\n49:     return; // unreachable — helps TypeScript narrow\n50:   }\n51: \n52:   // Find the agent\n53:   const agent = state.agents.find((a: AgentState) => a.feature_id === featureId);\n54:   if (!agent) {\n55:     outputError(\n56:       outputFmt,\n57:       `Agent not found for feature: ${featureId}. Use 'woco status' to see active agents.`\n58:     );\n59:     return; // unreachable — helps TypeScript narrow\n60:   }\n61: \n62:   // Only abort agents that are actually active (running, installing, queued, resolving_conflict)\n63:   const abortable = new Set([\"running\", \"installing\", \"queued\", \"resolving_conflict\"]);\n64:   if (!abortable.has(agent.status)) {\n65:     outputError(\n66:       outputFmt,\n67:       `Agent ${featureId} is not in an abortable state (current: ${agent.status}). ` +\n68:         `Only running, installing, queued, or resolving_conflict agents can be aborted.`\n69:     );\n70:     return; // unreachable — helps TypeScript narrow\n71:   }\n72: \n73:   // 1. Kill the multiplexer session (if any)\n74:   let muxKilled = false;\n75:   try {\n76:     killMuxSession(featureId, config);\n77:     muxKilled = true;\n78:   } catch {\n79:     // Session may not exist — that's fine\n80:   }\n81: \n82:   // 2. Kill the process by PID (if any and still running)\n83:   let processKilled = false;\n84:   if (agent.pid && isProcessRunning(agent.pid)) {\n85:     try {\n86:       process.kill(agent.pid, \"SIGTERM\");\n87:       processKilled = true;\n88:     } catch {\n89:       // Process may have already exited\n90:     }\n91:   }\n92: \n93:   // 3. Update wave state\n94:   const newStatus = opts.requeue ? \"queued\" : \"failed\";\n95:   const updates: Partial<AgentState> = {\n96:     status: newStatus as AgentState[\"status\"],\n97:     error: opts.requeue ? null : \"Aborted by user\",\n98:     completed_at: opts.requeue ? null : new Date().toISOString(),\n99:   };\n100: \n101:   // If requeuing, reset retry-related fields so the agent gets a fresh start\n102:   if (opts.requeue) {\n103:     updates.retries = 0;\n104:     updates.build_passed = null;\n105:     updates.build_output = null;\n106:     updates.started_at = null;\n107:     updates.completed_at = null;\n108:     updates.activity = null;\n109:     updates.activity_updated_at = null;\n110:   }\n111: \n112:   updateAgent(state, featureId, updates);\n113:   saveState(projectRoot, state);\n114: \n115:   // 4. Output result\n116:   const muxName = getMultiplexerName(config);\n117:   const result = {\n118:     feature_id: featureId,\n119:     previous_status: agent.status,\n120:     new_status: newStatus,\n121:     mux_killed: muxKilled,\n122:     process_killed: processKilled,\n123:     requeued: !!opts.requeue,\n124:   };\n125: \n126:   output(outputFmt, result, () => {\n127:     console.log(`\\nAborted agent: ${featureId}`);\n128:     console.log(`  Previous status: ${agent.status}`);\n129:     console.log(`  New status: ${newStatus}`);\n130:     if (muxKilled) console.log(`  Killed ${muxName} session: ${config.agent.tmuxPrefix}-${featureId}`);\n131:     if (processKilled) console.log(`  Killed process: PID ${agent.pid}`);\n132:     if (opts.requeue) {\n133:       console.log(`  Feature returned to queue for retry.`);\n134:     } else {\n135:       console.log(`  Feature marked as failed.`);\n136:     }\n137:   });\n138: }\n\n(End of file - total 138 lines)\n</content>","title":"src/commands/abort.ts","metadata":{"preview":"/**\n * abort.ts — Kill a single running agent without nuking the entire wave.\n *\n * Usage: woco abort <feature-id> [--requeue] [--output json]\n *\n * Kills the multiplexer session (if any) and the agent process, then updates\n * wave state to mark the agent as \"failed\" (default) or \"queued\"\n * (if --requeue is passed, returning it to the queue for retry).\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport {\n  loadState,\n  saveState,\n  updateAgent,\n  type AgentState,\n} from \"../lib/state.js\";\nimport {\n  killMuxSession,\n  getMultiplexerName,","truncated":false,"loaded":[]},"time":{"start":1773437514299,"end":1773437514303}}}}
