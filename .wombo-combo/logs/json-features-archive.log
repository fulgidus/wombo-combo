{"type":"tool_use","timestamp":1773433290074,"sessionID":"ses_31723c3f7ffeOSpWSm8CuFEVeu","part":{"id":"prt_ce8dc7c57001RLtBDMQCp7q3Z7","sessionID":"ses_31723c3f7ffeOSpWSm8CuFEVeu","messageID":"msg_ce8dc6dba001dWsBwOhYXTC4pN","type":"tool","callID":"toolu_vrtx_01Lw38sK6RYXpsY72gar1BaK","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-json-features-archive/src/commands/tasks/list.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-json-features-archive/src/commands/tasks/list.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tasks/list.ts — List and filter tasks from the tasks file.\n3:  *\n4:  * Usage:\n5:  *   woco tasks list                     # list all tasks\n6:  *   woco tasks list --status backlog    # filter by status\n7:  *   woco tasks list --priority high     # filter by priority\n8:  *   woco tasks list --ready             # show only ready tasks\n9:  *   woco tasks list --archive           # include archived tasks\n10:  */\n11: \n12: import type { WomboConfig } from \"../../config.js\";\n13: import {\n14:   loadFeatures,\n15:   getReadyFeatures,\n16:   featureSummary,\n17:   formatDuration,\n18:   parseDurationMinutes,\n19:   type Feature,\n20:   type FeatureStatus,\n21:   type Priority,\n22:   type Difficulty,\n23:   type FeaturesFile,\n24: } from \"../../lib/tasks.js\";\n25: import { output, filterFieldsArray, renderCompactTable, type OutputFormat } from \"../../lib/output.js\";\n26: \n27: // ---------------------------------------------------------------------------\n28: // Types\n29: // ---------------------------------------------------------------------------\n30: \n31: export interface TasksListOptions {\n32:   projectRoot: string;\n33:   config: WomboConfig;\n34:   status?: FeatureStatus;\n35:   priority?: Priority;\n36:   difficulty?: Difficulty;\n37:   ready?: boolean;\n38:   includeArchive?: boolean;\n39:   outputFmt?: OutputFormat;\n40:   fields?: string[];\n41: }\n42: \n43: // ---------------------------------------------------------------------------\n44: // ANSI Helpers\n45: // ---------------------------------------------------------------------------\n46: \n47: const RESET = \"\\x1b[0m\";\n48: const BOLD = \"\\x1b[1m\";\n49: const DIM = \"\\x1b[2m\";\n50: \n51: const STATUS_COLOR: Record<FeatureStatus, string> = {\n52:   backlog: \"\\x1b[37m\",     // white\n53:   planned: \"\\x1b[36m\",     // cyan\n54:   in_progress: \"\\x1b[34m\", // blue\n55:   blocked: \"\\x1b[31m\",     // red\n56:   in_review: \"\\x1b[33m\",   // yellow\n57:   done: \"\\x1b[32m\",        // green\n58:   cancelled: \"\\x1b[90m\",   // gray\n59: };\n60: \n61: // ---------------------------------------------------------------------------\n62: // Command\n63: // ---------------------------------------------------------------------------\n64: \n65: export async function cmdTasksList(opts: TasksListOptions): Promise<void> {\n66:   const { projectRoot, config } = opts;\n67:   const data = loadFeatures(projectRoot, config);\n68: \n69:   let features: Feature[] = [...data.tasks];\n70: \n71:   // Include archive if requested\n72:   if (opts.includeArchive && data.archive?.length) {\n73:     features = [...features, ...data.archive];\n74:   }\n75: \n76:   // Filter by status\n77:   if (opts.status) {\n78:     features = features.filter((f) => f.status === opts.status);\n79:   }\n80: \n81:   // Filter by priority\n82:   if (opts.priority) {\n83:     features = features.filter((f) => f.priority === opts.priority);\n84:   }\n85: \n86:   // Filter by difficulty\n87:   if (opts.difficulty) {\n88:     features = features.filter((f) => f.difficulty === opts.difficulty);\n89:   }\n90: \n91:   // Filter to ready-only\n92:   if (opts.ready) {\n93:     const readyFeatures = getReadyFeatures(data);\n94:     const readyIds = new Set(readyFeatures.map((f) => f.id));\n95:     features = features.filter((f) => readyIds.has(f.id));\n96:   }\n97: \n98:   if (features.length === 0) {\n99:     output(opts.outputFmt ?? \"text\", { features: [], total: 0, effort: \"0m\" }, () => {\n100:       console.log(\"No tasks match the given filters.\");\n101:     });\n102:     return;\n103:   }\n104: \n105:   // Group by status for display\n106:   const byStatus = new Map<FeatureStatus, Feature[]>();\n107:   for (const f of features) {\n108:     const list = byStatus.get(f.status) ?? [];\n109:     list.push(f);\n110:     byStatus.set(f.status, list);\n111:   }\n112: \n113:   // Display\n114:   const totalEffort = features.reduce(\n115:     (sum, f) => sum + parseDurationMinutes(f.effort),\n116:     0\n117:   );\n118: \n119:   const fmt = opts.outputFmt ?? \"text\";\n120: \n121:   // Build the structured data for each feature\n122:   const featureData = features.map((f) => ({\n123:     id: f.id,\n124:     title: f.title,\n125:     status: f.status,\n126:     priority: f.priority,\n127:     difficulty: f.difficulty,\n128:     effort: f.effort,\n129:     completion: f.completion,\n130:     depends_on: f.depends_on,\n131:   }));\n132: \n133:   // If --fields is specified, use compact output mode\n134:   if (opts.fields?.length) {\n135:     const filtered = filterFieldsArray(featureData, opts.fields);\n136:     output(\n137:       fmt,\n138:       { features: filtered, total: features.length, effort: formatDuration(totalEffort) },\n139:       () => {\n140:         renderCompactTable(\n141:           featureData as Record<string, unknown>[],\n142:           opts.fields!\n143:         );\n144:       }\n145:     );\n146:     return;\n147:   }\n148: \n149:   output(\n150:     fmt,\n151:     {\n152:       features: featureData,\n153:       total: features.length,\n154:       effort: formatDuration(totalEffort),\n155:     },\n156:     () => {\n157:       console.log(`\\n${BOLD}Tasks (${features.length} total, ~${formatDuration(totalEffort)} effort)${RESET}\\n`);\n158: \n159:       const statusOrder: FeatureStatus[] = [\n160:         \"in_progress\",\n161:         \"planned\",\n162:         \"backlog\",\n163:         \"blocked\",\n164:         \"in_review\",\n165:         \"done\",\n166:         \"cancelled\",\n167:       ];\n168: \n169:       for (const status of statusOrder) {\n170:         const group = byStatus.get(status);\n171:         if (!group?.length) continue;\n172: \n173:         const color = STATUS_COLOR[status] ?? \"\";\n174:         console.log(`  ${color}${BOLD}${status.toUpperCase()}${RESET} (${group.length})`);\n175: \n176:         for (const f of group) {\n177:           const effort = formatDuration(parseDurationMinutes(f.effort));\n178:           const deps = f.depends_on.length > 0 ? ` ${DIM}deps: ${f.depends_on.join(\", \")}${RESET}` : \"\";\n179:           const completion = f.completion > 0 ? ` ${DIM}${f.completion}%${RESET}` : \"\";\n180:           console.log(\n181:             `    ${color}${f.id}${RESET} — ${f.title} [${f.priority}/${f.difficulty}] (${effort})${completion}${deps}`\n182:           );\n183:         }\n184:         console.log(\"\");\n185:       }\n186:     }\n187:   );\n188: }\n\n(End of file - total 188 lines)\n</content>","title":"src/commands/tasks/list.ts","metadata":{"preview":"/**\n * tasks/list.ts — List and filter tasks from the tasks file.\n *\n * Usage:\n *   woco tasks list                     # list all tasks\n *   woco tasks list --status backlog    # filter by status\n *   woco tasks list --priority high     # filter by priority\n *   woco tasks list --ready             # show only ready tasks\n *   woco tasks list --archive           # include archived tasks\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  getReadyFeatures,\n  featureSummary,\n  formatDuration,\n  parseDurationMinutes,\n  type Feature,\n  type FeatureStatus,","truncated":false,"loaded":[]},"time":{"start":1773433290035,"end":1773433290068}}}}
{"type":"tool_use","timestamp":1773433290469,"sessionID":"ses_31723c3f7ffeOSpWSm8CuFEVeu","part":{"id":"prt_ce8dc7d3e001PWreAltZ0IgwNk","sessionID":"ses_31723c3f7ffeOSpWSm8CuFEVeu","messageID":"msg_ce8dc6dba001dWsBwOhYXTC4pN","type":"tool","callID":"toolu_vrtx_01WyECb8oobo4PkU7b7LgU1T","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-json-features-archive/src/commands/tasks/add.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-json-features-archive/src/commands/tasks/add.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tasks/add.ts — Add a new task to the tasks file.\n3:  *\n4:  * Usage:\n5:  *   woco tasks add <id> --title \"Task Title\" [--description \"...\"]\n6:  *                   [--priority medium] [--difficulty easy] [--effort PT2H]\n7:  *                   [--depends-on \"task1,task2\"]\n8:  */\n9: \n10: import type { WomboConfig } from \"../../config.js\";\n11: import {\n12:   loadFeatures,\n13:   saveFeatures,\n14:   createBlankFeature,\n15:   allFeatureIds,\n16:   type Priority,\n17:   type Difficulty,\n18: } from \"../../lib/tasks.js\";\n19: import {\n20:   VALID_PRIORITIES,\n21:   VALID_DIFFICULTIES,\n22: } from \"../../lib/task-schema.js\";\n23: import { outputError, outputMessage, type OutputFormat } from \"../../lib/output.js\";\n24: import { validateEnum } from \"../../lib/validate.js\";\n25: \n26: // ---------------------------------------------------------------------------\n27: // Types\n28: // ---------------------------------------------------------------------------\n29: \n30: export interface TasksAddOptions {\n31:   projectRoot: string;\n32:   config: WomboConfig;\n33:   id: string;\n34:   title: string;\n35:   description?: string;\n36:   priority?: Priority;\n37:   difficulty?: Difficulty;\n38:   effort?: string;\n39:   dependsOn?: string[];\n40:   outputFmt?: OutputFormat;\n41:   dryRun?: boolean;\n42: }\n43: \n44: // ---------------------------------------------------------------------------\n45: // Command\n46: // ---------------------------------------------------------------------------\n47: \n48: export async function cmdTasksAdd(opts: TasksAddOptions): Promise<void> {\n49:   const { projectRoot, config } = opts;\n50:   const fmt = opts.outputFmt ?? \"text\";\n51: \n52:   if (!opts.id) {\n53:     outputError(fmt, \"Usage: woco tasks add <id> --title \\\"Task Title\\\"\");\n54:     return;\n55:   }\n56: \n57:   if (!opts.title) {\n58:     outputError(fmt, \"--title is required when adding a task.\");\n59:     return;\n60:   }\n61: \n62:   // Validate priority and difficulty enums (imported from task-schema.ts)\n63:   if (opts.priority) {\n64:     const pResult = validateEnum(opts.priority, VALID_PRIORITIES, \"--priority\");\n65:     if (!pResult.valid) {\n66:       outputError(fmt, pResult.error!);\n67:       return;\n68:     }\n69:   }\n70: \n71:   if (opts.difficulty) {\n72:     const dResult = validateEnum(opts.difficulty, VALID_DIFFICULTIES, \"--difficulty\");\n73:     if (!dResult.valid) {\n74:       outputError(fmt, dResult.error!);\n75:       return;\n76:     }\n77:   }\n78: \n79:   const data = loadFeatures(projectRoot, config);\n80: \n81:   // Check for duplicate ID\n82:   const existingIds = allFeatureIds(data);\n83:   if (existingIds.includes(opts.id)) {\n84:     outputError(fmt, `Task ID \"${opts.id}\" already exists.`);\n85:     return;\n86:   }\n87: \n88:   // Validate depends_on references\n89:   if (opts.dependsOn?.length) {\n90:     for (const dep of opts.dependsOn) {\n91:       if (!existingIds.includes(dep)) {\n92:         outputError(fmt, `Dependency \"${dep}\" does not exist in the tasks file.`);\n93:         return;\n94:       }\n95:     }\n96:   }\n97: \n98:   // Create the feature\n99:   const feature = createBlankFeature(opts.id, opts.title, opts.description ?? \"\", {\n100:     priority: opts.priority,\n101:     difficulty: opts.difficulty,\n102:     effort: opts.effort,\n103:   });\n104: \n105:   // Set dependencies\n106:   if (opts.dependsOn?.length) {\n107:     feature.depends_on = opts.dependsOn;\n108:   }\n109: \n110:   // Dry-run: show what would be added without writing\n111:   if (opts.dryRun) {\n112:     outputMessage(fmt, `[dry-run] Would add task: ${opts.id} — ${opts.title}`, {\n113:       dry_run: true,\n114:       id: feature.id,\n115:       title: feature.title,\n116:       priority: feature.priority,\n117:       difficulty: feature.difficulty,\n118:       effort: feature.effort,\n119:       depends_on: feature.depends_on,\n120:     });\n121:     return;\n122:   }\n123: \n124:   // Append to features list\n125:   data.tasks.push(feature);\n126:   saveFeatures(projectRoot, config, data);\n127: \n128:   outputMessage(fmt, `Added task: ${opts.id} — ${opts.title}`, {\n129:     id: feature.id,\n130:     title: feature.title,\n131:     priority: feature.priority,\n132:     difficulty: feature.difficulty,\n133:     effort: feature.effort,\n134:     depends_on: feature.depends_on,\n135:   });\n136: \n137:   if (fmt === \"text\") {\n138:     console.log(`  priority: ${feature.priority}, difficulty: ${feature.difficulty}, effort: ${feature.effort}`);\n139:     if (feature.depends_on.length > 0) {\n140:       console.log(`  depends on: ${feature.depends_on.join(\", \")}`);\n141:     }\n142:   }\n143: }\n\n(End of file - total 143 lines)\n</content>","title":"src/commands/tasks/add.ts","metadata":{"preview":"/**\n * tasks/add.ts — Add a new task to the tasks file.\n *\n * Usage:\n *   woco tasks add <id> --title \"Task Title\" [--description \"...\"]\n *                   [--priority medium] [--difficulty easy] [--effort PT2H]\n *                   [--depends-on \"task1,task2\"]\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  saveFeatures,\n  createBlankFeature,\n  allFeatureIds,\n  type Priority,\n  type Difficulty,\n} from \"../../lib/tasks.js\";\nimport {\n  VALID_PRIORITIES,","truncated":false,"loaded":[]},"time":{"start":1773433290416,"end":1773433290459}}}}
