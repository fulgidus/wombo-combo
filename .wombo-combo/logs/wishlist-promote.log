{"type":"tool_use","timestamp":1773482657302,"sessionID":"ses_314328759ffeSwO8I1laVGgGu4","part":{"id":"prt_cebcdc074001TCLLR30RKSbJOl","sessionID":"ses_314328759ffeSwO8I1laVGgGu4","messageID":"msg_cebcdb65d001RCwwl7mA98tCZR","type":"tool","callID":"toolu_vrtx_011vDEM3xsto1LMKS1V5NjiR","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/wishlist-promote/src/lib/tui-browser.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/wishlist-promote/src/lib/tui-browser.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tui-browser.ts — Task browser view for the wombo-combo TUI.\n3:  *\n4:  * Shows all tasks organized by dependency streams with checkboxes for\n5:  * selection. Users can evaluate tasks, order them, select/deselect\n6:  * entire streams, and launch a wave with the selected tasks.\n7:  *\n8:  * Layout:\n9:  *   ┌───────────────────────────────────────────────────────┐\n10:  *   │ WOMBO-COMBO Task Browser  │ 42 tasks │ 5 selected    │\n11:  *   ├──────────────────────────────┬────────────────────────┤\n12:  *   │ ☑ json-features-check  done │ Title: ...             │\n13:  *   │ ☑ json-features-arch   done │ Status: backlog        │\n14:  *   │   ☐ json-ops-commands  back │ Priority: high         │\n15:  *   │ ── stream 2 ──              │ Effort: PT6H           │\n16:  *   │ ☐ tdd-test-detection   done │ Depends on:            │\n17:  *   │ ...                         │   - json-ops-commands  │\n18:  *   ├──────────────────────────────┴────────────────────────┤\n19:  *   │ Space:toggle  S:stream  L:launch  O:sort  Q:quit    │\n20:  *   └───────────────────────────────────────────────────────┘\n21:  *\n22:  * Keybinds:\n23:  *   Space     — toggle selection of current task\n24:  *   S         — toggle entire stream (select/deselect all tasks in the group)\n25:  *   A         — select all / deselect all (toggle)\n26:  *   L         — launch selected tasks as a new wave\n27:  *   Tab       — cycle sort field / switch to wave monitor (if wave running)\n28:  *   O         — cycle sort field (priority → status → name → effort → stream)\n29:  *   +/-       — change priority of selected task\n30:  *   Enter     — expand/collapse task detail inline\n31:  *   D         — toggle show done tasks (filter)\n32:  *   C         — cycle concurrency level\n33:  *   Q / C-c   — quit (saves session)\n34:  */\n35: \n36: import blessed from \"neo-blessed\";\n37: import type { Widgets } from \"neo-blessed\";\n38: import type { Task, TasksFile, Priority } from \"./tasks.js\";\n39: import { loadTasks, loadArchive, parseDurationMinutes, formatDuration, areDependenciesMet, getDoneTaskIds } from \"./tasks.js\";\n40: import { saveTaskToStore, saveTaskToArchive, removeTaskFromStore } from \"./task-store.js\";\n41: import { PRIORITY_ORDER, DIFFICULTY_ORDER } from \"./task-schema.js\";\n42: import type { TUISession, SortField } from \"./tui-session.js\";\n43: import { saveTUISession } from \"./tui-session.js\";\n44: import type { WomboConfig } from \"../config.js\";\n45: \n46: // ---------------------------------------------------------------------------\n47: // Types\n48: // ---------------------------------------------------------------------------\n49: \n50: export interface TaskBrowserOptions {\n51:   projectRoot: string;\n52:   config: WomboConfig;\n53:   session: TUISession;\n54:   /** Called when user presses L to launch selected tasks */\n55:   onLaunch: (selectedIds: string[]) => void;\n56:   /** Called when user presses q to quit */\n57:   onQuit: () => void;\n58:   /** Called when user presses Escape to go back to quest picker */\n59:   onBack?: () => void;\n60:   /** Called when user presses Tab to switch to wave monitor (if a wave is running) */\n61:   onSwitchToMonitor?: () => void;\n62:   /** Called when user presses E to create an errand (quest-less assisted task) */\n63:   onErrand?: () => void;\n64:   /** If set, filter to only tasks belonging to this quest */\n65:   questId?: string | null;\n66:   /** Human-readable quest title for header display */\n67:   questTitle?: string;\n68:   /** Task IDs belonging to the selected quest (used for filtering) */\n69:   questTaskIds?: string[];\n70: }\n71: \n72: /**\n73:  * A task node in the display tree with computed metadata.\n74:  */\n75: interface TaskNode {\n76:   task: Task;\n77:   /** Depth in the dependency chain (0 = leaf/no deps, higher = depends on more) */\n78:   depth: number;\n79:   /** ID of the stream (connected component) this task belongs to */\n80:   streamId: string;\n81:   /** Task IDs that depend on this task */\n82:   dependedOnBy: string[];\n83: }\n84: \n85: /**\n86:  * A stream is a group of related tasks connected by dependencies.\n87:  */\n88: interface Stream {\n89:   id: string;\n90:   nodes: TaskNode[];\n91: }\n92: \n93: // ---------------------------------------------------------------------------\n94: // Status / Priority display helpers\n95: // ---------------------------------------------------------------------------\n96: \n97: const STATUS_ABBREV: Record<string, string> = {\n98:   backlog: \"BACK\",\n99:   planned: \"PLAN\",\n100:   in_progress: \"PROG\",\n101:   blocked: \"BLKD\",\n102:   in_review: \"REVW\",\n103:   done: \"DONE\",\n104:   cancelled: \"CANC\",\n105: };\n106: \n107: const STATUS_COLORS: Record<string, string> = {\n108:   backlog: \"gray\",\n109:   planned: \"blue\",\n110:   in_progress: \"cyan\",\n111:   blocked: \"red\",\n112:   in_review: \"yellow\",\n113:   done: \"green\",\n114:   cancelled: \"gray\",\n115: };\n116: \n117: const PRIORITY_ABBREV: Record<string, string> = {\n118:   critical: \"CRIT\",\n119:   high: \"HIGH\",\n120:   medium: \"MED \",\n121:   low: \"LOW \",\n122:   wishlist: \"WISH\",\n123: };\n124: \n125: const PRIORITY_COLORS: Record<string, string> = {\n126:   critical: \"red\",\n127:   high: \"yellow\",\n128:   medium: \"white\",\n129:   low: \"gray\",\n130:   wishlist: \"gray\",\n131: };\n132: \n133: // ---------------------------------------------------------------------------\n134: // Helpers\n135: // ---------------------------------------------------------------------------\n136: \n137: function escapeBlessedTags(text: string): string {\n138:   return text.replace(/\\{/g, \"\\uFF5B\").replace(/\\}/g, \"\\uFF5D\");\n139: }\n140: \n141: const SORT_FIELDS: SortField[] = [\"priority\", \"status\", \"name\", \"effort\", \"stream\"];\n142: \n143: // ---------------------------------------------------------------------------\n144: // Task Graph Builder\n145: // ---------------------------------------------------------------------------\n146: \n147: /**\n148:  * Build a dependency graph from all tasks and organize them into streams\n149:  * (connected components). Within each stream, tasks are topologically sorted.\n150:  */\n151: function buildTaskGraph(tasks: Task[]): Stream[] {\n152:   const taskMap = new Map<string, Task>();\n153:   for (const t of tasks) taskMap.set(t.id, t);\n154: \n155:   // Build reverse dependency map (who depends on me?)\n156:   const dependedOnBy = new Map<string, string[]>();\n157:   for (const t of tasks) {\n158:     for (const dep of t.depends_on) {\n159:       if (!dependedOnBy.has(dep)) dependedOnBy.set(dep, []);\n160:       dependedOnBy.get(dep)!.push(t.id);\n161:     }\n162:   }\n163: \n164:   // Find connected components using undirected graph traversal\n165:   const visited = new Set<string>();\n166:   const components: string[][] = [];\n167: \n168:   function dfs(id: string, component: string[]): void {\n169:     if (visited.has(id)) return;\n170:     if (!taskMap.has(id)) return; // dep references a task not in our list\n171:     visited.add(id);\n172:     component.push(id);\n173:     // Follow forward deps\n174:     const task = taskMap.get(id)!;\n175:     for (const dep of task.depends_on) dfs(dep, component);\n176:     // Follow reverse deps\n177:     for (const rev of (dependedOnBy.get(id) ?? [])) dfs(rev, component);\n178:   }\n179: \n180:   for (const t of tasks) {\n181:     if (!visited.has(t.id)) {\n182:       const comp: string[] = [];\n183:       dfs(t.id, comp);\n184:       components.push(comp);\n185:     }\n186:   }\n187: \n188:   // For each component, compute depths and sort topologically\n189:   const streams: Stream[] = [];\n190:   for (const comp of components) {\n191:     // Compute depth: longest path from any leaf (task with no deps in this component)\n192:     const depthMap = new Map<string, number>();\n193:     const compSet = new Set(comp);\n194: \n195:     function computeDepth(id: string, visiting: Set<string>): number {\n196:       if (depthMap.has(id)) return depthMap.get(id)!;\n197:       if (visiting.has(id)) return 0; // cycle protection\n198:       visiting.add(id);\n199:       const task = taskMap.get(id);\n200:       if (!task) return 0;\n201:       let maxDepth = 0;\n202:       for (const dep of task.depends_on) {\n203:         if (compSet.has(dep)) {\n204:           maxDepth = Math.max(maxDepth, 1 + computeDepth(dep, visiting));\n205:         }\n206:       }\n207:       visiting.delete(id);\n208:       depthMap.set(id, maxDepth);\n209:       return maxDepth;\n210:     }\n211: \n212:     for (const id of comp) computeDepth(id, new Set());\n213: \n214:     // Sort: by depth ascending (leaves first), then by priority\n215:     const sorted = [...comp].sort((a, b) => {\n216:       const dA = depthMap.get(a) ?? 0;\n217:       const dB = depthMap.get(b) ?? 0;\n218:       if (dA !== dB) return dA - dB;\n219:       const tA = taskMap.get(a)!;\n220:       const tB = taskMap.get(b)!;\n221:       return PRIORITY_ORDER[tA.priority] - PRIORITY_ORDER[tB.priority];\n222:     });\n223: \n224:     // Use the deepest task's ID as the stream ID (it's the \"root\" task)\n225:     const maxDepthId = sorted[sorted.length - 1];\n226:     const streamId = maxDepthId;\n227: \n228:     const nodes: TaskNode[] = sorted.map((id) => ({\n229:       task: taskMap.get(id)!,\n230:       depth: depthMap.get(id) ?? 0,\n231:       streamId,\n232:       dependedOnBy: (dependedOnBy.get(id) ?? []).filter((d) => compSet.has(d)),\n233:     }));\n234: \n235:     streams.push({ id: streamId, nodes });\n236:   }\n237: \n238:   // Sort streams by highest-priority task in each\n239:   streams.sort((a, b) => {\n240:     const bestA = Math.min(...a.nodes.map((n) => PRIORITY_ORDER[n.task.priority]));\n241:     const bestB = Math.min(...b.nodes.map((n) => PRIORITY_ORDER[n.task.priority]));\n242:     return bestA - bestB;\n243:   });\n244: \n245:   return streams;\n246: }\n247: \n248: // ---------------------------------------------------------------------------\n249: // Task Browser Class\n250: // ---------------------------------------------------------------------------\n251: \n252: export class TaskBrowser {\n253:   private screen: Widgets.Screen;\n254:   private headerBox: Widgets.BoxElement;\n255:   private taskList: Widgets.ListElement;\n256:   private detailBox: Widgets.BoxElement;\n257:   private statusBar: Widgets.BoxElement;\n258: \n259:   private projectRoot: string;\n260:   private config: WomboConfig;\n261:   private session: TUISession;\n262:   private onLaunch: (selectedIds: string[]) => void;\n263:   private onQuit: () => void;\n264:   private onBack?: () => void;\n265:   private onSwitchToMonitor?: () => void;\n266:   private onErrand?: () => void;\n267: \n268:   /** Quest filtering */\n269:   private questId: string | null = null;\n270:   private questTitle: string | null = null;\n271:   private questTaskIds: Set<string> | null = null;\n272: \n273:   private allTasks: Task[] = [];\n274:   private archiveTasks: Task[] = [];\n275:   private doneIds: Set<string> = new Set();\n276:   private streams: Stream[] = [];\n277:   /** Flat ordered list of task nodes as displayed */\n278:   private displayNodes: TaskNode[] = [];\n279:   private selectedIndex: number = 0;\n280:   private selected: Set<string>;\n281:   private collapsed: Set<string>;\n282:   private hideDone: boolean = false;\n283:   private refreshTimer: ReturnType<typeof setInterval> | null = null;\n284:   private hasRunningWave: boolean = false;\n285: \n286:   constructor(opts: TaskBrowserOptions) {\n287:     this.projectRoot = opts.projectRoot;\n288:     this.config = opts.config;\n289:     this.session = opts.session;\n290:     this.onLaunch = opts.onLaunch;\n291:     this.onQuit = opts.onQuit;\n292:     this.onBack = opts.onBack;\n293:     this.onSwitchToMonitor = opts.onSwitchToMonitor;\n294:     this.onErrand = opts.onErrand;\n295:     this.selected = new Set(opts.session.selected);\n296:     this.collapsed = new Set(opts.session.collapsed);\n297: \n298:     // Quest filtering\n299:     this.questId = opts.questId ?? null;\n300:     this.questTitle = opts.questTitle ?? null;\n301:     this.questTaskIds = opts.questTaskIds ? new Set(opts.questTaskIds) : null;\n302: \n303:     // Load tasks\n304:     this.reloadTasks();\n305: \n306:     // Create screen\n307:     this.screen = blessed.screen({\n308:       smartCSR: true,\n309:       title: this.questTitle\n310:         ? `wombo-combo -- ${this.questTitle}`\n311:         : \"wombo-combo -- Task Browser\",\n312:       fullUnicode: true,\n313:     });\n314: \n315:     // Header\n316:     this.headerBox = blessed.box({\n317:       top: 0,\n318:       left: 0,\n319:       width: \"100%\",\n320:       height: 3,\n321:       tags: true,\n322:       style: { fg: \"white\", bg: \"black\" },\n323:     });\n324: \n325:     // Task list (left pane)\n326:     this.taskList = blessed.list({\n327:       top: 3,\n328:       left: 0,\n329:       width: \"60%\",\n330:       height: \"100%-6\",\n331:       tags: true,\n332:       scrollable: true,\n333:       mouse: true,\n334:       keys: true,\n335:       vi: true,\n336:       border: { type: \"line\" },\n337:       style: {\n338:         border: { fg: \"gray\" },\n339:         selected: { bg: \"blue\", fg: \"white\", bold: true },\n340:         item: { fg: \"white\" },\n341:       },\n342:       label: \" Tasks \",\n343:     });\n344: \n345:     // Detail pane (right pane)\n346:     this.detailBox = blessed.box({\n347:       top: 3,\n348:       left: \"60%\",\n349:       width: \"40%\",\n350:       height: \"100%-6\",\n351:       tags: true,\n352:       scrollable: true,\n353:       mouse: true,\n354:       border: { type: \"line\" },\n355:       style: {\n356:         border: { fg: \"gray\" },\n357:         fg: \"white\",\n358:       },\n359:       label: \" Details \",\n360:     });\n361: \n362:     // Status bar\n363:     this.statusBar = blessed.box({\n364:       bottom: 0,\n365:       left: 0,\n366:       width: \"100%\",\n367:       height: 3,\n368:       tags: true,\n369:       style: { fg: \"white\", bg: \"black\" },\n370:     });\n371: \n372:     // Assemble\n373:     this.screen.append(this.headerBox);\n374:     this.screen.append(this.taskList);\n375:     this.screen.append(this.detailBox);\n376:     this.screen.append(this.statusBar);\n377:     this.taskList.focus();\n378: \n379:     this.bindKeys();\n380:   }\n381: \n382:   // -------------------------------------------------------------------------\n383:   // Public API\n384:   // -------------------------------------------------------------------------\n385: \n386:   start(): void {\n387:     this.buildDisplay();\n388:     this.refresh();\n389:     this.screen.render();\n390:   }\n391: \n392:   stop(): void {\n393:     this.saveSession();\n394:     if (this.refreshTimer) {\n395:       clearInterval(this.refreshTimer);\n396:       this.refreshTimer = null;\n397:     }\n398:     this.screen.destroy();\n399:   }\n400: \n401:   /**\n402:    * Destroy the browser screen without saving session (caller already saved).\n403:    * Used by the TUI orchestrator after receiving onLaunch — the transition\n404:    * message is already displayed, so we just tear down the blessed screen\n405:    * and clear the terminal for the next view.\n406:    */\n407:   destroy(): void {\n408:     if (this.refreshTimer) {\n409:       clearInterval(this.refreshTimer);\n410:       this.refreshTimer = null;\n411:     }\n412:     this.screen.destroy();\n413:     // Clear terminal so the next view starts fresh\n414:     process.stdout.write(\"\\x1B[2J\\x1B[H\");\n415:   }\n416: \n417:   /** Let the orchestrator tell us a wave is running (enables Tab to switch) */\n418:   setHasRunningWave(running: boolean): void {\n419:     this.hasRunningWave = running;\n420:     this.refreshStatusBar();\n421:     this.screen.render();\n422:   }\n423: \n424:   // -------------------------------------------------------------------------\n425:   // Task Loading\n426:   // -------------------------------------------------------------------------\n427: \n428:   private reloadTasks(): void {\n429:     const tasksData = loadTasks(this.projectRoot, this.config);\n430:     const archiveData = loadArchive(this.projectRoot, this.config);\n431: \n432:     // Filter tasks by quest if a quest is selected\n433:     if (this.questTaskIds) {\n434:       this.allTasks = tasksData.tasks.filter((t) => this.questTaskIds!.has(t.id));\n435:     } else {\n436:       this.allTasks = tasksData.tasks;\n437:     }\n438: \n439:     this.archiveTasks = archiveData.tasks;\n440:     this.doneIds = getDoneTaskIds(tasksData, this.archiveTasks);\n441:     this.streams = buildTaskGraph(this.allTasks);\n442: \n443:     // Prune selected IDs that no longer exist\n444:     const validIds = new Set(this.allTasks.map((t) => t.id));\n445:     for (const id of this.selected) {\n446:       if (!validIds.has(id)) this.selected.delete(id);\n447:     }\n448:   }\n449: \n450:   // -------------------------------------------------------------------------\n451:   // Display Building\n452:   // -------------------------------------------------------------------------\n453: \n454:   private buildDisplay(): void {\n455:     this.displayNodes = [];\n456:     const sortedStreams = this.sortStreams(this.streams);\n457: \n458:     for (const stream of sortedStreams) {\n459:       const sortedNodes = this.sortNodesInStream(stream.nodes);\n460:       for (const node of sortedNodes) {\n461:         if (this.hideDone && node.task.status === \"done\") continue;\n462:         this.displayNodes.push(node);\n463:       }\n464:     }\n465:   }\n466: \n467:   private sortStreams(streams: Stream[]): Stream[] {\n468:     const field = this.session.sortBy;\n469:     const order = this.session.sortOrder === \"asc\" ? 1 : -1;\n470: \n471:     if (field === \"stream\") return streams; // natural grouping\n472: \n473:     return [...streams].sort((a, b) => {\n474:       const bestA = this.streamSortKey(a, field);\n475:       const bestB = this.streamSortKey(b, field);\n476:       return (bestA - bestB) * order;\n477:     });\n478:   }\n479: \n480:   private streamSortKey(stream: Stream, field: SortField): number {\n481:     switch (field) {\n482:       case \"priority\":\n483:         return Math.min(...stream.nodes.map((n) => PRIORITY_ORDER[n.task.priority]));\n484:       case \"effort\":\n485:         return Math.min(...stream.nodes.map((n) => parseDurationMinutes(n.task.effort)));\n486:       case \"status\": {\n487:         const STATUS_SORT: Record<string, number> = {\n488:           in_progress: 0, backlog: 1, planned: 2, blocked: 3,\n489:           in_review: 4, done: 5, cancelled: 6,\n490:         };\n491:         return Math.min(...stream.nodes.map((n) => STATUS_SORT[n.task.status] ?? 99));\n492:       }\n493:       case \"name\":\n494:         return 0; // alpha sort handled differently\n495:       default:\n496:         return 0;\n497:     }\n498:   }\n499: \n500:   private sortNodesInStream(nodes: TaskNode[]): TaskNode[] {\n501:     // Always sort by depth within a stream (topological order)\n502:     return [...nodes].sort((a, b) => a.depth - b.depth);\n503:   }\n504: \n505:   // -------------------------------------------------------------------------\n506:   // Key Bindings\n507:   // -------------------------------------------------------------------------\n508: \n509:   private bindKeys(): void {\n510:     // Quit (or go back to quest picker if in quest mode)\n511:     this.screen.key([\"q\", \"C-c\"], () => {\n512:       if (this.onBack && this.questId) {\n513:         // In quest-filtered mode: Q goes back to quest picker\n514:         this.saveSession();\n515:         this.destroy();\n516:         this.onBack();\n517:       } else {\n518:         this.stop();\n519:         this.onQuit();\n520:       }\n521:     });\n522: \n523:     // Escape -- go back to quest picker (always, if available)\n524:     this.screen.key([\"escape\"], () => {\n525:       if (this.onBack) {\n526:         this.saveSession();\n527:         this.destroy();\n528:         this.onBack();\n529:       }\n530:     });\n531: \n532:     // Navigate\n533:     this.taskList.on(\"select item\", (_item: any, index: number) => {\n534:       this.selectedIndex = index;\n535:       this.refreshDetail();\n536:       this.screen.render();\n537:     });\n538: \n539:     // Space — toggle selection\n540:     this.screen.key([\"space\"], () => {\n541:       this.toggleCurrent();\n542:     });\n543: \n544:     // s — toggle stream\n545:     this.screen.key([\"s\"], () => {\n546:       this.toggleStream();\n547:     });\n548: \n549:     // a — select all / deselect all\n550:     this.screen.key([\"a\"], () => {\n551:       this.toggleAll();\n552:     });\n553: \n554:     // l — launch selected\n555:     this.screen.key([\"l\"], () => {\n556:       this.launchSelected();\n557:     });\n558: \n559:     // Tab — cycle sort / switch to monitor\n560:     this.screen.key([\"tab\"], () => {\n561:       if (this.hasRunningWave && this.onSwitchToMonitor) {\n562:         this.saveSession();\n563:         this.stop();\n564:         this.onSwitchToMonitor();\n565:       } else {\n566:         this.cycleSort();\n567:       }\n568:     });\n569: \n570:     // O — cycle sort order (laptop-friendly alternative when Tab is used for view switch)\n571:     this.screen.key([\"o\"], () => {\n572:       this.cycleSort();\n573:     });\n574: \n575:     // +/- — change priority\n576:     this.screen.key([\"+\", \"=\"], () => {\n577:       this.changePriority(-1); // higher priority (lower number)\n578:     });\n579:     this.screen.key([\"-\"], () => {\n580:       this.changePriority(1); // lower priority (higher number)\n581:     });\n582: \n583:     // d — toggle hide done\n584:     this.screen.key([\"d\"], () => {\n585:       this.hideDone = !this.hideDone;\n586:       this.buildDisplay();\n587:       this.refreshTaskList();\n588:       this.refreshHeader();\n589:       this.refreshStatusBar();\n590:       this.screen.render();\n591:     });\n592: \n593:     // x — archive done/cancelled tasks\n594:     this.screen.key([\"x\"], () => {\n595:       this.archiveDone();\n596:     });\n597: \n598:     // c — change concurrency\n599:     this.screen.key([\"c\"], () => {\n600:       this.cycleConcurrency();\n601:     });\n602: \n603:     // e — errand (quest-less assisted task generation)\n604:     this.screen.key([\"e\"], () => {\n605:       if (!this.onErrand) return;\n606:       this.saveSession();\n607:       this.destroy();\n608:       this.onErrand();\n609:     });\n610:   }\n611: \n612:   // -------------------------------------------------------------------------\n613:   // Actions\n614:   // -------------------------------------------------------------------------\n615: \n616:   private toggleCurrent(): void {\n617:     const node = this.displayNodes[this.selectedIndex];\n618:     if (!node) return;\n619:     if (this.selected.has(node.task.id)) {\n620:       this.selected.delete(node.task.id);\n621:     } else {\n622:       this.selected.add(node.task.id);\n623:     }\n624:     this.refreshTaskList();\n625:     this.refreshHeader();\n626:     this.refreshDetail();\n627:     this.refreshStatusBar();\n628:     this.screen.render();\n629:   }\n630: \n631:   private toggleStream(): void {\n632:     const node = this.displayNodes[this.selectedIndex];\n633:     if (!node) return;\n634:     const streamId = node.streamId;\n635:     const streamNodes = this.displayNodes.filter((n) => n.streamId === streamId);\n636: \n637:     // If all in stream are selected, deselect all; otherwise select all\n638:     const allSelected = streamNodes.every((n) => this.selected.has(n.task.id));\n639:     for (const n of streamNodes) {\n640:       if (allSelected) {\n641:         this.selected.delete(n.task.id);\n642:       } else {\n643:         this.selected.add(n.task.id);\n644:       }\n645:     }\n646: \n647:     this.refreshTaskList();\n648:     this.refreshHeader();\n649:     this.refreshDetail();\n650:     this.refreshStatusBar();\n651:     this.screen.render();\n652:   }\n653: \n654:   private toggleAll(): void {\n655:     const allSelected = this.displayNodes.every((n) => this.selected.has(n.task.id));\n656:     for (const n of this.displayNodes) {\n657:       if (allSelected) {\n658:         this.selected.delete(n.task.id);\n659:       } else {\n660:         this.selected.add(n.task.id);\n661:       }\n662:     }\n663:     this.refreshTaskList();\n664:     this.refreshHeader();\n665:     this.refreshStatusBar();\n666:     this.screen.render();\n667:   }\n668: \n669:   private launchSelected(): void {\n670:     if (this.selected.size === 0) return;\n671:     this.saveSession();\n672:     const ids = [...this.selected];\n673: \n674:     // Show a transition message on the existing screen before the caller\n675:     // destroys it — avoids jarring flash of raw console output.\n676:     try {\n677:       this.taskList.setContent(\"\");\n678:       this.detailBox.setContent(\"\");\n679:       this.statusBar.setContent(\"\");\n680:       this.headerBox.setContent(\n681:         ` {bold}{cyan-fg}Launching ${ids.length} task(s)...{/cyan-fg}{/bold}`\n682:       );\n683:       this.screen.render();\n684:     } catch {\n685:       // Screen may already be in a bad state — proceed regardless\n686:     }\n687: \n688:     this.onLaunch(ids);\n689:   }\n690: \n691:   private cycleSort(): void {\n692:     const idx = SORT_FIELDS.indexOf(this.session.sortBy);\n693:     this.session.sortBy = SORT_FIELDS[(idx + 1) % SORT_FIELDS.length];\n694:     this.buildDisplay();\n695:     this.selectedIndex = Math.min(this.selectedIndex, this.displayNodes.length - 1);\n696:     this.refreshTaskList();\n697:     this.refreshHeader();\n698:     this.refreshStatusBar();\n699:     this.screen.render();\n700:   }\n701: \n702:   private changePriority(delta: number): void {\n703:     const node = this.displayNodes[this.selectedIndex];\n704:     if (!node) return;\n705:     const priorities: Priority[] = [\"critical\", \"high\", \"medium\", \"low\", \"wishlist\"];\n706:     const currentIdx = priorities.indexOf(node.task.priority);\n707:     const newIdx = Math.max(0, Math.min(priorities.length - 1, currentIdx + delta));\n708:     if (newIdx === currentIdx) return;\n709: \n710:     node.task.priority = priorities[newIdx];\n711:     // Persist the change\n712:     saveTaskToStore(this.projectRoot, this.config, node.task);\n713:     this.refreshTaskList();\n714:     this.refreshDetail();\n715:     this.screen.render();\n716:   }\n717: \n718:   private cycleConcurrency(): void {\n719:     const levels = [1, 2, 3, 5, 8, 10, 15, 20];\n720:     const idx = levels.indexOf(this.session.maxConcurrent);\n721:     this.session.maxConcurrent = levels[(idx + 1) % levels.length];\n722:     this.refreshStatusBar();\n723:     this.screen.render();\n724:   }\n725: \n726:   /**\n727:    * Archive all done/cancelled tasks. If tasks are selected, only archive\n728:    * those that are done/cancelled. Otherwise archive ALL done/cancelled.\n729:    */\n730:   private archiveDone(): void {\n731:     const candidates =\n732:       this.selected.size > 0\n733:         ? this.allTasks.filter(\n734:             (t) => this.selected.has(t.id) && (t.status === \"done\" || t.status === \"cancelled\")\n735:           )\n736:         : this.allTasks.filter(\n737:             (t) => t.status === \"done\" || t.status === \"cancelled\"\n738:           );\n739: \n740:     if (candidates.length === 0) return;\n741: \n742:     for (const task of candidates) {\n743:       saveTaskToArchive(this.projectRoot, this.config, task);\n744:       removeTaskFromStore(this.projectRoot, this.config, task.id);\n745:       this.selected.delete(task.id);\n746:     }\n747: \n748:     // Reload from disk and rebuild the display\n749:     this.reloadTasks();\n750:     this.buildDisplay();\n751:     this.selectedIndex = Math.min(this.selectedIndex, Math.max(0, this.displayNodes.length - 1));\n752:     this.refresh();\n753:   }\n754: \n755:   // -------------------------------------------------------------------------\n756:   // Session Persistence\n757:   // -------------------------------------------------------------------------\n758: \n759:   private saveSession(): void {\n760:     this.session.selected = [...this.selected];\n761:     this.session.collapsed = [...this.collapsed];\n762:     saveTUISession(this.projectRoot, this.session);\n763:   }\n764: \n765:   // -------------------------------------------------------------------------\n766:   // Refresh Logic\n767:   // -------------------------------------------------------------------------\n768: \n769:   private refresh(): void {\n770:     this.refreshHeader();\n771:     this.refreshTaskList();\n772:     this.refreshDetail();\n773:     this.refreshStatusBar();\n774:     this.screen.render();\n775:   }\n776: \n777:   private refreshHeader(): void {\n778:     const total = this.allTasks.length;\n779:     const displayed = this.displayNodes.length;\n780:     const selectedCount = this.selected.size;\n781:     const doneCount = this.allTasks.filter((t) => t.status === \"done\").length;\n782:     const readyCount = this.allTasks.filter(\n783:       (t) => t.status === \"backlog\" && areDependenciesMet(t, this.doneIds)\n784:     ).length;\n785: \n786:     let line1 = ` {bold}wombo-combo{/bold}`;\n787:     if (this.questTitle) {\n788:       line1 += ` {magenta-fg}\\u25B6 ${escapeBlessedTags(this.questTitle)}{/magenta-fg}`;\n789:     } else {\n790:       line1 += ` {cyan-fg}Task Browser{/cyan-fg}`;\n791:     }\n792:     line1 += `  {gray-fg}|{/gray-fg}  {white-fg}${total}{/white-fg} tasks`;\n793:     if (this.hideDone) line1 += ` ({white-fg}${displayed}{/white-fg} shown)`;\n794:     line1 += `  {gray-fg}|{/gray-fg}  {green-fg}${selectedCount}{/green-fg} selected`;\n795: \n796:     let line2 = ` {green-fg}${doneCount}{/green-fg} done`;\n797:     line2 += `  {cyan-fg}${readyCount}{/cyan-fg} ready`;\n798:     line2 += `  {gray-fg}|{/gray-fg}  Sort: {yellow-fg}${this.session.sortBy}{/yellow-fg}`;\n799:     line2 += `  {gray-fg}|{/gray-fg}  Concurrency: {yellow-fg}${this.session.maxConcurrent}{/yellow-fg}`;\n800: \n801:     this.headerBox.setContent(`${line1}\\n${line2}`);\n802:   }\n803: \n804:   private refreshTaskList(): void {\n805:     const items: string[] = [];\n806:     let lastStreamId = \"\";\n807: \n808:     for (let i = 0; i < this.displayNodes.length; i++) {\n809:       const node = this.displayNodes[i];\n810:       const t = node.task;\n811: \n812:       // Stream separator\n813:       if (node.streamId !== lastStreamId && lastStreamId !== \"\") {\n814:         // We use a visual separator row — but it's not selectable in blessed list,\n815:         // so we just change the color/style\n816:       }\n817:       lastStreamId = node.streamId;\n818: \n819:       // Checkbox\n820:       const isSelected = this.selected.has(t.id);\n821:       const checkbox = isSelected\n822:         ? \"{green-fg}\\u2611{/green-fg}\" // ☑\n823:         : \"{gray-fg}\\u2610{/gray-fg}\";  // ☐\n824: \n825:       // Indent based on depth\n826:       const indent = \"  \".repeat(node.depth);\n827: \n828:       // Dependency readiness indicator\n829:       const depsReady = areDependenciesMet(t, this.doneIds);\n830:       const readyIcon = t.status === \"done\"\n831:         ? \"{green-fg}\\u2713{/green-fg}\"   // ✓\n832:         : depsReady\n833:           ? \"{cyan-fg}\\u25CF{/cyan-fg}\"   // ● ready\n834:           : \"{red-fg}\\u25CB{/red-fg}\";     // ○ blocked\n835: \n836:       // Task ID (truncated)\n837:       const maxIdLen = 26 - node.depth * 2;\n838:       const fid = t.id.length > maxIdLen\n839:         ? t.id.slice(0, maxIdLen - 1) + \"\\u2026\"\n840:         : t.id.padEnd(maxIdLen);\n841: \n842:       // Priority\n843:       const pColor = PRIORITY_COLORS[t.priority] ?? \"white\";\n844:       const pAbbr = PRIORITY_ABBREV[t.priority] ?? t.priority.slice(0, 4).toUpperCase();\n845:       const priority = `{${pColor}-fg}${pAbbr}{/${pColor}-fg}`;\n846: \n847:       // Status\n848:       const sColor = STATUS_COLORS[t.status] ?? \"white\";\n849:       const sAbbr = STATUS_ABBREV[t.status] ?? t.status.slice(0, 4).toUpperCase();\n850:       const status = `{${sColor}-fg}${sAbbr}{/${sColor}-fg}`;\n851: \n852:       // Effort\n853:       const effort = formatDuration(parseDurationMinutes(t.effort));\n854: \n855:       items.push(\n856:         ` ${checkbox} ${indent}${readyIcon} ${fid} ${priority} ${status} {gray-fg}${effort}{/gray-fg}`\n857:       );\n858:     }\n859: \n860:     if (items.length === 0) {\n861:       items.push(\" {gray-fg}No tasks found{/gray-fg}\");\n862:     }\n863: \n864:     const prevSelected = this.selectedIndex;\n865:     this.taskList.setItems(items as any);\n866:     if (prevSelected < items.length) {\n867:       this.taskList.select(prevSelected);\n868:     }\n869:   }\n870: \n871:   private refreshDetail(): void {\n872:     const node = this.displayNodes[this.selectedIndex];\n873:     if (!node) {\n874:       this.detailBox.setContent(\"{gray-fg}No task selected{/gray-fg}\");\n875:       return;\n876:     }\n877: \n878:     const t = node.task;\n879:     const lines: string[] = [];\n880: \n881:     // Title\n882:     lines.push(`{bold}{white-fg}${escapeBlessedTags(t.title)}{/white-fg}{/bold}`);\n883:     lines.push(\"\");\n884: \n885:     // Status & Priority\n886:     const sColor = STATUS_COLORS[t.status] ?? \"white\";\n887:     lines.push(`  Status:     {${sColor}-fg}${t.status}{/${sColor}-fg}`);\n888:     const pColor = PRIORITY_COLORS[t.priority] ?? \"white\";\n889:     lines.push(`  Priority:   {${pColor}-fg}${t.priority}{/${pColor}-fg}  {gray-fg}(+/- to change){/gray-fg}`);\n890:     lines.push(`  Difficulty:  ${t.difficulty}`);\n891:     lines.push(`  Effort:      ${formatDuration(parseDurationMinutes(t.effort))}`);\n892:     lines.push(`  Completion:  ${t.completion}%`);\n893: \n894:     // Selection state\n895:     const isSelected = this.selected.has(t.id);\n896:     lines.push(`  Selected:   ${isSelected ? \"{green-fg}yes{/green-fg}\" : \"{gray-fg}no{/gray-fg}\"}`);\n897: \n898:     // Dependency readiness\n899:     const depsReady = areDependenciesMet(t, this.doneIds);\n900:     lines.push(`  Deps ready: ${depsReady ? \"{green-fg}yes{/green-fg}\" : \"{red-fg}no{/red-fg}\"}`);\n901: \n902:     // Stream info\n903:     lines.push(`  Stream:      ${node.streamId}`);\n904:     lines.push(`  Depth:       ${node.depth}`);\n905:     lines.push(\"\");\n906: \n907:     // Dependencies\n908:     if (t.depends_on.length > 0) {\n909:       lines.push(\"{bold}Dependencies:{/bold}\");\n910:       for (const dep of t.depends_on) {\n911:         const isDone = this.doneIds.has(dep);\n912:         const icon = isDone ? \"{green-fg}\\u2713{/green-fg}\" : \"{red-fg}\\u2717{/red-fg}\";\n913:         lines.push(`  ${icon} ${dep}`);\n914:       }\n915:       lines.push(\"\");\n916:     }\n917: \n918:     // Depended on by\n919:     if (node.dependedOnBy.length > 0) {\n920:       lines.push(\"{bold}Depended on by:{/bold}\");\n921:       for (const id of node.dependedOnBy) {\n922:         lines.push(`  \\u2192 ${id}`);\n923:       }\n924:       lines.push(\"\");\n925:     }\n926: \n927:     // Description\n928:     if (t.description) {\n929:       lines.push(\"{bold}Description:{/bold}\");\n930:       const desc = escapeBlessedTags(t.description.trim());\n931:       // Word-wrap to roughly 38 chars\n932:       const words = desc.split(/\\s+/);\n933:       let line = \" \";\n934:       for (const w of words) {\n935:         if (line.length + w.length > 36) {\n936:           lines.push(line);\n937:           line = \" \" + w;\n938:         } else {\n939:           line += \" \" + w;\n940:         }\n941:       }\n942:       if (line.trim()) lines.push(line);\n943:       lines.push(\"\");\n944:     }\n945: \n946:     // Agent type\n947:     if (t.agent_type) {\n948:       lines.push(`{bold}Agent:{/bold} ${escapeBlessedTags(t.agent_type)}`);\n949:     }\n950: \n951:     // Constraints\n952:     if (t.constraints.length > 0) {\n953:       lines.push(\"{bold}Constraints:{/bold}\");\n954:       for (const c of t.constraints) {\n955:         lines.push(`  \\u2022 ${escapeBlessedTags(c)}`);\n956:       }\n957:     }\n958: \n959:     this.detailBox.setContent(lines.join(\"\\n\"));\n960:     this.detailBox.setLabel(` ${t.id} `);\n961:   }\n962: \n963:   private refreshStatusBar(): void {\n964:     const selCount = this.selected.size;\n965:     const readyInSelection = [...this.selected].filter((id) => {\n966:       const t = this.allTasks.find((tt) => tt.id === id);\n967:       return t && (t.status === \"backlog\" || t.status === \"planned\") && areDependenciesMet(t, this.doneIds);\n968:     }).length;\n969: \n970:     let line1 = ` {bold}Keys:{/bold}`;\n971:     line1 += `  {gray-fg}Space{/gray-fg} toggle`;\n972:     line1 += `  {gray-fg}S{/gray-fg} stream`;\n973:     line1 += `  {gray-fg}A{/gray-fg} all`;\n974:     line1 += `  {gray-fg}+/-{/gray-fg} priority`;\n975:     line1 += `  {gray-fg}D{/gray-fg} ${this.hideDone ? \"show\" : \"hide\"} done`;\n976:     line1 += `  {gray-fg}X{/gray-fg} archive done`;\n977:     line1 += `  {gray-fg}C{/gray-fg} concurrency`;\n978:     if (this.onErrand) {\n979:       line1 += `  {gray-fg}E{/gray-fg} errand`;\n980:     }\n981:     line1 += `  {gray-fg}O{/gray-fg} sort`;\n982: \n983:     if (selCount > 0) {\n984:       line1 += `  {bold}{green-fg}L{/green-fg} LAUNCH (${selCount}){/bold}`;\n985:     }\n986:     if (this.hasRunningWave) {\n987:       line1 += `  {gray-fg}Tab{/gray-fg} monitor`;\n988:     }\n989:     if (this.onBack) {\n990:       line1 += `  {gray-fg}Esc{/gray-fg} back`;\n991:     }\n992:     if (this.questId) {\n993:       line1 += `  {gray-fg}Q{/gray-fg} back`;\n994:     } else {\n995:       line1 += `  {gray-fg}Q{/gray-fg} quit`;\n996:     }\n997: \n998:     let line2 = ` `;\n999:     if (selCount > 0) {\n1000:       line2 += `{green-fg}${selCount}{/green-fg} selected`;\n1001:       line2 += `  {cyan-fg}${readyInSelection}{/cyan-fg} launchable now`;\n1002:       const doneInSel = [...this.selected].filter((id) => {\n1003:         const t = this.allTasks.find((tt) => tt.id === id);\n1004:         return t?.status === \"done\";\n1005:       }).length;\n1006:       if (doneInSel > 0) {\n1007:         line2 += `  {yellow-fg}${doneInSel} already done (will be skipped){/yellow-fg}`;\n1008:       }\n1009:     } else {\n1010:       line2 += `{gray-fg}Select tasks with Space, then press L to launch{/gray-fg}`;  \n1011:     }\n1012: \n1013:     this.statusBar.setContent(`${line1}\\n${line2}`);\n1014:   }\n1015: }\n\n(End of file - total 1015 lines)\n</content>","title":"src/lib/tui-browser.ts","metadata":{"preview":"/**\n * tui-browser.ts — Task browser view for the wombo-combo TUI.\n *\n * Shows all tasks organized by dependency streams with checkboxes for\n * selection. Users can evaluate tasks, order them, select/deselect\n * entire streams, and launch a wave with the selected tasks.\n *\n * Layout:\n *   ┌───────────────────────────────────────────────────────┐\n *   │ WOMBO-COMBO Task Browser  │ 42 tasks │ 5 selected    │\n *   ├──────────────────────────────┬────────────────────────┤\n *   │ ☑ json-features-check  done │ Title: ...             │\n *   │ ☑ json-features-arch   done │ Status: backlog        │\n *   │   ☐ json-ops-commands  back │ Priority: high         │\n *   │ ── stream 2 ──              │ Effort: PT6H           │\n *   │ ☐ tdd-test-detection   done │ Depends on:            │\n *   │ ...                         │   - json-ops-commands  │\n *   ├──────────────────────────────┴────────────────────────┤\n *   │ Space:toggle  S:stream  L:launch  O:sort  Q:quit    │\n *   └───────────────────────────────────────────────────────┘","truncated":false,"loaded":[]},"time":{"start":1773482657298,"end":1773482657300}}}}
{"type":"tool_use","timestamp":1773482657713,"sessionID":"ses_314328759ffeSwO8I1laVGgGu4","part":{"id":"prt_cebcdc612001vhMY00jPtw57a6","sessionID":"ses_314328759ffeSwO8I1laVGgGu4","messageID":"msg_cebcdb65d001RCwwl7mA98tCZR","type":"tool","callID":"toolu_vrtx_016KJbb99izMu5FAgSgoCVqY","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/wishlist-promote/src/lib/tui-quest-picker.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/wishlist-promote/src/lib/tui-quest-picker.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tui-quest-picker.ts -- Quest picker view for the wombo-combo TUI.\n3:  *\n4:  * Shows all quests as a selectable list with an \"All Tasks\" option at the top.\n5:  * Selecting a quest navigates to the Task Browser filtered to that quest's tasks.\n6:  *\n7:  * Layout:\n8:  *   +-----------------------------------------------------------+\n9:  *   | WOMBO-COMBO Quest Picker  | 4 quests                      |\n10:  *   +---------------------------+-------------------------------+\n11:  *   | > All Tasks (42)          | Quest: auth-overhaul           |\n12:  *   |   auth-overhaul   ACTV    | Status: active                 |\n13:  *   |   search-api      DRFT    | Priority: high                 |\n14:  *   |   perf-optim      PAUS    | Tasks: 8 (3 done, 62%)         |\n15:  *   |   ui-redesign     PLAN    | Goal: Replace basic auth...    |\n16:  *   |                           |                                |\n17:  *   +---------------------------+-------------------------------+\n18:  *   | Enter:select  C:create  Q:quit                            |\n19:  *   +-----------------------------------------------------------+\n20:  *\n21:  * Keybinds:\n22:  *   Enter/Space  -- select quest (or \"All Tasks\") and proceed to browser\n23:  *   C            -- create new quest (Phase 2 p2-quest-create-tui)\n24:  *   A            -- activate/pause selected quest\n25:  *   Q / C-c      -- quit the TUI\n26:  */\n27: \n28: import blessed from \"neo-blessed\";\n29: import type { Widgets } from \"neo-blessed\";\n30: import type { Quest, QuestHitlMode } from \"./quest.js\";\n31: import { QUEST_STATUS_ORDER, createBlankQuest, VALID_HITL_MODES } from \"./quest.js\";\n32: import { loadAllQuests, saveQuest, loadQuest } from \"./quest-store.js\";\n33: import { VALID_PRIORITIES, VALID_DIFFICULTIES } from \"./task-schema.js\";\n34: import type { Priority, Difficulty } from \"./tasks.js\";\n35: import { loadTasks, getDoneTaskIds, loadArchive } from \"./tasks.js\";\n36: import type { WomboConfig } from \"../config.js\";\n37: \n38: // ---------------------------------------------------------------------------\n39: // Types\n40: // ---------------------------------------------------------------------------\n41: \n42: export type QuestPickerAction =\n43:   | { type: \"select\"; questId: string | null }\n44:   | { type: \"plan\"; questId: string }\n45:   | { type: \"genesis\" }\n46:   | { type: \"errand\" }\n47:   | { type: \"quit\" };\n48: \n49: export interface QuestPickerOptions {\n50:   projectRoot: string;\n51:   config: WomboConfig;\n52:   onSelect: (questId: string | null) => void;\n53:   onPlan?: (questId: string) => void;\n54:   onGenesis?: () => void;\n55:   onErrand?: () => void;\n56:   onQuit: () => void;\n57: }\n58: \n59: // ---------------------------------------------------------------------------\n60: // Display helpers\n61: // ---------------------------------------------------------------------------\n62: \n63: const STATUS_ABBREV: Record<string, string> = {\n64:   draft: \"DRFT\",\n65:   planning: \"PLAN\",\n66:   active: \"ACTV\",\n67:   paused: \"PAUS\",\n68:   completed: \"DONE\",\n69:   abandoned: \"ABAN\",\n70: };\n71: \n72: const STATUS_COLORS: Record<string, string> = {\n73:   draft: \"gray\",\n74:   planning: \"blue\",\n75:   active: \"green\",\n76:   paused: \"yellow\",\n77:   completed: \"cyan\",\n78:   abandoned: \"red\",\n79: };\n80: \n81: const PRIORITY_COLORS: Record<string, string> = {\n82:   critical: \"red\",\n83:   high: \"yellow\",\n84:   medium: \"white\",\n85:   low: \"gray\",\n86:   wishlist: \"gray\",\n87: };\n88: \n89: function escapeBlessedTags(text: string): string {\n90:   return text.replace(/\\{/g, \"\\uFF5B\").replace(/\\}/g, \"\\uFF5D\");\n91: }\n92: \n93: // ---------------------------------------------------------------------------\n94: // Quest summary for display\n95: // ---------------------------------------------------------------------------\n96: \n97: interface QuestSummary {\n98:   quest: Quest;\n99:   totalTasks: number;\n100:   doneTasks: number;\n101:   completionPct: number;\n102: }\n103: \n104: // ---------------------------------------------------------------------------\n105: // QuestPicker Class\n106: // ---------------------------------------------------------------------------\n107: \n108: export class QuestPicker {\n109:   private screen: Widgets.Screen;\n110:   private headerBox: Widgets.BoxElement;\n111:   private questList: Widgets.ListElement;\n112:   private detailBox: Widgets.BoxElement;\n113:   private statusBar: Widgets.BoxElement;\n114: \n115:   private projectRoot: string;\n116:   private config: WomboConfig;\n117:   private onSelect: (questId: string | null) => void;\n118:   private onPlan?: (questId: string) => void;\n119:   private onGenesis?: () => void;\n120:   private onErrand?: () => void;\n121:   private onQuit: () => void;\n122: \n123:   /** \"All Tasks\" + quest summaries */\n124:   private items: Array<{ type: \"all\" } | { type: \"quest\"; summary: QuestSummary }> = [];\n125:   private selectedIndex: number = 0;\n126:   private totalTaskCount: number = 0;\n127: \n128:   constructor(opts: QuestPickerOptions) {\n129:     this.projectRoot = opts.projectRoot;\n130:     this.config = opts.config;\n131:     this.onSelect = opts.onSelect;\n132:     this.onPlan = opts.onPlan;\n133:     this.onGenesis = opts.onGenesis;\n134:     this.onErrand = opts.onErrand;\n135:     this.onQuit = opts.onQuit;\n136: \n137:     this.loadQuests();\n138: \n139:     // Create screen\n140:     this.screen = blessed.screen({\n141:       smartCSR: true,\n142:       title: \"wombo-combo -- Quest Picker\",\n143:       fullUnicode: true,\n144:     });\n145: \n146:     // Header\n147:     this.headerBox = blessed.box({\n148:       top: 0,\n149:       left: 0,\n150:       width: \"100%\",\n151:       height: 3,\n152:       tags: true,\n153:       style: { fg: \"white\", bg: \"black\" },\n154:     });\n155: \n156:     // Quest list (left pane)\n157:     this.questList = blessed.list({\n158:       top: 3,\n159:       left: 0,\n160:       width: \"50%\",\n161:       height: \"100%-6\",\n162:       tags: true,\n163:       scrollable: true,\n164:       mouse: true,\n165:       keys: true,\n166:       vi: true,\n167:       border: { type: \"line\" },\n168:       style: {\n169:         border: { fg: \"gray\" },\n170:         selected: { bg: \"blue\", fg: \"white\", bold: true },\n171:         item: { fg: \"white\" },\n172:       },\n173:       label: \" Quests \",\n174:     });\n175: \n176:     // Detail pane (right pane)\n177:     this.detailBox = blessed.box({\n178:       top: 3,\n179:       left: \"50%\",\n180:       width: \"50%\",\n181:       height: \"100%-6\",\n182:       tags: true,\n183:       scrollable: true,\n184:       mouse: true,\n185:       border: { type: \"line\" },\n186:       style: {\n187:         border: { fg: \"gray\" },\n188:         fg: \"white\",\n189:       },\n190:       label: \" Details \",\n191:     });\n192: \n193:     // Status bar\n194:     this.statusBar = blessed.box({\n195:       bottom: 0,\n196:       left: 0,\n197:       width: \"100%\",\n198:       height: 3,\n199:       tags: true,\n200:       style: { fg: \"white\", bg: \"black\" },\n201:     });\n202: \n203:     // Assemble\n204:     this.screen.append(this.headerBox);\n205:     this.screen.append(this.questList);\n206:     this.screen.append(this.detailBox);\n207:     this.screen.append(this.statusBar);\n208:     this.questList.focus();\n209: \n210:     this.bindKeys();\n211:   }\n212: \n213:   // -----------------------------------------------------------------------\n214:   // Public API\n215:   // -----------------------------------------------------------------------\n216: \n217:   start(): void {\n218:     this.refreshAll();\n219:     this.screen.render();\n220:   }\n221: \n222:   stop(): void {\n223:     this.screen.destroy();\n224:   }\n225: \n226:   destroy(): void {\n227:     this.screen.destroy();\n228:     process.stdout.write(\"\\x1B[2J\\x1B[H\");\n229:   }\n230: \n231:   // -----------------------------------------------------------------------\n232:   // Data Loading\n233:   // -----------------------------------------------------------------------\n234: \n235:   private loadQuests(): void {\n236:     const quests = loadAllQuests(this.projectRoot);\n237:     const tasksData = loadTasks(this.projectRoot, this.config);\n238:     const archiveData = loadArchive(this.projectRoot, this.config);\n239:     const doneIds = getDoneTaskIds(tasksData, archiveData.tasks);\n240:     this.totalTaskCount = tasksData.tasks.length;\n241: \n242:     // Build task lookup for quest summaries\n243:     const taskMap = new Map(tasksData.tasks.map((t) => [t.id, t]));\n244: \n245:     // Sort quests: active first, then by status order, then by priority\n246:     const sorted = [...quests].sort((a, b) => {\n247:       const statusDiff = (QUEST_STATUS_ORDER[a.status] ?? 99) - (QUEST_STATUS_ORDER[b.status] ?? 99);\n248:       if (statusDiff !== 0) return statusDiff;\n249:       return 0;\n250:     });\n251: \n252:     // Build items list\n253:     this.items = [{ type: \"all\" as const }];\n254:     for (const quest of sorted) {\n255:       const totalTasks = quest.taskIds.length;\n256:       const doneTasks = quest.taskIds.filter((id) => doneIds.has(id)).length;\n257:       const completionPct = totalTasks > 0 ? Math.round((doneTasks / totalTasks) * 100) : 0;\n258: \n259:       this.items.push({\n260:         type: \"quest\" as const,\n261:         summary: { quest, totalTasks, doneTasks, completionPct },\n262:       });\n263:     }\n264:   }\n265: \n266:   // -----------------------------------------------------------------------\n267:   // Key Bindings\n268:   // -----------------------------------------------------------------------\n269: \n270:   private bindKeys(): void {\n271:     // Quit\n272:     this.screen.key([\"q\", \"C-c\"], () => {\n273:       this.stop();\n274:       this.onQuit();\n275:     });\n276: \n277:     // Navigate\n278:     this.questList.on(\"select item\", (_item: any, index: number) => {\n279:       this.selectedIndex = index;\n280:       this.refreshDetail();\n281:       this.screen.render();\n282:     });\n283: \n284:     // Enter/Space -- select\n285:     this.screen.key([\"enter\", \"space\"], () => {\n286:       this.selectCurrent();\n287:     });\n288: \n289:     // A -- activate/pause quest\n290:     this.screen.key([\"a\"], () => {\n291:       this.toggleQuestActive();\n292:     });\n293: \n294:     // C -- create new quest\n295:     this.screen.key([\"c\"], () => {\n296:       this.showCreateQuestModal();\n297:     });\n298: \n299:     // P -- plan quest (run planner agent)\n300:     this.screen.key([\"p\"], () => {\n301:       this.planQuest();\n302:     });\n303: \n304:     // G -- genesis (project-level decomposition)\n305:     this.screen.key([\"g\"], () => {\n306:       this.triggerGenesis();\n307:     });\n308: \n309:     // E -- errand (quick task generation without a quest)\n310:     this.screen.key([\"e\"], () => {\n311:       this.triggerErrand();\n312:     });\n313:   }\n314: \n315:   // -----------------------------------------------------------------------\n316:   // Actions\n317:   // -----------------------------------------------------------------------\n318: \n319:   private selectCurrent(): void {\n320:     const item = this.items[this.selectedIndex];\n321:     if (!item) return;\n322: \n323:     if (item.type === \"all\") {\n324:       this.destroy();\n325:       this.onSelect(null);\n326:     } else {\n327:       this.destroy();\n328:       this.onSelect(item.summary.quest.id);\n329:     }\n330:   }\n331: \n332:   private toggleQuestActive(): void {\n333:     const item = this.items[this.selectedIndex];\n334:     if (!item || item.type === \"all\") return;\n335: \n336:     const quest = item.summary.quest;\n337:     if (quest.status === \"active\") {\n338:       quest.status = \"paused\";\n339:     } else if (quest.status === \"draft\" || quest.status === \"paused\" || quest.status === \"planning\") {\n340:       quest.status = \"active\";\n341:       if (!quest.started_at) {\n342:         quest.started_at = new Date().toISOString();\n343:       }\n344:     } else {\n345:       // completed/abandoned -- can't toggle\n346:       return;\n347:     }\n348: \n349:     saveQuest(this.projectRoot, quest);\n350:     this.loadQuests();\n351:     this.refreshAll();\n352:     this.screen.render();\n353:   }\n354: \n355:   private planQuest(): void {\n356:     if (this.creatingQuest) return;\n357:     const item = this.items[this.selectedIndex];\n358:     if (!item || item.type === \"all\") return;\n359: \n360:     const quest = item.summary.quest;\n361:     // Only allow planning for draft or planning quests\n362:     if (quest.status !== \"draft\" && quest.status !== \"planning\") {\n363:       return;\n364:     }\n365: \n366:     if (!this.onPlan) return;\n367: \n368:     this.destroy();\n369:     this.onPlan(quest.id);\n370:   }\n371: \n372:   private triggerGenesis(): void {\n373:     if (this.creatingQuest) return;\n374:     if (!this.onGenesis) return;\n375: \n376:     this.destroy();\n377:     this.onGenesis();\n378:   }\n379: \n380:   private triggerErrand(): void {\n381:     if (this.creatingQuest) return;\n382:     if (!this.onErrand) return;\n383: \n384:     this.destroy();\n385:     this.onErrand();\n386:   }\n387: \n388:   // -----------------------------------------------------------------------\n389:   // Create Quest Modal\n390:   // -----------------------------------------------------------------------\n391: \n392:   /** Whether the create modal is currently showing (blocks other key handlers) */\n393:   private creatingQuest = false;\n394: \n395:   /**\n396:    * Show a multi-step modal form to create a new quest.\n397:    * Steps: ID -> Title -> Goal -> Priority -> Difficulty -> HITL -> Confirm\n398:    */\n399:   private showCreateQuestModal(): void {\n400:     if (this.creatingQuest) return;\n401:     this.creatingQuest = true;\n402: \n403:     // Overlay box that covers the detail pane\n404:     const modal = blessed.box({\n405:       parent: this.screen,\n406:       top: \"center\",\n407:       left: \"center\",\n408:       width: \"70%\",\n409:       height: \"80%\",\n410:       tags: true,\n411:       border: { type: \"line\" },\n412:       style: {\n413:         border: { fg: \"magenta\" },\n414:         fg: \"white\",\n415:         bg: \"black\",\n416:       },\n417:       label: \" {magenta-fg}New Quest{/magenta-fg} \",\n418:       shadow: true,\n419:     });\n420: \n421:     // Content area (instructions)\n422:     const content = blessed.box({\n423:       parent: modal,\n424:       top: 0,\n425:       left: 1,\n426:       right: 1,\n427:       height: 3,\n428:       tags: true,\n429:       style: { fg: \"white\", bg: \"black\" },\n430:     });\n431: \n432:     // Textbox for text input steps\n433:     const textbox = blessed.textbox({\n434:       parent: modal,\n435:       top: 3,\n436:       left: 1,\n437:       right: 1,\n438:       height: 3,\n439:       border: { type: \"line\" },\n440:       style: {\n441:         border: { fg: \"cyan\" },\n442:         fg: \"white\",\n443:         bg: \"black\",\n444:         focus: { border: { fg: \"magenta\" } },\n445:       },\n446:       inputOnFocus: true,\n447:     });\n448: \n449:     // Textarea for goal (multi-line)\n450:     const textarea = blessed.textarea({\n451:       parent: modal,\n452:       top: 3,\n453:       left: 1,\n454:       right: 1,\n455:       height: 10,\n456:       border: { type: \"line\" },\n457:       style: {\n458:         border: { fg: \"cyan\" },\n459:         fg: \"white\",\n460:         bg: \"black\",\n461:         focus: { border: { fg: \"magenta\" } },\n462:       },\n463:       inputOnFocus: true,\n464:       hidden: true,\n465:     });\n466: \n467:     // Selection list for enum steps (priority, difficulty, hitl)\n468:     const selectList = blessed.list({\n469:       parent: modal,\n470:       top: 3,\n471:       left: 1,\n472:       right: 1,\n473:       height: \"100%-8\",\n474:       tags: true,\n475:       keys: true,\n476:       vi: true,\n477:       border: { type: \"line\" },\n478:       style: {\n479:         border: { fg: \"cyan\" },\n480:         selected: { bg: \"blue\", fg: \"white\", bold: true },\n481:         item: { fg: \"white\" },\n482:         bg: \"black\",\n483:       },\n484:       hidden: true,\n485:     });\n486: \n487:     // Status line at bottom of modal\n488:     const statusLine = blessed.box({\n489:       parent: modal,\n490:       bottom: 0,\n491:       left: 1,\n492:       right: 1,\n493:       height: 1,\n494:       tags: true,\n495:       style: { fg: \"gray\", bg: \"black\" },\n496:     });\n497: \n498:     // Collected values\n499:     let questId = \"\";\n500:     let questTitle = \"\";\n501:     let questGoal = \"\";\n502:     let questPriority: Priority = \"medium\";\n503:     let questDifficulty: Difficulty = \"medium\";\n504:     let questHitl: QuestHitlMode = \"yolo\";\n505: \n506:     type Step = \"id\" | \"title\" | \"goal\" | \"priority\" | \"difficulty\" | \"hitl\";\n507:     const steps: Step[] = [\"id\", \"title\", \"goal\", \"priority\", \"difficulty\", \"hitl\"];\n508:     let currentStepIdx = 0;\n509: \n510:     const cleanup = () => {\n511:       modal.destroy();\n512:       this.creatingQuest = false;\n513:       this.questList.focus();\n514:       this.screen.render();\n515:     };\n516: \n517:     const showStep = (step: Step) => {\n518:       textbox.hide();\n519:       textarea.hide();\n520:       selectList.hide();\n521: \n522:       const stepLabel = `Step ${currentStepIdx + 1}/${steps.length}`;\n523: \n524:       switch (step) {\n525:         case \"id\":\n526:           content.setContent(\n527:             `{bold}${stepLabel} — Quest ID{/bold}\\n` +\n528:             `{gray-fg}Kebab-case identifier (e.g. auth-overhaul, search-api){/gray-fg}\\n` +\n529:             `{gray-fg}Esc to cancel{/gray-fg}`\n530:           );\n531:           statusLine.setContent(\"{gray-fg}Enter a unique ID for the quest{/gray-fg}\");\n532:           textbox.setValue(\"\");\n533:           textbox.show();\n534:           textbox.focus();\n535:           break;\n536: \n537:         case \"title\":\n538:           content.setContent(\n539:             `{bold}${stepLabel} — Title{/bold}\\n` +\n540:             `{gray-fg}Human-readable name for the quest{/gray-fg}\\n` +\n541:             `{gray-fg}Esc to go back{/gray-fg}`\n542:           );\n543:           statusLine.setContent(`{gray-fg}ID: ${questId}{/gray-fg}`);\n544:           textbox.setValue(\"\");\n545:           textbox.show();\n546:           textbox.focus();\n547:           break;\n548: \n549:         case \"goal\":\n550:           content.setContent(\n551:             `{bold}${stepLabel} — Goal{/bold}\\n` +\n552:             `{gray-fg}What should this quest achieve? (Enter to submit, Esc to go back){/gray-fg}\\n` +\n553:             `{gray-fg}Shift+Enter or \\\\n for newlines{/gray-fg}`\n554:           );\n555:           statusLine.setContent(`{gray-fg}ID: ${questId} | Title: ${questTitle}{/gray-fg}`);\n556:           textarea.setValue(\"\");\n557:           textarea.show();\n558:           textarea.focus();\n559:           break;\n560: \n561:         case \"priority\":\n562:           content.setContent(\n563:             `{bold}${stepLabel} — Priority{/bold}\\n` +\n564:             `{gray-fg}Select with Enter, Esc to go back{/gray-fg}`\n565:           );\n566:           statusLine.setContent(`{gray-fg}ID: ${questId} | Title: ${questTitle}{/gray-fg}`);\n567:           selectList.setItems(\n568:             (VALID_PRIORITIES as readonly string[]).map((p) => {\n569:               const dot = PRIORITY_COLORS[p] ?? \"white\";\n570:               const marker = p === \"medium\" ? \" {gray-fg}(default){/gray-fg}\" : \"\";\n571:               return `  {${dot}-fg}\\u25CF{/${dot}-fg}  ${p}${marker}`;\n572:             }) as any\n573:           );\n574:           // Pre-select \"medium\" (index 2)\n575:           selectList.select(2);\n576:           selectList.show();\n577:           selectList.focus();\n578:           break;\n579: \n580:         case \"difficulty\":\n581:           content.setContent(\n582:             `{bold}${stepLabel} — Difficulty{/bold}\\n` +\n583:             `{gray-fg}Select with Enter, Esc to go back{/gray-fg}`\n584:           );\n585:           statusLine.setContent(`{gray-fg}ID: ${questId} | Priority: ${questPriority}{/gray-fg}`);\n586:           selectList.setItems(\n587:             (VALID_DIFFICULTIES as readonly string[]).map((d) => {\n588:               const marker = d === \"medium\" ? \" {gray-fg}(default){/gray-fg}\" : \"\";\n589:               return `  ${d}${marker}`;\n590:             }) as any\n591:           );\n592:           selectList.select(2);\n593:           selectList.show();\n594:           selectList.focus();\n595:           break;\n596: \n597:         case \"hitl\":\n598:           content.setContent(\n599:             `{bold}${stepLabel} — HITL Mode{/bold}\\n` +\n600:             `{gray-fg}Human-in-the-loop mode for agents. Select with Enter, Esc to go back{/gray-fg}`\n601:           );\n602:           statusLine.setContent(`{gray-fg}ID: ${questId} | Difficulty: ${questDifficulty}{/gray-fg}`);\n603:           const hitlDescs: Record<string, string> = {\n604:             yolo: \"Full autonomy, no interruptions\",\n605:             cautious: \"Agent blocks on uncertainty, user answers in TUI\",\n606:             supervised: \"Like cautious, but prompt encourages asking often\",\n607:           };\n608:           selectList.setItems(\n609:             (VALID_HITL_MODES as readonly string[]).map((m) => {\n610:               const desc = hitlDescs[m] ?? \"\";\n611:               const marker = m === \"yolo\" ? \" {gray-fg}(default){/gray-fg}\" : \"\";\n612:               return `  ${m}${marker}  {gray-fg}— ${desc}{/gray-fg}`;\n613:             }) as any\n614:           );\n615:           selectList.select(0);\n616:           selectList.show();\n617:           selectList.focus();\n618:           break;\n619:       }\n620: \n621:       this.screen.render();\n622:     };\n623: \n624:     const goBack = () => {\n625:       if (currentStepIdx <= 0) {\n626:         cleanup();\n627:         return;\n628:       }\n629:       currentStepIdx--;\n630:       showStep(steps[currentStepIdx]);\n631:     };\n632: \n633:     const advanceOrFinish = () => {\n634:       currentStepIdx++;\n635:       if (currentStepIdx >= steps.length) {\n636:         // All done — create the quest\n637:         this.finishCreateQuest(\n638:           questId,\n639:           questTitle,\n640:           questGoal,\n641:           questPriority,\n642:           questDifficulty,\n643:           questHitl,\n644:           modal,\n645:           content,\n646:           statusLine\n647:         );\n648:         return;\n649:       }\n650:       showStep(steps[currentStepIdx]);\n651:     };\n652: \n653:     // --- Textbox submit/cancel for ID and Title steps ---\n654:     textbox.on(\"submit\", (value: string) => {\n655:       const trimmed = (value ?? \"\").trim();\n656:       const currentStep = steps[currentStepIdx];\n657: \n658:       if (currentStep === \"id\") {\n659:         // Validate ID\n660:         if (!trimmed) {\n661:           statusLine.setContent(\"{red-fg}ID cannot be empty{/red-fg}\");\n662:           this.screen.render();\n663:           textbox.focus();\n664:           return;\n665:         }\n666:         if (!/^[a-z0-9][a-z0-9-]*[a-z0-9]$|^[a-z0-9]$/.test(trimmed)) {\n667:           statusLine.setContent(\"{red-fg}ID must be kebab-case (lowercase letters, numbers, hyphens){/red-fg}\");\n668:           this.screen.render();\n669:           textbox.focus();\n670:           return;\n671:         }\n672:         // Check duplicate\n673:         const existing = loadQuest(this.projectRoot, trimmed);\n674:         if (existing) {\n675:           statusLine.setContent(`{red-fg}Quest \"${trimmed}\" already exists (${existing.status}){/red-fg}`);\n676:           this.screen.render();\n677:           textbox.focus();\n678:           return;\n679:         }\n680:         questId = trimmed;\n681:         advanceOrFinish();\n682:       } else if (currentStep === \"title\") {\n683:         if (!trimmed) {\n684:           statusLine.setContent(\"{red-fg}Title cannot be empty{/red-fg}\");\n685:           this.screen.render();\n686:           textbox.focus();\n687:           return;\n688:         }\n689:         questTitle = trimmed;\n690:         advanceOrFinish();\n691:       }\n692:     });\n693: \n694:     textbox.on(\"cancel\", () => {\n695:       goBack();\n696:     });\n697: \n698:     // --- Textarea submit/cancel for Goal step ---\n699:     textarea.key([\"enter\"], () => {\n700:       const val = (textarea.getValue() ?? \"\").trim();\n701:       if (!val) {\n702:         statusLine.setContent(\"{red-fg}Goal cannot be empty{/red-fg}\");\n703:         this.screen.render();\n704:         return;\n705:       }\n706:       questGoal = val;\n707:       advanceOrFinish();\n708:     });\n709: \n710:     textarea.key([\"escape\"], () => {\n711:       goBack();\n712:     });\n713: \n714:     // --- Select list for Priority, Difficulty, HITL ---\n715:     selectList.on(\"select item\", (_item: any, index: number) => {\n716:       // This fires on mouse click or manual select event\n717:     });\n718: \n719:     selectList.key([\"enter\", \"space\"], () => {\n720:       const currentStep = steps[currentStepIdx];\n721:       const idx = (selectList as any).selected ?? 0;\n722: \n723:       if (currentStep === \"priority\") {\n724:         questPriority = (VALID_PRIORITIES as readonly string[])[idx] as Priority;\n725:         advanceOrFinish();\n726:       } else if (currentStep === \"difficulty\") {\n727:         questDifficulty = (VALID_DIFFICULTIES as readonly string[])[idx] as Difficulty;\n728:         advanceOrFinish();\n729:       } else if (currentStep === \"hitl\") {\n730:         questHitl = (VALID_HITL_MODES as readonly string[])[idx] as QuestHitlMode;\n731:         advanceOrFinish();\n732:       }\n733:     });\n734: \n735:     selectList.key([\"escape\"], () => {\n736:       goBack();\n737:     });\n738: \n739:     // Start at step 0\n740:     showStep(steps[0]);\n741:   }\n742: \n743:   /**\n744:    * Finalize quest creation: save to store, show confirmation, reload list.\n745:    */\n746:   private finishCreateQuest(\n747:     id: string,\n748:     title: string,\n749:     goal: string,\n750:     priority: Priority,\n751:     difficulty: Difficulty,\n752:     hitlMode: QuestHitlMode,\n753:     modal: Widgets.BoxElement,\n754:     content: Widgets.BoxElement,\n755:     statusLine: Widgets.BoxElement\n756:   ): void {\n757:     try {\n758:       const baseBranch = this.config.baseBranch;\n759:       const quest = createBlankQuest(id, title, goal, baseBranch, {\n760:         priority,\n761:         difficulty,\n762:         hitlMode,\n763:       });\n764: \n765:       saveQuest(this.projectRoot, quest);\n766: \n767:       // Show confirmation briefly\n768:       content.setContent(\n769:         `{bold}{green-fg}\\u2714 Quest created!{/green-fg}{/bold}\\n\\n` +\n770:         `  {white-fg}${id}{/white-fg} — ${escapeBlessedTags(title)}\\n` +\n771:         `  Priority: ${priority}  |  Difficulty: ${difficulty}  |  HITL: ${hitlMode}\\n` +\n772:         `  Branch: quest/${id}  |  Base: ${baseBranch}`\n773:       );\n774:       statusLine.setContent(\"{gray-fg}Returning to quest list...{/gray-fg}\");\n775:       this.screen.render();\n776: \n777:       // After a brief delay, reload and return to picker\n778:       setTimeout(() => {\n779:         modal.destroy();\n780:         this.creatingQuest = false;\n781:         this.loadQuests();\n782:         // Select the newly created quest\n783:         const newIdx = this.items.findIndex(\n784:           (item) => item.type === \"quest\" && item.summary.quest.id === id\n785:         );\n786:         if (newIdx >= 0) this.selectedIndex = newIdx;\n787:         this.refreshAll();\n788:         this.questList.focus();\n789:         this.screen.render();\n790:       }, 1500);\n791:     } catch (err: unknown) {\n792:       const msg = err instanceof Error ? err.message : String(err);\n793:       content.setContent(\n794:         `{bold}{red-fg}\\u2718 Failed to create quest{/red-fg}{/bold}\\n\\n` +\n795:         `  ${escapeBlessedTags(msg)}`\n796:       );\n797:       statusLine.setContent(\"{gray-fg}Press Esc to return{/gray-fg}\");\n798:       this.screen.render();\n799: \n800:       const escHandler = () => {\n801:         modal.destroy();\n802:         this.creatingQuest = false;\n803:         this.questList.focus();\n804:         this.screen.render();\n805:       };\n806:       modal.key([\"escape\"], escHandler);\n807:     }\n808:   }\n809: \n810:   // -----------------------------------------------------------------------\n811:   // Refresh Logic\n812:   // -----------------------------------------------------------------------\n813: \n814:   private refreshAll(): void {\n815:     this.refreshHeader();\n816:     this.refreshList();\n817:     this.refreshDetail();\n818:     this.refreshStatusBar();\n819:   }\n820: \n821:   private refreshHeader(): void {\n822:     const questCount = this.items.length - 1; // exclude \"All Tasks\"\n823:     const activeCount = this.items.filter(\n824:       (i) => i.type === \"quest\" && i.summary.quest.status === \"active\"\n825:     ).length;\n826: \n827:     let line1 = ` {bold}wombo-combo{/bold} {magenta-fg}Quest Picker{/magenta-fg}`;\n828:     line1 += `  {gray-fg}|{/gray-fg}  {white-fg}${questCount}{/white-fg} quest${questCount !== 1 ? \"s\" : \"\"}`;\n829:     if (activeCount > 0) {\n830:       line1 += `  {gray-fg}|{/gray-fg}  {green-fg}${activeCount}{/green-fg} active`;\n831:     }\n832:     line1 += `  {gray-fg}|{/gray-fg}  {white-fg}${this.totalTaskCount}{/white-fg} total tasks`;\n833: \n834:     let line2 = ` {gray-fg}Select a quest to filter tasks, or choose \"All Tasks\" for the full list{/gray-fg}`;\n835: \n836:     this.headerBox.setContent(`${line1}\\n${line2}`);\n837:   }\n838: \n839:   private refreshList(): void {\n840:     const listItems: string[] = [];\n841: \n842:     for (const item of this.items) {\n843:       if (item.type === \"all\") {\n844:         listItems.push(\n845:           ` {bold}{cyan-fg}\\u25C6{/cyan-fg} All Tasks{/bold} {gray-fg}(${this.totalTaskCount}){/gray-fg}`\n846:         );\n847:       } else {\n848:         const { quest, totalTasks, doneTasks, completionPct } = item.summary;\n849: \n850:         // Status badge\n851:         const sColor = STATUS_COLORS[quest.status] ?? \"white\";\n852:         const sAbbr = STATUS_ABBREV[quest.status] ?? quest.status.slice(0, 4).toUpperCase();\n853:         const statusBadge = `{${sColor}-fg}${sAbbr}{/${sColor}-fg}`;\n854: \n855:         // Priority\n856:         const pColor = PRIORITY_COLORS[quest.priority] ?? \"white\";\n857:         const priorityDot = `{${pColor}-fg}\\u25CF{/${pColor}-fg}`;\n858: \n859:         // Title (truncated)\n860:         const maxTitleLen = 28;\n861:         const title = quest.title.length > maxTitleLen\n862:           ? quest.title.slice(0, maxTitleLen - 1) + \"\\u2026\"\n863:           : quest.title;\n864: \n865:         // Completion bar\n866:         const barWidth = 8;\n867:         const filled = Math.round((completionPct / 100) * barWidth);\n868:         const empty = barWidth - filled;\n869:         const bar = `{green-fg}${\"#\".repeat(filled)}{/green-fg}{gray-fg}${\"-\".repeat(empty)}{/gray-fg}`;\n870: \n871:         // Task count\n872:         const taskInfo = totalTasks > 0\n873:           ? `{gray-fg}${doneTasks}/${totalTasks}{/gray-fg}`\n874:           : `{gray-fg}0 tasks{/gray-fg}`;\n875: \n876:         listItems.push(\n877:           ` ${priorityDot} ${statusBadge} ${escapeBlessedTags(title)}  [${bar}] ${taskInfo}`\n878:         );\n879:       }\n880:     }\n881: \n882:     if (listItems.length === 0) {\n883:       listItems.push(\" {gray-fg}No quests found{/gray-fg}\");\n884:     }\n885: \n886:     const prevSelected = this.selectedIndex;\n887:     this.questList.setItems(listItems as any);\n888:     if (prevSelected < listItems.length) {\n889:       this.questList.select(prevSelected);\n890:     }\n891:   }\n892: \n893:   private refreshDetail(): void {\n894:     const item = this.items[this.selectedIndex];\n895:     if (!item) {\n896:       this.detailBox.setContent(\"{gray-fg}No item selected{/gray-fg}\");\n897:       this.detailBox.setLabel(\" Details \");\n898:       return;\n899:     }\n900: \n901:     if (item.type === \"all\") {\n902:       const lines: string[] = [\n903:         \"{bold}{cyan-fg}All Tasks{/cyan-fg}{/bold}\",\n904:         \"\",\n905:         \"  Browse all tasks across all quests\",\n906:         \"  and unassigned tasks.\",\n907:         \"\",\n908:         `  Total: {white-fg}${this.totalTaskCount}{/white-fg} tasks`,\n909:         \"\",\n910:         \"  Press {bold}Enter{/bold} to open the full task browser.\",\n911:       ];\n912:       this.detailBox.setContent(lines.join(\"\\n\"));\n913:       this.detailBox.setLabel(\" All Tasks \");\n914:       return;\n915:     }\n916: \n917:     const { quest, totalTasks, doneTasks, completionPct } = item.summary;\n918:     const lines: string[] = [];\n919: \n920:     // Title\n921:     lines.push(`{bold}{white-fg}${escapeBlessedTags(quest.title)}{/white-fg}{/bold}`);\n922:     lines.push(\"\");\n923: \n924:     // Status\n925:     const sColor = STATUS_COLORS[quest.status] ?? \"white\";\n926:     lines.push(`  Status:     {${sColor}-fg}${quest.status}{/${sColor}-fg}`);\n927: \n928:     // Priority\n929:     const pColor = PRIORITY_COLORS[quest.priority] ?? \"white\";\n930:     lines.push(`  Priority:   {${pColor}-fg}${quest.priority}{/${pColor}-fg}`);\n931: \n932:     // Difficulty\n933:     lines.push(`  Difficulty: ${quest.difficulty}`);\n934: \n935:     // HITL mode\n936:     lines.push(`  HITL:       ${quest.hitlMode}`);\n937:     lines.push(\"\");\n938: \n939:     // Task progress\n940:     if (totalTasks > 0) {\n941:       lines.push(\"{bold}Progress:{/bold}\");\n942:       lines.push(`  Tasks: ${doneTasks}/${totalTasks} done (${completionPct}%)`);\n943: \n944:       // Progress bar (wider in detail view)\n945:       const barWidth = 20;\n946:       const filled = Math.round((completionPct / 100) * barWidth);\n947:       const empty = barWidth - filled;\n948:       const bar = `{green-fg}${\"=\".repeat(filled)}{/green-fg}{gray-fg}${\"-\".repeat(empty)}{/gray-fg}`;\n949:       lines.push(`  [${bar}]`);\n950:     } else {\n951:       lines.push(\"{bold}Progress:{/bold}\");\n952:       lines.push(\"  {gray-fg}No tasks assigned{/gray-fg}\");\n953:     }\n954:     lines.push(\"\");\n955: \n956:     // Goal\n957:     if (quest.goal) {\n958:       lines.push(\"{bold}Goal:{/bold}\");\n959:       const goalText = escapeBlessedTags(quest.goal.trim());\n960:       const words = goalText.split(/\\s+/);\n961:       let line = \" \";\n962:       for (const w of words) {\n963:         if (line.length + w.length > 42) {\n964:           lines.push(line);\n965:           line = \" \" + w;\n966:         } else {\n967:           line += \" \" + w;\n968:         }\n969:       }\n970:       if (line.trim()) lines.push(line);\n971:       lines.push(\"\");\n972:     }\n973: \n974:     // Branch\n975:     lines.push(\"{bold}Branch:{/bold}\");\n976:     lines.push(`  ${quest.branch}`);\n977:     lines.push(`  Base: ${quest.baseBranch}`);\n978:     lines.push(\"\");\n979: \n980:     // Constraints\n981:     if (quest.constraints.add.length > 0) {\n982:       lines.push(\"{bold}Added Constraints:{/bold}\");\n983:       for (const c of quest.constraints.add) {\n984:         lines.push(`  + ${escapeBlessedTags(c)}`);\n985:       }\n986:       lines.push(\"\");\n987:     }\n988:     if (quest.constraints.ban.length > 0) {\n989:       lines.push(\"{bold}Banned:{/bold}\");\n990:       for (const b of quest.constraints.ban) {\n991:         lines.push(`  - ${escapeBlessedTags(b)}`);\n992:       }\n993:       lines.push(\"\");\n994:     }\n995: \n996:     // Dependencies\n997:     if (quest.depends_on.length > 0) {\n998:       lines.push(\"{bold}Depends on:{/bold}\");\n999:       for (const d of quest.depends_on) {\n1000:         lines.push(`  \\u2192 ${d}`);\n1001:       }\n1002:       lines.push(\"\");\n1003:     }\n1004: \n1005:     // Notes\n1006:     if (quest.notes.length > 0) {\n1007:       lines.push(\"{bold}Notes:{/bold}\");\n1008:       for (const n of quest.notes) {\n1009:         lines.push(`  ${escapeBlessedTags(n)}`);\n1010:       }\n1011:       lines.push(\"\");\n1012:     }\n1013: \n1014:     // Timestamps\n1015:     lines.push(\"{bold}Timeline:{/bold}\");\n1016:     lines.push(`  Created: ${quest.created_at.slice(0, 10)}`);\n1017:     if (quest.started_at) lines.push(`  Started: ${quest.started_at.slice(0, 10)}`);\n1018:     if (quest.ended_at) lines.push(`  Ended:   ${quest.ended_at.slice(0, 10)}`);\n1019: \n1020:     this.detailBox.setContent(lines.join(\"\\n\"));\n1021:     this.detailBox.setLabel(` ${quest.id} `);\n1022:   }\n1023: \n1024:   private refreshStatusBar(): void {\n1025:     let line1 = ` {bold}Keys:{/bold}`;\n1026:     line1 += `  {gray-fg}Enter{/gray-fg} select`;\n1027:     line1 += `  {gray-fg}C{/gray-fg} create`;\n1028:     line1 += `  {gray-fg}E{/gray-fg} errand`;\n1029:     line1 += `  {gray-fg}P{/gray-fg} plan`;\n1030:     line1 += `  {gray-fg}G{/gray-fg} genesis`;\n1031:     line1 += `  {gray-fg}A{/gray-fg} activate/pause`;\n1032:     line1 += `  {gray-fg}Q{/gray-fg} quit`;\n1033: \n1034:     const item = this.items[this.selectedIndex];\n1035:     let line2 = \" \";\n1036:     if (item?.type === \"all\") {\n1037:       line2 += `{cyan-fg}View all tasks across all quests{/cyan-fg}`;\n1038:     } else if (item?.type === \"quest\") {\n1039:       const q = item.summary.quest;\n1040:       line2 += `{white-fg}${escapeBlessedTags(q.id)}{/white-fg}`;\n1041:       line2 += `  {gray-fg}|{/gray-fg}  ${item.summary.totalTasks} task${item.summary.totalTasks !== 1 ? \"s\" : \"\"}`;\n1042:       line2 += `  {gray-fg}|{/gray-fg}  ${item.summary.completionPct}% complete`;\n1043:       if (q.status === \"draft\" || q.status === \"planning\") {\n1044:         line2 += `  {gray-fg}|{/gray-fg}  {magenta-fg}P to plan{/magenta-fg}`;\n1045:       }\n1046:     }\n1047: \n1048:     this.statusBar.setContent(`${line1}\\n${line2}`);\n1049:   }\n1050: }\n\n(End of file - total 1050 lines)\n</content>","title":"src/lib/tui-quest-picker.ts","metadata":{"preview":"/**\n * tui-quest-picker.ts -- Quest picker view for the wombo-combo TUI.\n *\n * Shows all quests as a selectable list with an \"All Tasks\" option at the top.\n * Selecting a quest navigates to the Task Browser filtered to that quest's tasks.\n *\n * Layout:\n *   +-----------------------------------------------------------+\n *   | WOMBO-COMBO Quest Picker  | 4 quests                      |\n *   +---------------------------+-------------------------------+\n *   | > All Tasks (42)          | Quest: auth-overhaul           |\n *   |   auth-overhaul   ACTV    | Status: active                 |\n *   |   search-api      DRFT    | Priority: high                 |\n *   |   perf-optim      PAUS    | Tasks: 8 (3 done, 62%)         |\n *   |   ui-redesign     PLAN    | Goal: Replace basic auth...    |\n *   |                           |                                |\n *   +---------------------------+-------------------------------+\n *   | Enter:select  C:create  Q:quit                            |\n *   +-----------------------------------------------------------+\n *","truncated":false,"loaded":[]},"time":{"start":1773482657709,"end":1773482657711}}}}
