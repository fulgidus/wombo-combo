{"type":"tool_use","timestamp":1773482838526,"sessionID":"ses_314328759ffeSwO8I1laVGgGu4","part":{"id":"prt_cebd085e5001CIMLKC3rXrr73Y","sessionID":"ses_314328759ffeSwO8I1laVGgGu4","messageID":"msg_cebd07798001XWWnljjH6Qn2Zo","type":"tool","callID":"toolu_vrtx_01BbzKwQ8q2tpuPehtyx5EUE","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/wishlist-promote/src/commands/tui.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/wishlist-promote/src/commands/tui.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tui.ts -- Unified TUI command entry point for wombo-combo.\n3:  *\n4:  * Orchestrates multiple views in a persistent loop:\n5:  *   1. Quest Picker (tui-quest-picker.ts) -- select a quest or \"All Tasks\"\n6:  *   2. Task Browser (tui-browser.ts) -- select tasks, change priorities, launch\n7:  *   3. Wave Monitor (tui.ts) -- watch running wave, view logs, retry agents\n8:  *   4. Plan Review (tui-plan-review.ts) -- review/edit/approve planner output\n9:  *   5. Genesis Review (tui-genesis-review.ts) -- review/edit/approve genesis plan\n10:  *\n11:  * Flow:\n12:  *   `woco` -> Quest Picker (if quests exist) -> Task Browser -> L -> launches\n13:  *   wave -> wave completes -> Q in monitor -> back to Quest Picker -> ...\n14:  *\n15:  *   Quest Picker -> P (plan) -> spinner -> Plan Review -> approve/cancel ->\n16:  *   back to Quest Picker\n17:  *\n18:  *   Quest Picker -> G (genesis) -> vision prompt -> spinner -> Genesis Review\n19:  *   -> approve/cancel -> back to Quest Picker\n20:  *\n21:  *   Quest Picker/Browser -> E (errand) -> description prompt -> spinner ->\n22:  *   Plan Review -> approve/cancel -> creates quest-less tasks -> back\n23:  *\n24:  * If no quests exist, the Quest Picker is skipped entirely and the flow goes\n25:  * straight to the Task Browser (backward compatible).\n26:  *\n27:  * Exit behavior:\n28:  *   - Q from Quest Picker: exits the process\n29:  *   - Q/Esc from Task Browser: back to Quest Picker (or exits if no quests)\n30:  *   - Q from Wave Monitor: back to Quest Picker\n31:  *   - Q/Esc from Plan Review: discard plan, back to Quest Picker\n32:  *\n33:  * Session state is persisted to .wombo-combo/tui-session.json so the user can\n34:  * close and reopen the TUI without losing their task selections.\n35:  */\n36: \n37: import type { WomboConfig } from \"../config.js\";\n38: import { ensureTasksFile } from \"../lib/tasks.js\";\n39: import { loadState } from \"../lib/state.js\";\n40: import { loadTUISession, saveTUISession } from \"../lib/tui-session.js\";\n41: import type { TUISession } from \"../lib/tui-session.js\";\n42: import { TaskBrowser } from \"../lib/tui-browser.js\";\n43: import { QuestPicker } from \"../lib/tui-quest-picker.js\";\n44: import type { QuestPickerAction } from \"../lib/tui-quest-picker.js\";\n45: import { PlanReview } from \"../lib/tui-plan-review.js\";\n46: import type { ProposedTask } from \"../lib/quest-planner.js\";\n47: import { runQuestPlanner, applyPlanToQuest } from \"../lib/quest-planner.js\";\n48: import type { PlanResult } from \"../lib/quest-planner.js\";\n49: import { loadAllQuests, loadQuest, saveQuest, listQuestIds, saveQuestKnowledge } from \"../lib/quest-store.js\";\n50: import { GenesisReview } from \"../lib/tui-genesis-review.js\";\n51: import type { GenesisReviewAction } from \"../lib/tui-genesis-review.js\";\n52: import { runGenesisPlanner } from \"../lib/genesis-planner.js\";\n53: import type { GenesisResult, ProposedQuest } from \"../lib/genesis-planner.js\";\n54: import { createBlankQuest } from \"../lib/quest.js\";\n55: import { runErrandPlanner, applyErrandPlan } from \"../lib/errand-planner.js\";\n56: import { cmdLaunch } from \"./launch.js\";\n57: import type { LaunchCommandOptions } from \"./launch.js\";\n58: import { cmdResume } from \"./resume.js\";\n59: \n60: // ---------------------------------------------------------------------------\n61: // Types\n62: // ---------------------------------------------------------------------------\n63: \n64: export interface TUICommandOptions {\n65:   projectRoot: string;\n66:   config: WomboConfig;\n67:   /** Max concurrent agents (override, or null to use session/config default) */\n68:   maxConcurrent?: number;\n69:   /** Model override */\n70:   model?: string;\n71:   /** Base branch override */\n72:   baseBranch?: string;\n73:   /** Max retries override */\n74:   maxRetries?: number;\n75:   /** Auto-push after merge */\n76:   autoPush?: boolean;\n77:   /** Skip TDD tests */\n78:   skipTests?: boolean;\n79:   /** Strict TDD mode */\n80:   strictTdd?: boolean;\n81:   /** Agent definition override */\n82:   agent?: string;\n83: }\n84: \n85: type BrowserAction =\n86:   | { type: \"launch\"; ids: string[] }\n87:   | { type: \"errand\" }\n88:   | { type: \"back\" }\n89:   | { type: \"quit\" };\n90: \n91: type PlanReviewResult =\n92:   | { type: \"approve\"; tasks: ProposedTask[]; knowledge: string | null }\n93:   | { type: \"cancel\" };\n94: \n95: // ---------------------------------------------------------------------------\n96: // Command -- Main Loop\n97: // ---------------------------------------------------------------------------\n98: \n99: export async function cmdTui(opts: TUICommandOptions): Promise<void> {\n100:   const { projectRoot, config } = opts;\n101: \n102:   // Ensure tasks file exists\n103:   await ensureTasksFile(projectRoot, config);\n104: \n105:   // Load session state (persisted selections, sort, concurrency)\n106:   const session = loadTUISession(projectRoot);\n107: \n108:   // Apply concurrency override from CLI if provided\n109:   if (opts.maxConcurrent !== undefined) {\n110:     session.maxConcurrent = opts.maxConcurrent;\n111:   }\n112: \n113:   // Main TUI loop:\n114:   //   Quest Picker -> Task Browser -> Launch -> Monitor -> back to Quest Picker\n115:   // Only exits when the user presses Q from the Quest Picker (or browser if no quests).\n116:   while (true) {\n117:     // Check for an active wave on each iteration\n118:     const existingState = loadState(projectRoot);\n119:     const hasRunningWave =\n120:       existingState !== null &&\n121:       existingState.agents.some(\n122:         (a) =>\n123:           a.status === \"running\" ||\n124:           a.status === \"queued\" ||\n125:           a.status === \"installing\" ||\n126:           a.status === \"resolving_conflict\" ||\n127:           a.status === \"retry\"\n128:       );\n129: \n130:     if (hasRunningWave) {\n131:       // A wave is already running -- resume it (wave monitor TUI).\n132:       // When the wave completes and the user presses Q, cmdResume returns\n133:       // and we loop back to the quest picker / browser.\n134:       console.log(\n135:         `Active wave detected: ${existingState!.wave_id}. Resuming...`\n136:       );\n137:       try {\n138:         await cmdResume({\n139:           projectRoot,\n140:           config,\n141:           maxConcurrent: opts.maxConcurrent,\n142:           model: opts.model,\n143:           interactive: false,\n144:           noTui: false,\n145:           autoPush: opts.autoPush ?? false,\n146:           baseBranch: opts.baseBranch,\n147:           maxRetries: opts.maxRetries,\n148:         });\n149:       } catch (err: any) {\n150:         // Don't crash -- show error and loop back\n151:         console.error(`\\nResume error: ${err.message}\\n`);\n152:         await sleep(2000);\n153:       }\n154:       // Clear terminal before showing picker/browser again\n155:       process.stdout.write(\"\\x1B[2J\\x1B[H\");\n156:       continue;\n157:     }\n158: \n159:     // -----------------------------------------------------------------------\n160:     // Quest Picker (skip if no quests exist)\n161:     // -----------------------------------------------------------------------\n162:     const quests = loadAllQuests(projectRoot);\n163:     const hasQuests = quests.length > 0;\n164: \n165:     let selectedQuestId: string | null = null;\n166: \n167:     if (hasQuests) {\n168:       const questAction = await showQuestPicker(projectRoot, config, opts);\n169: \n170:       if (questAction.type === \"quit\") {\n171:         // User pressed Q in quest picker -- exit cleanly\n172:         session.lastView = \"browser\";\n173:         saveTUISession(projectRoot, session);\n174:         break;\n175:       }\n176: \n177:       if (questAction.type === \"plan\") {\n178:         // User pressed P to plan a quest -- run planner + review\n179:         await handlePlanFlow(projectRoot, config, opts, questAction.questId);\n180:         // After planning (approve or cancel), loop back to quest picker\n181:         process.stdout.write(\"\\x1B[2J\\x1B[H\");\n182:         continue;\n183:       }\n184: \n185:       if (questAction.type === \"genesis\") {\n186:         // User pressed G to run genesis -- run genesis planner + review\n187:         await handleGenesisFlow(projectRoot, config, opts);\n188:         // After genesis (approve or cancel), loop back to quest picker\n189:         process.stdout.write(\"\\x1B[2J\\x1B[H\");\n190:         continue;\n191:       }\n192: \n193:       if (questAction.type === \"errand\") {\n194:         // User pressed E to create an errand (quest-less assisted task)\n195:         await handleErrandFlow(projectRoot, config, opts);\n196:         // After errand (approve or cancel), loop back to quest picker\n197:         process.stdout.write(\"\\x1B[2J\\x1B[H\");\n198:         continue;\n199:       }\n200: \n201:       selectedQuestId = questAction.questId;\n202:     }\n203: \n204:     // -----------------------------------------------------------------------\n205:     // Task Browser (filtered by quest if one was selected)\n206:     // -----------------------------------------------------------------------\n207:     const action = await showBrowser(\n208:       projectRoot,\n209:       config,\n210:       session,\n211:       opts,\n212:       selectedQuestId,\n213:       hasQuests\n214:     );\n215: \n216:     if (action.type === \"quit\") {\n217:       // User pressed Q in browser with no quest context -- exit cleanly\n218:       session.lastView = \"browser\";\n219:       saveTUISession(projectRoot, session);\n220:       break;\n221:     }\n222: \n223:     if (action.type === \"back\") {\n224:       // User pressed Q/Esc in quest-filtered browser -- back to quest picker\n225:       process.stdout.write(\"\\x1B[2J\\x1B[H\");\n226:       continue;\n227:     }\n228: \n229:     if (action.type === \"errand\") {\n230:       // User pressed E in browser to create an errand\n231:       await handleErrandFlow(projectRoot, config, opts);\n232:       process.stdout.write(\"\\x1B[2J\\x1B[H\");\n233:       continue;\n234:     }\n235: \n236:     if (action.type === \"launch\") {\n237:       // Save session before launching\n238:       session.selected = action.ids;\n239:       session.lastView = \"monitor\";\n240:       saveTUISession(projectRoot, session);\n241: \n242:       // Build launch options\n243:       const launchOpts: LaunchCommandOptions = {\n244:         projectRoot,\n245:         config,\n246:         features: action.ids,\n247:         maxConcurrent: session.maxConcurrent,\n248:         model: opts.model,\n249:         interactive: false,\n250:         dryRun: false,\n251:         baseBranch: opts.baseBranch ?? config.baseBranch,\n252:         maxRetries: opts.maxRetries ?? config.defaults.maxRetries,\n253:         noTui: false,\n254:         autoPush: opts.autoPush ?? false,\n255:         agent: opts.agent,\n256:         outputFmt: \"text\",\n257:         // Pass quest ID so launch uses quest branch and constraints\n258:         questId: selectedQuestId ?? undefined,\n259:       };\n260: \n261:       try {\n262:         await cmdLaunch(launchOpts);\n263:       } catch (err: any) {\n264:         // Don't crash -- show error and loop back\n265:         console.error(`\\nLaunch error: ${err.message}\\n`);\n266:         await sleep(2000);\n267:       }\n268: \n269:       // Clear terminal before showing picker/browser again\n270:       process.stdout.write(\"\\x1B[2J\\x1B[H\");\n271:       continue;\n272:     }\n273:   }\n274: }\n275: \n276: // ---------------------------------------------------------------------------\n277: // Quest Picker View -- Promise-based\n278: // ---------------------------------------------------------------------------\n279: \n280: /**\n281:  * Show the Quest Picker and return a Promise that resolves when the user\n282:  * takes an action (select quest, plan quest, or quit).\n283:  */\n284: function showQuestPicker(\n285:   projectRoot: string,\n286:   config: WomboConfig,\n287:   opts: TUICommandOptions\n288: ): Promise<QuestPickerAction> {\n289:   return new Promise<QuestPickerAction>((resolve) => {\n290:     const picker = new QuestPicker({\n291:       projectRoot,\n292:       config,\n293: \n294:       onSelect: (questId: string | null) => {\n295:         resolve({ type: \"select\", questId });\n296:       },\n297: \n298:       onPlan: (questId: string) => {\n299:         resolve({ type: \"plan\", questId });\n300:       },\n301: \n302:       onGenesis: () => {\n303:         resolve({ type: \"genesis\" });\n304:       },\n305: \n306:       onErrand: () => {\n307:         resolve({ type: \"errand\" });\n308:       },\n309: \n310:       onQuit: () => {\n311:         resolve({ type: \"quit\" });\n312:       },\n313:     });\n314: \n315:     picker.start();\n316:   });\n317: }\n318: \n319: // ---------------------------------------------------------------------------\n320: // Plan Flow -- Planner + Review\n321: // ---------------------------------------------------------------------------\n322: \n323: /**\n324:  * Run the quest planner agent, then show the plan review TUI.\n325:  * Handles the full flow: spinner → planner → review → approve/cancel.\n326:  */\n327: async function handlePlanFlow(\n328:   projectRoot: string,\n329:   config: WomboConfig,\n330:   opts: TUICommandOptions,\n331:   questId: string\n332: ): Promise<void> {\n333:   const quest = loadQuest(projectRoot, questId);\n334:   if (!quest) {\n335:     console.error(`\\nQuest \"${questId}\" not found.\\n`);\n336:     await sleep(2000);\n337:     return;\n338:   }\n339: \n340:   // Set quest to planning status\n341:   const prevStatus = quest.status;\n342:   quest.status = \"planning\";\n343:   saveQuest(projectRoot, quest);\n344: \n345:   // Show a planning spinner on the terminal (no blessed screen here)\n346:   console.log(`\\n  Planning quest: ${quest.title} (${quest.id})`);\n347:   console.log(`  Running quest planner agent...\\n`);\n348: \n349:   const spinChars = [\"\\u2802\", \"\\u2806\", \"\\u2807\", \"\\u2803\", \"\\u2809\", \"\\u280C\", \"\\u280E\", \"\\u280B\"];\n350:   let spinIdx = 0;\n351:   let lastProgress = \"\";\n352:   const spinTimer = setInterval(() => {\n353:     const ch = spinChars[spinIdx % spinChars.length];\n354:     spinIdx++;\n355:     process.stdout.write(`\\r  ${ch} ${lastProgress}`);\n356:   }, 120);\n357: \n358:   let planResult: PlanResult;\n359: \n360:   try {\n361:     planResult = await runQuestPlanner(quest, projectRoot, config, {\n362:       model: opts.model,\n363:       onProgress: (msg) => {\n364:         lastProgress = msg;\n365:       },\n366:     });\n367:   } catch (err: any) {\n368:     clearInterval(spinTimer);\n369:     process.stdout.write(\"\\r\" + \" \".repeat(80) + \"\\r\");\n370:     console.error(`\\n  Planner error: ${err.message}\\n`);\n371:     // Revert quest status\n372:     quest.status = prevStatus;\n373:     saveQuest(projectRoot, quest);\n374:     await sleep(3000);\n375:     return;\n376:   }\n377: \n378:   clearInterval(spinTimer);\n379:   process.stdout.write(\"\\r\" + \" \".repeat(80) + \"\\r\");\n380: \n381:   if (!planResult.success && planResult.tasks.length === 0) {\n382:     // Total failure — no tasks produced\n383:     console.error(`\\n  Planner failed: ${planResult.error ?? \"No tasks produced\"}\\n`);\n384:     quest.status = prevStatus;\n385:     saveQuest(projectRoot, quest);\n386:     await sleep(3000);\n387:     return;\n388:   }\n389: \n390:   console.log(`  Planner produced ${planResult.tasks.length} tasks.`);\n391:   if (planResult.issues.length > 0) {\n392:     const errors = planResult.issues.filter((i) => i.level === \"error\").length;\n393:     const warnings = planResult.issues.filter((i) => i.level === \"warning\").length;\n394:     if (errors > 0) console.log(`  ${errors} validation error(s).`);\n395:     if (warnings > 0) console.log(`  ${warnings} validation warning(s).`);\n396:   }\n397:   console.log(`  Opening plan review...\\n`);\n398:   await sleep(1000);\n399: \n400:   // Clear terminal before showing the plan review TUI\n401:   process.stdout.write(\"\\x1B[2J\\x1B[H\");\n402: \n403:   // Show the plan review TUI\n404:   const reviewAction = await showPlanReview(\n405:     questId,\n406:     quest.title,\n407:     planResult\n408:   );\n409: \n410:   if (reviewAction.type === \"cancel\") {\n411:     // User cancelled — revert quest status\n412:     quest.status = prevStatus;\n413:     saveQuest(projectRoot, quest);\n414:     console.log(`\\n  Plan discarded. Quest \"${questId}\" reverted to \"${prevStatus}\".\\n`);\n415:     await sleep(1500);\n416:     return;\n417:   }\n418: \n419:   // User approved — apply the plan\n420:   try {\n421:     // Update planResult with only the accepted tasks\n422:     const approvedResult: PlanResult = {\n423:       ...planResult,\n424:       tasks: reviewAction.tasks,\n425:       knowledge: reviewAction.knowledge,\n426:     };\n427: \n428:     const tasks = applyPlanToQuest(approvedResult, quest, projectRoot, config);\n429:     console.log(`\\n  Plan approved! Created ${tasks.length} tasks.`);\n430:     console.log(`  Quest \"${questId}\" is now active.`);\n431:     if (reviewAction.knowledge) {\n432:       console.log(`  Saved knowledge file (${reviewAction.knowledge.length} chars).`);\n433:     }\n434:     console.log();\n435:     await sleep(2000);\n436:   } catch (err: any) {\n437:     console.error(`\\n  Failed to apply plan: ${err.message}\\n`);\n438:     quest.status = prevStatus;\n439:     saveQuest(projectRoot, quest);\n440:     await sleep(3000);\n441:   }\n442: }\n443: \n444: // ---------------------------------------------------------------------------\n445: // Genesis Flow -- Vision Prompt + Planner + Review\n446: // ---------------------------------------------------------------------------\n447: \n448: /**\n449:  * Run the genesis planner: prompt user for a vision, run the genesis planner\n450:  * agent, then show the genesis review TUI.\n451:  * Handles the full flow: readline prompt → spinner → planner → review → create quests.\n452:  */\n453: async function handleGenesisFlow(\n454:   projectRoot: string,\n455:   config: WomboConfig,\n456:   opts: TUICommandOptions,\n457:   prefill?: string\n458: ): Promise<void> {\n459:   let vision: string;\n460: \n461:   if (prefill) {\n462:     // Pre-filled from wishlist promotion — show the pre-filled text\n463:     console.log();\n464:     console.log(\"  ╔══════════════════════════════════════╗\");\n465:     console.log(\"  ║         GENESIS PLANNER              ║\");\n466:     console.log(\"  ╚══════════════════════════════════════╝\");\n467:     console.log();\n468:     console.log(`  Pre-filled from wishlist: ${prefill}`);\n469:     console.log();\n470:     vision = prefill;\n471:   } else {\n472:     // Prompt the user for a project vision via readline (no blessed screen is active)\n473:     const readline = await import(\"node:readline\");\n474:     const rl = readline.createInterface({\n475:       input: process.stdin,\n476:       output: process.stdout,\n477:     });\n478: \n479:     vision = await new Promise<string>((resolve) => {\n480:       console.log();\n481:       console.log(\"  ╔══════════════════════════════════════╗\");\n482:       console.log(\"  ║         GENESIS PLANNER              ║\");\n483:       console.log(\"  ╚══════════════════════════════════════╝\");\n484:       console.log();\n485:       console.log(\"  Describe your project vision. The genesis planner will\");\n486:       console.log(\"  decompose it into a set of quests.\");\n487:       console.log();\n488:       rl.question(\"  Vision: \", (answer) => {\n489:         rl.close();\n490:         resolve(answer.trim());\n491:       });\n492:     });\n493:   }\n494: \n495:   if (!vision) {\n496:     console.log(\"\\n  No vision provided. Returning to quest picker.\\n\");\n497:     await sleep(1500);\n498:     return;\n499:   }\n500: \n501:   // Gather existing quest IDs so the planner can avoid duplicates\n502:   const existingQuestIds = listQuestIds(projectRoot);\n503: \n504:   // Show a planning spinner on the terminal\n505:   console.log();\n506:   console.log(`  Running genesis planner agent...`);\n507:   console.log();\n508: \n509:   const spinChars = [\"\\u2802\", \"\\u2806\", \"\\u2807\", \"\\u2803\", \"\\u2809\", \"\\u280C\", \"\\u280E\", \"\\u280B\"];\n510:   let spinIdx = 0;\n511:   let lastProgress = \"\";\n512:   const spinTimer = setInterval(() => {\n513:     const ch = spinChars[spinIdx % spinChars.length];\n514:     spinIdx++;\n515:     process.stdout.write(`\\r  ${ch} ${lastProgress}`);\n516:   }, 120);\n517: \n518:   let genesisResult: GenesisResult;\n519: \n520:   try {\n521:     genesisResult = await runGenesisPlanner(vision, projectRoot, config, {\n522:       existingQuestIds,\n523:       model: opts.model,\n524:       onProgress: (msg) => {\n525:         lastProgress = msg;\n526:       },\n527:     });\n528:   } catch (err: any) {\n529:     clearInterval(spinTimer);\n530:     process.stdout.write(\"\\r\" + \" \".repeat(80) + \"\\r\");\n531:     console.error(`\\n  Genesis planner error: ${err.message}\\n`);\n532:     await sleep(3000);\n533:     return;\n534:   }\n535: \n536:   clearInterval(spinTimer);\n537:   process.stdout.write(\"\\r\" + \" \".repeat(80) + \"\\r\");\n538: \n539:   if (!genesisResult.success && genesisResult.quests.length === 0) {\n540:     // Total failure — no quests produced\n541:     console.error(`\\n  Genesis planner failed: ${genesisResult.error ?? \"No quests produced\"}\\n`);\n542:     await sleep(3000);\n543:     return;\n544:   }\n545: \n546:   console.log(`  Genesis planner produced ${genesisResult.quests.length} quests.`);\n547:   if (genesisResult.issues.length > 0) {\n548:     const errors = genesisResult.issues.filter((i) => i.level === \"error\").length;\n549:     const warnings = genesisResult.issues.filter((i) => i.level === \"warning\").length;\n550:     if (errors > 0) console.log(`  ${errors} validation error(s).`);\n551:     if (warnings > 0) console.log(`  ${warnings} validation warning(s).`);\n552:   }\n553:   console.log(`  Opening genesis review...\\n`);\n554:   await sleep(1000);\n555: \n556:   // Clear terminal before showing the genesis review TUI\n557:   process.stdout.write(\"\\x1B[2J\\x1B[H\");\n558: \n559:   // Show the genesis review TUI\n560:   const reviewAction = await showGenesisReview(genesisResult);\n561: \n562:   if (reviewAction.type === \"cancel\") {\n563:     console.log(`\\n  Genesis plan discarded.\\n`);\n564:     await sleep(1500);\n565:     return;\n566:   }\n567: \n568:   // User approved — create quests from accepted proposals\n569:   const baseBranch = opts.baseBranch ?? config.baseBranch;\n570:   const created: string[] = [];\n571: \n572:   for (const proposed of reviewAction.quests) {\n573:     const quest = createBlankQuest(proposed.id, proposed.title, proposed.goal, baseBranch, {\n574:       priority: proposed.priority,\n575:       difficulty: proposed.difficulty,\n576:       hitlMode: proposed.hitl_mode,\n577:     });\n578: \n579:     // Apply constraints from the genesis planner\n580:     quest.constraints.add = proposed.constraints.add ?? [];\n581:     quest.constraints.ban = proposed.constraints.ban ?? [];\n582:     quest.depends_on = proposed.depends_on ?? [];\n583:     quest.notes = proposed.notes ?? [];\n584: \n585:     saveQuest(projectRoot, quest);\n586:     created.push(quest.id);\n587:   }\n588: \n589:   console.log(`\\n  Genesis plan approved! Created ${created.length} quests:`);\n590:   for (const id of created) {\n591:     console.log(`    - ${id}`);\n592:   }\n593: \n594:   // Save knowledge if the planner produced any (attach to the first quest)\n595:   const knowledge = reviewAction.knowledge;\n596:   if (knowledge && created.length > 0) {\n597:     saveQuestKnowledge(projectRoot, created[0], knowledge);\n598:     console.log(`  Saved knowledge file (${knowledge.length} chars) to quest \"${created[0]}\".`);\n599:   }\n600: \n601:   console.log();\n602:   await sleep(2000);\n603: }\n604: \n605: // ---------------------------------------------------------------------------\n606: // Errand Flow -- Quick Task Generation (quest-less)\n607: // ---------------------------------------------------------------------------\n608: \n609: /**\n610:  * Run the errand planner: prompt user for a brief description, run the quest\n611:  * planner agent with an errand-specific prompt, then show plan review to let\n612:  * the user accept/reject/edit the proposed tasks.\n613:  *\n614:  * Created tasks go directly into the task store without any quest association.\n615:  */\n616: async function handleErrandFlow(\n617:   projectRoot: string,\n618:   config: WomboConfig,\n619:   opts: TUICommandOptions,\n620:   prefill?: string\n621: ): Promise<void> {\n622:   let description: string;\n623: \n624:   if (prefill) {\n625:     // Pre-filled from wishlist promotion — show the pre-filled text\n626:     console.log();\n627:     console.log(\"  ╔══════════════════════════════════════╗\");\n628:     console.log(\"  ║           ERRAND PLANNER             ║\");\n629:     console.log(\"  ╚══════════════════════════════════════╝\");\n630:     console.log();\n631:     console.log(`  Pre-filled from wishlist: ${prefill}`);\n632:     console.log();\n633:     description = prefill;\n634:   } else {\n635:     // Prompt the user for a description via readline (no blessed screen is active)\n636:     const readline = await import(\"node:readline\");\n637:     const rl = readline.createInterface({\n638:       input: process.stdin,\n639:       output: process.stdout,\n640:     });\n641: \n642:     description = await new Promise<string>((resolve) => {\n643:       console.log();\n644:       console.log(\"  ╔══════════════════════════════════════╗\");\n645:       console.log(\"  ║           ERRAND PLANNER             ║\");\n646:       console.log(\"  ╚══════════════════════════════════════╝\");\n647:       console.log();\n648:       console.log(\"  Describe the errand. The planner will explore the\");\n649:       console.log(\"  codebase and generate tasks for you.\");\n650:       console.log();\n651:       rl.question(\"  Errand: \", (answer) => {\n652:         rl.close();\n653:         resolve(answer.trim());\n654:       });\n655:     });\n656:   }\n657: \n658:   if (!description) {\n659:     console.log(\"\\n  No description provided. Returning.\\n\");\n660:     await sleep(1500);\n661:     return;\n662:   }\n663: \n664:   // Show a planning spinner on the terminal\n665:   console.log();\n666:   console.log(`  Running errand planner...`);\n667:   console.log();\n668: \n669:   const spinChars = [\"\\u2802\", \"\\u2806\", \"\\u2807\", \"\\u2803\", \"\\u2809\", \"\\u280C\", \"\\u280E\", \"\\u280B\"];\n670:   let spinIdx = 0;\n671:   let lastProgress = \"\";\n672:   const spinTimer = setInterval(() => {\n673:     const ch = spinChars[spinIdx % spinChars.length];\n674:     spinIdx++;\n675:     process.stdout.write(`\\r  ${ch} ${lastProgress}`);\n676:   }, 120);\n677: \n678:   let planResult: PlanResult;\n679: \n680:   try {\n681:     planResult = await runErrandPlanner(description, projectRoot, config, {\n682:       model: opts.model,\n683:       onProgress: (msg) => {\n684:         lastProgress = msg;\n685:       },\n686:     });\n687:   } catch (err: any) {\n688:     clearInterval(spinTimer);\n689:     process.stdout.write(\"\\r\" + \" \".repeat(80) + \"\\r\");\n690:     console.error(`\\n  Errand planner error: ${err.message}\\n`);\n691:     await sleep(3000);\n692:     return;\n693:   }\n694: \n695:   clearInterval(spinTimer);\n696:   process.stdout.write(\"\\r\" + \" \".repeat(80) + \"\\r\");\n697: \n698:   if (!planResult.success && planResult.tasks.length === 0) {\n699:     console.error(`\\n  Errand planner failed: ${planResult.error ?? \"No tasks produced\"}\\n`);\n700:     await sleep(3000);\n701:     return;\n702:   }\n703: \n704:   console.log(`  Errand planner produced ${planResult.tasks.length} task(s).`);\n705:   if (planResult.issues.length > 0) {\n706:     const errors = planResult.issues.filter((i) => i.level === \"error\").length;\n707:     const warnings = planResult.issues.filter((i) => i.level === \"warning\").length;\n708:     if (errors > 0) console.log(`  ${errors} validation error(s).`);\n709:     if (warnings > 0) console.log(`  ${warnings} validation warning(s).`);\n710:   }\n711:   console.log(`  Opening plan review...\\n`);\n712:   await sleep(1000);\n713: \n714:   // Clear terminal before showing the plan review TUI\n715:   process.stdout.write(\"\\x1B[2J\\x1B[H\");\n716: \n717:   // Reuse the plan review TUI (it works for any set of proposed tasks)\n718:   const reviewAction = await showPlanReview(\n719:     \"(errand)\",\n720:     description.length > 50 ? description.slice(0, 47) + \"...\" : description,\n721:     planResult\n722:   );\n723: \n724:   if (reviewAction.type === \"cancel\") {\n725:     console.log(`\\n  Errand plan discarded.\\n`);\n726:     await sleep(1500);\n727:     return;\n728:   }\n729: \n730:   // User approved -- create tasks directly (no quest)\n731:   try {\n732:     const approvedResult: PlanResult = {\n733:       ...planResult,\n734:       tasks: reviewAction.tasks,\n735:       knowledge: reviewAction.knowledge,\n736:     };\n737: \n738:     const tasks = applyErrandPlan(approvedResult, projectRoot, config);\n739:     console.log(`\\n  Errand approved! Created ${tasks.length} task(s):`);\n740:     for (const t of tasks) {\n741:       console.log(`    - ${t.id}: ${t.title}`);\n742:     }\n743:     console.log();\n744:     await sleep(2000);\n745:   } catch (err: any) {\n746:     console.error(`\\n  Failed to create errand tasks: ${err.message}\\n`);\n747:     await sleep(3000);\n748:   }\n749: }\n750: \n751: // ---------------------------------------------------------------------------\n752: // Genesis Review View -- Promise-based\n753: // ---------------------------------------------------------------------------\n754: \n755: /**\n756:  * Show the Genesis Review TUI and return a Promise that resolves when the\n757:  * user approves or cancels.\n758:  */\n759: function showGenesisReview(\n760:   genesisResult: GenesisResult\n761: ): Promise<GenesisReviewAction> {\n762:   return new Promise<GenesisReviewAction>((resolve) => {\n763:     const review = new GenesisReview({\n764:       genesisResult,\n765: \n766:       onApprove: (quests, knowledge) => {\n767:         resolve({ type: \"approve\", quests, knowledge });\n768:       },\n769: \n770:       onCancel: () => {\n771:         resolve({ type: \"cancel\" });\n772:       },\n773:     });\n774: \n775:     review.start();\n776:   });\n777: }\n778: \n779: // ---------------------------------------------------------------------------\n780: // Plan Review View -- Promise-based\n781: // ---------------------------------------------------------------------------\n782: \n783: /**\n784:  * Show the Plan Review TUI and return a Promise that resolves when the user\n785:  * approves or cancels.\n786:  */\n787: function showPlanReview(\n788:   questId: string,\n789:   questTitle: string,\n790:   planResult: PlanResult\n791: ): Promise<PlanReviewResult> {\n792:   return new Promise<PlanReviewResult>((resolve) => {\n793:     const review = new PlanReview({\n794:       questId,\n795:       questTitle,\n796:       planResult,\n797: \n798:       onApprove: (tasks, knowledge) => {\n799:         resolve({ type: \"approve\", tasks, knowledge });\n800:       },\n801: \n802:       onCancel: () => {\n803:         resolve({ type: \"cancel\" });\n804:       },\n805:     });\n806: \n807:     review.start();\n808:   });\n809: }\n810: \n811: // ---------------------------------------------------------------------------\n812: // Browser View -- Promise-based\n813: // ---------------------------------------------------------------------------\n814: \n815: /**\n816:  * Show the Task Browser and return a Promise that resolves when the user\n817:  * takes an action (launch, back, or quit).\n818:  */\n819: function showBrowser(\n820:   projectRoot: string,\n821:   config: WomboConfig,\n822:   session: TUISession,\n823:   opts: TUICommandOptions,\n824:   questId: string | null,\n825:   hasQuestPicker: boolean\n826: ): Promise<BrowserAction> {\n827:   // Reload session from disk in case state changed after a wave\n828:   const freshSession = loadTUISession(projectRoot);\n829:   // Merge any runtime overrides\n830:   if (opts.maxConcurrent !== undefined) {\n831:     freshSession.maxConcurrent = opts.maxConcurrent;\n832:   }\n833:   // Copy fresh values back into the shared session object\n834:   Object.assign(session, freshSession);\n835: \n836:   // Load quest details for filtering if a quest was selected\n837:   let questTitle: string | undefined;\n838:   let questTaskIds: string[] | undefined;\n839:   if (questId) {\n840:     const quest = loadQuest(projectRoot, questId);\n841:     if (quest) {\n842:       questTitle = quest.title;\n843:       questTaskIds = quest.taskIds;\n844:     }\n845:   }\n846: \n847:   return new Promise<BrowserAction>((resolve) => {\n848:     const browser = new TaskBrowser({\n849:       projectRoot,\n850:       config,\n851:       session,\n852:       questId,\n853:       questTitle,\n854:       questTaskIds,\n855: \n856:       onLaunch: (selectedIds: string[]) => {\n857:         if (selectedIds.length === 0) return;\n858:         // The browser has already shown a transition message on-screen.\n859:         // Destroy the blessed screen and clear the terminal.\n860:         browser.destroy();\n861:         resolve({ type: \"launch\", ids: selectedIds });\n862:       },\n863: \n864:       onQuit: () => {\n865:         browser.stop();\n866:         resolve({ type: \"quit\" });\n867:       },\n868: \n869:       onBack: hasQuestPicker\n870:         ? () => {\n871:             resolve({ type: \"back\" });\n872:           }\n873:         : undefined,\n874: \n875:       // Errand is available when not in quest-filtered mode\n876:       onErrand: !questId\n877:         ? () => {\n878:             resolve({ type: \"errand\" });\n879:           }\n880:         : undefined,\n881: \n882:       onSwitchToMonitor: undefined,\n883:     });\n884: \n885:     browser.start();\n886:   });\n887: }\n888: \n889: // ---------------------------------------------------------------------------\n890: // Helpers\n891: // ---------------------------------------------------------------------------\n892: \n893: function sleep(ms: number): Promise<void> {\n894:   return new Promise((r) => setTimeout(r, ms));\n895: }\n\n(End of file - total 895 lines)\n</content>","title":"src/commands/tui.ts","metadata":{"preview":"/**\n * tui.ts -- Unified TUI command entry point for wombo-combo.\n *\n * Orchestrates multiple views in a persistent loop:\n *   1. Quest Picker (tui-quest-picker.ts) -- select a quest or \"All Tasks\"\n *   2. Task Browser (tui-browser.ts) -- select tasks, change priorities, launch\n *   3. Wave Monitor (tui.ts) -- watch running wave, view logs, retry agents\n *   4. Plan Review (tui-plan-review.ts) -- review/edit/approve planner output\n *   5. Genesis Review (tui-genesis-review.ts) -- review/edit/approve genesis plan\n *\n * Flow:\n *   `woco` -> Quest Picker (if quests exist) -> Task Browser -> L -> launches\n *   wave -> wave completes -> Q in monitor -> back to Quest Picker -> ...\n *\n *   Quest Picker -> P (plan) -> spinner -> Plan Review -> approve/cancel ->\n *   back to Quest Picker\n *\n *   Quest Picker -> G (genesis) -> vision prompt -> spinner -> Genesis Review\n *   -> approve/cancel -> back to Quest Picker\n *","truncated":false,"loaded":[]},"time":{"start":1773482838521,"end":1773482838525}}}}
{"type":"tool_use","timestamp":1773482839206,"sessionID":"ses_314328759ffeSwO8I1laVGgGu4","part":{"id":"prt_cebd089fa001v3uR39EVCTEIGO","sessionID":"ses_314328759ffeSwO8I1laVGgGu4","messageID":"msg_cebd07798001XWWnljjH6Qn2Zo","type":"tool","callID":"toolu_vrtx_01FpXa1ZWkv2M58c1LQUJaCD","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/wishlist-promote/src/lib/tui-wishlist.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/wishlist-promote/src/lib/tui-wishlist.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tui-wishlist.ts -- Wishlist browser view for the wombo-combo TUI.\n3:  *\n4:  * Shows all wishlist items in a selectable list. Users can promote items\n5:  * to errands (E key) or genesis input (G key). After promotion, the user\n6:  * is asked whether to delete the wishlist item.\n7:  *\n8:  * Layout:\n9:  *   ┌───────────────────────────────────────────────────────┐\n10:  *   │ WOMBO-COMBO Wishlist  │ 5 items                      │\n11:  *   ├──────────────────────────┬────────────────────────────┤\n12:  *   │ • Fix login timeout...   │ Text: Fix login timeout    │\n13:  *   │ • Add dark mode support  │   for SSO users on slow    │\n14:  *   │ • Refactor DB layer      │   connections               │\n15:  *   │ • Update docs for v2     │                             │\n16:  *   │                          │ Tags: auth, ux              │\n17:  *   │                          │ Created: 2025-01-15         │\n18:  *   ├──────────────────────────┴────────────────────────────┤\n19:  *   │ E:errand  G:genesis  D:delete  Esc:back  Q:quit      │\n20:  *   └───────────────────────────────────────────────────────┘\n21:  *\n22:  * Keybinds:\n23:  *   E         — promote selected item to errand (pre-fill description)\n24:  *   G         — promote selected item to genesis (pre-fill vision)\n25:  *   D / Del   — delete selected item\n26:  *   Esc / Q   — go back to quest picker\n27:  */\n28: \n29: import blessed from \"neo-blessed\";\n30: import type { Widgets } from \"neo-blessed\";\n31: import type { WishlistItem } from \"./wishlist-store.js\";\n32: import { loadWishlist, deleteItem } from \"./wishlist-store.js\";\n33: \n34: // ---------------------------------------------------------------------------\n35: // Types\n36: // ---------------------------------------------------------------------------\n37: \n38: export type WishlistAction =\n39:   | { type: \"promote-errand\"; item: WishlistItem }\n40:   | { type: \"promote-genesis\"; item: WishlistItem }\n41:   | { type: \"back\" }\n42:   | { type: \"quit\" };\n43: \n44: export interface WishlistPickerOptions {\n45:   projectRoot: string;\n46:   onPromoteErrand: (item: WishlistItem) => void;\n47:   onPromoteGenesis: (item: WishlistItem) => void;\n48:   onBack: () => void;\n49:   onQuit: () => void;\n50: }\n51: \n52: // ---------------------------------------------------------------------------\n53: // Helpers\n54: // ---------------------------------------------------------------------------\n55: \n56: function escapeBlessedTags(text: string): string {\n57:   return text.replace(/\\{/g, \"\\uFF5B\").replace(/\\}/g, \"\\uFF5D\");\n58: }\n59: \n60: // ---------------------------------------------------------------------------\n61: // WishlistPicker Class\n62: // ---------------------------------------------------------------------------\n63: \n64: export class WishlistPicker {\n65:   private screen: Widgets.Screen;\n66:   private headerBox: Widgets.BoxElement;\n67:   private itemList: Widgets.ListElement;\n68:   private detailBox: Widgets.BoxElement;\n69:   private statusBar: Widgets.BoxElement;\n70: \n71:   private projectRoot: string;\n72:   private onPromoteErrand: (item: WishlistItem) => void;\n73:   private onPromoteGenesis: (item: WishlistItem) => void;\n74:   private onBack: () => void;\n75:   private onQuit: () => void;\n76: \n77:   private items: WishlistItem[] = [];\n78:   private selectedIndex: number = 0;\n79: \n80:   constructor(opts: WishlistPickerOptions) {\n81:     this.projectRoot = opts.projectRoot;\n82:     this.onPromoteErrand = opts.onPromoteErrand;\n83:     this.onPromoteGenesis = opts.onPromoteGenesis;\n84:     this.onBack = opts.onBack;\n85:     this.onQuit = opts.onQuit;\n86: \n87:     this.loadItems();\n88: \n89:     // Create screen\n90:     this.screen = blessed.screen({\n91:       smartCSR: true,\n92:       title: \"wombo-combo -- Wishlist\",\n93:       fullUnicode: true,\n94:     });\n95: \n96:     // Header\n97:     this.headerBox = blessed.box({\n98:       top: 0,\n99:       left: 0,\n100:       width: \"100%\",\n101:       height: 3,\n102:       tags: true,\n103:       style: { fg: \"white\", bg: \"black\" },\n104:     });\n105: \n106:     // Item list (left pane)\n107:     this.itemList = blessed.list({\n108:       top: 3,\n109:       left: 0,\n110:       width: \"50%\",\n111:       height: \"100%-6\",\n112:       tags: true,\n113:       scrollable: true,\n114:       mouse: true,\n115:       keys: true,\n116:       vi: true,\n117:       border: { type: \"line\" },\n118:       style: {\n119:         border: { fg: \"gray\" },\n120:         selected: { bg: \"blue\", fg: \"white\", bold: true },\n121:         item: { fg: \"white\" },\n122:       },\n123:       label: \" Wishlist \",\n124:     });\n125: \n126:     // Detail pane (right pane)\n127:     this.detailBox = blessed.box({\n128:       top: 3,\n129:       left: \"50%\",\n130:       width: \"50%\",\n131:       height: \"100%-6\",\n132:       tags: true,\n133:       scrollable: true,\n134:       mouse: true,\n135:       border: { type: \"line\" },\n136:       style: {\n137:         border: { fg: \"gray\" },\n138:         fg: \"white\",\n139:       },\n140:       label: \" Details \",\n141:     });\n142: \n143:     // Status bar\n144:     this.statusBar = blessed.box({\n145:       bottom: 0,\n146:       left: 0,\n147:       width: \"100%\",\n148:       height: 3,\n149:       tags: true,\n150:       style: { fg: \"white\", bg: \"black\" },\n151:     });\n152: \n153:     // Assemble\n154:     this.screen.append(this.headerBox);\n155:     this.screen.append(this.itemList);\n156:     this.screen.append(this.detailBox);\n157:     this.screen.append(this.statusBar);\n158:     this.itemList.focus();\n159: \n160:     this.bindKeys();\n161:   }\n162: \n163:   // -----------------------------------------------------------------------\n164:   // Public API\n165:   // -----------------------------------------------------------------------\n166: \n167:   start(): void {\n168:     this.refreshAll();\n169:     this.screen.render();\n170:   }\n171: \n172:   stop(): void {\n173:     this.screen.destroy();\n174:   }\n175: \n176:   destroy(): void {\n177:     this.screen.destroy();\n178:     process.stdout.write(\"\\x1B[2J\\x1B[H\");\n179:   }\n180: \n181:   // -----------------------------------------------------------------------\n182:   // Data Loading\n183:   // -----------------------------------------------------------------------\n184: \n185:   private loadItems(): void {\n186:     this.items = loadWishlist(this.projectRoot);\n187:   }\n188: \n189:   // -----------------------------------------------------------------------\n190:   // Key Bindings\n191:   // -----------------------------------------------------------------------\n192: \n193:   private bindKeys(): void {\n194:     // Quit\n195:     this.screen.key([\"q\", \"C-c\"], () => {\n196:       this.stop();\n197:       this.onQuit();\n198:     });\n199: \n200:     // Escape -- go back\n201:     this.screen.key([\"escape\"], () => {\n202:       this.destroy();\n203:       this.onBack();\n204:     });\n205: \n206:     // Navigate\n207:     this.itemList.on(\"select item\", (_item: any, index: number) => {\n208:       this.selectedIndex = index;\n209:       this.refreshDetail();\n210:       this.screen.render();\n211:     });\n212: \n213:     // E -- promote to errand\n214:     this.screen.key([\"e\"], () => {\n215:       this.promoteToErrand();\n216:     });\n217: \n218:     // G -- promote to genesis\n219:     this.screen.key([\"g\"], () => {\n220:       this.promoteToGenesis();\n221:     });\n222: \n223:     // D / Delete -- delete item\n224:     this.screen.key([\"d\", \"delete\"], () => {\n225:       this.deleteSelected();\n226:     });\n227:   }\n228: \n229:   // -----------------------------------------------------------------------\n230:   // Actions\n231:   // -----------------------------------------------------------------------\n232: \n233:   private promoteToErrand(): void {\n234:     const item = this.items[this.selectedIndex];\n235:     if (!item) return;\n236: \n237:     this.destroy();\n238:     this.onPromoteErrand(item);\n239:   }\n240: \n241:   private promoteToGenesis(): void {\n242:     const item = this.items[this.selectedIndex];\n243:     if (!item) return;\n244: \n245:     this.destroy();\n246:     this.onPromoteGenesis(item);\n247:   }\n248: \n249:   private deleteSelected(): void {\n250:     const item = this.items[this.selectedIndex];\n251:     if (!item) return;\n252: \n253:     deleteItem(this.projectRoot, item.id);\n254:     this.loadItems();\n255:     this.selectedIndex = Math.min(\n256:       this.selectedIndex,\n257:       Math.max(0, this.items.length - 1)\n258:     );\n259:     this.refreshAll();\n260:     this.screen.render();\n261:   }\n262: \n263:   // -----------------------------------------------------------------------\n264:   // Refresh Logic\n265:   // -----------------------------------------------------------------------\n266: \n267:   private refreshAll(): void {\n268:     this.refreshHeader();\n269:     this.refreshList();\n270:     this.refreshDetail();\n271:     this.refreshStatusBar();\n272:   }\n273: \n274:   private refreshHeader(): void {\n275:     const count = this.items.length;\n276:     let line1 = ` {bold}wombo-combo{/bold} {yellow-fg}Wishlist{/yellow-fg}`;\n277:     line1 += `  {gray-fg}|{/gray-fg}  {white-fg}${count}{/white-fg} item${count !== 1 ? \"s\" : \"\"}`;\n278: \n279:     let line2 = ` {gray-fg}Promote items to errands or genesis quests{/gray-fg}`;\n280: \n281:     this.headerBox.setContent(`${line1}\\n${line2}`);\n282:   }\n283: \n284:   private refreshList(): void {\n285:     const listItems: string[] = [];\n286: \n287:     for (const item of this.items) {\n288:       // Truncate text for list display\n289:       const maxLen = 40;\n290:       const text = item.text.length > maxLen\n291:         ? item.text.slice(0, maxLen - 1) + \"\\u2026\"\n292:         : item.text;\n293: \n294:       // Tags badge\n295:       const tagsBadge = item.tags.length > 0\n296:         ? ` {gray-fg}[${item.tags.join(\", \")}]{/gray-fg}`\n297:         : \"\";\n298: \n299:       // Date\n300:       const created = item.created_at.slice(0, 10);\n301: \n302:       listItems.push(\n303:         ` {yellow-fg}\\u2022{/yellow-fg} ${escapeBlessedTags(text)}${tagsBadge} {gray-fg}${created}{/gray-fg}`\n304:       );\n305:     }\n306: \n307:     if (listItems.length === 0) {\n308:       listItems.push(\" {gray-fg}No wishlist items{/gray-fg}\");\n309:     }\n310: \n311:     const prevSelected = this.selectedIndex;\n312:     this.itemList.setItems(listItems as any);\n313:     if (prevSelected < listItems.length) {\n314:       this.itemList.select(prevSelected);\n315:     }\n316:   }\n317: \n318:   private refreshDetail(): void {\n319:     const item = this.items[this.selectedIndex];\n320:     if (!item) {\n321:       this.detailBox.setContent(\"{gray-fg}No item selected{/gray-fg}\");\n322:       this.detailBox.setLabel(\" Details \");\n323:       return;\n324:     }\n325: \n326:     const lines: string[] = [];\n327: \n328:     // Full text\n329:     lines.push(\"{bold}{white-fg}Description:{/white-fg}{/bold}\");\n330:     // Word-wrap the text to roughly 42 chars\n331:     const text = escapeBlessedTags(item.text.trim());\n332:     const words = text.split(/\\s+/);\n333:     let line = \" \";\n334:     for (const w of words) {\n335:       if (line.length + w.length > 42) {\n336:         lines.push(line);\n337:         line = \" \" + w;\n338:       } else {\n339:         line += \" \" + w;\n340:       }\n341:     }\n342:     if (line.trim()) lines.push(line);\n343:     lines.push(\"\");\n344: \n345:     // Tags\n346:     if (item.tags.length > 0) {\n347:       lines.push(\"{bold}Tags:{/bold}\");\n348:       lines.push(`  ${item.tags.map((t) => `{cyan-fg}${escapeBlessedTags(t)}{/cyan-fg}`).join(\"  \")}`);\n349:       lines.push(\"\");\n350:     }\n351: \n352:     // Created date\n353:     lines.push(\"{bold}Created:{/bold}\");\n354:     lines.push(`  ${item.created_at.slice(0, 10)} ${item.created_at.slice(11, 19)}`);\n355:     lines.push(\"\");\n356: \n357:     // ID\n358:     lines.push(\"{bold}ID:{/bold}\");\n359:     lines.push(`  {gray-fg}${item.id}{/gray-fg}`);\n360:     lines.push(\"\");\n361: \n362:     // Promotion hints\n363:     lines.push(\"{bold}Promote:{/bold}\");\n364:     lines.push(\"  {green-fg}E{/green-fg} \\u2192 Create errand from this item\");\n365:     lines.push(\"  {magenta-fg}G{/magenta-fg} \\u2192 Use as genesis vision\");\n366: \n367:     this.detailBox.setContent(lines.join(\"\\n\"));\n368:     this.detailBox.setLabel(` Item ${this.selectedIndex + 1}/${this.items.length} `);\n369:   }\n370: \n371:   private refreshStatusBar(): void {\n372:     let line1 = ` {bold}Keys:{/bold}`;\n373:     line1 += `  {gray-fg}E{/gray-fg} promote to errand`;\n374:     line1 += `  {gray-fg}G{/gray-fg} promote to genesis`;\n375:     line1 += `  {gray-fg}D{/gray-fg} delete`;\n376:     line1 += `  {gray-fg}Esc{/gray-fg} back`;\n377:     line1 += `  {gray-fg}Q{/gray-fg} quit`;\n378: \n379:     let line2 = ` `;\n380:     const item = this.items[this.selectedIndex];\n381:     if (item) {\n382:       const truncText = item.text.length > 60\n383:         ? item.text.slice(0, 57) + \"...\"\n384:         : item.text;\n385:       line2 += `{white-fg}${escapeBlessedTags(truncText)}{/white-fg}`;\n386:     } else {\n387:       line2 += `{gray-fg}Add items with: woco wishlist add \"your idea\"{/gray-fg}`;\n388:     }\n389: \n390:     this.statusBar.setContent(`${line1}\\n${line2}`);\n391:   }\n392: }\n\n(End of file - total 392 lines)\n</content>","title":"src/lib/tui-wishlist.ts","metadata":{"preview":"/**\n * tui-wishlist.ts -- Wishlist browser view for the wombo-combo TUI.\n *\n * Shows all wishlist items in a selectable list. Users can promote items\n * to errands (E key) or genesis input (G key). After promotion, the user\n * is asked whether to delete the wishlist item.\n *\n * Layout:\n *   ┌───────────────────────────────────────────────────────┐\n *   │ WOMBO-COMBO Wishlist  │ 5 items                      │\n *   ├──────────────────────────┬────────────────────────────┤\n *   │ • Fix login timeout...   │ Text: Fix login timeout    │\n *   │ • Add dark mode support  │   for SSO users on slow    │\n *   │ • Refactor DB layer      │   connections               │\n *   │ • Update docs for v2     │                             │\n *   │                          │ Tags: auth, ux              │\n *   │                          │ Created: 2025-01-15         │\n *   ├──────────────────────────┴────────────────────────────┤\n *   │ E:errand  G:genesis  D:delete  Esc:back  Q:quit      │\n *   └───────────────────────────────────────────────────────┘","truncated":false,"loaded":[]},"time":{"start":1773482839202,"end":1773482839205}}}}
{"type":"text","timestamp":1773482839598,"sessionID":"ses_314328759ffeSwO8I1laVGgGu4","part":{"id":"prt_cebd08010001xe8Xk2ShOHIyxO","sessionID":"ses_314328759ffeSwO8I1laVGgGu4","messageID":"msg_cebd07798001XWWnljjH6Qn2Zo","type":"text","text":"Good. I can see the current state: `tui.ts` has been modified (prefill params added to errand/genesis flows), `tui-wishlist.ts` is created but untracked, and nothing is committed yet. Let me read the current state of all relevant files.","time":{"start":1773482839598,"end":1773482839598}}}
{"type":"tool_use","timestamp":1773482839602,"sessionID":"ses_314328759ffeSwO8I1laVGgGu4","part":{"id":"prt_cebd08ca3001ek6yoMx53IrilW","sessionID":"ses_314328759ffeSwO8I1laVGgGu4","messageID":"msg_cebd07798001XWWnljjH6Qn2Zo","type":"tool","callID":"toolu_vrtx_01FLxQCsb9CYBmbfeQCZhsDv","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/wishlist-promote/src/lib/tui-quest-picker.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/wishlist-promote/src/lib/tui-quest-picker.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tui-quest-picker.ts -- Quest picker view for the wombo-combo TUI.\n3:  *\n4:  * Shows all quests as a selectable list with an \"All Tasks\" option at the top.\n5:  * Selecting a quest navigates to the Task Browser filtered to that quest's tasks.\n6:  *\n7:  * Layout:\n8:  *   +-----------------------------------------------------------+\n9:  *   | WOMBO-COMBO Quest Picker  | 4 quests                      |\n10:  *   +---------------------------+-------------------------------+\n11:  *   | > All Tasks (42)          | Quest: auth-overhaul           |\n12:  *   |   auth-overhaul   ACTV    | Status: active                 |\n13:  *   |   search-api      DRFT    | Priority: high                 |\n14:  *   |   perf-optim      PAUS    | Tasks: 8 (3 done, 62%)         |\n15:  *   |   ui-redesign     PLAN    | Goal: Replace basic auth...    |\n16:  *   |                           |                                |\n17:  *   +---------------------------+-------------------------------+\n18:  *   | Enter:select  C:create  Q:quit                            |\n19:  *   +-----------------------------------------------------------+\n20:  *\n21:  * Keybinds:\n22:  *   Enter/Space  -- select quest (or \"All Tasks\") and proceed to browser\n23:  *   C            -- create new quest (Phase 2 p2-quest-create-tui)\n24:  *   A            -- activate/pause selected quest\n25:  *   Q / C-c      -- quit the TUI\n26:  */\n27: \n28: import blessed from \"neo-blessed\";\n29: import type { Widgets } from \"neo-blessed\";\n30: import type { Quest, QuestHitlMode } from \"./quest.js\";\n31: import { QUEST_STATUS_ORDER, createBlankQuest, VALID_HITL_MODES } from \"./quest.js\";\n32: import { loadAllQuests, saveQuest, loadQuest } from \"./quest-store.js\";\n33: import { VALID_PRIORITIES, VALID_DIFFICULTIES } from \"./task-schema.js\";\n34: import type { Priority, Difficulty } from \"./tasks.js\";\n35: import { loadTasks, getDoneTaskIds, loadArchive } from \"./tasks.js\";\n36: import type { WomboConfig } from \"../config.js\";\n37: \n38: // ---------------------------------------------------------------------------\n39: // Types\n40: // ---------------------------------------------------------------------------\n41: \n42: export type QuestPickerAction =\n43:   | { type: \"select\"; questId: string | null }\n44:   | { type: \"plan\"; questId: string }\n45:   | { type: \"genesis\" }\n46:   | { type: \"errand\" }\n47:   | { type: \"quit\" };\n48: \n49: export interface QuestPickerOptions {\n50:   projectRoot: string;\n51:   config: WomboConfig;\n52:   onSelect: (questId: string | null) => void;\n53:   onPlan?: (questId: string) => void;\n54:   onGenesis?: () => void;\n55:   onErrand?: () => void;\n56:   onQuit: () => void;\n57: }\n58: \n59: // ---------------------------------------------------------------------------\n60: // Display helpers\n61: // ---------------------------------------------------------------------------\n62: \n63: const STATUS_ABBREV: Record<string, string> = {\n64:   draft: \"DRFT\",\n65:   planning: \"PLAN\",\n66:   active: \"ACTV\",\n67:   paused: \"PAUS\",\n68:   completed: \"DONE\",\n69:   abandoned: \"ABAN\",\n70: };\n71: \n72: const STATUS_COLORS: Record<string, string> = {\n73:   draft: \"gray\",\n74:   planning: \"blue\",\n75:   active: \"green\",\n76:   paused: \"yellow\",\n77:   completed: \"cyan\",\n78:   abandoned: \"red\",\n79: };\n80: \n81: const PRIORITY_COLORS: Record<string, string> = {\n82:   critical: \"red\",\n83:   high: \"yellow\",\n84:   medium: \"white\",\n85:   low: \"gray\",\n86:   wishlist: \"gray\",\n87: };\n88: \n89: function escapeBlessedTags(text: string): string {\n90:   return text.replace(/\\{/g, \"\\uFF5B\").replace(/\\}/g, \"\\uFF5D\");\n91: }\n92: \n93: // ---------------------------------------------------------------------------\n94: // Quest summary for display\n95: // ---------------------------------------------------------------------------\n96: \n97: interface QuestSummary {\n98:   quest: Quest;\n99:   totalTasks: number;\n100:   doneTasks: number;\n101:   completionPct: number;\n102: }\n103: \n104: // ---------------------------------------------------------------------------\n105: // QuestPicker Class\n106: // ---------------------------------------------------------------------------\n107: \n108: export class QuestPicker {\n109:   private screen: Widgets.Screen;\n110:   private headerBox: Widgets.BoxElement;\n111:   private questList: Widgets.ListElement;\n112:   private detailBox: Widgets.BoxElement;\n113:   private statusBar: Widgets.BoxElement;\n114: \n115:   private projectRoot: string;\n116:   private config: WomboConfig;\n117:   private onSelect: (questId: string | null) => void;\n118:   private onPlan?: (questId: string) => void;\n119:   private onGenesis?: () => void;\n120:   private onErrand?: () => void;\n121:   private onQuit: () => void;\n122: \n123:   /** \"All Tasks\" + quest summaries */\n124:   private items: Array<{ type: \"all\" } | { type: \"quest\"; summary: QuestSummary }> = [];\n125:   private selectedIndex: number = 0;\n126:   private totalTaskCount: number = 0;\n127: \n128:   constructor(opts: QuestPickerOptions) {\n129:     this.projectRoot = opts.projectRoot;\n130:     this.config = opts.config;\n131:     this.onSelect = opts.onSelect;\n132:     this.onPlan = opts.onPlan;\n133:     this.onGenesis = opts.onGenesis;\n134:     this.onErrand = opts.onErrand;\n135:     this.onQuit = opts.onQuit;\n136: \n137:     this.loadQuests();\n138: \n139:     // Create screen\n140:     this.screen = blessed.screen({\n141:       smartCSR: true,\n142:       title: \"wombo-combo -- Quest Picker\",\n143:       fullUnicode: true,\n144:     });\n145: \n146:     // Header\n147:     this.headerBox = blessed.box({\n148:       top: 0,\n149:       left: 0,\n150:       width: \"100%\",\n151:       height: 3,\n152:       tags: true,\n153:       style: { fg: \"white\", bg: \"black\" },\n154:     });\n155: \n156:     // Quest list (left pane)\n157:     this.questList = blessed.list({\n158:       top: 3,\n159:       left: 0,\n160:       width: \"50%\",\n161:       height: \"100%-6\",\n162:       tags: true,\n163:       scrollable: true,\n164:       mouse: true,\n165:       keys: true,\n166:       vi: true,\n167:       border: { type: \"line\" },\n168:       style: {\n169:         border: { fg: \"gray\" },\n170:         selected: { bg: \"blue\", fg: \"white\", bold: true },\n171:         item: { fg: \"white\" },\n172:       },\n173:       label: \" Quests \",\n174:     });\n175: \n176:     // Detail pane (right pane)\n177:     this.detailBox = blessed.box({\n178:       top: 3,\n179:       left: \"50%\",\n180:       width: \"50%\",\n181:       height: \"100%-6\",\n182:       tags: true,\n183:       scrollable: true,\n184:       mouse: true,\n185:       border: { type: \"line\" },\n186:       style: {\n187:         border: { fg: \"gray\" },\n188:         fg: \"white\",\n189:       },\n190:       label: \" Details \",\n191:     });\n192: \n193:     // Status bar\n194:     this.statusBar = blessed.box({\n195:       bottom: 0,\n196:       left: 0,\n197:       width: \"100%\",\n198:       height: 3,\n199:       tags: true,\n200:       style: { fg: \"white\", bg: \"black\" },\n201:     });\n202: \n203:     // Assemble\n204:     this.screen.append(this.headerBox);\n205:     this.screen.append(this.questList);\n206:     this.screen.append(this.detailBox);\n207:     this.screen.append(this.statusBar);\n208:     this.questList.focus();\n209: \n210:     this.bindKeys();\n211:   }\n212: \n213:   // -----------------------------------------------------------------------\n214:   // Public API\n215:   // -----------------------------------------------------------------------\n216: \n217:   start(): void {\n218:     this.refreshAll();\n219:     this.screen.render();\n220:   }\n221: \n222:   stop(): void {\n223:     this.screen.destroy();\n224:   }\n225: \n226:   destroy(): void {\n227:     this.screen.destroy();\n228:     process.stdout.write(\"\\x1B[2J\\x1B[H\");\n229:   }\n230: \n231:   // -----------------------------------------------------------------------\n232:   // Data Loading\n233:   // -----------------------------------------------------------------------\n234: \n235:   private loadQuests(): void {\n236:     const quests = loadAllQuests(this.projectRoot);\n237:     const tasksData = loadTasks(this.projectRoot, this.config);\n238:     const archiveData = loadArchive(this.projectRoot, this.config);\n239:     const doneIds = getDoneTaskIds(tasksData, archiveData.tasks);\n240:     this.totalTaskCount = tasksData.tasks.length;\n241: \n242:     // Build task lookup for quest summaries\n243:     const taskMap = new Map(tasksData.tasks.map((t) => [t.id, t]));\n244: \n245:     // Sort quests: active first, then by status order, then by priority\n246:     const sorted = [...quests].sort((a, b) => {\n247:       const statusDiff = (QUEST_STATUS_ORDER[a.status] ?? 99) - (QUEST_STATUS_ORDER[b.status] ?? 99);\n248:       if (statusDiff !== 0) return statusDiff;\n249:       return 0;\n250:     });\n251: \n252:     // Build items list\n253:     this.items = [{ type: \"all\" as const }];\n254:     for (const quest of sorted) {\n255:       const totalTasks = quest.taskIds.length;\n256:       const doneTasks = quest.taskIds.filter((id) => doneIds.has(id)).length;\n257:       const completionPct = totalTasks > 0 ? Math.round((doneTasks / totalTasks) * 100) : 0;\n258: \n259:       this.items.push({\n260:         type: \"quest\" as const,\n261:         summary: { quest, totalTasks, doneTasks, completionPct },\n262:       });\n263:     }\n264:   }\n265: \n266:   // -----------------------------------------------------------------------\n267:   // Key Bindings\n268:   // -----------------------------------------------------------------------\n269: \n270:   private bindKeys(): void {\n271:     // Quit\n272:     this.screen.key([\"q\", \"C-c\"], () => {\n273:       this.stop();\n274:       this.onQuit();\n275:     });\n276: \n277:     // Navigate\n278:     this.questList.on(\"select item\", (_item: any, index: number) => {\n279:       this.selectedIndex = index;\n280:       this.refreshDetail();\n281:       this.screen.render();\n282:     });\n283: \n284:     // Enter/Space -- select\n285:     this.screen.key([\"enter\", \"space\"], () => {\n286:       this.selectCurrent();\n287:     });\n288: \n289:     // A -- activate/pause quest\n290:     this.screen.key([\"a\"], () => {\n291:       this.toggleQuestActive();\n292:     });\n293: \n294:     // C -- create new quest\n295:     this.screen.key([\"c\"], () => {\n296:       this.showCreateQuestModal();\n297:     });\n298: \n299:     // P -- plan quest (run planner agent)\n300:     this.screen.key([\"p\"], () => {\n301:       this.planQuest();\n302:     });\n303: \n304:     // G -- genesis (project-level decomposition)\n305:     this.screen.key([\"g\"], () => {\n306:       this.triggerGenesis();\n307:     });\n308: \n309:     // E -- errand (quick task generation without a quest)\n310:     this.screen.key([\"e\"], () => {\n311:       this.triggerErrand();\n312:     });\n313:   }\n314: \n315:   // -----------------------------------------------------------------------\n316:   // Actions\n317:   // -----------------------------------------------------------------------\n318: \n319:   private selectCurrent(): void {\n320:     const item = this.items[this.selectedIndex];\n321:     if (!item) return;\n322: \n323:     if (item.type === \"all\") {\n324:       this.destroy();\n325:       this.onSelect(null);\n326:     } else {\n327:       this.destroy();\n328:       this.onSelect(item.summary.quest.id);\n329:     }\n330:   }\n331: \n332:   private toggleQuestActive(): void {\n333:     const item = this.items[this.selectedIndex];\n334:     if (!item || item.type === \"all\") return;\n335: \n336:     const quest = item.summary.quest;\n337:     if (quest.status === \"active\") {\n338:       quest.status = \"paused\";\n339:     } else if (quest.status === \"draft\" || quest.status === \"paused\" || quest.status === \"planning\") {\n340:       quest.status = \"active\";\n341:       if (!quest.started_at) {\n342:         quest.started_at = new Date().toISOString();\n343:       }\n344:     } else {\n345:       // completed/abandoned -- can't toggle\n346:       return;\n347:     }\n348: \n349:     saveQuest(this.projectRoot, quest);\n350:     this.loadQuests();\n351:     this.refreshAll();\n352:     this.screen.render();\n353:   }\n354: \n355:   private planQuest(): void {\n356:     if (this.creatingQuest) return;\n357:     const item = this.items[this.selectedIndex];\n358:     if (!item || item.type === \"all\") return;\n359: \n360:     const quest = item.summary.quest;\n361:     // Only allow planning for draft or planning quests\n362:     if (quest.status !== \"draft\" && quest.status !== \"planning\") {\n363:       return;\n364:     }\n365: \n366:     if (!this.onPlan) return;\n367: \n368:     this.destroy();\n369:     this.onPlan(quest.id);\n370:   }\n371: \n372:   private triggerGenesis(): void {\n373:     if (this.creatingQuest) return;\n374:     if (!this.onGenesis) return;\n375: \n376:     this.destroy();\n377:     this.onGenesis();\n378:   }\n379: \n380:   private triggerErrand(): void {\n381:     if (this.creatingQuest) return;\n382:     if (!this.onErrand) return;\n383: \n384:     this.destroy();\n385:     this.onErrand();\n386:   }\n387: \n388:   // -----------------------------------------------------------------------\n389:   // Create Quest Modal\n390:   // -----------------------------------------------------------------------\n391: \n392:   /** Whether the create modal is currently showing (blocks other key handlers) */\n393:   private creatingQuest = false;\n394: \n395:   /**\n396:    * Show a multi-step modal form to create a new quest.\n397:    * Steps: ID -> Title -> Goal -> Priority -> Difficulty -> HITL -> Confirm\n398:    */\n399:   private showCreateQuestModal(): void {\n400:     if (this.creatingQuest) return;\n401:     this.creatingQuest = true;\n402: \n403:     // Overlay box that covers the detail pane\n404:     const modal = blessed.box({\n405:       parent: this.screen,\n406:       top: \"center\",\n407:       left: \"center\",\n408:       width: \"70%\",\n409:       height: \"80%\",\n410:       tags: true,\n411:       border: { type: \"line\" },\n412:       style: {\n413:         border: { fg: \"magenta\" },\n414:         fg: \"white\",\n415:         bg: \"black\",\n416:       },\n417:       label: \" {magenta-fg}New Quest{/magenta-fg} \",\n418:       shadow: true,\n419:     });\n420: \n421:     // Content area (instructions)\n422:     const content = blessed.box({\n423:       parent: modal,\n424:       top: 0,\n425:       left: 1,\n426:       right: 1,\n427:       height: 3,\n428:       tags: true,\n429:       style: { fg: \"white\", bg: \"black\" },\n430:     });\n431: \n432:     // Textbox for text input steps\n433:     const textbox = blessed.textbox({\n434:       parent: modal,\n435:       top: 3,\n436:       left: 1,\n437:       right: 1,\n438:       height: 3,\n439:       border: { type: \"line\" },\n440:       style: {\n441:         border: { fg: \"cyan\" },\n442:         fg: \"white\",\n443:         bg: \"black\",\n444:         focus: { border: { fg: \"magenta\" } },\n445:       },\n446:       inputOnFocus: true,\n447:     });\n448: \n449:     // Textarea for goal (multi-line)\n450:     const textarea = blessed.textarea({\n451:       parent: modal,\n452:       top: 3,\n453:       left: 1,\n454:       right: 1,\n455:       height: 10,\n456:       border: { type: \"line\" },\n457:       style: {\n458:         border: { fg: \"cyan\" },\n459:         fg: \"white\",\n460:         bg: \"black\",\n461:         focus: { border: { fg: \"magenta\" } },\n462:       },\n463:       inputOnFocus: true,\n464:       hidden: true,\n465:     });\n466: \n467:     // Selection list for enum steps (priority, difficulty, hitl)\n468:     const selectList = blessed.list({\n469:       parent: modal,\n470:       top: 3,\n471:       left: 1,\n472:       right: 1,\n473:       height: \"100%-8\",\n474:       tags: true,\n475:       keys: true,\n476:       vi: true,\n477:       border: { type: \"line\" },\n478:       style: {\n479:         border: { fg: \"cyan\" },\n480:         selected: { bg: \"blue\", fg: \"white\", bold: true },\n481:         item: { fg: \"white\" },\n482:         bg: \"black\",\n483:       },\n484:       hidden: true,\n485:     });\n486: \n487:     // Status line at bottom of modal\n488:     const statusLine = blessed.box({\n489:       parent: modal,\n490:       bottom: 0,\n491:       left: 1,\n492:       right: 1,\n493:       height: 1,\n494:       tags: true,\n495:       style: { fg: \"gray\", bg: \"black\" },\n496:     });\n497: \n498:     // Collected values\n499:     let questId = \"\";\n500:     let questTitle = \"\";\n501:     let questGoal = \"\";\n502:     let questPriority: Priority = \"medium\";\n503:     let questDifficulty: Difficulty = \"medium\";\n504:     let questHitl: QuestHitlMode = \"yolo\";\n505: \n506:     type Step = \"id\" | \"title\" | \"goal\" | \"priority\" | \"difficulty\" | \"hitl\";\n507:     const steps: Step[] = [\"id\", \"title\", \"goal\", \"priority\", \"difficulty\", \"hitl\"];\n508:     let currentStepIdx = 0;\n509: \n510:     const cleanup = () => {\n511:       modal.destroy();\n512:       this.creatingQuest = false;\n513:       this.questList.focus();\n514:       this.screen.render();\n515:     };\n516: \n517:     const showStep = (step: Step) => {\n518:       textbox.hide();\n519:       textarea.hide();\n520:       selectList.hide();\n521: \n522:       const stepLabel = `Step ${currentStepIdx + 1}/${steps.length}`;\n523: \n524:       switch (step) {\n525:         case \"id\":\n526:           content.setContent(\n527:             `{bold}${stepLabel} — Quest ID{/bold}\\n` +\n528:             `{gray-fg}Kebab-case identifier (e.g. auth-overhaul, search-api){/gray-fg}\\n` +\n529:             `{gray-fg}Esc to cancel{/gray-fg}`\n530:           );\n531:           statusLine.setContent(\"{gray-fg}Enter a unique ID for the quest{/gray-fg}\");\n532:           textbox.setValue(\"\");\n533:           textbox.show();\n534:           textbox.focus();\n535:           break;\n536: \n537:         case \"title\":\n538:           content.setContent(\n539:             `{bold}${stepLabel} — Title{/bold}\\n` +\n540:             `{gray-fg}Human-readable name for the quest{/gray-fg}\\n` +\n541:             `{gray-fg}Esc to go back{/gray-fg}`\n542:           );\n543:           statusLine.setContent(`{gray-fg}ID: ${questId}{/gray-fg}`);\n544:           textbox.setValue(\"\");\n545:           textbox.show();\n546:           textbox.focus();\n547:           break;\n548: \n549:         case \"goal\":\n550:           content.setContent(\n551:             `{bold}${stepLabel} — Goal{/bold}\\n` +\n552:             `{gray-fg}What should this quest achieve? (Enter to submit, Esc to go back){/gray-fg}\\n` +\n553:             `{gray-fg}Shift+Enter or \\\\n for newlines{/gray-fg}`\n554:           );\n555:           statusLine.setContent(`{gray-fg}ID: ${questId} | Title: ${questTitle}{/gray-fg}`);\n556:           textarea.setValue(\"\");\n557:           textarea.show();\n558:           textarea.focus();\n559:           break;\n560: \n561:         case \"priority\":\n562:           content.setContent(\n563:             `{bold}${stepLabel} — Priority{/bold}\\n` +\n564:             `{gray-fg}Select with Enter, Esc to go back{/gray-fg}`\n565:           );\n566:           statusLine.setContent(`{gray-fg}ID: ${questId} | Title: ${questTitle}{/gray-fg}`);\n567:           selectList.setItems(\n568:             (VALID_PRIORITIES as readonly string[]).map((p) => {\n569:               const dot = PRIORITY_COLORS[p] ?? \"white\";\n570:               const marker = p === \"medium\" ? \" {gray-fg}(default){/gray-fg}\" : \"\";\n571:               return `  {${dot}-fg}\\u25CF{/${dot}-fg}  ${p}${marker}`;\n572:             }) as any\n573:           );\n574:           // Pre-select \"medium\" (index 2)\n575:           selectList.select(2);\n576:           selectList.show();\n577:           selectList.focus();\n578:           break;\n579: \n580:         case \"difficulty\":\n581:           content.setContent(\n582:             `{bold}${stepLabel} — Difficulty{/bold}\\n` +\n583:             `{gray-fg}Select with Enter, Esc to go back{/gray-fg}`\n584:           );\n585:           statusLine.setContent(`{gray-fg}ID: ${questId} | Priority: ${questPriority}{/gray-fg}`);\n586:           selectList.setItems(\n587:             (VALID_DIFFICULTIES as readonly string[]).map((d) => {\n588:               const marker = d === \"medium\" ? \" {gray-fg}(default){/gray-fg}\" : \"\";\n589:               return `  ${d}${marker}`;\n590:             }) as any\n591:           );\n592:           selectList.select(2);\n593:           selectList.show();\n594:           selectList.focus();\n595:           break;\n596: \n597:         case \"hitl\":\n598:           content.setContent(\n599:             `{bold}${stepLabel} — HITL Mode{/bold}\\n` +\n600:             `{gray-fg}Human-in-the-loop mode for agents. Select with Enter, Esc to go back{/gray-fg}`\n601:           );\n602:           statusLine.setContent(`{gray-fg}ID: ${questId} | Difficulty: ${questDifficulty}{/gray-fg}`);\n603:           const hitlDescs: Record<string, string> = {\n604:             yolo: \"Full autonomy, no interruptions\",\n605:             cautious: \"Agent blocks on uncertainty, user answers in TUI\",\n606:             supervised: \"Like cautious, but prompt encourages asking often\",\n607:           };\n608:           selectList.setItems(\n609:             (VALID_HITL_MODES as readonly string[]).map((m) => {\n610:               const desc = hitlDescs[m] ?? \"\";\n611:               const marker = m === \"yolo\" ? \" {gray-fg}(default){/gray-fg}\" : \"\";\n612:               return `  ${m}${marker}  {gray-fg}— ${desc}{/gray-fg}`;\n613:             }) as any\n614:           );\n615:           selectList.select(0);\n616:           selectList.show();\n617:           selectList.focus();\n618:           break;\n619:       }\n620: \n621:       this.screen.render();\n622:     };\n623: \n624:     const goBack = () => {\n625:       if (currentStepIdx <= 0) {\n626:         cleanup();\n627:         return;\n628:       }\n629:       currentStepIdx--;\n630:       showStep(steps[currentStepIdx]);\n631:     };\n632: \n633:     const advanceOrFinish = () => {\n634:       currentStepIdx++;\n635:       if (currentStepIdx >= steps.length) {\n636:         // All done — create the quest\n637:         this.finishCreateQuest(\n638:           questId,\n639:           questTitle,\n640:           questGoal,\n641:           questPriority,\n642:           questDifficulty,\n643:           questHitl,\n644:           modal,\n645:           content,\n646:           statusLine\n647:         );\n648:         return;\n649:       }\n650:       showStep(steps[currentStepIdx]);\n651:     };\n652: \n653:     // --- Textbox submit/cancel for ID and Title steps ---\n654:     textbox.on(\"submit\", (value: string) => {\n655:       const trimmed = (value ?? \"\").trim();\n656:       const currentStep = steps[currentStepIdx];\n657: \n658:       if (currentStep === \"id\") {\n659:         // Validate ID\n660:         if (!trimmed) {\n661:           statusLine.setContent(\"{red-fg}ID cannot be empty{/red-fg}\");\n662:           this.screen.render();\n663:           textbox.focus();\n664:           return;\n665:         }\n666:         if (!/^[a-z0-9][a-z0-9-]*[a-z0-9]$|^[a-z0-9]$/.test(trimmed)) {\n667:           statusLine.setContent(\"{red-fg}ID must be kebab-case (lowercase letters, numbers, hyphens){/red-fg}\");\n668:           this.screen.render();\n669:           textbox.focus();\n670:           return;\n671:         }\n672:         // Check duplicate\n673:         const existing = loadQuest(this.projectRoot, trimmed);\n674:         if (existing) {\n675:           statusLine.setContent(`{red-fg}Quest \"${trimmed}\" already exists (${existing.status}){/red-fg}`);\n676:           this.screen.render();\n677:           textbox.focus();\n678:           return;\n679:         }\n680:         questId = trimmed;\n681:         advanceOrFinish();\n682:       } else if (currentStep === \"title\") {\n683:         if (!trimmed) {\n684:           statusLine.setContent(\"{red-fg}Title cannot be empty{/red-fg}\");\n685:           this.screen.render();\n686:           textbox.focus();\n687:           return;\n688:         }\n689:         questTitle = trimmed;\n690:         advanceOrFinish();\n691:       }\n692:     });\n693: \n694:     textbox.on(\"cancel\", () => {\n695:       goBack();\n696:     });\n697: \n698:     // --- Textarea submit/cancel for Goal step ---\n699:     textarea.key([\"enter\"], () => {\n700:       const val = (textarea.getValue() ?? \"\").trim();\n701:       if (!val) {\n702:         statusLine.setContent(\"{red-fg}Goal cannot be empty{/red-fg}\");\n703:         this.screen.render();\n704:         return;\n705:       }\n706:       questGoal = val;\n707:       advanceOrFinish();\n708:     });\n709: \n710:     textarea.key([\"escape\"], () => {\n711:       goBack();\n712:     });\n713: \n714:     // --- Select list for Priority, Difficulty, HITL ---\n715:     selectList.on(\"select item\", (_item: any, index: number) => {\n716:       // This fires on mouse click or manual select event\n717:     });\n718: \n719:     selectList.key([\"enter\", \"space\"], () => {\n720:       const currentStep = steps[currentStepIdx];\n721:       const idx = (selectList as any).selected ?? 0;\n722: \n723:       if (currentStep === \"priority\") {\n724:         questPriority = (VALID_PRIORITIES as readonly string[])[idx] as Priority;\n725:         advanceOrFinish();\n726:       } else if (currentStep === \"difficulty\") {\n727:         questDifficulty = (VALID_DIFFICULTIES as readonly string[])[idx] as Difficulty;\n728:         advanceOrFinish();\n729:       } else if (currentStep === \"hitl\") {\n730:         questHitl = (VALID_HITL_MODES as readonly string[])[idx] as QuestHitlMode;\n731:         advanceOrFinish();\n732:       }\n733:     });\n734: \n735:     selectList.key([\"escape\"], () => {\n736:       goBack();\n737:     });\n738: \n739:     // Start at step 0\n740:     showStep(steps[0]);\n741:   }\n742: \n743:   /**\n744:    * Finalize quest creation: save to store, show confirmation, reload list.\n745:    */\n746:   private finishCreateQuest(\n747:     id: string,\n748:     title: string,\n749:     goal: string,\n750:     priority: Priority,\n751:     difficulty: Difficulty,\n752:     hitlMode: QuestHitlMode,\n753:     modal: Widgets.BoxElement,\n754:     content: Widgets.BoxElement,\n755:     statusLine: Widgets.BoxElement\n756:   ): void {\n757:     try {\n758:       const baseBranch = this.config.baseBranch;\n759:       const quest = createBlankQuest(id, title, goal, baseBranch, {\n760:         priority,\n761:         difficulty,\n762:         hitlMode,\n763:       });\n764: \n765:       saveQuest(this.projectRoot, quest);\n766: \n767:       // Show confirmation briefly\n768:       content.setContent(\n769:         `{bold}{green-fg}\\u2714 Quest created!{/green-fg}{/bold}\\n\\n` +\n770:         `  {white-fg}${id}{/white-fg} — ${escapeBlessedTags(title)}\\n` +\n771:         `  Priority: ${priority}  |  Difficulty: ${difficulty}  |  HITL: ${hitlMode}\\n` +\n772:         `  Branch: quest/${id}  |  Base: ${baseBranch}`\n773:       );\n774:       statusLine.setContent(\"{gray-fg}Returning to quest list...{/gray-fg}\");\n775:       this.screen.render();\n776: \n777:       // After a brief delay, reload and return to picker\n778:       setTimeout(() => {\n779:         modal.destroy();\n780:         this.creatingQuest = false;\n781:         this.loadQuests();\n782:         // Select the newly created quest\n783:         const newIdx = this.items.findIndex(\n784:           (item) => item.type === \"quest\" && item.summary.quest.id === id\n785:         );\n786:         if (newIdx >= 0) this.selectedIndex = newIdx;\n787:         this.refreshAll();\n788:         this.questList.focus();\n789:         this.screen.render();\n790:       }, 1500);\n791:     } catch (err: unknown) {\n792:       const msg = err instanceof Error ? err.message : String(err);\n793:       content.setContent(\n794:         `{bold}{red-fg}\\u2718 Failed to create quest{/red-fg}{/bold}\\n\\n` +\n795:         `  ${escapeBlessedTags(msg)}`\n796:       );\n797:       statusLine.setContent(\"{gray-fg}Press Esc to return{/gray-fg}\");\n798:       this.screen.render();\n799: \n800:       const escHandler = () => {\n801:         modal.destroy();\n802:         this.creatingQuest = false;\n803:         this.questList.focus();\n804:         this.screen.render();\n805:       };\n806:       modal.key([\"escape\"], escHandler);\n807:     }\n808:   }\n809: \n810:   // -----------------------------------------------------------------------\n811:   // Refresh Logic\n812:   // -----------------------------------------------------------------------\n813: \n814:   private refreshAll(): void {\n815:     this.refreshHeader();\n816:     this.refreshList();\n817:     this.refreshDetail();\n818:     this.refreshStatusBar();\n819:   }\n820: \n821:   private refreshHeader(): void {\n822:     const questCount = this.items.length - 1; // exclude \"All Tasks\"\n823:     const activeCount = this.items.filter(\n824:       (i) => i.type === \"quest\" && i.summary.quest.status === \"active\"\n825:     ).length;\n826: \n827:     let line1 = ` {bold}wombo-combo{/bold} {magenta-fg}Quest Picker{/magenta-fg}`;\n828:     line1 += `  {gray-fg}|{/gray-fg}  {white-fg}${questCount}{/white-fg} quest${questCount !== 1 ? \"s\" : \"\"}`;\n829:     if (activeCount > 0) {\n830:       line1 += `  {gray-fg}|{/gray-fg}  {green-fg}${activeCount}{/green-fg} active`;\n831:     }\n832:     line1 += `  {gray-fg}|{/gray-fg}  {white-fg}${this.totalTaskCount}{/white-fg} total tasks`;\n833: \n834:     let line2 = ` {gray-fg}Select a quest to filter tasks, or choose \"All Tasks\" for the full list{/gray-fg}`;\n835: \n836:     this.headerBox.setContent(`${line1}\\n${line2}`);\n837:   }\n838: \n839:   private refreshList(): void {\n840:     const listItems: string[] = [];\n841: \n842:     for (const item of this.items) {\n843:       if (item.type === \"all\") {\n844:         listItems.push(\n845:           ` {bold}{cyan-fg}\\u25C6{/cyan-fg} All Tasks{/bold} {gray-fg}(${this.totalTaskCount}){/gray-fg}`\n846:         );\n847:       } else {\n848:         const { quest, totalTasks, doneTasks, completionPct } = item.summary;\n849: \n850:         // Status badge\n851:         const sColor = STATUS_COLORS[quest.status] ?? \"white\";\n852:         const sAbbr = STATUS_ABBREV[quest.status] ?? quest.status.slice(0, 4).toUpperCase();\n853:         const statusBadge = `{${sColor}-fg}${sAbbr}{/${sColor}-fg}`;\n854: \n855:         // Priority\n856:         const pColor = PRIORITY_COLORS[quest.priority] ?? \"white\";\n857:         const priorityDot = `{${pColor}-fg}\\u25CF{/${pColor}-fg}`;\n858: \n859:         // Title (truncated)\n860:         const maxTitleLen = 28;\n861:         const title = quest.title.length > maxTitleLen\n862:           ? quest.title.slice(0, maxTitleLen - 1) + \"\\u2026\"\n863:           : quest.title;\n864: \n865:         // Completion bar\n866:         const barWidth = 8;\n867:         const filled = Math.round((completionPct / 100) * barWidth);\n868:         const empty = barWidth - filled;\n869:         const bar = `{green-fg}${\"#\".repeat(filled)}{/green-fg}{gray-fg}${\"-\".repeat(empty)}{/gray-fg}`;\n870: \n871:         // Task count\n872:         const taskInfo = totalTasks > 0\n873:           ? `{gray-fg}${doneTasks}/${totalTasks}{/gray-fg}`\n874:           : `{gray-fg}0 tasks{/gray-fg}`;\n875: \n876:         listItems.push(\n877:           ` ${priorityDot} ${statusBadge} ${escapeBlessedTags(title)}  [${bar}] ${taskInfo}`\n878:         );\n879:       }\n880:     }\n881: \n882:     if (listItems.length === 0) {\n883:       listItems.push(\" {gray-fg}No quests found{/gray-fg}\");\n884:     }\n885: \n886:     const prevSelected = this.selectedIndex;\n887:     this.questList.setItems(listItems as any);\n888:     if (prevSelected < listItems.length) {\n889:       this.questList.select(prevSelected);\n890:     }\n891:   }\n892: \n893:   private refreshDetail(): void {\n894:     const item = this.items[this.selectedIndex];\n895:     if (!item) {\n896:       this.detailBox.setContent(\"{gray-fg}No item selected{/gray-fg}\");\n897:       this.detailBox.setLabel(\" Details \");\n898:       return;\n899:     }\n900: \n901:     if (item.type === \"all\") {\n902:       const lines: string[] = [\n903:         \"{bold}{cyan-fg}All Tasks{/cyan-fg}{/bold}\",\n904:         \"\",\n905:         \"  Browse all tasks across all quests\",\n906:         \"  and unassigned tasks.\",\n907:         \"\",\n908:         `  Total: {white-fg}${this.totalTaskCount}{/white-fg} tasks`,\n909:         \"\",\n910:         \"  Press {bold}Enter{/bold} to open the full task browser.\",\n911:       ];\n912:       this.detailBox.setContent(lines.join(\"\\n\"));\n913:       this.detailBox.setLabel(\" All Tasks \");\n914:       return;\n915:     }\n916: \n917:     const { quest, totalTasks, doneTasks, completionPct } = item.summary;\n918:     const lines: string[] = [];\n919: \n920:     // Title\n921:     lines.push(`{bold}{white-fg}${escapeBlessedTags(quest.title)}{/white-fg}{/bold}`);\n922:     lines.push(\"\");\n923: \n924:     // Status\n925:     const sColor = STATUS_COLORS[quest.status] ?? \"white\";\n926:     lines.push(`  Status:     {${sColor}-fg}${quest.status}{/${sColor}-fg}`);\n927: \n928:     // Priority\n929:     const pColor = PRIORITY_COLORS[quest.priority] ?? \"white\";\n930:     lines.push(`  Priority:   {${pColor}-fg}${quest.priority}{/${pColor}-fg}`);\n931: \n932:     // Difficulty\n933:     lines.push(`  Difficulty: ${quest.difficulty}`);\n934: \n935:     // HITL mode\n936:     lines.push(`  HITL:       ${quest.hitlMode}`);\n937:     lines.push(\"\");\n938: \n939:     // Task progress\n940:     if (totalTasks > 0) {\n941:       lines.push(\"{bold}Progress:{/bold}\");\n942:       lines.push(`  Tasks: ${doneTasks}/${totalTasks} done (${completionPct}%)`);\n943: \n944:       // Progress bar (wider in detail view)\n945:       const barWidth = 20;\n946:       const filled = Math.round((completionPct / 100) * barWidth);\n947:       const empty = barWidth - filled;\n948:       const bar = `{green-fg}${\"=\".repeat(filled)}{/green-fg}{gray-fg}${\"-\".repeat(empty)}{/gray-fg}`;\n949:       lines.push(`  [${bar}]`);\n950:     } else {\n951:       lines.push(\"{bold}Progress:{/bold}\");\n952:       lines.push(\"  {gray-fg}No tasks assigned{/gray-fg}\");\n953:     }\n954:     lines.push(\"\");\n955: \n956:     // Goal\n957:     if (quest.goal) {\n958:       lines.push(\"{bold}Goal:{/bold}\");\n959:       const goalText = escapeBlessedTags(quest.goal.trim());\n960:       const words = goalText.split(/\\s+/);\n961:       let line = \" \";\n962:       for (const w of words) {\n963:         if (line.length + w.length > 42) {\n964:           lines.push(line);\n965:           line = \" \" + w;\n966:         } else {\n967:           line += \" \" + w;\n968:         }\n969:       }\n970:       if (line.trim()) lines.push(line);\n971:       lines.push(\"\");\n972:     }\n973: \n974:     // Branch\n975:     lines.push(\"{bold}Branch:{/bold}\");\n976:     lines.push(`  ${quest.branch}`);\n977:     lines.push(`  Base: ${quest.baseBranch}`);\n978:     lines.push(\"\");\n979: \n980:     // Constraints\n981:     if (quest.constraints.add.length > 0) {\n982:       lines.push(\"{bold}Added Constraints:{/bold}\");\n983:       for (const c of quest.constraints.add) {\n984:         lines.push(`  + ${escapeBlessedTags(c)}`);\n985:       }\n986:       lines.push(\"\");\n987:     }\n988:     if (quest.constraints.ban.length > 0) {\n989:       lines.push(\"{bold}Banned:{/bold}\");\n990:       for (const b of quest.constraints.ban) {\n991:         lines.push(`  - ${escapeBlessedTags(b)}`);\n992:       }\n993:       lines.push(\"\");\n994:     }\n995: \n996:     // Dependencies\n997:     if (quest.depends_on.length > 0) {\n998:       lines.push(\"{bold}Depends on:{/bold}\");\n999:       for (const d of quest.depends_on) {\n1000:         lines.push(`  \\u2192 ${d}`);\n1001:       }\n1002:       lines.push(\"\");\n1003:     }\n1004: \n1005:     // Notes\n1006:     if (quest.notes.length > 0) {\n1007:       lines.push(\"{bold}Notes:{/bold}\");\n1008:       for (const n of quest.notes) {\n1009:         lines.push(`  ${escapeBlessedTags(n)}`);\n1010:       }\n1011:       lines.push(\"\");\n1012:     }\n1013: \n1014:     // Timestamps\n1015:     lines.push(\"{bold}Timeline:{/bold}\");\n1016:     lines.push(`  Created: ${quest.created_at.slice(0, 10)}`);\n1017:     if (quest.started_at) lines.push(`  Started: ${quest.started_at.slice(0, 10)}`);\n1018:     if (quest.ended_at) lines.push(`  Ended:   ${quest.ended_at.slice(0, 10)}`);\n1019: \n1020:     this.detailBox.setContent(lines.join(\"\\n\"));\n1021:     this.detailBox.setLabel(` ${quest.id} `);\n1022:   }\n1023: \n1024:   private refreshStatusBar(): void {\n1025:     let line1 = ` {bold}Keys:{/bold}`;\n1026:     line1 += `  {gray-fg}Enter{/gray-fg} select`;\n1027:     line1 += `  {gray-fg}C{/gray-fg} create`;\n1028:     line1 += `  {gray-fg}E{/gray-fg} errand`;\n1029:     line1 += `  {gray-fg}P{/gray-fg} plan`;\n1030:     line1 += `  {gray-fg}G{/gray-fg} genesis`;\n1031:     line1 += `  {gray-fg}A{/gray-fg} activate/pause`;\n1032:     line1 += `  {gray-fg}Q{/gray-fg} quit`;\n1033: \n1034:     const item = this.items[this.selectedIndex];\n1035:     let line2 = \" \";\n1036:     if (item?.type === \"all\") {\n1037:       line2 += `{cyan-fg}View all tasks across all quests{/cyan-fg}`;\n1038:     } else if (item?.type === \"quest\") {\n1039:       const q = item.summary.quest;\n1040:       line2 += `{white-fg}${escapeBlessedTags(q.id)}{/white-fg}`;\n1041:       line2 += `  {gray-fg}|{/gray-fg}  ${item.summary.totalTasks} task${item.summary.totalTasks !== 1 ? \"s\" : \"\"}`;\n1042:       line2 += `  {gray-fg}|{/gray-fg}  ${item.summary.completionPct}% complete`;\n1043:       if (q.status === \"draft\" || q.status === \"planning\") {\n1044:         line2 += `  {gray-fg}|{/gray-fg}  {magenta-fg}P to plan{/magenta-fg}`;\n1045:       }\n1046:     }\n1047: \n1048:     this.statusBar.setContent(`${line1}\\n${line2}`);\n1049:   }\n1050: }\n\n(End of file - total 1050 lines)\n</content>","title":"src/lib/tui-quest-picker.ts","metadata":{"preview":"/**\n * tui-quest-picker.ts -- Quest picker view for the wombo-combo TUI.\n *\n * Shows all quests as a selectable list with an \"All Tasks\" option at the top.\n * Selecting a quest navigates to the Task Browser filtered to that quest's tasks.\n *\n * Layout:\n *   +-----------------------------------------------------------+\n *   | WOMBO-COMBO Quest Picker  | 4 quests                      |\n *   +---------------------------+-------------------------------+\n *   | > All Tasks (42)          | Quest: auth-overhaul           |\n *   |   auth-overhaul   ACTV    | Status: active                 |\n *   |   search-api      DRFT    | Priority: high                 |\n *   |   perf-optim      PAUS    | Tasks: 8 (3 done, 62%)         |\n *   |   ui-redesign     PLAN    | Goal: Replace basic auth...    |\n *   |                           |                                |\n *   +---------------------------+-------------------------------+\n *   | Enter:select  C:create  Q:quit                            |\n *   +-----------------------------------------------------------+\n *","truncated":false,"loaded":[]},"time":{"start":1773482839596,"end":1773482839600}}}}
