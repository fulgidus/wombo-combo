{"type":"text","timestamp":1773482696097,"sessionID":"ses_314328759ffeSwO8I1laVGgGu4","part":{"id":"prt_cebce46a3001wqObWywienoMce","sessionID":"ses_314328759ffeSwO8I1laVGgGu4","messageID":"msg_cebce3d3b001MXDHAPTYvFeyPn","type":"text","text":"OK, so the wishlist is only available through the `wishlist-store.ts` module but not yet exposed in the TUI. The task description says:\n\n> \"Add promotion flow from wishlist TUI: E key on a selected item pre-fills the errand description prompt and triggers the errand flow. G key promotes to genesis input. After promotion, optionally delete the wishlist item. Wire the callbacks through tui.ts main loop.\"\n\nThis means I need to:\n1. Create a wishlist TUI view (like the quest picker / task browser)\n2. Add E key to promote wishlist item → errand (pre-fills description)\n3. Add G key to promote wishlist item → genesis (pre-fills vision)\n4. After promotion, optionally delete the wishlist item\n5. Wire it into the tui.ts main loop\n\nLet me now look at the TUI session to understand view tracking:","time":{"start":1773482696097,"end":1773482696097}}}
{"type":"tool_use","timestamp":1773482696099,"sessionID":"ses_314328759ffeSwO8I1laVGgGu4","part":{"id":"prt_cebce5b69001xwkyBnDzR9Nmma","sessionID":"ses_314328759ffeSwO8I1laVGgGu4","messageID":"msg_cebce3d3b001MXDHAPTYvFeyPn","type":"tool","callID":"toolu_vrtx_0121KxAhWxDnH9yv2MWENBBj","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/wishlist-promote/src/lib/tui-session.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/wishlist-promote/src/lib/tui-session.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tui-session.ts — Persist TUI session state across opens/closes.\n3:  *\n4:  * Stores task selection, sort preferences, and view state so the user\n5:  * can close the TUI and reopen it without losing work.\n6:  *\n7:  * File: .wombo-combo/tui-session.json\n8:  */\n9: \n10: import { existsSync, readFileSync, writeFileSync, mkdirSync } from \"node:fs\";\n11: import { resolve } from \"node:path\";\n12: import { WOMBO_DIR } from \"../config.js\";\n13: \n14: // ---------------------------------------------------------------------------\n15: // Types\n16: // ---------------------------------------------------------------------------\n17: \n18: export type SortField = \"priority\" | \"status\" | \"name\" | \"stream\" | \"effort\";\n19: export type SortOrder = \"asc\" | \"desc\";\n20: \n21: export interface TUISession {\n22:   /** IDs of tasks selected for the next wave launch */\n23:   selected: string[];\n24:   /** Current sort field */\n25:   sortBy: SortField;\n26:   /** Sort direction */\n27:   sortOrder: SortOrder;\n28:   /** Max concurrent agents for launches from the TUI */\n29:   maxConcurrent: number;\n30:   /** Which view was last active */\n31:   lastView: \"browser\" | \"monitor\";\n32:   /** Collapsed stream group IDs (for tree display) */\n33:   collapsed: string[];\n34: }\n35: \n36: // ---------------------------------------------------------------------------\n37: // Defaults\n38: // ---------------------------------------------------------------------------\n39: \n40: const SESSION_FILE = \"tui-session.json\";\n41: \n42: const DEFAULT_SESSION: TUISession = {\n43:   selected: [],\n44:   sortBy: \"priority\",\n45:   sortOrder: \"desc\",\n46:   maxConcurrent: 5,\n47:   lastView: \"browser\",\n48:   collapsed: [],\n49: };\n50: \n51: // ---------------------------------------------------------------------------\n52: // Path\n53: // ---------------------------------------------------------------------------\n54: \n55: function sessionPath(projectRoot: string): string {\n56:   return resolve(projectRoot, WOMBO_DIR, SESSION_FILE);\n57: }\n58: \n59: // ---------------------------------------------------------------------------\n60: // Load / Save\n61: // ---------------------------------------------------------------------------\n62: \n63: /**\n64:  * Load TUI session from disk. Returns defaults if not found.\n65:  */\n66: export function loadTUISession(projectRoot: string): TUISession {\n67:   const fp = sessionPath(projectRoot);\n68:   try {\n69:     if (existsSync(fp)) {\n70:       const raw = readFileSync(fp, \"utf-8\");\n71:       const data = JSON.parse(raw);\n72:       return { ...DEFAULT_SESSION, ...data };\n73:     }\n74:   } catch {\n75:     // Corrupt file — use defaults\n76:   }\n77:   return { ...DEFAULT_SESSION };\n78: }\n79: \n80: /**\n81:  * Save TUI session to disk.\n82:  */\n83: export function saveTUISession(projectRoot: string, session: TUISession): void {\n84:   const dir = resolve(projectRoot, WOMBO_DIR);\n85:   if (!existsSync(dir)) mkdirSync(dir, { recursive: true });\n86:   const fp = sessionPath(projectRoot);\n87:   writeFileSync(fp, JSON.stringify(session, null, 2) + \"\\n\");\n88: }\n\n(End of file - total 88 lines)\n</content>","title":"src/lib/tui-session.ts","metadata":{"preview":"/**\n * tui-session.ts — Persist TUI session state across opens/closes.\n *\n * Stores task selection, sort preferences, and view state so the user\n * can close the TUI and reopen it without losing work.\n *\n * File: .wombo-combo/tui-session.json\n */\n\nimport { existsSync, readFileSync, writeFileSync, mkdirSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\nimport { WOMBO_DIR } from \"../config.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type SortField = \"priority\" | \"status\" | \"name\" | \"stream\" | \"effort\";\nexport type SortOrder = \"asc\" | \"desc\";\n","truncated":false,"loaded":[]},"time":{"start":1773482696095,"end":1773482696098}}}}
