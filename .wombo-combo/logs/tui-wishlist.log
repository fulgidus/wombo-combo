{"type":"tool_use","timestamp":1773483390662,"sessionID":"ses_314277f9bffeVWfnq7bm5y0Dtk","part":{"id":"prt_cebd8ee69001f8qIyPzpeNB5B1","sessionID":"ses_314277f9bffeVWfnq7bm5y0Dtk","messageID":"msg_cebd8e4fd001K76Of378zOWu6E","type":"tool","callID":"toolu_vrtx_01L4vcwBT19RzPUEpbX72hix","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/tui-wishlist/src/commands/tui.ts","limit":120,"offset":1},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/tui-wishlist/src/commands/tui.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tui.ts -- Unified TUI command entry point for wombo-combo.\n3:  *\n4:  * Orchestrates multiple views in a persistent loop:\n5:  *   1. Quest Picker (tui-quest-picker.ts) -- select a quest or \"All Tasks\"\n6:  *   2. Task Browser (tui-browser.ts) -- select tasks, change priorities, launch\n7:  *   3. Wave Monitor (tui.ts) -- watch running wave, view logs, retry agents\n8:  *   4. Plan Review (tui-plan-review.ts) -- review/edit/approve planner output\n9:  *   5. Genesis Review (tui-genesis-review.ts) -- review/edit/approve genesis plan\n10:  *\n11:  * Flow:\n12:  *   `woco` -> Quest Picker (if quests exist) -> Task Browser -> L -> launches\n13:  *   wave -> wave completes -> Q in monitor -> back to Quest Picker -> ...\n14:  *\n15:  *   Quest Picker -> P (plan) -> spinner -> Plan Review -> approve/cancel ->\n16:  *   back to Quest Picker\n17:  *\n18:  *   Quest Picker -> G (genesis) -> vision prompt -> spinner -> Genesis Review\n19:  *   -> approve/cancel -> back to Quest Picker\n20:  *\n21:  *   Quest Picker/Browser -> E (errand) -> description prompt -> spinner ->\n22:  *   Plan Review -> approve/cancel -> creates quest-less tasks -> back\n23:  *\n24:  * If no quests exist, the Quest Picker is skipped entirely and the flow goes\n25:  * straight to the Task Browser (backward compatible).\n26:  *\n27:  * Exit behavior:\n28:  *   - Q from Quest Picker: exits the process\n29:  *   - Q/Esc from Task Browser: back to Quest Picker (or exits if no quests)\n30:  *   - Q from Wave Monitor: back to Quest Picker\n31:  *   - Q/Esc from Plan Review: discard plan, back to Quest Picker\n32:  *\n33:  * Session state is persisted to .wombo-combo/tui-session.json so the user can\n34:  * close and reopen the TUI without losing their task selections.\n35:  */\n36: \n37: import type { WomboConfig } from \"../config.js\";\n38: import { ensureTasksFile } from \"../lib/tasks.js\";\n39: import { loadState } from \"../lib/state.js\";\n40: import { loadTUISession, saveTUISession } from \"../lib/tui-session.js\";\n41: import type { TUISession } from \"../lib/tui-session.js\";\n42: import { TaskBrowser } from \"../lib/tui-browser.js\";\n43: import { QuestPicker } from \"../lib/tui-quest-picker.js\";\n44: import type { QuestPickerAction } from \"../lib/tui-quest-picker.js\";\n45: import { PlanReview } from \"../lib/tui-plan-review.js\";\n46: import type { ProposedTask } from \"../lib/quest-planner.js\";\n47: import { runQuestPlanner, applyPlanToQuest } from \"../lib/quest-planner.js\";\n48: import type { PlanResult } from \"../lib/quest-planner.js\";\n49: import { loadAllQuests, loadQuest, saveQuest, listQuestIds, saveQuestKnowledge } from \"../lib/quest-store.js\";\n50: import { GenesisReview } from \"../lib/tui-genesis-review.js\";\n51: import type { GenesisReviewAction } from \"../lib/tui-genesis-review.js\";\n52: import { runGenesisPlanner } from \"../lib/genesis-planner.js\";\n53: import type { GenesisResult, ProposedQuest } from \"../lib/genesis-planner.js\";\n54: import { createBlankQuest } from \"../lib/quest.js\";\n55: import { runErrandPlanner, applyErrandPlan } from \"../lib/errand-planner.js\";\n56: import { WishlistPicker } from \"../lib/tui-wishlist.js\";\n57: import type { WishlistAction } from \"../lib/tui-wishlist.js\";\n58: import { deleteItem as deleteWishlistItem } from \"../lib/wishlist-store.js\";\n59: import type { WishlistItem } from \"../lib/wishlist-store.js\";\n60: import { cmdLaunch } from \"./launch.js\";\n61: import type { LaunchCommandOptions } from \"./launch.js\";\n62: import { cmdResume } from \"./resume.js\";\n63: \n64: // ---------------------------------------------------------------------------\n65: // Types\n66: // ---------------------------------------------------------------------------\n67: \n68: export interface TUICommandOptions {\n69:   projectRoot: string;\n70:   config: WomboConfig;\n71:   /** Max concurrent agents (override, or null to use session/config default) */\n72:   maxConcurrent?: number;\n73:   /** Model override */\n74:   model?: string;\n75:   /** Base branch override */\n76:   baseBranch?: string;\n77:   /** Max retries override */\n78:   maxRetries?: number;\n79:   /** Auto-push after merge */\n80:   autoPush?: boolean;\n81:   /** Skip TDD tests */\n82:   skipTests?: boolean;\n83:   /** Strict TDD mode */\n84:   strictTdd?: boolean;\n85:   /** Agent definition override */\n86:   agent?: string;\n87: }\n88: \n89: type BrowserAction =\n90:   | { type: \"launch\"; ids: string[] }\n91:   | { type: \"errand\" }\n92:   | { type: \"back\" }\n93:   | { type: \"quit\" };\n94: \n95: type PlanReviewResult =\n96:   | { type: \"approve\"; tasks: ProposedTask[]; knowledge: string | null }\n97:   | { type: \"cancel\" };\n98: \n99: // ---------------------------------------------------------------------------\n100: // Command -- Main Loop\n101: // ---------------------------------------------------------------------------\n102: \n103: export async function cmdTui(opts: TUICommandOptions): Promise<void> {\n104:   const { projectRoot, config } = opts;\n105: \n106:   // Ensure tasks file exists\n107:   await ensureTasksFile(projectRoot, config);\n108: \n109:   // Load session state (persisted selections, sort, concurrency)\n110:   const session = loadTUISession(projectRoot);\n111: \n112:   // Apply concurrency override from CLI if provided\n113:   if (opts.maxConcurrent !== undefined) {\n114:     session.maxConcurrent = opts.maxConcurrent;\n115:   }\n116: \n117:   // Main TUI loop:\n118:   //   Quest Picker -> Task Browser -> Launch -> Monitor -> back to Quest Picker\n119:   // Only exits when the user presses Q from the Quest Picker (or browser if no quests).\n120:   while (true) {\n\n(Showing lines 1-120 of 1017. Use offset=121 to continue.)\n</content>","title":"src/commands/tui.ts","metadata":{"preview":"/**\n * tui.ts -- Unified TUI command entry point for wombo-combo.\n *\n * Orchestrates multiple views in a persistent loop:\n *   1. Quest Picker (tui-quest-picker.ts) -- select a quest or \"All Tasks\"\n *   2. Task Browser (tui-browser.ts) -- select tasks, change priorities, launch\n *   3. Wave Monitor (tui.ts) -- watch running wave, view logs, retry agents\n *   4. Plan Review (tui-plan-review.ts) -- review/edit/approve planner output\n *   5. Genesis Review (tui-genesis-review.ts) -- review/edit/approve genesis plan\n *\n * Flow:\n *   `woco` -> Quest Picker (if quests exist) -> Task Browser -> L -> launches\n *   wave -> wave completes -> Q in monitor -> back to Quest Picker -> ...\n *\n *   Quest Picker -> P (plan) -> spinner -> Plan Review -> approve/cancel ->\n *   back to Quest Picker\n *\n *   Quest Picker -> G (genesis) -> vision prompt -> spinner -> Genesis Review\n *   -> approve/cancel -> back to Quest Picker\n *","truncated":true,"loaded":[]},"time":{"start":1773483390659,"end":1773483390662}}}}
{"type":"text","timestamp":1773483391096,"sessionID":"ses_314277f9bffeVWfnq7bm5y0Dtk","part":{"id":"prt_cebd8ec5e002mEiK88iJGK9s09","sessionID":"ses_314277f9bffeVWfnq7bm5y0Dtk","messageID":"msg_cebd8e4fd001K76Of378zOWu6E","type":"text","text":"Let me also look at the main TUI loop and the import section, and the task browser status bar:","time":{"start":1773483391096,"end":1773483391096}}}
{"type":"tool_use","timestamp":1773483391099,"sessionID":"ses_314277f9bffeVWfnq7bm5y0Dtk","part":{"id":"prt_cebd8f6c4001hBN04vcAUdw6nu","sessionID":"ses_314277f9bffeVWfnq7bm5y0Dtk","messageID":"msg_cebd8e4fd001K76Of378zOWu6E","type":"tool","callID":"toolu_vrtx_015ZPhC6hAMqCTWg493erbf9","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/tui-wishlist/src/commands/tui.ts","limit":200,"offset":100},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/tui-wishlist/src/commands/tui.ts</path>\n<type>file</type>\n<content>100: // Command -- Main Loop\n101: // ---------------------------------------------------------------------------\n102: \n103: export async function cmdTui(opts: TUICommandOptions): Promise<void> {\n104:   const { projectRoot, config } = opts;\n105: \n106:   // Ensure tasks file exists\n107:   await ensureTasksFile(projectRoot, config);\n108: \n109:   // Load session state (persisted selections, sort, concurrency)\n110:   const session = loadTUISession(projectRoot);\n111: \n112:   // Apply concurrency override from CLI if provided\n113:   if (opts.maxConcurrent !== undefined) {\n114:     session.maxConcurrent = opts.maxConcurrent;\n115:   }\n116: \n117:   // Main TUI loop:\n118:   //   Quest Picker -> Task Browser -> Launch -> Monitor -> back to Quest Picker\n119:   // Only exits when the user presses Q from the Quest Picker (or browser if no quests).\n120:   while (true) {\n121:     // Check for an active wave on each iteration\n122:     const existingState = loadState(projectRoot);\n123:     const hasRunningWave =\n124:       existingState !== null &&\n125:       existingState.agents.some(\n126:         (a) =>\n127:           a.status === \"running\" ||\n128:           a.status === \"queued\" ||\n129:           a.status === \"installing\" ||\n130:           a.status === \"resolving_conflict\" ||\n131:           a.status === \"retry\"\n132:       );\n133: \n134:     if (hasRunningWave) {\n135:       // A wave is already running -- resume it (wave monitor TUI).\n136:       // When the wave completes and the user presses Q, cmdResume returns\n137:       // and we loop back to the quest picker / browser.\n138:       console.log(\n139:         `Active wave detected: ${existingState!.wave_id}. Resuming...`\n140:       );\n141:       try {\n142:         await cmdResume({\n143:           projectRoot,\n144:           config,\n145:           maxConcurrent: opts.maxConcurrent,\n146:           model: opts.model,\n147:           interactive: false,\n148:           noTui: false,\n149:           autoPush: opts.autoPush ?? false,\n150:           baseBranch: opts.baseBranch,\n151:           maxRetries: opts.maxRetries,\n152:         });\n153:       } catch (err: any) {\n154:         // Don't crash -- show error and loop back\n155:         console.error(`\\nResume error: ${err.message}\\n`);\n156:         await sleep(2000);\n157:       }\n158:       // Clear terminal before showing picker/browser again\n159:       process.stdout.write(\"\\x1B[2J\\x1B[H\");\n160:       continue;\n161:     }\n162: \n163:     // -----------------------------------------------------------------------\n164:     // Quest Picker (skip if no quests exist)\n165:     // -----------------------------------------------------------------------\n166:     const quests = loadAllQuests(projectRoot);\n167:     const hasQuests = quests.length > 0;\n168: \n169:     let selectedQuestId: string | null = null;\n170: \n171:     if (hasQuests) {\n172:       const questAction = await showQuestPicker(projectRoot, config, opts);\n173: \n174:       if (questAction.type === \"quit\") {\n175:         // User pressed Q in quest picker -- exit cleanly\n176:         session.lastView = \"browser\";\n177:         saveTUISession(projectRoot, session);\n178:         break;\n179:       }\n180: \n181:       if (questAction.type === \"plan\") {\n182:         // User pressed P to plan a quest -- run planner + review\n183:         await handlePlanFlow(projectRoot, config, opts, questAction.questId);\n184:         // After planning (approve or cancel), loop back to quest picker\n185:         process.stdout.write(\"\\x1B[2J\\x1B[H\");\n186:         continue;\n187:       }\n188: \n189:       if (questAction.type === \"genesis\") {\n190:         // User pressed G to run genesis -- run genesis planner + review\n191:         await handleGenesisFlow(projectRoot, config, opts);\n192:         // After genesis (approve or cancel), loop back to quest picker\n193:         process.stdout.write(\"\\x1B[2J\\x1B[H\");\n194:         continue;\n195:       }\n196: \n197:       if (questAction.type === \"errand\") {\n198:         // User pressed E to create an errand (quest-less assisted task)\n199:         await handleErrandFlow(projectRoot, config, opts);\n200:         // After errand (approve or cancel), loop back to quest picker\n201:         process.stdout.write(\"\\x1B[2J\\x1B[H\");\n202:         continue;\n203:       }\n204: \n205:       if (questAction.type === \"wishlist\") {\n206:         // User pressed W to browse wishlist\n207:         await handleWishlistFlow(projectRoot, config, opts);\n208:         // After wishlist (promote, back, or quit), loop back to quest picker\n209:         process.stdout.write(\"\\x1B[2J\\x1B[H\");\n210:         continue;\n211:       }\n212: \n213:       selectedQuestId = questAction.questId;\n214:     }\n215: \n216:     // -----------------------------------------------------------------------\n217:     // Task Browser (filtered by quest if one was selected)\n218:     // -----------------------------------------------------------------------\n219:     const action = await showBrowser(\n220:       projectRoot,\n221:       config,\n222:       session,\n223:       opts,\n224:       selectedQuestId,\n225:       hasQuests\n226:     );\n227: \n228:     if (action.type === \"quit\") {\n229:       // User pressed Q in browser with no quest context -- exit cleanly\n230:       session.lastView = \"browser\";\n231:       saveTUISession(projectRoot, session);\n232:       break;\n233:     }\n234: \n235:     if (action.type === \"back\") {\n236:       // User pressed Q/Esc in quest-filtered browser -- back to quest picker\n237:       process.stdout.write(\"\\x1B[2J\\x1B[H\");\n238:       continue;\n239:     }\n240: \n241:     if (action.type === \"errand\") {\n242:       // User pressed E in browser to create an errand\n243:       await handleErrandFlow(projectRoot, config, opts);\n244:       process.stdout.write(\"\\x1B[2J\\x1B[H\");\n245:       continue;\n246:     }\n247: \n248:     if (action.type === \"launch\") {\n249:       // Save session before launching\n250:       session.selected = action.ids;\n251:       session.lastView = \"monitor\";\n252:       saveTUISession(projectRoot, session);\n253: \n254:       // Build launch options\n255:       const launchOpts: LaunchCommandOptions = {\n256:         projectRoot,\n257:         config,\n258:         features: action.ids,\n259:         maxConcurrent: session.maxConcurrent,\n260:         model: opts.model,\n261:         interactive: false,\n262:         dryRun: false,\n263:         baseBranch: opts.baseBranch ?? config.baseBranch,\n264:         maxRetries: opts.maxRetries ?? config.defaults.maxRetries,\n265:         noTui: false,\n266:         autoPush: opts.autoPush ?? false,\n267:         agent: opts.agent,\n268:         outputFmt: \"text\",\n269:         // Pass quest ID so launch uses quest branch and constraints\n270:         questId: selectedQuestId ?? undefined,\n271:       };\n272: \n273:       try {\n274:         await cmdLaunch(launchOpts);\n275:       } catch (err: any) {\n276:         // Don't crash -- show error and loop back\n277:         console.error(`\\nLaunch error: ${err.message}\\n`);\n278:         await sleep(2000);\n279:       }\n280: \n281:       // Clear terminal before showing picker/browser again\n282:       process.stdout.write(\"\\x1B[2J\\x1B[H\");\n283:       continue;\n284:     }\n285:   }\n286: }\n287: \n288: // ---------------------------------------------------------------------------\n289: // Quest Picker View -- Promise-based\n290: // ---------------------------------------------------------------------------\n291: \n292: /**\n293:  * Show the Quest Picker and return a Promise that resolves when the user\n294:  * takes an action (select quest, plan quest, or quit).\n295:  */\n296: function showQuestPicker(\n297:   projectRoot: string,\n298:   config: WomboConfig,\n299:   opts: TUICommandOptions\n\n(Showing lines 100-299 of 1017. Use offset=300 to continue.)\n</content>","title":"src/commands/tui.ts","metadata":{"preview":"// Command -- Main Loop\n// ---------------------------------------------------------------------------\n\nexport async function cmdTui(opts: TUICommandOptions): Promise<void> {\n  const { projectRoot, config } = opts;\n\n  // Ensure tasks file exists\n  await ensureTasksFile(projectRoot, config);\n\n  // Load session state (persisted selections, sort, concurrency)\n  const session = loadTUISession(projectRoot);\n\n  // Apply concurrency override from CLI if provided\n  if (opts.maxConcurrent !== undefined) {\n    session.maxConcurrent = opts.maxConcurrent;\n  }\n\n  // Main TUI loop:\n  //   Quest Picker -> Task Browser -> Launch -> Monitor -> back to Quest Picker\n  // Only exits when the user presses Q from the Quest Picker (or browser if no quests).","truncated":true,"loaded":[]},"time":{"start":1773483391095,"end":1773483391098}}}}
