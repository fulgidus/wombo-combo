status === \"backlog\" || t.status === \"planned\") && areDependenciesMet(t, this.doneIds);\n1000:     }).length;\n1001: \n1002:     let line1 = ` {bold}Keys:{/bold}`;\n1003:     line1 += `  {gray-fg}Space{/gray-fg} toggle`;\n1004:     line1 += `  {gray-fg}S{/gray-fg} stream`;\n1005:     line1 += `  {gray-fg}A{/gray-fg} all`;\n1006:     line1 += `  {gray-fg}+/-{/gray-fg} priority`;\n1007:     line1 += `  {gray-fg}D{/gray-fg} ${this.hideDone ? \"show\" : \"hide\"} done`;\n1008:     line1 += `  {gray-fg}X{/gray-fg} archive done`;\n1009:     line1 += `  {gray-fg}C{/gray-fg} concurrency`;\n1010:     if (this.onErrand) {\n1011:       line1 += `  {gray-fg}E{/gray-fg} errand`;\n1012:     }\n1013:     line1 += `  {gray-fg}W{/gray-fg} wishlist`;\n1014:     line1 += `  {gray-fg}O{/gray-fg} sort`;\n1015: \n1016:     if (selCount > 0) {\n1017:       line1 += `  {bold}{green-fg}L{/green-fg} LAUNCH (${selCount}){/bold}`;\n1018:     }\n1019:     if (this.hasRunningWave) {\n1020:       line1 += `  {gray-fg}Tab{/gray-fg} monitor`;\n1021:     }\n1022:     if (this.onBack) {\n1023:       line1 += `  {gray-fg}Esc{/gray-fg} back`;\n1024:     }\n1025:     if (this.questId) {\n1026:       line1 += `  {gray-fg}Q{/gray-fg} back`;\n1027:     } else {\n1028:       line1 += `  {gray-fg}Q{/gray-fg} quit`;\n1029:     }\n1030: \n1031:     let line2 = ` `;\n1032:     if (selCount > 0) {\n1033:       line2 += `{green-fg}${selCount}{/green-fg} selected`;\n1034:       line2 += `  {cyan-fg}${readyInSelection}{/cyan-fg} launchable now`;\n1035:       const doneInSel = [...this.selected].filter((id) => {\n1036:         const t = this.allTasks.find((tt) => tt.id === id);\n1037:         return t?.status === \"done\";\n1038:       }).length;\n1039:       if (doneInSel > 0) {\n1040:         line2 += `  {yellow-fg}${doneInSel} already done (will be skipped){/yellow-fg}`;\n1041:       }\n1042:     } else {\n1043:       line2 += `{gray-fg}Select tasks with Space, then press L to launch{/gray-fg}`;  \n1044:     }\n1045: \n1046:     this.statusBar.setContent(`${line1}\\n${line2}`);\n1047:   }\n1048: }\n\n(End of file - total 1048 lines)\n</content>","title":"src/lib/tui-browser.ts","metadata":{"preview":"    if (t.description) {\n      lines.push(\"{bold}Description:{/bold}\");\n      const desc = escapeBlessedTags(t.description.trim());\n      // Word-wrap to roughly 38 chars\n      const words = desc.split(/\\s+/);\n      let line = \" \";\n      for (const w of words) {\n        if (line.length + w.length > 36) {\n          lines.push(line);\n          line = \" \" + w;\n        } else {\n          line += \" \" + w;\n        }\n      }\n      if (line.trim()) lines.push(line);\n      lines.push(\"\");\n    }\n\n    // Agent type\n    if (t.agent_type) {","truncated":false,"loaded":[]},"time":{"start":1773483396296,"end":1773483396298}}}}
