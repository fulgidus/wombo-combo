"interface TasksCheckOptions\",\n      \"summary\": \"Type definition TasksCheckOptions\",\n      \"score\": 8\n    },\n    {\n      \"id\": \"src/commands/tasks/check.ts::checkTasks#function\",\n      \"kind\": \"function\",\n      \"name\": \"checkTasks\",\n      \"file\": \"src/commands/tasks/check.ts\",\n      \"line\": 66,\n      \"signature\": \"function checkTasks(data: FeaturesFile): CheckResult\",\n      \"summary\": \"function checkTasks(data: FeaturesFile): CheckResult\",\n      \"score\": 8\n    },\n    {\n      \"id\": \"src/commands/tasks/check.ts::cmdTasksCheck#function\",\n      \"kind\": \"function\",\n      \"name\": \"cmdTasksCheck\",\n      \"file\": \"src/commands/tasks/check.ts\",\n      \"line\": 160,\n      \"signature\": \"async function cmdTasksCheck(opts: TasksCheckOptions): Promise<void>\",\n      \"summary\": \"async function cmdTasksCheck(opts: TasksCheckOptions): Promise<void>\",\n      \"score\": 8\n    }\n  ],\n  \"_meta\": {\n    \"timing_ms\": 6.6,\n    \"total_symbols\": 968,\n    \"truncated\": true,\n    \"tokens_saved\": 32676,\n    \"total_tokens_saved\": 1742076,\n    \"cost_avoided\": {\n      \"claude_opus_4_6\": 0.1634,\n      \"claude_sonnet_4_6\": 0.098,\n      \"claude_haiku_4_5\": 0.0327,\n      \"gpt5_latest\": 0.3268\n    },\n    \"total_cost_avoided\": {\n      \"claude_opus_4_6\": 8.7104,\n      \"claude_sonnet_4_6\": 5.2262,\n      \"claude_haiku_4_5\": 1.7421,\n      \"gpt5_latest\": 17.4208\n    },\n    \"powered_by\": \"jcodemunch-mcp by jgravelle \\u00b7 https://github.com/jgravelle/jcodemunch-mcp\"\n  }\n}","title":"","metadata":{"truncated":false},"time":{"start":1773483374962,"end":1773483374986},"attachments":[]}}}
