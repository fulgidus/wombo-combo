:   writeFileSync(tmp, content, \"utf-8\");\n81:   renameSync(tmp, filePath);\n82: }\n83: \n84: /**\n85:  * Normalize a parsed item to ensure all fields are present.\n86:  */\n87: function normalizeItem(item: Partial<WishlistItem>): WishlistItem {\n88:   return {\n89:     id: item.id ?? randomUUID(),\n90:     text: item.text ?? \"\",\n91:     created_at: item.created_at ?? new Date().toISOString(),\n92:     tags: item.tags ?? [],\n93:   };\n94: }\n95: \n96: // ---------------------------------------------------------------------------\n97: // Public API — Load\n98: // ---------------------------------------------------------------------------\n99: \n100: /**\n101:  * Load all wishlist items from .wombo-combo/wishlist.yml.\n102:  * Returns an empty array if the file does not exist or is empty.\n103:  */\n104: export function loadWishlist(projectRoot: string): WishlistItem[] {\n105:   const filePath = wishlistPath(projectRoot);\n106:   if (!existsSync(filePath)) return [];\n107: \n108:   try {\n109:     const raw = readFileSync(filePath, \"utf-8\");\n110:     const parsed = parseYaml(raw);\n111: \n112:     // YAML parses empty files / `null` as null\n113:     if (!parsed) return [];\n114:     if (!Array.isArray(parsed)) {\n115:       console.error(`wishlist.yml: expected a YAML array, got ${typeof parsed}`);\n116:       return [];\n117:     }\n118: \n119:     return parsed.map((item: unknown) => normalizeItem(item as Partial<WishlistItem>));\n\n(Showing lines 40-119 of 200. Use offset=120 to continue.)\n</content>","title":"src/lib/wishlist-store.ts","metadata":{"preview":"  /** Optional tags for categorization */\n  tags: string[];\n}\n\n// ---------------------------------------------------------------------------\n// Constants\n// ---------------------------------------------------------------------------\n\n/** Filename for the wishlist store inside .wombo-combo/ */\nconst WISHLIST_FILE = \"wishlist.yml\";\n\nconst YAML_OPTS = {\n  lineWidth: 120,\n  defaultKeyTyp