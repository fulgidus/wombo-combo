{"type":"tool_use","timestamp":1773483681717,"sessionID":"ses_314277f9bffeVWfnq7bm5y0Dtk","part":{"id":"prt_cebdd64ca0026ICxtpwshQC1L0","sessionID":"ses_314277f9bffeVWfnq7bm5y0Dtk","messageID":"msg_cebdd5ad90011BzoHW5b1kJg8h","type":"tool","callID":"toolu_vrtx_01K7FPRQmwNYxbiHTvGxY15m","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/tui-wishlist/src/index.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/tui-wishlist/src/index.ts</path>\n<type>file</type>\n<content>1: #!/usr/bin/env bun\n2: /**\n3:  * index.ts — CLI entry point for the wombo-combo agent orchestration system.\n4:  *\n5:  * Every command has a short alias (e.g., woco i = woco init, woco t ls = woco tasks list).\n6:  *\n7:  * Usage:\n8:  *   woco init                                         (alias: i)\n9:  *   woco launch --top-priority 3                      (alias: l)\n10:  *   woco launch --quickest-wins 5\n11:  *   woco launch --priority high\n12:  *   woco launch --difficulty easy\n13:  *   woco launch --tasks \"feat-a,feat-b\"\n14:  *   woco launch --all-ready\n15:  *   woco launch ... --max-concurrent 3 --model \"anthropic/claude-sonnet-4-20250514\"\n16:  *   woco launch ... --interactive\n17:  *   woco resume                                       (alias: r)\n18:  *   woco status                                       (alias: s)\n19:  *   woco verify [feature-id]                          (alias: v)\n20:  *   woco merge [feature-id]                           (alias: m)\n21:  *   woco retry <feature-id>                           (alias: re)\n22:  *   woco abort <feature-id> [--requeue] [--output json]  (alias: a)\n23:  *   woco logs <feature-id> [--tail N] [--follow]      (alias: lo)\n24:  *   woco cleanup                                      (alias: c)\n25:  *   woco history [wave-id] [--output json]            (alias: h)\n26:  *   woco tasks list [--status <s>] [--priority <p>]   (alias: t ls)\n27:  *   woco tasks add <id> <title> [options]             (alias: t a)\n28:  *   woco tasks set-status <task-id> <status>          (alias: t ss)\n29:  *   woco tasks set-priority <task-id> <priority>      (alias: t sp)\n30:  *   woco tasks set-difficulty <task-id> <difficulty>   (alias: t sd)\n31:  *   woco tasks check                                  (alias: t ch)\n32:  *   woco tasks archive [task-id] [--dry-run]          (alias: t ar)\n33:  *   woco tasks show <task-id>                         (alias: t sh)\n34:  *   woco tasks graph [--ascii] [--mermaid]            (alias: t g)\n35:  *   woco completion <bash|zsh|fish>                   (alias: comp)\n36:  *   woco tui                                          (default when no args)\n37:  *   woco help                                         (alias: -h, --help)\n38:  *   woco version\n39:  *   woco -v\n40:  */\n41: \n42: import { resolve } from \"node:path\";\n43: import { existsSync, readFileSync } from \"node:fs\";\n44: import { loadConfig, validateConfig } from \"./config.js\";\n45: import { loadState, saveState } from \"./lib/state.js\";\n46: \n47: // ---------------------------------------------------------------------------\n48: // Dev-mode guard: warn if running the global binary inside the wombo-combo repo\n49: // ---------------------------------------------------------------------------\n50: \n51: function checkDevModeGuard(): void {\n52:   const cwd = process.cwd();\n53:   const pkgPath = resolve(cwd, \"package.json\");\n54: \n55:   // Are we inside the wombo-combo repo?\n56:   if (!existsSync(pkgPath)) return;\n57: \n58:   let pkgName: string | undefined;\n59:   try {\n60:     const raw = readFileSync(pkgPath, \"utf-8\");\n61:     pkgName = JSON.parse(raw).name;\n62:   } catch {\n63:     return;\n64:   }\n65:   if (pkgName !== \"wombo-combo\") return;\n66: \n67:   // We're in the wombo-combo repo. Is the source being run from a different location?\n68:   // import.meta.dir = directory of THIS file (index.ts). If it's under cwd,\n69:   // we're running local source (bun dev). If it's elsewhere (e.g. ~/.bun/install),\n70:   // we're running the globally installed binary.\n71:   const sourceDir = resolve(import.meta.dir);\n72:   const projectSrc = resolve(cwd, \"src\");\n73: \n74:   if (!sourceDir.startsWith(projectSrc)) {\n75:     console.warn(\n76:       \"\\x1b[33m[WARNING]\\x1b[0m You are running the globally installed woco binary \" +\n77:       \"inside the wombo-combo repo.\\n\" +\n78:       \"  Use \\x1b[1mbun dev <command>\\x1b[0m instead to run from local source.\\n\" +\n79:       \"  See AGENTS.md for details.\\n\"\n80:     );\n81:   }\n82: }\n83: \n84: import { cmdInit } from \"./commands/init.js\";\n85: import { cmdLaunch } from \"./commands/launch.js\";\n86: import { cmdResume } from \"./commands/resume.js\";\n87: import { cmdStatus } from \"./commands/status.js\";\n88: import { cmdVerify } from \"./commands/verify.js\";\n89: import { cmdMerge } from \"./commands/merge.js\";\n90: import { cmdRetry } from \"./commands/retry.js\";\n91: import { cmdCleanup } from \"./commands/cleanup.js\";\n92: import { cmdAbort } from \"./commands/abort.js\";\n93: import { cmdLogs } from \"./commands/logs.js\";\n94: import { cmdUpgrade } from \"./commands/upgrade.js\";\n95: import { cmdHistory } from \"./commands/history.js\";\n96: import { cmdCompletion } from \"./commands/completion.js\";\n97: import { cmdTasksList } from \"./commands/tasks/list.js\";\n98: import { cmdTasksAdd } from \"./commands/tasks/add.js\";\n99: import { cmdTasksSetStatus } from \"./commands/tasks/set-status.js\";\n100: import { cmdTasksSetPriority } from \"./commands/tasks/set-priority.js\";\n101: import { cmdTasksSetDifficulty } from \"./commands/tasks/set-difficulty.js\";\n102: import { cmdTasksCheck } from \"./commands/tasks/check.js\";\n103: import { cmdTasksArchive } from \"./commands/tasks/archive.js\";\n104: import { cmdTasksShow } from \"./commands/tasks/show.js\";\n105: import { cmdTasksGraph } from \"./commands/tasks/graph.js\";\n106: import { cmdTui } from \"./commands/tui.js\";\n107: import { handleQuestSubcommand } from \"./commands/quest.js\";\n108: import { cmdGenesis } from \"./commands/genesis.js\";\n109: \n110: import { ensureTasksFile } from \"./lib/tasks.js\";\n111: import type { Priority, Difficulty, FeatureStatus } from \"./lib/tasks.js\";\n112: import type { QuestHitlMode } from \"./lib/quest.js\";\n113: import { resolveOutputFormat, outputError, type OutputFormat } from \"./lib/output.js\";\n114: import { validateId, validateText, validateBranchName, validateDuration, assertValid } from \"./lib/validate.js\";\n115: import { findCommandDef, commandToSchema, allCommandSchemas } from \"./lib/schema.js\";\n116: import { buildToonSpec, renderToonLegend } from \"./lib/toon-spec.js\";\n117: import { addItem as addWishlistItem, deleteItem as deleteWishlistItem, listItems as listWishlistItems } from \"./lib/wishlist-store.js\";\n118: \n119: // ---------------------------------------------------------------------------\n120: // Types\n121: // ---------------------------------------------------------------------------\n122: \n123: export interface CLIArgs {\n124:   command: string;\n125:   subcommand?: string;\n126:   // Selection options (launch)\n127:   topPriority?: number;\n128:   quickestWins?: number;\n129:   priority?: Priority;\n130:   difficulty?: Difficulty;\n131:   tasks?: string[];\n132:   allReady?: boolean;\n133:   // Launch / runtime options\n134:   maxConcurrent?: number;\n135:   model?: string;\n136:   interactive: boolean;\n137:   dryRun: boolean;\n138:   baseBranch?: string;\n139:   maxRetries?: number;\n140:   noTui: boolean;\n141:   autoPush: boolean;\n142:   // Abort options\n143:   requeue: boolean;\n144:   // General\n145:   featureId?: string;\n146:   force: boolean;\n147:   // Output format\n148:   outputFmt: OutputFormat;\n149:   // Upgrade options\n150:   checkOnly: boolean;\n151:   tag?: string;\n152:   // Features subcommand extras\n153:   status?: string;\n154:   ready?: boolean;\n155:   includeArchive?: boolean;\n156:   title?: string;\n157:   description?: string;\n158:   effort?: string;\n159:   dependsOn?: string[];\n160:   // Logs options\n161:   tail?: number;\n162:   follow?: boolean;\n163:   // Compact output\n164:   fields?: string[];\n165:   // Graph options\n166:   ascii?: boolean;\n167:   mermaidRaw?: boolean;\n168:   graphSubtasks?: boolean;\n169:   // Browser verification\n170:   browser?: boolean;\n171:   // TDD verification\n172:   skipTests?: boolean;\n173:   strictTdd?: boolean;\n174:   // Agent selection (per-task override)\n175:   agent?: string;\n176:   // Quest-specific options\n177:   goal?: string;\n178:   hitlMode?: QuestHitlMode;\n179:   /** Quest ID to scope a launch to (--quest <id>) */\n180:   questId?: string;\n181:   /** Tech stack description for genesis (--tech-stack) */\n182:   techStack?: string;\n183:   /** Constraints for genesis (--constraint, can be repeated) */\n184:   genesisConstraints?: string[];\n185:   /** Skip TUI review (--no-tui for genesis) */\n186:   genesisNoTui?: boolean;\n187:   /** Tags for wishlist items (--tag, can be repeated) */\n188:   wishlistTags?: string[];\n189: }\n190: \n191: // ---------------------------------------------------------------------------\n192: // Command & Subcommand Aliases\n193: // ---------------------------------------------------------------------------\n194: \n195: /** Map of short aliases → canonical top-level command names. */\n196: export const COMMAND_ALIASES: Record<string, string> = {\n197:   i: \"init\",\n198:   l: \"launch\",\n199:   r: \"resume\",\n200:   s: \"status\",\n201:   v: \"verify\",\n202:   m: \"merge\",\n203:   re: \"retry\",\n204:   a: \"abort\",\n205:   c: \"cleanup\",\n206:   h: \"history\",\n207:   lo: \"logs\",\n208:   t: \"tasks\",\n209:   features: \"tasks\", // backward-compat full-word alias\n210:   q: \"quest\",\n211:   g: \"genesis\",\n212:   u: \"upgrade\",\n213:   d: \"describe\",\n214:   comp: \"completion\",\n215:   tui: \"tui\",\n216:   w: \"wishlist\",\n217:   wl: \"wishlist\",\n218: };\n219: \n220: /** Map of short aliases → canonical tasks subcommand names. */\n221: export const SUBCOMMAND_ALIASES: Record<string, string> = {\n222:   ls: \"list\",\n223:   a: \"add\",\n224:   ss: \"set-status\",\n225:   sp: \"set-priority\",\n226:   sd: \"set-difficulty\",\n227:   ch: \"check\",\n228:   validate: \"check\", // backward-compat full-word alias\n229:   ar: \"archive\",\n230:   sh: \"show\",\n231:   g: \"graph\",\n232: };\n233: \n234: /** Map of short aliases → canonical quest subcommand names. */\n235: export const QUEST_SUBCOMMAND_ALIASES: Record<string, string> = {\n236:   c: \"create\",\n237:   ls: \"list\",\n238:   sh: \"show\",\n239:   pl: \"plan\",\n240:   a: \"activate\",\n241:   p: \"pause\",\n242:   co: \"complete\",\n243:   ab: \"abandon\",\n244: };\n245: \n246: /** Map of short aliases → canonical wishlist subcommand names. */\n247: export const WISHLIST_SUBCOMMAND_ALIASES: Record<string, string> = {\n248:   a: \"add\",\n249:   ls: \"list\",\n250:   rm: \"delete\",\n251:   del: \"delete\",\n252:   d: \"delete\",\n253: };\n254: \n255: // ---------------------------------------------------------------------------\n256: // Arg Parsing\n257: // ---------------------------------------------------------------------------\n258: \n259: export function parseArgs(argv: string[]): CLIArgs {\n260:   const args = argv.slice(2); // skip 'bun' and script path\n261:   const result: CLIArgs = {\n262:     command: args[0] || \"tui\",\n263:     interactive: false,\n264:     dryRun: false,\n265:     noTui: false,\n266:     autoPush: false,\n267:     requeue: false,\n268:     force: false,\n269:     checkOnly: false,\n270:     outputFmt: resolveOutputFormat(undefined), // auto-detect until --output overrides\n271:   };\n272: \n273:   // Resolve top-level command alias (e.g., \"i\" → \"init\", \"t\" → \"tasks\")\n274:   result.command = COMMAND_ALIASES[result.command] ?? result.command;\n275: \n276:   // If the command is \"tasks\", treat the second positional as the subcommand\n277:   let startIdx = 1;\n278:   if (result.command === \"tasks\") {\n279:     result.subcommand = args[1] || \"list\";\n280:     // Resolve subcommand alias (e.g., \"ls\" → \"list\", \"ss\" → \"set-status\")\n281:     result.subcommand = SUBCOMMAND_ALIASES[result.subcommand] ?? result.subcommand;\n282:     startIdx = 2;\n283:   } else if (result.command === \"quest\") {\n284:     result.subcommand = args[1] || \"list\";\n285:     // Resolve quest subcommand alias (e.g., \"c\" → \"create\", \"sh\" → \"show\")\n286:     result.subcommand = QUEST_SUBCOMMAND_ALIASES[result.subcommand] ?? result.subcommand;\n287:     startIdx = 2;\n288:   } else if (result.command === \"wishlist\") {\n289:     result.subcommand = args[1] || \"list\";\n290:     // Resolve wishlist subcommand alias (e.g., \"a\" → \"add\", \"ls\" → \"list\")\n291:     result.subcommand = WISHLIST_SUBCOMMAND_ALIASES[result.subcommand] ?? result.subcommand;\n292:     startIdx = 2;\n293:   }\n294: \n295:   for (let i = startIdx; i < args.length; i++) {\n296:     const arg = args[i];\n297: \n298:     // Helper: consume the next argument, or exit with a clear error\n299:     function requireValue(flag: string): string {\n300:       if (i + 1 >= args.length) {\n301:         outputError(result.outputFmt, `Flag ${flag} requires a value.`);\n302:       }\n303:       return args[++i];\n304:     }\n305: \n306:     switch (arg) {\n307:       // --- Selection options ---\n308:       case \"--top-priority\":\n309:         result.topPriority = parseInt(requireValue(arg), 10);\n310:         break;\n311:       case \"--quickest-wins\":\n312:         result.quickestWins = parseInt(requireValue(arg), 10);\n313:         break;\n314:       case \"--priority\":\n315:         result.priority = requireValue(arg) as Priority;\n316:         break;\n317:       case \"--difficulty\":\n318:         result.difficulty = requireValue(arg) as Difficulty;\n319:         break;\n320:       case \"--tasks\":\n321:       case \"--features\": // backward-compat alias\n322:         result.tasks = requireValue(arg).split(\",\").map((s) => s.trim());\n323:         break;\n324:       case \"--all-ready\":\n325:         result.allReady = true;\n326:         break;\n327: \n328:       // --- Launch / runtime options ---\n329:       case \"--max-concurrent\":\n330:         result.maxConcurrent = parseInt(requireValue(arg), 10);\n331:         break;\n332:       case \"--model\":\n333:       case \"-m\":\n334:         result.model = requireValue(arg);\n335:         break;\n336:       case \"--interactive\":\n337:         result.interactive = true;\n338:         break;\n339:       case \"--dry-run\":\n340:         result.dryRun = true;\n341:         break;\n342:       case \"--no-tui\":\n343:         result.noTui = true;\n344:         break;\n345:       case \"--auto-push\":\n346:         result.autoPush = true;\n347:         break;\n348:       case \"--requeue\":\n349:         result.requeue = true;\n350:         break;\n351:       case \"--base-branch\":\n352:         result.baseBranch = requireValue(arg);\n353:         break;\n354:       case \"--max-retries\":\n355:         result.maxRetries = parseInt(requireValue(arg), 10);\n356:         break;\n357: \n358:       // --- General flags ---\n359:       case \"--force\":\n360:         result.force = true;\n361:         break;\n362:       case \"--check\":\n363:         result.checkOnly = true;\n364:         break;\n365:       case \"--tag\":\n366:       case \"--release\":\n367:         result.tag = requireValue(arg);\n368:         break;\n369:       case \"--output\":\n370:       case \"-o\":\n371:         result.outputFmt = resolveOutputFormat(requireValue(arg));\n372:         break;\n373: \n374:       // --- Tasks subcommand options ---\n375:       case \"--status\":\n376:         result.status = requireValue(arg);\n377:         break;\n378:       case \"--ready\":\n379:         result.ready = true;\n380:         break;\n381:       case \"--include-archive\":\n382:         result.includeArchive = true;\n383:         break;\n384:       case \"--title\":\n385:         result.title = requireValue(arg);\n386:         break;\n387:       case \"--description\":\n388:       case \"--desc\":\n389:         result.description = requireValue(arg);\n390:         break;\n391:       case \"--effort\":\n392:         result.effort = requireValue(arg);\n393:         break;\n394:       case \"--depends-on\":\n395:         result.dependsOn = requireValue(arg).split(\",\").map((s) => s.trim());\n396:         break;\n397:       case \"--fields\":\n398:         result.fields = requireValue(arg).split(\",\").map((s) => s.trim());\n399:         break;\n400: \n401:       // --- Graph options ---\n402:       case \"--ascii\":\n403:         result.ascii = true;\n404:         break;\n405:       case \"--mermaid\":\n406:         result.mermaidRaw = true;\n407:         break;\n408:       case \"--subtasks\":\n409:         result.graphSubtasks = true;\n410:         break;\n411: \n412:       // --- Logs options ---\n413:       case \"--tail\":\n414:         result.tail = parseInt(requireValue(arg), 10);\n415:         break;\n416:       case \"--follow\":\n417:       case \"-f\":\n418:         result.follow = true;\n419:         break;\n420: \n421:       // --- Browser verification ---\n422:       case \"--browser\":\n423:         result.browser = true;\n424:         break;\n425: \n426:       // --- TDD verification ---\n427:       case \"--skip-tests\":\n428:         result.skipTests = true;\n429:         break;\n430:       case \"--strict-tdd\":\n431:         result.strictTdd = true;\n432:         break;\n433: \n434:       // --- Agent selection ---\n435:       case \"--agent\":\n436:         result.agent = requireValue(arg);\n437:         break;\n438: \n439:       // --- Quest-specific options ---\n440:       case \"--goal\":\n441:         result.goal = requireValue(arg);\n442:         break;\n443:       case \"--hitl\":\n444:         result.hitlMode = requireValue(arg) as QuestHitlMode;\n445:         break;\n446:       case \"--quest\":\n447:         result.questId = requireValue(arg);\n448:         break;\n449: \n450:       // --- Genesis-specific options ---\n451:       case \"--tech-stack\":\n452:         result.techStack = requireValue(arg);\n453:         break;\n454:       case \"--constraint\":\n455:         if (!result.genesisConstraints) result.genesisConstraints = [];\n456:         result.genesisConstraints.push(requireValue(arg));\n457:         break;\n458: \n459:       // --- Wishlist-specific options ---\n460:       case \"--tag\":\n461:         if (!result.wishlistTags) result.wishlistTags = [];\n462:         result.wishlistTags.push(requireValue(arg));\n463:         break;\n464: \n465:       // --- Positional (feature-id, title for add, etc.) ---\n466:       default:\n467:         if (!arg.startsWith(\"-\")) {\n468:           if (!result.featureId) {\n469:             result.featureId = arg;\n470:           } else if (!result.title) {\n471:             result.title = arg;\n472:           }\n473:         }\n474:         break;\n475:     }\n476:   }\n477: \n478:   return result;\n479: }\n480: \n481: // ---------------------------------------------------------------------------\n482: // Help\n483: // ---------------------------------------------------------------------------\n484: \n485: function cmdHelp(): void {\n486:   console.log(`\n487: wombo-combo — AI Agent Orchestration System\n488: \n489:   WOMBO COMBO! Parallel feature development with AI agents.\n490: \n491: Commands:                        (alias)\n492:   init                           (i)     Generate .wombo-combo/config.json in the current project\n493:   launch                         (l)     Launch a wave of agents to implement features\n494:   resume                         (r)     Resume a previously stopped wave\n495:   status                         (s)     Show the status of the current wave\n496:   verify                         (v)     Run build verification on completed agents\n497:   merge                          (m)     Merge verified branches into the base branch\n498:   retry                          (re)    Retry a failed agent\n499:   abort                          (a)     Kill a single running agent (--requeue to return to queue)\n500:   logs                           (lo)    Pretty-print agent logs for a feature\n501:   cleanup                        (c)     Remove all wave worktrees and multiplexer sessions\n502:   history                        (h)     List/view past wave results (stored in .wombo-combo/history/)\n503:   tasks                          (t)     Manage tasks file (see below; 'features' also accepted)\n504:   quest                          (q)     Manage quests (scoped missions; see below)\n505:   genesis                        (g)     Run genesis planner (project-level decomposition into quests)\n506:   tui                                    Interactive TUI: browse tasks, select, launch, monitor\n507:   upgrade                        (u)     Check for updates and upgrade wombo-combo\n508:   describe                       (d)     Emit JSON schema or TOON legend (--output toon)\n509:   completion                     (comp)  Generate shell completions (bash, zsh, fish)\n510:   version                                Print version and exit\n511:   help                                   Show this help\n512: \n513: Tasks Subcommands:               (alias)\n514:   tasks list                     (ls)    List tasks (--status, --priority, --difficulty, --ready, --include-archive)\n515:   tasks add <id> <title>         (a)     Add a new task (--desc, --priority, --difficulty, --effort, --depends-on)\n516:   tasks set-status <id> <s>      (ss)    Change a task's status\n517:   tasks set-priority <id> <p>    (sp)    Change a task's priority (critical/high/medium/low/wishlist)\n518:   tasks set-difficulty <id> <d>  (sd)    Change a task's difficulty (trivial/easy/medium/hard/very_hard)\n519:   tasks check                    (ch)    Validate tasks file (schema, deps, duplicates, cycles)\n520:   tasks archive [id]             (ar)    Move done/cancelled to archive (--dry-run)\n521:   tasks show <id>                (sh)    Show task details\n522:   tasks graph                    (g)     Visualize dependency graph (--ascii, --mermaid, --subtasks)\n523: \n524: Quest Subcommands:               (alias)\n525:   quest create <id> \"Title\"      (c)     Create a new quest (--goal, --priority, --difficulty, --hitl)\n526:   quest list                     (ls)    List all quests (--status to filter)\n527:   quest show <id>                (sh)    Show quest details\n528:   quest activate <id>            (a)     Activate a quest (creates branch, sets status to active)\n529:   quest pause <id>               (p)     Pause an active/planning quest\n530:   quest complete <id>            (co)    Complete quest (merges branch into base; --force to skip merge)\n531:   quest abandon <id>              (ab)    Abandon quest without merging (--force to delete branch)\n532: \n533: Genesis Options:\n534:   --tech-stack <text>      Describe the tech stack (e.g., \"React, Node, Postgres\")\n535:   --constraint <text>      Add a constraint (can be repeated: --constraint \"...\" --constraint \"...\")\n536:   --model <model>          Model override for the genesis planner agent\n537:   --no-tui                 Skip interactive review, auto-approve all quests\n538:   --dry-run                Show proposed quests without creating them\n539: \n540: Selection Options (for launch):\n541:   --top-priority N         Select top N tasks by priority\n542:   --quickest-wins N        Select N tasks with lowest effort\n543:   --priority <level>       Filter by priority (critical/high/medium/low/wishlist)\n544:   --difficulty <level>     Filter by difficulty (trivial/easy/medium/hard/very_hard)\n545:   --tasks \"id1,id2\"        Select specific tasks by ID (--features also accepted)\n546:   --all-ready              Select all tasks whose dependencies are met\n547: \n548: Launch Options:\n549:   --max-concurrent N       Max agents running in parallel (default: from config)\n550:   --model <model>          Model to use (e.g., \"anthropic/claude-sonnet-4-20250514\")\n551:   --interactive            Use multiplexer (dmux/tmux) TUI mode instead of headless\n552:   --no-tui                 Headless mode without neo-blessed TUI (periodic console dashboard)\n553:   --auto-push              Push base branch to remote after all merges complete\n554:   --dry-run                Show what would be launched without launching\n555:   --base-branch <branch>   Base branch (default: from config)\n556:   --max-retries N          Max retries per agent (default: from config)\n557:   --browser                Enable browser-based verification (run after build passes)\n558:   --skip-tests             Skip running tests during TDD verification\n559:   --strict-tdd             Strict TDD: fail verification if new files are missing tests\n560:   --agent <name>           Override agent definition for all launched tasks (name without .md extension)\n561:   --quest <id>             Scope launch to a quest (uses quest branch as base, applies quest constraints)\n562: \n563: General:\n564:   --force                  Force overwrite (e.g., for init) / skip prompts (e.g., for upgrade)\n565:   --output <fmt>           Output format: text (default on TTY), json (default when piped), or toon (WOMBO_OUTPUT=toon)\n566:   -o <fmt>                 Alias for --output\n567:   --dry-run                Show what would happen without performing the action\n568:   --fields <list>          Comma-separated fields to include (e.g., id,status,priority)\n569: \n570: Upgrade Options:\n571:   --check                  Only check for updates, don't install\n572:   --tag <tag>              Install a specific version (e.g., v0.1.0)\n573: \n574: Logs Options:\n575:   --tail N                 Show only the last N lines\n576:   --follow, -f             Stream new output as it arrives (like tail -f)\n577: \n578: Aliases (every command has a short form):\n579:   woco i                         woco init\n580:   woco l --all-ready             woco launch --all-ready\n581:   woco t ls                      woco tasks list\n582:   woco t a my-task \"Title\"       woco tasks add my-task \"Title\"\n583:   woco t ss my-task done         woco tasks set-status my-task done\n584:   woco q c my-quest \"Quest\"      woco quest create my-quest \"Quest\" --goal \"...\"\n585:   woco q ls                      woco quest list\n586:   woco q sh my-quest             woco quest show my-quest\n587: \n588: Shell Completion:\n589:   eval \"$(woco completion bash)\"    # Bash: add to ~/.bashrc\n590:   eval \"$(woco completion zsh)\"     # Zsh:  add to ~/.zshrc\n591:   woco completion fish | source     # Fish (or save to ~/.config/fish/completions/woco.fish)\n592: \n593: Examples:\n594:   woco init\n595:   woco launch --quickest-wins 3\n596:   woco launch --priority high --interactive\n597:   woco launch --tasks \"auth-flow,search-api\" --max-concurrent 2\n598:   woco resume\n599:   woco status\n600:   woco verify\n601:   woco merge\n602:   woco retry auth-flow\n603:   woco abort auth-flow\n604:   woco abort auth-flow --requeue\n605:   woco abort auth-flow --output json\n606:   woco logs auth-flow\n607:   woco logs auth-flow --tail 50\n608:   woco logs auth-flow --follow\n609:   woco logs auth-flow --output json\n610:   woco cleanup\n611:   woco tasks list --status ready --priority high\n612:   woco tasks list --fields id,status,priority --output json\n613:   woco tasks add my-task \"My Cool Task\" --priority high --difficulty easy\n614:   woco tasks set-status my-task in-progress\n615:   woco tasks check\n616:   woco tasks archive --dry-run\n617:   woco tasks show my-task\n618:   woco history\n619:   woco history wave-2026-03-12-420\n620:   woco history --output json\n621:   woco describe                           # list all commands as JSON\n622:   woco describe launch                    # describe a specific command\n623:   woco describe tasks add                 # describe a subcommand\n624:   woco describe --output toon             # emit TOON format legend/spec\n625:   woco quest create auth \"Auth Overhaul\" --goal \"Replace basic auth with OAuth2\" --priority high\n626:   woco quest list\n627:   woco quest activate auth\n628:   woco quest complete auth\n629:   woco genesis \"Build a SaaS dashboard with auth, billing, and analytics\"\n630:   woco genesis \"Modernize the frontend\" --tech-stack \"React, TypeScript, Tailwind\"\n631:   woco g \"Add multi-tenant support\" --constraint \"No breaking changes\" --constraint \"Keep backward compat\"\n632:   woco genesis \"...\" --dry-run\n633: `);\n634: }\n635: \n636: // ---------------------------------------------------------------------------\n637: // Main\n638: // ---------------------------------------------------------------------------\n639: \n640: async function main(): Promise<void> {\n641:   checkDevModeGuard();\n642: \n643:   const PROJECT_ROOT = resolve(process.cwd());\n644:   const args = parseArgs(process.argv);\n645: \n646:   // -----------------------------------------------------------------------\n647:   // Input validation at the CLI boundary\n648:   // -----------------------------------------------------------------------\n649:   if (args.featureId) {\n650:     assertValid(validateId(args.featureId, \"feature ID\"));\n651:   }\n652:   if (args.title) {\n653:     assertValid(validateText(args.title, \"title\"));\n654:   }\n655:   if (args.description) {\n656:     assertValid(validateText(args.description, \"description\"));\n657:   }\n658:   if (args.baseBranch) {\n659:     assertValid(validateBranchName(args.baseBranch, \"base branch\"));\n660:   }\n661:   if (args.effort) {\n662:     assertValid(validateDuration(args.effort, \"effort\"));\n663:   }\n664:   if (args.tasks) {\n665:     for (const fid of args.tasks) {\n666:       assertValid(validateId(fid, \"task ID in --tasks\"));\n667:     }\n668:   }\n669:   if (args.dependsOn) {\n670:     for (const dep of args.dependsOn) {\n671:       assertValid(validateId(dep, \"dependency ID in --depends-on\"));\n672:     }\n673:   }\n674: \n675:   // Validate numeric args are not NaN\n676:   const numericArgs: [string, number | undefined][] = [\n677:     [\"--top-priority\", args.topPriority],\n678:     [\"--quickest-wins\", args.quickestWins],\n679:     [\"--max-concurrent\", args.maxConcurrent],\n680:     [\"--max-retries\", args.maxRetries],\n681:     [\"--tail\", args.tail],\n682:   ];\n683:   for (const [flag, value] of numericArgs) {\n684:     if (value !== undefined && isNaN(value)) {\n685:       outputError(args.outputFmt, `${flag} requires a numeric value.`);\n686:     }\n687:   }\n688: \n689:   // Commands that don't need config loading\n690:   if (args.command === \"version\" || args.command === \"-v\" || args.command === \"-V\") {\n691:     const pkgPath = resolve(import.meta.dir, \"..\", \"package.json\");\n692:     const pkgFile = Bun.file(pkgPath);\n693:     try {\n694:       const pkg = await pkgFile.json();\n695:       console.log(`wombo-combo ${pkg.version ?? \"(unknown version)\"}`);\n696:     } catch {\n697:       console.log(\"wombo-combo (unknown version)\");\n698:     }\n699:     return;\n700:   }\n701: \n702:   if (args.command === \"help\" || args.command === \"--help\" || args.command === \"-h\") {\n703:     cmdHelp();\n704:     return;\n705:   }\n706: \n707:   if (args.command === \"describe\") {\n708:     // Schema introspection: `woco describe [command]`\n709:     if (args.outputFmt === \"toon\") {\n710:       // Emit TOON format legend — self-describing, cacheable by agents\n711:       const pkgPath = resolve(import.meta.dir, \"..\", \"package.json\");\n712:       let version = \"unknown\";\n713:       try {\n714:         const pkg = await Bun.file(pkgPath).json();\n715:         version = pkg.version ?? \"unknown\";\n716:       } catch {}\n717: \n718:       if (!args.featureId) {\n719:         // Full TOON spec (legend + all commands)\n720:         console.log(renderToonLegend(version));\n721:       } else {\n722:         // JSON structure for the full spec (--output toon with a specific command\n723:         // still emits JSON since TOON is a line-oriented data format, not a schema format)\n724:         const spec = buildToonSpec(version);\n725:         const cmdName = args.title\n726:           ? `${args.featureId} ${args.title}`\n727:           : args.featureId;\n728:         const cmdSpec = spec.commands.find((c) => c.command === cmdName);\n729:         if (!cmdSpec) {\n730:           outputError(args.outputFmt, `Unknown command: \"${cmdName}\". Run 'woco describe --output toon' to see the full TOON spec.`);\n731:           return;\n732:         }\n733:         console.log(JSON.stringify(cmdSpec, null, 2));\n734:       }\n735:       return;\n736:     }\n737: \n738:     if (!args.featureId) {\n739:       // No command specified — list all commands\n740:       console.log(JSON.stringify(allCommandSchemas(), null, 2));\n741:     } else {\n742:       // Describe a specific command. Handle compound names: \"features list\"\n743:       const cmdName = args.title\n744:         ? `${args.featureId} ${args.title}`\n745:         : args.featureId;\n746:       const def = findCommandDef(cmdName);\n747:       if (!def) {\n748:         outputError(args.outputFmt, `Unknown command: \"${cmdName}\". Run 'woco describe' to list all commands.`);\n749:         return;\n750:       }\n751:       console.log(JSON.stringify(commandToSchema(def), null, 2));\n752:     }\n753:     return;\n754:   }\n755: \n756:   if (args.command === \"init\") {\n757:     await cmdInit({ projectRoot: PROJECT_ROOT, force: args.force });\n758:     return;\n759:   }\n760: \n761:   if (args.command === \"upgrade\") {\n762:     await cmdUpgrade({\n763:       force: args.force,\n764:       tag: args.tag,\n765:       checkOnly: args.checkOnly,\n766:     });\n767:     return;\n768:   }\n769: \n770:   if (args.command === \"completion\") {\n771:     cmdCompletion({ shell: args.featureId }); // first positional = shell name\n772:     return;\n773:   }\n774: \n775:   if (args.command === \"logs\") {\n776:     if (!args.featureId) {\n777:       outputError(args.outputFmt, \"Usage: woco logs <feature-id> [--tail N] [--follow] [--output json]\");\n778:       return;\n779:     }\n780:     await cmdLogs({\n781:       projectRoot: PROJECT_ROOT,\n782:       featureId: args.featureId,\n783:       tail: args.tail,\n784:       follow: args.follow,\n785:       outputFmt: args.outputFmt,\n786:     });\n787:     return;\n788:   }\n789: \n790:   // Everything else requires config\n791:   const config = loadConfig(PROJECT_ROOT);\n792:   validateConfig(config);\n793: \n794:   // Commands that operate on the tasks file — ensure it exists first\n795:   const needsTasksFile = new Set([\"launch\", \"resume\", \"verify\", \"retry\", \"tasks\", \"tui\"]);\n796:   if (needsTasksFile.has(args.command)) {\n797:     await ensureTasksFile(PROJECT_ROOT, config);\n798:   }\n799: \n800:   switch (args.command) {\n801:     case \"launch\":\n802:       // Apply browser verification override if --browser flag was passed\n803:       if (args.browser !== undefined) {\n804:         config.browser.enabled = args.browser;\n805:       }\n806:       try {\n807:         await cmdLaunch({\n808:           projectRoot: PROJECT_ROOT,\n809:           config,\n810:           topPriority: args.topPriority,\n811:           quickestWins: args.quickestWins,\n812:           priority: args.priority,\n813:           difficulty: args.difficulty,\n814:           features: args.tasks,\n815:           allReady: args.allReady,\n816:           maxConcurrent: args.maxConcurrent ?? config.defaults.maxConcurrent,\n817:           model: args.model,\n818:           interactive: args.interactive,\n819:           dryRun: args.dryRun,\n820:           baseBranch: args.baseBranch ?? config.baseBranch,\n821:           maxRetries: args.maxRetries ?? config.defaults.maxRetries,\n822:           noTui: args.noTui,\n823:           autoPush: args.autoPush,\n824:           outputFmt: args.outputFmt,\n825:           agent: args.agent,\n826:           questId: args.questId,\n827:         });\n828:       } catch (err: any) {\n829:         outputError(args.outputFmt ?? \"text\", err.message);\n830:       }\n831:       break;\n832: \n833:     case \"resume\":\n834:       await cmdResume({\n835:         projectRoot: PROJECT_ROOT,\n836:         config,\n837:         maxConcurrent: args.maxConcurrent,\n838:         model: args.model,\n839:         interactive: args.interactive,\n840:         noTui: args.noTui,\n841:         autoPush: args.autoPush,\n842:         baseBranch: args.baseBranch,\n843:         maxRetries: args.maxRetries,\n844:         outputFmt: args.outputFmt,\n845:       });\n846:       break;\n847: \n848:     case \"status\":\n849:       await cmdStatus({ projectRoot: PROJECT_ROOT, config, outputFmt: args.outputFmt });\n850:       break;\n851: \n852:     case \"verify\":\n853:       await cmdVerify({\n854:         projectRoot: PROJECT_ROOT,\n855:         config,\n856:         featureId: args.featureId,\n857:         model: args.model,\n858:         maxRetries: args.maxRetries,\n859:         browserVerify: args.browser,\n860:         skipTests: args.skipTests,\n861:         strictTdd: args.strictTdd,\n862:         outputFmt: args.outputFmt,\n863:       });\n864:       break;\n865: \n866:     case \"merge\":\n867:       await cmdMerge({\n868:         projectRoot: PROJECT_ROOT,\n869:         config,\n870:         featureId: args.featureId,\n871:         autoPush: args.autoPush,\n872:         dryRun: args.dryRun,\n873:         model: args.model,\n874:         outputFmt: args.outputFmt,\n875:       });\n876:       break;\n877: \n878:     case \"retry\": {\n879:       if (!args.featureId) {\n880:         outputError(args.outputFmt, \"Usage: woco retry <feature-id>\");\n881:         return;\n882:       }\n883:       await cmdRetry({\n884:         projectRoot: PROJECT_ROOT,\n885:         config,\n886:         featureId: args.featureId,\n887:         model: args.model,\n888:         interactive: args.interactive,\n889:         dryRun: args.dryRun,\n890:         outputFmt: args.outputFmt,\n891:       });\n892:       break;\n893:     }\n894: \n895:     case \"cleanup\":\n896:       await cmdCleanup({ projectRoot: PROJECT_ROOT, config, dryRun: args.dryRun, outputFmt: args.outputFmt });\n897:       break;\n898: \n899:     case \"history\":\n900:       await cmdHistory({\n901:         projectRoot: PROJECT_ROOT,\n902:         config,\n903:         waveId: args.featureId,\n904:         outputFmt: args.outputFmt,\n905:       });\n906:       break;\n907: \n908:     case \"abort\": {\n909:       if (!args.featureId) {\n910:         outputError(args.outputFmt, \"Usage: woco abort <feature-id> [--requeue] [--output json]\");\n911:         return;\n912:       }\n913:       await cmdAbort({\n914:         projectRoot: PROJECT_ROOT,\n915:         config,\n916:         featureId: args.featureId,\n917:         requeue: args.requeue,\n918:         outputFmt: args.outputFmt,\n919:       });\n920:       break;\n921:     }\n922: \n923:     case \"tasks\":\n924:       await handleTasksSubcommand(args, PROJECT_ROOT, config);\n925:       break;\n926: \n927:     case \"quest\":\n928:       await handleQuestSubcommand({\n929:         projectRoot: PROJECT_ROOT,\n930:         config,\n931:         subcommand: args.subcommand ?? \"list\",\n932:         questId: args.featureId,\n933:         title: args.title,\n934:         goal: args.goal,\n935:         priority: args.priority,\n936:         difficulty: args.difficulty,\n937:         hitlMode: args.hitlMode,\n938:         status: args.status,\n939:         agent: args.agent,\n940:         dryRun: args.dryRun,\n941:         force: args.force,\n942:         outputFmt: args.outputFmt,\n943:         fields: args.fields,\n944:       });\n945:       break;\n946: \n947:     case \"genesis\":\n948:       await cmdGenesis({\n949:         projectRoot: PROJECT_ROOT,\n950:         config,\n951:         vision: args.featureId,  // first positional arg is the vision text\n952:         techStack: args.techStack,\n953:         constraints: args.genesisConstraints,\n954:         model: args.model,\n955:         dryRun: args.dryRun,\n956:         noTui: args.noTui,\n957:         outputFmt: args.outputFmt,\n958:       });\n959:       break;\n960: \n961:     case \"wishlist\":\n962:       handleWishlistSubcommand(args, PROJECT_ROOT, config);\n963:       break;\n964: \n965:     case \"tui\":\n966:       await cmdTui({\n967:         projectRoot: PROJECT_ROOT,\n968:         config,\n969:         maxConcurrent: args.maxConcurrent,\n970:         model: args.model,\n971:         baseBranch: args.baseBranch,\n972:         maxRetries: args.maxRetries,\n973:         autoPush: args.autoPush,\n974:         skipTests: args.skipTests,\n975:         strictTdd: args.strictTdd,\n976:         agent: args.agent,\n977:       });\n978:       break;\n979: \n980:     default:\n981:       if (args.outputFmt !== \"text\") {\n982:         outputError(args.outputFmt, `Unknown command: ${args.command}`);\n983:       }\n984:       console.error(`Unknown command: ${args.command}`);\n985:       cmdHelp();\n986:       process.exit(1);\n987:       return;\n988:   }\n989: }\n990: \n991: // ---------------------------------------------------------------------------\n992: // Tasks Subcommand Router\n993: // ---------------------------------------------------------------------------\n994: \n995: async function handleTasksSubcommand(\n996:   args: CLIArgs,\n997:   projectRoot: string,\n998:   config: import(\"./config.js\").WomboConfig\n999: ): Promise<void> {\n1000:   switch (args.subcommand) {\n1001:     case \"list\":\n1002:       await cmdTasksList({\n1003:         projectRoot,\n1004:         config,\n1005:         status: args.status as FeatureStatus | undefined,\n1006:         priority: args.priority,\n1007:         difficulty: args.difficulty,\n1008:         ready: args.ready,\n1009:         includeArchive: args.includeArchive,\n1010:         outputFmt: args.outputFmt,\n1011:         fields: args.fields,\n1012:       });\n1013:       break;\n1014: \n1015:     case \"add\": {\n1016:       if (!args.featureId || !args.title) {\n1017:         outputError(args.outputFmt, \"Usage: woco tasks add <id> <title> [--desc <desc>] [--priority <p>] [--difficulty <d>] [--effort <e>] [--depends-on <ids>]\");\n1018:         return;\n1019:       }\n1020:       await cmdTasksAdd({\n1021:         projectRoot,\n1022:         config,\n1023:         id: args.featureId,\n1024:         title: args.title,\n1025:         description: args.description,\n1026:         priority: args.priority,\n1027:         difficulty: args.difficulty,\n1028:         effort: args.effort,\n1029:         dependsOn: args.dependsOn,\n1030:         outputFmt: args.outputFmt,\n1031:         dryRun: args.dryRun,\n1032:       });\n1033:       break;\n1034:     }\n1035: \n1036:     case \"set-status\": {\n1037:       // The new status can come from the second positional (stored in args.title)\n1038:       // or from the --status flag\n1039:       const newStatus = args.title || args.status;\n1040:       if (!args.featureId || !newStatus) {\n1041:         outputError(args.outputFmt, \"Usage: woco tasks set-status <task-id> <status>\");\n1042:         return;\n1043:       }\n1044:       await cmdTasksSetStatus({\n1045:         projectRoot,\n1046:         config,\n1047:         featureId: args.featureId,\n1048:         newStatus,\n1049:         outputFmt: args.outputFmt,\n1050:         dryRun: args.dryRun,\n1051:       });\n1052:       break;\n1053:     }\n1054: \n1055:     case \"set-priority\": {\n1056:       // The new priority can come from the second positional (stored in args.title)\n1057:       // or from the --priority flag\n1058:       const newPriority = args.title || (args.priority as string | undefined);\n1059:       if (!args.featureId || !newPriority) {\n1060:         outputError(args.outputFmt, \"Usage: woco tasks set-priority <task-id> <priority>\");\n1061:         return;\n1062:       }\n1063:       await cmdTasksSetPriority({\n1064:         projectRoot,\n1065:         config,\n1066:         featureId: args.featureId,\n1067:         newPriority,\n1068:         outputFmt: args.outputFmt,\n1069:         dryRun: args.dryRun,\n1070:       });\n1071:       break;\n1072:     }\n1073: \n1074:     case \"set-difficulty\": {\n1075:       // The new difficulty can come from the second positional (stored in args.title)\n1076:       // or from the --difficulty flag\n1077:       const newDifficulty = args.title || (args.difficulty as string | undefined);\n1078:       if (!args.featureId || !newDifficulty) {\n1079:         outputError(args.outputFmt, \"Usage: woco tasks set-difficulty <task-id> <difficulty>\");\n1080:         return;\n1081:       }\n1082:       await cmdTasksSetDifficulty({\n1083:         projectRoot,\n1084:         config,\n1085:         featureId: args.featureId,\n1086:         newDifficulty,\n1087:         outputFmt: args.outputFmt,\n1088:         dryRun: args.dryRun,\n1089:       });\n1090:       break;\n1091:     }\n1092: \n1093:     case \"check\":\n1094:       await cmdTasksCheck({ projectRoot, config, outputFmt: args.outputFmt });\n1095:       break;\n1096: \n1097:     case \"archive\":\n1098:       await cmdTasksArchive({\n1099:         projectRoot,\n1100:         config,\n1101:         featureId: args.featureId,\n1102:         dryRun: args.dryRun,\n1103:         outputFmt: args.outputFmt,\n1104:       });\n1105:       break;\n1106: \n1107:     case \"show\": {\n1108:       if (!args.featureId) {\n1109:         outputError(args.outputFmt, \"Usage: woco tasks show <task-id>\");\n1110:         return;\n1111:       }\n1112:       await cmdTasksShow({\n1113:         projectRoot,\n1114:         config,\n1115:         featureId: args.featureId,\n1116:         outputFmt: args.outputFmt,\n1117:         fields: args.fields,\n1118:       });\n1119:       break;\n1120:     }\n1121: \n1122:     case \"graph\":\n1123:       await cmdTasksGraph({\n1124:         projectRoot,\n1125:         config,\n1126:         status: args.status as FeatureStatus | undefined,\n1127:         ascii: args.ascii,\n1128:         mermaid: args.mermaidRaw,\n1129:         subtasks: args.graphSubtasks,\n1130:         outputFmt: args.outputFmt,\n1131:       });\n1132:       break;\n1133: \n1134:     case \"help\":\n1135:     case \"--help\":\n1136:     case \"-h\":\n1137:       cmdHelp();\n1138:       break;\n1139: \n1140:     default:\n1141:       outputError(args.outputFmt, `Unknown tasks subcommand: ${args.subcommand}. Run 'woco tasks help' or 'woco help' for usage.`);\n1142:       return;\n1143:   }\n1144: }\n1145: \n1146: // ---------------------------------------------------------------------------\n1147: // Error Handlers & Entry\n1148: // ---------------------------------------------------------------------------\n1149: \n1150: // Global error handlers — prevent silent crashes\n1151: process.on(\"uncaughtException\", (err) => {\n1152:   console.error(`\\n[FATAL] Uncaught exception: ${err.message}`);\n1153:   console.error(err.stack);\n1154:   try {\n1155:     const state = loadState(process.cwd());\n1156:     if (state) saveState(process.cwd(), state);\n1157:   } catch {}\n1158:   process.exit(1);\n1159: });\n1160: \n1161: process.on(\"unhandledRejection\", (reason: any) => {\n1162:   console.error(`\\n[FATAL] Unhandled rejection: ${reason?.message || reason}`);\n1163:   if (reason?.stack) console.error(reason.stack);\n1164:   try {\n1165:     const state = loadState(process.cwd());\n1166:     if (state) saveState(process.cwd(), state);\n1167:   } catch {}\n1168:   process.exit(1);\n1169: });\n1170: \n1171: main().catch((err) => {\n1172:   console.error(\"Fatal error:\", err.message);\n1173:   process.exit(1);\n1174: });\n\n(End of file - total 1174 lines)\n</content>","title":"src/index.ts","metadata":{"preview":"#!/usr/bin/env bun\n/**\n * index.ts — CLI entry point for the wombo-combo agent orchestration system.\n *\n * Every command has a short alias (e.g., woco i = woco init, woco t ls = woco tasks list).\n *\n * Usage:\n *   woco init                                         (alias: i)\n *   woco launch --top-priority 3                      (alias: l)\n *   woco launch --quickest-wins 5\n *   woco launch --priority high\n *   woco launch --difficulty easy\n *   woco launch --tasks \"feat-a,feat-b\"\n *   woco launch --all-ready\n *   woco launch ... --max-concurrent 3 --model \"anthropic/claude-sonnet-4-20250514\"\n *   woco launch ... --interactive\n *   woco resume                                       (alias: r)\n *   woco status                                       (alias: s)\n *   woco verify [feature-id]                          (alias: v)\n *   woco merge [feature-id]                           (alias: m)","truncated":false,"loaded":[]},"time":{"start":1773483681713,"end":1773483681716}}}}
