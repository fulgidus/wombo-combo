=> void;\n65:   /** If set, filter to only tasks belonging to this quest */\n66:   questId?: string | null;\n67:   /** Human-readable quest title for header display */\n68:   questTitle?: string;\n69:   /** Task IDs belonging to the selected quest (used for filtering) */\n70:   questTaskIds?: string[];\n71: }\n72: \n73: /**\n74:  * A task node in the display tree with computed metadata.\n75:  */\n76: interface TaskNode {\n77:   task: Task;\n78:   /** Depth in the dependency chain (0 = leaf/no deps, higher = depends on more) */\n79:   depth: number;\n80:   /** ID of the stream (connected component) this task belongs to */\n81:   streamId: string;\n82:   /** Task IDs that depend on this task */\n83:   dependedOnBy: string[];\n84: }\n85: \n86: /**\n87:  * A stream is a group of related tasks connected by dependencies.\n88:  */\n89: interface Stream {\n90:   id: string;\n91:   nodes: TaskNode[];\n92: }\n93: \n94: // ---------------------------------------------------------------------------\n95: // Status / Priority display helpers\n96: // ---------------------------------------------------------------------------\n97: \n98: const STATUS_ABBREV: Record<string, string> = {\n99:   backlog: \"BACK\",\n100:   planned: \"PLAN\",\n\n(Showing lines 1-100 of 1048. Use offset=101 to continue.)\n</content>","title":"src/lib/tui-browser.ts","metadata":{"preview":"/**\n * tui-browser.ts — Task browser view for the wombo-combo TUI.\n *\n * Shows all tasks organized by dependency streams with checkboxes for\n * selection. Users can evaluate tasks, order them, select/deselect\n * entire streams, and launch a wave with the selected tasks.\n *\n * Layout:\n *   ┌───────────────────────────────────────────────────────┐\n *   │ WOMBO-COMBO Task Browser  │ 42 tasks │ 5 selected    │\n *   ├──────────────────────────────┬────────────────────────┤\n *   │ ☑ json-features-check  done │ Title: ...             │\n *   │ ☑ json-features-arch   done │ Status: backlog        │\n *   │   ☐ json-ops