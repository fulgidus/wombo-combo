{"type":"tool_use","timestamp":1773483467707,"sessionID":"ses_314277f9bffeVWfnq7bm5y0Dtk","part":{"id":"prt_cebda1e43001NDPEUlnn5aQtr5","sessionID":"ses_314277f9bffeVWfnq7bm5y0Dtk","messageID":"msg_cebda0721001kEXhmkjBnBvZCe","type":"tool","callID":"toolu_vrtx_017aStDua72kQTDMY1B6Rmdj","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/tui-wishlist/src/lib/tui-wishlist.ts","limit":200,"offset":200},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/tui-wishlist/src/lib/tui-wishlist.ts</path>\n<type>file</type>\n<content>200:   // -----------------------------------------------------------------------\n201:   // Public API\n202:   // -----------------------------------------------------------------------\n203: \n204:   start(): void {\n205:     this.refreshAll();\n206:     this.screen.render();\n207:   }\n208: \n209:   stop(): void {\n210:     this.screen.destroy();\n211:   }\n212: \n213:   destroy(): void {\n214:     this.screen.destroy();\n215:     process.stdout.write(\"\\x1B[2J\\x1B[H\");\n216:   }\n217: \n218:   // -----------------------------------------------------------------------\n219:   // Data Loading\n220:   // -----------------------------------------------------------------------\n221: \n222:   private loadItems(): void {\n223:     this.items = loadWishlist(this.projectRoot);\n224:   }\n225: \n226:   // -----------------------------------------------------------------------\n227:   // Key Bindings\n228:   // -----------------------------------------------------------------------\n229: \n230:   private bindKeys(): void {\n231:     // Quit\n232:     this.screen.key([\"q\", \"C-c\"], () => {\n233:       this.stop();\n234:       this.onQuit();\n235:     });\n236: \n237:     // Escape -- go back\n238:     this.screen.key([\"escape\"], () => {\n239:       this.destroy();\n240:       this.onBack();\n241:     });\n242: \n243:     // Navigate\n244:     this.itemList.on(\"select item\", (_item: any, index: number) => {\n245:       this.selectedIndex = index;\n246:       this.refreshDetail();\n247:       this.screen.render();\n248:     });\n249: \n250:     // E -- promote to errand\n251:     this.screen.key([\"e\"], () => {\n252:       this.promoteToErrand();\n253:     });\n254: \n255:     // G -- promote to genesis\n256:     this.screen.key([\"g\"], () => {\n257:       this.promoteToGenesis();\n258:     });\n259: \n260:     // D / Delete -- delete item\n261:     this.screen.key([\"d\", \"delete\"], () => {\n262:       this.deleteSelected();\n263:     });\n264:   }\n265: \n266:   // -----------------------------------------------------------------------\n267:   // Actions\n268:   // -----------------------------------------------------------------------\n269: \n270:   private promoteToErrand(): void {\n271:     const item = this.items[this.selectedIndex];\n272:     if (!item) return;\n273: \n274:     this.destroy();\n275:     this.onPromoteErrand(item);\n276:   }\n277: \n278:   private promoteToGenesis(): void {\n279:     const item = this.items[this.selectedIndex];\n280:     if (!item) return;\n281: \n282:     this.destroy();\n283:     this.onPromoteGenesis(item);\n284:   }\n285: \n286:   private deleteSelected(): void {\n287:     const item = this.items[this.selectedIndex];\n288:     if (!item) return;\n289: \n290:     deleteItem(this.projectRoot, item.id);\n291:     this.loadItems();\n292:     this.selectedIndex = Math.min(\n293:       this.selectedIndex,\n294:       Math.max(0, this.items.length - 1)\n295:     );\n296:     this.refreshAll();\n297:     this.screen.render();\n298:   }\n299: \n300:   // -----------------------------------------------------------------------\n301:   // Refresh Logic\n302:   // -----------------------------------------------------------------------\n303: \n304:   private refreshAll(): void {\n305:     this.refreshHeader();\n306:     this.refreshList();\n307:     this.refreshDetail();\n308:     this.refreshStatusBar();\n309:   }\n310: \n311:   private refreshHeader(): void {\n312:     const count = this.items.length;\n313:     let line1 = ` {bold}wombo-combo{/bold} {yellow-fg}Wishlist{/yellow-fg}`;\n314:     line1 += `  {gray-fg}|{/gray-fg}  {white-fg}${count}{/white-fg} item${count !== 1 ? \"s\" : \"\"}`;\n315: \n316:     let line2 = ` {gray-fg}Promote items to errands or genesis quests{/gray-fg}`;\n317: \n318:     this.headerBox.setContent(`${line1}\\n${line2}`);\n319:   }\n320: \n321:   private refreshList(): void {\n322:     const listItems: string[] = [];\n323: \n324:     for (const item of this.items) {\n325:       // Truncate text for list display\n326:       const maxLen = 40;\n327:       const text = item.text.length > maxLen\n328:         ? item.text.slice(0, maxLen - 1) + \"\\u2026\"\n329:         : item.text;\n330: \n331:       // Tags badge\n332:       const tagsBadge = item.tags.length > 0\n333:         ? ` {gray-fg}[${item.tags.join(\", \")}]{/gray-fg}`\n334:         : \"\";\n335: \n336:       // Date\n337:       const created = item.created_at.slice(0, 10);\n338: \n339:       listItems.push(\n340:         ` {yellow-fg}\\u2022{/yellow-fg} ${escapeBlessedTags(text)}${tagsBadge} {gray-fg}${created}{/gray-fg}`\n341:       );\n342:     }\n343: \n344:     if (listItems.length === 0) {\n345:       listItems.push(\" {gray-fg}No wishlist items{/gray-fg}\");\n346:     }\n347: \n348:     const prevSelected = this.selectedIndex;\n349:     this.itemList.setItems(listItems as any);\n350:     if (prevSelected < listItems.length) {\n351:       this.itemList.select(prevSelected);\n352:     }\n353:   }\n354: \n355:   private refreshDetail(): void {\n356:     const item = this.items[this.selectedIndex];\n357:     if (!item) {\n358:       this.detailBox.setContent(\"{gray-fg}No item selected{/gray-fg}\");\n359:       this.detailBox.setLabel(\" Details \");\n360:       return;\n361:     }\n362: \n363:     const lines: string[] = [];\n364: \n365:     // Full text\n366:     lines.push(\"{bold}{white-fg}Description:{/white-fg}{/bold}\");\n367:     // Word-wrap the text to roughly 42 chars\n368:     const text = escapeBlessedTags(item.text.trim());\n369:     const words = text.split(/\\s+/);\n370:     let line = \" \";\n371:     for (const w of words) {\n372:       if (line.length + w.length > 42) {\n373:         lines.push(line);\n374:         line = \" \" + w;\n375:       } else {\n376:         line += \" \" + w;\n377:       }\n378:     }\n379:     if (line.trim()) lines.push(line);\n380:     lines.push(\"\");\n381: \n382:     // Tags\n383:     if (item.tags.length > 0) {\n384:       lines.push(\"{bold}Tags:{/bold}\");\n385:       lines.push(`  ${item.tags.map((t) => `{cyan-fg}${escapeBlessedTags(t)}{/cyan-fg}`).join(\"  \")}`);\n386:       lines.push(\"\");\n387:     }\n388: \n389:     // Created date\n390:     lines.push(\"{bold}Created:{/bold}\");\n391:     lines.push(`  ${item.created_at.slice(0, 10)} ${item.created_at.slice(11, 19)}`);\n392:     lines.push(\"\");\n393: \n394:     // ID\n395:     lines.push(\"{bold}ID:{/bold}\");\n396:     lines.push(`  {gray-fg}${item.id}{/gray-fg}`);\n397:     lines.push(\"\");\n398: \n399:     // Promotion hints\n\n(Showing lines 200-399 of 724. Use offset=400 to continue.)\n</content>","title":"src/lib/tui-wishlist.ts","metadata":{"preview":"  // -----------------------------------------------------------------------\n  // Public API\n  // -----------------------------------------------------------------------\n\n  start(): void {\n    this.refreshAll();\n    this.screen.render();\n  }\n\n  stop(): void {\n    this.screen.destroy();\n  }\n\n  destroy(): void {\n    this.screen.destroy();\n    process.stdout.write(\"\\x1B[2J\\x1B[H\");\n  }\n\n  // -----------------------------------------------------------------------\n  // Data Loading","truncated":true,"loaded":[]},"time":{"start":1773483467702,"end":1773483467706}}}}
