on                                Print version and exit\n486:   help                                   Show this help\n487: \n488: Tasks Subcommands:               (alias)\n489:   tasks list                     (ls)    List tasks (--status, --priority, --difficulty, --ready, --include-archive)\n490:   tasks add <id> <title>         (a)     Add a new task (--desc, --priority, --difficulty, --effort, --depends-on)\n491:   tasks set-status <id> <s>      (ss)    Change a task's status\n492:   tasks set-priority <id> <p>    (sp)    Change a task's priority (critical/high/medium/low/wishlist)\n493:   tasks set-difficulty <id> <d>  (sd)    Change a task's difficulty (trivial/easy/medium/hard/very_hard)\n494:   tasks check                    (ch)    Validate tasks file (schema, deps, duplicates, cycles)\n495:   tasks archive [id]             (ar)    Move done/cancelled to archive (--dry-run)\n496:   tasks show <id>                (sh)    Show task details\n497:   tasks graph                    (g)     Visualize dependency graph (--ascii, --mermaid, --subtasks)\n498: \n499: Quest Subcommands:               (alias)\n500:   quest create <id> \"Title\"      (c)     Create a new quest (--goal, --priority, --difficulty, --hitl)\n501:   quest list                     (ls)    List all quests (--status to filter)\n502:   quest show <id>                (sh)    Show quest details\n503:   quest activate <id>            (a)     Activate a quest (creates branch, sets status to active)\n504:   quest pause <id>               (p)     Pause an active/planning quest\n505:   quest complete <id>            (co)    Complete quest (merges branch into base; --force to skip merge)\n506:   quest abandon <id>              (ab)    Abandon quest without merging (--force to delete branch)\n507: \n508: Genesis Options:\n509:   --tech-stack <text>      Describe the tech stack (e.g., \"React, Node, Postgres\")\n510:   --constraint <text>      Add a constraint (can be repeated: --constraint \"...\" --constraint \"...\")\n511:   --model <model>          Model override for the genesis planner agent\n512:   --no-tui                 Skip interactive review, auto-approve all quests\n513:   --dry-run                Show proposed quests without creating them\n514: \n515: Selection Options (for launch):\n516:   --top-priority N         Select top N tasks by priority\n517:   --quickest-wins N        Select N tasks with lowest effort\n518:   --priority <level>       Filter by priority (critical/high/medium/low/wishlist)\n519:   --difficulty <level>     Filter by difficulty (trivial/easy/medium/hard/very_hard)\n520:   --tasks \"id1,id2\"        Select specific tasks by ID (--features also accepted)\n521:   --all-ready              Select all tasks whose dependencies are met\n522: \n523: Launch Options:\n524:   --max-concurrent N       Max agents running in parallel (default: from config)\n525:   --model <model>          Model to use (e.g., \"anthropic/claude-sonnet-4-20250514\")\n526:   --interactive            Use multiplexer (dmux/tmux) TUI mode instead of headless\n527:   --no-tui                 Headless mode without neo-blessed TUI (periodic console dashboard)\n528:   --auto-push              Push base branch to remote after all merges complete\n529:   --dry-run                Show what would be launched without launching\n530:   --base-branch <branch>   Base branch (default: from config)\n531:   --max-retries N          Max retries per agent (default: from config)\n532:   --browser                Enable browser-based verification (run after build passes)\n533:   --skip-tests             Skip running tests during TDD verification\n534:   --strict-tdd             Strict TDD: fail verification if new files are missing tests\n535:   --agent <name>           Override agent definition for all launched tasks (name without .md extension)\n536:   --quest <id>             Scope launch to a quest (uses quest branch as base, applies quest constraints)\n537: \n538: General:\n539:   --force                  Force overwrite (e.g., for init) / skip prompts (e.g., for upgrade)\n540:   --output <fmt>           Output format: text (default on TTY), json (default when piped), or toon (WOMBO_OUTPUT=toon)\n541:   -o <fmt>                 Alias for --output\n542:   --dry-run                Show what would happen without performing the action\n543:   --fields <list>          Comma-separated fields to include (e.g., id,status,priority)\n544: \n545: Upgrade Options:\n546:   --check                  Only check for updates, don't install\n547:   --tag <tag>              Install a specific version (e.g., v0.1.0)\n548: \n549: Logs Options:\n550:   --tail N                 Show only the last N lines\n551:   --follow, -f             Stream new output as it arrives (like tail -f)\n552: \n553: Aliases (every command has a short form):\n554:   woco i                         woco init\n555:   woco l --all-ready             woco launch --all-ready\n556:   woco t ls                      woco tasks list\n557:   woco t a my-task \"Title\"       woco tasks add my-task \"Title\"\n558:   woco t ss my-task done         woco tasks set-status my-task done\n559:   woco q c my-quest \"Quest\"      woco quest create my-quest \"Quest\" --goal \"...\"\n560:   woco q ls                      woco quest list\n561:   woco q sh my-quest             woco quest show my-quest\n562: \n563: Shell Completion:\n564:   eval \"$(woco completion bash)\"    # Bash: add to ~/.bashrc\n565:   eval \"$(woco completion zsh)\"     # Zsh:  add to ~/.zshrc\n566:   woco completion fish | source     # Fish (or save to ~/.config/fish/completions/woco.fish)\n567: \n568: Examples:\n569:   woco init\n\n(Showing lines 470-569 of 1145. Use offset=570 to continue.)\n</content>","title":"src/index.ts","metadata":{"preview":"  status                         (s)     Show the status of the current wave\n  verify                         (v)     Run build verification on completed agents\n  merge                          (m)     Merge verified branches into the base branch\n  retry                          (re)    Retry a failed agent\n  abort                          (a)     Kill a single running agent (--requeue to return to queue)\n  logs                           (lo)    Pretty-print agent logs for a feature\n  cleanup                        (c)     Remove all wave worktrees and multiplexer sessions\n  history                        (h)     List/view past wave results (stored in .wombo-combo/history/)\n  tasks                          (t)     Manage tasks file (see below; 'features' also accepted)\n  quest                          (q)     Manage quests (scoped missions; see below)\n  genesis                        (g)     Run genesis planner (project-level decomposition into quests)\n  tui                                    Interactive TUI: browse tasks, select, launch, monitor\n  upgrade                        (u)     Check for updates and upgrade wombo-combo\n  describe                       (d)     Emit JSON schema or TOON legend (--output toon)\n  completion                     (comp)  Generate shell completions (bash, zsh, fish)\n  version                                Print version and exit\n  help                                   Show this help\n\nTasks Subcommands:               (alias)\n  tasks list                     (ls)    List tasks (--status, --priority, --difficulty, --ready, --include-archive)","truncated":true,"loaded":[]},"time":{"start":1773483554837,"end":1773483554840}}}}
{"type":"tool_use","timestamp":1773483555403,"sessionID":"ses_314277f9bffeVWfnq7bm5y0Dtk","part":{"id":"prt_cebdb78150019MVE5OYghNFxSL","sessionID":"ses_314277f9bffeVWfnq7bm5y0Dtk","messageID":"msg_cebdb6947001Ec6aYoBx2LY8qG","type":"tool","callID":"toolu_vrtx_017bkfhZPzAW6rFqLsyoYMDW","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/tui-wishlist/src/index.ts","limit":200,"offset":570},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/tui-wishlist/src/index.ts</path>\n<type>file</type>\n<content>570:   woco launch --quickest-wins 3\n571:   woco launch --priority high --interactive\n572:   woco launch --tasks \"auth-flow,search-api\" --max-concurrent 2\n573:   woco resume\n574:   woco status\n575:   woco verify\n576:   woco merge\n577:   woco retry auth-flow\n578:   woco abort auth-flow\n579:   woco abort auth-flow --requeue\n580:   woco abort auth-flow --output json\n581:   woco logs auth-flow\n582:   woco logs auth-flow --tail 50\n583:   woco logs auth-flow --follow\n584:   woco logs auth-flow --output json\n585:   woco cleanup\n586:   woco tasks list --status ready --priority high\n587:   woco tasks list --fields id,status,priority --output json\n588:   woco tasks add my-task \"My Cool Task\" --priority high --difficulty easy\n589:   woco tasks set-status my-task in-progress\n590:   woco tasks check\n591:   woco tasks archive --dry-run\n592:   woco tasks show my-task\n593:   woco history\n594:   woco history wave-2026-03-12-420\n595:   woco history --output json\n596:   woco describe                           # list all commands as JSON\n597:   woco describe launch                    # describe a specific command\n598:   woco describe tasks add                 # describe a subcommand\n599:   woco describe --output toon             # emit TOON format legend/spec\n600:   woco quest create auth \"Auth Overhaul\" --goal \"Replace basic auth with OAuth2\" --priority high\n601:   woco quest list\n602:   woco quest activate auth\n603:   woco quest complete auth\n604:   woco genesis \"Build a SaaS dashboard with auth, billing, and analytics\"\n605:   woco genesis \"Modernize the frontend\" --tech-stack \"React, TypeScript, Tailwind\"\n606:   woco g \"Add multi-tenant support\" --constraint \"No breaking changes\" --constraint \"Keep backward compat\"\n607:   woco genesis \"...\" --dry-run\n608: `);\n609: }\n610: \n611: // ---------------------------------------------------------------------------\n612: // Main\n613: // ---------------------------------------------------------------------------\n614: \n615: async function main(): Promise<void> {\n616:   checkDevModeGuard();\n617: \n618:   const PROJECT_ROOT = resolve(process.cwd());\n619:   const args = parseArgs(process.argv);\n620: \n621:   // -----------------------------------------------------------------------\n622:   // Input validation at the CLI boundary\n623:   // -----------------------------------------------------------------------\n624:   if (args.featureId) {\n625:     assertValid(validateId(args.featureId, \"feature ID\"));\n626:   }\n627:   if (args.title) {\n628:     assertValid(validateText(args.title, \"title\"));\n629:   }\n630:   if (args.description) {\n631:     assertValid(validateText(args.description, \"description\"));\n632:   }\n633:   if (args.baseBranch) {\n634:     assertValid(validateBranchName(args.baseBranch, \"base branch\"));\n635:   }\n636:   if (args.effort) {\n637:     assertValid(validateDuration(args.effort, \"effort\"));\n638:   }\n639:   if (args.tasks) {\n640:     for (const fid of args.tasks) {\n641:       assertValid(validateId(fid, \"task ID in --tasks\"));\n642:     }\n643:   }\n644:   if (args.dependsOn) {\n645:     for (const dep of args.dependsOn) {\n646:       assertValid(validateId(dep, \"dependency ID in --depends-on\"));\n647:     }\n648:   }\n649: \n650:   // Validate numeric args are not NaN\n651:   const numericArgs: [string, number | undefined][] = [\n652:     [\"--top-priority\", args.topPriority],\n653:     [\"--quickest-wins\", args.quickestWins],\n654:     [\"--max-concurrent\", args.maxConcurrent],\n655:     [\"--max-retries\", args.maxRetries],\n656:     [\"--tail\", args.tail],\n657:   ];\n658:   for (const [flag, value] of numericArgs) {\n659:     if (value !== undefined && isNaN(value)) {\n660:       outputError(args.outputFmt, `${flag} requires a numeric value.`);\n661:     }\n662:   }\n663: \n664:   // Commands that don't need config loading\n665:   if (args.command === \"version\" || args.command === \"-v\" || args.command === \"-V\") {\n666:     const pkgPath = resolve(import.meta.dir, \"..\", \"package.json\");\n667:     const pkgFile = Bun.file(pkgPath);\n668:     try {\n669:       const pkg = await pkgFile.json();\n670:       console.log(`wombo-combo ${pkg.version ?? \"(unknown version)\"}`);\n671:     } catch {\n672:       console.log(\"wombo-combo (unknown version)\");\n673:     }\n674:     return;\n675:   }\n676: \n677:   if (args.command === \"help\" || args.command === \"--help\" || args.command === \"-h\") {\n678:     cmdHelp();\n679:     return;\n680:   }\n681: \n682:   if (args.command === \"describe\") {\n683:     // Schema introspection: `woco describe [command]`\n684:     if (args.outputFmt === \"toon\") {\n685:       // Emit TOON format legend — self-describing, cacheable by agents\n686:       const pkgPath = resolve(import.meta.dir, \"..\", \"package.json\");\n687:       let version = \"unknown\";\n688:       try {\n689:         const pkg = await Bun.file(pkgPath).json();\n690:         version = pkg.version ?? \"unknown\";\n691:       } catch {}\n692: \n693:       if (!args.featureId) {\n694:         // Full TOON spec (legend + all commands)\n695:         console.log(renderToonLegend(version));\n696:       } else {\n697:         // JSON structure for the full spec (--output toon with a specific command\n698:         // still emits JSON since TOON is a line-oriented data format, not a schema format)\n699:         const spec = buildToonSpec(version);\n700:         const cmdName = args.title\n701:           ? `${args.featureId} ${args.title}`\n702:           : args.featureId;\n703:         const cmdSpec = spec.commands.find((c) => c.command === cmdName);\n704:         if (!cmdSpec) {\n705:           outputError(args.outputFmt, `Unknown command: \"${cmdName}\". Run 'woco describe --output toon' to see the full TOON spec.`);\n706:           return;\n707:         }\n708:         console.log(JSON.stringify(cmdSpec, null, 2));\n709:       }\n710:       return;\n711:     }\n712: \n713:     if (!args.featureId) {\n714:       // No command specified — list all commands\n715:       console.log(JSON.stringify(allCommandSchemas(), null, 2));\n716:     } else {\n717:       // Describe a specific command. Handle compound names: \"features list\"\n718:       const cmdName = args.title\n719:         ? `${args.featureId} ${args.title}`\n720:         : args.featureId;\n721:       const def = findCommandDef(cmdName);\n722:       if (!def) {\n723:         outputError(args.outputFmt, `Unknown command: \"${cmdName}\". Run 'woco describe' to list all commands.`);\n724:         return;\n725:       }\n726:       console.log(JSON.stringify(commandToSchema(def), null, 2));\n727:     }\n728:     return;\n729:   }\n730: \n731:   if (args.command === \"init\") {\n732:     await cmdInit({ projectRoot: PROJECT_ROOT, force: args.force });\n733:     return;\n734:   }\n735: \n736:   if (args.command === \"upgrade\") {\n737:     await cmdUpgrade({\n738:       force: args.force,\n739:       tag: args.tag,\n740:       checkOnly: args.checkOnly,\n741:     });\n742:     return;\n743:   }\n744: \n745:   if (args.command === \"completion\") {\n746:     cmdCompletion({ shell: args.featureId }); // first positional = shell name\n747:     return;\n748:   }\n749: \n750:   if (args.command === \"logs\") {\n751:     if (!args.featureId) {\n752:       outputError(args.outputFmt, \"Usage: woco logs <feature-id> [--tail N] [--follow] [--output json]\");\n753:       return;\n754:     }\n755:     await cmdLogs({\n756:       projectRoot: PROJECT_ROOT,\n757:       featureId: args.featureId,\n758:       tail: args.tail,\n759:       follow: args.follow,\n760:       outputFmt: args.outputFmt,\n761:     });\n762:     return;\n763:   }\n764: \n765:   // Everything else requires config\n766:   const config = loadConfig(PROJECT_ROOT);\n767:   validateConfig(config);\n768: \n769:   // Commands that operate on the tasks file — ensure it exists first\n\n(Showing lines 570-769 of 1145. Use offset=770 to continue.)\n</content>","title":"src/index.ts","metadata":{"preview":"  woco launch --quickest-wins 3\n  woco launch --priority high --interactive\n  woco launch --tasks \"auth-flow,search-api\" --max-concurrent 2\n  woco resume\n  woco status\n  woco verify\n  woco merge\n  woco retry auth-flow\n  woco abort auth-flow\n  woco abort auth-flow --requeue\n  woco abort auth-flow --output json\n  woco logs auth-flow\n  woco logs auth-flow --tail 50\n  woco logs auth-flow --follow\n  woco logs auth-flow --output json\n  woco cleanup\n  woco tasks list --status ready --priority high\n  woco tasks list --fields id,status,priority --output json\n  woco tasks add my-task \"My Cool Task\" --priority high --difficulty easy\n  woco tasks set-status my-task in-progress","truncated":true,"loaded":[]},"time":{"start":1773483555399,"end":1773483555402}}}}
