{"type":"tool_use","timestamp":1773483688781,"sessionID":"ses_314277f9bffeVWfnq7bm5y0Dtk","part":{"id":"prt_cebdd828b001TDVIt7oGSDDZ6M","sessionID":"ses_314277f9bffeVWfnq7bm5y0Dtk","messageID":"msg_cebdd7a3a0019XQAkcnxvmyNDo","type":"tool","callID":"toolu_vrtx_01VgTxmRuFeedoAPXstZSN4x","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/tui-wishlist/src/lib/output.ts","offset":50},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/tui-wishlist/src/lib/output.ts</path>\n<type>file</type>\n<content>50: /**\n51:  * Emit structured data.\n52:  *   - JSON mode: outputs a single JSON line to stdout\n53:  *   - TOON mode: calls toonRenderer if provided, otherwise uses generic TOON formatter\n54:  *   - Text mode: calls textRenderer\n55:  */\n56: export function output(\n57:   format: OutputFormat,\n58:   data: unknown,\n59:   textRenderer: () => void,\n60:   toonRenderer?: () => void\n61: ): void {\n62:   if (format === \"json\") {\n63:     console.log(JSON.stringify(data));\n64:   } else if (format === \"toon\") {\n65:     if (toonRenderer) {\n66:       toonRenderer();\n67:     } else {\n68:       // Generic fallback: convert structured data to TOON\n69:       console.log(renderGeneric(data));\n70:     }\n71:   } else {\n72:     textRenderer();\n73:   }\n74: }\n75: \n76: /**\n77:  * Emit an error. In JSON mode, outputs {\"error\": message} to stderr.\n78:  * In TOON mode, outputs \"#ERROR message\" to stderr.\n79:  * In text mode, outputs the message to stderr normally.\n80:  */\n81: export function outputError(format: OutputFormat, message: string, exitCode: number = 1): never {\n82:   if (format === \"json\") {\n83:     console.error(JSON.stringify({ error: message }));\n84:   } else if (format === \"toon\") {\n85:     console.error(`#ERROR ${message}`);\n86:   } else {\n87:     console.error(message);\n88:   }\n89:   process.exit(exitCode);\n90: }\n91: \n92: /**\n93:  * Emit a success/info message. In JSON mode, outputs {\"message\": msg, ...extra}.\n94:  * In TOON mode, outputs \"#MSG message\" to stdout.\n95:  * In text mode, outputs the message to stdout normally.\n96:  */\n97: export function outputMessage(\n98:   format: OutputFormat,\n99:   message: string,\n100:   extra?: Record<string, unknown>\n101: ): void {\n102:   if (format === \"json\") {\n103:     console.log(JSON.stringify({ message, ...extra }));\n104:   } else if (format === \"toon\") {\n105:     console.log(`#MSG ${message}`);\n106:   } else {\n107:     console.log(message);\n108:   }\n109: }\n110: \n111: // ---------------------------------------------------------------------------\n112: // Field filtering for compact output (--fields)\n113: // ---------------------------------------------------------------------------\n114: \n115: /**\n116:  * Filter an object to only include the specified fields.\n117:  * If fields is undefined/empty, returns the object unchanged.\n118:  */\n119: export function filterFields<T extends Record<string, unknown>>(\n120:   obj: T,\n121:   fields?: string[]\n122: ): Partial<T> {\n123:   if (!fields || fields.length === 0) return obj;\n124:   const result: Partial<T> = {};\n125:   for (const field of fields) {\n126:     if (field in obj) {\n127:       (result as any)[field] = (obj as any)[field];\n128:     }\n129:   }\n130:   return result;\n131: }\n132: \n133: /**\n134:  * Filter an array of objects to only include specified fields per object.\n135:  * If fields is undefined/empty, returns the array unchanged.\n136:  */\n137: export function filterFieldsArray<T extends Record<string, unknown>>(\n138:   arr: T[],\n139:   fields?: string[]\n140: ): Partial<T>[] {\n141:   if (!fields || fields.length === 0) return arr;\n142:   return arr.map((obj) => filterFields(obj, fields));\n143: }\n144: \n145: /**\n146:  * Render a compact text table from an array of objects with selected fields.\n147:  * Used for text-mode --fields output.\n148:  */\n149: export function renderCompactTable(\n150:   items: Record<string, unknown>[],\n151:   fields: string[]\n152: ): void {\n153:   if (items.length === 0) return;\n154: \n155:   // Calculate column widths\n156:   const widths: Record<string, number> = {};\n157:   for (const field of fields) {\n158:     widths[field] = field.length;\n159:     for (const item of items) {\n160:       const val = String(item[field] ?? \"\");\n161:       widths[field] = Math.max(widths[field], val.length);\n162:     }\n163:   }\n164: \n165:   // Header\n166:   const header = fields.map((f) => f.padEnd(widths[f])).join(\"  \");\n167:   console.log(header);\n168:   console.log(fields.map((f) => \"─\".repeat(widths[f])).join(\"  \"));\n169: \n170:   // Rows\n171:   for (const item of items) {\n172:     const row = fields.map((f) => String(item[f] ?? \"\").padEnd(widths[f])).join(\"  \");\n173:     console.log(row);\n174:   }\n175: }\n\n(End of file - total 175 lines)\n</content>","title":"src/lib/output.ts","metadata":{"preview":"/**\n * Emit structured data.\n *   - JSON mode: outputs a single JSON line to stdout\n *   - TOON mode: calls toonRenderer if provided, otherwise uses generic TOON formatter\n *   - Text mode: calls textRenderer\n */\nexport function output(\n  format: OutputFormat,\n  data: unknown,\n  textRenderer: () => void,\n  toonRenderer?: () => void\n): void {\n  if (format === \"json\") {\n    console.log(JSON.stringify(data));\n  } else if (format === \"toon\") {\n    if (toonRenderer) {\n      toonRenderer();\n    } else {\n      // Generic fallback: convert structured data to TOON\n      console.log(renderGeneric(data));","truncated":false,"loaded":[]},"time":{"start":1773483688779,"end":1773483688781}}}}
