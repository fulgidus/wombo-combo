peof setInterval> | null = null;\n285:   private hasRunningWave: boolean = false;\n286:   /** Active wishlist overlay (null when closed) */\n287:   private wishlistOverlay: WishlistOverlay | null = null;\n288: \n289:   constructor(opts: TaskBrowserOptions) {\n290:     this.projectRoot = opts.projectRoot;\n291:     this.config = opts.config;\n292:     this.session = opts.session;\n293:     this.onLaunch = opts.onLaunch;\n294:     this.onQuit = opts.onQuit;\n295:     this.onBack = opts.onBack;\n296:     this.onSwitchToMonitor = opts.onSwitchToMonitor;\n297:     this.onErrand = opts.onErrand;\n298:     this.selected = new Set(opts.session.selected);\n299:     this.collapsed = new Set(opts.session.collapsed);\n300: \n301:     // Quest filtering\n302:     this.questId = opts.questId ?? null;\n303:     this.questTitle = opts.questTitle ?? null;\n304:     this.questTaskIds = opts.questTaskIds ? new Set(opts.questTaskIds) : null;\n305: \n306:     // Load tasks\n307:     this.reloadTasks();\n308: \n309:     // Create screen\n310:     this.screen = blessed.screen({\n311:       smartCSR: true,\n312:       title: this.questTitle\n313:         ? `wombo-combo -- ${this.questTitle}`\n314:         : \"wombo-combo -- Task Browser\",\n315:       fullUnicode: true,\n316:     });\n317: \n318:     // Header\n319:     this.headerBox = blessed.box({\n320:       top: 0,\n321:       left: 0,\n322:       width: \"100%\",\n323:       height: 3,\n324:       tags: true,\n325:       style: { fg: \"white\", bg: \"black\" },\n326:     });\n327: \n328:     // Task list (left pane)\n329:     this.taskList = blessed.list({\n330:       top: 3,\n331:       left: 0,\n332:       width: \"60%\",\n333:       height: \"100%-6\",\n334:       tags: true,\n335:       scrollable: true,\n336:       mouse: true,\n337:       keys: true,\n338:       vi: true,\n339:       border: { type: \"line\" },\n340:       style: {\n341:         border: { fg: \"gray\" },\n342:         selected: { bg: \"blue\", fg: \"white\", bold: true },\n343:         item: { fg: \"white\" },\n344:       },\n345:       label: \" Tasks \",\n346:     });\n347: \n348:     // Detail pane (right pane)\n349:     this.detailBox = blessed.box({\n350:       top: 3,\n351:       left: \"60%\",\n352:       width: \"40%\",\n353:       height: \"100%-6\",\n354:       tags: true,\n355:       scrollable: true,\n356:       mouse: true,\n357:       border: { type: \"line\" },\n358:       style: {\n359:         border: { fg: \"gray\" },\n360:         fg: \"white\",\n361:       },\n362:       label: \" Details \",\n363:     });\n364: \n365:     // Status bar\n366:     this.statusBar = blessed.box({\n367:       bottom: 0,\n368:       left: 0,\n369:       width: \"100%\",\n370:       height: 3,\n371:       tags: true,\n372:       style: { fg: \"white\", bg: \"black\" },\n373:     });\n374: \n375:     // Assemble\n376:     this.screen.append(this.headerBox);\n377:     this.screen.append(this.taskList);\n378:     this.screen.append(this.detailBox);\n379:     this.screen.append(this.statusBar);\n380:     this.taskList.focus();\n381: \n382:     this.bindKeys();\n383:   }\n384: \n385:   // -------------------------------------------------------------------------\n386:   // Public API\n387:   // -------------------------------------------------------------------------\n388: \n389:   start(): void {\n390:     this.buildDisplay();\n391:     this.refresh();\n392:     this.screen.render();\n393:   }\n394: \n395:   stop(): void {\n396:     this.saveSession();\n397:     if (this.refreshTimer) {\n398:       clearInterval(this.refreshTimer);\n399:       this.refreshTimer = null;\n400:     }\n401:     this.screen.destroy();\n402:   }\n403: \n404:   /**\n405:    * Destroy the browser screen without saving session (caller already saved).\n406:    * Used by the TUI orchestrator after receiving onLaunch — the transition\n407:    * message is already displayed, so we just tear down the blessed screen\n408:    * and clear the terminal for the next view.\n409:    */\n410:   destroy(): void {\n411:     if (this.refreshTimer) {\n412:       clearInterval(this.refreshTimer);\n413:       this.refreshTimer = null;\n414:     }\n415:     this.screen.destroy();\n416:     // Clear terminal so the next view starts fresh\n417:     process.stdout.write(\"\\x1B[2J\\x1B[H\");\n418:   }\n419: \n420:   /** Let the orchestrator tell us a wave is running (enables Tab to switch) */\n421:   setHasRunningWave(running: boolean): void {\n422:     this.hasRunningWave = running;\n423:     this.refreshStatusBar();\n424:     this.screen.render();\n425:   }\n426: \n427:   // -------------------------------------------------------------------------\n428:   // Task Loading\n429:   // -------------------------------------------------------------------------\n430: \n431:   private reloadTasks(): void {\n432:     const tasksData = loadTasks(this.projectRoot, this.config);\n433:     const archiveData = loadArchive(this.projectRoot, this.config);\n434: \n435:     // Filter tasks by quest if a quest is selected\n436:     if (this.questTaskIds) {\n437:       this.allTasks = tasksData.tasks.filter((t) => this.questTaskIds!.has(t.id));\n438:     } else {\n439:       this.allTasks = tasksData.tasks;\n440:     }\n441: \n442:     this.archiveTasks = archiveData.tasks;\n443:     this.doneIds = getDoneTaskIds(tasksData, this.archiveTasks);\n444:     this.streams = buildTaskGraph(this.allTasks);\n445: \n446:     // Prune selected IDs that no longer exist\n447:     const validIds = new Set(this.allTasks.map((t) => t.id));\n448:     for (const id of this.selected) {\n449:       if (!validIds.has(id)) this.selected.delete(id);\n\n(Showing lines 250-449 of 1048. Use offset=450 to continue.)\n</content>","title":"src/lib/tui-browser.ts","metadata":{"preview":"// Task Browser Class\n// ---------------------------------------------------------------------------\n\nexport class TaskBrowser {\n  private screen: Widgets.Screen;\n  private headerBox: Widgets.BoxEl