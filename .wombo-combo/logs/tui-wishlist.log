{"type":"tool_use","timestamp":1773483686253,"sessionID":"ses_314277f9bffeVWfnq7bm5y0Dtk","part":{"id":"prt_cebdd76f3001a7xe9NGgvBC9wb","sessionID":"ses_314277f9bffeVWfnq7bm5y0Dtk","messageID":"msg_cebdd683700137CjnKER3NrMPc","type":"tool","callID":"toolu_vrtx_01UfUVNLh1StXPEyDMwn6Tk3","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/tui-wishlist/src/lib/output.ts","limit":50},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/tui-wishlist/src/lib/output.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * output.ts — Shared output helpers for agent-ready CLI.\n3:  *\n4:  * Provides a centralized way for commands to emit structured data that\n5:  * renders as human-readable text on TTY, as JSON when --output json\n6:  * is specified, or as compact TOON notation when --output toon is used.\n7:  *\n8:  * Usage in commands:\n9:  *   import { output, OutputFormat } from \"../lib/output.js\";\n10:  *\n11:  *   // At the end of a command:\n12:  *   output(format, data, textRenderer, toonRenderer);  // emits JSON, text, or TOON\n13:  *   outputError(format, message);                      // emits error in the right format\n14:  */\n15: \n16: import { renderGeneric } from \"./toon.js\";\n17: \n18: // ---------------------------------------------------------------------------\n19: // Types\n20: // ---------------------------------------------------------------------------\n21: \n22: export type OutputFormat = \"text\" | \"json\" | \"toon\";\n23: \n24: // ---------------------------------------------------------------------------\n25: // Helpers\n26: // ---------------------------------------------------------------------------\n27: \n28: /**\n29:  * Determine the output format. Priority:\n30:  *   1. Explicit --output flag value\n31:  *   2. WOMBO_OUTPUT env var (for agent pipelines)\n32:  *   3. Default to \"text\"\n33:  *\n34:  * Note: We intentionally do NOT auto-detect based on TTY. Many legitimate\n35:  * use cases (bun dev, piped to less/grep, CI) have non-TTY stdout but still\n36:  * want human output. Agents should explicitly pass --output json or set\n37:  * WOMBO_OUTPUT=json.\n38:  */\n39: export function resolveOutputFormat(explicit?: string): OutputFormat {\n40:   if (explicit === \"json\") return \"json\";\n41:   if (explicit === \"toon\") return \"toon\";\n42:   if (explicit === \"text\") return \"text\";\n43:   // Check env var for agent pipelines\n44:   const env = process.env.WOMBO_OUTPUT;\n45:   if (env === \"json\") return \"json\";\n46:   if (env === \"toon\") return \"toon\";\n47:   return \"text\";\n48: }\n49: \n50: /**\n\n(Showing lines 1-50 of 175. Use offset=51 to continue.)\n</content>","title":"src/lib/output.ts","metadata":{"preview":"/**\n * output.ts — Shared output helpers for agent-ready CLI.\n *\n * Provides a centralized way for commands to emit structured data that\n * renders as human-readable text on TTY, as JSON when --output json\n * is specified, or as compact TOON notation when --output toon is used.\n *\n * Usage in commands:\n *   import { output, OutputFormat } from \"../lib/output.js\";\n *\n *   // At the end of a command:\n *   output(format, data, textRenderer, toonRenderer);  // emits JSON, text, or TOON\n *   outputError(format, message);                      // emits error in the right format\n */\n\nimport { renderGeneric } from \"./toon.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------","truncated":true,"loaded":[]},"time":{"start":1773483686250,"end":1773483686253}}}}
