{"type":"tool_use","timestamp":1773483385909,"sessionID":"ses_314277f9bffeVWfnq7bm5y0Dtk","part":{"id":"prt_cebd8e278001LVEVnFdHUgy03u","sessionID":"ses_314277f9bffeVWfnq7bm5y0Dtk","messageID":"msg_cebd8cdd20012Ub9GpMSTnz4S7","type":"tool","callID":"toolu_vrtx_01SC2mbrPiUUyjXmV4dEKL6q","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/tui-wishlist/src/commands/tui.ts","offset":760,"limit":250},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/tui-wishlist/src/commands/tui.ts</path>\n<type>file</type>\n<content>760:     await sleep(2000);\n761:   } catch (err: any) {\n762:     console.error(`\\n  Failed to create errand tasks: ${err.message}\\n`);\n763:     await sleep(3000);\n764:   }\n765: }\n766: \n767: // ---------------------------------------------------------------------------\n768: // Wishlist Flow -- Browse + Promote to Errand/Genesis\n769: // ---------------------------------------------------------------------------\n770: \n771: /**\n772:  * Show the wishlist picker. When the user promotes an item, run the\n773:  * appropriate flow (errand or genesis) with the item text pre-filled.\n774:  * After promotion completes, offer to delete the wishlist item.\n775:  */\n776: async function handleWishlistFlow(\n777:   projectRoot: string,\n778:   config: WomboConfig,\n779:   opts: TUICommandOptions\n780: ): Promise<void> {\n781:   const action = await showWishlistPicker(projectRoot);\n782: \n783:   if (action.type === \"back\" || action.type === \"quit\") {\n784:     return;\n785:   }\n786: \n787:   if (action.type === \"promote-errand\") {\n788:     const item = action.item;\n789:     await handleErrandFlow(projectRoot, config, opts, item.text);\n790:     await maybeDeleteWishlistItem(projectRoot, item);\n791:     return;\n792:   }\n793: \n794:   if (action.type === \"promote-genesis\") {\n795:     const item = action.item;\n796:     await handleGenesisFlow(projectRoot, config, opts, item.text);\n797:     await maybeDeleteWishlistItem(projectRoot, item);\n798:     return;\n799:   }\n800: }\n801: \n802: /**\n803:  * Show the Wishlist Picker TUI and return a Promise that resolves when the\n804:  * user takes an action.\n805:  */\n806: function showWishlistPicker(projectRoot: string): Promise<WishlistAction> {\n807:   return new Promise<WishlistAction>((resolve) => {\n808:     const picker = new WishlistPicker({\n809:       projectRoot,\n810: \n811:       onPromoteErrand: (item) => {\n812:         resolve({ type: \"promote-errand\", item });\n813:       },\n814: \n815:       onPromoteGenesis: (item) => {\n816:         resolve({ type: \"promote-genesis\", item });\n817:       },\n818: \n819:       onBack: () => {\n820:         resolve({ type: \"back\" });\n821:       },\n822: \n823:       onQuit: () => {\n824:         resolve({ type: \"quit\" });\n825:       },\n826:     });\n827: \n828:     picker.start();\n829:   });\n830: }\n831: \n832: /**\n833:  * After a wishlist item has been promoted, ask the user whether to delete it.\n834:  * Uses a simple readline prompt (no blessed screen is active at this point).\n835:  */\n836: async function maybeDeleteWishlistItem(\n837:   projectRoot: string,\n838:   item: WishlistItem\n839: ): Promise<void> {\n840:   const readline = await import(\"node:readline\");\n841:   const rl = readline.createInterface({\n842:     input: process.stdin,\n843:     output: process.stdout,\n844:   });\n845: \n846:   const truncText =\n847:     item.text.length > 50 ? item.text.slice(0, 47) + \"...\" : item.text;\n848: \n849:   const answer = await new Promise<string>((resolve) => {\n850:     rl.question(\n851:       `\\n  Delete wishlist item \"${truncText}\"? [y/N] `,\n852:       (ans) => {\n853:         rl.close();\n854:         resolve(ans.trim().toLowerCase());\n855:       }\n856:     );\n857:   });\n858: \n859:   if (answer === \"y\" || answer === \"yes\") {\n860:     const deleted = deleteWishlistItem(projectRoot, item.id);\n861:     if (deleted) {\n862:       console.log(`  Wishlist item deleted.\\n`);\n863:     } else {\n864:       console.log(`  Item not found (may have been already deleted).\\n`);\n865:     }\n866:   } else {\n867:     console.log(`  Wishlist item kept.\\n`);\n868:   }\n869: \n870:   await sleep(1000);\n871: }\n872: \n873: // ---------------------------------------------------------------------------\n874: // Genesis Review View -- Promise-based\n875: // ---------------------------------------------------------------------------\n876: \n877: /**\n878:  * Show the Genesis Review TUI and return a Promise that resolves when the\n879:  * user approves or cancels.\n880:  */\n881: function showGenesisReview(\n882:   genesisResult: GenesisResult\n883: ): Promise<GenesisReviewAction> {\n884:   return new Promise<GenesisReviewAction>((resolve) => {\n885:     const review = new GenesisReview({\n886:       genesisResult,\n887: \n888:       onApprove: (quests, knowledge) => {\n889:         resolve({ type: \"approve\", quests, knowledge });\n890:       },\n891: \n892:       onCancel: () => {\n893:         resolve({ type: \"cancel\" });\n894:       },\n895:     });\n896: \n897:     review.start();\n898:   });\n899: }\n900: \n901: // ---------------------------------------------------------------------------\n902: // Plan Review View -- Promise-based\n903: // ---------------------------------------------------------------------------\n904: \n905: /**\n906:  * Show the Plan Review TUI and return a Promise that resolves when the user\n907:  * approves or cancels.\n908:  */\n909: function showPlanReview(\n910:   questId: string,\n911:   questTitle: string,\n912:   planResult: PlanResult\n913: ): Promise<PlanReviewResult> {\n914:   return new Promise<PlanReviewResult>((resolve) => {\n915:     const review = new PlanReview({\n916:       questId,\n917:       questTitle,\n918:       planResult,\n919: \n920:       onApprove: (tasks, knowledge) => {\n921:         resolve({ type: \"approve\", tasks, knowledge });\n922:       },\n923: \n924:       onCancel: () => {\n925:         resolve({ type: \"cancel\" });\n926:       },\n927:     });\n928: \n929:     review.start();\n930:   });\n931: }\n932: \n933: // ---------------------------------------------------------------------------\n934: // Browser View -- Promise-based\n935: // ---------------------------------------------------------------------------\n936: \n937: /**\n938:  * Show the Task Browser and return a Promise that resolves when the user\n939:  * takes an action (launch, back, or quit).\n940:  */\n941: function showBrowser(\n942:   projectRoot: string,\n943:   config: WomboConfig,\n944:   session: TUISession,\n945:   opts: TUICommandOptions,\n946:   questId: string | null,\n947:   hasQuestPicker: boolean\n948: ): Promise<BrowserAction> {\n949:   // Reload session from disk in case state changed after a wave\n950:   const freshSession = loadTUISession(projectRoot);\n951:   // Merge any runtime overrides\n952:   if (opts.maxConcurrent !== undefined) {\n953:     freshSession.maxConcurrent = opts.maxConcurrent;\n954:   }\n955:   // Copy fresh values back into the shared session object\n956:   Object.assign(session, freshSession);\n957: \n958:   // Load quest details for filtering if a quest was selected\n959:   let questTitle: string | undefined;\n960:   let questTaskIds: string[] | undefined;\n961:   if (questId) {\n962:     const quest = loadQuest(projectRoot, questId);\n963:     if (quest) {\n964:       questTitle = quest.title;\n965:       questTaskIds = quest.taskIds;\n966:     }\n967:   }\n968: \n969:   return new Promise<BrowserAction>((resolve) => {\n970:     const browser = new TaskBrowser({\n971:       projectRoot,\n972:       config,\n973:       session,\n974:       questId,\n975:       questTitle,\n976:       questTaskIds,\n977: \n978:       onLaunch: (selectedIds: string[]) => {\n979:         if (selectedIds.length === 0) return;\n980:         // The browser has already shown a transition message on-screen.\n981:         // Destroy the blessed screen and clear the terminal.\n982:         browser.destroy();\n983:         resolve({ type: \"launch\", ids: selectedIds });\n984:       },\n985: \n986:       onQuit: () => {\n987:         browser.stop();\n988:         resolve({ type: \"quit\" });\n989:       },\n990: \n991:       onBack: hasQuestPicker\n992:         ? () => {\n993:             resolve({ type: \"back\" });\n994:           }\n995:         : undefined,\n996: \n997:       // Errand is available when not in quest-filtered mode\n998:       onErrand: !questId\n999:         ? () => {\n1000:             resolve({ type: \"errand\" });\n1001:           }\n1002:         : undefined,\n1003: \n1004:       onSwitchToMonitor: undefined,\n1005:     });\n1006: \n1007:     browser.start();\n1008:   });\n1009: }\n\n(Showing lines 760-1009 of 1017. Use offset=1010 to continue.)\n</content>","title":"src/commands/tui.ts","metadata":{"preview":"    await sleep(2000);\n  } catch (err: any) {\n    console.error(`\\n  Failed to create errand tasks: ${err.message}\\n`);\n    await sleep(3000);\n  }\n}\n\n// ---------------------------------------------------------------------------\n// Wishlist Flow -- Browse + Promote to Errand/Genesis\n// ---------------------------------------------------------------------------\n\n/**\n * Show the wishlist picker. When the user promotes an item, run the\n * appropriate flow (errand or genesis) with the item text pre-filled.\n * After promotion completes, offer to delete the wishlist item.\n */\nasync function handleWishlistFlow(\n  projectRoot: string,\n  config: WomboConfig,\n  opts: TUICommandOptions","truncated":true,"loaded":[]},"time":{"start":1773483385900,"end":1773483385908}}}}
