:         agent,\n327:         `BROWSER: ${br.summary} (${Math.round(br.totalDurationMs / 1000)}s)`\n328:       );\n329:     } else if (fullResult.browser.skipReason && config.browser.enabled) {\n330:       printAgentUpdate(agent, `BROWSER: skipped — ${fullResult.browser.skipReason}`);\n331:     }\n332: \n333:     // Report TDD verification status if it ran\n334:     if (fullResult.tdd.ran) {\n335:       const tdd = fullResult.tdd;\n336:       const tddIcon = tdd.passed ? \"✓\" : \"✗\";\n337:       printAgentUpdate(agent, `TDD: ${tddIcon} ${tdd.summary}`);\n338:       if (tdd.hasWarnings) {\n339:         printAgentUpdate(agent, `TDD: ⚠ Missing tests detected (non-blocking)`);\n340:       }\n341:     } else if (fullResult.tdd.skipReason && config.tdd?.enabled) {\n342:       printAgentUpdate(agent, `TDD: skipped — ${fullResult.tdd.skipReason}`);\n343:     }\n344: \n345:     if (fullResult.overallPassed) {\n346:       updateAgent(state, agent.feature_id, {\n347:         status: \"verified\",\n348:         build_passed: true,\n349:         build_output: null,\n350:       });\n351:       saveState(projectRoot, state);\n352:       printAgentUpdate(agent, `BUILD PASSED (${Math.round(buildResult.durationMs / 1000)}s)`);\n353: \n354:       // Auto-merge: attempt merge + conflict resolution\n355:       await attemptMerge(projectRoot, state, agent, feature, config, model);\n356:     } else {\n357:       const errorSummary = fullResult.combinedErrorSummary;\n358: \n359:       if (agent.retries < agent.max_retries) {\n360:         updateAgent(state, agent.feature_id, {\n361:           status: \"retry\",\n362:           retries: agent.retries + 1,\n363:           build_passed: false,\n364:           build_output: errorSummary,\n365:         });\n366:         saveState(projectRoot, state);\n367:         printAgentUpdate(\n368:           agent,\n369:           `VERIFICATION FAILED — retrying (${agent.retries}/${agent.max_retries})`\n370:         );\n371: \n372:         // Retry with error details\n373:         if (agent.session_id) {\n374:           const retryResult = retryHeadless({\n375:             worktreePath: agent.worktree,\n376:             featureId: agent.feature_id,\n377:             sessionId: agent.session_id,\n378:             buildErrors: errorSummary,\n379:             model,\n380:             config,\n381:           });\n382: \n383:           updateAgent(state, agent.feature_id, {\n384:             status: \"running\",\n385:             pid: retryResult.pid,\n386:           });\n387:           saveState(projectRoot, state);\n388: \n389:           // Add retry process to monitor so events are tracked\n390:           if (monitor) {\n391:             monitor.addProcess(agent.feature_id, retryResult.process);\n392:           }\n393:         } else {\n394:           // Agent has no session — reset to queued for a fresh launch\n395:           wtLog(agent.feature_id, `no session — resetting to queued for fresh launch (retry ${agent.retries}/${agent.max_retries})`);\n396:           updateAgent(state, agent.feature_id, {\n397:             status: \"queued\",\n398:             error: null,\n399:             activity: \"waiting for relaunch...\",\n400:           });\n401:           saveState(projectRoot, state);\n402:         }\n403:       } else {\n404:         updateAgent(state, agent.feature_id, {\n405:           status: \"failed\",\n406:           build_passed: false,\n407:           build_output: errorSummary,\n408:           error: `Verification failed after ${agent.max_retries} retries`,\n409:           completed_at: new Date().toISOString(),\n410:         });\n411:         saveState(projectRoot, state);\n412:         printAgentUpdate(agent, \"VERIFICATION FAILED — max retries reached\");\n413: \n414:         // Cascade failure to downstream agents\n415:         const cancelled = cancelDownstream(state, agent.feature_id);\n416:         if (cancelled.length > 0) {\n417:           printAgentUpdate(agent, `downstream cancelled: ${cancelled.join(\", \")}`);\n418:           saveState(projectRoot, state);\n419:         }\n420:       }\n421:     }\n422:   } catch (err: any) {\n423:     // Catch-all — never let build verification crash the process\n424:     printAgentUpdate(agent, `VERIFY ERROR: ${err.message?.slice(0, 100)}`);\n425:     updateAgent(state, agent.feature_id, {\n426:       status: \"failed\",\n427:       error: `Build verification error: ${err.message}`,\n428:       completed_at: new Date().toISOString(),\n429:     });\n430:     saveState(projectRoot, state);\n431:   }\n432: }\n433: \n434: /**\n435:  * Attempt to merge a verified agent's branch into the base branch.\n436:  *\n437:  * Handles conflict detection, base-into-feature merge, and resolver agent\n438:  * launch. Extracted from handleBuildVerification so it can be called\n439:  * independently (e.g., from resume's sequential merge phase).\n\n(Showing lines 290-439 of 1706. Use offset=440 to continue.)\n</content>","title":"src/commands/launch.ts","metadata":{"preview":"      error: err.message,\n      activity: null,\n      completed_at: new Date().toISOString(),\n    });\n    saveState(projectRoot, state);\n    wtLog(agent.feature_id, `SETUP FAILED: ${err.message.split(\"\\n\")[0]}`);\n  }\n}\n\n/**\n * Handle build verification after agent completion.\n * Runs build, auto-merges on pass, retries on failure if retries remain.\n *\n * ASYNC — runs build and merge without blocking the event loop.\n */\nexport async function handleBuildVerification(\n  projectRoot: string,\n  state: WaveState,\n  agent: AgentState,\n  feature: Feature,","truncated":true,"loaded":[]},"time":{"start":1773445095746,"end":1773445095752}}}}
