{"type":"tool_use","timestamp":1773445795139,"sessionID":"ses_316650d1dffespdzjLs3PfWdD3","part":{"id":"prt_ce99b4b9f0015KrR4vXxXqTjzf","sessionID":"ses_316650d1dffespdzjLs3PfWdD3","messageID":"msg_ce99b3650001Qrc8ocWQ6tGWyM","type":"tool","callID":"toolu_vrtx_01Rhy57zEJ8sg3Q8tEyQPe4r","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/tdd-red-green-coercion/tests/features.test.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/tdd-red-green-coercion/tests/features.test.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * features.test.ts — Unit tests for tasks YAML parsing, validation,\n3:  * duration parsing, and dependency resolution.\n4:  *\n5:  * Coverage:\n6:  *   - loadFeatures with null tasks, empty arrays, valid data\n7:  *   - parseDurationMinutes for ISO 8601 durations\n8:  *   - formatDuration for human-readable output\n9:  *   - Dependency resolution (areDependenciesMet, getReadyFeatures)\n10:  *   - normalizeTask defaults\n11:  *   - createBlankFeature\n12:  *   - findFeatureById (recursive search)\n13:  *   - selectFeatures strategies\n14:  *   - YAML schema edge cases\n15:  */\n16: \n17: import { describe, test, expect, beforeEach, afterEach } from \"bun:test\";\n18: import { mkdtempSync, writeFileSync, rmSync, mkdirSync } from \"node:fs\";\n19: import { join } from \"node:path\";\n20: import { tmpdir } from \"node:os\";\n21: import type { WomboConfig } from \"../src/config.js\";\n22: import {\n23:   loadFeatures,\n24:   parseDurationMinutes,\n25:   formatDuration,\n26:   areDependenciesMet,\n27:   getReadyFeatures,\n28:   getDoneFeatureIds,\n29:   selectFeatures,\n30:   createBlankFeature,\n31:   findFeatureById,\n32:   allFeatureIds,\n33:   featureSummary,\n34:   PRIORITY_ORDER,\n35:   DIFFICULTY_ORDER,\n36: } from \"../src/lib/tasks.js\";\n37: import type {\n38:   Feature,\n39:   FeaturesFile,\n40:   Subtask,\n41:   Priority,\n42:   Difficulty,\n43: } from \"../src/lib/tasks.js\";\n44: \n45: // ---------------------------------------------------------------------------\n46: // Helpers\n47: // ---------------------------------------------------------------------------\n48: \n49: function makeConfig(overrides?: Partial<WomboConfig>): WomboConfig {\n50:   return {\n51:     tasksDir: \"tasks\",\n52:     archiveDir: \"archive\",\n53:     baseBranch: \"main\",\n54:     build: { command: \"bun run build\", timeout: 300_000, artifactDir: \"dist\" },\n55:     install: { command: \"bun install\", timeout: 120_000 },\n56:     git: {\n57:       branchPrefix: \"feature/\",\n58:       worktreePrefix: \"wombo-\",\n59:       remote: \"origin\",\n60:       mergeStrategy: \"--no-ff\",\n61:     },\n62:     agent: {\n63:       bin: null,\n64:       name: \"generalist-agent\",\n65:       configFiles: [],\n66:       tmuxPrefix: \"wombo\",\n67:       multiplexer: \"auto\",\n68:     },\n69:     portless: {\n70:       enabled: true,\n71:       bin: null,\n72:       proxyPort: 1355,\n73:       https: false,\n74:     },\n75:     backup: { maxBackups: 5 },\n76:     defaults: { maxConcurrent: 6, maxRetries: 2 },\n77:     browser: {\n78:       enabled: false,\n79:       bin: null,\n80:       headless: true,\n81:       testCommand: null,\n82:       launchTimeout: 30_000,\n83:       testTimeout: 60_000,\n84:       defaultViewport: { width: 1280, height: 720 },\n85:     },\n86:     agentRegistry: {\n87:       mode: \"auto\",\n88:       source: \"msitarzewski/agency-agents\",\n89:       cacheDir: \"agents-cache\",\n90:       cacheTTL: 24 * 60 * 60 * 1000,\n91:     },\n92:     tdd: {\n93:       enabled: false,\n94:       testCommand: \"bun test\",\n95:     },\n96:     ...overrides,\n97:   };\n98: }\n99: \n100: function makeFeature(overrides?: Partial<Feature>): Feature {\n101:   return {\n102:     id: \"test-feature\",\n103:     title: \"Test Feature\",\n104:     description: \"A test feature\",\n105:     status: \"backlog\",\n106:     completion: 0,\n107:     difficulty: \"medium\",\n108:     priority: \"medium\",\n109:     depends_on: [],\n110:     effort: \"PT1H\",\n111:     started_at: null,\n112:     ended_at: null,\n113:     constraints: [],\n114:     forbidden: [],\n115:     references: [],\n116:     notes: [],\n117:     subtasks: [],\n118:     ...overrides,\n119:   };\n120: }\n121: \n122: function makeFeaturesFile(\n123:   tasks: Feature[] = [],\n124:   archive: Feature[] = []\n125: ): FeaturesFile {\n126:   return {\n127:     version: \"1\",\n128:     meta: {\n129:       created_at: \"2025-01-01T00:00:00Z\",\n130:       updated_at: \"2025-01-01T00:00:00Z\",\n131:       project: \"test-project\",\n132:       generator: \"test\",\n133:       maintainer: \"tester\",\n134:     },\n135:     tasks,\n136:     archive,\n137:   };\n138: }\n139: \n140: /**\n141:  * Write a YAML string to the .wombo-combo/tasks.yml inside the given tmpDir.\n142:  * Also creates the .wombo-combo directory.\n143:  */\n144: function writeTasksYaml(dir: string, yaml: string): void {\n145:   mkdirSync(join(dir, \".wombo-combo\"), { recursive: true });\n146:   writeFileSync(join(dir, \".wombo-combo\", \"tasks.yml\"), yaml);\n147: }\n148: \n149: /**\n150:  * Write archive YAML to .wombo-combo/archive.yml.\n151:  */\n152: function writeArchiveYaml(dir: string, yaml: string): void {\n153:   mkdirSync(join(dir, \".wombo-combo\"), { recursive: true });\n154:   writeFileSync(join(dir, \".wombo-combo\", \"archive.yml\"), yaml);\n155: }\n156: \n157: let tmpDir: string;\n158: \n159: beforeEach(() => {\n160:   tmpDir = mkdtempSync(join(tmpdir(), \"wombo-test-features-\"));\n161: });\n162: \n163: afterEach(() => {\n164:   rmSync(tmpDir, { recursive: true, force: true });\n165: });\n166: \n167: // ---------------------------------------------------------------------------\n168: // ISO 8601 Duration Parsing\n169: // ---------------------------------------------------------------------------\n170: \n171: describe(\"parseDurationMinutes\", () => {\n172:   test(\"parses hours only\", () => {\n173:     expect(parseDurationMinutes(\"PT1H\")).toBe(60);\n174:     expect(parseDurationMinutes(\"PT2H\")).toBe(120);\n175:     expect(parseDurationMinutes(\"PT0H\")).toBe(0);\n176:   });\n177: \n178:   test(\"parses minutes only\", () => {\n179:     expect(parseDurationMinutes(\"PT30M\")).toBe(30);\n180:     expect(parseDurationMinutes(\"PT1M\")).toBe(1);\n181:     expect(parseDurationMinutes(\"PT90M\")).toBe(90);\n182:   });\n183: \n184:   test(\"parses days only\", () => {\n185:     expect(parseDurationMinutes(\"P1D\")).toBe(1440);\n186:     expect(parseDurationMinutes(\"P2D\")).toBe(2880);\n187:   });\n188: \n189:   test(\"parses combined durations\", () => {\n190:     expect(parseDurationMinutes(\"PT1H30M\")).toBe(90);\n191:     expect(parseDurationMinutes(\"P1DT4H\")).toBe(1680);\n192:     expect(parseDurationMinutes(\"P2DT4H\")).toBe(3120);\n193:     expect(parseDurationMinutes(\"P1DT2H30M\")).toBe(1590);\n194:   });\n195: \n196:   test(\"parses seconds (rounds up to minutes)\", () => {\n197:     expect(parseDurationMinutes(\"PT30S\")).toBe(1); // ceil(30/60) = 1\n198:     expect(parseDurationMinutes(\"PT60S\")).toBe(1); // ceil(60/60) = 1\n199:     expect(parseDurationMinutes(\"PT61S\")).toBe(2); // ceil(61/60) = 2\n200:     expect(parseDurationMinutes(\"PT1H30S\")).toBe(61); // 60 + ceil(30/60)\n201:   });\n202: \n203:   test(\"returns Infinity for unparseable strings\", () => {\n204:     expect(parseDurationMinutes(\"\")).toBe(Infinity);\n205:     expect(parseDurationMinutes(\"invalid\")).toBe(Infinity);\n206:     expect(parseDurationMinutes(\"1H\")).toBe(Infinity); // missing P\n207:     expect(parseDurationMinutes(\"hello world\")).toBe(Infinity);\n208:   });\n209: \n210:   test(\"handles edge case: PT alone parses as zero duration\", () => {\n211:     // \"PT\" matches the regex: P with T but all time groups are optional\n212:     expect(parseDurationMinutes(\"PT\")).toBe(0);\n213:   });\n214: \n215:   test(\"handles P alone (zero duration)\", () => {\n216:     // P with no components - the regex should handle this\n217:     const result = parseDurationMinutes(\"P\");\n218:     // P alone matches /^P(?:(\\d+)D)?(?:T(?:(\\d+)H)?(?:(\\d+)M)?(?:(\\d+)S)?)?$/\n219:     // All groups are undefined, defaults to 0\n220:     expect(result).toBe(0);\n221:   });\n222: });\n223: \n224: // ---------------------------------------------------------------------------\n225: // Duration Formatting\n226: // ---------------------------------------------------------------------------\n227: \n228: describe(\"formatDuration\", () => {\n229:   test(\"formats minutes only\", () => {\n230:     expect(formatDuration(30)).toBe(\"30m\");\n231:     expect(formatDuration(1)).toBe(\"1m\");\n232:     expect(formatDuration(59)).toBe(\"59m\");\n233:   });\n234: \n235:   test(\"formats hours only\", () => {\n236:     expect(formatDuration(60)).toBe(\"1h\");\n237:     expect(formatDuration(120)).toBe(\"2h\");\n238:   });\n239: \n240:   test(\"formats hours and minutes\", () => {\n241:     expect(formatDuration(90)).toBe(\"1h 30m\");\n242:     expect(formatDuration(150)).toBe(\"2h 30m\");\n243:   });\n244: \n245:   test(\"formats days\", () => {\n246:     expect(formatDuration(1440)).toBe(\"1d\");\n247:     expect(formatDuration(2880)).toBe(\"2d\");\n248:   });\n249: \n250:   test(\"formats days and hours\", () => {\n251:     expect(formatDuration(1500)).toBe(\"1d 1h\");\n252:     expect(formatDuration(1560)).toBe(\"1d 2h\");\n253:   });\n254: \n255:   test(\"formats days, hours, and minutes\", () => {\n256:     expect(formatDuration(1530)).toBe(\"1d 1h 30m\");\n257:   });\n258: \n259:   test(\"formats Infinity as unknown\", () => {\n260:     expect(formatDuration(Infinity)).toBe(\"unknown\");\n261:   });\n262: \n263:   test(\"formats zero\", () => {\n264:     expect(formatDuration(0)).toBe(\"0m\");\n265:   });\n266: });\n267: \n268: // ---------------------------------------------------------------------------\n269: // loadFeatures — YAML parsing edge cases\n270: // ---------------------------------------------------------------------------\n271: \n272: describe(\"loadFeatures\", () => {\n273:   const config = makeConfig();\n274: \n275:   test(\"loads valid tasks file\", () => {\n276:     const yaml = `\n277: version: \"1\"\n278: meta:\n279:   created_at: \"2025-01-01T00:00:00Z\"\n280:   updated_at: \"2025-01-01T00:00:00Z\"\n281:   project: test\n282:   generator: test\n283:   maintainer: tester\n284: tasks:\n285:   - id: feat-a\n286:     title: Feature A\n287:     description: Description of A\n288:     status: backlog\n289:     completion: 0\n290:     difficulty: medium\n291:     priority: high\n292:     depends_on: []\n293:     effort: PT2H\n294:     started_at: null\n295:     ended_at: null\n296:     constraints: []\n297:     forbidden: []\n298:     references: []\n299:     notes: []\n300:     subtasks: []\n301: `;\n302:     writeTasksYaml(tmpDir, yaml);\n303:     const data = loadFeatures(tmpDir, config);\n304:     expect(data.tasks).toHaveLength(1);\n305:     expect(data.tasks[0].id).toBe(\"feat-a\");\n306:     expect(data.tasks[0].priority).toBe(\"high\");\n307:     expect(data.archive).toHaveLength(0);\n308:   });\n309: \n310:   test(\"handles null tasks (empty YAML key)\", () => {\n311:     const yaml = `\n312: version: \"1\"\n313: meta:\n314:   created_at: \"2025-01-01T00:00:00Z\"\n315:   updated_at: \"2025-01-01T00:00:00Z\"\n316:   project: test\n317:   generator: test\n318:   maintainer: tester\n319: tasks:\n320: `;\n321:     writeTasksYaml(tmpDir, yaml);\n322:     const data = loadFeatures(tmpDir, config);\n323:     expect(data.tasks).toBeArray();\n324:     expect(data.tasks).toHaveLength(0);\n325:     expect(data.archive).toBeArray();\n326:     expect(data.archive).toHaveLength(0);\n327:   });\n328: \n329:   test(\"handles tasks with null depends_on and arrays\", () => {\n330:     const yaml = `\n331: version: \"1\"\n332: meta:\n333:   created_at: \"2025-01-01T00:00:00Z\"\n334:   updated_at: \"2025-01-01T00:00:00Z\"\n335:   project: test\n336:   generator: test\n337:   maintainer: tester\n338: tasks:\n339:   - id: feat-a\n340:     title: Feature A\n341:     description: \"\"\n342:     status: backlog\n343:     completion: 0\n344:     difficulty: medium\n345:     priority: medium\n346:     effort: PT1H\n347:     started_at: null\n348:     ended_at: null\n349: `;\n350:     writeTasksYaml(tmpDir, yaml);\n351:     const data = loadFeatures(tmpDir, config);\n352:     expect(data.tasks).toHaveLength(1);\n353:     // normalizeTask should default null arrays to []\n354:     const f = data.tasks[0];\n355:     expect(f.depends_on).toBeArray();\n356:     expect(f.depends_on).toHaveLength(0);\n357:     expect(f.constraints).toBeArray();\n358:     expect(f.forbidden).toBeArray();\n359:     expect(f.references).toBeArray();\n360:     expect(f.notes).toBeArray();\n361:     expect(f.subtasks).toBeArray();\n362:   });\n363: \n364:   test(\"handles nested subtasks normalization (flattened by migration)\", () => {\n365:     // With folder-based storage, subtasks are flattened to top-level tasks\n366:     // during migration. The parent task gains a depends_on reference to its\n367:     // former subtask, and the subtask becomes a standalone top-level task.\n368:     const yaml = `\n369: version: \"1\"\n370: meta:\n371:   created_at: \"2025-01-01T00:00:00Z\"\n372:   updated_at: \"2025-01-01T00:00:00Z\"\n373:   project: test\n374:   generator: test\n375:   maintainer: tester\n376: tasks:\n377:   - id: feat-a\n378:     title: Feature A\n379:     description: \"\"\n380:     status: backlog\n381:     completion: 0\n382:     difficulty: medium\n383:     priority: medium\n384:     effort: PT1H\n385:     started_at: null\n386:     ended_at: null\n387:     subtasks:\n388:       - id: sub-1\n389:         title: Subtask 1\n390:         description: \"\"\n391:         status: backlog\n392:         completion: 0\n393:         difficulty: easy\n394:         priority: medium\n395:         effort: PT30M\n396:         started_at: null\n397:         ended_at: null\n398: `;\n399:     writeTasksYaml(tmpDir, yaml);\n400:     const data = loadFeatures(tmpDir, config);\n401:     // After migration, both feat-a and sub-1 are top-level tasks\n402:     const ids = data.tasks.map((t) => t.id).sort();\n403:     expect(ids).toContain(\"feat-a\");\n404:     expect(ids).toContain(\"sub-1\");\n405:     // The parent's subtasks array is empty (flattened)\n406:     const parent = data.tasks.find((t) => t.id === \"feat-a\")!;\n407:     expect(parent.subtasks).toBeArray();\n408:     expect(parent.subtasks).toHaveLength(0);\n409:     // The parent now depends on its former subtask\n410:     expect(parent.depends_on).toContain(\"sub-1\");\n411:     // The former subtask is a top-level task with normalized arrays\n412:     const subtask = data.tasks.find((t) => t.id === \"sub-1\")!;\n413:     expect(subtask.depends_on).toBeArray();\n414:     expect(subtask.constraints).toBeArray();\n415:     expect(subtask.subtasks).toBeArray();\n416:   });\n417: \n418:   test(\"returns empty tasks on corrupted YAML (graceful degradation)\", () => {\n419:     // With folder-based storage, corrupted legacy YAML is caught during\n420:     // migration and the store returns an empty TasksFile instead of throwing.\n421:     writeTasksYaml(tmpDir, \"{{{{not valid yaml::::\");\n422:     const data = loadFeatures(tmpDir, config);\n423:     expect(data.tasks).toBeArray();\n424:     expect(data.tasks).toHaveLength(0);\n425:   });\n426: \n427:   test(\"returns empty tasks on missing path (graceful degradation)\", () => {\n428:     // With folder-based storage, a missing path returns an empty TasksFile\n429:     // instead of throwing (the store creates default meta on demand).\n430:     const data = loadFeatures(\"/nonexistent/path\", config);\n431:     expect(data.tasks).toBeArray();\n432:     expect(data.tasks).toHaveLength(0);\n433:   });\n434: \n435:   test(\"handles custom tasks file path\", () => {\n436:     const customConfig = makeConfig({ tasksFile: \"custom-tasks.yml\" });\n437:     const yaml = `\n438: version: \"1\"\n439: meta:\n440:   created_at: \"2025-01-01T00:00:00Z\"\n441:   updated_at: \"2025-01-01T00:00:00Z\"\n442:   project: test\n443:   generator: test\n444:   maintainer: tester\n445: tasks: []\n446: `;\n447:     mkdirSync(join(tmpDir, \".wombo-combo\"), { recursive: true });\n448:     writeFileSync(join(tmpDir, \".wombo-combo\", \"custom-tasks.yml\"), yaml);\n449:     const data = loadFeatures(tmpDir, customConfig);\n450:     expect(data.tasks).toHaveLength(0);\n451:   });\n452: \n453:   test(\"supports legacy 'features' YAML key\", () => {\n454:     const yaml = `\n455: version: \"1\"\n456: meta:\n457:   created_at: \"2025-01-01T00:00:00Z\"\n458:   updated_at: \"2025-01-01T00:00:00Z\"\n459:   project: test\n460:   generator: test\n461:   maintainer: tester\n462: features:\n463:   - id: legacy-feat\n464:     title: Legacy Feature\n465:     description: Loaded via features key\n466:     status: backlog\n467:     completion: 0\n468:     difficulty: medium\n469:     priority: medium\n470:     depends_on: []\n471:     effort: PT1H\n472:     started_at: null\n473:     ended_at: null\n474:     constraints: []\n475:     forbidden: []\n476:     references: []\n477:     notes: []\n478:     subtasks: []\n479: `;\n480:     writeTasksYaml(tmpDir, yaml);\n481:     const data = loadFeatures(tmpDir, config);\n482:     expect(data.tasks).toHaveLength(1);\n483:     expect(data.tasks[0].id).toBe(\"legacy-feat\");\n484:   });\n485: });\n486: \n487: // ---------------------------------------------------------------------------\n488: // Dependency Resolution\n489: // ---------------------------------------------------------------------------\n490: \n491: describe(\"areDependenciesMet\", () => {\n492:   test(\"returns true when feature has no dependencies\", () => {\n493:     const feature = makeFeature({ depends_on: [] });\n494:     const doneIds = new Set<string>();\n495:     expect(areDependenciesMet(feature, doneIds)).toBe(true);\n496:   });\n497: \n498:   test(\"returns true when all dependencies are done\", () => {\n499:     const feature = makeFeature({ depends_on: [\"dep-a\", \"dep-b\"] });\n500:     const doneIds = new Set([\"dep-a\", \"dep-b\", \"dep-c\"]);\n501:     expect(areDependenciesMet(feature, doneIds)).toBe(true);\n502:   });\n503: \n504:   test(\"returns false when some dependencies are not done\", () => {\n505:     const feature = makeFeature({ depends_on: [\"dep-a\", \"dep-b\"] });\n506:     const doneIds = new Set([\"dep-a\"]);\n507:     expect(areDependenciesMet(feature, doneIds)).toBe(false);\n508:   });\n509: \n510:   test(\"returns false when no dependencies are done\", () => {\n511:     const feature = makeFeature({ depends_on: [\"dep-a\", \"dep-b\"] });\n512:     const doneIds = new Set<string>();\n513:     expect(areDependenciesMet(feature, doneIds)).toBe(false);\n514:   });\n515: });\n516: \n517: describe(\"getDoneFeatureIds\", () => {\n518:   test(\"identifies features with done status\", () => {\n519:     const data = makeFeaturesFile([\n520:       makeFeature({ id: \"feat-done\", status: \"done\", completion: 100 }),\n521:       makeFeature({ id: \"feat-wip\", status: \"in_progress\", completion: 50 }),\n522:     ]);\n523:     const doneIds = getDoneFeatureIds(data);\n524:     expect(doneIds.has(\"feat-done\")).toBe(true);\n525:     expect(doneIds.has(\"feat-wip\")).toBe(false);\n526:   });\n527: \n528:   test(\"identifies features with 100% completion as done\", () => {\n529:     const data = makeFeaturesFile([\n530:       makeFeature({\n531:         id: \"feat-complete\",\n532:         status: \"in_review\",\n533:         completion: 100,\n534:       }),\n535:     ]);\n536:     const doneIds = getDoneFeatureIds(data);\n537:     expect(doneIds.has(\"feat-complete\")).toBe(true);\n538:   });\n539: \n540:   test(\"includes archived features as done\", () => {\n541:     const data = makeFeaturesFile(\n542:       [],\n543:       [makeFeature({ id: \"archived-feat\", status: \"done\", completion: 100 })]\n544:     );\n545:     const doneIds = getDoneFeatureIds(data);\n546:     expect(doneIds.has(\"archived-feat\")).toBe(true);\n547:   });\n548: \n549:   test(\"includes done subtasks\", () => {\n550:     const data = makeFeaturesFile([\n551:       makeFeature({\n552:         id: \"parent\",\n553:         status: \"in_progress\",\n554:         subtasks: [\n555:           {\n556:             id: \"sub-done\",\n557:             title: \"Done sub\",\n558:             description: \"\",\n559:             status: \"done\",\n560:             completion: 100,\n561:             difficulty: \"easy\",\n562:             priority: \"medium\",\n563:             depends_on: [],\n564:             effort: \"PT30M\",\n565:             started_at: null,\n566:             ended_at: null,\n567:             constraints: [],\n568:             forbidden: [],\n569:             references: [],\n570:             notes: [],\n571:             subtasks: [],\n572:           },\n573:         ],\n574:       }),\n575:     ]);\n576:     const doneIds = getDoneFeatureIds(data);\n577:     expect(doneIds.has(\"sub-done\")).toBe(true);\n578:     expect(doneIds.has(\"parent\")).toBe(false);\n579:   });\n580: });\n581: \n582: describe(\"getReadyFeatures\", () => {\n583:   test(\"returns backlog features with deps met\", () => {\n584:     const data = makeFeaturesFile([\n585:       makeFeature({ id: \"ready\", status: \"backlog\", depends_on: [] }),\n586:       makeFeature({\n587:         id: \"blocked\",\n588:         status: \"backlog\",\n589:         depends_on: [\"not-done\"],\n590:       }),\n591:       makeFeature({ id: \"in-progress\", status: \"in_progress\" }),\n592:     ]);\n593:     const ready = getReadyFeatures(data);\n594:     expect(ready).toHaveLength(1);\n595:     expect(ready[0].id).toBe(\"ready\");\n596:   });\n597: \n598:   test(\"considers archived deps as met\", () => {\n599:     const data = makeFeaturesFile(\n600:       [\n601:         makeFeature({\n602:           id: \"waiting\",\n603:           status: \"backlog\",\n604:           depends_on: [\"archived-dep\"],\n605:         }),\n606:       ],\n607:       [\n608:         makeFeature({\n609:           id: \"archived-dep\",\n610:           status: \"done\",\n611:           completion: 100,\n612:         }),\n613:       ]\n614:     );\n615:     const ready = getReadyFeatures(data);\n616:     expect(ready).toHaveLength(1);\n617:     expect(ready[0].id).toBe(\"waiting\");\n618:   });\n619: \n620:   test(\"excludes features with non-zero completion\", () => {\n621:     const data = makeFeaturesFile([\n622:       makeFeature({ id: \"partial\", status: \"backlog\", completion: 50 }),\n623:     ]);\n624:     const ready = getReadyFeatures(data);\n625:     expect(ready).toHaveLength(0);\n626:   });\n627: \n628:   test(\"returns empty array when no features are ready\", () => {\n629:     const data = makeFeaturesFile([\n630:       makeFeature({\n631:         id: \"blocked\",\n632:         status: \"backlog\",\n633:         depends_on: [\"missing\"],\n634:       }),\n635:     ]);\n636:     const ready = getReadyFeatures(data);\n637:     expect(ready).toHaveLength(0);\n638:   });\n639: });\n640: \n641: // ---------------------------------------------------------------------------\n642: // selectFeatures strategies\n643: // ---------------------------------------------------------------------------\n644: \n645: describe(\"selectFeatures\", () => {\n646:   const highPriority = makeFeature({\n647:     id: \"high-pri\",\n648:     priority: \"high\",\n649:     effort: \"PT2H\",\n650:   });\n651:   const criticalSmall = makeFeature({\n652:     id: \"critical-small\",\n653:     priority: \"critical\",\n654:     effort: \"PT30M\",\n655:   });\n656:   const mediumLong = makeFeature({\n657:     id: \"medium-long\",\n658:     priority: \"medium\",\n659:     effort: \"P1D\",\n660:   });\n661:   const lowQuick = makeFeature({\n662:     id: \"low-quick\",\n663:     priority: \"low\",\n664:     effort: \"PT15M\",\n665:     difficulty: \"easy\",\n666:   });\n667: \n668:   const data = makeFeaturesFile([highPriority, criticalSmall, mediumLong, lowQuick]);\n669: \n670:   test(\"allReady returns all ready features sorted by priority\", () => {\n671:     const selected = selectFeatures(data, { allReady: true });\n672:     expect(selected).toHaveLength(4);\n673:     expect(selected[0].id).toBe(\"critical-small\");\n674:     expect(selected[1].id).toBe(\"high-pri\");\n675:   });\n676: \n677:   test(\"topPriority selects top N by priority\", () => {\n678:     const selected = selectFeatures(data, { topPriority: 2 });\n679:     expect(selected).toHaveLength(2);\n680:     expect(selected[0].id).toBe(\"critical-small\");\n681:     expect(selected[1].id).toBe(\"high-pri\");\n682:   });\n683: \n684:   test(\"quickestWins selects N lowest effort\", () => {\n685:     const selected = selectFeatures(data, { quickestWins: 2 });\n686:     expect(selected).toHaveLength(2);\n687:     // Sorted by effort: 15m, 30m, 2h, 1d\n688:     expect(selected[0].id).toBe(\"low-quick\");\n689:     expect(selected[1].id).toBe(\"critical-small\");\n690:   });\n691: \n692:   test(\"priority filter selects matching priority\", () => {\n693:     const selected = selectFeatures(data, { priority: \"high\" });\n694:     expect(selected).toHaveLength(1);\n695:     expect(selected[0].id).toBe(\"high-pri\");\n696:   });\n697: \n698:   test(\"difficulty filter selects matching difficulty\", () => {\n699:     const selected = selectFeatures(data, { difficulty: \"easy\" });\n700:     expect(selected).toHaveLength(1);\n701:     expect(selected[0].id).toBe(\"low-quick\");\n702:   });\n703: \n704:   test(\"featureIds selects specific features (backward compat)\", () => {\n705:     const selected = selectFeatures(data, {\n706:       featureIds: [\"high-pri\", \"low-quick\"],\n707:     });\n708:     expect(selected).toHaveLength(2);\n709:   });\n710: \n711:   test(\"featureIds with nonexistent IDs still returns valid ones\", () => {\n712:     const selected = selectFeatures(data, {\n713:       featureIds: [\"high-pri\", \"nonexistent\"],\n714:     });\n715:     expect(selected).toHaveLength(1);\n716:     expect(selected[0].id).toBe(\"high-pri\");\n717:   });\n718: \n719:   test(\"default returns all ready sorted by priority\", () => {\n720:     const selected = selectFeatures(data, {});\n721:     expect(selected).toHaveLength(4);\n722:     expect(selected[0].id).toBe(\"critical-small\");\n723:   });\n724: });\n725: \n726: // ---------------------------------------------------------------------------\n727: // createBlankFeature\n728: // ---------------------------------------------------------------------------\n729: \n730: describe(\"createBlankFeature\", () => {\n731:   test(\"creates feature with default values\", () => {\n732:     const f = createBlankFeature(\"my-feat\", \"My Feature\");\n733:     expect(f.id).toBe(\"my-feat\");\n734:     expect(f.title).toBe(\"My Feature\");\n735:     expect(f.status).toBe(\"backlog\");\n736:     expect(f.completion).toBe(0);\n737:     expect(f.difficulty).toBe(\"medium\");\n738:     expect(f.priority).toBe(\"medium\");\n739:     expect(f.effort).toBe(\"PT1H\");\n740:     expect(f.depends_on).toEqual([]);\n741:     expect(f.subtasks).toEqual([]);\n742:   });\n743: \n744:   test(\"creates feature with custom options\", () => {\n745:     const f = createBlankFeature(\"my-feat\", \"My Feature\", \"Description\", {\n746:       priority: \"critical\",\n747:       difficulty: \"hard\",\n748:       effort: \"P2D\",\n749:     });\n750:     expect(f.priority).toBe(\"critical\");\n751:     expect(f.difficulty).toBe(\"hard\");\n752:     expect(f.effort).toBe(\"P2D\");\n753:     expect(f.description).toBe(\"Description\");\n754:   });\n755: });\n756: \n757: // ---------------------------------------------------------------------------\n758: // findFeatureById\n759: // ---------------------------------------------------------------------------\n760: \n761: describe(\"findFeatureById\", () => {\n762:   test(\"finds top-level feature\", () => {\n763:     const data = makeFeaturesFile([makeFeature({ id: \"target\" })]);\n764:     const found = findFeatureById(data, \"target\");\n765:     expect(found).toBeDefined();\n766:     expect(found!.id).toBe(\"target\");\n767:   });\n768: \n769:   test(\"finds feature in archive\", () => {\n770:     const data = makeFeaturesFile(\n771:       [],\n772:       [makeFeature({ id: \"archived\" })]\n773:     );\n774:     const found = findFeatureById(data, \"archived\");\n775:     expect(found).toBeDefined();\n776:     expect(found!.id).toBe(\"archived\");\n777:   });\n778: \n779:   test(\"finds nested subtask\", () => {\n780:     const data = makeFeaturesFile([\n781:       makeFeature({\n782:         id: \"parent\",\n783:         subtasks: [\n784:           {\n785:             id: \"nested-sub\",\n786:             title: \"Nested\",\n787:             description: \"\",\n788:             status: \"backlog\",\n789:             completion: 0,\n790:             difficulty: \"easy\",\n791:             priority: \"medium\",\n792:             depends_on: [],\n793:             effort: \"PT30M\",\n794:             started_at: null,\n795:             ended_at: null,\n796:             constraints: [],\n797:             forbidden: [],\n798:             references: [],\n799:             notes: [],\n800:             subtasks: [],\n801:           },\n802:         ],\n803:       }),\n804:     ]);\n805:     const found = findFeatureById(data, \"nested-sub\");\n806:     expect(found).toBeDefined();\n807:     expect(found!.id).toBe(\"nested-sub\");\n808:   });\n809: \n810:   test(\"returns undefined for nonexistent ID\", () => {\n811:     const data = makeFeaturesFile([makeFeature({ id: \"exists\" })]);\n812:     const found = findFeatureById(data, \"nonexistent\");\n813:     expect(found).toBeUndefined();\n814:   });\n815: });\n816: \n817: // ---------------------------------------------------------------------------\n818: // allFeatureIds\n819: // ---------------------------------------------------------------------------\n820: \n821: describe(\"allFeatureIds\", () => {\n822:   test(\"collects all IDs including subtasks and archive\", () => {\n823:     const data = makeFeaturesFile(\n824:       [\n825:         makeFeature({\n826:           id: \"feat-a\",\n827:           subtasks: [\n828:             {\n829:               id: \"sub-1\",\n830:               title: \"Sub\",\n831:               description: \"\",\n832:               status: \"backlog\",\n833:               completion: 0,\n834:               difficulty: \"easy\",\n835:               priority: \"medium\",\n836:               depends_on: [],\n837:               effort: \"PT30M\",\n838:               started_at: null,\n839:               ended_at: null,\n840:               constraints: [],\n841:               forbidden: [],\n842:               references: [],\n843:               notes: [],\n844:               subtasks: [],\n845:             },\n846:           ],\n847:         }),\n848:       ],\n849:       [makeFeature({ id: \"archived\" })]\n850:     );\n851:     const ids = allFeatureIds(data);\n852:     expect(ids).toContain(\"feat-a\");\n853:     expect(ids).toContain(\"sub-1\");\n854:     expect(ids).toContain(\"archived\");\n855:   });\n856: });\n857: \n858: // ---------------------------------------------------------------------------\n859: // featureSummary\n860: // ---------------------------------------------------------------------------\n861: \n862: describe(\"featureSummary\", () => {\n863:   test(\"produces formatted summary string\", () => {\n864:     const f = makeFeature({\n865:       id: \"auth-flow\",\n866:       title: \"Auth Flow\",\n867:       priority: \"high\",\n868:       difficulty: \"medium\",\n869:       effort: \"PT2H\",\n870:     });\n871:     const summary = featureSummary(f);\n872:     expect(summary).toContain(\"[high/medium]\");\n873:     expect(summary).toContain(\"auth-flow\");\n874:     expect(summary).toContain(\"Auth Flow\");\n875:     expect(summary).toContain(\"2h\");\n876:   });\n877: });\n878: \n879: // ---------------------------------------------------------------------------\n880: // Priority and Difficulty orderings\n881: // ---------------------------------------------------------------------------\n882: \n883: describe(\"PRIORITY_ORDER\", () => {\n884:   test(\"critical < high < medium < low < wishlist\", () => {\n885:     expect(PRIORITY_ORDER.critical).toBeLessThan(PRIORITY_ORDER.high);\n886:     expect(PRIORITY_ORDER.high).toBeLessThan(PRIORITY_ORDER.medium);\n887:     expect(PRIORITY_ORDER.medium).toBeLessThan(PRIORITY_ORDER.low);\n888:     expect(PRIORITY_ORDER.low).toBeLessThan(PRIORITY_ORDER.wishlist);\n889:   });\n890: });\n891: \n892: describe(\"DIFFICULTY_ORDER\", () => {\n893:   test(\"trivial < easy < medium < hard < very_hard\", () => {\n894:     expect(DIFFICULTY_ORDER.trivial).toBeLessThan(DIFFICULTY_ORDER.easy);\n895:     expect(DIFFICULTY_ORDER.easy).toBeLessThan(DIFFICULTY_ORDER.medium);\n896:     expect(DIFFICULTY_ORDER.medium).toBeLessThan(DIFFICULTY_ORDER.hard);\n897:     expect(DIFFICULTY_ORDER.hard).toBeLessThan(DIFFICULTY_ORDER.very_hard);\n898:   });\n899: });\n\n(End of file - total 899 lines)\n</content>","title":"tests/features.test.ts","metadata":{"preview":"/**\n * features.test.ts — Unit tests for tasks YAML parsing, validation,\n * duration parsing, and dependency resolution.\n *\n * Coverage:\n *   - loadFeatures with null tasks, empty arrays, valid data\n *   - parseDurationMinutes for ISO 8601 durations\n *   - formatDuration for human-readable output\n *   - Dependency resolution (areDependenciesMet, getReadyFeatures)\n *   - normalizeTask defaults\n *   - createBlankFeature\n *   - findFeatureById (recursive search)\n *   - selectFeatures strategies\n *   - YAML schema edge cases\n */\n\nimport { describe, test, expect, beforeEach, afterEach } from \"bun:test\";\nimport { mkdtempSync, writeFileSync, rmSync, mkdirSync } from \"node:fs\";\nimport { join } from \"node:path\";\nimport { tmpdir } from \"node:os\";","truncated":false,"loaded":[]},"time":{"start":1773445795135,"end":1773445795138}}}}
