{"type":"tool_use","timestamp":1773445263337,"sessionID":"ses_316701812ffeYe5yCqGzB5GjN6","part":{"id":"prt_ce992a271001gMIkO0NPgI4DDj","sessionID":"ses_316701812ffeYe5yCqGzB5GjN6","messageID":"msg_ce992994a001cgJIFTjpMv6OVv","type":"tool","callID":"toolu_vrtx_01P1yb2GZ3XnXyV417uHk76E","tool":"write","state":{"status":"completed","input":{"content":"/**\n * test-runner.test.ts — Unit tests for test command execution and output parsing.\n *\n * Coverage:\n *   - parseTestCounts: bun test format, jest-like format, unparseable output\n *   - extractTestErrorSummary: error line extraction, fallback to tail\n *   - runTests: real command execution with pass/fail scenarios\n */\n\nimport { describe, test, expect, beforeEach, afterEach } from \"bun:test\";\nimport { mkdtempSync, writeFileSync, rmSync, mkdirSync } from \"node:fs\";\nimport { join } from \"node:path\";\nimport { tmpdir } from \"node:os\";\n\nimport {\n  parseTestCounts,\n  extractTestErrorSummary,\n  runTests,\n  type TestCounts,\n} from \"../src/lib/test-runner.js\";\n\n// ---------------------------------------------------------------------------\n// Helpers\n// ---------------------------------------------------------------------------\n\nlet tmpDir: string;\n\nbeforeEach(() => {\n  tmpDir = mkdtempSync(join(tmpdir(), \"wombo-test-runner-\"));\n});\n\nafterEach(() => {\n  rmSync(tmpDir, { recursive: true, force: true });\n});\n\n// ---------------------------------------------------------------------------\n// parseTestCounts — Bun test format\n// ---------------------------------------------------------------------------\n\ndescribe(\"parseTestCounts\", () => {\n  describe(\"bun test format\", () => {\n    test(\"parses pass and fail counts\", () => {\n      const result = parseTestCounts(\"42 pass\\n3 fail\", \"\");\n      expect(result.parsed).toBe(true);\n      expect(result.passed).toBe(42);\n      expect(result.failed).toBe(3);\n      expect(result.total).toBe(45);\n    });\n\n    test(\"parses pass, fail, and skip counts\", () => {\n      const result = parseTestCounts(\"10 pass\\n2 fail\\n1 skip\", \"\");\n      expect(result.parsed).toBe(true);\n      expect(result.passed).toBe(10);\n      expect(result.failed).toBe(2);\n      expect(result.skipped).toBe(1);\n      expect(result.total).toBe(13);\n    });\n\n    test(\"parses pass only (zero failures)\", () => {\n      const result = parseTestCounts(\"100 pass\", \"\");\n      expect(result.parsed).toBe(true);\n      expect(result.passed).toBe(100);\n      expect(result.failed).toBe(0);\n      expect(result.total).toBe(100);\n    });\n\n    test(\"parses fail only (zero passes)\", () => {\n      const result = parseTestCounts(\"5 fail\", \"\");\n      expect(result.parsed).toBe(true);\n      expect(result.passed).toBe(0);\n      expect(result.failed).toBe(5);\n      expect(result.total).toBe(5);\n    });\n\n    test(\"handles pass/fail on the same line\", () => {\n      const result = parseTestCounts(\"42 pass, 3 fail\", \"\");\n      expect(result.parsed).toBe(true);\n      expect(result.passed).toBe(42);\n      expect(result.failed).toBe(3);\n    });\n\n    test(\"case insensitive matching\", () => {\n      const result = parseTestCounts(\"42 PASS\\n3 FAIL\", \"\");\n      expect(result.parsed).toBe(true);\n      expect(result.passed).toBe(42);\n      expect(result.failed).toBe(3);\n    });\n\n    test(\"parses from stderr when stdout is empty\", () => {\n      const result = parseTestCounts(\"\", \"10 pass\\n2 fail\");\n      expect(result.parsed).toBe(true);\n      expect(result.passed).toBe(10);\n      expect(result.failed).toBe(2);\n    });\n  });\n\n  describe(\"jest-like format\", () => {\n    test(\"parses Tests: X passed, Y failed, Z total\", () => {\n      const result = parseTestCounts(\n        \"Tests: 15 passed, 3 failed, 18 total\",\n        \"\"\n      );\n      expect(result.parsed).toBe(true);\n      expect(result.passed).toBe(15);\n      expect(result.failed).toBe(3);\n      expect(result.total).toBe(18);\n    });\n\n    test(\"parses Tests: X passed (no failures)\", () => {\n      const result = parseTestCounts(\n        \"Tests: 25 passed, 25 total\",\n        \"\"\n      );\n      expect(result.parsed).toBe(true);\n      expect(result.passed).toBe(25);\n      expect(result.failed).toBe(0);\n    });\n\n    test(\"parses Tests: X passed, Y failed, Z skipped, W total\", () => {\n      const result = parseTestCounts(\n        \"Tests: 10 passed, 2 failed, 3 skipped, 15 total\",\n        \"\"\n      );\n      expect(result.parsed).toBe(true);\n      expect(result.passed).toBe(10);\n      expect(result.failed).toBe(2);\n      expect(result.skipped).toBe(3);\n      expect(result.total).toBe(15);\n    });\n  });\n\n  describe(\"unparseable output\", () => {\n    test(\"returns parsed=false for empty output\", () => {\n      const result = parseTestCounts(\"\", \"\");\n      expect(result.parsed).toBe(false);\n      expect(result.total).toBe(0);\n    });\n\n    test(\"returns parsed=false for no test count output\", () => {\n      const result = parseTestCounts(\"Build completed successfully\", \"\");\n      expect(result.parsed).toBe(false);\n      expect(result.total).toBe(0);\n    });\n\n    test(\"returns all zeros for unparseable output\", () => {\n      const result = parseTestCounts(\"some random output\", \"\");\n      expect(result.passed).toBe(0);\n      expect(result.failed).toBe(0);\n      expect(result.skipped).toBe(0);\n    });\n  });\n});\n\n// ---------------------------------------------------------------------------\n// extractTestErrorSummary\n// ---------------------------------------------------------------------------\n\ndescribe(\"extractTestErrorSummary\", () => {\n  test(\"extracts lines containing 'error'\", () => {\n    const stdout = \"test 1 passed\\nerror: something broke\\ntest 3 passed\";\n    const result = extractTestErrorSummary(stdout, \"\");\n    expect(result).toContain(\"error: something broke\");\n  });\n\n  test(\"extracts lines containing 'FAIL'\", () => {\n    const stdout = \"FAIL src/foo.test.ts\\n  expected 1 but got 2\";\n    const result = extractTestErrorSummary(stdout, \"\");\n    expect(result).toContain(\"FAIL\");\n  });\n\n  test(\"captures context lines after error\", () => {\n    const stdout = [\n      \"test 1 passed\",\n      \"error: assertion failed\",\n      \"  expected: 42\",\n      \"  received: 0\",\n      \"  at test.ts:10\",\n      \"test 2 passed\",\n    ].join(\"\\n\");\n    const result = extractTestErrorSummary(stdout, \"\");\n    expect(result).toContain(\"expected: 42\");\n    expect(result).toContain(\"received: 0\");\n  });\n\n  test(\"falls back to last 30 lines when no error patterns found\", () => {\n    const lines = Array.from({ length: 50 }, (_, i) => `line ${i + 1}`);\n    const result = extractTestErrorSummary(lines.join(\"\\n\"), \"\");\n    // Should contain lines from near the end\n    expect(result).toContain(\"line 50\");\n    expect(result).toContain(\"line 21\");\n  });\n\n  test(\"truncates very long error output\", () => {\n    const longError = \"error: \" + \"x\".repeat(5000);\n    const result = extractTestErrorSummary(longError, \"\");\n    expect(result.length).toBeLessThanOrEqual(3100); // 3000 + \"[... truncated]\"\n  });\n\n  test(\"combines stdout and stderr\", () => {\n    const result = extractTestErrorSummary(\"\", \"error in stderr\");\n    expect(result).toContain(\"error in stderr\");\n  });\n\n  test(\"extracts expect() assertion errors\", () => {\n    const stdout = \"test 1\\nexpect(received).toBe(expected)\\n  Expected: true\\n  Received: false\";\n    const result = extractTestErrorSummary(stdout, \"\");\n    expect(result).toContain(\"expect(received)\");\n  });\n});\n\n// ---------------------------------------------------------------------------\n// runTests — Integration test with real command execution\n// ---------------------------------------------------------------------------\n\ndescribe(\"runTests\", () => {\n  test(\"returns passed=true for successful command\", async () => {\n    const result = await runTests(tmpDir, \"echo 'all good'\");\n    expect(result.passed).toBe(true);\n    expect(result.exitCode).toBe(0);\n    expect(result.durationMs).toBeGreaterThanOrEqual(0);\n  });\n\n  test(\"returns passed=false for failing command\", async () => {\n    const result = await runTests(tmpDir, \"exit 1\");\n    expect(result.passed).toBe(false);\n    expect(result.exitCode).not.toBe(0);\n  });\n\n  test(\"captures stdout\", async () => {\n    const result = await runTests(tmpDir, \"echo 'hello world'\");\n    expect(result.stdout).toContain(\"hello world\");\n  });\n\n  test(\"captures stderr\", async () => {\n    const result = await runTests(tmpDir, \"echo 'error output' >&2\");\n    expect(result.stderr).toContain(\"error output\");\n  });\n\n  test(\"parses test counts from output\", async () => {\n    const result = await runTests(tmpDir, \"echo '10 pass\\n2 fail'\");\n    expect(result.testCounts.parsed).toBe(true);\n    expect(result.testCounts.passed).toBe(10);\n    expect(result.testCounts.failed).toBe(2);\n  });\n\n  test(\"provides error summary for failing tests\", async () => {\n    const result = await runTests(\n      tmpDir,\n      \"echo 'error: assertion failed' && exit 1\"\n    );\n    expect(result.passed).toBe(false);\n    expect(result.errorSummary).toContain(\"error\");\n  });\n\n  test(\"provides empty error summary for passing tests\", async () => {\n    const result = await runTests(tmpDir, \"echo 'all good'\");\n    expect(result.errorSummary).toBe(\"\");\n  });\n\n  test(\"measures duration\", async () => {\n    const result = await runTests(tmpDir, \"sleep 0.1 && echo done\");\n    expect(result.durationMs).toBeGreaterThanOrEqual(50);\n  });\n\n  test(\"respects timeout\", async () => {\n    // Use a very short timeout\n    const result = await runTests(tmpDir, \"sleep 10\", 500);\n    expect(result.passed).toBe(false);\n  }, 5000);\n\n  test(\"handles non-existent command gracefully\", async () => {\n    const result = await runTests(tmpDir, \"nonexistent-cmd-xyz-123\");\n    expect(result.passed).toBe(false);\n  });\n});\n","filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/tdd-red-green-coercion/tests/test-runner.test.ts"},"output":"Wrote file successfully.\n\nLSP errors detected in other files:\n<diagnostics file=\"/home/fulgidus/Documents/wombo-combo-worktrees/tdd-red-green-coercion/tests/config.test.ts\">\nERROR [123:23] Property 'worktreePrefix' does not exist on type '{ branchPrefix: string; remote: string; mergeStrategy: string; }'.\nERROR [231:16] Property 'worktreePrefix' does not exist on type '{ branchPrefix: string; remote: string; mergeStrategy: string; }'.\n</diagnostics>","title":"tests/test-runner.test.ts","metadata":{"diagnostics":{"/home/fulgidus/Documents/wombo-combo-worktrees/tdd-red-green-coercion/src/lib/prompt.ts":[],"/home/fulgidus/Documents/wombo-combo-worktrees/tdd-red-green-coercion/src/config.ts":[],"/home/fulgidus/Documents/wombo-combo-worktrees/tdd-red-green-coercion/src/lib/verifier.ts":[],"/home/fulgidus/Documents/wombo-combo-worktrees/tdd-red-green-coercion/src/lib/test-runner.ts":[],"/home/fulgidus/Documents/wombo-combo-worktrees/tdd-red-green-coercion/src/lib/tdd-verifier.ts":[],"/home/fulgidus/Documents/wombo-combo-worktrees/tdd-red-green-coercion/src/lib/test-detection.ts":[{"range":{"start":{"line":16,"character":37},"end":{"line":16,"character":45}},"message":"'relative' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"}],"/home/fulgidus/Documents/wombo-combo-worktrees/tdd-red-green-coercion/src/commands/verify.ts":[],"/home/fulgidus/Documents/wombo-combo-worktrees/tdd-red-green-coercion/src/index.ts":[{"range":{"start":{"line":626,"character":10},"end":{"line":626,"character":16}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":646,"charact