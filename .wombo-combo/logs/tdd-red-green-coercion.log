{"type":"tool_use","timestamp":1773445073714,"sessionID":"ses_316701812ffeYe5yCqGzB5GjN6","part":{"id":"prt_ce9904466001gRfo1Yanw28f6m","sessionID":"ses_316701812ffeYe5yCqGzB5GjN6","messageID":"msg_ce9903a160011U4PefcGy3bNR7","type":"tool","callID":"toolu_vrtx_01S5GGDHVx5SLXC54LxfpVeP","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/tdd-red-green-coercion/tests/config.test.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/tdd-red-green-coercion/tests/config.test.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * config.test.ts — Unit tests for config.ts (loadConfig, validateConfig, deepMerge).\n3:  *\n4:  * Coverage:\n5:  *   - loadConfig: returns defaults when no config file, merges partial config,\n6:  *     deep-merges nested objects, handles legacy tasksFile/archiveFile migration,\n7:  *     throws on invalid JSON\n8:  *   - validateConfig: validates required fields, numeric constraints, enum values\n9:  *   - DEFAULT_CONFIG: sensible defaults for all fields\n10:  *   - generateDefaultConfig: returns valid JSON string\n11:  */\n12: \n13: import { describe, test, expect, beforeEach, afterEach } from \"bun:test\";\n14: import { mkdtempSync, writeFileSync, rmSync, mkdirSync } from \"node:fs\";\n15: import { join } from \"node:path\";\n16: import { tmpdir } from \"node:os\";\n17: import {\n18:   loadConfig,\n19:   validateConfig,\n20:   DEFAULT_CONFIG,\n21:   CONFIG_FILE,\n22:   WOMBO_DIR,\n23:   generateDefaultConfig,\n24: } from \"../src/config.js\";\n25: import type { WomboConfig } from \"../src/config.js\";\n26: \n27: // ---------------------------------------------------------------------------\n28: // Helpers\n29: // ---------------------------------------------------------------------------\n30: \n31: let tmpDir: string;\n32: \n33: beforeEach(() => {\n34:   tmpDir = mkdtempSync(join(tmpdir(), \"wombo-test-config-\"));\n35: });\n36: \n37: afterEach(() => {\n38:   rmSync(tmpDir, { recursive: true, force: true });\n39: });\n40: \n41: function writeConfig(dir: string, config: Record<string, unknown>): void {\n42:   mkdirSync(join(dir, WOMBO_DIR), { recursive: true });\n43:   writeFileSync(\n44:     join(dir, CONFIG_FILE),\n45:     JSON.stringify(config, null, 2)\n46:   );\n47: }\n48: \n49: // ---------------------------------------------------------------------------\n50: // DEFAULT_CONFIG\n51: // ---------------------------------------------------------------------------\n52: \n53: describe(\"DEFAULT_CONFIG\", () => {\n54:   test(\"has all required top-level fields\", () => {\n55:     expect(DEFAULT_CONFIG.tasksDir).toBe(\"tasks\");\n56:     expect(DEFAULT_CONFIG.archiveDir).toBe(\"archive\");\n57:     expect(DEFAULT_CONFIG.baseBranch).toBeDefined();\n58:     expect(DEFAULT_CONFIG.build).toBeDefined();\n59:     expect(DEFAULT_CONFIG.install).toBeDefined();\n60:     expect(DEFAULT_CONFIG.git).toBeDefined();\n61:     expect(DEFAULT_CONFIG.agent).toBeDefined();\n62:     expect(DEFAULT_CONFIG.portless).toBeDefined();\n63:     expect(DEFAULT_CONFIG.backup).toBeDefined();\n64:     expect(DEFAULT_CONFIG.defaults).toBeDefined();\n65:     expect(DEFAULT_CONFIG.browser).toBeDefined();\n66:     expect(DEFAULT_CONFIG.agentRegistry).toBeDefined();\n67:     expect(DEFAULT_CONFIG.tdd).toBeDefined();\n68:   });\n69: \n70:   test(\"passes its own validateConfig\", () => {\n71:     expect(() => validateConfig(DEFAULT_CONFIG)).not.toThrow();\n72:   });\n73: \n74:   test(\"has sensible numeric defaults\", () => {\n75:     expect(DEFAULT_CONFIG.defaults.maxConcurrent).toBeGreaterThanOrEqual(1);\n76:     expect(DEFAULT_CONFIG.defaults.maxRetries).toBeGreaterThanOrEqual(0);\n77:     expect(DEFAULT_CONFIG.backup.maxBackups).toBeGreaterThanOrEqual(0);\n78:     expect(DEFAULT_CONFIG.build.timeout).toBeGreaterThan(0);\n79:     expect(DEFAULT_CONFIG.install.timeout).toBeGreaterThan(0);\n80:   });\n81: });\n82: \n83: // ---------------------------------------------------------------------------\n84: // loadConfig\n85: // ---------------------------------------------------------------------------\n86: \n87: describe(\"loadConfig\", () => {\n88:   test(\"returns defaults when no config file exists\", () => {\n89:     const config = loadConfig(tmpDir);\n90:     expect(config.baseBranch).toBe(DEFAULT_CONFIG.baseBranch);\n91:     expect(config.build.command).toBe(DEFAULT_CONFIG.build.command);\n92:     expect(config.git.branchPrefix).toBe(DEFAULT_CONFIG.git.branchPrefix);\n93:     expect(config.tdd.enabled).toBe(false);\n94:   });\n95: \n96:   test(\"merges partial config with defaults\", () => {\n97:     writeConfig(tmpDir, { baseBranch: \"custom-main\" });\n98:     const config = loadConfig(tmpDir);\n99:     // Custom value\n100:     expect(config.baseBranch).toBe(\"custom-main\");\n101:     // Defaults preserved\n102:     expect(config.build.command).toBe(DEFAULT_CONFIG.build.command);\n103:     expect(config.git.branchPrefix).toBe(DEFAULT_CONFIG.git.branchPrefix);\n104:   });\n105: \n106:   test(\"deep-merges nested objects\", () => {\n107:     writeConfig(tmpDir, {\n108:       build: { command: \"npm run build\" },\n109:     });\n110:     const config = loadConfig(tmpDir);\n111:     // Custom nested value\n112:     expect(config.build.command).toBe(\"npm run build\");\n113:     // Other nested defaults preserved\n114:     expect(config.build.timeout).toBe(DEFAULT_CONFIG.build.timeout);\n115:     expect(config.build.artifactDir).toBe(DEFAULT_CONFIG.build.artifactDir);\n116:   });\n117: \n118:   test(\"deep-merges git config partially\", () => {\n119:     writeConfig(tmpDir, {\n120:       git: { worktreePrefix: \"custom-\" },\n121:     });\n122:     const config = loadConfig(tmpDir);\n123:     expect(config.git.worktreePrefix).toBe(\"custom-\");\n124:     expect(config.git.branchPrefix).toBe(DEFAULT_CONFIG.git.branchPrefix);\n125:     expect(config.git.remote).toBe(DEFAULT_CONFIG.git.remote);\n126:   });\n127: \n128:   test(\"replaces arrays instead of merging them\", () => {\n129:     writeConfig(tmpDir, {\n130:       agent: { configFiles: [\".custom-config\"] },\n131:     });\n132:     const config = loadConfig(tmpDir);\n133:     expect(config.agent.configFiles).toEqual([\".custom-config\"]);\n134:   });\n135: \n136:   test(\"throws on invalid JSON\", () => {\n137:     mkdirSync(join(tmpDir, WOMBO_DIR), { recursive: true });\n138:     writeFileSync(join(tmpDir, CONFIG_FILE), \"{{not valid json\");\n139:     expect(() => loadConfig(tmpDir)).toThrow();\n140:   });\n141: \n142:   test(\"migrates legacy tasksFile to tasksDir\", () => {\n143:     writeConfig(tmpDir, { tasksFile: \"my-tasks.yml\" });\n144:     const config = loadConfig(tmpDir);\n145:     expect(config.tasksDir).toBe(\"my-tasks\");\n146:   });\n147: \n148:   test(\"migrates legacy archiveFile to archiveDir\", () => {\n149:     writeConfig(tmpDir, { archiveFile: \"my-archive.yaml\" });\n150:     const config = loadConfig(tmpDir);\n151:     expect(config.archiveDir).toBe(\"my-archive\");\n152:   });\n153: \n154:   test(\"does not migrate tasksFile if tasksDir is already set\", () => {\n155:     writeConfig(tmpDir, { tasksFile: \"old.yml\", tasksDir: \"new-dir\" });\n156:     const config = loadConfig(tmpDir);\n157:     expect(config.tasksDir).toBe(\"new-dir\");\n158:   });\n159: \n160:   test(\"deep-merges tdd config\", () => {\n161:     writeConfig(tmpDir, {\n162:       tdd: { enabled: true },\n163:     });\n164:     const config = loadConfig(tmpDir);\n165:     expect(config.tdd.enabled).toBe(true);\n166:     expect(config.tdd.testCommand).toBe(DEFAULT_CONFIG.tdd.testCommand);\n167:   });\n168: \n169:   test(\"deep-merges agentRegistry config\", () => {\n170:     writeConfig(tmpDir, {\n171:       agentRegistry: { mode: \"disabled\" },\n172:     });\n173:     const config = loadConfig(tmpDir);\n174:     expect(config.agentRegistry.mode).toBe(\"disabled\");\n175:     expect(config.agentRegistry.source).toBe(DEFAULT_CONFIG.agentRegistry.source);\n176:     expect(config.agentRegistry.cacheTTL).toBe(DEFAULT_CONFIG.agentRegistry.cacheTTL);\n177:   });\n178: });\n179: \n180: // ---------------------------------------------------------------------------\n181: // validateConfig\n182: // ---------------------------------------------------------------------------\n183: \n184: describe(\"validateConfig\", () => {\n185:   function validConfig(): WomboConfig {\n186:     return JSON.parse(JSON.stringify(DEFAULT_CONFIG)) as WomboConfig;\n187:   }\n188: \n189:   test(\"accepts the default config\", () => {\n190:     expect(() => validateConfig(validConfig())).not.toThrow();\n191:   });\n192: \n193:   test(\"throws on empty tasksDir\", () => {\n194:     const config = validConfig();\n195:     config.tasksDir = \"\";\n196:     expect(() => validateConfig(config)).toThrow(\"tasksDir\");\n197:   });\n198: \n199:   test(\"throws on empty archiveDir\", () => {\n200:     const config = validConfig();\n201:     config.archiveDir = \"\";\n202:     expect(() => validateConfig(config)).toThrow(\"archiveDir\");\n203:   });\n204: \n205:   test(\"throws on empty baseBranch\", () => {\n206:     const config = validConfig();\n207:     config.baseBranch = \"\";\n208:     expect(() => validateConfig(config)).toThrow(\"baseBranch\");\n209:   });\n210: \n211:   test(\"throws on empty build command\", () => {\n212:     const config = validConfig();\n213:     config.build.command = \"\";\n214:     expect(() => validateConfig(config)).toThrow(\"build.command\");\n215:   });\n216: \n217:   test(\"throws on empty install command\", () => {\n218:     const config = validConfig();\n219:     config.install.command = \"\";\n220:     expect(() => validateConfig(config)).toThrow(\"install.command\");\n221:   });\n222: \n223:   test(\"throws on empty branchPrefix\", () => {\n224:     const config = validConfig();\n225:     config.git.branchPrefix = \"\";\n226:     expect(() => validateConfig(config)).toThrow(\"branchPrefix\");\n227:   });\n228: \n229:   test(\"throws on empty worktreePrefix\", () => {\n230:     const config = validConfig();\n231:     config.git.worktreePrefix = \"\";\n232:     expect(() => validateConfig(config)).toThrow(\"worktreePrefix\");\n233:   });\n234: \n235:   test(\"throws on maxConcurrent < 1\", () => {\n236:     const config = validConfig();\n237:     config.defaults.maxConcurrent = 0;\n238:     expect(() => validateConfig(config)).toThrow(\"maxConcurrent\");\n239:   });\n240: \n241:   test(\"throws on negative maxRetries\", () => {\n242:     const config = validConfig();\n243:     config.defaults.maxRetries = -1;\n244:     expect(() => validateConfig(config)).toThrow(\"maxRetries\");\n245:   });\n246: \n247:   test(\"throws on negative maxBackups\", () => {\n248:     const config = validConfig();\n249:     config.backup.maxBackups = -1;\n250:     expect(() => validateConfig(config)).toThrow(\"maxBackups\");\n251:   });\n252: \n253:   test(\"throws on invalid agentRegistry.mode\", () => {\n254:     const config = validConfig();\n255:     (config.agentRegistry as any).mode = \"invalid-mode\";\n256:     expect(() => validateConfig(config)).toThrow(\"mode\");\n257:   });\n258: \n259:   test(\"accepts all valid agentRegistry modes\", () => {\n260:     for (const mode of [\"auto\", \"monitored\", \"disabled\"] as const) {\n261:       const config = validConfig();\n262:       config.agentRegistry.mode = mode;\n263:       expect(() => validateConfig(config)).not.toThrow();\n264:     }\n265:   });\n266: \n267:   test(\"throws on empty agentRegistry.source\", () => {\n268:     const config = validConfig();\n269:     config.agentRegistry.source = \"\";\n270:     expect(() => validateConfig(config)).toThrow(\"source\");\n271:   });\n272: \n273:   test(\"throws on empty agentRegistry.cacheDir\", () => {\n274:     const config = validConfig();\n275:     config.agentRegistry.cacheDir = \"\";\n276:     expect(() => validateConfig(config)).toThrow(\"cacheDir\");\n277:   });\n278: \n279:   test(\"throws when tdd.enabled is true but testCommand is empty\", () => {\n280:     const config = validConfig();\n281:     config.tdd.enabled = true;\n282:     config.tdd.testCommand = \"\";\n283:     expect(() => validateConfig(config)).toThrow(\"testCommand\");\n284:   });\n285: \n286:   test(\"allows empty testCommand when tdd is disabled\", () => {\n287:     const config = validConfig();\n288:     config.tdd.enabled = false;\n289:     config.tdd.testCommand = \"\";\n290:     expect(() => validateConfig(config)).not.toThrow();\n291:   });\n292: });\n293: \n294: // ---------------------------------------------------------------------------\n295: // generateDefaultConfig\n296: // ---------------------------------------------------------------------------\n297: \n298: describe(\"generateDefaultConfig\", () => {\n299:   test(\"returns valid JSON string\", () => {\n300:     const jsonStr = generateDefaultConfig();\n301:     expect(() => JSON.parse(jsonStr)).not.toThrow();\n302:   });\n303: \n304:   test(\"returned JSON matches DEFAULT_CONFIG\", () => {\n305:     const parsed = JSON.parse(generateDefaultConfig());\n306:     expect(parsed.baseBranch).toBe(DEFAULT_CONFIG.baseBranch);\n307:     expect(parsed.build.command).toBe(DEFAULT_CONFIG.build.command);\n308:     expect(parsed.tdd.enabled).toBe(DEFAULT_CONFIG.tdd.enabled);\n309:   });\n310: \n311:   test(\"ends with newline\", () => {\n312:     const jsonStr = generateDefaultConfig();\n313:     expect(jsonStr.endsWith(\"\\n\")).toBe(true);\n314:   });\n315: });\n\n(End of file - total 315 lines)\n</content>","title":"tests/config.test.ts","metadata":{"preview":"/**\n * config.test.ts — Unit tests for config.ts (loadConfig, validateConfig, deepMerge).\n *\n * Coverage:\n *   - loadConfig: returns defaults when no config file, merges partial config,\n *     deep-merges nested objects, handles legacy tasksFile/archiveFile migration,\n *     throws on invalid JSON\n *   - validateConfig: validates required fields, numeric constraints, enum values\n *   - DEFAULT_CONFIG: sensible defaults for all fields\n *   - generateDefaultConfig: returns valid JSON string\n */\n\nimport { describe, test, expect, beforeEach, afterEach } from \"bun:test\";\nimport { mkdtempSync, writeFileSync, rmSync, mkdirSync } from \"node:fs\";\nimport { join } from \"node:path\";\nimport { tmpdir } from \"node:os\";\nimport {\n  loadConfig,\n  validateConfig,\n  DEFAULT_CONFIG,","truncated":false,"loaded":[]},"time":{"start":1773445073710,"end":1773445073713}}}}
