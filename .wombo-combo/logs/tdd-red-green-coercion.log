{"type":"tool_use","timestamp":1773445800514,"sessionID":"ses_316650d1dffespdzjLs3PfWdD3","part":{"id":"prt_ce99b5d9f001rotwAezwFOcj5r","sessionID":"ses_316650d1dffespdzjLs3PfWdD3","messageID":"msg_ce99b4e20001Wgoc3LY4Sah3gf","type":"tool","callID":"toolu_vrtx_01CFks4FnWJR9ynHWdJowNPp","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/tdd-red-green-coercion/tests/config.test.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/tdd-red-green-coercion/tests/config.test.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * config.test.ts — Unit tests for config.ts (loadConfig, validateConfig, deepMerge).\n3:  *\n4:  * Coverage:\n5:  *   - loadConfig: returns defaults when no config file, merges partial config,\n6:  *     deep-merges nested objects, handles legacy tasksFile/archiveFile migration,\n7:  *     throws on invalid JSON\n8:  *   - validateConfig: validates required fields, numeric constraints, enum values\n9:  *   - DEFAULT_CONFIG: sensible defaults for all fields\n10:  *   - generateDefaultConfig: returns valid JSON string\n11:  */\n12: \n13: import { describe, test, expect, beforeEach, afterEach } from \"bun:test\";\n14: import { mkdtempSync, writeFileSync, rmSync, mkdirSync } from \"node:fs\";\n15: import { join } from \"node:path\";\n16: import { tmpdir } from \"node:os\";\n17: import {\n18:   loadConfig,\n19:   validateConfig,\n20:   DEFAULT_CONFIG,\n21:   CONFIG_FILE,\n22:   WOMBO_DIR,\n23:   generateDefaultConfig,\n24: } from \"../src/config.js\";\n25: import type { WomboConfig } from \"../src/config.js\";\n26: \n27: // ---------------------------------------------------------------------------\n28: // Helpers\n29: // ---------------------------------------------------------------------------\n30: \n31: let tmpDir: string;\n32: \n33: beforeEach(() => {\n34:   tmpDir = mkdtempSync(join(tmpdir(), \"wombo-test-config-\"));\n35: });\n36: \n37: afterEach(() => {\n38:   rmSync(tmpDir, { recursive: true, force: true });\n39: });\n40: \n41: function writeConfig(dir: string, config: Record<string, unknown>): void {\n42:   mkdirSync(join(dir, WOMBO_DIR), { recursive: true });\n43:   writeFileSync(\n44:     join(dir, CONFIG_FILE),\n45:     JSON.stringify(config, null, 2)\n46:   );\n47: }\n48: \n49: // ---------------------------------------------------------------------------\n50: // DEFAULT_CONFIG\n51: // ---------------------------------------------------------------------------\n52: \n53: describe(\"DEFAULT_CONFIG\", () => {\n54:   test(\"has all required top-level fields\", () => {\n55:     expect(DEFAULT_CONFIG.tasksDir).toBe(\"tasks\");\n56:     expect(DEFAULT_CONFIG.archiveDir).toBe(\"archive\");\n57:     expect(DEFAULT_CONFIG.baseBranch).toBeDefined();\n58:     expect(DEFAULT_CONFIG.build).toBeDefined();\n59:     expect(DEFAULT_CONFIG.install).toBeDefined();\n60:     expect(DEFAULT_CONFIG.git).toBeDefined();\n61:     expect(DEFAULT_CONFIG.agent).toBeDefined();\n62:     expect(DEFAULT_CONFIG.portless).toBeDefined();\n63:     expect(DEFAULT_CONFIG.backup).toBeDefined();\n64:     expect(DEFAULT_CONFIG.defaults).toBeDefined();\n65:     expect(DEFAULT_CONFIG.browser).toBeDefined();\n66:     expect(DEFAULT_CONFIG.agentRegistry).toBeDefined();\n67:     expect(DEFAULT_CONFIG.tdd).toBeDefined();\n68:   });\n69: \n70:   test(\"passes its own validateConfig\", () => {\n71:     expect(() => validateConfig(DEFAULT_CONFIG)).not.toThrow();\n72:   });\n73: \n74:   test(\"has sensible numeric defaults\", () => {\n75:     expect(DEFAULT_CONFIG.defaults.maxConcurrent).toBeGreaterThanOrEqual(1);\n76:     expect(DEFAULT_CONFIG.defaults.maxRetries).toBeGreaterThanOrEqual(0);\n77:     expect(DEFAULT_CONFIG.backup.maxBackups).toBeGreaterThanOrEqual(0);\n78:     expect(DEFAULT_CONFIG.build.timeout).toBeGreaterThan(0);\n79:     expect(DEFAULT_CONFIG.install.timeout).toBeGreaterThan(0);\n80:   });\n81: });\n82: \n83: // ---------------------------------------------------------------------------\n84: // loadConfig\n85: // ---------------------------------------------------------------------------\n86: \n87: describe(\"loadConfig\", () => {\n88:   test(\"returns defaults when no config file exists\", () => {\n89:     const config = loadConfig(tmpDir);\n90:     expect(config.baseBranch).toBe(DEFAULT_CONFIG.baseBranch);\n91:     expect(config.build.command).toBe(DEFAULT_CONFIG.build.command);\n92:     expect(config.git.branchPrefix).toBe(DEFAULT_CONFIG.git.branchPrefix);\n93:     expect(config.tdd.enabled).toBe(false);\n94:   });\n95: \n96:   test(\"merges partial config with defaults\", () => {\n97:     writeConfig(tmpDir, { baseBranch: \"custom-main\" });\n98:     const config = loadConfig(tmpDir);\n99:     // Custom value\n100:     expect(config.baseBranch).toBe(\"custom-main\");\n101:     // Defaults preserved\n102:     expect(config.build.command).toBe(DEFAULT_CONFIG.build.command);\n103:     expect(config.git.branchPrefix).toBe(DEFAULT_CONFIG.git.branchPrefix);\n104:   });\n105: \n106:   test(\"deep-merges nested objects\", () => {\n107:     writeConfig(tmpDir, {\n108:       build: { command: \"npm run build\" },\n109:     });\n110:     const config = loadConfig(tmpDir);\n111:     // Custom nested value\n112:     expect(config.build.command).toBe(\"npm run build\");\n113:     // Other nested defaults preserved\n114:     expect(config.build.timeout).toBe(DEFAULT_CONFIG.build.timeout);\n115:     expect(config.build.artifactDir).toBe(DEFAULT_CONFIG.build.artifactDir);\n116:   });\n117: \n118:   test(\"deep-merges git config partially\", () => {\n119:     writeConfig(tmpDir, {\n120:       git: { worktreePrefix: \"custom-\" },\n121:     });\n122:     const config = loadConfig(tmpDir);\n123:     expect(config.git.worktreePrefix).toBe(\"custom-\");\n124:     expect(config.git.branchPrefix).toBe(DEFAULT_CONFIG.git.branchPrefix);\n125:     expect(config.git.remote).toBe(DEFAULT_CONFIG.git.remote);\n126:   });\n127: \n128:   test(\"replaces arrays instead of merging them\", () => {\n129:     writeConfig(tmpDir, {\n130:       agent: { configFiles: [\".custom-config\"] },\n131:     });\n132:     const config = loadConfig(tmpDir);\n133:     expect(config.agent.configFiles).toEqual([\".custom-config\"]);\n134:   });\n135: \n136:   test(\"throws on invalid JSON\", () => {\n137:     mkdirSync(join(tmpDir, WOMBO_DIR), { recursive: true });\n138:     writeFileSync(join(tmpDir, CONFIG_FILE), \"{{not valid json\");\n139:     expect(() => loadConfig(tmpDir)).toThrow();\n140:   });\n141: \n142:   test(\"migrates legacy tasksFile to tasksDir\", () => {\n143:     writeConfig(tmpDir, { tasksFile: \"my-tasks.yml\" });\n144:     const config = loadConfig(tmpDir);\n145:     expect(config.tasksDir).toBe(\"my-tasks\");\n146:   });\n147: \n148:   test(\"migrates legacy archiveFile to archiveDir\", () => {\n149:     writeConfig(tmpDir, { archiveFile: \"my-archive.yaml\" });\n150:     const config = loadConfig(tmpDir);\n151:     expect(config.archiveDir).toBe(\"my-archive\");\n152:   });\n153: \n154:   test(\"does not migrate tasksFile if tasksDir is already set\", () => {\n155:     writeConfig(tmpDir, { tasksFile: \"old.yml\", tasksDir: \"new-dir\" });\n156:     const config = loadConfig(tmpDir);\n157:     expect(config.tasksDir).toBe(\"new-dir\");\n158:   });\n159: \n160:   test(\"deep-merges tdd config\", () => {\n161:     writeConfig(tmpDir, {\n162:       tdd: { enabled: true },\n163:     });\n164:     const config = loadConfig(tmpDir);\n165:     expect(config.tdd.enabled).toBe(true);\n166:     expect(config.tdd.testCommand).toBe(DEFAULT_CONFIG.tdd.testCommand);\n167:   });\n168: \n169:   test(\"deep-merges agentRegistry config\", () => {\n170:     writeConfig(tmpDir, {\n171:       agentRegistry: { mode: \"disabled\" },\n172:     });\n173:     const config = loadConfig(tmpDir);\n174:     expect(config.agentRegistry.mode).toBe(\"disabled\");\n175:     expect(config.agentRegistry.source).toBe(DEFAULT_CONFIG.agentRegistry.source);\n176:     expect(config.agentRegistry.cacheTTL).toBe(DEFAULT_CONFIG.agentRegistry.cacheTTL);\n177:   });\n178: });\n179: \n180: // ---------------------------------------------------------------------------\n181: // validateConfig\n182: // ---------------------------------------------------------------------------\n183: \n184: describe(\"validateConfig\", () => {\n185:   function validConfig(): WomboConfig {\n186:     return JSON.parse(JSON.stringify(DEFAULT_CONFIG)) as WomboConfig;\n187:   }\n188: \n189:   test(\"accepts the default config\", () => {\n190:     expect(() => validateConfig(validConfig())).not.toThrow();\n191:   });\n192: \n193:   test(\"throws on empty tasksDir\", () => {\n194:     const config = validConfig();\n195:     config.tasksDir = \"\";\n196:     expect(() => validateConfig(config)).toThrow(\"tasksDir\");\n197:   });\n198: \n199:   test(\"throws on empty archiveDir\", () => {\n200:     const config = validConfig();\n201:     config.archiveDir = \"\";\n202:     expect(() => validateConfig(config)).toThrow(\"archiveDir\");\n203:   });\n204: \n205:   test(\"throws on empty baseBranch\", () => {\n206:     const config = validConfig();\n207:     config.baseBranch = \"\";\n208:     expect(() => validateConfig(config)).toThrow(\"baseBranch\");\n209:   });\n210: \n211:   test(\"throws on empty build command\", () => {\n212:     const config = validConfig();\n213:     config.build.command = \"\";\n214:     expect(() => validateConfig(config)).toThrow(\"build.command\");\n215:   });\n216: \n217:   test(\"throws on empty install command\", () => {\n218:     const config = validConfig();\n219:     config.install.command = \"\";\n220:     expect(() => validateConfig(config)).toThrow(\"install.command\");\n221:   });\n222: \n223:   test(\"throws on empty branchPrefix\", () => {\n224:     const config = validConfig();\n225:     config.git.branchPrefix = \"\";\n226:     expect(() => validateConfig(config)).toThrow(\"branchPrefix\");\n227:   });\n228: \n229:   test(\"throws on empty worktreePrefix\", () => {\n230:     const config = validConfig();\n231:     config.git.worktreePrefix = \"\";\n232:     expect(() => validateConfig(config)).toThrow(\"worktreePrefix\");\n233:   });\n234: \n235:   test(\"throws on maxConcurrent < 1\", () => {\n236:     const config = validConfig();\n237:     config.defaults.maxConcurrent = 0;\n238:     expect(() => validateConfig(config)).toThrow(\"maxConcurrent\");\n239:   });\n240: \n241:   test(\"throws on negative maxRetries\", () => {\n242:     const config = validConfig();\n243:     config.defaults.maxRetries = -1;\n244:     expect(() => validateConfig(config)).toThrow(\"maxRetries\");\n245:   });\n246: \n247:   test(\"throws on negative maxBackups\", () => {\n248:     const config = validConfig();\n249:     config.backup.maxBackups = -1;\n250:     expect(() => validateConfig(config)).toThrow(\"maxBackups\");\n251:   });\n252: \n253:   test(\"throws on invalid agentRegistry.mode\", () => {\n254:     const config = validConfig();\n255:     (config.agentRegistry as any).mode = \"invalid-mode\";\n256:     expect(() => validateConfig(config)).toThrow(\"mode\");\n257:   });\n258: \n259:   test(\"accepts all valid agentRegistry modes\", () => {\n260:     for (const mode of [\"auto\", \"monitored\", \"disabled\"] as const) {\n261:       const config = validConfig();\n262:       config.agentRegistry.mode = mode;\n263:       expect(() => validateConfig(config)).not.toThrow();\n264:     }\n265:   });\n266: \n267:   test(\"throws on empty agentRegistry.source\", () => {\n268:     const config = validConfig();\n269:     config.agentRegistry.source = \"\";\n270:     expect(() => validateConfig(config)).toThrow(\"source\");\n271:   });\n272: \n273:   test(\"throws on empty agentRegistry.cacheDir\", () => {\n274:     const config = validConfig();\n275:     config.agentRegistry.cacheDir = \"\";\n276:     expect(() => validateConfig(config)).toThrow(\"cacheDir\");\n277:   });\n278: \n279:   test(\"throws when tdd.enabled is true but testCommand is empty\", () => {\n280:     const config = validConfig();\n281:     config.tdd.enabled = true;\n282:     config.tdd.testCommand = \"\";\n283:     expect(() => validateConfig(config)).toThrow(\"testCommand\");\n284:   });\n285: \n286:   test(\"allows empty testCommand when tdd is disabled\", () => {\n287:     const config = validConfig();\n288:     config.tdd.enabled = false;\n289:     config.tdd.testCommand = \"\";\n290:     expect(() => validateConfig(config)).not.toThrow();\n291:   });\n292: });\n293: \n294: // ---------------------------------------------------------------------------\n295: // generateDefaultConfig\n296: // ---------------------------------------------------------------------------\n297: \n298: describe(\"generateDefaultConfig\", () => {\n299:   test(\"returns valid JSON string\", () => {\n300:     const jsonStr = generateDefaultConfig();\n301:     expect(() => JSON.parse(jsonStr)).not.toThrow();\n302:   });\n303: \n304:   test(\"returned JSON matches DEFAULT_CONFIG\", () => {\n305:     const parsed = JSON.parse(generateDefaultConfig());\n306:     expect(parsed.baseBranch).toBe(DEFAULT_CONFIG.baseBranch);\n307:     expect(parsed.build.command).toBe(DEFAULT_CONFIG.build.command);\n308:     expect(parsed.tdd.enabled).toBe(DEFAULT_CONFIG.tdd.enabled);\n309:   });\n310: \n311:   test(\"ends with newline\", () => {\n312:     const jsonStr = generateDefaultConfig();\n313:     expect(jsonStr.endsWith(\"\\n\")).toBe(true);\n314:   });\n315: });\n\n(End of file - total 315 lines)\n</content>","title":"tests/config.test.ts","metadata":{"preview":"/**\n * config.test.ts — Unit tests for config.ts (loadConfig, validateConfig, deepMerge).\n *\n * Coverage:\n *   - loadConfig: returns defaults when no config file, merges partial config,\n *     deep-merges nested objects, handles legacy tasksFile/archiveFile migration,\n *     throws on invalid JSON\n *   - validateConfig: validates required fields, numeric constraints, enum values\n *   - DEFAULT_CONFIG: sensible defaults for all fields\n *   - generateDefaultConfig: returns valid JSON string\n */\n\nimport { describe, test, expect, beforeEach, afterEach } from \"bun:test\";\nimport { mkdtempSync, writeFileSync, rmSync, mkdirSync } from \"node:fs\";\nimport { join } from \"node:path\";\nimport { tmpdir } from \"node:os\";\nimport {\n  loadConfig,\n  validateConfig,\n  DEFAULT_CONFIG,","truncated":false,"loaded":[]},"time":{"start":1773445800511,"end":1773445800513}}}}
{"type":"tool_use","timestamp":1773445801172,"sessionID":"ses_316650d1dffespdzjLs3PfWdD3","part":{"id":"prt_ce99b6240001OAGhhgltZvSD4Z","sessionID":"ses_316650d1dffespdzjLs3PfWdD3","messageID":"msg_ce99b4e20001Wgoc3LY4Sah3gf","type":"tool","callID":"toolu_vrtx_01HCgrz4NxWjrwmf4aHMURCz","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/tdd-red-green-coercion/tests/output.test.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/tdd-red-green-coercion/tests/output.test.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * output.test.ts — Unit tests for output helpers.\n3:  *\n4:  * Coverage:\n5:  *   - resolveOutputFormat: explicit flag, env var, defaults\n6:  *   - filterFields: field selection, empty fields, missing fields\n7:  *   - filterFieldsArray: array variant\n8:  */\n9: \n10: import { describe, test, expect, afterEach } from \"bun:test\";\n11: import {\n12:   resolveOutputFormat,\n13:   filterFields,\n14:   filterFieldsArray,\n15: } from \"../src/lib/output.js\";\n16: \n17: // ---------------------------------------------------------------------------\n18: // resolveOutputFormat\n19: // ---------------------------------------------------------------------------\n20: \n21: describe(\"resolveOutputFormat\", () => {\n22:   const originalEnv = process.env.WOMBO_OUTPUT;\n23: \n24:   afterEach(() => {\n25:     if (originalEnv === undefined) {\n26:       delete process.env.WOMBO_OUTPUT;\n27:     } else {\n28:       process.env.WOMBO_OUTPUT = originalEnv;\n29:     }\n30:   });\n31: \n32:   test(\"returns 'json' when explicit flag is 'json'\", () => {\n33:     expect(resolveOutputFormat(\"json\")).toBe(\"json\");\n34:   });\n35: \n36:   test(\"returns 'text' when explicit flag is 'text'\", () => {\n37:     expect(resolveOutputFormat(\"text\")).toBe(\"text\");\n38:   });\n39: \n40:   test(\"returns 'toon' when explicit flag is 'toon'\", () => {\n41:     expect(resolveOutputFormat(\"toon\")).toBe(\"toon\");\n42:   });\n43: \n44:   test(\"returns 'text' when no explicit flag and no env var\", () => {\n45:     delete process.env.WOMBO_OUTPUT;\n46:     expect(resolveOutputFormat()).toBe(\"text\");\n47:   });\n48: \n49:   test(\"returns 'text' when explicit flag is undefined and no env var\", () => {\n50:     delete process.env.WOMBO_OUTPUT;\n51:     expect(resolveOutputFormat(undefined)).toBe(\"text\");\n52:   });\n53: \n54:   test(\"returns 'json' from WOMBO_OUTPUT env var\", () => {\n55:     process.env.WOMBO_OUTPUT = \"json\";\n56:     expect(resolveOutputFormat()).toBe(\"json\");\n57:   });\n58: \n59:   test(\"returns 'toon' from WOMBO_OUTPUT env var\", () => {\n60:     process.env.WOMBO_OUTPUT = \"toon\";\n61:     expect(resolveOutputFormat()).toBe(\"toon\");\n62:   });\n63: \n64:   test(\"explicit flag takes priority over env var\", () => {\n65:     process.env.WOMBO_OUTPUT = \"json\";\n66:     expect(resolveOutputFormat(\"text\")).toBe(\"text\");\n67:   });\n68: \n69:   test(\"returns 'text' for unknown explicit values\", () => {\n70:     expect(resolveOutputFormat(\"xml\")).toBe(\"text\");\n71:     expect(resolveOutputFormat(\"csv\")).toBe(\"text\");\n72:   });\n73: \n74:   test(\"returns 'text' for unknown env values\", () => {\n75:     process.env.WOMBO_OUTPUT = \"xml\";\n76:     expect(resolveOutputFormat()).toBe(\"text\");\n77:   });\n78: });\n79: \n80: // ---------------------------------------------------------------------------\n81: // filterFields\n82: // ---------------------------------------------------------------------------\n83: \n84: describe(\"filterFields\", () => {\n85:   const obj = {\n86:     id: \"task-1\",\n87:     title: \"My Task\",\n88:     status: \"backlog\",\n89:     priority: \"high\",\n90:     description: \"A task\",\n91:   };\n92: \n93:   test(\"returns full object when fields is undefined\", () => {\n94:     expect(filterFields(obj)).toEqual(obj);\n95:   });\n96: \n97:   test(\"returns full object when fields is empty array\", () => {\n98:     expect(filterFields(obj, [])).toEqual(obj);\n99:   });\n100: \n101:   test(\"filters to specified fields\", () => {\n102:     const result = filterFields(obj, [\"id\", \"status\"]);\n103:     expect(result).toEqual({ id: \"task-1\", status: \"backlog\" });\n104:   });\n105: \n106:   test(\"ignores fields not present in object\", () => {\n107:     const result = filterFields(obj, [\"id\", \"nonexistent\"]);\n108:     expect(result).toEqual({ id: \"task-1\" });\n109:     expect(\"nonexistent\" in result).toBe(false);\n110:   });\n111: \n112:   test(\"returns empty object when no fields match\", () => {\n113:     const result = filterFields(obj, [\"foo\", \"bar\"]);\n114:     expect(Object.keys(result)).toHaveLength(0);\n115:   });\n116: \n117:   test(\"preserves field values including null and empty string\", () => {\n118:     const objWithNull = { a: null, b: \"\", c: 0, d: false } as Record<string, unknown>;\n119:     const result = filterFields(objWithNull, [\"a\", \"b\", \"c\", \"d\"]);\n120:     expect(result).toEqual({ a: null, b: \"\", c: 0, d: false });\n121:   });\n122: });\n123: \n124: // ---------------------------------------------------------------------------\n125: // filterFieldsArray\n126: // ---------------------------------------------------------------------------\n127: \n128: describe(\"filterFieldsArray\", () => {\n129:   const arr = [\n130:     { id: \"t1\", title: \"Task 1\", status: \"done\" },\n131:     { id: \"t2\", title: \"Task 2\", status: \"backlog\" },\n132:   ];\n133: \n134:   test(\"returns full array when fields is undefined\", () => {\n135:     expect(filterFieldsArray(arr)).toEqual(arr);\n136:   });\n137: \n138:   test(\"returns full array when fields is empty\", () => {\n139:     expect(filterFieldsArray(arr, [])).toEqual(arr);\n140:   });\n141: \n142:   test(\"filters each object to specified fields\", () => {\n143:     const result = filterFieldsArray(arr, [\"id\", \"status\"]);\n144:     expect(result).toEqual([\n145:       { id: \"t1\", status: \"done\" },\n146:       { id: \"t2\", status: \"backlog\" },\n147:     ]);\n148:   });\n149: \n150:   test(\"handles empty array\", () => {\n151:     expect(filterFieldsArray([], [\"id\"])).toEqual([]);\n152:   });\n153: });\n\n(End of file - total 153 lines)\n</content>","title":"tests/output.test.ts","metadata":{"preview":"/**\n * output.test.ts — Unit tests for output helpers.\n *\n * Coverage:\n *   - resolveOutputFormat: explicit flag, env var, defaults\n *   - filterFields: field selection, empty fields, missing fields\n *   - filterFieldsArray: array variant\n */\n\nimport { describe, test, expect, afterEach } from \"bun:test\";\nimport {\n  resolveOutputFormat,\n  filterFields,\n  filterFieldsArray,\n} from \"../src/lib/output.js\";\n\n// ---------------------------------------------------------------------------\n// resolveOutputFormat\n// ---------------------------------------------------------------------------\n","truncated":false,"loaded":[]},"time":{"start":1773445801169,"end":1773445801172}}}}
{"type":"tool_use","timestamp":1773445801690,"sessionID":"ses_316650d1dffespdzjLs3PfWdD3","part":{"id":"prt_ce99b64d2001MCiAqp6L3TDDle","sessionID":"ses_316650d1dffespdzjLs3PfWdD3","messageID":"msg_ce99b4e20001Wgoc3LY4Sah3gf","type":"tool","callID":"toolu_vrtx_01MAt8f4bKzinKkkTQXpi2CC","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/tdd-red-green-coercion/tests/validate.test.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/tdd-red-green-coercion/tests/validate.test.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * validate.test.ts — Unit tests for input validation functions.\n3:  *\n4:  * Coverage:\n5:  *   - validateId: kebab-case, empty, control chars, path traversal, query params,\n6:  *     percent-encoding, length limits\n7:  *   - validateText: control chars, allows newlines/tabs\n8:  *   - validateBranchName: empty, control chars, \"..\", special chars\n9:  *   - validateDuration: ISO 8601 patterns, invalid formats\n10:  *   - validateEnum: allowed values, rejected values\n11:  *   - assertValid: exits on invalid (not directly testable without mocking process.exit)\n12:  */\n13: \n14: import { describe, test, expect } from \"bun:test\";\n15: import {\n16:   validateId,\n17:   validateText,\n18:   validateBranchName,\n19:   validateDuration,\n20:   validateEnum,\n21: } from \"../src/lib/validate.js\";\n22: \n23: // ---------------------------------------------------------------------------\n24: // validateId\n25: // ---------------------------------------------------------------------------\n26: \n27: describe(\"validateId\", () => {\n28:   test(\"accepts valid kebab-case ids\", () => {\n29:     expect(validateId(\"my-task\").valid).toBe(true);\n30:     expect(validateId(\"task-1\").valid).toBe(true);\n31:     expect(validateId(\"a\").valid).toBe(true);\n32:     expect(validateId(\"abc-def-ghi\").valid).toBe(true);\n33:     expect(validateId(\"123\").valid).toBe(true);\n34:     expect(validateId(\"a1b2c3\").valid).toBe(true);\n35:   });\n36: \n37:   test(\"rejects empty string\", () => {\n38:     const result = validateId(\"\");\n39:     expect(result.valid).toBe(false);\n40:     expect(result.error).toContain(\"empty\");\n41:   });\n42: \n43:   test(\"rejects uppercase letters\", () => {\n44:     const result = validateId(\"MyTask\");\n45:     expect(result.valid).toBe(false);\n46:     expect(result.error).toContain(\"kebab-case\");\n47:   });\n48: \n49:   test(\"rejects spaces\", () => {\n50:     const result = validateId(\"my task\");\n51:     expect(result.valid).toBe(false);\n52:   });\n53: \n54:   test(\"rejects underscores\", () => {\n55:     const result = validateId(\"my_task\");\n56:     expect(result.valid).toBe(false);\n57:   });\n58: \n59:   test(\"rejects dots\", () => {\n60:     const result = validateId(\"my.task\");\n61:     expect(result.valid).toBe(false);\n62:   });\n63: \n64:   test(\"rejects path traversal\", () => {\n65:     const result = validateId(\"../etc/passwd\");\n66:     expect(result.valid).toBe(false);\n67:     expect(result.error).toContain(\"path traversal\");\n68:   });\n69: \n70:   test(\"rejects query params\", () => {\n71:     const result = validateId(\"task?id=1\");\n72:     expect(result.valid).toBe(false);\n73:     expect(result.error).toContain(\"query\");\n74:   });\n75: \n76:   test(\"rejects fragment\", () => {\n77:     const result = validateId(\"task#section\");\n78:     expect(result.valid).toBe(false);\n79:     expect(result.error).toContain(\"query\");\n80:   });\n81: \n82:   test(\"rejects percent-encoded characters\", () => {\n83:     const result = validateId(\"task%20name\");\n84:     expect(result.valid).toBe(false);\n85:     expect(result.error).toContain(\"percent-encoded\");\n86:   });\n87: \n88:   test(\"rejects control characters\", () => {\n89:     const result = validateId(\"task\\x00name\");\n90:     expect(result.valid).toBe(false);\n91:     expect(result.error).toContain(\"control\");\n92:   });\n93: \n94:   test(\"rejects id starting with hyphen\", () => {\n95:     const result = validateId(\"-task\");\n96:     expect(result.valid).toBe(false);\n97:   });\n98: \n99:   test(\"rejects id longer than 128 characters\", () => {\n100:     const longId = \"a\" + \"-b\".repeat(64); // 129 chars\n101:     const result = validateId(longId);\n102:     expect(result.valid).toBe(false);\n103:   });\n104: \n105:   test(\"accepts id at max 128 characters\", () => {\n106:     const maxId = \"a\" + \"-b\".repeat(63) + \"c\"; // exactly 128 chars\n107:     // Note: 1 + 63*2 + 1 = 128\n108:     const result = validateId(maxId);\n109:     expect(result.valid).toBe(true);\n110:   });\n111: \n112:   test(\"uses custom label in error message\", () => {\n113:     const result = validateId(\"\", \"Feature ID\");\n114:     expect(result.error).toContain(\"Feature ID\");\n115:   });\n116: });\n117: \n118: // ---------------------------------------------------------------------------\n119: // validateText\n120: // ---------------------------------------------------------------------------\n121: \n122: describe(\"validateText\", () => {\n123:   test(\"accepts normal text\", () => {\n124:     expect(validateText(\"Hello, world!\").valid).toBe(true);\n125:   });\n126: \n127:   test(\"accepts text with newlines and tabs\", () => {\n128:     expect(validateText(\"Line 1\\nLine 2\\tTabbed\").valid).toBe(true);\n129:   });\n130: \n131:   test(\"accepts empty string\", () => {\n132:     expect(validateText(\"\").valid).toBe(true);\n133:   });\n134: \n135:   test(\"accepts unicode text\", () => {\n136:     expect(validateText(\"こんにちは世界 🌍\").valid).toBe(true);\n137:   });\n138: \n139:   test(\"rejects null bytes\", () => {\n140:     const result = validateText(\"text\\x00more\");\n141:     expect(result.valid).toBe(false);\n142:     expect(result.error).toContain(\"control\");\n143:   });\n144: \n145:   test(\"rejects bell character\", () => {\n146:     const result =