{"type":"tool_use","timestamp":1773445785924,"sessionID":"ses_316650d1dffespdzjLs3PfWdD3","part":{"id":"prt_ce99b27400016T4u8RAKRFdc0C","sessionID":"ses_316650d1dffespdzjLs3PfWdD3","messageID":"msg_ce99b1c1f001aboGM4m9QoZxVc","type":"tool","callID":"toolu_vrtx_011fYoWuPbYQbKaFXAwdkngq","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/tdd-red-green-coercion/src/lib/tdd-verifier.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/tdd-red-green-coercion/src/lib/tdd-verifier.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tdd-verifier.ts — TDD verification step for the build pipeline.\n3:  *\n4:  * Responsibilities:\n5:  *   - Run tests via test-runner.ts and capture results\n6:  *   - Run test-detection.ts to check new files have tests\n7:  *   - Combine results into a structured TddVerificationResult\n8:  *   - Support strict mode (blocking) vs warn mode (non-blocking)\n9:  *   - Render human-readable reports\n10:  *\n11:  * This module is called by verifier.ts as an additional step in the\n12:  * full verification pipeline, after the build passes.\n13:  */\n14: \n15: import type { WomboConfig } from \"../config.js\";\n16: import { runTests, type TestRunResult } from \"./test-runner.js\";\n17: import {\n18:   detectTests,\n19:   renderTestDetectionReport,\n20:   type TestDetectionReport,\n21: } from \"./test-detection.js\";\n22: \n23: // ---------------------------------------------------------------------------\n24: // Types\n25: // ---------------------------------------------------------------------------\n26: \n27: /** Options for running TDD verification */\n28: export interface TddVerificationOptions {\n29:   /** Absolute path to the worktree */\n30:   worktreePath: string;\n31:   /** Feature ID (used for git diff comparison) */\n32:   featureId: string;\n33:   /** Full config */\n34:   config: WomboConfig;\n35:   /** Skip running tests entirely */\n36:   skipTests?: boolean;\n37:   /** Strict TDD mode: fail verification if tests are missing */\n38:   strictTdd?: boolean;\n39:   /** Base branch for git diff comparison (default: from config) */\n40:   baseBranch?: string;\n41: }\n42: \n43: /** Result of TDD verification */\n44: export interface TddVerificationResult {\n45:   /** Whether TDD verification was run at all */\n46:   ran: boolean;\n47:   /** Why it was skipped (null if it ran) */\n48:   skipReason: string | null;\n49:   /** Test run results (null if tests were skipped or not run) */\n50:   testRun: TestRunResult | null;\n51:   /** Test detection report (null if skipped) */\n52:   testDetection: TestDetectionReport | null;\n53:   /** Whether TDD verification passed overall */\n54:   passed: boolean;\n55:   /** Whether there are warnings (missing tests in non-strict mode) */\n56:   hasWarnings: boolean;\n57:   /** Human-readable summary */\n58:   summary: string;\n59:   /** Whether strict mode was used */\n60:   strictMode: boolean;\n61: }\n62: \n63: // ---------------------------------------------------------------------------\n64: // TDD Verification Runner\n65: // ---------------------------------------------------------------------------\n66: \n67: /**\n68:  * Run the TDD verification step.\n69:  *\n70:  * This is the main entry point called by the verification pipeline.\n71:  * It runs in two sub-steps:\n72:  *   1. Run the test command and capture results\n73:  *   2. Run test detection to find files missing tests\n74:  *\n75:  * In non-strict mode (default), missing tests produce warnings but don't\n76:  * fail verification. In strict mode (--strict-tdd), missing tests cause\n77:  * verification to fail.\n78:  */\n79: export async function runTddVerification(\n80:   opts: TddVerificationOptions\n81: ): Promise<TddVerificationResult> {\n82:   const { worktreePath, config } = opts;\n83:   const strictMode = opts.strictTdd ?? false;\n84: \n85:   // Check if TDD is enabled in config\n86:   if (!config.tdd?.enabled) {\n87:     return {\n88:       ran: false,\n89:       skipReason: \"TDD is disabled (set tdd.enabled: true in .wombo-combo/config.json)\",\n90:       testRun: null,\n91:       testDetection: null,\n92:       passed: true,\n93:       hasWarnings: false,\n94:       summary: \"TDD verification skipped (disabled)\",\n95:       strictMode,\n96:     };\n97:   }\n98: \n99:   // Check if tests should be skipped via --skip-tests flag\n100:   if (opts.skipTests) {\n101:     return {\n102:       ran: false,\n103:       skipReason: \"Tests skipped via --skip-tests flag\",\n104:       testRun: null,\n105:       testDetection: null,\n106:       passed: true,\n107:       hasWarnings: false,\n108:       summary: \"TDD verification skipped (--skip-tests)\",\n109:       strictMode,\n110:     };\n111:   }\n112: \n113:   const testCommand = config.tdd.testCommand || \"bun test\";\n114:   const baseBranch = opts.baseBranch ?? config.baseBranch;\n115: \n116:   // Step 1: Run the test command\n117:   let testRun: TestRunResult | null = null;\n118:   try {\n119:     testRun = await runTests(worktreePath, testCommand);\n120:   } catch (err: any) {\n121:     // Test command failed to execute (not the same as tests failing)\n122:     return {\n123:       ran: true,\n124:       skipReason: null,\n125:       testRun: null,\n126:       testDetection: null,\n127:       passed: false,\n128:       hasWarnings: false,\n129:       summary: `Test command failed to execute: ${err.message}`,\n130:       strictMode,\n131:     };\n132:   }\n133: \n134:   // Step 2: Run test detection (check if new files have tests)\n135:   let testDetection: TestDetectionReport | null = null;\n136:   try {\n137:     testDetection = detectTests(worktreePath, baseBranch);\n138:   } catch (err: any) {\n139:     // Test detection failed — non-fatal, just skip it\n140:     testDetection = null;\n141:   }\n142: \n143:   // Step 3: Determine overall pass/fail\n144:   const testsPassed = testRun.passed;\n145:   const hasMissingTests =\n146:     testDetection !== null && testDetection.missingTests.length > 0;\n147:   const hasWarnings = hasMissingTests && !strictMode;\n148: \n149:   // In strict mode, missing tests cause failure\n150:   // In non-strict mode, only test failures cause failure\n151:   const passed = strictMode\n152:     ? testsPassed && !hasMissingTests\n153:     : testsPassed;\n154: \n155:   // Build summary\n156:   const summary = buildSummary(testRun, testDetection, strictMode);\n157: \n158:   return {\n159:     ran: true,\n160:     skipReason: null,\n161:     testRun,\n162:     testDetection,\n163:     passed,\n164:     hasWarnings,\n165:     summary,\n166:     strictMode,\n167:   };\n168: }\n169: \n170: // ---------------------------------------------------------------------------\n171: // Summary Building\n172: // ---------------------------------------------------------------------------\n173: \n174: /**\n175:  * Build a human-readable summary of TDD verification results.\n176:  */\n177: function buildSummary(\n178:   testRun: TestRunResult,\n179:   testDetection: TestDetectionReport | null,\n180:   strictMode: boolean\n181: ): string {\n182:   const parts: string[] = [];\n183: \n184:   // Test run summary\n185:   if (testRun.testCounts.parsed) {\n186:     parts.push(\n187:       `Tests: ${testRun.testCounts.passed} passed, ` +\n188:       `${testRun.testCounts.failed} failed` +\n189:       (testRun.testCounts.skipped > 0\n190:         ? `, ${testRun.testCounts.skipped} skipped`\n191:         : \"\") +\n192:       ` (${Math.round(testRun.durationMs / 1000)}s)`\n193:     );\n194:   } else {\n195:     parts.push(\n196:       `Tests: ${testRun.passed ? \"PASSED\" : \"FAILED\"} ` +\n197:       `(exit code ${testRun.exitCode}, ${Math.round(testRun.durationMs / 1000)}s)`\n198:     );\n199:   }\n200: \n201:   // Test detection summary\n202:   if (testDetection) {\n203:     const { missingTests, coveredCount, testableCount, coveragePercent } =\n204:       testDetection;\n205:     if (missingTests.length > 0) {\n206:       const label = strictMode ? \"FAIL\" : \"WARN\";\n207:       parts.push(\n208:         `Coverage: ${coveredCount}/${testableCount} files (${coveragePercent}) — ` +\n209:         `${label}: ${missingTests.length} file(s) missing tests`\n210:       );\n211:     } else if (testableCount > 0) {\n212:       parts.push(\n213:         `Coverage: ${coveredCount}/${testableCount} files (${coveragePercent})`\n214:       );\n215:     }\n216:   }\n217: \n218:   return parts.join(\" | \");\n219: }\n220: \n221: // ---------------------------------------------------------------------------\n222: // Error Summary Extraction\n223: // ---------------------------------------------------------------------------\n224: \n225: /**\n226:  * Extract a concise error summary from TDD verification results.\n227:  * Used for retry prompts when TDD verification fails.\n228:  */\n229: export function extractTddErrorSummary(\n230:   result: TddVerificationResult\n231: ): string {\n232:   const parts: string[] = [];\n233: \n234:   if (result.testRun && !result.testRun.passed) {\n235:     parts.push(\"--- Test Failures ---\");\n236:     parts.push(result.testRun.errorSummary || \"(no error details)\");\n237:   }\n238: \n239:   if (\n240:     result.strictMode &&\n241:     result.testDetection &&\n242:     result.testDetection.missingTests.length > 0\n243:   ) {\n244:     parts.push(\"\");\n245:     parts.push(\"--- Missing Tests (strict TDD mode) ---\");\n246:     for (const path of result.testDetection.missingTests) {\n247:       parts.push(`  ${path}`);\n248:     }\n249:   }\n250: \n251:   return parts.join(\"\\n\").slice(0, 4000);\n252: }\n253: \n254: // ---------------------------------------------------------------------------\n255: // Text Rendering\n256: // ---------------------------------------------------------------------------\n257: \n258: /**\n259:  * Render a TDD verification result as human-readable text to stdout.\n260:  */\n261: export function renderTddVerificationReport(\n262:   result: TddVerificationResult\n263: ): void {\n264:   if (!result.ran) {\n265:     console.log(`\\n  TDD: ${result.skipReason}\\n`);\n266:     return;\n267:   }\n268: \n269:   console.log(`\\n${\"─\".repeat(60)}`);\n270:   console.log(`  TDD Verification Report`);\n271:   console.log(`${\"─\".repeat(60)}`);\n272: \n273:   // Test run results\n274:   if (result.testRun) {\n275:     const tr = result.testRun;\n276:     const statusIcon = tr.passed ? \"\\x1b[32m✓\\x1b[0m\" : \"\\x1b[31m✗\\x1b[0m\";\n277:     console.log(`\\n  ${statusIcon} Test Run: ${tr.passed ? \"PASSED\" : \"FAILED\"}`);\n278:     console.log(`    Command exit code: ${tr.exitCode}`);\n279:     console.log(`    Duration: ${Math.round(tr.durationMs / 1000)}s`);\n280: \n281:     if (tr.testCounts.parsed) {\n282:       console.log(\n283:         `    Results: ${tr.testCounts.passed} passed, ` +\n284:         `${tr.testCounts.failed} failed, ` +\n285:         `${tr.testCounts.skipped} skipped ` +\n286:         `(${tr.testCounts.total} total)`\n287:       );\n288:     }\n289:   }\n290: \n291:   // Test detection results\n292:   if (result.testDetection) {\n293:     renderTestDetectionReport(result.testDetection);\n294:   }\n295: \n296:   // Overall status\n297:   const overallIcon = result.passed\n298:     ? \"\\x1b[32m✓\\x1b[0m\"\n299:     : \"\\x1b[31m✗\\x1b[0m\";\n300:   const modeLabel = result.strictMode ? \" (strict)\" : \"\";\n301:   console.log(`  ${overallIcon} TDD Overall: ${result.passed ? \"PASSED\" : \"FAILED\"}${modeLabel}`);\n302: \n303:   if (result.hasWarnings) {\n304:     console.log(\n305:       `  \\x1b[33m⚠\\x1b[0m Warnings: Some new files are missing tests ` +\n306:       `(non-blocking — use --strict-tdd to enforce)`\n307:     );\n308:   }\n309: \n310:   console.log(`${\"─\".repeat(60)}\\n`);\n311: }\n\n(End of file - total 311 lines)\n</content>","title":"src/lib/tdd-verifier.ts","metadata":{"preview":"/**\n * tdd-verifier.ts — TDD verification step for the build pipeline.\n *\n * Responsibilities:\n *   - Run tests via test-runner.ts and capture results\n *   - Run test-detection.ts to check new files have tests\n *   - Combine results into a structured TddVerificationResult\n *   - Support strict mode (blocking) vs warn mode (non-blocking)\n *   - Render human-readable reports\n *\n * This module is called by verifier.ts as an additional step in the\n * full verification pipeline, after the build passes.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport { runTests, type TestRunResult } from \"./test-runner.js\";\nimport {\n  detectTests,\n  renderTestDetectionReport,\n  type TestDetectionReport,","truncated":false,"loaded":[]},"time":{"start":1773445785919,"end":1773445785923}}}}
{"type":"tool_use","timestamp":1773445786375,"sessionID":"ses_316650d1dffespdzjLs3PfWdD3","part":{"id":"prt_ce99b2941001VhSb0k1yobUWLq","sessionID":"ses_316650d1dffespdzjLs3PfWdD3","messageID":"msg_ce99b1c1f001aboGM4m9QoZxVc","type":"tool","callID":"toolu_vrtx_01V5oRHnx7GJtKGbqsspfatT","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/tdd-red-green-coercion/src/lib/test-detection.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/tdd-red-green-coercion/src/lib/test-detection.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * test-detection.ts — Detect test files and coverage for new/modified code.\n3:  *\n4:  * Responsibilities:\n5:  *   - Parse `git diff --name-status` to find added/modified .ts files in src/\n6:  *   - For each source file, check if corresponding test files exist\n7:  *   - Use configurable test file patterns (default: tests/**\\/*.test.ts, src/**\\/*.test.ts)\n8:  *   - Exclude non-testable files: *.d.ts, index.ts (re-export barrels), types-only files\n9:  *   - Report: source files missing tests, source files with tests, coverage ratio\n10:  *   - Output as structured data compatible with outputMessage() for --output json\n11:  *\n12:  * Exported for use by tdd-verification-step and other consumers.\n13:  */\n14: \n15: import { execSync } from \"node:child_process\";\n16: import { existsSync, readFileSync, readdirSync, statSync } from \"node:fs\";\n17: import { resolve, basename, dirname, relative, join } from \"node:path\";\n18: \n19: // ---------------------------------------------------------------------------\n20: // Types\n21: // ---------------------------------------------------------------------------\n22: \n23: /** Status of a file in git diff --name-status */\n24: export type DiffStatus = \"A\" | \"M\" | \"D\" | \"R\" | \"C\" | \"T\" | \"U\" | \"X\";\n25: \n26: /** A source file detected from git diff */\n27: export interface DiffFile {\n28:   /** Git diff status: A=added, M=modified, D=deleted, etc. */\n29:   status: DiffStatus;\n30:   /** File path relative to repo root */\n31:   path: string;\n32: }\n33: \n34: /** Result of test detection for a single source file */\n35: export interface SourceFileTestInfo {\n36:   /** Source file path relative to repo root */\n37:   sourcePath: string;\n38:   /** Whether a corresponding test file was found */\n39:   hasTest: boolean;\n40:   /** Path(s) of matching test file(s), empty if none found */\n41:   testFiles: string[];\n42:   /** Whether the file was excluded from test requirements */\n43:   excluded: boolean;\n44:   /** Reason for exclusion, if applicable */\n45:   excludeReason?: string;\n46: }\n47: \n48: /** Overall test detection report */\n49: export interface TestDetectionReport {\n50:   /** All source files analyzed (excludes deleted files) */\n51:   sourceFiles: SourceFileTestInfo[];\n52:   /** Source files that have corresponding tests */\n53:   withTests: string[];\n54:   /** Source files missing tests (excluding excluded files) */\n55:   missingTests: string[];\n56:   /** Source files excluded from test requirements */\n57:   excludedFiles: string[];\n58:   /** Number of testable source files (total - excluded) */\n59:   testableCount: number;\n60:   /** Number of testable source files that have tests */\n61:   coveredCount: number;\n62:   /** Coverage ratio (0-1), NaN if no testable files */\n63:   coverageRatio: number;\n64:   /** Human-readable coverage percentage string */\n65:   coveragePercent: string;\n66:   /** Git ref used for comparison */\n67:   comparedTo: string;\n68: }\n69: \n70: /** Configuration for test detection */\n71: export interface TestDetectionConfig {\n72:   /** Glob patterns for test file locations (relative to repo root) */\n73:   testFilePatterns: string[];\n74:   /** Source directory prefixes to scan (e.g., [\"src/\"]) */\n75:   sourceDirs: string[];\n76:   /** File extensions to consider as source files */\n77:   sourceExtensions: string[];\n78:   /** Additional filename patterns to exclude (beyond built-in exclusions) */\n79:   excludePatterns: string[];\n80: }\n81: \n82: // ---------------------------------------------------------------------------\n83: // Defaults\n84: // ---------------------------------------------------------------------------\n85: \n86: export const DEFAULT_TEST_DETECTION_CONFIG: TestDetectionConfig = {\n87:   testFilePatterns: [\n88:     \"tests/**/*.test.ts\",\n89:     \"src/**/*.test.ts\",\n90:     \"test/**/*.test.ts\",\n91:     \"tests/**/*.spec.ts\",\n92:     \"src/**/*.spec.ts\",\n93:     \"test/**/*.spec.ts\",\n94:   ],\n95:   sourceDirs: [\"src/\"],\n96:   sourceExtensions: [\".ts\", \".tsx\"],\n97:   excludePatterns: [],\n98: };\n99: \n100: // ---------------------------------------------------------------------------\n101: // Git Diff Parsing\n102: // ---------------------------------------------------------------------------\n103: \n104: /**\n105:  * Parse `git diff --name-status` output to find added/modified files.\n106:  *\n107:  * Supports comparison against:\n108:  *   - A specific ref (e.g., \"HEAD~1\", \"main\", \"origin/main\")\n109:  *   - Default: HEAD~1\n110:  *\n111:  * Only returns Added (A) and Modified (M) files. Deleted files are excluded\n112:  * since they no longer need tests.\n113:  */\n114: export function getChangedFiles(\n115:   projectRoot: string,\n116:   compareRef: string = \"HEAD~1\"\n117: ): DiffFile[] {\n118:   let diffOutput: string;\n119:   try {\n120:     diffOutput = execSync(\n121:       `git diff --name-status \"${compareRef}\"`,\n122:       {\n123:         cwd: projectRoot,\n124:         encoding: \"utf-8\",\n125:         maxBuffer: 10 * 1024 * 1024,\n126:         stdio: [\"pipe\", \"pipe\", \"pipe\"],\n127:       }\n128:     ).trim();\n129:   } catch (err: any) {\n130:     // If the ref doesn't exist (e.g., first commit), try --name-status against empty tree\n131:     try {\n132:       diffOutput = execSync(\n133:         `git diff --name-status $(git hash-object -t tree /dev/null)`,\n134:         {\n135:           cwd: projectRoot,\n136:           encoding: \"utf-8\",\n137:           maxBuffer: 10 * 1024 * 1024,\n138:           stdio: [\"pipe\", \"pipe\", \"pipe\"],\n139:         }\n140:       ).trim();\n141:     } catch {\n142:       // If all else fails, list tracked files as \"Added\"\n143:       try {\n144:         diffOutput = execSync(\n145:           `git ls-files`,\n146:           {\n147:             cwd: projectRoot,\n148:             encoding: \"utf-8\",\n149:             maxBuffer: 10 * 1024 * 1024,\n150:             stdio: [\"pipe\", \"pipe\", \"pipe\"],\n151:           }\n152:         )\n153:           .trim()\n154:           .split(\"\\n\")\n155:           .filter(Boolean)\n156:           .map((f) => `A\\t${f}`)\n157:           .join(\"\\n\");\n158:       } catch {\n159:         return [];\n160:       }\n161:     }\n162:   }\n163: \n164:   if (!diffOutput) return [];\n165: \n166:   const files: DiffFile[] = [];\n167:   for (const line of diffOutput.split(\"\\n\")) {\n168:     if (!line.trim()) continue;\n169: \n170:     // Format: STATUS\\tFILENAME  or  STATUS\\tOLDNAME\\tNEWNAME (for renames)\n171:     const parts = line.split(\"\\t\");\n172:     if (parts.length < 2) continue;\n173: \n174:     // Status may have a number suffix for renames/copies (e.g., R100)\n175:     const statusChar = parts[0].charAt(0) as DiffStatus;\n176:     // For renames/copies, use the new filename (last part)\n177:     const filePath = parts[parts.length - 1];\n178: \n179:     // Only include Added and Modified files\n180:     if (statusChar === \"A\" || statusChar === \"M\") {\n181:       files.push({ status: statusChar, path: filePath });\n182:     }\n183:   }\n184: \n185:   return files;\n186: }\n187: \n188: /**\n189:  * Filter diff files to only include source files matching the config.\n190:  * Excludes test files themselves from the source file list.\n191:  */\n192: export function filterSourceFiles(\n193:   files: DiffFile[],\n194:   config: TestDetectionConfig = DEFAULT_TEST_DETECTION_CONFIG\n195: ): DiffFile[] {\n196:   return files.filter((file) => {\n197:     // Must be in one of the configured source directories\n198:     const inSourceDir = config.sourceDirs.some((dir) =>\n199:       file.path.startsWith(dir)\n200:     );\n201:     if (!inSourceDir) return false;\n202: \n203:     // Must have a matching source extension\n204:     const hasSourceExt = config.sourceExtensions.some((ext) =>\n205:       file.path.endsWith(ext)\n206:     );\n207:     if (!hasSourceExt) return false;\n208: \n209:     // Exclude test files from source file list\n210:     if (isTestFile(file.path)) return false;\n211: \n212:     return true;\n213:   });\n214: }\n215: \n216: // ---------------------------------------------------------------------------\n217: // Test File Detection\n218: // ---------------------------------------------------------------------------\n219: \n220: /**\n221:  * Check if a file path looks like a test file.\n222:  */\n223: export function isTestFile(filePath: string): boolean {\n224:   const name = basename(filePath);\n225:   return (\n226:     name.endsWith(\".test.ts\") ||\n227:     name.endsWith(\".test.tsx\") ||\n228:     name.endsWith(\".spec.ts\") ||\n229:     name.endsWith(\".spec.tsx\") ||\n230:     name.endsWith(\".test.js\") ||\n231:     name.endsWith(\".spec.js\")\n232:   );\n233: }\n234: \n235: /**\n236:  * Check if a file should be excluded from test requirements.\n237:  *\n238:  * Excluded files:\n239:  *   - *.d.ts (type declaration files)\n240:  *   - index.ts that are re-export barrels (only exports, no logic)\n241:  *   - Files that contain only type/interface/enum exports (types-only)\n242:  *   - Files matching additional exclude patterns from config\n243:  */\n244: export function isExcludedFile(\n245:   filePath: string,\n246:   projectRoot: string,\n247:   config: TestDetectionConfig = DEFAULT_TEST_DETECTION_CONFIG\n248: ): { excluded: boolean; reason?: string } {\n249:   const name = basename(filePath);\n250: \n251:   // Type declaration files\n252:   if (name.endsWith(\".d.ts\")) {\n253:     return { excluded: true, reason: \"Type declaration file (*.d.ts)\" };\n254:   }\n255: \n256:   // Check additional exclude patterns\n257:   for (const pattern of config.excludePatterns) {\n258:     if (filePath.includes(pattern) || name === pattern) {\n259:       return { excluded: true, reason: `Matches exclude pattern: ${pattern}` };\n260:     }\n261:   }\n262: \n263:   // For index.ts files, check if they're re-export barrels\n264:   if (name === \"index.ts\" || name === \"index.tsx\") {\n265:     const absPath = resolve(projectRoot, filePath);\n266:     if (existsSync(absPath)) {\n267:       if (isBarrelFile(absPath)) {\n268:         return { excluded: true, reason: \"Re-export barrel (index.ts)\" };\n269:       }\n270:     }\n271:   }\n272: \n273:   // Check if file is types-only\n274:   const absPath = resolve(projectRoot, filePath);\n275:   if (existsSync(absPath)) {\n276:     if (isTypesOnlyFile(absPath)) {\n277:       return { excluded: true, reason: \"Types-only file (no runtime logic)\" };\n278:     }\n279:   }\n280: \n281:   return { excluded: false };\n282: }\n283: \n284: /**\n285:  * Check if a file is a re-export barrel (only contains export statements).\n286:  *\n287:  * A barrel file consists entirely of:\n288:  *   - export { ... } from \"...\"\n289:  *   - export * from \"...\"\n290:  *   - export type { ... } from \"...\"\n291:  *   - Comments\n292:  *   - Empty lines\n293:  */\n294: export function isBarrelFile(absPath: string): boolean {\n295:   try {\n296:     const content = readFileSync(absPath, \"utf-8\");\n297:     const lines = content.split(\"\\n\");\n298: \n299:     let hasExport = false;\n300:     for (const line of lines) {\n301:       const trimmed = line.trim();\n302:       if (!trimmed) continue; // empty line\n303:       if (trimmed.startsWith(\"//\") || trimmed.startsWith(\"/*\") || trimmed.startsWith(\"*\")) continue; // comment\n304:       if (trimmed.startsWith(\"export \") && trimmed.includes(\" from \")) {\n305:         hasExport = true;\n306:         continue; // re-export\n307:       }\n308:       // Any other non-empty, non-comment line means it's not a barrel\n309:       return false;\n310:     }\n311: \n312:     return hasExport; // Must have at least one export to be a barrel\n313:   } catch {\n314:     return false;\n315:   }\n316: }\n317: \n318: /**\n319:  * Check if a file contains only type definitions (interfaces, types, enums)\n320:  * with no runtime code.\n321:  *\n322:  * Heuristic: A types-only file has no lines that produce runtime code.\n323:  * Lines that are types-only:\n324:  *   - export type / export interface / export enum\n325:  *   - type / interface / enum declarations\n326:  *   - import statements (import type or regular — removed at compile time if only types used)\n327:  *   - Comments, empty lines\n328:  *   - Opening/closing braces for type bodies\n329:  */\n330: export function isTypesOnlyFile(absPath: string): boolean {\n331:   try {\n332:     const content = readFileSync(absPath, \"utf-8\");\n333:     const lines = content.split(\"\\n\");\n334: \n335:     let hasTypeDecl = false;\n336:     let inBlockComment = false;\n337: \n338:     for (const line of lines) {\n339:       const trimmed = line.trim();\n340: \n341:       // Track block comments\n342:       if (inBlockComment) {\n343:         if (trimmed.includes(\"*/\")) {\n344:           inBlockComment = false;\n345:         }\n346:         continue;\n347:       }\n348:       if (trimmed.startsWith(\"/*\")) {\n349:         inBlockComment = true;\n350:         if (trimmed.includes(\"*/\")) {\n351:           inBlockComment = false;\n352:         }\n353:         continue;\n354:       }\n355: \n356:       if (!trimmed) continue; // empty line\n357:       if (trimmed.startsWith(\"//\")) continue; // line comment\n358: \n359:       // Import statements (removed at compile time for type-only usage)\n360:       if (trimmed.startsWith(\"import \")) continue;\n361: \n362:       // Type-only declarations\n363:       if (\n364:         trimmed.startsWith(\"export type \") ||\n365:         trimmed.startsWith(\"export interface \") ||\n366:         trimmed.startsWith(\"export enum \") ||\n367:         trimmed.startsWith(\"type \") ||\n368:         trimmed.startsWith(\"interface \") ||\n369:         trimmed.startsWith(\"enum \") ||\n370:         trimmed.startsWith(\"export declare \") ||\n371:         trimmed.startsWith(\"declare \")\n372:       ) {\n373:         hasTypeDecl = true;\n374:         continue;\n375:       }\n376: \n377:       // Allow lines that are part of type/interface/enum bodies\n378:       // (property declarations, closing braces, semicolons, pipes for union types)\n379:       if (\n380:         trimmed === \"}\" ||\n381:         trimmed === \"};\" ||\n382:         trimmed === \"{\" ||\n383:         trimmed.startsWith(\"|\") ||\n384:         trimmed.startsWith(\"&\") ||\n385:         // Property-like lines in interfaces/types (e.g., \"  name: string;\")\n386:         /^[a-zA-Z_$][\\w$?]*\\s*[?]?\\s*:\\s*.+[;,]?\\s*$/.test(trimmed) ||\n387:         /^\\[[\\w\\s:]+\\]\\s*:\\s*.+[;,]?\\s*$/.test(trimmed) || // index signatures\n388:         // Readonly modifier\n389:         trimmed.startsWith(\"readonly \")\n390:       ) {\n391:         continue;\n392:       }\n393: \n394:       // Any other line is runtime code\n395:       return false;\n396:     }\n397: \n398:     return hasTypeDecl; // Must have at least one type declaration\n399:   } catch {\n400:     return false;\n401:   }\n402: }\n403: \n404: // ---------------------------------------------------------------------------\n405: // Test File Matching\n406: // ---------------------------------------------------------------------------\n407: \n408: /**\n409:  * Find existing test files that correspond to a given source file.\n410:  *\n411:  * Strategy: For a source file like `src/lib/foo.ts`, look for:\n412:  *   1. tests/foo.test.ts (flat test dir)\n413:  *   2. tests/lib/foo.test.ts (mirrored structure)\n414:  *   3. src/lib/foo.test.ts (co-located)\n415:  *   4. tests/foo.spec.ts (spec variant)\n416:  *   5. tests/lib/foo.spec.ts (mirrored spec)\n417:  *   6. src/lib/foo.spec.ts (co-located spec)\n418:  *   7. test/foo.test.ts, test/lib/foo.test.ts (singular test dir)\n419:  *\n420:  * Also scans existing test directories for any test file that matches\n421:  * the basename pattern.\n422:  */\n423: export function findTestFiles(\n424:   sourcePath: string,\n425:   projectRoot: string,\n426:   _config: TestDetectionConfig = DEFAULT_TEST_DETECTION_CONFIG\n427: ): string[] {\n428:   const name = basename(sourcePath);\n429:   const ext = name.endsWith(\".tsx\") ? \".tsx\" : \".ts\";\n430:   const nameWithoutExt = name.replace(/\\.(tsx?|jsx?)$/, \"\");\n431:   const sourceDir = dirname(sourcePath);\n432: \n433:   // Build candidate test file paths\n434:   const candidates: string[] = [];\n435: \n436:   // Remove the first source directory prefix for mirrored paths\n437:   // e.g., \"src/lib/foo.ts\" → \"lib/foo.ts\"\n438:   const relativeFromSrc = sourceDir.startsWith(\"src/\")\n439:     ? sourceDir.slice(4)\n440:     : sourceDir.startsWith(\"src\")\n441:       ? sourceDir.slice(3)\n442:       : sourceDir;\n443: \n444:   const testSuffixes = [\".test\", \".spec\"];\n445:   const testDirs = [\"tests\", \"test\", \"__tests__\"];\n446: \n447:   for (const suffix of testSuffixes) {\n448:     // Flat test directory: tests/foo.test.ts\n449:     for (const testDir of testDirs) {\n450:       candidates.push(`${testDir}/${nameWithoutExt}${suffix}${ext}`);\n451:     }\n452: \n453:     // Mirrored structure: tests/lib/foo.test.ts\n454:     if (relativeFromSrc) {\n455:       for (const testDir of testDirs) {\n456:         candidates.push(\n457:           `${testDir}/${relativeFromSrc}/${nameWithoutExt}${suffix}${ext}`\n458:         );\n459:       }\n460:     }\n461: \n462:     // Co-located: src/lib/foo.test.ts\n463:     candidates.push(`${sourceDir}/${nameWithoutExt}${suffix}${ext}`);\n464:   }\n465: \n466:   // Deduplicate and check existence\n467:   const found: string[] = [];\n468:   const seen = new Set<string>();\n469:   for (const candidate of candidates) {\n470:     // Normalize path (remove double slashes, etc.)\n471:     const normalized = candidate.replace(/\\/+/g, \"/\");\n472:     if (seen.has(normalized)) continue;\n473:     seen.add(normalized);\n474: \n475:     const absPath = resolve(projectRoot, normalized);\n476:     if (existsSync(absPath)) {\n477:       found.push(normalized);\n478:     }\n479:   }\n480: \n481:   // Additionally, scan test directories for any matching test file\n482:   // This catches cases where tests are organized differently\n483:   for (const testDir of testDirs) {\n484:     const absDirPath = resolve(projectRoot, testDir);\n485:     if (!existsSync(absDirPath)) continue;\n486:     try {\n487:       scanForMatchingTests(absDirPath, testDir, nameWithoutExt, found, seen);\n488:     } catch {\n489:       // Best effort — directory may not be readable\n490:     }\n491:   }\n492: \n493:   return found;\n494: }\n495: \n496: /**\n497:  * Recursively scan a directory for test files matching a source file name.\n498:  */\n499: function scanForMatchingTests(\n500:   dirPath: string,\n501:   relativeDirPath: string,\n502:   nameWithoutExt: string,\n503:   found: string[],\n504:   seen: Set<string>\n505: ): void {\n506:   let entries: string[];\n507:   try {\n508:     entries = readdirSync(dirPath);\n509:   } catch {\n510:     return;\n511:   }\n512: \n513:   for (const entry of entries) {\n514:     const entryPath = join(dirPath, entry);\n515:     const relPath = `${relativeDirPath}/${entry}`;\n516: \n517:     // Check if this is a matching test file\n518:     if (\n519:       entry === `${nameWithoutExt}.test.ts` ||\n520:       entry === `${nameWithoutExt}.test.tsx` ||\n521:       entry === `${nameWithoutExt}.spec.ts` ||\n522:       entry === `${nameWithoutExt}.spec.tsx`\n523:     ) {\n524:       const normalized = relPath.replace(/\\/+/g, \"/\");\n525:       if (!seen.has(normalized)) {\n526:         seen.add(normalized);\n527:         found.push(normalized);\n528:       }\n529:     }\n530: \n531:     // Recurse into subdirectories (limit depth to 5 to prevent runaway)\n532:     try {\n533:       const entryStat = statSync(entryPath);\n534:       if (entryStat.isDirectory() && relativeDirPath.split(\"/\").length < 6) {\n535:         scanForMatchingTests(entryPath, relPath, nameWithoutExt, found, seen);\n536:       }\n537:     } catch {\n538:       // Skip unreadable entries\n539:     }\n540:   }\n541: }\n542: \n543: // ---------------------------------------------------------------------------\n544: // Main Detection Logic\n545: // ---------------------------------------------------------------------------\n546: \n547: /**\n548:  * Run test detection analysis on a project.\n549:  *\n550:  * @param projectRoot - Absolute path to the project root\n551:  * @param compareRef - Git ref to compare against (default: \"HEAD~1\")\n552:  * @param config - Test detection configuration (uses defaults if omitted)\n553:  * @returns Structured test detection report\n554:  */\n555: export function detectTests(\n556:   projectRoot: string,\n557:   compareRef: string = \"HEAD~1\",\n558:   config: TestDetectionConfig = DEFAULT_TEST_DETECTION_CONFIG\n559: ): TestDetectionReport {\n560:   // Step 1: Get changed files from git diff\n561:   const changedFiles = getChangedFiles(projectRoot, compareRef);\n562: \n563:   // Step 2: Filter to source files only\n564:   const sourceFiles = filterSourceFiles(changedFiles, config);\n565: \n566:   // Step 3: Analyze each source file\n567:   const results: SourceFileTestInfo[] = [];\n568:   const withTests: string[] = [];\n569:   const missingTests: string[] = [];\n570:   const excludedFiles: string[] = [];\n571: \n572:   for (const file of sourceFiles) {\n573:     // Check exclusions\n574:     const exclusion = isExcludedFile(file.path, projectRoot, config);\n575: \n576:     if (exclusion.excluded) {\n577:       results.push({\n578:         sourcePath: file.path,\n579:         hasTest: false,\n580:         testFiles: [],\n581:         excluded: true,\n582:         excludeReason: exclusion.reason,\n583:       });\n584:       excludedFiles.push(file.path);\n585:       continue;\n586:     }\n587: \n588:     // Find test files\n589:     const testFiles = findTestFiles(file.path, projectRoot, config);\n590:     const hasTest = testFiles.length > 0;\n591: \n592:     results.push({\n593:       sourcePath: file.path,\n594:       hasTest,\n595:       testFiles,\n596:       excluded: false,\n597:     });\n598: \n599:     if (hasTest) {\n600:       withTests.push(file.path);\n601:     } else {\n602:       missingTests.push(file.path);\n603:     }\n604:   }\n605: \n606:   // Step 4: Calculate coverage\n607:   const testableCount = results.filter((r) => !r.excluded).length;\n608:   const coveredCount = withTests.length;\n609:   const coverageRatio =\n610:     testableCount > 0 ? coveredCount / testableCount : NaN;\n611:   const coveragePercent = isNaN(coverageRatio)\n612:     ? \"N/A\"\n613:     : `${(coverageRatio * 100).toFixed(1)}%`;\n614: \n615:   return {\n616:     sourceFiles: results,\n617:     withTests,\n618:     missingTests,\n619:     excludedFiles,\n620:     testableCount,\n621:     coveredCount,\n622:     coverageRatio,\n623:     coveragePercent,\n624:     comparedTo: compareRef,\n625:   };\n626: }\n627: \n628: // ---------------------------------------------------------------------------\n629: // Text Rendering\n630: // ---------------------------------------------------------------------------\n631: \n632: /**\n633:  * Render a test detection report as human-readable text to stdout.\n634:  * Used by the output() helper in text mode.\n635:  */\n636: export function renderTestDetectionReport(report: TestDetectionReport): void {\n637:   console.log(`\\n${\"─\".repeat(60)}`);\n638:   console.log(`  Test Detection Report (compared to ${report.comparedTo})`);\n639:   console.log(`${\"─\".repeat(60)}`);\n640: \n641:   if (report.sourceFiles.length === 0) {\n642:     console.log(\"  No source files changed.\\n\");\n643:     return;\n644:   }\n645: \n646:   // Files with tests\n647:   if (report.withTests.length > 0) {\n648:     console.log(`\\n  \\x1b[32m✓ Files with tests (${report.withTests.length}):\\x1b[0m`);\n649:     for (const info of report.sourceFiles.filter((f) => f.hasTest)) {\n650:       const tests = info.testFiles.join(\", \");\n651:       console.log(`    ${info.sourcePath} → ${tests}`);\n652:     }\n653:   }\n654: \n655:   // Files missing tests\n656:   if (report.missingTests.length > 0) {\n657:     console.log(`\\n  \\x1b[31m✗ Files missing tests (${report.missingTests.length}):\\x1b[0m`);\n658:     for (const path of report.missingTests) {\n659:       console.log(`    ${path}`);\n660:     }\n661:   }\n662: \n663:   // Excluded files\n664:   if (report.excludedFiles.length > 0) {\n665:     console.log(`\\n  \\x1b[33m⊘ Excluded files (${report.excludedFiles.length}):\\x1b[0m`);\n666:     for (const info of report.sourceFiles.filter((f) => f.excluded)) {\n667:       console.log(`    ${info.sourcePath} — ${info.excludeReason}`);\n668:     }\n669:   }\n670: \n671:   // Summary\n672:   console.log(`\\n${\"─\".repeat(60)}`);\n673:   console.log(\n674:     `  Coverage: ${report.coveredCount}/${report.testableCount} testable files ` +\n675:     `(${report.coveragePercent})`\n676:   );\n677:   console.log(`${\"─\".repeat(60)}\\n`);\n678: }\n\n(End of file - total 678 lines)\n</content>","title":"src/lib/test-detection.ts","metadata":{"preview":"/**\n * test-detection.ts — Detect test files and coverage for new/modified code.\n *\n * Responsibilities:\n *   - Parse `git diff --name-status` to find added/modified .ts files in src/\n *   - For each source file, check if corresponding test files exist\n *   - Use configurable test file patterns (default: tests/**\\/*.test.ts, src/**\\/*.test.ts)\n *   - Exclude non-testable files: *.d.ts, index.ts (re-export barrels), types-only files\n *   - Report: source files missing tests, source files with tests, coverage ratio\n *   - Output as structured data compatible with outputMessage() for --output json\n *\n * Exported for use by tdd-verification-step and other consumers.\n */\n\nimport { execSync } from \"node:child_process\";\nimport { existsSync, readFileSync, readdirSync, statSync } from \"node:fs\";\nimport { resolve, basename, dirname, relative, join } from \"node:path\";\n\n// ---------------------------------------------------------------------------\n// Types","truncated":false,"loaded":[]},"time":{"start":1773445786363,"end":1773445786373}}}}
{"type":"tool_use","timestamp":1773445786958,"sessionID":"ses_316650d1dffespdzjLs3PfWdD3","part":{"id":"prt_ce99b2afd0013KxX2axuLlxqYE","sessionID":"ses_316650d1dffespdzjLs3PfWdD3","messageID":"msg_ce99b1c1f001aboGM4m9QoZxVc","type":"tool","callID":"toolu_vrtx_01AE9D17Ug6wwKuvmYaTYWgS","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/tdd-red-green-coercion/src/lib/test-runner.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/tdd-red-green-coercion/src/lib/test-runner.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * test-runner.ts — Run test commands and capture results.\n3:  *\n4:  * Responsibilities:\n5:  *   - Run the configured test command (e.g. `bun test`) in a worktree\n6:  *   - Capture exit code, stdout, stderr\n7:  *   - Parse test output to extract pass/fail counts\n8:  *   - Produce structured TestRunResult for the TDD verification pipeline\n9:  *\n10:  * This module is used by tdd-verifier.ts as part of the TDD verification step.\n11:  */\n12: \n13: import { exec } from \"node:child_process\";\n14: \n15: // ---------------------------------------------------------------------------\n16: // Types\n17: // ---------------------------------------------------------------------------\n18: \n19: /** Result of running the test command */\n20: export interface TestRunResult {\n21:   /** Whether the test command exited successfully (exit code 0) */\n22:   passed: boolean;\n23:   /** Process exit code */\n24:   exitCode: number;\n25:   /** Standard output */\n26:   stdout: string;\n27:   /** Standard error */\n28:   stderr: string;\n29:   /** Duration in milliseconds */\n30:   durationMs: number;\n31:   /** Parsed test counts (best-effort extraction from output) */\n32:   testCounts: TestCounts;\n33:   /** Error summary for retry prompts (empty if passed) */\n34:   errorSummary: string;\n35: }\n36: \n37: /** Parsed test pass/fail counts from test runner output */\n38: export interface TestCounts {\n39:   /** Total number of tests detected */\n40:   total: number;\n41:   /** Number of passing tests */\n42:   passed: number;\n43:   /** Number of failing tests */\n44:   failed: number;\n45:   /** Number of skipped tests */\n46:   skipped: number;\n47:   /** Whether counts could be parsed from output */\n48:   parsed: boolean;\n49: }\n50: \n51: // ---------------------------------------------------------------------------\n52: // Test Runner\n53: // ---------------------------------------------------------------------------\n54: \n55: /**\n56:  * Run the test command in a worktree directory.\n57:  *\n58:  * @param worktreePath - Absolute path to the worktree\n59:  * @param testCommand - Test command to run (e.g., \"bun test\")\n60:  * @param timeout - Timeout in milliseconds (default: 120_000)\n61:  * @returns Structured test run result\n62:  */\n63: export function runTests(\n64:   worktreePath: string,\n65:   testCommand: string,\n66:   timeout: number = 120_000\n67: ): Promise<TestRunResult> {\n68:   return new Promise((resolvePromise) => {\n69:     const start = Date.now();\n70: \n71:     exec(\n72:       testCommand,\n73:       {\n74:         cwd: worktreePath,\n75:         encoding: \"utf-8\",\n76:         timeout,\n77:         maxBuffer: 10 * 1024 * 1024,\n78:       },\n79:       (error, stdout, stderr) => {\n80:         const durationMs = Date.now() - start;\n81:         const exitCode = error ? (error as any).code ?? 1 : 0;\n82:         const passed = !error;\n83: \n84:         const testCounts = parseTestCounts(stdout ?? \"\", stderr ?? \"\");\n85: \n86:         let errorSummary = \"\";\n87:         if (!passed) {\n88:           errorSummary = extractTestErrorSummary(stdout ?? \"\", stderr ?? \"\");\n89:         }\n90: \n91:         resolvePromise({\n92:           passed,\n93:           exitCode,\n94:           stdout: stdout ?? \"\",\n95:           stderr: stderr ?? \"\",\n96:           durationMs,\n97:           testCounts,\n98:           errorSummary,\n99:         });\n100:       }\n101:     );\n102:   });\n103: }\n104: \n105: // ---------------------------------------------------------------------------\n106: // Output Parsing\n107: // ---------------------------------------------------------------------------\n108: \n109: /**\n110:  * Parse test counts from test runner output.\n111:  *\n112:  * Supports common formats:\n113:  *   - Bun test: \"42 pass, 3 fail, 2 skip\" or \"X pass\\nY fail\"\n114:  *   - Generic: \"Tests: X passed, Y failed, Z skipped, W total\"\n115:  *   - Jest-like: \"Tests:  X passed, Y failed, Z total\"\n116:  */\n117: export function parseTestCounts(stdout: string, stderr: string): TestCounts {\n118:   const combined = stdout + \"\\n\" + stderr;\n119:   const result: TestCounts = {\n120:     total: 0,\n121:     passed: 0,\n122:     failed: 0,\n123:     skipped: 0,\n124:     parsed: false,\n125:   };\n126: \n127:   // Bun test format: \"42 pass\" and \"3 fail\" on separate or same lines\n128:   const bunPassMatch = combined.match(/(\\d+)\\s+pass/i);\n129:   const bunFailMatch = combined.match(/(\\d+)\\s+fail/i);\n130:   const bunSkipMatch = combined.match(/(\\d+)\\s+skip/i);\n131: \n132:   if (bunPassMatch || bunFailMatch) {\n133:     result.passed = bunPassMatch ? parseInt(bunPassMatch[1], 10) : 0;\n134:     result.failed = bunFailMatch ? parseInt(bunFailMatch[1], 10) : 0;\n135:     result.skipped = bunSkipMatch ? parseInt(bunSkipMatch[1], 10) : 0;\n136:     result.total = result.passed + result.failed + result.skipped;\n137:     result.parsed = true;\n138:     return result;\n139:   }\n140: \n141:   // Jest-like format: \"Tests:  X passed, Y failed, Z total\"\n142:   const jestMatch = combined.match(\n143:     /Tests:\\s+(\\d+)\\s+passed(?:,\\s+(\\d+)\\s+failed)?(?:,\\s+(\\d+)\\s+skipped)?(?:,\\s+(\\d+)\\s+total)?/i\n144:   );\n145:   if (jestMatch) {\n146:     result.passed = parseInt(jestMatch[1], 10);\n147:     result.failed = jestMatch[2] ? parseInt(jestMatch[2], 10) : 0;\n148:     result.skipped = jestMatch[3] ? parseInt(jestMatch[3], 10) : 0;\n149:     result.total = jestMatch[4]\n150:       ? parseInt(jestMatch[4], 10)\n151:       : result.passed + result.failed + result.skipped;\n152:     result.parsed = true;\n153:     return result;\n154:   }\n155: \n156:   return result;\n157: }\n158: \n159: /**\n160:  * Extract a concise error summary from test output.\n161:  * Used for retry prompts when tests fail.\n162:  */\n163: export function extractTestErrorSummary(\n164:   stdout: string,\n165:   stderr: string\n166: ): string {\n167:   const combined = stdout + \"\\n\" + stderr;\n168:   const lines = combined.split(\"\\n\");\n169: \n170:   const errorLines: string[] = [];\n171:   let capturing = false;\n172:   let contextLines = 0;\n173: \n174:   for (const line of lines) {\n175:     const isError =\n176:       /(?:error|fail|FAIL|Error|AssertionError|expect\\()/i.test(line) &&\n177:       !/warning/i.test(line);\n178: \n179:     if (isError) {\n180:       capturing = true;\n181:       contextLines = 0;\n182:       errorLines.push(line);\n183:     } else if (capturing) {\n184:       contextLines++;\n185:       if (contextLines <= 5) {\n186:         errorLines.push(line);\n187:       } else {\n188:         capturing = false;\n189:       }\n190:     }\n191:   }\n192: \n193:   if (errorLines.length === 0) {\n194:     // Fall back to last 30 lines\n195:     const tail = lines.slice(-30).join(\"\\n\");\n196:     return truncate(tail, 3000);\n197:   }\n198: \n199:   return truncate(errorLines.join(\"\\n\"), 3000);\n200: }\n201: \n202: /**\n203:  * Truncate a string to maxLen characters.\n204:  */\n205: function truncate(s: string, maxLen: number): string {\n206:   if (s.length <= maxLen) return s;\n207:   return s.slice(0, maxLen) + \"\\n\\n[... truncated]\";\n208: }\n\n(End of file - total 208 lines)\n</content>","title":"src/lib/test-runner.ts","metadata":{"preview":"/**\n * test-runner.ts — Run test commands and capture results.\n *\n * Responsibilities:\n *   - Run the configured test command (e.g. `bun test`) in a worktree\n *   - Capture exit code, stdout, stderr\n *   - Parse test output to extract pass/fail counts\n *   - Produce structured TestRunResult for the TDD verification pipeline\n *\n * This module is used by tdd-verifier.ts as part of the TDD verification step.\n */\n\nimport { exec } from \"node:child_process\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\n/** Result of running the test command */\nexport interface TestRunResult {","truncated":false,"loaded":[]},"time":{"start":1773445786947,"end":1773445786955}}}}
{"type":"tool_use","timestamp":1773445787455,"sessionID":"ses_316650d1dffespdzjLs3PfWdD3","part":{"id":"prt_ce99b2d45001DeuDQ1PMxZvZEj","sessionID":"ses_316650d1dffespdzjLs3PfWdD3","messageID":"msg_ce99b1c1f001aboGM4m9QoZxVc","type":"tool","callID":"toolu_vrtx_01SssqAZCNn2W1BCtazGJnrA","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/tdd-red-green-coercion/src/lib/verifier.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/tdd-red-green-coercion/src/lib/verifier.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * verifier.ts — Build verification in worktrees.\n3:  *\n4:  * Responsibilities:\n5:  *   - Run the project build command in a worktree\n6:  *   - Capture and parse build output\n7:  *   - Determine pass/fail\n8:  *   - Extract error messages for retry prompts\n9:  *   - Run browser-based verification when enabled\n10:  *   - Run TDD verification (tests + test detection) when enabled\n11:  *\n12:  * IMPORTANT: runBuild is ASYNC — does not block the event loop.\n13:  */\n14: \n15: import { exec } from \"node:child_process\";\n16: import { existsSync } from \"node:fs\";\n17: import { resolve } from \"node:path\";\n18: import type { WomboConfig } from \"../config.js\";\n19: import {\n20:   runBrowserVerification,\n21:   extractBrowserErrorSummary,\n22:   type BrowserVerificationResult,\n23: } from \"./browser-verifier.js\";\n24: import {\n25:   runTddVerification,\n26:   extractTddErrorSummary,\n27:   type TddVerificationResult,\n28: } from \"./tdd-verifier.js\";\n29: \n30: // ---------------------------------------------------------------------------\n31: // Types\n32: // ---------------------------------------------------------------------------\n33: \n34: export interface BuildResult {\n35:   passed: boolean;\n36:   exitCode: number;\n37:   stdout: string;\n38:   stderr: string;\n39:   /** Combined output, truncated for use in retry prompts */\n40:   errorSummary: string;\n41:   /** Duration in milliseconds */\n42:   durationMs: number;\n43: }\n44: \n45: /** Options for controlling the full verification pipeline */\n46: export interface FullVerificationOptions {\n47:   /** Skip running tests (--skip-tests) */\n48:   skipTests?: boolean;\n49:   /** Strict TDD mode — fail if new files are missing tests (--strict-tdd) */\n50:   strictTdd?: boolean;\n51: }\n52: \n53: /**\n54:  * Combined result of build verification + browser verification + TDD verification.\n55:  */\n56: export interface FullVerificationResult {\n57:   /** Build result (always runs) */\n58:   build: BuildResult;\n59:   /** Browser verification result (may be skipped) */\n60:   browser: BrowserVerificationResult;\n61:   /** TDD verification result (may be skipped) */\n62:   tdd: TddVerificationResult;\n63:   /** Overall pass: build passed AND browser passed AND tdd passed */\n64:   overallPassed: boolean;\n65:   /** Combined error summary for retry prompts */\n66:   combinedErrorSummary: string;\n67: }\n68: \n69: // ---------------------------------------------------------------------------\n70: // Build Verification\n71: // ---------------------------------------------------------------------------\n72: \n73: /**\n74:  * Run the build command in a worktree directory.\n75:  * Uses config for the build command and timeout.\n76:  */\n77: export function runBuild(\n78:   worktreePath: string,\n79:   config: WomboConfig\n80: ): Promise<BuildResult> {\n81:   return new Promise((resolvePromise) => {\n82:     const start = Date.now();\n83: \n84:     exec(\n85:       config.build.command,\n86:       {\n87:         cwd: worktreePath,\n88:         encoding: \"utf-8\",\n89:         timeout: config.build.timeout,\n90:         maxBuffer: 10 * 1024 * 1024,\n91:       },\n92:       (error, stdout, stderr) => {\n93:         const durationMs = Date.now() - start;\n94:         const exitCode = error ? (error as any).code ?? 1 : 0;\n95:         const passed = !error;\n96: \n97:         let errorSummary = \"\";\n98:         if (!passed) {\n99:           errorSummary = extractErrorSummary(stdout ?? \"\", stderr ?? \"\");\n100:         }\n101: \n102:         resolvePromise({\n103:           passed,\n104:           exitCode,\n105:           stdout: stdout ?? \"\",\n106:           stderr: stderr ?? \"\",\n107:           errorSummary,\n108:           durationMs,\n109:         });\n110:       }\n111:     );\n112:   });\n113: }\n114: \n115: // ---------------------------------------------------------------------------\n116: // Error Extraction\n117: // ---------------------------------------------------------------------------\n118: \n119: /**\n120:  * Extract a concise error summary from build output.\n121:  */\n122: function extractErrorSummary(stdout: string, stderr: string): string {\n123:   const combined = stdout + \"\\n\" + stderr;\n124:   const lines = combined.split(\"\\n\");\n125: \n126:   const errorLines: string[] = [];\n127:   let capturing = false;\n128:   let contextLines = 0;\n129: \n130:   for (const line of lines) {\n131:     const isError =\n132:       /error/i.test(line) &&\n133:       !/warning/i.test(line) &&\n134:       !/^info/i.test(line);\n135:     const isTypeError = /TS\\d+/.test(line);\n136: \n137:     if (isError || isTypeError) {\n138:       capturing = true;\n139:       contextLines = 0;\n140:       errorLines.push(line);\n141:     } else if (capturing) {\n142:       contextLines++;\n143:       if (contextLines <= 3) {\n144:         errorLines.push(line);\n145:       } else {\n146:         capturing = false;\n147:       }\n148:     }\n149:   }\n150: \n151:   if (errorLines.length === 0) {\n152:     const tail = lines.slice(-50).join(\"\\n\");\n153:     return truncate(tail, 4000);\n154:   }\n155: \n156:   return truncate(errorLines.join(\"\\n\"), 4000);\n157: }\n158: \n159: /**\n160:  * Truncate a string to maxLen characters.\n161:  */\n162: function truncate(s: string, maxLen: number): string {\n163:   if (s.length <= maxLen) return s;\n164:   return s.slice(0, maxLen) + \"\\n\\n[... truncated, showing first 4000 chars]\";\n165: }\n166: \n167: // ---------------------------------------------------------------------------\n168: // Quick Check\n169: // ---------------------------------------------------------------------------\n170: \n171: /**\n172:  * Quick check if the build artifacts exist.\n173:  */\n174: export function hasBuildArtifacts(\n175:   worktreePath: string,\n176:   config: WomboConfig\n177: ): boolean {\n178:   try {\n179:     return existsSync(resolve(worktreePath, config.build.artifactDir));\n180:   } catch {\n181:     return false;\n182:   }\n183: }\n184: \n185: // ---------------------------------------------------------------------------\n186: // Full Verification (Build + Browser)\n187: // ---------------------------------------------------------------------------\n188: \n189: /**\n190:  * Run the complete verification pipeline:\n191:  *   1. Run the build command\n192:  *   2. If build passes and browser testing is enabled, run browser tests\n193:  *   3. If build passes and TDD is enabled, run tests + test detection\n194:  *\n195:  * Browser testing and TDD verification are additive — they run AFTER the\n196:  * build passes and are skipped if the build fails.\n197:  */\n198: export async function runFullVerification(\n199:   worktreePath: string,\n200:   featureId: string,\n201:   config: WomboConfig,\n202:   opts?: FullVerificationOptions\n203: ): Promise<FullVerificationResult> {\n204:   const skipTests = opts?.skipTests ?? false;\n205:   const strictTdd = opts?.strictTdd ?? false;\n206: \n207:   // Default TDD result (skipped)\n208:   const defaultTddResult: TddVerificationResult = {\n209:     ran: false,\n210:     skipReason: \"Skipped because build failed\",\n211:     testRun: null,\n212:     testDetection: null,\n213:     passed: true,\n214:     hasWarnings: false,\n215:     summary: \"TDD verification skipped (build failed)\",\n216:     strictMode: strictTdd,\n217:   };\n218: \n219:   // Step 1: Build verification (always runs)\n220:   const buildResult = await runBuild(worktreePath, config);\n221: \n222:   // If build failed, skip browser testing and TDD verification\n223:   if (!buildResult.passed) {\n224:     return {\n225:       build: buildResult,\n226:       browser: {\n227:         ran: false,\n228:         skipReason: \"Skipped because build failed\",\n229:         browserResult: null,\n230:       },\n231:       tdd: defaultTddResult,\n232:       overallPassed: false,\n233:       combinedErrorSummary: buildResult.errorSummary,\n234:     };\n235:   }\n236: \n237:   // Step 2: Browser verification (runs only if build passed and browser enabled)\n238:   const browserResult = await runBrowserVerification({\n239:     worktreePath,\n240:     featureId,\n241:     config,\n242:   });\n243: \n244:   // Step 3: TDD verification (runs only if build passed and TDD enabled)\n245:   const tddResult = await runTddVerification({\n246:     worktreePath,\n247:     featureId,\n248:     config,\n249:     skipTests,\n250:     strictTdd,\n251:     baseBranch: config.baseBranch,\n252:   });\n253: \n254:   // Determine overall pass\n255:   const browserPassed = !browserResult.ran || (browserResult.browserResult?.allPassed ?? true);\n256:   const tddPassed = tddResult.passed;\n257:   const overallPassed = buildResult.passed && browserPassed && tddPassed;\n258: \n259:   // Combine error summaries\n260:   let combinedErrorSummary = \"\";\n261:   if (!buildResult.passed) {\n262:     combinedErrorSummary = buildResult.errorSummary;\n263:   }\n264:   if (browserResult.ran && browserResult.browserResult && !browserResult.browserResult.allPassed) {\n265:     const browserErrors = extractBrowserErrorSummary(browserResult.browserResult);\n266:     combinedErrorSummary = combinedErrorSummary\n267:       ? `${combinedErrorSummary}\\n\\n--- Browser Test Errors ---\\n\\n${browserErrors}`\n268:       : browserErrors;\n269:   }\n270:   if (tddResult.ran && !tddResult.passed) {\n271:     const tddErrors = extractTddErrorSummary(tddResult);\n272:     combinedErrorSummary = combinedErrorSummary\n273:       ? `${combinedErrorSummary}\\n\\n--- TDD Verification Errors ---\\n\\n${tddErrors}`\n274:       : tddErrors;\n275:   }\n276: \n277:   return {\n278:     build: buildResult,\n279:     browser: browserResult,\n280:     tdd: tddResult,\n281:     overallPassed,\n282:     combinedErrorSummary,\n283:   };\n284: }\n\n(End of file - total 284 lines)\n</content>","title":"src/lib/verifier.ts","metadata":{"preview":"/**\n * verifier.ts — Build verification in worktrees.\n *\n * Responsibilities:\n *   - Run the project build command in a worktree\n *   - Capture and parse build output\n *   - Determine pass/fail\n *   - Extract error messages for retry prompts\n *   - Run browser-based verification when enabled\n *   - Run TDD verification (tests + test detection) when enabled\n *\n * IMPORTANT: runBuild is ASYNC — does not block the event loop.\n */\n\nimport { exec } from \"node:child_process\";\nimport { existsSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\nimport type { WomboConfig } from \"../config.js\";\nimport {\n  runBrowserVerification,","truncated":false,"loaded":[]},"time":{"start":1773445787450,"end":1773445787454}}}}
{"type":"tool_use","timestamp":1773445789092,"sessionID":"ses_316650d1dffespdzjLs3PfWdD3","part":{"id":"prt_ce99b2fa3001Oj2Afqmo7yKfuH","sessionID":"ses_316650d1dffespdzjLs3PfWdD3","messageID":"msg_ce99b1c1f001aboGM4m9QoZxVc","type":"tool","callID":"toolu_vrtx_01WQv7pJdsud53pfC1Kvj5qv","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/tdd-red-green-coercion/src/lib/prompt.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/tdd-red-green-coercion/src/lib/prompt.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * prompt.ts — Generate agent prompts from feature specs.\n3:  *\n4:  * Responsibilities:\n5:  *   - Transform a Feature into a structured prompt for the agent\n6:  *   - Include feature spec, subtasks, constraints, forbidden items, references\n7:  *   - Generate the build command and success criteria\n8:  *   - All project-specific values come from config (no hardcoded Astro references)\n9:  */\n10: \n11: import type { Feature, Subtask } from \"./tasks.js\";\n12: import { formatDuration, parseDurationMinutes } from \"./tasks.js\";\n13: import type { WomboConfig } from \"../config.js\";\n14: import { isPortlessAvailable, portlessUrl } from \"./portless.js\";\n15: \n16: // ---------------------------------------------------------------------------\n17: // Prompt Generation\n18: // ---------------------------------------------------------------------------\n19: \n20: /**\n21:  * Generate the full prompt for an autonomous agent working on a feature.\n22:  */\n23: export function generatePrompt(\n24:   feature: Feature,\n25:   baseBranch: string,\n26:   config: WomboConfig\n27: ): string {\n28:   const sections: string[] = [];\n29: \n30:   // Header\n31:   sections.push(`# Feature Implementation: ${feature.title}`);\n32:   sections.push(`**Feature ID:** \\`${feature.id}\\``);\n33:   sections.push(`**Branch:** \\`${config.git.branchPrefix}${feature.id}\\``);\n34:   sections.push(`**Base:** \\`${baseBranch}\\``);\n35:   sections.push(\n36:     `**Estimated Effort:** ${formatDuration(parseDurationMinutes(feature.effort))}`\n37:   );\n38:   sections.push(\n39:     `**Difficulty:** ${feature.difficulty} | **Priority:** ${feature.priority}`\n40:   );\n41: \n42:   // Description\n43:   sections.push(`\\n## Description\\n`);\n44:   sections.push(feature.description.trim());\n45: \n46:   // Subtasks\n47:   if (feature.subtasks.length > 0) {\n48:     sections.push(`\\n## Subtasks\\n`);\n49:     sections.push(\n50:       \"Complete these in order. Mark each done with a commit when finished.\\n\"\n51:     );\n52:     for (let i = 0; i < feature.subtasks.length; i++) {\n53:       sections.push(formatSubtask(feature.subtasks[i], i + 1, 0));\n54:     }\n55:   }\n56: \n57:   // Constraints\n58:   if (feature.constraints.length > 0) {\n59:     sections.push(`\\n## Constraints\\n`);\n60:     sections.push(\n61:       \"You MUST follow these constraints. Violating any is a failure.\\n\"\n62:     );\n63:     for (const c of feature.constraints) {\n64:       sections.push(`- ${c}`);\n65:     }\n66:   }\n67: \n68:   // Forbidden\n69:   if (feature.forbidden.length > 0) {\n70:     sections.push(`\\n## Forbidden\\n`);\n71:     sections.push(\n72:       \"You MUST NOT do any of the following. Violating any is a failure.\\n\"\n73:     );\n74:     for (const f of feature.forbidden) {\n75:       sections.push(`- ${f}`);\n76:     }\n77:   }\n78: \n79:   // References (files to explore)\n80:   if (feature.references.length > 0) {\n81:     sections.push(`\\n## Key Files to Explore\\n`);\n82:     sections.push(\n83:       \"Start by reading these files to understand the current state:\\n\"\n84:     );\n85:     for (const r of feature.references) {\n86:       sections.push(`- \\`${r}\\``);\n87:     }\n88:   }\n89: \n90:   // Notes\n91:   if (feature.notes.length > 0) {\n92:     sections.push(`\\n## Planning Notes\\n`);\n93:     for (const n of feature.notes) {\n94:       sections.push(`- ${n}`);\n95:     }\n96:   }\n97: \n98:   // Build verification — uses config, no hardcoded Astro command\n99:   sections.push(`\\n## Build Verification\\n`);\n100:   sections.push(\n101:     \"After completing all changes, run the build to verify everything works:\\n\"\n102:   );\n103:   sections.push(\"```bash\");\n104:   sections.push(config.build.command);\n105:   sections.push(\"```\\n\");\n106:   sections.push(\n107:     \"If the build fails, fix the errors before considering the task complete.\"\n108:   );\n109: \n110:   // Browser testing — inform agents about browser verification capabilities\n111:   if (config.browser.enabled) {\n112:     sections.push(`\\n## Browser Testing\\n`);\n113:     sections.push(\n114:       \"This project has browser-based verification enabled. After the build passes, \" +\n115:       \"browser tests will run automatically as part of the verification pipeline.\\n\"\n116:     );\n117:     sections.push(\"To add browser tests for this feature:\\n\");\n118:     sections.push(\"1. Create the directory `.wombo-browser/tests/` in the worktree root\");\n119:     sections.push(\"2. Add test scripts (`.sh`, `.ts`, or `.js` files) that will be executed in order\");\n120:     sections.push(\"3. Each test script receives these environment variables:\");\n121:     sections.push(\"   - `BROWSER_DEBUG_PORT` — Chrome DevTools Protocol port\");\n122:     sections.push(\"   - `BROWSER_WS_ENDPOINT` — WebSocket endpoint for the browser\");\n123:     sections.push(\"   - `BROWSER_HEADLESS` — whether the browser is running headless\");\n124:     sections.push(\"   - `BROWSER_SCREENSHOT_PATH` — path to save a screenshot for this test\");\n125:     sections.push(\"4. A test passes if it exits with code 0, fails otherwise\\n\");\n126:     if (config.browser.testCommand) {\n127:       sections.push(\n128:         `Alternatively, the project uses a custom browser test command: \\`${config.browser.testCommand}\\``\n129:       );\n130:     }\n131:     sections.push(\n132:       \"\\nBrowser tests are optional — if no tests are found, browser verification is skipped.\"\n133:     );\n134:   }\n135: \n136:   // Portless server testing instructions\n137:   if (config.portless.enabled && isPortlessAvailable(config)) {\n138:     sections.push(`\\n## Server Testing (portless)\\n`);\n139:     sections.push(\n140:       \"This worktree is configured with **portless** to prevent port collisions \" +\n141:       \"between concurrent agents. When starting any localhost server for testing:\\n\"\n142:     );\n143:     sections.push(\"```bash\");\n144:     sections.push(\"# Instead of running a server directly:\");\n145:     sections.push(\"#   npm run dev\");\n146:     sections.push(\"#   bun run dev\");\n147:     sections.push(\"#   node server.js\");\n148:     sections.push(\"\");\n149:     sections.push(\"# Wrap it with portless:\");\n150:     sections.push(`portless run npm run dev`);\n151:     sections.push(`portless run bun run dev`);\n152:     sections.push(`portless run node server.js`);\n153:     sections.push(\"```\\n\");\n154:     sections.push(\n155:       `Your dev server will be available at: \\`${portlessUrl(feature.id, config)}\\``\n156:     );\n157:     sections.push(\"\");\n158:     sections.push(\"**Rules:**\");\n159:     sections.push(\"- ALWAYS use `portless run <command>` when starting any server that listens on a port\");\n160:     sections.push(\"- Do NOT hardcode port numbers — portless assigns ports automatically via the `PORT` env var\");\n161:     sections.push(\"- The `PORT` and `PORTLESS_URL` environment variables are set automatically\");\n162:     sections.push(\"- If you need to reference the server URL in tests or config, use the `PORTLESS_URL` env var\");\n163:   }\n164: \n165:   // TDD instructions — deterministic injection based on config\n166:   if (config.tdd?.enabled) {\n167:     const testCmd = config.tdd.testCommand || \"bun test\";\n168:     sections.push(`\\n## Test-Driven Development (TDD)\\n`);\n169:     sections.push(\n170:       \"You MUST follow the **red-green-refactor** TDD cycle for all implementation work:\\n\"\n171:     );\n172:     sections.push(\"### Workflow\\n\");\n173:     sections.push(`1. **🔴 Red** — Write a failing test first. Run \\`${testCmd}\\` to confirm it fails.`);\n174:     sections.push(`2. **🟢 Green** — Write minimal code to make the test pass. Run \\`${testCmd}\\` to confirm.`);\n175:     sections.push(`3. **🔵 Refactor** — Clean up while keeping tests green. Run \\`${testCmd}\\` after each change.`);\n176:     sections.push(`4. **Repeat** for each new behavior or edge case.\\n`);\n177:     sections.push(\"### Rules\\n\");\n178:     sections.push(\"- **Never skip the red step.** Every new behavior starts with a failing test.\");\n179:     sections.push(\"- **One behavior per cycle.** Each iteration covers exactly one small behavior.\");\n180:     sections.push(\"- **Commit at green.** Each commit should have all tests passing.\");\n181:     sections.push(`- **Run tests frequently.** Run \\`${testCmd}\\` after every meaningful change.`);\n182:     sections.push(\"- Use `import { describe, test, expect } from \\\"bun:test\\\";` for test files.\");\n183:     sections.push(\"- Place tests next to source: `src/foo.ts` → `src/foo.test.ts` (or `tests/foo.test.ts`).\");\n184:   }\n185: \n186:   // Commit guidelines\n187:   sections.push(`\\n## Commit Guidelines\\n`);\n188:   sections.push(\"- Use conventional commits: `feat(scope):`, `fix(scope):`, `refactor(scope):`, `docs(scope):`\");\n189:   sections.push(`- Scope should be: \\`${feature.id}\\` or a relevant module name`);\n190:   sections.push(\"- Commit after each logical unit of work (roughly per subtask)\");\n191:   sections.push(\"- Do NOT squash all changes into one commit\");\n192:   sections.push(\"- Do NOT push to remote -- the orchestrator handles that\");\n193:   sections.push(`- Do NOT modify \\`${config.tasksDir}\\` -- the orchestrator handles that`);\n194: \n195:   // Final instruction\n196:   sections.push(`\\n## Execution\\n`);\n197:   sections.push(\"1. Read the key files listed above to understand the codebase\");\n198:   sections.push(\"2. Create a plan (use the TodoWrite tool)\");\n199:   sections.push(\"3. Implement each subtask, committing as you go\");\n200:   sections.push(`4. Run \\`${config.build.command}\\` to verify`);\n201:   sections.push(\"5. If the build passes, you are done\");\n202:   sections.push(\"6. If the build fails, fix the errors and re-run until it passes\");\n203: \n204:   return sections.join(\"\\n\");\n205: }\n206: \n207: // ---------------------------------------------------------------------------\n208: // Subtask Formatting\n209: // ---------------------------------------------------------------------------\n210: \n211: // ---------------------------------------------------------------------------\n212: // Conflict Resolution Prompt\n213: // ---------------------------------------------------------------------------\n214: \n215: /**\n216:  * Generate a prompt for an agent that resolves merge conflicts.\n217:  *\n218:  * The agent is launched in the feature worktree AFTER `git merge <baseBranch>`\n219:  * has been run there, leaving conflict markers in the working tree.\n220:  */\n221: export function generateConflictResolutionPrompt(\n222:   feature: Feature,\n223:   baseBranch: string,\n224:   mergeError: string,\n225:   config: WomboConfig\n226: ): string {\n227:   const sections: string[] = [];\n228: \n229:   sections.push(`# Merge Conflict Resolution: ${feature.title}`);\n230:   sections.push(`**Feature ID:** \\`${feature.id}\\``);\n231:   sections.push(`**Feature Branch:** \\`${config.git.branchPrefix}${feature.id}\\``);\n232:   sections.push(`**Base Branch:** \\`${baseBranch}\\``);\n233: \n234:   sections.push(`\\n## Situation\\n`);\n235:   sections.push(\n236:     `The feature branch \\`${config.git.branchPrefix}${feature.id}\\` has been completed and build-verified, ` +\n237:     `but merging it into \\`${baseBranch}\\` produced conflicts. The base branch (\\`${baseBranch}\\`) has been ` +\n238:     `merged INTO this feature branch's worktree, so the conflict markers are present in the working tree right now.`\n239:   );\n240: \n241:   sections.push(`\\n## Merge Error Output\\n`);\n242:   sections.push(\"```\");\n243:   sections.push(mergeError);\n244:   sections.push(\"```\");\n245: \n246:   sections.push(`\\n## Feature Description\\n`);\n247:   sections.push(feature.description.trim());\n248: \n249:   sections.push(`\\n## Your Task\\n`);\n250:   sections.push(\"1. Find all files with conflict markers (`<<<<<<<`, `=======`, `>>>>>>>`)\");\n251:   sections.push(\"2. Resolve each conflict by combining both sides intelligently:\");\n252:   sections.push(`   - The \\`HEAD\\` side is the feature's work (keep this intent)`);\n253:   sections.push(`   - The \\`${baseBranch}\\` side is upstream changes (integrate these)`);\n254:   sections.push(\"3. Remove ALL conflict markers — no `<<<<<<<`, `=======`, or `>>>>>>>` should remain\");\n255:   sections.push(\"4. Run the build to verify everything compiles:\");\n256:   sections.push(\"   ```bash\");\n257:   sections.push(`   ${config.build.command}`);\n258:   sections.push(\"   ```\");\n259:   sections.push(\"5. If the build fails, fix the errors\");\n260:   sections.push(\"6. Stage all resolved files and commit the merge:\");\n261:   sections.push(\"   ```bash\");\n262:   sections.push(\"   git add -A\");\n263:   sections.push('   git commit --no-edit');\n264:   sections.push(\"   ```\");\n265: \n266:   sections.push(`\\n## Rules\\n`);\n267:   sections.push(\"- Do NOT abort the merge (`git merge --abort`)\");\n268:   sections.push(\"- Do NOT create new branches or rebase\");\n269:   sections.push(\"- Do NOT push to remote\");\n270:   sections.push(`- Do NOT modify \\`${config.tasksDir}\\``);\n271:   sections.push(\"- Keep BOTH the feature's changes and the upstream changes where possible\");\n272:   sections.push(\"- If in doubt, prefer the feature's implementation but ensure upstream additions are not lost\");\n273: \n274:   return sections.join(\"\\n\");\n275: }\n276: \n277: // ---------------------------------------------------------------------------\n278: // Subtask Formatting\n279: // ---------------------------------------------------------------------------\n280: \n281: function formatSubtask(\n282:   subtask: Subtask,\n283:   index: number,\n284:   depth: number\n285: ): string {\n286:   const indent = \"  \".repeat(depth);\n287:   const lines: string[] = [];\n288: \n289:   lines.push(\n290:     `${indent}${index}. **${subtask.title}** (\\`${subtask.id}\\`, ${formatDuration(parseDurationMinutes(subtask.effort))})`\n291:   );\n292:   lines.push(`${indent}   ${subtask.description.trim()}`);\n293: \n294:   if (subtask.constraints.length > 0) {\n295:     for (const c of subtask.constraints) {\n296:       lines.push(`${indent}   - Constraint: ${c}`);\n297:     }\n298:   }\n299:   if (subtask.forbidden.length > 0) {\n300:     for (const f of subtask.forbidden) {\n301:       lines.push(`${indent}   - Forbidden: ${f}`);\n302:     }\n303:   }\n304:   if (subtask.references.length > 0) {\n305:     lines.push(\n306:       `${indent}   - Files: ${subtask.references.map((r) => `\\`${r}\\``).join(\", \")}`\n307:     );\n308:   }\n309:   if (subtask.depends_on.length > 0) {\n310:     lines.push(\n311:       `${indent}   - Depends on: ${subtask.depends_on.map((d) => `\\`${d}\\``).join(\", \")}`\n312:     );\n313:   }\n314: \n315:   // Nested subtasks\n316:   if (subtask.subtasks.length > 0) {\n317:     for (let i = 0; i < subtask.subtasks.length; i++) {\n318:       lines.push(formatSubtask(subtask.subtasks[i], i + 1, depth + 1));\n319:     }\n320:   }\n321: \n322:   return lines.join(\"\\n\");\n323: }\n\n(End of file - total 323 lines)\n</content>","title":"src/lib/prompt.ts","metadata":{"preview":"/**\n * prompt.ts — Generate agent prompts from feature specs.\n *\n * Responsibilities:\n *   - Transform a Feature into a structured prompt for the agent\n *   - Include feature spec, subtasks, constraints, forbidden items, references\n *   - Generate the build command and success criteria\n *   - All project-specific values come from config (no hardcoded Astro references)\n */\n\nimport type { Feature, Subtask } from \"./tasks.js\";\nimport { formatDuration, parseDurationMinutes } from \"./tasks.js\";\nimport type { WomboConfig } from \"../config.js\";\nimport { isPortlessAvailable, portlessUrl } from \"./portless.js\";\n\n// ---------------------------------------------------------------------------\n// Prompt Generation\n// ---------------------------------------------------------------------------\n\n/**","truncated":false,"loaded":[]},"time":{"start":1773445789088,"end":1773445789091}}}}
{"type":"tool_use","timestamp":1773445789116,"sessionID":"ses_316650d1dffespdzjLs3PfWdD3","part":{"id":"prt_ce99b35a1001DD4SwD3w6Cq2lp","sessionID":"ses_316650d1dffespdzjLs3PfWdD3","messageID":"msg_ce99b1c1f001aboGM4m9QoZxVc","type":"tool","callID":"toolu_vrtx_01Qyi9wHSZKxz8L27oerY2sv","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/tdd-red-green-coercion/src/config.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/tdd-red-green-coercion/src/config.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * config.ts — Load .wombo-combo/config.json, merge with defaults, validate, expose typed config.\n3:  *\n4:  * The config file lives at .wombo-combo/config.json inside the target project root.\n5:  * All values have sensible defaults so minimal config works out of the box.\n6:  */\n7: \n8: import { readFileSync, existsSync } from \"node:fs\";\n9: import { resolve } from \"node:path\";\n10: import type { MultiplexerPreference } from \"./lib/multiplexer.js\";\n11: \n12: // ---------------------------------------------------------------------------\n13: // .wombo-combo directory constant\n14: // ---------------------------------------------------------------------------\n15: \n16: /** Name of the directory that holds all wombo-combo files */\n17: export const WOMBO_DIR = \".wombo-combo\";\n18: \n19: // ---------------------------------------------------------------------------\n20: // Types\n21: // ---------------------------------------------------------------------------\n22: \n23: /** Agent registry download mode */\n24: export type AgentRegistryMode = \"auto\" | \"monitored\" | \"disabled\";\n25: \n26: export interface WomboConfig {\n27:   /** Directory name for task files relative to .wombo-combo/ (folder-based storage) */\n28:   tasksDir: string;\n29:   /** Directory name for archived task files relative to .wombo-combo/ */\n30:   archiveDir: string;\n31:   /** @deprecated Use tasksDir. Legacy single-file path relative to .wombo-combo/ */\n32:   tasksFile?: string;\n33:   /** @deprecated Use archiveDir. Legacy single-file path relative to .wombo-combo/ */\n34:   archiveFile?: string;\n35:   /** Base branch to create feature branches from */\n36:   baseBranch: string;\n37:   /** Build configuration */\n38:   build: {\n39:     /** Build command to run in worktrees */\n40:     command: string;\n41:     /** Build timeout in milliseconds */\n42:     timeout: number;\n43:     /** Build artifact directory (for quick \"did it build?\" checks) */\n44:     artifactDir: string;\n45:   };\n46:   /** Install configuration */\n47:   install: {\n48:     /** Install command to run in worktrees */\n49:     command: string;\n50:     /** Install timeout in milliseconds */\n51:     timeout: number;\n52:   };\n53:   /** Git configuration */\n54:   git: {\n55:     /** Branch name prefix for feature branches */\n56:     branchPrefix: string;\n57:     /** Git remote name */\n58:     remote: string;\n59:     /** Merge strategy flag */\n60:     mergeStrategy: string;\n61:   };\n62:   /** Agent configuration */\n63:   agent: {\n64:     /** Path to agent binary (null = auto-detect) */\n65:     bin: string | null;\n66:     /** Agent name to pass via --agent flag */\n67:     name: string;\n68:     /** Config files/dirs to copy into worktrees */\n69:     configFiles: string[];\n70:     /** Session name prefix for terminal multiplexer */\n71:     tmuxPrefix: string;\n72:     /** Terminal multiplexer preference: \"auto\" (prefer dmux), \"dmux\", or \"tmux\" */\n73:     multiplexer: MultiplexerPreference;\n74:   };\n75:   /** Portless integration for localhost server testing */\n76:   portless: {\n77:     /** Whether portless is enabled for agent worktrees */\n78:     enabled: boolean;\n79:     /** Path to portless binary (null = auto-detect via PATH) */\n80:     bin: string | null;\n81:     /** Proxy port (portless default is 1355) */\n82:     proxyPort: number;\n83:     /** Whether to use HTTPS mode */\n84:     https: boolean;\n85:   };\n86:   /** Backup configuration for tasks file */\n87:   backup: {\n88:     /** Maximum number of timestamped backups to keep */\n89:     maxBackups: number;\n90:   };\n91:   /** Default runtime values */\n92:   defaults: {\n93:     /** Max concurrent agents */\n94:     maxConcurrent: number;\n95:     /** Max retries per agent */\n96:     maxRetries: number;\n97:   };\n98:   /** Browser testing configuration */\n99:   browser: BrowserConfig;\n100:   /** Agent registry configuration for specialized agent downloads */\n101:   agentRegistry: AgentRegistryConfig;\n102:   /** Test-Driven Development configuration */\n103:   tdd: TddConfig;\n104: }\n105: \n106: /** Configuration for browser-based verification and testing */\n107: export interface BrowserConfig {\n108:   /** Enable browser testing in the verify pipeline */\n109:   enabled: boolean;\n110:   /** Path to browser binary (null = auto-detect) */\n111:   bin: string | null;\n112:   /** Run browser in headless mode (required for CI) */\n113:   headless: boolean;\n114:   /** Custom test command to run browser tests (overrides script discovery) */\n115:   testCommand: string | null;\n116:   /** Timeout for launching a browser instance (ms) */\n117:   launchTimeout: number;\n118:   /** Timeout for each browser test script (ms) */\n119:   testTimeout: number;\n120:   /** Default viewport size */\n121:   defaultViewport: {\n122:     width: number;\n123:     height: number;\n124:   };\n125: }\n126: \n127: /** Configuration for the external agent registry (e.g. agency-agents) */\n128: export interface AgentRegistryConfig {\n129:   /**\n130:    * Download mode:\n131:    * - \"auto\"      — download agents without asking (default)\n132:    * - \"monitored\" — user reviews/edits/rejects each agent before launch\n133:    * - \"disabled\"  — always use the generalist agent\n134:    */\n135:   mode: AgentRegistryMode;\n136:   /** GitHub repo in \"owner/repo\" format to pull agent definitions from */\n137:   source: string;\n138:   /** Cache directory name (relative to .wombo-combo/) */\n139:   cacheDir: string;\n140:   /** Cache TTL in milliseconds. Cached agents older than this are re-fetched. Default 24h. */\n141:   cacheTTL: number;\n142: }\n143: \n144: /** Configuration for Test-Driven Development workflow */\n145: export interface TddConfig {\n146:   /** Enable TDD red-green-refactor instructions in agent prompts */\n147:   enabled: boolean;\n148:   /** Test command to run (default: \"bun test\") */\n149:   testCommand: string;\n150:   /** Strict TDD mode: fail verification if new files are missing tests */\n151:   strictTdd: boolean;\n152:   /** Test command timeout in milliseconds (default: 120_000) */\n153:   testTimeout: number;\n154: }\n155: \n156: // ---------------------------------------------------------------------------\n157: // Defaults\n158: // ---------------------------------------------------------------------------\n159: \n160: export const DEFAULT_CONFIG: WomboConfig = {\n161:   tasksDir: \"tasks\",\n162:   archiveDir: \"archive\",\n163:   baseBranch: \"develop\",\n164:   build: {\n165:     command: \"bun run build\",\n166:     timeout: 300_000,\n167:     artifactDir: \"dist\",\n168:   },\n169:   install: {\n170:     command: \"bun install\",\n171:     timeout: 120_000,\n172:   },\n173:   git: {\n174:     branchPrefix: \"feature/\",\n175:     remote: \"origin\",\n176:     mergeStrategy: \"--no-ff\",\n177:   },\n178:   agent: {\n179:     bin: null,\n180:     name: \"generalist-agent\",\n181:     configFiles: [\".opencode/\", \"opencode.json\", \"AGENTS.md\"],\n182:     tmuxPrefix: \"wombo\",\n183:     multiplexer: \"auto\",\n184:   },\n185:   portless: {\n186:     enabled: true,\n187:     bin: null,\n188:     proxyPort: 1355,\n189:     https: false,\n190:   },\n191:   backup: {\n192:     maxBackups: 5,\n193:   },\n194:   defaults: {\n195:     maxConcurrent: 6,\n196:     maxRetries: 2,\n197:   },\n198:   browser: {\n199:     enabled: false,\n200:     bin: null,\n201:     headless: true,\n202:     testCommand: null,\n203:     launchTimeout: 30_000,\n204:     testTimeout: 60_000,\n205:     defaultViewport: {\n206:       width: 1280,\n207:       height: 720,\n208:     },\n209:   },\n210:   agentRegistry: {\n211:     mode: \"auto\",\n212:     source: \"msitarzewski/agency-agents\",\n213:     cacheDir: \"agents-cache\",\n214:     cacheTTL: 24 * 60 * 60 * 1000, // 24 hours\n215:   },\n216:   tdd: {\n217:     enabled: false,\n218:     testCommand: \"bun test\",\n219:     strictTdd: false,\n220:     testTimeout: 120_000,\n221:   },\n222: };\n223: \n224: // ---------------------------------------------------------------------------\n225: // Config File Name\n226: // ---------------------------------------------------------------------------\n227: \n228: export const CONFIG_FILE = `${WOMBO_DIR}/config.json`;\n229: \n230: // ---------------------------------------------------------------------------\n231: // Loader\n232: // ---------------------------------------------------------------------------\n233: \n234: /**\n235:  * Deep-merge source into target. Only merges plain objects, not arrays.\n236:  */\n237: function deepMerge<T extends Record<string, any>>(target: T, source: Partial<T>): T {\n238:   const result = { ...target };\n239:   for (const key of Object.keys(source) as (keyof T)[]) {\n240:     const srcVal = source[key];\n241:     const tgtVal = target[key];\n242:     if (\n243:       srcVal !== undefined &&\n244:       srcVal !== null &&\n245:       typeof srcVal === \"object\" &&\n246:       !Array.isArray(srcVal) &&\n247:       typeof tgtVal === \"object\" &&\n248:       !Array.isArray(tgtVal) &&\n249:       tgtVal !== null\n250:     ) {\n251:       result[key] = deepMerge(tgtVal as any, srcVal as any);\n252:     } else if (srcVal !== undefined) {\n253:       result[key] = srcVal as T[keyof T];\n254:     }\n255:   }\n256:   return result;\n257: }\n258: \n259: /**\n260:  * Load .wombo-combo/config.json from the given project root and merge with defaults.\n261:  * Returns the full config. If no config file exists, returns defaults.\n262:  */\n263: export function loadConfig(projectRoot: string): WomboConfig {\n264:   const configPath = resolve(projectRoot, CONFIG_FILE);\n265: \n266:   if (!existsSync(configPath)) {\n267:     return { ...DEFAULT_CONFIG };\n268:   }\n269: \n270:   try {\n271:     const raw = readFileSync(configPath, \"utf-8\");\n272:     const partial = JSON.parse(raw) as Partial<WomboConfig>;\n273: \n274:     // Migrate legacy single-file config keys to folder-based\n275:     if ((partial as any).tasksFile && !partial.tasksDir) {\n276:       // Legacy \"tasks.yml\" → strip extension for dir name, or use as-is\n277:       const legacy = (partial as any).tasksFile as string;\n278:       partial.tasksDir = legacy.replace(/\\.ya?ml$/i, \"\") || \"tasks\";\n279:       delete (partial as any).tasksFile;\n280:     }\n281:     if ((partial as any).archiveFile && !partial.archiveDir) {\n282:       const legacy = (partial as any).archiveFile as string;\n283:       partial.archiveDir = legacy.replace(/\\.ya?ml$/i, \"\") || \"archive\";\n284:       delete (partial as any).archiveFile;\n285:     }\n286: \n287:     return deepMerge(DEFAULT_CONFIG, partial);\n288:   } catch (err: any) {\n289:     throw new Error(`Failed to load ${CONFIG_FILE}: ${err.message}`);\n290:   }\n291: }\n292: \n293: /**\n294:  * Resolve the agent binary path. Priority:\n295:  *   1. config.agent.bin (explicit)\n296:  *   2. OPENCODE_BIN env var\n297:  *   3. ~/.opencode/bin/opencode (default install location)\n298:  */\n299: export function resolveAgentBin(config: WomboConfig): string {\n300:   if (config.agent.bin) return config.agent.bin;\n301:   if (process.env.OPENCODE_BIN) return process.env.OPENCODE_BIN;\n302:   return resolve(process.env.HOME || \"~\", \".opencode/bin/opencode\");\n303: }\n304: \n305: /**\n306:  * Validate the config for obvious issues. Throws on error.\n307:  */\n308: export function validateConfig(config: WomboConfig): void {\n309:   if (!config.tasksDir) {\n310:     throw new Error(\"config.tasksDir must be a non-empty string\");\n311:   }\n312:   if (!config.archiveDir) {\n313:     throw new Error(\"config.archiveDir must be a non-empty string\");\n314:   }\n315:   if (!config.baseBranch) {\n316:     throw new Error(\"config.baseBranch must be a non-empty string\");\n317:   }\n318:   if (!config.build.command) {\n319:     throw new Error(\"config.build.command must be a non-empty string\");\n320:   }\n321:   if (!config.install.command) {\n322:     throw new Error(\"config.install.command must be a non-empty string\");\n323:   }\n324:   if (!config.git.branchPrefix) {\n325:     throw new Error(\"config.git.branchPrefix must be a non-empty string\");\n326:   }\n327:   if (config.defaults.maxConcurrent < 1) {\n328:     throw new Error(\"config.defaults.maxConcurrent must be >= 1\");\n329:   }\n330:   if (config.defaults.maxRetries < 0) {\n331:     throw new Error(\"config.defaults.maxRetries must be >= 0\");\n332:   }\n333:   if (config.backup.maxBackups < 0) {\n334:     throw new Error(\"config.backup.maxBackups must be >= 0\");\n335:   }\n336:   const validModes: AgentRegistryMode[] = [\"auto\", \"monitored\", \"disabled\"];\n337:   if (!validModes.includes(config.agentRegistry.mode)) {\n338:     throw new Error(`config.agentRegistry.mode must be one of: ${validModes.join(\", \")}`);\n339:   }\n340:   if (!config.agentRegistry.source) {\n341:     throw new Error(\"config.agentRegistry.source must be a non-empty string\");\n342:   }\n343:   if (!config.agentRegistry.cacheDir) {\n344:     throw new Error(\"config.agentRegistry.cacheDir must be a non-empty string\");\n345:   }\n346:   if (config.tdd.enabled && !config.tdd.testCommand) {\n347:     throw new Error(\"config.tdd.testCommand must be a non-empty string when TDD is enabled\");\n348:   }\n349: }\n350: \n351: /**\n352:  * Generate the default .wombo-combo/config.json content string (for `woco init`).\n353:  */\n354: export function generateDefaultConfig(): string {\n355:   return JSON.stringify(DEFAULT_CONFIG, null, 2) + \"\\n\";\n356: }\n\n(End of file - total 356 lines)\n</content>","title":"src/config.ts","metadata":{"preview":"/**\n * config.ts — Load .wombo-combo/config.json, merge with defaults, validate, expose typed config.\n *\n * The config file lives at .wombo-combo/config.json inside the target project root.\n * All values have sensible defaults so minimal config works out of the box.\n */\n\nimport { readFileSync, existsSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\nimport type { MultiplexerPreference } from \"./lib/multiplexer.js\";\n\n// ---------------------------------------------------------------------------\n// .wombo-combo directory constant\n// ---------------------------------------------------------------------------\n\n/** Name of the directory that holds all wombo-combo files */\nexport const WOMBO_DIR = \".wombo-combo\";\n\n// ---------------------------------------------------------------------------\n// Types","truncated":false,"loaded":[]},"time":{"start":1773445789113,"end":1773445789115}}}}
