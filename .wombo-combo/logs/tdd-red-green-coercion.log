ult.valid).toBe(false);\n198:   });\n199: \n200:   test(\"rejects caret\", () => {\n201:     const result = validateBranchName(\"branch^2\");\n202:     expect(result.valid).toBe(false);\n203:   });\n204: \n205:   test(\"rejects colon\", () => {\n206:     const result = validateBranchName(\"branch:name\");\n207:     expect(result.valid).toBe(false);\n208:   });\n209: \n210:   test(\"rejects backslash\", () => {\n211:     const result = validateBranchName(\"branch\\\\name\");\n212:     expect(result.valid).toBe(false);\n213:   });\n214: \n215:   test(\"rejects question mark\", () => {\n216:     const result = validateBranchName(\"branch?name\");\n217:     expect(result.valid).toBe(false);\n218:   });\n219: \n220:   test(\"rejects asterisk\", () => {\n221:     const result = validateBranchName(\"branch*name\");\n222:     expect(result.valid).toBe(false);\n223:   });\n224: \n225:   test(\"rejects open bracket\", () => {\n226:     const result = validateBranchName(\"branch[0]\");\n227:     expect(result.valid).toBe(false);\n228:   });\n229: \n230:   test(\"rejects control characters\", () => {\n231:     const result = validateBranchName(\"branch\\x00name\");\n232:     expect(result.valid).toBe(false);\n233:   });\n234: \n235:   test(\"uses custom label in error message\", () => {\n236:     const result = validateBranchName(\"\", \"base branch\");\n237:     expect(result.error).toContain(\"base branch\");\n238:   });\n239: });\n240: \n241: // ---------------------------------------------------------------------------\n242: // validateDuration\n243: // ---------------------------------------------------------------------------\n244: \n245: describe(\"validateDuration\", () => {\n246:   test(\"accepts valid ISO 8601 durations\", () => {\n247:     expect(validateDuration(\"PT1H\").valid).toBe(true);\n248:     expect(validateDuration(\"PT30M\").valid).toBe(true);\n249:     expect(validateDuration(\"PT2H30M\").valid).toBe(true);\n250:     expect(validateDuration(\"P1D\").valid).toBe(true);\n251:     expect(validateDuration(\"P1DT4H\").valid).toBe(true);\n252:     expect(validateDuration(\"P1Y2M3DT4H5M6S\").valid).toBe(true);\n253:     expect(validateDuration(\"PT0S\").valid).toBe(true);\n254:   });\n255: \n256:   test(\"rejects empty string\", () => {\n257:     const result = validateDuration(\"\");\n258:     expect(result.valid).toBe(false);\n259:     expect(result.error).toContain(\"empty\");\n260:   });\n261: \n262:   test(\"rejects plain numbers\", () => {\n263:     const result = validateDuration(\"60\");\n264:     expect(result.valid).toBe(false);\n265:     expect(result.error).toContain(\"ISO 8601\");\n266:   });\n267: \n268:   test(\"rejects human-readable durations\", () => {\n269:     expect(validateDuration(\"2 hours\").valid).toBe(false);\n270:     expect(validateDuration(\"1h30m\").valid).toBe(false);\n271:     expect(validateDuration(\"90 minutes\").valid).toBe(false);\n272:   });\n273: \n274:   test(\"rejects lowercase p\", () => {\n275:     const result = validateDuration(\"pt1h\");\n276:     expect(result.valid).toBe(false);\n277:   });\n278: \n279:   test(\"rejects missing P prefix\", () => {\n280:     const result = validateDuration(\"T1H\");\n281:     expect(result.valid).toBe(false);\n282:   });\n283: \n284:   test(\"uses custom label in error message\", () => {\n285:     const result = validateDuration(\"bad\", \"effort estimate\");\n286:     expect(result.error).toContain(\"effort estimate\");\n287:   });\n288: });\n289: \n290: // ---------------------------------------------------------------------------\n291: // validateEnum\n292: // ---------------------------------------------------------------------------\n293: \n294: describe(\"validateEnum\", () => {\n295:   const allowed = [\"alpha\", \"beta\", \"gamma\"] as const;\n296: \n297:   test(\"accepts allowed values\", () => {\n298:     expect(validateEnum(\"alpha\", allowed).valid).toBe(true);\n299:     expect(validateEnum(\"beta\", allowed).valid).toBe(true);\n300:     expect(validateEnum(\"gamma\", allowed).valid).toBe(true);\n301:   });\n302: \n303:   test(\"rejects disallowed values\", () => {\n304:     const result = validateEnum(\"delta\", allowed);\n305:     expect(result.valid).toBe(false);\n306:     expect(result.error).toContain(\"delta\");\n307:     expect(result.error).toContain(\"alpha\");\n308:   });\n309: \n310:   test(\"rejects empty string\", () => {\n311:     const result = validateEnum(\"\", allowed);\n312:     expect(result.valid).toBe(false);\n313:   });\n314: \n315:   test(\"is case-sensitive\", () => {\n316:     const result = validateEnum(\"Alpha\", allowed);\n317:     expect(result.valid).toBe(false);\n318:   });\n319: \n320:   test(\"uses custom label in error message\", () => {\n321:     const result = validateEnum(\"bad\", allowed, \"status\");\n322:     expect(result.error).toContain(\"status\");\n323:   });\n324: });\n\n(End of file - total 324 lines)\n</content>","title":"tests/validate.test.ts","metadata":{"preview":"/**\n * validate.test.ts — Unit tests for input validation functions.\n *\n * Coverage:\n *   - validateId: kebab-case, empty, control chars, path traversal, query params,\n *     percent-encoding, length limits\n *   - validateText: control chars, allows newlines/tabs\n *   - validateBranchName: empty, control chars, \"..\", special chars\n *   - validateDuration: ISO 8601 patterns, invalid formats\n *   - validateEnum: allowed values, rejected values\n *   - assertValid: exits on invalid (not directly testable without mocking process.exit)\n */\n\nimport { describe, test, expect } from \"bun:test\";\nimport {\n  validateId,\n  validateText,\n  validateBranchName,\n  validateDuration,\n  validateEnum,","truncated":false,"loaded":[]},"time":{"start":1773445801687,"end":1773445801689}}}}
