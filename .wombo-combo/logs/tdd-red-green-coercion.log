{"type":"tool_use","timestamp":1773445186633,"sessionID":"ses_316701812ffeYe5yCqGzB5GjN6","part":{"id":"prt_ce99115640018b4aX004ywXF6t","sessionID":"ses_316701812ffeYe5yCqGzB5GjN6","messageID":"msg_ce99109b50017FtkF2XM6Ag9ml","type":"tool","callID":"toolu_vrtx_01WQGZYP7ZNtZXHbXARpmtQF","tool":"write","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/tdd-red-green-coercion/tests/test-detection.test.ts","content":"/**\n * test-detection.test.ts — Unit tests for test file detection and coverage analysis.\n *\n * Coverage:\n *   - isTestFile: identifies test/spec files by name pattern\n *   - isBarrelFile: detects re-export barrel files (index.ts)\n *   - isTypesOnlyFile: detects files with only type definitions\n *   - isExcludedFile: combines exclusion rules (.d.ts, barrels, types-only, custom patterns)\n *   - filterSourceFiles: filters git diff output to only source files\n *   - findTestFiles: locates matching test files for a source file\n *   - detectTests: full detection pipeline with coverage report\n *   - renderTestDetectionReport: renders report to console\n */\n\nimport { describe, test, expect, beforeEach, afterEach } from \"bun:test\";\nimport { mkdtempSync, writeFileSync, rmSync, mkdirSync } from \"node:fs\";\nimport { join } from \"node:path\";\nimport { tmpdir } from \"node:os\";\n\nimport {\n  isTestFile,\n  isBarrelFile,\n  isTypesOnlyFile,\n  isExcludedFile,\n  filterSourceFiles,\n  findTestFiles,\n  detectTests,\n  DEFAULT_TEST_DETECTION_CONFIG,\n  type DiffFile,\n  type TestDetectionConfig,\n} from \"../src/lib/test-detection.js\";\n\n// ---------------------------------------------------------------------------\n// Helpers\n// ---------------------------------------------------------------------------\n\nlet tmpDir: string;\n\nbeforeEach(() => {\n  tmpDir = mkdtempSync(join(tmpdir(), \"wombo-test-detection-\"));\n});\n\nafterEach(() => {\n  rmSync(tmpDir, { recursive: true, force: true });\n});\n\nfunction writeFile(relativePath: string, content: string): void {\n  const full = join(tmpDir, relativePath);\n  mkdirSync(join(full, \"..\"), { recursive: true });\n  writeFileSync(full, content);\n}\n\n// ---------------------------------------------------------------------------\n// isTestFile\n// ---------------------------------------------------------------------------\n\ndescribe(\"isTestFile\", () => {\n  test(\"identifies .test.ts files\", () => {\n    expect(isTestFile(\"foo.test.ts\")).toBe(true);\n    expect(isTestFile(\"src/lib/foo.test.ts\")).toBe(true);\n  });\n\n  test(\"identifies .spec.ts files\", () => {\n    expect(isTestFile(\"foo.spec.ts\")).toBe(true);\n    expect(isTestFile(\"tests/bar.spec.ts\")).toBe(true);\n  });\n\n  test(\"identifies .test.tsx files\", () => {\n    expect(isTestFile(\"Component.test.tsx\")).toBe(true);\n  });\n\n  test(\"identifies .spec.tsx files\", () => {\n    expect(isTestFile(\"Component.spec.tsx\")).toBe(true);\n  });\n\n  test(\"identifies .test.js files\", () => {\n    expect(isTestFile(\"foo.test.js\")).toBe(true);\n  });\n\n  test(\"identifies .spec.js files\", () => {\n    expect(isTestFile(\"foo.spec.js\")).toBe(true);\n  });\n\n  test(\"rejects regular source files\", () => {\n    expect(isTestFile(\"foo.ts\")).toBe(false);\n    expect(isTestFile(\"foo.tsx\")).toBe(false);\n    expect(isTestFile(\"foo.js\")).toBe(false);\n    expect(isTestFile(\"config.ts\")).toBe(false);\n  });\n\n  test(\"rejects files with 'test' in the name but not as suffix\", () => {\n    expect(isTestFile(\"test-utils.ts\")).toBe(false);\n    expect(isTestFile(\"testing.ts\")).toBe(false);\n  });\n\n  test(\"rejects type declaration files\", () => {\n    expect(isTestFile(\"foo.d.ts\")).toBe(false);\n  });\n});\n\n// ---------------------------------------------------------------------------\n// isBarrelFile\n// ---------------------------------------------------------------------------\n\ndescribe(\"isBarrelFile\", () => {\n  test(\"detects barrel with named exports\", () => {\n    writeFile(\"barrel.ts\", `export { foo } from \"./foo.js\";\\nexport { bar } from \"./bar.js\";\\n`);\n    expect(isBarrelFile(join(tmpDir, \"barrel.ts\"))).toBe(true);\n  });\n\n  test(\"detects barrel with star exports\", () => {\n    writeFile(\"barrel.ts\", `export * from \"./foo.js\";\\nexport * from \"./bar.js\";\\n`);\n    expect(isBarrelFile(join(tmpDir, \"barrel.ts\"))).toBe(true);\n  });\n\n  test(\"detects barrel with type exports\", () => {\n    writeFile(\"barrel.ts\", `export type { Foo } from \"./foo.js\";\\n`);\n    expect(isBarrelFile(join(tmpDir, \"barrel.ts\"))).toBe(true);\n  });\n\n  test(\"allows comments and empty lines in barrels\", () => {\n    writeFile(\"barrel.ts\", `// Re-export all public API\\n\\nexport { foo } from \"./foo.js\";\\n`);\n    expect(isBarrelFile(join(tmpDir, \"barrel.ts\"))).toBe(true);\n  });\n\n  test(\"rejects files with function declarations\", () => {\n    writeFile(\"not-barrel.ts\", `export { foo } from \"./foo.js\";\\n\\nexport function helper() { return 1; }\\n`);\n    expect(isBarrelFile(join(tmpDir, \"not-barrel.ts\"))).toBe(false);\n  });\n\n  test(\"rejects files with variable declarations\", () => {\n    writeFile(\"not-barrel.ts\", `export { foo } from \"./foo.js\";\\nconst x = 42;\\n`);\n    expect(isBarrelFile(join(tmpDir, \"not-barrel.ts\"))).toBe(false);\n  });\n\n  test(\"rejects empty files (no exports)\", () => {\n    writeFile(\"empty.ts\", \"\");\n    expect(isBarrelFile(join(tmpDir, \"empty.ts\"))).toBe(false);\n  });\n\n  test(\"rejects files with only comments (no exports)\", () => {\n    writeFile(\"comments.ts\", \"// Just a comment\\n\");\n    expect(isBarrelFile(join(tmpDir, \"comments.ts\"))).toBe(false);\n  });\n\n  test(\"returns false for non-existent files\", () => {\n    expect(isBarrelFile(join(tmpDir, \"nonexistent.ts\"))).toBe(false);\n  });\n});\n\n// ---------------------------------------------------------------------------\n// isTypesOnlyFile\n// ---------------------------------------------------------------------------\n\ndescribe(\"isTypesOnlyFile\", () => {\n  test(\"detects file with only interface exports\", () => {\n    writeFile(\"types.ts\", `export interface Foo {\\n  name: string;\\n}\\n`);\n    expect(isTypesOnlyFile(join(tmpDir, \"types.ts\"))).toBe(true);\n  });\n\n  test(\"detects file with only type exports\", () => {\n    writeFile(\"types.ts\", `export type Status = \"ready\" | \"done\";\\n`);\n    expect(isTypesOnlyFile(join(tmpDir, \"types.ts\"))).toBe(true);\n  });\n\n  test(\"detects file with enum (type-only context)\", () => {\n    writeFile(\"types.ts\", `export enum Color {\\n  Red,\\n  Green,\\n  Blue,\\n}\\n`);\n    // Note: enums produce runtime code, but the heuristic treats them as types-only\n    // because they're in a declarative style. This is the expected behavior.\n    expect(isTypesOnlyFile(join(tmpDir, \"types.ts\"))).toBe(true);\n  });\n\n  test(\"detects file with imports + type declarations\", () => {\n    writeFile(\"types.ts\", `import type { Bar } from \"./bar.js\";\\n\\nexport interface Foo extends Bar {\\n  name: string;\\n}\\n`);\n    expect(isTypesOnlyFile(join(tmpDir, \"types.ts\"))).toBe(true);\n  });\n\n  test(\"detects file with declare statements\", () => {\n    writeFile(\"types.ts\", `declare module \"my-module\" {\\n  export function doStuff(): void;\\n}\\n`);\n    expect(isTypesOnlyFile(join(tmpDir, \"types.ts\"))).toBe(true);\n  });\n\n  test(\"rejects files with function declarations\", () => {\n    writeFile(\"logic.ts\", `export interface Foo {\\n  name: string;\\n}\\n\\nexport function createFoo(): Foo {\\n  return { name: \"foo\" };\\n}\\n`);\n    expect(isTypesOnlyFile(join(tmpDir, \"logic.ts\"))).toBe(false);\n  });\n\n  test(\"rejects files with variable declarations\", () => {\n    writeFile(\"logic.ts\", `export interface Foo {}\\nconst x = 42;\\n`);\n    expect(isTypesOnlyFile(join(tmpDir, \"logic.ts\"))).toBe(false);\n  });\n\n  test(\"rejects files with class declarations\", () => {\n    writeFile(\"logic.ts\", `export interface Foo {}\\nexport class Bar implements Foo {}\\n`);\n    expect(isTypesOnlyFile(join(tmpDir, \"logic.ts\"))).toBe(false);\n  });\n\n  test(\"rejects empty files\", () => {\n    writeFile(\"empty.ts\", \"\");\n    expect(isTypesOnlyFile(join(tmpDir, \"empty.ts\"))).toBe(false);\n  });\n\n  test(\"handles block comments correctly\", () => {\n    writeFile(\"types.ts\", `/**\\n * Type definitions\\n */\\nexport type Foo = string;\\n`);\n    expect(isTypesOnlyFile(join(tmpDir, \"types.ts\"))).toBe(true);\n  });\n\n  test(\"returns false for non-existent files\", () => {\n    expect(isTypesOnlyFile(join(tmpDir, \"nonexistent.ts\"))).toBe(false);\n  });\n});\n\n// ---------------------------------------------------------------------------\n// isExcludedFile\n// ---------------------------------------------------------------------------\n\ndescribe(\"isExcludedFile\", () => {\n  test(\"excludes .d.ts files\", () => {\n    const result = isExcludedFile(\"src/lib/foo.d.ts\", tmpDir);\n    expect(result.excluded).toBe(true);\n    expect(result.reason).toContain(\".d.ts\");\n  });\n\n  test(\"excludes barrel index.ts files\", () => {\n    writeFile(\"src/lib/index.ts\", `export { foo } from \"./foo.js\";\\nexport { bar } from \"./bar.js\";\\n`);\n    const result = isExcludedFile(\"src/lib/index.ts\", tmpDir);\n    expect(result.excluded).toBe(true);\n    expect(result.reason).toContain(\"barrel\");\n  });\n\n  test(\"does not exclude index.ts with logic\", () => {\n    writeFile(\"src/lib/index.ts\", `export { foo } from \"./foo.js\";\\n\\nconsole.log(\"side effect\");\\n`);\n    const result = isExcludedFile(\"src/lib/index.ts\", tmpDir);\n    expect(result.excluded).toBe(false);\n  });\n\n  test(\"excludes types-only files\", () => {\n    writeFile(\"src/lib/types.ts\", `export interface Foo {\\n  name: string;\\n}\\n`);\n    const result = isExcludedFile(\"src/lib/types.ts\", tmpDir);\n    expect(result.excluded).toBe(true);\n    expect(result.reason).toContain(\"Types-only\");\n  });\n\n  test(\"does not exclude files with runtime logic\", () => {\n    writeFile(\"src/lib/utils.ts\", `export function add(a: number, b: number): number {\\n  return a + b;\\n}\\n`);\n    const result = isExcludedFile(\"src/lib/utils.ts\", tmpDir);\n    expect(result.excluded).toBe(false);\n  });\n\n  test(\"respects custom exclude patterns\", () => {\n    writeFile(\"src/lib/generated.ts\", `export const x = 42;\\n`);\n    const config: TestDetectionConfig = {\n      ...DEFAULT_TEST_DETECTION_CONFIG,\n      excludePatterns: [\"generated\"],\n    };\n    const result = isExcludedFile(\"src/lib/generated.ts\", tmpDir, config);\n    expect(result.excluded).toBe(true);\n    expect(result.reason).toContain(\"exclude pattern\");\n  });\n\n  test(\"does not exclude non-matching custom patterns\", () => {\n    writeFile(\"src/lib/utils.ts\", `export const x = 42;\\n`);\n    const config: TestDetectionConfig = {\n      ...DEFAULT_TEST_DETECTION_CONFIG,\n      excludePatterns: [\"generated\"],\n    };\n    const result = isExcludedFile(\"src/lib/utils.ts\", tmpDir, config);\n    expect(result.excluded).toBe(false);\n  });\n});\n\n// ---------------------------------------------------------------------------\n// filterSourceFiles\n// ---------------------------------------------------------------------------\n\ndescribe(\"filterSourceFiles\", () => {\n  test(\"includes .ts files in src/\", () => {\n    const files: DiffFile[] = [\n      { status: \"A\", path: \"src/lib/foo.ts\" },\n      { status: \"M\", path: \"src/config.ts\" },\n    ];\n    const result = filterSourceFiles(files);\n    expect(result).toHaveLength(2);\n  });\n\n  test(\"excludes files outside source directories\", () => {\n    const files: DiffFile[] = [\n      { status: \"A\", path: \"docs/readme.md\" },\n      { status: \"A\", path: \"package.json\" },\n      { status: \"A\", path: \".gitignore\" },\n    ];\n    const result = filterSourceFiles(files);\n    expect(result).toHaveLength(0);\n  });\n\n  test(\"excludes test files from source file list\", () => {\n    const files: DiffFile[] = [\n      { status: \"A\", path: \"src/lib/foo.ts\" },\n      { status: \"A\", path: \"src/lib/foo.test.ts\" },\n      { status: \"A\", path: \"src/lib/foo.spec.ts\" },\n    ];\n    const result = filterSourceFiles(files);\n    expect(result).toHaveLength(1);\n    expect(result[0].path).toBe(\"src/lib/foo.ts\");\n  });\n\n  test(\"excludes files with non-source extensions\", () => {\n    const files: DiffFile[] = [\n      { status: \"A\", path: \"src/styles.css\" },\n      { status: \"A\", path: \"src/data.json\" },\n    ];\n    const result = filterSourceFiles(files);\n    expect(result).toHaveLength(0);\n  });\n\n  test(\"includes .tsx files\", () => {\n    const files: DiffFile[] = [\n      { status: \"A\", path: \"src/components/Button.tsx\" },\n    ];\n    const result = filterSourceFiles(files);\n    expect(result).toHaveLength(1);\n  });\n\n  test(\"respects custom source directories\", () => {\n    const files: DiffFile[] = [\n      { status: \"A\", path: \"lib/foo.ts\" },\n      { status: \"A\", path: \"src/bar.ts\" },\n    ];\n    const config: TestDetectionConfig = {\n      ...DEFAULT_TEST_DETECTION_CONFIG,\n      sourceDirs: [\"lib/\"],\n    };\n    const result = filterSourceFiles(files, config);\n    expect(result).toHaveLength(1);\n    expect(result[0].path).toBe(\"lib/foo.ts\");\n  });\n\n  test(\"respects custom source extensions\", () => {\n    const files: DiffFile[] = [\n      { status: \"A\", path: \"src/foo.js\" },\n      { status: \"A\", path: \"src/bar.ts\" },\n    ];\n    const config: TestDetectionConfig = {\n      ...DEFAULT_TEST_DETECTION_CONFIG,\n      sourceExtensions: [\".js\"],\n    };\n    const result = filterSourceFiles(files, config);\n    expect(result).toHaveLength(1);\n    expect(result[0].path).toBe(\"src/foo.js\");\n  });\n});\n\n// ---------------------------------------------------------------------------\n// findTestFiles\n// ---------------------------------------------------------------------------\n\ndescribe(\"findTestFiles\", () => {\n  test(\"finds co-located test files\", () => {\n    writeFile(\"src/lib/foo.test.ts\", \"// test\");\n    const found = findTestFiles(\"src/lib/foo.ts\", tmpDir);\n    expect(found.length).toBeGreaterThanOrEqual(1);\n    expect(found).toContain(\"src/lib/foo.test.ts\");\n  });\n\n  test(\"finds flat test directory test files\", () => {\n    writeFile(\"tests/foo.test.ts\", \"// test\");\n    const found = findTestFiles(\"src/lib/foo.ts\", tmpDir);\n    expect(found.length).toBeGreaterThanOrEqual(1);\n    expect(found).toContain(\"tests/foo.test.ts\");\n  });\n\n  test(\"finds mirrored test directory structure\", () => {\n    writeFile(\"tests/lib/foo.test.ts\", \"// test\");\n    const found = findTestFiles(\"src/lib/foo.ts\", tmpDir);\n    expect(found.length).toBeGreaterThanOrEqual(1);\n    expect(found).toContain(\"tests/lib/foo.test.ts\");\n  });\n\n  test(\"finds .spec.ts variants\", () => {\n    writeFile(\"tests/foo.spec.ts\", \"// spec\");\n    const found = findTestFiles(\"src/lib/foo.ts\", tmpDir);\n    expect(found.length).toBeGreaterThanOrEqual(1);\n    expect(found).toContain(\"tests/foo.spec.ts\");\n  });\n\n  test(\"finds test files in test/ directory (singular)\", () => {\n    writeFile(\"test/foo.test.ts\", \"// test\");\n    const found = findTestFiles(\"src/lib/foo.ts\", tmpDir);\n    expect(found.length).toBeGreaterThanOrEqual(1);\n    expect(found).toContain(\"test/foo.test.ts\");\n  });\n\n  test(\"returns empty array when no test files exist\", () => {\n    const found = findTestFiles(\"src/lib/bar.ts\", tmpDir);\n    expect(found).toHaveLength(0);\n  });\n\n  test(\"finds multiple test files\", () => {\n    writeFile(\"tests/foo.test.ts\", \"// test 1\");\n    writeFile(\"tests/foo.spec.ts\", \"// test 2\");\n    writeFile(\"src/lib/foo.test.ts\", \"// test 3\");\n    const found = findTestFiles(\"src/lib/foo.ts\", tmpDir);\n    expect(found.length).toBeGreaterThanOrEqual(3);\n  });\n\n  test(\"deduplicates found test files\", () => {\n    writeFile(\"tests/foo.test.ts\", \"// test\");\n    const found = findTestFiles(\"src/lib/foo.ts\", tmpDir);\n    const unique = new Set(found);\n    expect(unique.size).toBe(found.length);\n  });\n});\n\n// ---------------------------------------------------------------------------\n// DEFAULT_TEST_DETECTION_CONFIG\n// ---------------------------------------------------------------------------\n\ndescribe(\"DEFAULT_TEST_DETECTION_CONFIG\", () => {\n  test(\"has test file patterns\", () => {\n    expect(DEFAULT_TEST_DETECTION_CONFIG.testFilePatterns.length).toBeGreaterThan(0);\n  });\n\n  test(\"includes src/ as source directory\", () => {\n    expect(DEFAULT_TEST_DETECTION_CONFIG.sourceDirs).toContain(\"src/\");\n  });\n\n  test(\"includes .ts and .tsx extensions\", () => {\n    expect(DEFAULT_TEST_DETECTION_CONFIG.sourceExtensions).toContain(\".ts\");\n    expect(DEFAULT_TEST_DETECTION_CONFIG.sourceExtensions).toContain(\".tsx\");\n  });\n\n  test(\"has empty exclude patterns by default\", () => {\n    expect(DEFAULT_TEST_DETECTION_CONFIG.excludePatterns).toEqual([]);\n  });\n});\n\n// ---------------------------------------------------------------------------\n// detectTests (integration-like, uses git in tmpDir)\n// ---------------------------------------------------------------------------\n\ndescribe(\"detectTests\", () => {\n  test(\"returns empty report for non-git directory\", () => {\n    // tmpDir is not a git repo, so getChangedFiles should return []\n    const report = detectTests(tmpDir);\n    expect(report.sourceFiles).toHaveLength(0);\n    expect(report.testableCount).toBe(0);\n    expect(report.coveredCount).toBe(0);\n  });\n\n  test(\"report has all required fields\", () => {\n    const report = detectTests(tmpDir);\n    expec