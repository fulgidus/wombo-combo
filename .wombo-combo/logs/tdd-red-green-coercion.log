n129:     expect(prompt).toContain(\"npm run build\");\n130:   });\n131: \n132:   test(\"includes constraints when present\", () => {\n133:     const feature = makeFeature({\n134:       constraints: [\"Must use TypeScript\", \"Must pass linting\"],\n135:     });\n136:     const config = makeConfig();\n137:     const prompt = generatePrompt(feature, \"main\", config);\n138:     expect(prompt).toContain(\"Must use TypeScript\");\n139:     expect(prompt).toContain(\"Must pass linting\");\n140:     expect(prompt).toContain(\"## Constraints\");\n141:   });\n142: \n143:   test(\"includes forbidden when present\", () => {\n144:     const feature = makeFeature({\n145:       forbidden: [\"Do not use eval\", \"Do not add dependencies\"],\n146:     });\n147:     const config = makeConfig();\n148:     const prompt = generatePrompt(feature, \"main\", config);\n149:     expect(prompt).toContain(\"Do not use eval\");\n150:     expect(prompt).toContain(\"## Forbidden\");\n151:   });\n152: \n153:   test(\"includes references when present\", () => {\n154:     const feature = makeFeature({\n155:       references: [\"src/lib/auth.ts\", \"src/config.ts\"],\n156:     });\n157:     const config = makeConfig();\n158:     const prompt = generatePrompt(feature, \"main\", config);\n159:     expect(prompt).toContain(\"src/lib/auth.ts\");\n160:     expect(prompt).toContain(\"src/config.ts\");\n161:     expect(prompt).toContain(\"Key Files\");\n162:   });\n163: \n164:   test(\"includes notes when present\", () => {\n165:     const feature = makeFeature({\n166:       notes: [\"Consider edge cases for empty input\"],\n167:     });\n168:     const config = makeConfig();\n169:     const prompt = generatePrompt(feature, \"main\", config);\n170:     expect(prompt).toContain(\"Consider edge cases for empty input\");\n171:     expect(prompt).toContain(\"Planning Notes\");\n172:   });\n173: \n174:   test(\"includes commit guidelines\", () => {\n175:     const prompt = generatePrompt(makeFeature(), \"main\", makeConfig());\n176:     expect(prompt).toContain(\"Commit Guidelines\");\n177:     expect(prompt).toContain(\"conventional commits\");\n178:     expect(prompt).toContain(\"feat(scope):\");\n179:   });\n180: \n181:   test(\"includes execution instructions\", () => {\n182:     const prompt = generatePrompt(makeFeature(), \"main\", makeConfig());\n183:     expect(prompt).toContain(\"## Execution\");\n184:   });\n185: });\n186: \n187: // ---------------------------------------------------------------------------\n188: // generatePrompt — TDD section\n189: // ---------------------------------------------------------------------------\n190: \n191: describe(\"generatePrompt — TDD section\", () => {\n192:   test(\"does NOT include TDD section when TDD is disabled\", () => {\n193:     const config = makeConfig({ tdd: { enabled: false, testCommand: \"bun test\", strictTdd: false, testTimeout: 120_000 } });\n194:     const prompt = generatePrompt(makeFeature(), \"main\", config);\n195:     expect(prompt).not.toContain(\"Test-Driven Development\");\n196:     expect(prompt).not.toContain(\"red-green-refactor\");\n197:   });\n198: \n199:   test(\"includes TDD section when TDD is enabled\", () => {\n200:     const config = makeConfig({ tdd: { enabled: true, testCommand: \"bun test\", strictTdd: false, testTimeout: 120_000 } });\n201:     const prompt = generatePrompt(makeFeature(), \"main\", config);\n202:     expect(prompt).toContain(\"Test-Driven Development\");\n203:     expect(prompt).toContain(\"TDD\");\n204:   });\n205: \n206:   test(\"includes red-green-refactor workflow steps\", () => {\n207:     const config = makeConfig({ tdd: { enabled: true, testCommand: \"bun test\", strictTdd: false, testTimeout: 120_000 } });\n208:     const prompt = generatePrompt(makeFeature(), \"main\", config);\n209:     expect(prompt).toContain(\"Red\");\n210:     expect(prompt).toContain(\"Green\");\n211:     expect(prompt).toContain(\"Refactor\");\n212:   });\n213: \n214:   test(\"includes the configured test command\", () => {\n215:     const config = makeConfig({ tdd: { enabled: true, testCommand: \"npm test\", strictTdd: false, testTimeout: 120_000 } });\n216:     const prompt = generatePrompt(makeFeature(), \"main\", config);\n217:     expect(prompt).toContain(\"npm test\");\n218:   });\n219: \n220:   test(\"includes red phase instruction to write failing test first\", () => {\n221:     const config = makeConfig({ tdd: { enabled: true, testCommand: \"bun test\", strictTdd: false, testTimeout: 120_000 } });\n222:     const prompt = generatePrompt(makeFeature(), \"main\", config);\n223:     expect(prompt).toContain(\"failing test\");\n224:     expect(prompt).toContain(\"confirm it fails\");\n225:   });\n226: \n227:   test(\"includes green phase instruction to make test pass\", () => {\n228:     const config = makeConfig({ tdd: { enabled: true, testCommand: \"bun test\", strictTdd: false, testTimeout: 120_000 } });\n229:     const prompt = generatePrompt(makeFeature(), \"main\", config);\n230:     expect(prompt).toContain(\"make the test pass\");\n231:   });\n232: \n233:   test(\"includes rule about never skipping red step\", () => {\n234:     const config = makeConfig({ tdd: { enabled: true, testCommand: \"bun test\", strictTdd: false, testTimeout: 120_000 } });\n235:     const prompt = generatePrompt(makeFeature(), \"main\", config);\n236:     expect(prompt).toContain(\"Never skip the red step\");\n237:   });\n238: \n239:   test(\"includes rule about committing at green\", () => {\n240:     const config = makeConfig({ tdd: { enabled: true, testCommand: \"bun test\", strictTdd: false, testTimeout: 120_000 } });\n241:     const prompt = generatePrompt(makeFeature(), \"main\", config);\n242:     expect(prompt).toContain(\"Commit at green\");\n243:   });\n244: \n245:   test(\"includes rule about running tests frequently\", () => {\n246:     const config = makeConfig({ tdd: { enabled: true, testCommand: \"bun test\", strictTdd: false, testTimeout: 120_000 } });\n247:     const prompt = generatePrompt(makeFeature(), \"main\", config);\n248:     expect(prompt).toContain(\"Run tests frequently\");\n249:   });\n250: \n251:   test(\"includes test file placement guidance\", () => {\n252:     const config = makeConfig({ tdd: { enabled: true, testCommand: \"bun test\", strictTdd: false, testTimeout: 120_000 } });\n253:     const prompt = generatePrompt(makeFeature(), \"main\", config);\n254:     expect(prompt).toContain(\".test.ts\");\n255:   });\n256: \n257:   test(\"uses bun:test import in guidance\", () => {\n258:     const config = makeConfig({ tdd: { enabled: true, testCommand: \"bun test\", strictTdd: false, testTimeout: 120_000 } });\n259:     const prompt = generatePrompt(makeFeature(), \"main\", config);\n260:     expect(prompt).toContain(\"bun:test\");\n261:   });\n262: });\n263: \n264: // ---------------------------------------------------------------------------\n265: // generatePrompt — Subtasks\n266: // ---------------------------------------------------------------------------\n267: \n268: describe(\"generatePrompt — subtasks\", () => {\n269:   test(\"includes subtask section when subtasks exist\", () => {\n270:     const feature = makeFeature({\n271:       subtasks: [\n272:         {\n273:           id: \"sub-1\",\n274:           title: \"First Step\",\n275:           description: \"Do the first thing\",\n276:           status: \"backlog\",\n277:           completion: 0,\n278:           difficulty: \"easy\",\n279:           priority: \"medium\",\n280:           depends_on: [],\n281:           effort: \"PT30M\",\n282:           started_at: null,\n283:           ended_at: null,\n284:           constraints: [],\n285:           forbidden: [],\n286:           references: [],\n287:           notes: [],\n288:           subtasks: [],\n289:         },\n290:       ],\n291:     });\n292:     const prompt = generatePrompt(feature, \"main\", makeConfig());\n293:     expect(prompt).toContain(\"## Subtasks\");\n294:     expect(prompt).toContain(\"First Step\");\n295:     expect(prompt).toContain(\"sub-1\");\n296:   });\n297: \n298:   test(\"omits subtask section when no subtasks\", () => {\n299:     const feature = makeFeature({ subtasks: [] });\n300:     const prompt = generatePrompt(feature, \"main\", makeConfig());\n301:     expect(prompt).not.toContain(\"## Subtasks\");\n302:   });\n303: });\n304: \n305: // ---------------------------------------------------------------------------\n306: // generatePrompt — Browser section\n307: // ---------------------------------------------------------------------------\n308: \n309: describe(\"generatePrompt — browser section\", () => {\n310:   test(\"does NOT include browser section when disabled\", () => {\n311:     const config = makeConfig({ browser: { enabled: false, bin: null, headless: true, testCommand: null, launchTimeout: 30_000, testTimeout: 60_000, defaultViewport: { width: 1280, height: 720 } } });\n312:     const prompt = generatePrompt(makeFeature(), \"main\", config);\n313:     expect(prompt).not.toContain(\"## Browser Testing\");\n314:   });\n315: \n316:   test(\"includes browser section when enabled\", () => {\n317:     const config = makeConfig({ browser: { enabled: true, bin: null, headless: true, testCommand: null, launchTimeout: 30_000, testTimeout: 60_000, defaultViewport: { width: 1280, height: 720 } } });\n318:     const prompt = generatePrompt(makeFeature(), \"main\", config);\n319:     expect(prompt).toContain(\"Browser Testing\");\n320:     expect(prompt).toContain(\"browser-based verification\");\n321:   });\n322: });\n323: \n324: // ---------------------------------------------------------------------------\n325: // generateConflictResolutionPrompt\n326: // ---------------------------------------------------------------------------\n327: \n328: describe(\"generateConflictResolutionPrompt\", () => {\n329:   test(\"includes merge conflict resolution title\", () => {\n330:     const feature = makeFeature({ title: \"Auth Flow\" });\n331:     const config = makeConfig();\n332:     const prompt = generateConflictResolutionPrompt(\n333:       feature,\n334:       \"main\",\n335:       \"CONFLICT: merge conflict in src/auth.ts\",\n336:       config\n337:     );\n338:     expect(prompt).toContain(\"Merge Conflict Resolution\");\n339:     expect(prompt).toContain(\"Auth Flow\");\n340:   });\n341: \n342:   test(\"includes merge error output\", () => {\n343:     const feature = makeFeature();\n344:     const config = makeConfig();\n345:     const prompt = generateConflictResolutionPrompt(\n346:       feature,\n347:       \"main\",\n348:       \"CONFLICT (content): Merge conflict in src/index.ts\",\n349:       config\n350:     );\n351:     expect(prompt).toContain(\"CONFLICT (content)\");\n352:   });\n353: \n354:   test(\"includes rules about not aborting merge\", () => {\n355:     const feature = makeFeature();\n356:     const config = makeConfig();\n357:     const prompt = generateConflictResolutionPrompt(\n358:       feature,\n359:       \"main\",\n360:       \"conflict\",\n361:       config\n362:     );\n363:     expect(prompt).toContain(\"Do NOT abort the merge\");\n364:   });\n365: \n366:   test(\"includes build command\", () => {\n367:     const config = makeConfig({ build: { command: \"make build\", timeout: 300_000, artifactDir: \"build\" } });\n368:     const prompt = generateConflictResolutionPrompt(\n369:       makeFeature(),\n370:       \"main\",\n371:       \"conflict\",\n372:       config\n373:     );\n374:     expect(prompt).toContain(\"make build\");\n375:   });\n376: });\n\n(End of file - total 376 lines)\n</content>","title":"tests/prompt.test.ts","metadata":{"preview":"// ---------------------------------------------------------------------------\n\ndescribe(\"generatePrompt — basic structure\", () => {\n  test(\"includes feature title and ID\", () => {\n    const feature = makeFeature();\n    const config = makeConfig();\n    const prompt = generatePrompt(featur