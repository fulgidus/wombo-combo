{"type":"tool_use","timestamp":1773445794320,"sessionID":"ses_316650d1dffespdzjLs3PfWdD3","part":{"id":"prt_ce99b43ba0014f3k60XrNEluiQ","sessionID":"ses_316650d1dffespdzjLs3PfWdD3","messageID":"msg_ce99b3650001Qrc8ocWQ6tGWyM","type":"tool","callID":"toolu_vrtx_01PwXgrQYhXJjJSJjBj2ULtG","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/tdd-red-green-coercion/src/commands/verify.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/tdd-red-green-coercion/src/commands/verify.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * verify.ts — Run build verification on completed agents.\n3:  *\n4:  * Usage: woco verify [feature-id] [--browser] [--skip-tests] [--strict-tdd] [--output json]\n5:  *\n6:  * Runs the build command in each completed agent's worktree. If a specific\n7:  * feature-id is given, verifies only that agent. Otherwise verifies all\n8:  * agents with status \"completed\".\n9:  *\n10:  * When --browser is passed (or browser.enabled is true in config), also\n11:  * runs browser-based verification after the build passes.\n12:  *\n13:  * When TDD is enabled (tdd.enabled in config), also runs tests and checks\n14:  * for test coverage of new files. Use --skip-tests to skip or --strict-tdd\n15:  * to fail on missing tests.\n16:  */\n17: \n18: import type { WomboConfig } from \"../config.js\";\n19: import { loadFeatures, type Feature } from \"../lib/tasks.js\";\n20: import { loadState } from \"../lib/state.js\";\n21: import { printDashboard } from \"../lib/ui.js\";\n22: import { handleBuildVerification } from \"./launch.js\";\n23: import { output, outputMessage, type OutputFormat } from \"../lib/output.js\";\n24: import { renderVerifyResults } from \"../lib/toon.js\";\n25: \n26: // ---------------------------------------------------------------------------\n27: // Types\n28: // ---------------------------------------------------------------------------\n29: \n30: export interface VerifyCommandOptions {\n31:   projectRoot: string;\n32:   config: WomboConfig;\n33:   featureId?: string;\n34:   model?: string;\n35:   maxRetries?: number;\n36:   /** Enable browser verification (overrides config.browser.enabled) */\n37:   browserVerify?: boolean;\n38:   /** Skip running tests during TDD verification */\n39:   skipTests?: boolean;\n40:   /** Strict TDD mode: fail verification if new files are missing tests */\n41:   strictTdd?: boolean;\n42:   outputFmt?: OutputFormat;\n43: }\n44: \n45: // ---------------------------------------------------------------------------\n46: // Command\n47: // ---------------------------------------------------------------------------\n48: \n49: export async function cmdVerify(opts: VerifyCommandOptions): Promise<void> {\n50:   const { projectRoot, config } = opts;\n51:   const fmt = opts.outputFmt ?? \"text\";\n52: \n53:   // Apply browser verification override if --browser flag was passed\n54:   if (opts.browserVerify !== undefined) {\n55:     config.browser.enabled = opts.browserVerify;\n56:   }\n57: \n58:   // Apply TDD overrides from CLI flags\n59:   if (opts.strictTdd !== undefined) {\n60:     config.tdd.strictTdd = opts.strictTdd;\n61:   }\n62: \n63:   const state = loadState(projectRoot);\n64:   if (!state) {\n65:     outputMessage(fmt, \"No active wave.\", {\n66:       wave_id: null,\n67:       agents: [],\n68:       verified: 0,\n69:     });\n70:     return;\n71:   }\n72: \n73:   const toVerify = opts.featureId\n74:     ? state.agents.filter((a) => a.feature_id === opts.featureId)\n75:     : state.agents.filter((a) => a.status === \"completed\");\n76: \n77:   if (toVerify.length === 0) {\n78:     outputMessage(fmt, \"No agents to verify.\", {\n79:       wave_id: state.wave_id,\n80:       agents: [],\n81:       verified: 0,\n82:     });\n83:     return;\n84:   }\n85: \n86:   if (fmt === \"text\") {\n87:     console.log(`\\nVerifying ${toVerify.length} agent(s)...\\n`);\n88:   }\n89: \n90:   const data = loadFeatures(projectRoot, config);\n91: \n92:   for (const agent of toVerify) {\n93:     const feature = data.tasks.find((f: Feature) => f.id === agent.feature_id);\n94:     if (!feature) continue;\n95: \n96:     await handleBuildVerification(\n97:       projectRoot,\n98:       state,\n99:       agent,\n100:       feature,\n101:       config,\n102:       opts.model,\n103:       undefined, // monitor\n104:       { skipTests: opts.skipTests, strictTdd: opts.strictTdd }\n105:     );\n106:   }\n107: \n108:   // Collect results for JSON output\n109:   const results = toVerify.map((agent) => {\n110:     // Re-read agent state after verification (it was mutated in place)\n111:     const updatedAgent = state.agents.find((a) => a.feature_id === agent.feature_id);\n112:     return {\n113:       feature_id: agent.feature_id,\n114:       branch: agent.branch,\n115:       status: updatedAgent?.status ?? agent.status,\n116:       build_passed: updatedAgent?.build_passed ?? agent.build_passed,\n117:       error: updatedAgent?.error ?? agent.error,\n118:     };\n119:   });\n120: \n121:   output(fmt, {\n122:     wave_id: state.wave_id,\n123:     verified: results.filter((r) => r.status === \"verified\").length,\n124:     failed: results.filter((r) => r.status === \"failed\").length,\n125:     agents: results,\n126:   }, () => {\n127:     printDashboard(state);\n128:   }, () => {\n129:     console.log(renderVerifyResults({\n130:       wave_id: state.wave_id,\n131:       verified: results.filter((r) => r.status === \"verified\").length,\n132:       failed: results.filter((r) => r.status === \"failed\").length,\n133:       agents: results,\n134:     }));\n135:   });\n136: }\n\n(End of file - total 136 lines)\n</content>","title":"src/commands/verify.ts","metadata":{"preview":"/**\n * verify.ts — Run build verification on completed agents.\n *\n * Usage: woco verify [feature-id] [--browser] [--skip-tests] [--strict-tdd] [--output json]\n *\n * Runs the build command in each completed agent's worktree. If a specific\n * feature-id is given, verifies only that agent. Otherwise verifies all\n * agents with status \"completed\".\n *\n * When --browser is passed (or browser.enabled is true in config), also\n * runs browser-based verification after the build passes.\n *\n * When TDD is enabled (tdd.enabled in config), also runs tests and checks\n * for test coverage of new files. Use --skip-tests to skip or --strict-tdd\n * to fail on missing tests.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport { loadFeatures, type Feature } from \"../lib/tasks.js\";\nimport { loadState } from \"../lib/state.js\";","truncated":false,"loaded":[]},"time":{"start":1773445794309,"end":1773445794319}}}}
