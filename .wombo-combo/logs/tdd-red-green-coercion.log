{"type":"tool_use","timestamp":1773445384935,"sessionID":"ses_316701812ffeYe5yCqGzB5GjN6","part":{"id":"prt_ce99508ea001pw8CMMOc2N1HTR","sessionID":"ses_316701812ffeYe5yCqGzB5GjN6","messageID":"msg_ce994fe3f001OU7VNTqLFuzLyz","type":"tool","callID":"toolu_vrtx_01EiXzp1uY4jXUow27DwJRpp","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/tdd-red-green-coercion/src/lib/tasks.ts","offset":60,"limit":80},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/tdd-red-green-coercion/src/lib/tasks.ts</path>\n<type>file</type>\n<content>60: \n61: /**\n62:  * Unified task type. Previously split into Feature and Subtask, but the shapes\n63:  * are identical so there is no reason to maintain two names.\n64:  */\n65: export interface Task {\n66:   id: string;\n67:   title: string;\n68:   description: string;\n69:   status: TaskStatus;\n70:   completion: number;\n71:   difficulty: Difficulty;\n72:   priority: Priority;\n73:   depends_on: string[];\n74:   effort: string;\n75:   started_at: string | null;\n76:   ended_at: string | null;\n77:   constraints: string[];\n78:   forbidden: string[];\n79:   references: string[];\n80:   notes: string[];\n81:   subtasks: Task[];\n82:   /**\n83:    * Optional agent type from an external registry (e.g. agency-agents).\n84:    * Format: \"category/agent-name\" (e.g. \"engineering/engineering-frontend-developer\").\n85:    * When set, wombo downloads and patches the specified agent definition\n86:    * instead of using the default generalist agent.\n87:    */\n88:   agent_type?: string;\n89:   /**\n90:    * Optional local agent definition file name (without extension).\n91:    * References a file in `.opencode/agents/<agent>.md`.\n92:    * When omitted, defaults to the config's `agent.name` (typically \"generalist-agent\").\n93:    * This is independent of `agent_type` which references external registry agents.\n94:    */\n95:   agent?: string;\n96: }\n97: \n98: /**\n99:  * Shape of tasks.yml (active tasks).\n100:  */\n101: export interface TasksFile {\n102:   version: string;\n103:   meta: {\n104:     created_at: string;\n105:     updated_at: string;\n106:     project: string;\n107:     generator: string;\n108:     maintainer: string;\n109:   };\n110:   tasks: Task[];\n111: }\n112: \n113: /**\n114:  * Shape of archive.yml (archived tasks). Same structure as TasksFile.\n115:  */\n116: export type ArchiveFile = TasksFile;\n117: \n118: // Backward-compat aliases (ease migration in consuming code)\n119: export type Feature = Task;\n120: export type Subtask = Task;\n121: export type FeatureStatus = TaskStatus;\n122: export type FeaturesFile = TasksFile & { archive: Task[] };\n123: \n124: // Re-export ordering maps from the canonical source (task-schema.ts)\n125: import { PRIORITY_ORDER, DIFFICULTY_ORDER } from \"./task-schema.js\";\n126: export { PRIORITY_ORDER, DIFFICULTY_ORDER };\n127: \n128: // ---------------------------------------------------------------------------\n129: // ISO 8601 Duration Parser\n130: // ---------------------------------------------------------------------------\n131: \n132: /**\n133:  * Parse an ISO 8601 duration string into total minutes.\n134:  * Supports: P[nY][nM][nD][T[nH][nM][nS]]\n135:  * Examples: PT1H -> 60, PT30M -> 30, P1D -> 1440, P2DT4H -> 3360, PT1H30M -> 90\n136:  *           P1Y -> 525600, P2M -> 86400\n137:  * Year/month approximations: 1Y = 365D, 1M = 30D\n138:  */\n139: export function parseDurationMinutes(iso: string): number {\n\n(Showing lines 60-139 of 661. Use offset=140 to continue.)\n</content>","title":"src/lib/tasks.ts","metadata":{"preview":"\n/**\n * Unified task type. Previously split into Feature and Subtask, but the shapes\n * are identical so there is no reason to maintain two names.\n */\nexport interface Task {\n  id: string;\n  title: string;\n  description: string;\n  status: TaskStatus;\n  completion: number;\n  difficulty: Difficulty;\n  priority: Priority;\n  depends_on: string[];\n  effort: string;\n  started_at: string | null;\n  ended_at: string | null;\n  constraints: string[];\n  forbidden: string[];\n  references: string[];","truncated":true,"loaded":[]},"time":{"start":1773445384930,"end":1773445384934}}}}
