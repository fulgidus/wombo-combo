{"type":"tool_use","timestamp":1773445069303,"sessionID":"ses_316701812ffeYe5yCqGzB5GjN6","part":{"id":"prt_ce99037c5001ZKWZQx6HYDgyt7","sessionID":"ses_316701812ffeYe5yCqGzB5GjN6","messageID":"msg_ce99028000012vxHl0X3aka4Bh","type":"tool","callID":"toolu_vrtx_01XCAQ9djnr1iycCSANRtEjo","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/tdd-red-green-coercion/src/index.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/tdd-red-green-coercion/src/index.ts</path>\n<type>file</type>\n<content>1: #!/usr/bin/env bun\n2: /**\n3:  * index.ts — CLI entry point for the wombo-combo agent orchestration system.\n4:  *\n5:  * Every command has a short alias (e.g., woco i = woco init, woco t ls = woco tasks list).\n6:  *\n7:  * Usage:\n8:  *   woco init                                         (alias: i)\n9:  *   woco launch --top-priority 3                      (alias: l)\n10:  *   woco launch --quickest-wins 5\n11:  *   woco launch --priority high\n12:  *   woco launch --difficulty easy\n13:  *   woco launch --tasks \"feat-a,feat-b\"\n14:  *   woco launch --all-ready\n15:  *   woco launch ... --max-concurrent 3 --model \"anthropic/claude-sonnet-4-20250514\"\n16:  *   woco launch ... --interactive\n17:  *   woco resume                                       (alias: r)\n18:  *   woco status                                       (alias: s)\n19:  *   woco verify [feature-id]                          (alias: v)\n20:  *   woco merge [feature-id]                           (alias: m)\n21:  *   woco retry <feature-id>                           (alias: re)\n22:  *   woco abort <feature-id> [--requeue] [--output json]  (alias: a)\n23:  *   woco logs <feature-id> [--tail N] [--follow]      (alias: lo)\n24:  *   woco cleanup                                      (alias: c)\n25:  *   woco history [wave-id] [--output json]            (alias: h)\n26:  *   woco tasks list [--status <s>] [--priority <p>]   (alias: t ls)\n27:  *   woco tasks add <id> <title> [options]             (alias: t a)\n28:  *   woco tasks set-status <task-id> <status>          (alias: t ss)\n29:  *   woco tasks set-priority <task-id> <priority>      (alias: t sp)\n30:  *   woco tasks set-difficulty <task-id> <difficulty>   (alias: t sd)\n31:  *   woco tasks check                                  (alias: t ch)\n32:  *   woco tasks archive [task-id] [--dry-run]          (alias: t ar)\n33:  *   woco tasks show <task-id>                         (alias: t sh)\n34:  *   woco tasks graph [--ascii] [--mermaid]            (alias: t g)\n35:  *   woco completion <bash|zsh|fish>                   (alias: comp)\n36:  *   woco tui                                          (default when no args)\n37:  *   woco help                                         (alias: -h, --help)\n38:  *   woco version\n39:  *   woco -v\n40:  */\n41: \n42: import { resolve } from \"node:path\";\n43: import { existsSync, readFileSync } from \"node:fs\";\n44: import { loadConfig, validateConfig } from \"./config.js\";\n45: import { loadState, saveState } from \"./lib/state.js\";\n46: \n47: // ---------------------------------------------------------------------------\n48: // Dev-mode guard: warn if running the global binary inside the wombo-combo repo\n49: // ---------------------------------------------------------------------------\n50: \n51: function checkDevModeGuard(): void {\n52:   const cwd = process.cwd();\n53:   const pkgPath = resolve(cwd, \"package.json\");\n54: \n55:   // Are we inside the wombo-combo repo?\n56:   if (!existsSync(pkgPath)) return;\n57: \n58:   let pkgName: string | undefined;\n59:   try {\n60:     const raw = readFileSync(pkgPath, \"utf-8\");\n61:     pkgName = JSON.parse(raw).name;\n62:   } catch {\n63:     return;\n64:   }\n65:   if (pkgName !== \"wombo-combo\") return;\n66: \n67:   // We're in the wombo-combo repo. Is the source being run from a different location?\n68:   // import.meta.dir = directory of THIS file (index.ts). If it's under cwd,\n69:   // we're running local source (bun dev). If it's elsewhere (e.g. ~/.bun/install),\n70:   // we're running the globally installed binary.\n71:   const sourceDir = resolve(import.meta.dir);\n72:   const projectSrc = resolve(cwd, \"src\");\n73: \n74:   if (!sourceDir.startsWith(projectSrc)) {\n75:     console.warn(\n76:       \"\\x1b[33m[WARNING]\\x1b[0m You are running the globally installed woco binary \" +\n77:       \"inside the wombo-combo repo.\\n\" +\n78:       \"  Use \\x1b[1mbun dev <command>\\x1b[0m instead to run from local source.\\n\" +\n79:       \"  See AGENTS.md for details.\\n\"\n80:     );\n81:   }\n82: }\n83: \n84: import { cmdInit } from \"./commands/init.js\";\n85: import { cmdLaunch } from \"./commands/launch.js\";\n86: import { cmdResume } from \"./commands/resume.js\";\n87: import { cmdStatus } from \"./commands/status.js\";\n88: import { cmdVerify } from \"./commands/verify.js\";\n89: import { cmdMerge } from \"./commands/merge.js\";\n90: import { cmdRetry } from \"./commands/retry.js\";\n91: import { cmdCleanup } from \"./commands/cleanup.js\";\n92: import { cmdAbort } from \"./commands/abort.js\";\n93: import { cmdLogs } from \"./commands/logs.js\";\n94: import { cmdUpgrade } from \"./commands/upgrade.js\";\n95: import { cmdHistory } from \"./commands/history.js\";\n96: import { cmdCompletion } from \"./commands/completion.js\";\n97: import { cmdTasksList } from \"./commands/tasks/list.js\";\n98: import { cmdTasksAdd } from \"./commands/tasks/add.js\";\n99: import { cmdTasksSetStatus } from \"./commands/tasks/set-status.js\";\n100: import { cmdTasksSetPriority } from \"./commands/tasks/set-priority.js\";\n101: import { cmdTasksSetDifficulty } from \"./commands/tasks/set-difficulty.js\";\n102: import { cmdTasksCheck } from \"./commands/tasks/check.js\";\n103: import { cmdTasksArchive } from \"./commands/tasks/archive.js\";\n104: import { cmdTasksShow } from \"./commands/tasks/show.js\";\n105: import { cmdTasksGraph } from \"./commands/tasks/graph.js\";\n106: import { cmdTui } from \"./commands/tui.js\";\n107: \n108: import { ensureTasksFile } from \"./lib/tasks.js\";\n109: import type { Priority, Difficulty, FeatureStatus } from \"./lib/tasks.js\";\n110: import { resolveOutputFormat, type OutputFormat } from \"./lib/output.js\";\n111: import { validateId, validateText, validateBranchName, validateDuration, assertValid } from \"./lib/validate.js\";\n112: import { findCommandDef, commandToSchema, allCommandSchemas } from \"./lib/schema.js\";\n113: import { buildToonSpec, renderToonLegend } from \"./lib/toon-spec.js\";\n114: \n115: // ---------------------------------------------------------------------------\n116: // Types\n117: // ---------------------------------------------------------------------------\n118: \n119: export interface CLIArgs {\n120:   command: string;\n121:   subcommand?: string;\n122:   // Selection options (launch)\n123:   topPriority?: number;\n124:   quickestWins?: number;\n125:   priority?: Priority;\n126:   difficulty?: Difficulty;\n127:   tasks?: string[];\n128:   allReady?: boolean;\n129:   // Launch / runtime options\n130:   maxConcurrent?: number;\n131:   model?: string;\n132:   interactive: boolean;\n133:   dryRun: boolean;\n134:   baseBranch?: string;\n135:   maxRetries?: number;\n136:   noTui: boolean;\n137:   autoPush: boolean;\n138:   // Abort options\n139:   requeue: boolean;\n140:   // General\n141:   featureId?: string;\n142:   force: boolean;\n143:   // Output format\n144:   outputFmt: OutputFormat;\n145:   // Upgrade options\n146:   checkOnly: boolean;\n147:   tag?: string;\n148:   // Features subcommand extras\n149:   status?: string;\n150:   ready?: boolean;\n151:   includeArchive?: boolean;\n152:   title?: string;\n153:   description?: string;\n154:   effort?: string;\n155:   dependsOn?: string[];\n156:   // Logs options\n157:   tail?: number;\n158:   follow?: boolean;\n159:   // Compact output\n160:   fields?: string[];\n161:   // Graph options\n162:   ascii?: boolean;\n163:   mermaidRaw?: boolean;\n164:   graphSubtasks?: boolean;\n165:   // Browser verification\n166:   browser?: boolean;\n167:   // TDD verification\n168:   skipTests?: boolean;\n169:   strictTdd?: boolean;\n170:   // Agent selection (per-task override)\n171:   agent?: string;\n172: }\n173: \n174: // ---------------------------------------------------------------------------\n175: // Command & Subcommand Aliases\n176: // ---------------------------------------------------------------------------\n177: \n178: /** Map of short aliases → canonical top-level command names. */\n179: export const COMMAND_ALIASES: Record<string, string> = {\n180:   i: \"init\",\n181:   l: \"launch\",\n182:   r: \"resume\",\n183:   s: \"status\",\n184:   v: \"verify\",\n185:   m: \"merge\",\n186:   re: \"retry\",\n187:   a: \"abort\",\n188:   c: \"cleanup\",\n189:   h: \"history\",\n190:   lo: \"logs\",\n191:   t: \"tasks\",\n192:   features: \"tasks\", // backward-compat full-word alias\n193:   u: \"upgrade\",\n194:   d: \"describe\",\n195:   comp: \"completion\",\n196:   tui: \"tui\",\n197: };\n198: \n199: /** Map of short aliases → canonical tasks subcommand names. */\n200: export const SUBCOMMAND_ALIASES: Record<string, string> = {\n201:   ls: \"list\",\n202:   a: \"add\",\n203:   ss: \"set-status\",\n204:   sp: \"set-priority\",\n205:   sd: \"set-difficulty\",\n206:   ch: \"check\",\n207:   validate: \"check\", // backward-compat full-word alias\n208:   ar: \"archive\",\n209:   sh: \"show\",\n210:   g: \"graph\",\n211: };\n212: \n213: // ---------------------------------------------------------------------------\n214: // Arg Parsing\n215: // ---------------------------------------------------------------------------\n216: \n217: export function parseArgs(argv: string[]): CLIArgs {\n218:   const args = argv.slice(2); // skip 'bun' and script path\n219:   const result: CLIArgs = {\n220:     command: args[0] || \"tui\",\n221:     interactive: false,\n222:     dryRun: false,\n223:     noTui: false,\n224:     autoPush: false,\n225:     requeue: false,\n226:     force: false,\n227:     checkOnly: false,\n228:     outputFmt: resolveOutputFormat(undefined), // auto-detect until --output overrides\n229:   };\n230: \n231:   // Resolve top-level command alias (e.g., \"i\" → \"init\", \"t\" → \"tasks\")\n232:   result.command = COMMAND_ALIASES[result.command] ?? result.command;\n233: \n234:   // If the command is \"tasks\", treat the second positional as the subcommand\n235:   let startIdx = 1;\n236:   if (result.command === \"tasks\") {\n237:     result.subcommand = args[1] || \"list\";\n238:     // Resolve subcommand alias (e.g., \"ls\" → \"list\", \"ss\" → \"set-status\")\n239:     result.subcommand = SUBCOMMAND_ALIASES[result.subcommand] ?? result.subcommand;\n240:     startIdx = 2;\n241:   }\n242: \n243:   for (let i = startIdx; i < args.length; i++) {\n244:     const arg = args[i];\n245: \n246:     // Helper: consume the next argument, or exit with a clear error\n247:     function requireValue(flag: string): string {\n248:       if (i + 1 >= args.length) {\n249:         console.error(`Flag ${flag} requires a value.`);\n250:         process.exit(1);\n251:       }\n252:       return args[++i];\n253:     }\n254: \n255:     switch (arg) {\n256:       // --- Selection options ---\n257:       case \"--top-priority\":\n258:         result.topPriority = parseInt(requireValue(arg), 10);\n259:         break;\n260:       case \"--quickest-wins\":\n261:         result.quickestWins = parseInt(requireValue(arg), 10);\n262:         break;\n263:       case \"--priority\":\n264:         result.priority = requireValue(arg) as Priority;\n265:         break;\n266:       case \"--difficulty\":\n267:         result.difficulty = requireValue(arg) as Difficulty;\n268:         break;\n269:       case \"--tasks\":\n270:       case \"--features\": // backward-compat alias\n271:         result.tasks = requireValue(arg).split(\",\").map((s) => s.trim());\n272:         break;\n273:       case \"--all-ready\":\n274:         result.allReady = true;\n275:         break;\n276: \n277:       // --- Launch / runtime options ---\n278:       case \"--max-concurrent\":\n279:         result.maxConcurrent = parseInt(requireValue(arg), 10);\n280:         break;\n281:       case \"--model\":\n282:       case \"-m\":\n283:         result.model = requireValue(arg);\n284:         break;\n285:       case \"--interactive\":\n286:         result.interactive = true;\n287:         break;\n288:       case \"--dry-run\":\n289:         result.dryRun = true;\n290:         break;\n291:       case \"--no-tui\":\n292:         result.noTui = true;\n293:         break;\n294:       case \"--auto-push\":\n295:         result.autoPush = true;\n296:         break;\n297:       case \"--requeue\":\n298:         result.requeue = true;\n299:         break;\n300:       case \"--base-branch\":\n301:         result.baseBranch = requireValue(arg);\n302:         break;\n303:       case \"--max-retries\":\n304:         result.maxRetries = parseInt(requireValue(arg), 10);\n305:         break;\n306: \n307:       // --- General flags ---\n308:       case \"--force\":\n309:         result.force = true;\n310:         break;\n311:       case \"--check\":\n312:         result.checkOnly = true;\n313:         break;\n314:       case \"--tag\":\n315:       case \"--release\":\n316:         result.tag = requireValue(arg);\n317:         break;\n318:       case \"--output\":\n319:       case \"-o\":\n320:         result.outputFmt = resolveOutputFormat(requireValue(arg));\n321:         break;\n322: \n323:       // --- Tasks subcommand options ---\n324:       case \"--status\":\n325:         result.status = requireValue(arg);\n326:         break;\n327:       case \"--ready\":\n328:         result.ready = true;\n329:         break;\n330:       case \"--include-archive\":\n331:         result.includeArchive = true;\n332:         break;\n333:       case \"--title\":\n334:         result.title = requireValue(arg);\n335:         break;\n336:       case \"--description\":\n337:       case \"--desc\":\n338:         result.description = requireValue(arg);\n339:         break;\n340:       case \"--effort\":\n341:         result.effort = requireValue(arg);\n342:         break;\n343:       case \"--depends-on\":\n344:         result.dependsOn = requireValue(arg).split(\",\").map((s) => s.trim());\n345:         break;\n346:       case \"--fields\":\n347:         result.fields = requireValue(arg).split(\",\").map((s) => s.trim());\n348:         break;\n349: \n350:       // --- Graph options ---\n351:       case \"--ascii\":\n352:         result.ascii = true;\n353:         break;\n354:       case \"--mermaid\":\n355:         result.mermaidRaw = true;\n356:         break;\n357:       case \"--subtasks\":\n358:         result.graphSubtasks = true;\n359:         break;\n360: \n361:       // --- Logs options ---\n362:       case \"--tail\":\n363:         result.tail = parseInt(requireValue(arg), 10);\n364:         break;\n365:       case \"--follow\":\n366:       case \"-f\":\n367:         result.follow = true;\n368:         break;\n369: \n370:       // --- Browser verification ---\n371:       case \"--browser\":\n372:         result.browser = true;\n373:         break;\n374: \n375:       // --- TDD verification ---\n376:       case \"--skip-tests\":\n377:         result.skipTests = true;\n378:         break;\n379:       case \"--strict-tdd\":\n380:         result.strictTdd = true;\n381:         break;\n382: \n383:       // --- Agent selection ---\n384:       case \"--agent\":\n385:         result.agent = requireValue(arg);\n386:         break;\n387: \n388:       // --- Positional (feature-id, title for add, etc.) ---\n389:       default:\n390:         if (!arg.startsWith(\"-\")) {\n391:           if (!result.featureId) {\n392:             result.featureId = arg;\n393:           } else if (!result.title) {\n394:             result.title = arg;\n395:           }\n396:         }\n397:         break;\n398:     }\n399:   }\n400: \n401:   return result;\n402: }\n403: \n404: // ---------------------------------------------------------------------------\n405: // Help\n406: // ---------------------------------------------------------------------------\n407: \n408: function cmdHelp(): void {\n409:   console.log(`\n410: wombo-combo — AI Agent Orchestration System\n411: \n412:   WOMBO COMBO! Parallel feature development with AI agents.\n413: \n414: Commands:                        (alias)\n415:   init                           (i)     Generate .wombo-combo/config.json in the current project\n416:   launch                         (l)     Launch a wave of agents to implement features\n417:   resume                         (r)     Resume a previously stopped wave\n418:   status                         (s)     Show the status of the current wave\n419:   verify                         (v)     Run build verification on completed agents\n420:   merge                          (m)     Merge verified branches into the base branch\n421:   retry                          (re)    Retry a failed agent\n422:   abort                          (a)     Kill a single running agent (--requeue to return to queue)\n423:   logs                           (lo)    Pretty-print agent logs for a feature\n424:   cleanup                        (c)     Remove all wave worktrees and multiplexer sessions\n425:   history                        (h)     List/view past wave results (stored in .wombo-combo/history/)\n426:   tasks                          (t)     Manage tasks file (see below; 'features' also accepted)\n427:   tui                                    Interactive TUI: browse tasks, select, launch, monitor\n428:   upgrade                        (u)     Check for updates and upgrade wombo-combo\n429:   describe                       (d)     Emit JSON schema or TOON legend (--output toon)\n430:   completion                     (comp)  Generate shell completions (bash, zsh, fish)\n431:   version                                Print version and exit\n432:   help                                   Show this help\n433: \n434: Tasks Subcommands:               (alias)\n435:   tasks list                     (ls)    List tasks (--status, --priority, --difficulty, --ready, --include-archive)\n436:   tasks add <id> <title>         (a)     Add a new task (--desc, --priority, --difficulty, --effort, --depends-on)\n437:   tasks set-status <id> <s>      (ss)    Change a task's status\n438:   tasks set-priority <id> <p>    (sp)    Change a task's priority (critical/high/medium/low/wishlist)\n439:   tasks set-difficulty <id> <d>  (sd)    Change a task's difficulty (trivial/easy/medium/hard/very_hard)\n440:   tasks check                    (ch)    Validate tasks file (schema, deps, duplicates, cycles)\n441:   tasks archive [id]             (ar)    Move done/cancelled to archive (--dry-run)\n442:   tasks show <id>                (sh)    Show task details\n443:   tasks graph                    (g)     Visualize dependency graph (--ascii, --mermaid, --subtasks)\n444: \n445: Selection Options (for launch):\n446:   --top-priority N         Select top N tasks by priority\n447:   --quickest-wins N        Select N tasks with lowest effort\n448:   --priority <level>       Filter by priority (critical/high/medium/low/wishlist)\n449:   --difficulty <level>     Filter by difficulty (trivial/easy/medium/hard/very_hard)\n450:   --tasks \"id1,id2\"        Select specific tasks by ID (--features also accepted)\n451:   --all-ready              Select all tasks whose dependencies are met\n452: \n453: Launch Options:\n454:   --max-concurrent N       Max agents running in parallel (default: from config)\n455:   --model <model>          Model to use (e.g., \"anthropic/claude-sonnet-4-20250514\")\n456:   --interactive            Use multiplexer (dmux/tmux) TUI mode instead of headless\n457:   --no-tui                 Headless mode without neo-blessed TUI (periodic console dashboard)\n458:   --auto-push              Push base branch to remote after all merges complete\n459:   --dry-run                Show what would be launched without launching\n460:   --base-branch <branch>   Base branch (default: from config)\n461:   --max-retries N          Max retries per agent (default: from config)\n462:   --browser                Enable browser-based verification (run after build passes)\n463:   --skip-tests             Skip running tests during TDD verification\n464:   --strict-tdd             Strict TDD: fail verification if new files are missing tests\n465:   --agent <name>           Override agent definition for all launched tasks (name without .md extension)\n466: \n467: General:\n468:   --force                  Force overwrite (e.g., for init) / skip prompts (e.g., for upgrade)\n469:   --output <fmt>           Output format: text (default on TTY), json (default when piped), or toon (WOMBO_OUTPUT=toon)\n470:   -o <fmt>                 Alias for --output\n471:   --dry-run                Show what would happen without performing the action\n472:   --fields <list>          Comma-separated fields to include (e.g., id,status,priority)\n473: \n474: Upgrade Options:\n475:   --check                  Only check for updates, don't install\n476:   --tag <tag>              Install a specific version (e.g., v0.1.0)\n477: \n478: Logs Options:\n479:   --tail N                 Show only the last N lines\n480:   --follow, -f             Stream new output as it arrives (like tail -f)\n481: \n482: Aliases (every command has a short form):\n483:   woco i                         woco init\n484:   woco l --all-ready             woco launch --all-ready\n485:   woco t ls                      woco tasks list\n486:   woco t a my-task \"Title\"       woco tasks add my-task \"Title\"\n487:   woco t ss my-task done         woco tasks set-status my-task done\n488: \n489: Shell Completion:\n490:   eval \"$(woco completion bash)\"    # Bash: add to ~/.bashrc\n491:   eval \"$(woco completion zsh)\"     # Zsh:  add to ~/.zshrc\n492:   woco completion fish | source     # Fish (or save to ~/.config/fish/completions/woco.fish)\n493: \n494: Examples:\n495:   woco init\n496:   woco launch --quickest-wins 3\n497:   woco launch --priority high --interactive\n498:   woco launch --tasks \"auth-flow,search-api\" --max-concurrent 2\n499:   woco resume\n500:   woco status\n501:   woco verify\n502:   woco merge\n503:   woco retry auth-flow\n504:   woco abort auth-flow\n505:   woco abort auth-flow --requeue\n506:   woco abort auth-flow --output json\n507:   woco logs auth-flow\n508:   woco logs auth-flow --tail 50\n509:   woco logs auth-flow --follow\n510:   woco logs auth-flow --output json\n511:   woco cleanup\n512:   woco tasks list --status ready --priority high\n513:   woco tasks list --fields id,status,priority --output json\n514:   woco tasks add my-task \"My Cool Task\" --priority high --difficulty easy\n515:   woco tasks set-status my-task in-progress\n516:   woco tasks check\n517:   woco tasks archive --dry-run\n518:   woco tasks show my-task\n519:   woco history\n520:   woco history wave-2026-03-12-420\n521:   woco history --output json\n522:   woco describe                           # list all commands as JSON\n523:   woco describe launch                    # describe a specific command\n524:   woco describe tasks add                 # describe a subcommand\n525:   woco describe --output toon             # emit TOON format legend/spec\n526: `);\n527: }\n528: \n529: // ---------------------------------------------------------------------------\n530: // Main\n531: // ---------------------------------------------------------------------------\n532: \n533: async function main(): Promise<void> {\n534:   checkDevModeGuard();\n535: \n536:   const PROJECT_ROOT = resolve(process.cwd());\n537:   const args = parseArgs(process.argv);\n538: \n539:   // -----------------------------------------------------------------------\n540:   // Input validation at the CLI boundary\n541:   // -----------------------------------------------------------------------\n542:   if (args.featureId) {\n543:     assertValid(validateId(args.featureId, \"feature ID\"));\n544:   }\n545:   if (args.title) {\n546:     assertValid(validateText(args.title, \"title\"));\n547:   }\n548:   if (args.description) {\n549:     assertValid(validateText(args.description, \"description\"));\n550:   }\n551:   if (args.baseBranch) {\n552:     assertValid(validateBranchName(args.baseBranch, \"base branch\"));\n553:   }\n554:   if (args.effort) {\n555:     assertValid(validateDuration(args.effort, \"effort\"));\n556:   }\n557:   if (args.tasks) {\n558:     for (const fid of args.tasks) {\n559:       assertValid(validateId(fid, \"task ID in --tasks\"));\n560:     }\n561:   }\n562:   if (args.dependsOn) {\n563:     for (const dep of args.dependsOn) {\n564:       assertValid(validateId(dep, \"dependency ID in --depends-on\"));\n565:     }\n566:   }\n567: \n568:   // Validate numeric args are not NaN\n569:   const numericArgs: [string, number | undefined][] = [\n570:     [\"--top-priority\", args.topPriority],\n571:     [\"--quickest-wins\", args.quickestWins],\n572:     [\"--max-concurrent\", args.maxConcurrent],\n573:     [\"--max-retries\", args.maxRetries],\n574:     [\"--tail\", args.tail],\n575:   ];\n576:   for (const [flag, value] of numericArgs) {\n577:     if (value !== undefined && isNaN(value)) {\n578:       console.error(`${flag} requires a numeric value.`);\n579:       process.exit(1);\n580:     }\n581:   }\n582: \n583:   // Commands that don't need config loading\n584:   if (args.command === \"version\" || args.command === \"-v\" || args.command === \"-V\") {\n585:     const pkgPath = resolve(import.meta.dir, \"..\", \"package.json\");\n586:     const pkgFile = Bun.file(pkgPath);\n587:     try {\n588:       const pkg = await pkgFile.json();\n589:       console.log(`wombo-combo ${pkg.version ?? \"(unknown version)\"}`);\n590:     } catch {\n591:       console.log(\"wombo-combo (unknown version)\");\n592:     }\n593:     return;\n594:   }\n595: \n596:   if (args.command === \"help\" || args.command === \"--help\" || args.command === \"-h\") {\n597:     cmdHelp();\n598:     return;\n599:   }\n600: \n601:   if (args.command === \"describe\") {\n602:     // Schema introspection: `woco describe [command]`\n603:     if (args.outputFmt === \"toon\") {\n604:       // Emit TOON format legend — self-describing, cacheable by agents\n605:       const pkgPath = resolve(import.meta.dir, \"..\", \"package.json\");\n606:       let version = \"unknown\";\n607:       try {\n608:         const pkg = await Bun.file(pkgPath).json();\n609:         version = pkg.version ?? \"unknown\";\n610:       } catch {}\n611: \n612:       if (!args.featureId) {\n613:         // Full TOON spec (legend + all commands)\n614:         console.log(renderToonLegend(version));\n615:       } else {\n616:         // JSON structure for the full spec (--output toon with a specific command\n617:         // still emits JSON since TOON is a line-oriented data format, not a schema format)\n618:         const spec = buildToonSpec(version);\n619:         const cmdName = args.title\n620:           ? `${args.featureId} ${args.title}`\n621:           : args.featureId;\n622:         const cmdSpec = spec.commands.find((c) => c.command === cmdName);\n623:         if (!cmdSpec) {\n624:           console.error(`Unknown command: \"${cmdName}\"`);\n625:           console.error(\"Run 'woco describe --output toon' to see the full TOON spec.\");\n626:           process.exit(1);\n627:           return;\n628:         }\n629:         console.log(JSON.stringify(cmdSpec, null, 2));\n630:       }\n631:       return;\n632:     }\n633: \n634:     if (!args.featureId) {\n635:       // No command specified — list all commands\n636:       console.log(JSON.stringify(allCommandSchemas(), null, 2));\n637:     } else {\n638:       // Describe a specific command. Handle compound names: \"features list\"\n639:       const cmdName = args.title\n640:         ? `${args.featureId} ${args.title}`\n641:         : args.featureId;\n642:       const def = findCommandDef(cmdName);\n643:       if (!def) {\n644:         console.error(`Unknown command: \"${cmdName}\"`);\n645:         console.error(\"Run 'woco describe' to list all commands.\");\n646:         process.exit(1);\n647:         return;\n648:       }\n649:       console.log(JSON.stringify(commandToSchema(def), null, 2));\n650:     }\n651:     return;\n652:   }\n653: \n654:   if (args.command === \"init\") {\n655:     await cmdInit({ projectRoot: PROJECT_ROOT, force: args.force });\n656:     return;\n657:   }\n658: \n659:   if (args.command === \"upgrade\") {\n660:     await cmdUpgrade({\n661:       force: args.force,\n662:       tag: args.tag,\n663:       checkOnly: args.checkOnly,\n664:     });\n665:     return;\n666:   }\n667: \n668:   if (args.command === \"completion\") {\n669:     cmdCompletion({ shell: args.featureId }); // first positional = shell name\n670:     return;\n671:   }\n672: \n673:   if (args.command === \"logs\") {\n674:     if (!args.featureId) {\n675:       console.error(\"Usage: woco logs <feature-id> [--tail N] [--follow] [--output json]\");\n676:       process.exit(1);\n677:       return;\n678:     }\n679:     await cmdLogs({\n680:       projectRoot: PROJECT_ROOT,\n681:       featureId: args.featureId,\n682:       tail: args.tail,\n683:       follow: args.follow,\n684:       outputFmt: args.outputFmt,\n685:     });\n686:     return;\n687:   }\n688: \n689:   // Everything else requires config\n690:   const config = loadConfig(PROJECT_ROOT);\n691:   validateConfig(config);\n692: \n693:   // Commands that operate on the tasks file — ensure it exists first\n694:   const needsTasksFile = new Set([\"launch\", \"resume\", \"verify\", \"retry\", \"tasks\", \"tui\"]);\n695:   if (needsTasksFile.has(args.command)) {\n696:     await ensureTasksFile(PROJECT_ROOT, config);\n697:   }\n698: \n699:   switch (args.command) {\n700:     case \"launch\":\n701:       // Apply browser verification override if --browser flag was passed\n702:       if (args.browser !== undefined) {\n703:         config.browser.enabled = args.browser;\n704:       }\n705:       await cmdLaunch({\n706:         projectRoot: PROJECT_ROOT,\n707:         config,\n708:         topPriority: args.topPriority,\n709:         quickestWins: args.quickestWins,\n710:         priority: args.priority,\n711:         difficulty: args.difficulty,\n712:         features: args.tasks,\n713:         allReady: args.allReady,\n714:         maxConcurrent: args.maxConcurrent ?? config.defaults.maxConcurrent,\n715:         model: args.model,\n716:         interactive: args.interactive,\n717:         dryRun: args.dryRun,\n718:         baseBranch: args.baseBranch ?? config.baseBranch,\n719:         maxRetries: args.maxRetries ?? config.defaults.maxRetries,\n720:         noTui: args.noTui,\n721:         autoPush: args.autoPush,\n722:         outputFmt: args.outputFmt,\n723:         agent: args.agent,\n724:       });\n725:       break;\n726: \n727:     case \"resume\":\n728:       await cmdResume({\n729:         projectRoot: PROJECT_ROOT,\n730:         config,\n731:         maxConcurrent: args.maxConcurrent,\n732:         model: args.model,\n733:         interactive: args.interactive,\n734:         noTui: args.noTui,\n735:         autoPush: args.autoPush,\n736:         baseBranch: args.baseBranch,\n737:         maxRetries: args.maxRetries,\n738:         outputFmt: args.outputFmt,\n739:       });\n740:       break;\n741: \n742:     case \"status\":\n743:       await cmdStatus({ projectRoot: PROJECT_ROOT, config, outputFmt: args.outputFmt });\n744:       break;\n745: \n746:     case \"verify\":\n747:       await cmdVerify({\n748:         projectRoot: PROJECT_ROOT,\n749:         config,\n750:         featureId: args.featureId,\n751:         model: args.model,\n752:         maxRetries: args.maxRetries,\n753:         browserVerify: args.browser,\n754:         skipTests: args.skipTests,\n755:         strictTdd: args.strictTdd,\n756:         outputFmt: args.outputFmt,\n757:       });\n758:       break;\n759: \n760:     case \"merge\":\n761:       await cmdMerge({\n762:         projectRoot: PROJECT_ROOT,\n763:         config,\n764:         featureId: args.featureId,\n765:         autoPush: args.autoPush,\n766:         dryRun: args.dryRun,\n767:         model: args.model,\n768:         outputFmt: args.outputFmt,\n769:       });\n770:       break;\n771: \n772:     case \"retry\": {\n773:       if (!args.featureId) {\n774:         console.error(\"Usage: woco retry <feature-id>\");\n775:         process.exit(1);\n776:         return;\n777:       }\n778:       await cmdRetry({\n779:         projectRoot: PROJECT_ROOT,\n780:         config,\n781:         featureId: args.featureId,\n782:         model: args.model,\n783:         interactive: args.interactive,\n784:         dryRun: args.dryRun,\n785:         outputFmt: args.outputFmt,\n786:       });\n787:       break;\n788:     }\n789: \n790:     case \"cleanup\":\n791:       await cmdCleanup({ projectRoot: PROJECT_ROOT, config, dryRun: args.dryRun, outputFmt: args.outputFmt });\n792:       break;\n793: \n794:     case \"history\":\n795:       await cmdHistory({\n796:         projectRoot: PROJECT_ROOT,\n797:         config,\n798:         waveId: args.featureId,\n799:         outputFmt: args.outputFmt,\n800:       });\n801:       break;\n802: \n803:     case \"abort\": {\n804:       if (!args.featureId) {\n805:         console.error(\"Usage: woco abort <feature-id> [--requeue] [--output json]\");\n806:         process.exit(1);\n807:         return;\n808:       }\n809:       await cmdAbort({\n810:         projectRoot: PROJECT_ROOT,\n811:         config,\n812:         featureId: args.featureId,\n813:         requeue: args.requeue,\n814:         outputFmt: args.outputFmt,\n815:       });\n816:       break;\n817:     }\n818: \n819:     case \"tasks\":\n820:       await handleTasksSubcommand(args, PROJECT_ROOT, config);\n821:       break;\n822: \n823:     case \"tui\":\n824:       await cmdTui({\n825:         projectRoot: PROJECT_ROOT,\n826:         config,\n827:         maxConcurrent: args.maxConcurrent,\n828:         model: args.model,\n829:         baseBranch: args.baseBranch,\n830:         maxRetries: args.maxRetries,\n831:         autoPush: args.autoPush,\n832:         skipTests: args.skipTests,\n833:         strictTdd: args.strictTdd,\n834:         agent: args.agent,\n835:       });\n836:       break;\n837: \n838:     default:\n839:       console.error(`Unknown command: ${args.command}`);\n840:       cmdHelp();\n841:       process.exit(1);\n842:       return;\n843:   }\n844: }\n845: \n846: // ---------------------------------------------------------------------------\n847: // Tasks Subcommand Router\n848: // ---------------------------------------------------------------------------\n849: \n850: async function handleTasksSubcommand(\n851:   args: CLIArgs,\n852:   projectRoot: string,\n853:   config: import(\"./config.js\").WomboConfig\n854: ): Promise<void> {\n855:   switch (args.subcommand) {\n856:     case \"list\":\n857:       await cmdTasksList({\n858:         projectRoot,\n859:         config,\n860:         status: args.status as FeatureStatus | undefined,\n861:         priority: args.priority,\n862:         difficulty: args.difficulty,\n863:         ready: args.ready,\n864:         includeArchive: args.includeArchive,\n865:         outputFmt: args.outputFmt,\n866:         fields: args.fields,\n867:       });\n868:       break;\n869: \n870:     case \"add\": {\n871:       if (!args.featureId || !args.title) {\n872:         console.error(\"Usage: woco tasks add <id> <title> [--desc <desc>] [--priority <p>] [--difficulty <d>] [--effort <e>] [--depends-on <ids>]\");\n873:         process.exit(1);\n874:         return;\n875:       }\n876:       await cmdTasksAdd({\n877:         projectRoot,\n878:         config,\n879:         id: args.featureId,\n880:         title: args.title,\n881:         description: args.description,\n882:         priority: args.priority,\n883:         difficulty: args.difficulty,\n884:         effort: args.effort,\n885:         dependsOn: args.dependsOn,\n886:         outputFmt: args.outputFmt,\n887:         dryRun: args.dryRun,\n888:       });\n889:       break;\n890:     }\n891: \n892:     case \"set-status\": {\n893:       // The new status can come from the second positional (stored in args.title)\n894:       // or from the --status flag\n895:       const newStatus = args.title || args.status;\n896:       if (!args.featureId || !newStatus) {\n897:         console.error(\"Usage: woco tasks set-status <task-id> <status>\");\n898:         process.exit(1);\n899:         return;\n900:       }\n901:       await cmdTasksSetStatus({\n902:         projectRoot,\n903:         config,\n904:         featureId: args.featureId,\n905:         newStatus,\n906:         outputFmt: args.outputFmt,\n907:         dryRun: args.dryRun,\n908:       });\n909:       break;\n910:     }\n911: \n912:     case \"set-priority\": {\n913:       // The new priority can come from the second positional (stored in args.title)\n914:       // or from the --priority flag\n915:       const newPriority = args.title || (args.priority as string | undefined);\n916:       if (!args.featureId || !newPriority) {\n917:         console.error(\"Usage: woco tasks set-priority <task-id> <priority>\");\n918:         process.exit(1);\n919:         return;\n920:       }\n921:       await cmdTasksSetPriority({\n922:         projectRoot,\n923:         config,\n924:         featureId: args.featureId,\n925:         newPriority,\n926:         outputFmt: args.outputFmt,\n927:         dryRun: args.dryRun,\n928:       });\n929:       break;\n930:     }\n931: \n932:     case \"set-difficulty\": {\n933:       // The new difficulty can come from the second positional (stored in args.title)\n934:       // or from the --difficulty flag\n935:       const newDifficulty = args.title || (args.difficulty as string | undefined);\n936:       if (!args.featureId || !newDifficulty) {\n937:         console.error(\"Usage: woco tasks set-difficulty <task-id> <difficulty>\");\n938:         process.exit(1);\n939:         return;\n940:       }\n941:       await cmdTasksSetDifficulty({\n942:         projectRoot,\n943:         config,\n944:         featureId: args.featureId,\n945:         newDifficulty,\n946:         outputFmt: args.outputFmt,\n947:         dryRun: args.dryRun,\n948:       });\n949:       break;\n950:     }\n951: \n952:     case \"check\":\n953:       await cmdTasksCheck({ projectRoot, config, outputFmt: args.outputFmt });\n954:       break;\n955: \n956:     case \"archive\":\n957:       await cmdTasksArchive({\n958:         projectRoot,\n959:         config,\n960:         featureId: args.featureId,\n961:         dryRun: args.dryRun,\n962:         outputFmt: args.outputFmt,\n963:       });\n964:       break;\n965: \n966:     case \"show\": {\n967:       if (!args.featureId) {\n968:         console.error(\"Usage: woco tasks show <task-id>\");\n969:         process.exit(1);\n970:         return;\n971:       }\n972:       await cmdTasksShow({\n973:         projectRoot,\n974:         config,\n975:         featureId: args.featureId,\n976:         outputFmt: args.outputFmt,\n977:         fields: args.fields,\n978:       });\n979:       break;\n980:     }\n981: \n982:     case \"graph\":\n983:       await cmdTasksGraph({\n984:         projectRoot,\n985:         config,\n986:         status: args.status as FeatureStatus | undefined,\n987:         ascii: args.ascii,\n988:         mermaid: args.mermaidRaw,\n989:         subtasks: args.graphSubtasks,\n990:         outputFmt: args.outputFmt,\n991:       });\n992:       break;\n993: \n994:     case \"help\":\n995:     case \"--help\":\n996:     case \"-h\":\n997:       cmdHelp();\n998:       break;\n999: \n1000:     default:\n1001:       console.error(`Unknown tasks subcommand: ${args.subcommand}`);\n1002:       console.error(\"Run 'woco tasks help' or 'woco help' for usage.\");\n1003:       process.exit(1);\n1004:       return;\n1005:   }\n1006: }\n1007: \n1008: // ---------------------------------------------------------------------------\n1009: // Error Handlers & Entry\n1010: // ---------------------------------------------------------------------------\n1011: \n1012: // Global error handlers — prevent silent crashes\n1013: process.on(\"uncaughtException\", (err) => {\n1014:   console.error(`\\n[FATAL] Uncaught exception: ${err.message}`);\n1015:   console.error(err.stack);\n1016:   try {\n1017:     const state = loadState(process.cwd());\n1018:     if (state) saveState(process.cwd(), state);\n1019:   } catch {}\n1020:   process.exit(1);\n1021: });\n1022: \n1023: process.on(\"unhandledRejection\", (reason: any) => {\n1024:   console.error(`\\n[FATAL] Unhandled rejection: ${reason?.message || reason}`);\n1025:   if (reason?.stack) console.error(reason.stack);\n1026:   try {\n1027:     const state = loadState(process.cwd());\n1028:     if (state) saveState(process.cwd(), state);\n1029:   } catch {}\n1030:   process.exit(1);\n1031: });\n1032: \n1033: main().catch((err) => {\n1034:   console.error(\"Fatal error:\", err.message);\n1035:   process.exit(1);\n1036: });\n\n(End of file - total 1036 lines)\n</content>","title":"src/index.ts","metadata":{"preview":"#!/usr/bin/env bun\n/**\n * index.ts — CLI entry point for the wombo-combo agent orchestration system.\n *\n * Every command has a short alias (e.g., woco i = woco init, woco t ls = woco tasks list).\n *\n * Usage:\n *   woco init                                         (alias: i)\n *   woco launch --top-priority 3                      (alias: l)\n *   woco launch --quickest-wins 5\n *   woco launch --priority high\n *   woco launch --difficulty easy\n *   woco launch --tasks \"feat-a,feat-b\"\n *   woco launch --all-ready\n *   woco launch ... --max-concurrent 3 --model \"anthropic/claude-sonnet-4-20250514\"\n *   woco launch ... --interactive\n *   woco resume                                       (alias: r)\n *   woco status                                       (alias: s)\n *   woco verify [feature-id]                          (alias: v)\n *   woco merge [feature-id]                           (alias: m)","truncated":false,"loaded":[]},"time":{"start":1773445069298,"end":1773445069301}}}}
