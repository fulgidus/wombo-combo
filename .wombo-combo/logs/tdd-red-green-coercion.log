{"type":"tool_use","timestamp":1773445466812,"sessionID":"ses_316701812ffeYe5yCqGzB5GjN6","part":{"id":"prt_ce9964689001r7VOe6yK1Bavqv","sessionID":"ses_316701812ffeYe5yCqGzB5GjN6","messageID":"msg_ce9963721001NfgqG6e62TWG0Z","type":"tool","callID":"toolu_vrtx_01AFLpU9FgLhpEW1Dgye8Hbb","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/tdd-red-green-coercion/tests/prompt-tdd.test.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/tdd-red-green-coercion/tests/prompt-tdd.test.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * prompt-tdd.test.ts — Unit tests for TDD instruction injection in agent prompts.\n3:  *\n4:  * Coverage:\n5:  *   - generatePrompt includes TDD section when tdd.enabled is true\n6:  *   - generatePrompt omits TDD section when tdd.enabled is false\n7:  *   - TDD section includes red-green-refactor workflow\n8:  *   - TDD section uses configured test command\n9:  *   - TDD section includes rules about test-first development\n10:  *   - Non-testable items (config, docs) are not blocked by TDD\n11:  */\n12: \n13: import { describe, test, expect } from \"bun:test\";\n14: \n15: import { generatePrompt } from \"../src/lib/prompt.js\";\n16: import { DEFAULT_CONFIG, type WomboConfig, type TddConfig } from \"../src/config.js\";\n17: import type { Feature } from \"../src/lib/tasks.js\";\n18: \n19: // ---------------------------------------------------------------------------\n20: // Helpers\n21: // ---------------------------------------------------------------------------\n22: \n23: /** Create a minimal feature for prompt generation. */\n24: function makeFeature(overrides: Partial<Feature> = {}): Feature {\n25:   return {\n26:     id: \"test-feature\",\n27:     title: \"Test Feature\",\n28:     description: \"A test feature for TDD prompt tests.\",\n29:     status: \"ready\",\n30:     completion: 0,\n31:     difficulty: \"medium\",\n32:     priority: \"high\",\n33:     depends_on: [],\n34:     effort: \"PT2H\",\n35:     started_at: null,\n36:     ended_at: null,\n37:     constraints: [],\n38:     forbidden: [],\n39:     references: [],\n40:     notes: [],\n41:     subtasks: [],\n42:     ...overrides,\n43:   };\n44: }\n45: \n46: /** Create a config with optional TDD overrides. */\n47: function makeConfig(tddOverrides: Partial<TddConfig> = {}): WomboConfig {\n48:   return {\n49:     ...JSON.parse(JSON.stringify(DEFAULT_CONFIG)),\n50:     tdd: {\n51:       ...DEFAULT_CONFIG.tdd,\n52:       ...tddOverrides,\n53:     },\n54:   };\n55: }\n56: \n57: // ---------------------------------------------------------------------------\n58: // TDD Section Injection\n59: // ---------------------------------------------------------------------------\n60: \n61: describe(\"generatePrompt — TDD instructions\", () => {\n62:   test(\"includes TDD section when tdd.enabled is true\", () => {\n63:     const config = makeConfig({ enabled: true, testCommand: \"bun test\" });\n64:     const prompt = generatePrompt(makeFeature(), \"main\", config);\n65:     expect(prompt).toContain(\"Test-Driven Development (TDD)\");\n66:   });\n67: \n68:   test(\"omits TDD section when tdd.enabled is false\", () => {\n69:     const config = makeConfig({ enabled: false });\n70:     const prompt = generatePrompt(makeFeature(), \"main\", config);\n71:     expect(prompt).not.toContain(\"Test-Driven Development (TDD)\");\n72:   });\n73: \n74:   test(\"includes red-green-refactor workflow\", () => {\n75:     const config = makeConfig({ enabled: true, testCommand: \"bun test\" });\n76:     const prompt = generatePrompt(makeFeature(), \"main\", config);\n77:     expect(prompt).toContain(\"Red\");\n78:     expect(prompt).toContain(\"Green\");\n79:     expect(prompt).toContain(\"Refactor\");\n80:   });\n81: \n82:   test(\"uses configured test command in instructions\", () => {\n83:     const config = makeConfig({ enabled: true, testCommand: \"npm test\" });\n84:     const prompt = generatePrompt(makeFeature(), \"main\", config);\n85:     expect(prompt).toContain(\"npm test\");\n86:   });\n87: \n88:   test(\"uses default bun test command when not specified\", () => {\n89:     const config = makeConfig({ enabled: true, testCommand: \"bun test\" });\n90:     const prompt = generatePrompt(makeFeature(), \"main\", config);\n91:     expect(prompt).toContain(\"bun test\");\n92:   });\n93: \n94:   test(\"includes rule about writing failing tests first\", () => {\n95:     const config = makeConfig({ enabled: true, testCommand: \"bun test\" });\n96:     const prompt = generatePrompt(makeFeature(), \"main\", config);\n97:     expect(prompt).toContain(\"failing test\");\n98:   });\n99: \n100:   test(\"includes rule about never skipping the red step\", () => {\n101:     const config = makeConfig({ enabled: true, testCommand: \"bun test\" });\n102:     const prompt = generatePrompt(makeFeature(), \"main\", config);\n103:     expect(prompt).toContain(\"Never skip the red step\");\n104:   });\n105: \n106:   test(\"includes instruction to commit at green\", () => {\n107:     const config = makeConfig({ enabled: true, testCommand: \"bun test\" });\n108:     const prompt = generatePrompt(makeFeature(), \"main\", config);\n109:     expect(prompt).toContain(\"Commit at green\");\n110:   });\n111: \n112:   test(\"includes instruction about running tests frequently\", () => {\n113:     const config = makeConfig({ enabled: true, testCommand: \"bun test\" });\n114:     const prompt = generatePrompt(makeFeature(), \"main\", config);\n115:     expect(prompt).toContain(\"Run tests frequently\");\n116:   });\n117: \n118:   test(\"includes bun:test import instructions\", () => {\n119:     const config = makeConfig({ enabled: true, testCommand: \"bun test\" });\n120:     const prompt = generatePrompt(makeFeature(), \"main\", config);\n121:     expect(prompt).toContain(\"bun:test\");\n122:   });\n123: \n124:   test(\"includes test file placement guidance\", () => {\n125:     const config = makeConfig({ enabled: true, testCommand: \"bun test\" });\n126:     const prompt = generatePrompt(makeFeature(), \"main\", config);\n127:     expect(prompt).toContain(\".test.ts\");\n128:   });\n129: \n130:   test(\"TDD section is placed before commit guidelines\", () => {\n131:     const config = makeConfig({ enabled: true, testCommand: \"bun test\" });\n132:     const prompt = generatePrompt(makeFeature(), \"main\", config);\n133:     const tddIndex = prompt.indexOf(\"Test-Driven Development\");\n134:     const commitIndex = prompt.indexOf(\"Commit Guidelines\");\n135:     expect(tddIndex).toBeGreaterThan(-1);\n136:     expect(commitIndex).toBeGreaterThan(-1);\n137:     expect(tddIndex).toBeLessThan(commitIndex);\n138:   });\n139: });\n140: \n141: // ---------------------------------------------------------------------------\n142: // Prompt structure with TDD enabled\n143: // ---------------------------------------------------------------------------\n144: \n145: describe(\"generatePrompt — overall structure with TDD\", () => {\n146:   test(\"always includes build verification section\", () => {\n147:     const config = makeConfig({ enabled: true, testCommand: \"bun test\" });\n148:     const prompt = generatePrompt(makeFeature(), \"main\", config);\n149:     expect(prompt).toContain(\"Build Verification\");\n150:   });\n151: \n152:   test(\"always includes commit guidelines\", () => {\n153:     const config = makeConfig({ enabled: true, testCommand: \"bun test\" });\n154:     const prompt = generatePrompt(makeFeature(), \"main\", config);\n155:     expect(prompt).toContain(\"Commit Guidelines\");\n156:   });\n157: \n158:   test(\"always includes execution section\", () => {\n159:     const config = makeConfig({ enabled: true, testCommand: \"bun test\" });\n160:     const prompt = generatePrompt(makeFeature(), \"main\", config);\n161:     expect(prompt).toContain(\"Execution\");\n162:   });\n163: \n164:   test(\"includes feature description\", () => {\n165:     const feature = makeFeature({ description: \"Unique test description xyz\" });\n166:     const config = makeConfig({ enabled: true, testCommand: \"bun test\" });\n167:     const prompt = generatePrompt(feature, \"main\", config);\n168:     expect(prompt).toContain(\"Unique test description xyz\");\n169:   });\n170: \n171:   test(\"includes constraints when present\", () => {\n172:     const feature = makeFeature({\n173:       constraints: [\"Must not break existing tests\"],\n174:     });\n175:     const config = makeConfig({ enabled: true, testCommand: \"bun test\" });\n176:     const prompt = generatePrompt(feature, \"main\", config);\n177:     expect(prompt).toContain(\"Must not break existing tests\");\n178:   });\n179: \n180:   test(\"includes forbidden items when present\", () => {\n181:     const feature = makeFeature({\n182:       forbidden: [\"Do not make TDD mandatory for config files\"],\n183:     });\n184:     const config = makeConfig({ enabled: true, testCommand: \"bun test\" });\n185:     const prompt = generatePrompt(feature, \"main\", config);\n186:     expect(prompt).toContain(\"Do not make TDD mandatory for config files\");\n187:   });\n188: });\n189: \n190: // ---------------------------------------------------------------------------\n191: // Non-testable items are not blocked\n192: // ---------------------------------------------------------------------------\n193: \n194: describe(\"generatePrompt — non-testable items handling\", () => {\n195:   test(\"prompt does not force tests for config-only tasks\", () => {\n196:     const feature = makeFeature({\n197:       id: \"config-update\",\n198:       title: \"Update Config\",\n199:       description: \"Update config.json with new defaults\",\n200:     });\n201:     const config = makeConfig({ enabled: true, testCommand: \"bun test\" });\n202:     const prompt = generatePrompt(feature, \"main\", config);\n203:     // The prompt includes TDD instructions but does not say \"you must write tests for config files\"\n204:     // It says \"Place tests next to source\" which is a general guideline\n205:     expect(prompt).toContain(\"Test-Driven Development\");\n206:     // Does NOT contain anything that would prevent config-only changes\n207:     expect(prompt).not.toContain(\"must write tests for every file\");\n208:   });\n209: \n210:   test(\"prompt does not force tests for documentation tasks\", () => {\n211:     const feature = makeFeature({\n212:       id: \"docs-update\",\n213:       title: \"Update Documentation\",\n214:       description: \"Update README and AGENTS.md\",\n215:     });\n216:     const config = makeConfig({ enabled: true, testCommand: \"bun test\" });\n217:     const prompt = generatePrompt(feature, \"main\", config);\n218:     // TDD instructions are included but they're general guidelines\n219:     expect(prompt).toContain(\"Test-Driven Development\");\n220:     // No blocking requirement for docs\n221:     expect(prompt).not.toContain(\"must write tests for every file\");\n222:   });\n223: });\n\n(End of file - total 223 lines)\n</content>","title":"tests/prompt-tdd.test.ts","metadata":{"preview":"/**\n * prompt-tdd.test.ts — Unit tests for TDD instruction injection in agent prompts.\n *\n * Coverage:\n *   - generatePrompt includes TDD section when tdd.enabled is true\n *   - generatePrompt omits TDD section when tdd.enabled is false\n *   - TDD section includes red-green-refactor workflow\n *   - TDD section uses configured test command\n *   - TDD section includes rules about test-first development\n *   - Non-testable items (config, docs) are not blocked by TDD\n */\n\nimport { describe, test, expect } from \"bun:test\";\n\nimport { generatePrompt } from \"../src/lib/prompt.js\";\nimport { DEFAULT_CONFIG, type WomboConfig, type TddConfig } from \"../src/config.js\";\nimport type { Feature } from \"../src/lib/tasks.js\";\n\n// ---------------------------------------------------------------------------\n// Helpers","truncated":false,"loaded":[]},"time":{"start":1773445466804,"end":1773445466811}}}}
