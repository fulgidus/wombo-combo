{"type":"tool_use","timestamp":1773445418857,"sessionID":"ses_316701812ffeYe5yCqGzB5GjN6","part":{"id":"prt_ce99515ff001p1eOowWLQhbX3u","sessionID":"ses_316701812ffeYe5yCqGzB5GjN6","messageID":"msg_ce9950ba3001jlgiCdhlH0qmzB","type":"tool","callID":"toolu_vrtx_01Bh2gh878cTWzbfGQDRyX7k","tool":"write","state":{"status":"completed","input":{"content":"/**\n * prompt-tdd.test.ts — Unit tests for TDD instruction injection in agent prompts.\n *\n * Coverage:\n *   - generatePrompt includes TDD section when tdd.enabled is true\n *   - generatePrompt omits TDD section when tdd.enabled is false\n *   - TDD section includes red-green-refactor workflow\n *   - TDD section uses configured test command\n *   - TDD section includes rules about test-first development\n *   - Non-testable items (config, docs) are not blocked by TDD\n */\n\nimport { describe, test, expect } from \"bun:test\";\n\nimport { generatePrompt } from \"../src/lib/prompt.js\";\nimport { DEFAULT_CONFIG, type WomboConfig, type TddConfig } from \"../src/config.js\";\nimport type { Feature } from \"../src/lib/tasks.js\";\n\n// ---------------------------------------------------------------------------\n// Helpers\n// ---------------------------------------------------------------------------\n\n/** Create a minimal feature for prompt generation. */\nfunction makeFeature(overrides: Partial<Feature> = {}): Feature {\n  return {\n    id: \"test-feature\",\n    title: \"Test Feature\",\n    description: \"A test feature for TDD prompt tests.\",\n    status: \"ready\",\n    completion: 0,\n    difficulty: \"medium\",\n    priority: \"high\",\n    depends_on: [],\n    effort: \"PT2H\",\n    started_at: null,\n    ended_at: null,\n    constraints: [],\n    forbidden: [],\n    references: [],\n    notes: [],\n    subtasks: [],\n    ...overrides,\n  };\n}\n\n/** Create a config with optional TDD overrides. */\nfunction makeConfig(tddOverrides: Partial<TddConfig> = {}): WomboConfig {\n  return {\n    ...JSON.parse(JSON.stringify(DEFAULT_CONFIG)),\n    tdd: {\n      ...DEFAULT_CONFIG.tdd,\n      ...tddOverrides,\n    },\n  };\n}\n\n// ---------------------------------------------------------------------------\n// TDD Section Injection\n// ---------------------------------------------------------------------------\n\ndescribe(\"generatePrompt — TDD instructions\", () => {\n  test(\"includes TDD section when tdd.enabled is true\", () => {\n    const config = makeConfig({ enabled: true, testCommand: \"bun test\" });\n    const prompt = generatePrompt(makeFeature(), \"main\", config);\n    expect(prompt).toContain(\"Test-Driven Development (TDD)\");\n  });\n\n  test(\"omits TDD section when tdd.enabled is false\", () => {\n    const config = makeConfig({ enabled: false });\n    const prompt = generatePrompt(makeFeature(), \"main\", config);\n    expect(prompt).not.toContain(\"Test-Driven Development (TDD)\");\n  });\n\n  test(\"includes red-green-refactor workflow\", () => {\n    const config = makeConfig({ enabled: true, testCommand: \"bun test\" });\n    const prompt = generatePrompt(makeFeature(), \"main\", config);\n    expect(prompt).toContain(\"Red\");\n    expect(prompt).toContain(\"Green\");\n    expect(prompt).toContain(\"Refactor\");\n  });\n\n  test(\"uses configured test command in instructions\", () => {\n    const config = makeConfig({ enabled: true, testCommand: \"npm test\" });\n    const prompt = generatePrompt(makeFeature(), \"main\", config);\n    expect(prompt).toContain(\"npm test\");\n  });\n\n  test(\"uses default bun test command when not specified\", () => {\n    const config = makeConfig({ enabled: true, testCommand: \"bun test\" });\n    const prompt = generatePrompt(makeFeature(), \"main\", config);\n    expect(prompt).toContain(\"bun test\");\n  });\n\n  test(\"includes rule about writing failing tests first\", () => {\n    const config = makeConfig({ enabled: true, testCommand: \"bun test\" });\n    const prompt = generatePrompt(makeFeature(), \"main\", config);\n    expect(prompt).toContain(\"failing test\");\n  });\n\n  test(\"includes rule about never skipping the red step\", () => {\n    const config = makeConfig({ enabled: true, testCommand: \"bun test\" });\n    const prompt = generatePrompt(makeFeature(), \"main\", config);\n    expect(prompt).toContain(\"Never skip the red step\");\n  });\n\n  test(\"includes instruction to commit at green\", () => {\n    const config = makeConfig({ enabled: true, testCommand: \"bun test\" });\n    const prompt = generatePrompt(makeFeature(), \"main\", config);\n    expect(prompt).toContain(\"Commit at green\");\n  });\n\n  test(\"includes instruction about running tests frequently\", () => {\n    const config = makeConfig({ enabled: true, testCommand: \"bun test\" });\n    const prompt = generatePrompt(makeFeature(), \"main\", config);\n    expect(prompt).toContain(\"Run tests frequently\");\n  });\n\n  test(\"includes bun:test import instructions\", () => {\n    const config = makeConfig({ enabled: true, testCommand: \"bun test\" });\n    const prompt = generatePrompt(makeFeature(), \"main\", config);\n    expect(prompt).toContain(\"bun:test\");\n  });\n\n  test(\"includes test file placement guidance\", () => {\n    const config = makeConfig({ enabled: true, testCommand: \"bun test\" });\n    const prompt = generatePrompt(makeFeature(), \"main\", config);\n    expect(prompt).toContain(\".test.ts\");\n  });\n\n  test(\"TDD section is placed before commit guidelines\", () => {\n    const config = makeConfig({ enabled: true, testCommand: \"bun test\" });\n    const prompt = generatePrompt(makeFeature(), \"main\", config);\n    const tddIndex = prompt.indexOf(\"Test-Driven Development\");\n    const commitIndex = prompt.indexOf(\"Commit Guidelines\");\n    expect(tddIndex).toBeGreaterThan(-1);\n    expect(commitIndex).toBeGreaterThan(-1);\n    expect(tddIndex).toBeLessThan(commitIndex);\n  });\n});\n\n// ---------------------------------------------------------------------------\n// Prompt structure with TDD enabled\n// ---------------------------------------------------------------------------\n\ndescribe(\"generatePrompt — overall structure with TDD\", () => {\n  test(\"always includes build verification section\", () => {\n    const config = makeConfig({ enabled: true, testCommand: \"bun test\" });\n    const prompt = generatePrompt(makeFeature(), \"main\", config);\n    expect(prompt).toContain(\"Build Verification\");\n  });\n\n  test(\"always includes commit guidelines\", () => {\n    const config = makeConfig({ enabled: true, testCommand: \"bun test\" });\n    const prompt = generatePrompt(makeFeature(), \"main\", config);\n    expect(prompt).toContain(\"Commit Guidelines\");\n  });\n\n  test(\"always includes execution section\", () => {\n    const config = makeConfig({ enabled: true, testCommand: \"bun test\" });\n    const prompt = generatePrompt(makeFeature(), \"main\", config);\n    expect(prompt).toContain(\"Execution\");\n  });\n\n  test(\"includes feature description\", () => {\n    const feature = makeFeature({ description: \"Unique test description xyz\" });\n    const config = makeConfig({ enabled: true, testCommand: \"bun test\" });\n    const prompt = generatePrompt(feature, \"main\", config);\n    expect(prompt).toContain(\"Unique test description xyz\");\n  });\n\n  test(\"includes constraints when present\", () => {\n    const feature = makeFeature({\n      constraints: [\"Must not break existing tests\"],\n    });\n    const config = makeConfig({ enabled: true, testCommand: \"bun test\" });\n    const prompt = generatePrompt(feature, \"main\", config);\n    expect(prompt).toContain(\"Must not break existing tests\");\n  });\n\n  test(\"includes forbidden items when present\", () => {\n    const feature = makeFeature({\n      forbidden: [\"Do not make TDD mandatory for config files\"],\n    });\n    const config = makeConfig({ enabled: true, testCommand: \"bun test\" });\n    const prompt = generatePrompt(feature, \"main\", config);\n    expect(prompt).toContain(\"Do not make TDD mandatory for config files\");\n  });\n});\n\n// ---------------------------------------------------------------------------\n// Non-testable items are not blocked\n// ---------------------------------------------------------------------------\n\ndescribe(\"generatePrompt — non-testable items handling\", () => {\n  test(\"prompt does not force tests for config-only tasks\", () => {\n    const feature = makeFeature({\n      id: \"config-update\",\n      title: \"Update Config\",\n      description: \"Update config.json with new defaults\",\n    });\n    const config = makeConfig({ enabled: true, testCommand: \"bun test\" });\n    const prompt = generatePrompt(feature, \"main\", config);\n    // The prompt includes TDD instructions but does not say \"you must write tests for config files\"\n    // It says \"Place tests next to source\" which is a general guideline\n    expect(prompt).toContain(\"Test-Driven Development\");\n    // Does NOT contain anything that would prevent config-only changes\n    expect(prompt).not.toContain(\"must write tests for every file\");\n  });\n\n  test(\"prompt does not force tests for documentation tasks\", () => {\n    const feature = makeFeature({\n      id: \"docs-update\",\n      title: \"Update Documentation\",\n      description: \"Update README and AGENTS.md\",\n    });\n    const config = makeConfig({ enabled: true, testCommand: \"bun test\" });\n    const prompt = generatePrompt(feature, \"main\", config);\n    // TDD instructions are included but they're general guidelines\n    expect(prompt).toContain(\"Test-Driven Development\");\n    // No blocking requirement for docs\n    expect(prompt).not.toContain(\"must write tests for every file\");\n  });\n});\n","filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/tdd-red-green-coercion/tests/prompt-tdd.test.ts"},"output":"Wrote file successfully.\n\nLSP errors detected in other files:\n<diagnostics file=\"/home