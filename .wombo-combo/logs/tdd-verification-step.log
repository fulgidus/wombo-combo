{"type":"tool_use","timestamp":1773436121539,"sessionID":"ses_316fcb79fffeLVMPL0QpkiSz53","part":{"id":"prt_ce907ae28001IIdhwuPUiVHHDB","sessionID":"ses_316fcb79fffeLVMPL0QpkiSz53","messageID":"msg_ce907a582001kRWR42cuRZT4nL","type":"tool","callID":"toolu_vrtx_01678LKu4Yfh8exvj7Ae5nQC","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-tdd-verification-step/src/lib/test-runner.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-tdd-verification-step/src/lib/test-runner.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * test-runner.ts — Run test commands and capture results.\n3:  *\n4:  * Responsibilities:\n5:  *   - Run the configured test command (e.g. `bun test`) in a worktree\n6:  *   - Capture exit code, stdout, stderr\n7:  *   - Parse test output to extract pass/fail counts\n8:  *   - Produce structured TestRunResult for the TDD verification pipeline\n9:  *\n10:  * This module is used by tdd-verifier.ts as part of the TDD verification step.\n11:  */\n12: \n13: import { exec } from \"node:child_process\";\n14: \n15: // ---------------------------------------------------------------------------\n16: // Types\n17: // ---------------------------------------------------------------------------\n18: \n19: /** Result of running the test command */\n20: export interface TestRunResult {\n21:   /** Whether the test command exited successfully (exit code 0) */\n22:   passed: boolean;\n23:   /** Process exit code */\n24:   exitCode: number;\n25:   /** Standard output */\n26:   stdout: string;\n27:   /** Standard error */\n28:   stderr: string;\n29:   /** Duration in milliseconds */\n30:   durationMs: number;\n31:   /** Parsed test counts (best-effort extraction from output) */\n32:   testCounts: TestCounts;\n33:   /** Error summary for retry prompts (empty if passed) */\n34:   errorSummary: string;\n35: }\n36: \n37: /** Parsed test pass/fail counts from test runner output */\n38: export interface TestCounts {\n39:   /** Total number of tests detected */\n40:   total: number;\n41:   /** Number of passing tests */\n42:   passed: number;\n43:   /** Number of failing tests */\n44:   failed: number;\n45:   /** Number of skipped tests */\n46:   skipped: number;\n47:   /** Whether counts could be parsed from output */\n48:   parsed: boolean;\n49: }\n50: \n51: // ---------------------------------------------------------------------------\n52: // Test Runner\n53: // ---------------------------------------------------------------------------\n54: \n55: /**\n56:  * Run the test command in a worktree directory.\n57:  *\n58:  * @param worktreePath - Absolute path to the worktree\n59:  * @param testCommand - Test command to run (e.g., \"bun test\")\n60:  * @param timeout - Timeout in milliseconds (default: 120_000)\n61:  * @returns Structured test run result\n62:  */\n63: export function runTests(\n64:   worktreePath: string,\n65:   testCommand: string,\n66:   timeout: number = 120_000\n67: ): Promise<TestRunResult> {\n68:   return new Promise((resolvePromise) => {\n69:     const start = Date.now();\n70: \n71:     exec(\n72:       testCommand,\n73:       {\n74:         cwd: worktreePath,\n75:         encoding: \"utf-8\",\n76:         timeout,\n77:         maxBuffer: 10 * 1024 * 1024,\n78:       },\n79:       (error, stdout, stderr) => {\n80:         const durationMs = Date.now() - start;\n81:         const exitCode = error ? (error as any).code ?? 1 : 0;\n82:         const passed = !error;\n83: \n84:         const testCounts = parseTestCounts(stdout ?? \"\", stderr ?? \"\");\n85: \n86:         let errorSummary = \"\";\n87:         if (!passed) {\n88:           errorSummary = extractTestErrorSummary(stdout ?? \"\", stderr ?? \"\");\n89:         }\n90: \n91:         resolvePromise({\n92:           passed,\n93:           exitCode,\n94:           stdout: stdout ?? \"\",\n95:           stderr: stderr ?? \"\",\n96:           durationMs,\n97:           testCounts,\n98:           errorSummary,\n99:         });\n100:       }\n101:     );\n102:   });\n103: }\n104: \n105: // ---------------------------------------------------------------------------\n106: // Output Parsing\n107: // ---------------------------------------------------------------------------\n108: \n109: /**\n110:  * Parse test counts from test runner output.\n111:  *\n112:  * Supports common formats:\n113:  *   - Bun test: \"42 pass, 3 fail, 2 skip\" or \"X pass\\nY fail\"\n114:  *   - Generic: \"Tests: X passed, Y failed, Z skipped, W total\"\n115:  *   - Jest-like: \"Tests:  X passed, Y failed, Z total\"\n116:  */\n117: export function parseTestCounts(stdout: string, stderr: string): TestCounts {\n118:   const combined = stdout + \"\\n\" + stderr;\n119:   const result: TestCounts = {\n120:     total: 0,\n121:     passed: 0,\n122:     failed: 0,\n123:     skipped: 0,\n124:     parsed: false,\n125:   };\n126: \n127:   // Bun test format: \"42 pass\" and \"3 fail\" on separate or same lines\n128:   const bunPassMatch = combined.match(/(\\d+)\\s+pass/i);\n129:   const bunFailMatch = combined.match(/(\\d+)\\s+fail/i);\n130:   const bunSkipMatch = combined.match(/(\\d+)\\s+skip/i);\n131: \n132:   if (bunPassMatch || bunFailMatch) {\n133:     result.passed = bunPassMatch ? parseInt(bunPassMatch[1], 10) : 0;\n134:     result.failed = bunFailMatch ? parseInt(bunFailMatch[1], 10) : 0;\n135:     result.skipped = bunSkipMatch ? parseInt(bunSkipMatch[1], 10) : 0;\n136:     result.total = result.passed + result.failed + result.skipped;\n137:     result.parsed = true;\n138:     return result;\n139:   }\n140: \n141:   // Jest-like format: \"Tests:  X passed, Y failed, Z total\"\n142:   const jestMatch = combined.match(\n143:     /Tests:\\s+(\\d+)\\s+passed(?:,\\s+(\\d+)\\s+failed)?(?:,\\s+(\\d+)\\s+skipped)?(?:,\\s+(\\d+)\\s+total)?/i\n144:   );\n145:   if (jestMatch) {\n146:     result.passed = parseInt(jestMatch[1], 10);\n147:     result.failed = jestMatch[2] ? parseInt(jestMatch[2], 10) : 0;\n148:     result.skipped = jestMatch[3] ? parseInt(jestMatch[3], 10) : 0;\n149:     result.total = jestMatch[4]\n150:       ? parseInt(jestMatch[4], 10)\n151:       : result.passed + result.failed + result.skipped;\n152:     result.parsed = true;\n153:     return result;\n154:   }\n155: \n156:   return result;\n157: }\n158: \n159: /**\n160:  * Extract a concise error summary from test output.\n161:  * Used for retry prompts when tests fail.\n162:  */\n163: export function extractTestErrorSummary(\n164:   stdout: string,\n165:   stderr: string\n166: ): string {\n167:   const combined = stdout + \"\\n\" + stderr;\n168:   const lines = combined.split(\"\\n\");\n169: \n170:   const errorLines: string[] = [];\n171:   let capturing = false;\n172:   let contextLines = 0;\n173: \n174:   for (const line of lines) {\n175:     const isError =\n176:       /(?:error|fail|FAIL|Error|AssertionError|expect\\()/i.test(line) &&\n177:       !/warning/i.test(line);\n178: \n179:     if (isError) {\n180:       capturing = true;\n181:       contextLines = 0;\n182:       errorLines.push(line);\n183:     } else if (capturing) {\n184:       contextLines++;\n185:       if (contextLines <= 5) {\n186:         errorLines.push(line);\n187:       } else {\n188:         capturing = false;\n189:       }\n190:     }\n191:   }\n192: \n193:   if (errorLines.length === 0) {\n194:     // Fall back to last 30 lines\n195:     const tail = lines.slice(-30).join(\"\\n\");\n196:     return truncate(tail, 3000);\n197:   }\n198: \n199:   return truncate(errorLines.join(\"\\n\"), 3000);\n200: }\n201: \n202: /**\n203:  * Truncate a string to maxLen characters.\n204:  */\n205: function truncate(s: string, maxLen: number): string {\n206:   if (s.length <= maxLen) return s;\n207:   return s.slice(0, maxLen) + \"\\n\\n[... truncated]\";\n208: }\n\n(End of file - total 208 lines)\n</content>","title":"src/lib/test-runner.ts","metadata":{"preview":"/**\n * test-runner.ts — Run test commands and capture results.\n *\n * Responsibilities:\n *   - Run the configured test command (e.g. `bun test`) in a worktree\n *   - Capture exit code, stdout, stderr\n *   - Parse test output to extract pass/fail counts\n *   - Produce structured TestRunResult for the TDD verification pipeline\n *\n * This module is used by tdd-verifier.ts as part of the TDD verification step.\n */\n\nimport { exec } from \"node:child_process\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\n/** Result of running the test command */\nexport interface TestRunResult {","truncated":false,"loaded":[]},"time":{"start":1773436121537,"end":1773436121538}}}}
