{"type":"tool_use","timestamp":1773435840128,"sessionID":"ses_316fcb79fffeLVMPL0QpkiSz53","part":{"id":"prt_ce90364d8001PRLOdVbNeTWBZd","sessionID":"ses_316fcb79fffeLVMPL0QpkiSz53","messageID":"msg_ce9035be7001ZXIEROed8hAc7C","type":"tool","callID":"toolu_vrtx_018AGANoyePfZdpxwSj3jBTg","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-tdd-verification-step/src/lib/verifier.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-tdd-verification-step/src/lib/verifier.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * verifier.ts — Build verification in worktrees.\n3:  *\n4:  * Responsibilities:\n5:  *   - Run the project build command in a worktree\n6:  *   - Capture and parse build output\n7:  *   - Determine pass/fail\n8:  *   - Extract error messages for retry prompts\n9:  *   - Run browser-based verification when enabled\n10:  *\n11:  * IMPORTANT: runBuild is ASYNC — does not block the event loop.\n12:  */\n13: \n14: import { exec } from \"node:child_process\";\n15: import { existsSync } from \"node:fs\";\n16: import { resolve } from \"node:path\";\n17: import type { WomboConfig } from \"../config.js\";\n18: import {\n19:   runBrowserVerification,\n20:   extractBrowserErrorSummary,\n21:   type BrowserVerificationResult,\n22: } from \"./browser-verifier.js\";\n23: \n24: // ---------------------------------------------------------------------------\n25: // Types\n26: // ---------------------------------------------------------------------------\n27: \n28: export interface BuildResult {\n29:   passed: boolean;\n30:   exitCode: number;\n31:   stdout: string;\n32:   stderr: string;\n33:   /** Combined output, truncated for use in retry prompts */\n34:   errorSummary: string;\n35:   /** Duration in milliseconds */\n36:   durationMs: number;\n37: }\n38: \n39: /**\n40:  * Combined result of build verification + browser verification.\n41:  */\n42: export interface FullVerificationResult {\n43:   /** Build result (always runs) */\n44:   build: BuildResult;\n45:   /** Browser verification result (may be skipped) */\n46:   browser: BrowserVerificationResult;\n47:   /** Overall pass: build passed AND browser passed (or was skipped) */\n48:   overallPassed: boolean;\n49:   /** Combined error summary for retry prompts */\n50:   combinedErrorSummary: string;\n51: }\n52: \n53: // ---------------------------------------------------------------------------\n54: // Build Verification\n55: // ---------------------------------------------------------------------------\n56: \n57: /**\n58:  * Run the build command in a worktree directory.\n59:  * Uses config for the build command and timeout.\n60:  */\n61: export function runBuild(\n62:   worktreePath: string,\n63:   config: WomboConfig\n64: ): Promise<BuildResult> {\n65:   return new Promise((resolvePromise) => {\n66:     const start = Date.now();\n67: \n68:     exec(\n69:       config.build.command,\n70:       {\n71:         cwd: worktreePath,\n72:         encoding: \"utf-8\",\n73:         timeout: config.build.timeout,\n74:         maxBuffer: 10 * 1024 * 1024,\n75:       },\n76:       (error, stdout, stderr) => {\n77:         const durationMs = Date.now() - start;\n78:         const exitCode = error ? (error as any).code ?? 1 : 0;\n79:         const passed = !error;\n80: \n81:         let errorSummary = \"\";\n82:         if (!passed) {\n83:           errorSummary = extractErrorSummary(stdout ?? \"\", stderr ?? \"\");\n84:         }\n85: \n86:         resolvePromise({\n87:           passed,\n88:           exitCode,\n89:           stdout: stdout ?? \"\",\n90:           stderr: stderr ?? \"\",\n91:           errorSummary,\n92:           durationMs,\n93:         });\n94:       }\n95:     );\n96:   });\n97: }\n98: \n99: // ---------------------------------------------------------------------------\n100: // Error Extraction\n101: // ---------------------------------------------------------------------------\n102: \n103: /**\n104:  * Extract a concise error summary from build output.\n105:  */\n106: function extractErrorSummary(stdout: string, stderr: string): string {\n107:   const combined = stdout + \"\\n\" + stderr;\n108:   const lines = combined.split(\"\\n\");\n109: \n110:   const errorLines: string[] = [];\n111:   let capturing = false;\n112:   let contextLines = 0;\n113: \n114:   for (const line of lines) {\n115:     const isError =\n116:       /error/i.test(line) &&\n117:       !/warning/i.test(line) &&\n118:       !/^info/i.test(line);\n119:     const isTypeError = /TS\\d+/.test(line);\n120: \n121:     if (isError || isTypeError) {\n122:       capturing = true;\n123:       contextLines = 0;\n124:       errorLines.push(line);\n125:     } else if (capturing) {\n126:       contextLines++;\n127:       if (contextLines <= 3) {\n128:         errorLines.push(line);\n129:       } else {\n130:         capturing = false;\n131:       }\n132:     }\n133:   }\n134: \n135:   if (errorLines.length === 0) {\n136:     const tail = lines.slice(-50).join(\"\\n\");\n137:     return truncate(tail, 4000);\n138:   }\n139: \n140:   return truncate(errorLines.join(\"\\n\"), 4000);\n141: }\n142: \n143: /**\n144:  * Truncate a string to maxLen characters.\n145:  */\n146: function truncate(s: string, maxLen: number): string {\n147:   if (s.length <= maxLen) return s;\n148:   return s.slice(0, maxLen) + \"\\n\\n[... truncated, showing first 4000 chars]\";\n149: }\n150: \n151: // ---------------------------------------------------------------------------\n152: // Quick Check\n153: // ---------------------------------------------------------------------------\n154: \n155: /**\n156:  * Quick check if the build artifacts exist.\n157:  */\n158: export function hasBuildArtifacts(\n159:   worktreePath: string,\n160:   config: WomboConfig\n161: ): boolean {\n162:   try {\n163:     return existsSync(resolve(worktreePath, config.build.artifactDir));\n164:   } catch {\n165:     return false;\n166:   }\n167: }\n168: \n169: // ---------------------------------------------------------------------------\n170: // Full Verification (Build + Browser)\n171: // ---------------------------------------------------------------------------\n172: \n173: /**\n174:  * Run the complete verification pipeline:\n175:  *   1. Run the build command\n176:  *   2. If build passes and browser testing is enabled, run browser tests\n177:  *\n178:  * Browser testing is additive — it runs AFTER the build passes and is\n179:  * skipped if the build fails (no point testing a broken build in browser).\n180:  */\n181: export async function runFullVerification(\n182:   worktreePath: string,\n183:   featureId: string,\n184:   config: WomboConfig\n185: ): Promise<FullVerificationResult> {\n186:   // Step 1: Build verification (always runs)\n187:   const buildResult = await runBuild(worktreePath, config);\n188: \n189:   // If build failed, skip browser testing\n190:   if (!buildResult.passed) {\n191:     return {\n192:       build: buildResult,\n193:       browser: {\n194:         ran: false,\n195:         skipReason: \"Skipped because build failed\",\n196:         browserResult: null,\n197:       },\n198:       overallPassed: false,\n199:       combinedErrorSummary: buildResult.errorSummary,\n200:     };\n201:   }\n202: \n203:   // Step 2: Browser verification (runs only if build passed and browser enabled)\n204:   const browserResult = await runBrowserVerification({\n205:     worktreePath,\n206:     featureId,\n207:     config,\n208:   });\n209: \n210:   // Determine overall pass\n211:   const browserPassed = !browserResult.ran || (browserResult.browserResult?.allPassed ?? true);\n212:   const overallPassed = buildResult.passed && browserPassed;\n213: \n214:   // Combine error summaries\n215:   let combinedErrorSummary = \"\";\n216:   if (!buildResult.passed) {\n217:     combinedErrorSummary = buildResult.errorSummary;\n218:   }\n219:   if (browserResult.ran && browserResult.browserResult && !browserResult.browserResult.allPassed) {\n220:     const browserErrors = extractBrowserErrorSummary(browserResult.browserResult);\n221:     combinedErrorSummary = combinedErrorSummary\n222:       ? `${combinedErrorSummary}\\n\\n--- Browser Test Errors ---\\n\\n${browserErrors}`\n223:       : browserErrors;\n224:   }\n225: \n226:   return {\n227:     build: buildResult,\n228:     browser: browserResult,\n229:     overallPassed,\n230:     combinedErrorSummary,\n231:   };\n232: }\n\n(End of file - total 232 lines)\n</content>","title":"src/lib/verifier.ts","metadata":{"preview":"/**\n * verifier.ts — Build verification in worktrees.\n *\n * Responsibilities:\n *   - Run the project build command in a worktree\n *   - Capture and parse build output\n *   - Determine pass/fail\n *   - Extract error messages for retry prompts\n *   - Run browser-based verification when enabled\n *\n * IMPORTANT: runBuild is ASYNC — does not block the event loop.\n */\n\nimport { exec } from \"node:child_process\";\nimport { existsSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\nimport type { WomboConfig } from \"../config.js\";\nimport {\n  runBrowserVerification,\n  extractBrowserErrorSummary,","truncated":false,"loaded":[]},"time":{"start":1773435840104,"end":1773435840126}}}}
{"type":"tool_use","timestamp":1773435840690,"sessionID":"ses_316fcb79fffeLVMPL0QpkiSz53","part":{"id":"prt_ce90366760014wNdYKMKa9Rrzs","sessionID":"ses_316fcb79fffeLVMPL0QpkiSz53","messageID":"msg_ce9035be7001ZXIEROed8hAc7C","type":"tool","callID":"toolu_vrtx_01GJ4cvyPP5NynYEkFFnPxtu","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-tdd-verification-step/src/commands/verify.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-tdd-verification-step/src/commands/verify.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * verify.ts — Run build verification on completed agents.\n3:  *\n4:  * Usage: woco verify [feature-id] [--browser]\n5:  *\n6:  * Runs the build command in each completed agent's worktree. If a specific\n7:  * feature-id is given, verifies only that agent. Otherwise verifies all\n8:  * agents with status \"completed\".\n9:  *\n10:  * When --browser is passed (or browser.enabled is true in config), also\n11:  * runs browser-based verification after the build passes.\n12:  */\n13: \n14: import type { WomboConfig } from \"../config.js\";\n15: import { loadFeatures, type Feature } from \"../lib/tasks.js\";\n16: import { loadState, saveState } from \"../lib/state.js\";\n17: import { printDashboard } from \"../lib/ui.js\";\n18: import { handleBuildVerification } from \"./launch.js\";\n19: \n20: // ---------------------------------------------------------------------------\n21: // Types\n22: // ---------------------------------------------------------------------------\n23: \n24: export interface VerifyCommandOptions {\n25:   projectRoot: string;\n26:   config: WomboConfig;\n27:   featureId?: string;\n28:   model?: string;\n29:   maxRetries?: number;\n30:   /** Enable browser verification (overrides config.browser.enabled) */\n31:   browserVerify?: boolean;\n32: }\n33: \n34: // ---------------------------------------------------------------------------\n35: // Command\n36: // ---------------------------------------------------------------------------\n37: \n38: export async function cmdVerify(opts: VerifyCommandOptions): Promise<void> {\n39:   const { projectRoot, config } = opts;\n40: \n41:   // Apply browser verification override if --browser flag was passed\n42:   if (opts.browserVerify !== undefined) {\n43:     config.browser.enabled = opts.browserVerify;\n44:   }\n45: \n46:   const state = loadState(projectRoot);\n47:   if (!state) {\n48:     console.log(\"No active wave.\");\n49:     return;\n50:   }\n51: \n52:   const toVerify = opts.featureId\n53:     ? state.agents.filter((a) => a.feature_id === opts.featureId)\n54:     : state.agents.filter((a) => a.status === \"completed\");\n55: \n56:   if (toVerify.length === 0) {\n57:     console.log(\"No agents to verify.\");\n58:     return;\n59:   }\n60: \n61:   console.log(`\\nVerifying ${toVerify.length} agent(s)...\\n`);\n62: \n63:   const data = loadFeatures(projectRoot, config);\n64: \n65:   for (const agent of toVerify) {\n66:     const feature = data.tasks.find((f: Feature) => f.id === agent.feature_id);\n67:     if (!feature) continue;\n68: \n69:     await handleBuildVerification(projectRoot, state, agent, feature, config, opts.model);\n70:   }\n71: \n72:   printDashboard(state);\n73: }\n\n(End of file - total 73 lines)\n</content>","title":"src/commands/verify.ts","metadata":{"preview":"/**\n * verify.ts — Run build verification on completed agents.\n *\n * Usage: woco verify [feature-id] [--browser]\n *\n * Runs the build command in each completed agent's worktree. If a specific\n * feature-id is given, verifies only that agent. Otherwise verifies all\n * agents with status \"completed\".\n *\n * When --browser is passed (or browser.enabled is true in config), also\n * runs browser-based verification after the build passes.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport { loadFeatures, type Feature } from \"../lib/tasks.js\";\nimport { loadState, saveState } from \"../lib/state.js\";\nimport { printDashboard } from \"../lib/ui.js\";\nimport { handleBuildVerification } from \"./launch.js\";\n\n// ---------------------------------------------------------------------------","truncated":false,"loaded":[]},"time":{"start":1773435840683,"end":1773435840688}}}}
{"type":"tool_use","timestamp":1773435841089,"sessionID":"ses_316fcb79fffeLVMPL0QpkiSz53","part":{"id":"prt_ce90368ad001XsfIYfFfm3timh","sessionID":"ses_316fcb79fffeLVMPL0QpkiSz53","messageID":"msg_ce9035be7001ZXIEROed8hAc7C","type":"tool","callID":"toolu_vrtx_011AFhg6jX42L1oCcvUm53xg","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-tdd-verification-step/src/config.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-tdd-verification-step/src/config.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * config.ts — Load .wombo-combo/config.json, merge with defaults, validate, expose typed config.\n3:  *\n4:  * The config file lives at .wombo-combo/config.json inside the target project root.\n5:  * All values have sensible defaults so minimal config works out of the box.\n6:  */\n7: \n8: import { readFileSync, existsSync } from \"node:fs\";\n9: import { resolve } from \"node:path\";\n10: import type { MultiplexerPreference } from \"./lib/multiplexer.js\";\n11: \n12: // ---------------------------------------------------------------------------\n13: // .wombo-combo directory constant\n14: // ---------------------------------------------------------------------------\n15: \n16: /** Name of the directory that holds all wombo-combo files */\n17: export const WOMBO_DIR = \".wombo-combo\";\n18: \n19: // ---------------------------------------------------------------------------\n20: // Types\n21: // ---------------------------------------------------------------------------\n22: \n23: /** Agent registry download mode */\n24: export type AgentRegistryMode = \"auto\" | \"monitored\" | \"disabled\";\n25: \n26: export interface WomboConfig {\n27:   /** Directory name for task files relative to .wombo-combo/ (folder-based storage) */\n28:   tasksDir: string;\n29:   /** Directory name for archived task files relative to .wombo-combo/ */\n30:   archiveDir: string;\n31:   /** @deprecated Use tasksDir. Legacy single-file path relative to .wombo-combo/ */\n32:   tasksFile?: string;\n33:   /** @deprecated Use archiveDir. Legacy single-file path relative to .wombo-combo/ */\n34:   archiveFile?: string;\n35:   /** Base branch to create feature branches from */\n36:   baseBranch: string;\n37:   /** Build configuration */\n38:   build: {\n39:     /** Build command to run in worktrees */\n40:     command: string;\n41:     /** Build timeout in milliseconds */\n42:     timeout: number;\n43:     /** Build artifact directory (for quick \"did it build?\" checks) */\n44:     artifactDir: string;\n45:   };\n46:   /** Install configuration */\n47:   install: {\n48:     /** Install command to run in worktrees */\n49:     command: string;\n50:     /** Install timeout in milliseconds */\n51:     timeout: number;\n52:   };\n53:   /** Git configuration */\n54:   git: {\n55:     /** Branch name prefix for feature branches */\n56:     branchPrefix: string;\n57:     /** Worktree directory name prefix */\n58:     worktreePrefix: string;\n59:     /** Git remote name */\n60:     remote: string;\n61:     /** Merge strategy flag */\n62:     mergeStrategy: string;\n63:   };\n64:   /** Agent configuration */\n65:   agent: {\n66:     /** Path to agent binary (null = auto-detect) */\n67:     bin: string | null;\n68:     /** Agent name to pass via --agent flag */\n69:     name: string;\n70:     /** Config files/dirs to copy into worktrees */\n71:     configFiles: string[];\n72:     /** Session name prefix for terminal multiplexer */\n73:     tmuxPrefix: string;\n74:     /** Terminal multiplexer preference: \"auto\" (prefer dmux), \"dmux\", or \"tmux\" */\n75:     multiplexer: MultiplexerPreference;\n76:   };\n77:   /** Portless integration for localhost server testing */\n78:   portless: {\n79:     /** Whether portless is enabled for agent worktrees */\n80:     enabled: boolean;\n81:     /** Path to portless binary (null = auto-detect via PATH) */\n82:     bin: string | null;\n83:     /** Proxy port (portless default is 1355) */\n84:     proxyPort: number;\n85:     /** Whether to use HTTPS mode */\n86:     https: boolean;\n87:   };\n88:   /** Backup configuration for tasks file */\n89:   backup: {\n90:     /** Maximum number of timestamped backups to keep */\n91:     maxBackups: number;\n92:   };\n93:   /** Default runtime values */\n94:   defaults: {\n95:     /** Max concurrent agents */\n96:     maxConcurrent: number;\n97:     /** Max retries per agent */\n98:     maxRetries: number;\n99:   };\n100:   /** Browser testing configuration */\n101:   browser: BrowserConfig;\n102:   /** Agent registry configuration for specialized agent downloads */\n103:   agentRegistry: AgentRegistryConfig;\n104:   /** Test-Driven Development configuration */\n105:   tdd: TddConfig;\n106: }\n107: \n108: /** Configuration for browser-based verification and testing */\n109: export interface BrowserConfig {\n110:   /** Enable browser testing in the verify pipeline */\n111:   enabled: boolean;\n112:   /** Path to browser binary (null = auto-detect) */\n113:   bin: string | null;\n114:   /** Run browser in headless mode (required for CI) */\n115:   headless: boolean;\n116:   /** Custom test command to run browser tests (overrides script discovery) */\n117:   testCommand: string | null;\n118:   /** Timeout for launching a browser instance (ms) */\n119:   launchTimeout: number;\n120:   /** Timeout for each browser test script (ms) */\n121:   testTimeout: number;\n122:   /** Default viewport size */\n123:   defaultViewport: {\n124:     width: number;\n125:     height: number;\n126:   };\n127: }\n128: \n129: /** Configuration for the external agent registry (e.g. agency-agents) */\n130: export interface AgentRegistryConfig {\n131:   /**\n132:    * Download mode:\n133:    * - \"auto\"      — download agents without asking (default)\n134:    * - \"monitored\" — user reviews/edits/rejects each agent before launch\n135:    * - \"disabled\"  — always use the generalist agent\n136:    */\n137:   mode: AgentRegistryMode;\n138:   /** GitHub repo in \"owner/repo\" format to pull agent definitions from */\n139:   source: string;\n140:   /** Cache directory name (relative to .wombo-combo/) */\n141:   cacheDir: string;\n142:   /** Cache TTL in milliseconds. Cached agents older than this are re-fetched. Default 24h. */\n143:   cacheTTL: number;\n144: }\n145: \n146: /** Configuration for Test-Driven Development workflow */\n147: export interface TddConfig {\n148:   /** Enable TDD red-green-refactor instructions in agent prompts */\n149:   enabled: boolean;\n150:   /** Test command to run (default: \"bun test\") */\n151:   testCommand: string;\n152: }\n153: \n154: // ---------------------------------------------------------------------------\n155: // Defaults\n156: // ---------------------------------------------------------------------------\n157: \n158: export const DEFAULT_CONFIG: WomboConfig = {\n159:   tasksDir: \"tasks\",\n160:   archiveDir: \"archive\",\n161:   baseBranch: \"develop\",\n162:   build: {\n163:     command: \"bun run build\",\n164:     timeout: 300_000,\n165:     artifactDir: \"dist\",\n166:   },\n167:   install: {\n168:     command: \"bun install\",\n169:     timeout: 120_000,\n170:   },\n171:   git: {\n172:     branchPrefix: \"feature/\",\n173:     worktreePrefix: \"wombo-\",\n174:     remote: \"origin\",\n175:     mergeStrategy: \"--no-ff\",\n176:   },\n177:   agent: {\n178:     bin: null,\n179:     name: \"generalist-agent\",\n180:     configFiles: [\".opencode/\", \"opencode.json\", \"AGENTS.md\"],\n181:     tmuxPrefix: \"wombo\",\n182:     multiplexer: \"auto\",\n183:   },\n184:   portless: {\n185:     enabled: true,\n186:     bin: null,\n187:     proxyPort: 1355,\n188:     https: false,\n189:   },\n190:   backup: {\n191:     maxBackups: 5,\n192:   },\n193:   defaults: {\n194:     maxConcurrent: 6,\n195:     maxRetries: 2,\n196:   },\n197:   browser: {\n198:     enabled: false,\n199:     bin: null,\n200:     headless: true,\n201:     testCommand: null,\n202:     launchTimeout: 30_000,\n203:     testTimeout: 60_000,\n204:     defaultViewport: {\n205:       width: 1280,\n206:       height: 720,\n207:     },\n208:   },\n209:   agentRegistry: {\n210:     mode: \"auto\",\n211:     source: \"msitarzewski/agency-agents\",\n212:     cacheDir: \"agents-cache\",\n213:     cacheTTL: 24 * 60 * 60 * 1000, // 24 hours\n214:   },\n215:   tdd: {\n216:     enabled: false,\n217:     testCommand: \"bun test\",\n218:   },\n219: };\n220: \n221: // ---------------------------------------------------------------------------\n222: // Config File Name\n223: // ---------------------------------------------------------------------------\n224: \n225: export const CONFIG_FILE = `${WOMBO_DIR}/config.json`;\n226: \n227: // ---------------------------------------------------------------------------\n228: // Loader\n229: // ---------------------------------------------------------------------------\n230: \n231: /**\n232:  * Deep-merge source into target. Only merges plain objects, not arrays.\n233:  */\n234: function deepMerge<T extends Record<string, any>>(target: T, source: Partial<T>): T {\n235:   const result = { ...target };\n236:   for (const key of Object.keys(source) as (keyof T)[]) {\n237:     const srcVal = source[key];\n238:     const tgtVal = target[key];\n239:     if (\n240:       srcVal !== undefined &&\n241:       srcVal !== null &&\n242:       typeof srcVal === \"object\" &&\n243:       !Array.isArray(srcVal) &&\n244:       typeof tgtVal === \"object\" &&\n245:       !Array.isArray(tgtVal) &&\n246:       tgtVal !== null\n247:     ) {\n248:       result[key] = deepMerge(tgtVal as any, srcVal as any);\n249:     } else if (srcVal !== undefined) {\n250:       result[key] = srcVal as T[keyof T];\n251:     }\n252:   }\n253:   return result;\n254: }\n255: \n256: /**\n257:  * Load .wombo-combo/config.json from the given project root and merge with defaults.\n258:  * Returns the full config. If no config file exists, returns defaults.\n259:  */\n260: export function loadConfig(projectRoot: string): WomboConfig {\n261:   const configPath = resolve(projectRoot, CONFIG_FILE);\n262: \n263:   if (!existsSync(configPath)) {\n264:     return { ...DEFAULT_CONFIG };\n265:   }\n266: \n267:   try {\n268:     const raw = readFileSync(configPath, \"utf-8\");\n269:     const partial = JSON.parse(raw) as Partial<WomboConfig>;\n270: \n271:     // Migrate legacy single-file config keys to folder-based\n272:     if ((partial as any).tasksFile && !partial.tasksDir) {\n273:       // Legacy \"tasks.yml\" → strip extension for dir name, or use as-is\n274:       const legacy = (partial as any).tasksFile as string;\n275:       partial.tasksDir = legacy.replace(/\\.ya?ml$/i, \"\") || \"tasks\";\n276:       delete (partial as any).tasksFile;\n277:     }\n278:     if ((partial as any).archiveFile && !partial.archiveDir) {\n279:       const legacy = (partial as any).archiveFile as string;\n280:       partial.archiveDir = legacy.replace(/\\.ya?ml$/i, \"\") || \"archive\";\n281:       delete (partial as any).archiveFile;\n282:     }\n283: \n284:     return deepMerge(DEFAULT_CONFIG, partial);\n285:   } catch (err: any) {\n286:     throw new Error(`Failed to load ${CONFIG_FILE}: ${err.message}`);\n287:   }\n288: }\n289: \n290: /**\n291:  * Resolve the agent binary path. Priority:\n292:  *   1. config.agent.bin (explicit)\n293:  *   2. OPENCODE_BIN env var\n294:  *   3. ~/.opencode/bin/opencode (default install location)\n295:  */\n296: export function resolveAgentBin(config: WomboConfig): string {\n297:   if (config.agent.bin) return config.agent.bin;\n298:   if (process.env.OPENCODE_BIN) return process.env.OPENCODE_BIN;\n299:   return resolve(process.env.HOME || \"~\", \".opencode/bin/opencode\");\n300: }\n301: \n302: /**\n303:  * Validate the config for obvious issues. Throws on error.\n304:  */\n305: export function validateConfig(config: WomboConfig): void {\n306:   if (!config.tasksDir) {\n307:     throw new Error(\"config.tasksDir must be a non-empty string\");\n308:   }\n309:   if (!config.archiveDir) {\n310:     throw new Error(\"config.archiveDir must be a non-empty string\");\n311:   }\n312:   if (!config.baseBranch) {\n313:     throw new Error(\"config.baseBranch must be a non-empty string\");\n314:   }\n315:   if (!config.build.command) {\n316:     throw new Error(\"config.build.command must be a non-empty string\");\n317:   }\n318:   if (!config.install.command) {\n319:     throw new Error(\"config.install.command must be a non-empty string\");\n320:   }\n321:   if (!config.git.branchPrefix) {\n322:     throw new Error(\"config.git.branchPrefix must be a non-empty string\");\n323:   }\n324:   if (!config.git.worktreePrefix) {\n325:     throw new Error(\"config.git.worktreePrefix must be a non-empty string\");\n326:   }\n327:   if (config.defaults.maxConcurrent < 1) {\n328:     throw new Error(\"config.defaults.maxConcurrent must be >= 1\");\n329:   }\n330:   if (config.defaults.maxRetries < 0) {\n331:     throw new Error(\"config.defaults.maxRetries must be >= 0\");\n332:   }\n333:   if (config.backup.maxBackups < 0) {\n334:     throw new Error(\"config.backup.maxBackups must be >= 0\");\n335:   }\n336:   const validModes: AgentRegistryMode[] = [\"auto\", \"monitored\", \"disabled\"];\n337:   if (!validModes.includes(config.agentRegistry.mode)) {\n338:     throw new Error(`config.agentRegistry.mode must be one of: ${validModes.join(\", \")}`);\n339:   }\n340:   if (!config.agentRegistry.source) {\n341:     throw new Error(\"config.agentRegistry.source must be a non-empty string\");\n342:   }\n343:   if (!config.agentRegistry.cacheDir) {\n344:     throw new Error(\"config.agentRegistry.cacheDir must be a non-empty string\");\n345:   }\n346:   if (config.tdd.enabled && !config.tdd.testCommand) {\n347:     throw new Error(\"config.tdd.testCommand must be a non-empty string when TDD is enabled\");\n348:   }\n349: }\n350: \n351: /**\n352:  * Generate the default .wombo-combo/config.json content string (for `woco init`).\n353:  */\n354: export function generateDefaultConfig(): string {\n355:   return JSON.stringify(DEFAULT_CONFIG, null, 2) + \"\\n\";\n356: }\n\n(End of file - total 356 lines)\n</content>","title":"src/config.ts","metadata":{"preview":"/**\n * config.ts — Load .wombo-combo/config.json, merge with defaults, validate, expose typed config.\n *\n * The config file lives at .wombo-combo/config.json inside the target project root.\n * All values have sensible defaults so minimal config works out of the box.\n */\n\nimport { readFileSync, existsSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\nimport type { MultiplexerPreference } from \"./lib/multiplexer.js\";\n\n// ---------------------------------------------------------------------------\n// .wombo-combo directory constant\n// ---------------------------------------------------------------------------\n\n/** Name of the directory that holds all wombo-combo files */\nexport const WOMBO_DIR = \".wombo-combo\";\n\n// ---------------------------------------------------------------------------\n// Types","truncated":false,"loaded":[]},"time":{"start":1773435841074,"end":1773435841084}}}}
