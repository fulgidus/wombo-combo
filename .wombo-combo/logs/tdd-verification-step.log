{"type":"tool_use","timestamp":1773436105443,"sessionID":"ses_316fcb79fffeLVMPL0QpkiSz53","part":{"id":"prt_ce90772700011kSWzHLatXTToT","sessionID":"ses_316fcb79fffeLVMPL0QpkiSz53","messageID":"msg_ce9076b15001RPsjCCcj6J1D4b","type":"tool","callID":"toolu_vrtx_01G8KGQiPB2FrQzR1UJCytwa","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-tdd-verification-step/src/lib/verifier.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-tdd-verification-step/src/lib/verifier.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * verifier.ts — Build verification in worktrees.\n3:  *\n4:  * Responsibilities:\n5:  *   - Run the project build command in a worktree\n6:  *   - Capture and parse build output\n7:  *   - Determine pass/fail\n8:  *   - Extract error messages for retry prompts\n9:  *   - Run browser-based verification when enabled\n10:  *   - Run TDD verification (tests + test detection) when enabled\n11:  *\n12:  * IMPORTANT: runBuild is ASYNC — does not block the event loop.\n13:  */\n14: \n15: import { exec } from \"node:child_process\";\n16: import { existsSync } from \"node:fs\";\n17: import { resolve } from \"node:path\";\n18: import type { WomboConfig } from \"../config.js\";\n19: import {\n20:   runBrowserVerification,\n21:   extractBrowserErrorSummary,\n22:   type BrowserVerificationResult,\n23: } from \"./browser-verifier.js\";\n24: import {\n25:   runTddVerification,\n26:   extractTddErrorSummary,\n27:   type TddVerificationResult,\n28: } from \"./tdd-verifier.js\";\n29: \n30: // ---------------------------------------------------------------------------\n31: // Types\n32: // ---------------------------------------------------------------------------\n33: \n34: export interface BuildResult {\n35:   passed: boolean;\n36:   exitCode: number;\n37:   stdout: string;\n38:   stderr: string;\n39:   /** Combined output, truncated for use in retry prompts */\n40:   errorSummary: string;\n41:   /** Duration in milliseconds */\n42:   durationMs: number;\n43: }\n44: \n45: /** Options for controlling the full verification pipeline */\n46: export interface FullVerificationOptions {\n47:   /** Skip running tests (--skip-tests) */\n48:   skipTests?: boolean;\n49:   /** Strict TDD mode — fail if new files are missing tests (--strict-tdd) */\n50:   strictTdd?: boolean;\n51: }\n52: \n53: /**\n54:  * Combined result of build verification + browser verification + TDD verification.\n55:  */\n56: export interface FullVerificationResult {\n57:   /** Build result (always runs) */\n58:   build: BuildResult;\n59:   /** Browser verification result (may be skipped) */\n60:   browser: BrowserVerificationResult;\n61:   /** TDD verification result (may be skipped) */\n62:   tdd: TddVerificationResult;\n63:   /** Overall pass: build passed AND browser passed AND tdd passed */\n64:   overallPassed: boolean;\n65:   /** Combined error summary for retry prompts */\n66:   combinedErrorSummary: string;\n67: }\n68: \n69: // ---------------------------------------------------------------------------\n70: // Build Verification\n71: // ---------------------------------------------------------------------------\n72: \n73: /**\n74:  * Run the build command in a worktree directory.\n75:  * Uses config for the build command and timeout.\n76:  */\n77: export function runBuild(\n78:   worktreePath: string,\n79:   config: WomboConfig\n80: ): Promise<BuildResult> {\n81:   return new Promise((resolvePromise) => {\n82:     const start = Date.now();\n83: \n84:     exec(\n85:       config.build.command,\n86:       {\n87:         cwd: worktreePath,\n88:         encoding: \"utf-8\",\n89:         timeout: config.build.timeout,\n90:         maxBuffer: 10 * 1024 * 1024,\n91:       },\n92:       (error, stdout, stderr) => {\n93:         const durationMs = Date.now() - start;\n94:         const exitCode = error ? (error as any).code ?? 1 : 0;\n95:         const passed = !error;\n96: \n97:         let errorSummary = \"\";\n98:         if (!passed) {\n99:           errorSummary = extractErrorSummary(stdout ?? \"\", stderr ?? \"\");\n100:         }\n101: \n102:         resolvePromise({\n103:           passed,\n104:           exitCode,\n105:           stdout: stdout ?? \"\",\n106:           stderr: stderr ?? \"\",\n107:           errorSummary,\n108:           durationMs,\n109:         });\n110:       }\n111:     );\n112:   });\n113: }\n114: \n115: // ---------------------------------------------------------------------------\n116: // Error Extraction\n117: // ---------------------------------------------------------------------------\n118: \n119: /**\n120:  * Extract a concise error summary from build output.\n121:  */\n122: function extractErrorSummary(stdout: string, stderr: string): string {\n123:   const combined = stdout + \"\\n\" + stderr;\n124:   const lines = combined.split(\"\\n\");\n125: \n126:   const errorLines: string[] = [];\n127:   let capturing = false;\n128:   let contextLines = 0;\n129: \n130:   for (const line of lines) {\n131:     const isError =\n132:       /error/i.test(line) &&\n133:       !/warning/i.test(line) &&\n134:       !/^info/i.test(line);\n135:     const isTypeError = /TS\\d+/.test(line);\n136: \n137:     if (isError || isTypeError) {\n138:       capturing = true;\n139:       contextLines = 0;\n140:       errorLines.push(line);\n141:     } else if (capturing) {\n142:       contextLines++;\n143:       if (contextLines <= 3) {\n144:         errorLines.push(line);\n145:       } else {\n146:         capturing = false;\n147:       }\n148:     }\n149:   }\n150: \n151:   if (errorLines.length === 0) {\n152:     const tail = lines.slice(-50).join(\"\\n\");\n153:     return truncate(tail, 4000);\n154:   }\n155: \n156:   return truncate(errorLines.join(\"\\n\"), 4000);\n157: }\n158: \n159: /**\n160:  * Truncate a string to maxLen characters.\n161:  */\n162: function truncate(s: string, maxLen: number): string {\n163:   if (s.length <= maxLen) return s;\n164:   return s.slice(0, maxLen) + \"\\n\\n[... truncated, showing first 4000 chars]\";\n165: }\n166: \n167: // ---------------------------------------------------------------------------\n168: // Quick Check\n169: // ---------------------------------------------------------------------------\n170: \n171: /**\n172:  * Quick check if the build artifacts exist.\n173:  */\n174: export function hasBuildArtifacts(\n175:   worktreePath: string,\n176:   config: WomboConfig\n177: ): boolean {\n178:   try {\n179:     return existsSync(resolve(worktreePath, config.build.artifactDir));\n180:   } catch {\n181:     return false;\n182:   }\n183: }\n184: \n185: // ---------------------------------------------------------------------------\n186: // Full Verification (Build + Browser)\n187: // ---------------------------------------------------------------------------\n188: \n189: /**\n190:  * Run the complete verification pipeline:\n191:  *   1. Run the build command\n192:  *   2. If build passes and browser testing is enabled, run browser tests\n193:  *   3. If build passes and TDD is enabled, run tests + test detection\n194:  *\n195:  * Browser testing and TDD verification are additive — they run AFTER the\n196:  * build passes and are skipped if the build fails.\n197:  */\n198: export async function runFullVerification(\n199:   worktreePath: string,\n200:   featureId: string,\n201:   config: WomboConfig,\n202:   opts?: FullVerificationOptions\n203: ): Promise<FullVerificationResult> {\n204:   const skipTests = opts?.skipTests ?? false;\n205:   const strictTdd = opts?.strictTdd ?? false;\n206: \n207:   // Default TDD result (skipped)\n208:   const defaultTddResult: TddVerificationResult = {\n209:     ran: false,\n210:     skipReason: \"Skipped because build failed\",\n211:     testRun: null,\n212:     testDetection: null,\n213:     passed: true,\n214:     hasWarnings: false,\n215:     summary: \"TDD verification skipped (build failed)\",\n216:     strictMode: strictTdd,\n217:   };\n218: \n219:   // Step 1: Build verification (always runs)\n220:   const buildResult = await runBuild(worktreePath, config);\n221: \n222:   // If build failed, skip browser testing and TDD verification\n223:   if (!buildResult.passed) {\n224:     return {\n225:       build: buildResult,\n226:       browser: {\n227:         ran: false,\n228:         skipReason: \"Skipped because build failed\",\n229:         browserResult: null,\n230:       },\n231:       tdd: defaultTddResult,\n232:       overallPassed: false,\n233:       combinedErrorSummary: buildResult.errorSummary,\n234:     };\n235:   }\n236: \n237:   // Step 2: Browser verification (runs only if build passed and browser enabled)\n238:   const browserResult = await runBrowserVerification({\n239:     worktreePath,\n240:     featureId,\n241:     config,\n242:   });\n243: \n244:   // Step 3: TDD verification (runs only if build passed and TDD enabled)\n245:   const tddResult = await runTddVerification({\n246:     worktreePath,\n247:     featureId,\n248:     config,\n249:     skipTests,\n250:     strictTdd,\n251:     baseBranch: config.baseBranch,\n252:   });\n253: \n254:   // Determine overall pass\n255:   const browserPassed = !browserResult.ran || (browserResult.browserResult?.allPassed ?? true);\n256:   const tddPassed = tddResult.passed;\n257:   const overallPassed = buildResult.passed && browserPassed && tddPassed;\n258: \n259:   // Combine error summaries\n260:   let combinedErrorSummary = \"\";\n261:   if (!buildResult.passed) {\n262:     combinedErrorSummary = buildResult.errorSummary;\n263:   }\n264:   if (browserResult.ran && browserResult.browserResult && !browserResult.browserResult.allPassed) {\n265:     const browserErrors = extractBrowserErrorSummary(browserResult.browserResult);\n266:     combinedErrorSummary = combinedErrorSummary\n267:       ? `${combinedErrorSummary}\\n\\n--- Browser Test Errors ---\\n\\n${browserErrors}`\n268:       : browserErrors;\n269:   }\n270:   if (tddResult.ran && !tddResult.passed) {\n271:     const tddErrors = extractTddErrorSummary(tddResult);\n272:     combinedErrorSummary = combinedErrorSummary\n273:       ? `${combinedErrorSummary}\\n\\n--- TDD Verification Errors ---\\n\\n${tddErrors}`\n274:       : tddErrors;\n275:   }\n276: \n277:   return {\n278:     build: buildResult,\n279:     browser: browserResult,\n280:     tdd: tddResult,\n281:     overallPassed,\n282:     combinedErrorSummary,\n283:   };\n284: }\n\n(End of file - total 284 lines)\n</content>","title":"src/lib/verifier.ts","metadata":{"preview":"/**\n * verifier.ts — Build verification in worktrees.\n *\n * Responsibilities:\n *   - Run the project build command in a worktree\n *   - Capture and parse build output\n *   - Determine pass/fail\n *   - Extract error messages for retry prompts\n *   - Run browser-based verification when enabled\n *   - Run TDD verification (tests + test detection) when enabled\n *\n * IMPORTANT: runBuild is ASYNC — does not block the event loop.\n */\n\nimport { exec } from \"node:child_process\";\nimport { existsSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\nimport type { WomboConfig } from \"../config.js\";\nimport {\n  runBrowserVerification,","truncated":false,"loaded":[]},"time":{"start":1773436105437,"end":1773436105442}}}}
