{"type":"tool_use","timestamp":1773436108369,"sessionID":"ses_316fcb79fffeLVMPL0QpkiSz53","part":{"id":"prt_ce9077aae001xitgHYINSradfZ","sessionID":"ses_316fcb79fffeLVMPL0QpkiSz53","messageID":"msg_ce90772f400150Yjltc3Nu0OYo","type":"tool","callID":"toolu_vrtx_012Py8aFsF4fteqNNh8gciN2","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-tdd-verification-step/src/lib/tdd-verifier.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-tdd-verification-step/src/lib/tdd-verifier.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tdd-verifier.ts — TDD verification step for the build pipeline.\n3:  *\n4:  * Responsibilities:\n5:  *   - Run tests via test-runner.ts and capture results\n6:  *   - Run test-detection.ts to check new files have tests\n7:  *   - Combine results into a structured TddVerificationResult\n8:  *   - Support strict mode (blocking) vs warn mode (non-blocking)\n9:  *   - Render human-readable reports\n10:  *\n11:  * This module is called by verifier.ts as an additional step in the\n12:  * full verification pipeline, after the build passes.\n13:  */\n14: \n15: import type { WomboConfig } from \"../config.js\";\n16: import { runTests, type TestRunResult } from \"./test-runner.js\";\n17: import {\n18:   detectTests,\n19:   renderTestDetectionReport,\n20:   type TestDetectionReport,\n21: } from \"./test-detection.js\";\n22: \n23: // ---------------------------------------------------------------------------\n24: // Types\n25: // ---------------------------------------------------------------------------\n26: \n27: /** Options for running TDD verification */\n28: export interface TddVerificationOptions {\n29:   /** Absolute path to the worktree */\n30:   worktreePath: string;\n31:   /** Feature ID (used for git diff comparison) */\n32:   featureId: string;\n33:   /** Full config */\n34:   config: WomboConfig;\n35:   /** Skip running tests entirely */\n36:   skipTests?: boolean;\n37:   /** Strict TDD mode: fail verification if tests are missing */\n38:   strictTdd?: boolean;\n39:   /** Base branch for git diff comparison (default: from config) */\n40:   baseBranch?: string;\n41: }\n42: \n43: /** Result of TDD verification */\n44: export interface TddVerificationResult {\n45:   /** Whether TDD verification was run at all */\n46:   ran: boolean;\n47:   /** Why it was skipped (null if it ran) */\n48:   skipReason: string | null;\n49:   /** Test run results (null if tests were skipped or not run) */\n50:   testRun: TestRunResult | null;\n51:   /** Test detection report (null if skipped) */\n52:   testDetection: TestDetectionReport | null;\n53:   /** Whether TDD verification passed overall */\n54:   passed: boolean;\n55:   /** Whether there are warnings (missing tests in non-strict mode) */\n56:   hasWarnings: boolean;\n57:   /** Human-readable summary */\n58:   summary: string;\n59:   /** Whether strict mode was used */\n60:   strictMode: boolean;\n61: }\n62: \n63: // ---------------------------------------------------------------------------\n64: // TDD Verification Runner\n65: // ---------------------------------------------------------------------------\n66: \n67: /**\n68:  * Run the TDD verification step.\n69:  *\n70:  * This is the main entry point called by the verification pipeline.\n71:  * It runs in two sub-steps:\n72:  *   1. Run the test command and capture results\n73:  *   2. Run test detection to find files missing tests\n74:  *\n75:  * In non-strict mode (default), missing tests produce warnings but don't\n76:  * fail verification. In strict mode (--strict-tdd), missing tests cause\n77:  * verification to fail.\n78:  */\n79: export async function runTddVerification(\n80:   opts: TddVerificationOptions\n81: ): Promise<TddVerificationResult> {\n82:   const { worktreePath, config } = opts;\n83:   const strictMode = opts.strictTdd ?? false;\n84: \n85:   // Check if TDD is enabled in config\n86:   if (!config.tdd?.enabled) {\n87:     return {\n88:       ran: false,\n89:       skipReason: \"TDD is disabled (set tdd.enabled: true in .wombo-combo/config.json)\",\n90:       testRun: null,\n91:       testDetection: null,\n92:       passed: true,\n93:       hasWarnings: false,\n94:       summary: \"TDD verification skipped (disabled)\",\n95:       strictMode,\n96:     };\n97:   }\n98: \n99:   // Check if tests should be skipped via --skip-tests flag\n100:   if (opts.skipTests) {\n101:     return {\n102:       ran: false,\n103:       skipReason: \"Tests skipped via --skip-tests flag\",\n104:       testRun: null,\n105:       testDetection: null,\n106:       passed: true,\n107:       hasWarnings: false,\n108:       summary: \"TDD verification skipped (--skip-tests)\",\n109:       strictMode,\n110:     };\n111:   }\n112: \n113:   const testCommand = config.tdd.testCommand || \"bun test\";\n114:   const baseBranch = opts.baseBranch ?? config.baseBranch;\n115: \n116:   // Step 1: Run the test command\n117:   let testRun: TestRunResult | null = null;\n118:   try {\n119:     testRun = await runTests(worktreePath, testCommand);\n120:   } catch (err: any) {\n121:     // Test command failed to execute (not the same as tests failing)\n122:     return {\n123:       ran: true,\n124:       skipReason: null,\n125:       testRun: null,\n126:       testDetection: null,\n127:       passed: false,\n128:       hasWarnings: false,\n129:       summary: `Test command failed to execute: ${err.message}`,\n130:       strictMode,\n131:     };\n132:   }\n133: \n134:   // Step 2: Run test detection (check if new files have tests)\n135:   let testDetection: TestDetectionReport | null = null;\n136:   try {\n137:     testDetection = detectTests(worktreePath, baseBranch);\n138:   } catch (err: any) {\n139:     // Test detection failed — non-fatal, just skip it\n140:     testDetection = null;\n141:   }\n142: \n143:   // Step 3: Determine overall pass/fail\n144:   const testsPassed = testRun.passed;\n145:   const hasMissingTests =\n146:     testDetection !== null && testDetection.missingTests.length > 0;\n147:   const hasWarnings = hasMissingTests && !strictMode;\n148: \n149:   // In strict mode, missing tests cause failure\n150:   // In non-strict mode, only test failures cause failure\n151:   const passed = strictMode\n152:     ? testsPassed && !hasMissingTests\n153:     : testsPassed;\n154: \n155:   // Build summary\n156:   const summary = buildSummary(testRun, testDetection, strictMode);\n157: \n158:   return {\n159:     ran: true,\n160:     skipReason: null,\n161:     testRun,\n162:     testDetection,\n163:     passed,\n164:     hasWarnings,\n165:     summary,\n166:     strictMode,\n167:   };\n168: }\n169: \n170: // ---------------------------------------------------------------------------\n171: // Summary Building\n172: // ---------------------------------------------------------------------------\n173: \n174: /**\n175:  * Build a human-readable summary of TDD verification results.\n176:  */\n177: function buildSummary(\n178:   testRun: TestRunResult,\n179:   testDetection: TestDetectionReport | null,\n180:   strictMode: boolean\n181: ): string {\n182:   const parts: string[] = [];\n183: \n184:   // Test run summary\n185:   if (testRun.testCounts.parsed) {\n186:     parts.push(\n187:       `Tests: ${testRun.testCounts.passed} passed, ` +\n188:       `${testRun.testCounts.failed} failed` +\n189:       (testRun.testCounts.skipped > 0\n190:         ? `, ${testRun.testCounts.skipped} skipped`\n191:         : \"\") +\n192:       ` (${Math.round(testRun.durationMs / 1000)}s)`\n193:     );\n194:   } else {\n195:     parts.push(\n196:       `Tests: ${testRun.passed ? \"PASSED\" : \"FAILED\"} ` +\n197:       `(exit code ${testRun.exitCode}, ${Math.round(testRun.durationMs / 1000)}s)`\n198:     );\n199:   }\n200: \n201:   // Test detection summary\n202:   if (testDetection) {\n203:     const { missingTests, coveredCount, testableCount, coveragePercent } =\n204:       testDetection;\n205:     if (missingTests.length > 0) {\n206:       const label = strictMode ? \"FAIL\" : \"WARN\";\n207:       parts.push(\n208:         `Coverage: ${coveredCount}/${testableCount} files (${coveragePercent}) — ` +\n209:         `${label}: ${missingTests.length} file(s) missing tests`\n210:       );\n211:     } else if (testableCount > 0) {\n212:       parts.push(\n213:         `Coverage: ${coveredCount}/${testableCount} files (${coveragePercent})`\n214:       );\n215:     }\n216:   }\n217: \n218:   return parts.join(\" | \");\n219: }\n220: \n221: // ---------------------------------------------------------------------------\n222: // Error Summary Extraction\n223: // ---------------------------------------------------------------------------\n224: \n225: /**\n226:  * Extract a concise error summary from TDD verification results.\n227:  * Used for retry prompts when TDD verification fails.\n228:  */\n229: export function extractTddErrorSummary(\n230:   result: TddVerificationResult\n231: ): string {\n232:   const parts: string[] = [];\n233: \n234:   if (result.testRun && !result.testRun.passed) {\n235:     parts.push(\"--- Test Failures ---\");\n236:     parts.push(result.testRun.errorSummary || \"(no error details)\");\n237:   }\n238: \n239:   if (\n240:     result.strictMode &&\n241:     result.testDetection &&\n242:     result.testDetection.missingTests.length > 0\n243:   ) {\n244:     parts.push(\"\");\n245:     parts.push(\"--- Missing Tests (strict TDD mode) ---\");\n246:     for (const path of result.testDetection.missingTests) {\n247:       parts.push(`  ${path}`);\n248:     }\n249:   }\n250: \n251:   return parts.join(\"\\n\").slice(0, 4000);\n252: }\n253: \n254: // ---------------------------------------------------------------------------\n255: // Text Rendering\n256: // ---------------------------------------------------------------------------\n257: \n258: /**\n259:  * Render a TDD verification result as human-readable text to stdout.\n260:  */\n261: export function renderTddVerificationReport(\n262:   result: TddVerificationResult\n263: ): void {\n264:   if (!result.ran) {\n265:     console.log(`\\n  TDD: ${result.skipReason}\\n`);\n266:     return;\n267:   }\n268: \n269:   console.log(`\\n${\"─\".repeat(60)}`);\n270:   console.log(`  TDD Verification Report`);\n271:   console.log(`${\"─\".repeat(60)}`);\n272: \n273:   // Test run results\n274:   if (result.testRun) {\n275:     const tr = result.testRun;\n276:     const statusIcon = tr.passed ? \"\\x1b[32m✓\\x1b[0m\" : \"\\x1b[31m✗\\x1b[0m\";\n277:     console.log(`\\n  ${statusIcon} Test Run: ${tr.passed ? \"PASSED\" : \"FAILED\"}`);\n278:     console.log(`    Command exit code: ${tr.exitCode}`);\n279:     console.log(`    Duration: ${Math.round(tr.durationMs / 1000)}s`);\n280: \n281:     if (tr.testCounts.parsed) {\n282:       console.log(\n283:         `    Results: ${tr.testCounts.passed} passed, ` +\n284:         `${tr.testCounts.failed} failed, ` +\n285:         `${tr.testCounts.skipped} skipped ` +\n286:         `(${tr.testCounts.total} total)`\n287:       );\n288:     }\n289:   }\n290: \n291:   // Test detection results\n292:   if (result.testDetection) {\n293:     renderTestDetectionReport(result.testDetection);\n294:   }\n295: \n296:   // Overall status\n297:   const overallIcon = result.passed\n298:     ? \"\\x1b[32m✓\\x1b[0m\"\n299:     : \"\\x1b[31m✗\\x1b[0m\";\n300:   const modeLabel = result.strictMode ? \" (strict)\" : \"\";\n301:   console.log(`  ${overallIcon} TDD Overall: ${result.passed ? \"PASSED\" : \"FAILED\"}${modeLabel}`);\n302: \n303:   if (result.hasWarnings) {\n304:     console.log(\n305:       `  \\x1b[33m⚠\\x1b[0m Warnings: Some new files are missing tests ` +\n306:       `(non-blocking — use --strict-tdd to enforce)`\n307:     );\n308:   }\n309: \n310:   console.log(`${\"─\".repeat(60)}\\n`);\n311: }\n\n(End of file - total 311 lines)\n</content>","title":"src/lib/tdd-verifier.ts","metadata":{"preview":"/**\n * tdd-verifier.ts — TDD verification step for the build pipeline.\n *\n * Responsibilities:\n *   - Run tests via test-runner.ts and capture results\n *   - Run test-detection.ts to check new files have tests\n *   - Combine results into a structured TddVerificationResult\n *   - Support strict mode (blocking) vs warn mode (non-blocking)\n *   - Render human-readable reports\n *\n * This module is called by verifier.ts as an additional step in the\n * full verification pipeline, after the build passes.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport { runTests, type TestRunResult } from \"./test-runner.js\";\nimport {\n  detectTests,\n  renderTestDetectionReport,\n  type TestDetectionReport,","truncated":false,"loaded":[]},"time":{"start":1773436108363,"end":1773436108368}}}}
