{"type":"tool_use","timestamp":1773433296528,"sessionID":"ses_31723c315ffeTdWKv3RfQTSDr6","part":{"id":"prt_ce8dc9401001ggk2au0pncjYkH","sessionID":"ses_31723c315ffeTdWKv3RfQTSDr6","messageID":"msg_ce8dc81e40015dIhbWchAGbscf","type":"tool","callID":"toolu_vrtx_01EkJkMwQUw69xaXcig1Fyf6","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-tdd-test-detection/src/lib/preflight.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-tdd-test-detection/src/lib/preflight.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * preflight.ts — Pre-launch confirmation dialog.\n3:  *\n4:  * Shows every launch — a confirmation step displaying:\n5:  *   - Tasks being launched\n6:  *   - Agent assignments (generalist or specialized)\n7:  *   - Registry mode (auto/monitored/disabled)\n8:  *   - Ability to change mode or reject specific agents\n9:  *\n10:  * Two implementations:\n11:  *   - tuiPreflightConfirm()     — blessed screen (default, rich UI)\n12:  *   - consolePreflightConfirm() — plain console fallback\n13:  *\n14:  * The preflight screen is destroyed before the monitoring TUI starts.\n15:  */\n16: \n17: import blessed from \"neo-blessed\";\n18: import type { AgentResolution, ResolvedAgent } from \"./agent-registry.js\";\n19: import { isSpecializedAgent } from \"./agent-registry.js\";\n20: import type { Task } from \"./tasks.js\";\n21: import type { AgentRegistryMode, WomboConfig } from \"../config.js\";\n22: \n23: // ---------------------------------------------------------------------------\n24: // Types\n25: // ---------------------------------------------------------------------------\n26: \n27: export interface PreflightResult {\n28:   /** Whether the user confirmed and wants to proceed */\n29:   proceed: boolean;\n30:   /**\n31:    * Final agent assignments after user edits.\n32:    * Task IDs mapped to their resolutions. Rejected agents are replaced\n33:    * with generalist fallbacks (name: null).\n34:    */\n35:   agents: Map<string, AgentResolution>;\n36:   /** Final registry mode (may differ from config if user changed it) */\n37:   mode: AgentRegistryMode;\n38: }\n39: \n40: /** Row data for display */\n41: interface PreflightRow {\n42:   taskId: string;\n43:   taskTitle: string;\n44:   agentName: string; // display name: \"generalist\" or the specialized name\n45:   agentType: string | null;\n46:   isSpecialized: boolean;\n47:   rejected: boolean;\n48: }\n49: \n50: // ---------------------------------------------------------------------------\n51: // Console Preflight (fallback)\n52: // ---------------------------------------------------------------------------\n53: \n54: /**\n55:  * Console-based preflight confirmation.\n56:  * Displays the launch plan and asks for y/n confirmation.\n57:  * Does NOT support interactive agent rejection (that's TUI-only).\n58:  */\n59: export async function consolePreflightConfirm(\n60:   tasks: Task[],\n61:   agents: Map<string, AgentResolution>,\n62:   config: WomboConfig\n63: ): Promise<PreflightResult> {\n64:   const mode = config.agentRegistry.mode;\n65: \n66:   console.log(`\\n${\"═\".repeat(60)}`);\n67:   console.log(`  LAUNCH PREFLIGHT`);\n68:   console.log(`${\"═\".repeat(60)}`);\n69:   console.log(`  Registry mode: ${mode}`);\n70:   console.log(`  Tasks: ${tasks.length}`);\n71:   console.log(`${\"─\".repeat(60)}`);\n72: \n73:   for (const task of tasks) {\n74:     const resolution = agents.get(task.id);\n75:     const agentLabel = resolution && isSpecializedAgent(resolution)\n76:       ? `${resolution.name} (${resolution.fromCache ? \"cached\" : \"fetched\"})`\n77:       : \"generalist\";\n78:     console.log(`  ${task.id.padEnd(30)} → ${agentLabel}`);\n79:   }\n80: \n81:   console.log(`${\"─\".repeat(60)}`);\n82: \n83:   // In non-interactive environments (piped stdin), just proceed\n84:   if (!process.stdin.isTTY) {\n85:     console.log(`  Non-interactive mode — proceeding automatically.\\n`);\n86:     return { proceed: true, agents, mode };\n87:   }\n88: \n89:   const answer = await new Promise<string>((resolve) => {\n90:     process.stdout.write(\"  Proceed? [Y/n] \");\n91:     process.stdin.setEncoding(\"utf-8\");\n92:     process.stdin.resume();\n93:     process.stdin.once(\"data\", (data) => {\n94:       process.stdin.pause();\n95:       resolve(data.toString().trim().toLowerCase());\n96:     });\n97:   });\n98: \n99:   const proceed = answer === \"\" || answer === \"y\" || answer === \"yes\";\n100:   if (!proceed) {\n101:     console.log(\"  Launch cancelled.\\n\");\n102:   }\n103: \n104:   return { proceed, agents, mode };\n105: }\n106: \n107: // ---------------------------------------------------------------------------\n108: // TUI Preflight (blessed)\n109: // ---------------------------------------------------------------------------\n110: \n111: /**\n112:  * TUI-based preflight confirmation using blessed.\n113:  *\n114:  * Layout:\n115:  *   ┌──────────────────────────────────────────┐\n116:  *   │ LAUNCH PREFLIGHT           mode: auto    │\n117:  *   ├──────────────────────────────────────────┤\n118:  *   │ Task ID          Agent          Status   │\n119:  *   │ ─────────────────────────────────────── │\n120:  *   │ > my-task        frontend-dev   ✓       │\n121:  *   │   other-task     generalist     ✓       │\n122:  *   ├──────────────────────────────────────────┤\n123:  *   │ Enter: launch  Tab: cycle mode  x: reject│\n124:  *   │ Esc: cancel    ↑/↓: navigate             │\n125:  *   └──────────────────────────────────────────┘\n126:  *\n127:  * In monitored mode, users can navigate tasks and press 'x' to reject\n128:  * specific specialized agents (falling back to generalist).\n129:  */\n130: export function tuiPreflightConfirm(\n131:   tasks: Task[],\n132:   agents: Map<string, AgentResolution>,\n133:   config: WomboConfig\n134: ): Promise<PreflightResult> {\n135:   return new Promise((resolvePromise) => {\n136:     let currentMode: AgentRegistryMode = config.agentRegistry.mode;\n137:     let selectedIndex = 0;\n138: \n139:     // Build rows\n140:     const rows: PreflightRow[] = tasks.map((task) => {\n141:       const resolution = agents.get(task.id);\n142:       const specialized = resolution && isSpecializedAgent(resolution);\n143:       return {\n144:         taskId: task.id,\n145:         taskTitle: task.title,\n146:         agentName: specialized ? resolution.name : \"generalist\",\n147:         agentType: specialized ? resolution.agentType : null,\n148:         isSpecialized: !!specialized,\n149:         rejected: false,\n150:       };\n151:     });\n152: \n153:     // Create screen\n154:     const screen = blessed.screen({\n155:       smartCSR: true,\n156:       title: \"wombo-combo — Launch Preflight\",\n157:       fullUnicode: true,\n158:     });\n159: \n160:     // Header\n161:     const header = blessed.box({\n162:       top: 0,\n163:       left: 0,\n164:       width: \"100%\",\n165:       height: 3,\n166:       tags: true,\n167:       content: \"\",\n168:       style: { fg: \"white\", bg: \"black\" },\n169:     });\n170: \n171:     // Task table\n172:     const table = blessed.list({\n173:       top: 3,\n174:       left: 0,\n175:       width: \"100%\",\n176:       height: \"100%-6\",\n177:       tags: true,\n178:       mouse: true,\n179:       keys: true,\n180:       scrollable: true,\n181:       style: {\n182:         selected: { fg: \"black\", bg: \"white\" },\n183:         item: { fg: \"white\" },\n184:       },\n185:     });\n186: \n187:     // Status bar\n188:     const statusBar = blessed.box({\n189:       bottom: 0,\n190:       left: 0,\n191:       width: \"100%\",\n192:       height: 3,\n193:       tags: true,\n194:       content: \"\",\n195:       style: { fg: \"white\", bg: \"black\" },\n196:     });\n197: \n198:     screen.append(header);\n199:     screen.append(table);\n200:     screen.append(statusBar);\n201: \n202:     function updateDisplay(): void {\n203:       // Header\n204:       const modeColors: Record<AgentRegistryMode, string> = {\n205:         auto: \"green\",\n206:         monitored: \"yellow\",\n207:         disabled: \"red\",\n208:       };\n209:       header.setContent(\n210:         `{bold} LAUNCH PREFLIGHT{/bold}` +\n211:         `{right}mode: {${modeColors[currentMode]}-fg}{bold}${currentMode}{/bold}{/${modeColors[currentMode]}-fg}  {/right}\\n` +\n212:         ` ${tasks.length} task(s) ready to launch`\n213:       );\n214: \n215:       // Table rows\n216:       const items: string[] = rows.map((row, i) => {\n217:         const cursor = i === selectedIndex ? \"{bold}>{/bold}\" : \" \";\n218:         const taskCol = row.taskId.substring(0, 28).padEnd(28);\n219:         const agentCol = row.rejected\n220:           ? `{red-fg}(rejected){/red-fg}`.padEnd(30)\n221:           : row.isSpecialized\n222:             ? `{cyan-fg}${row.agentName.substring(0, 20)}{/cyan-fg}`.padEnd(30)\n223:             : `{gray-fg}generalist{/gray-fg}`.padEnd(30);\n224:         const statusCol = row.rejected\n225:           ? \"{red-fg}✗{/red-fg}\"\n226:           : \"{green-fg}✓{/green-fg}\";\n227:         return ` ${cursor} ${taskCol} ${agentCol} ${statusCol}`;\n228:       });\n229: \n230:       table.setItems(items);\n231:       table.select(selectedIndex);\n232: \n233:       // Status bar\n234:       const specializedCount = rows.filter((r) => r.isSpecialized && !r.rejected).length;\n235:       const rejectedCount = rows.filter((r) => r.rejected).length;\n236:       const monitoredHint = currentMode === \"monitored\" ? \"  {yellow-fg}x{/yellow-fg}: reject agent\" : \"\";\n237:       statusBar.setContent(\n238:         ` {green-fg}Enter{/green-fg}: launch  {yellow-fg}Tab{/yellow-fg}: cycle mode  {red-fg}Esc{/red-fg}: cancel${monitoredHint}\\n` +\n239:         ` Specialized: ${specializedCount}  Generalist: ${rows.length - specializedCount}  Rejected: ${rejectedCount}`\n240:       );\n241: \n242:       screen.render();\n243:     }\n244: \n245:     function finish(proceed: boolean): void {\n246:       screen.destroy();\n247: \n248:       // Build final agent map with rejections applied\n249:       const finalAgents = new Map<string, AgentResolution>(agents);\n250:       for (const row of rows) {\n251:         if (row.rejected) {\n252:           finalAgents.set(row.taskId, {\n253:             taskId: row.taskId,\n254:             name: null,\n255:             rawContent: null,\n256:             fromCache: false,\n257:             agentType: null,\n258:           });\n259:         }\n260:       }\n261: \n262:       resolvePromise({ proceed, agents: finalAgents, mode: currentMode });\n263:     }\n264: \n265:     // Key bindings\n266:     screen.key([\"escape\", \"C-c\"], () => finish(false));\n267:     screen.key([\"enter\"], () => finish(true));\n268: \n269:     screen.key([\"tab\"], () => {\n270:       const modes: AgentRegistryMode[] = [\"auto\", \"monitored\", \"disabled\"];\n271:       const idx = modes.indexOf(currentMode);\n272:       currentMode = modes[(idx + 1) % modes.length];\n273:       updateDisplay();\n274:     });\n275: \n276:     screen.key([\"up\", \"k\"], () => {\n277:       selectedIndex = Math.max(0, selectedIndex - 1);\n278:       updateDisplay();\n279:     });\n280: \n281:     screen.key([\"down\", \"j\"], () => {\n282:       selectedIndex = Math.min(rows.length - 1, selectedIndex + 1);\n283:       updateDisplay();\n284:     });\n285: \n286:     screen.key([\"x\"], () => {\n287:       if (currentMode !== \"monitored\") return; // reject only in monitored mode\n288:       const row = rows[selectedIndex];\n289:       if (row && row.isSpecialized) {\n290:         row.rejected = !row.rejected; // toggle\n291:         updateDisplay();\n292:       }\n293:     });\n294: \n295:     // Initial render\n296:     updateDisplay();\n297:     table.focus();\n298:   });\n299: }\n\n(End of file - total 299 lines)\n</content>","title":"src/lib/preflight.ts","metadata":{"preview":"/**\n * preflight.ts — Pre-launch confirmation dialog.\n *\n * Shows every launch — a confirmation step displaying:\n *   - Tasks being launched\n *   - Agent assignments (generalist or specialized)\n *   - Registry mode (auto/monitored/disabled)\n *   - Ability to change mode or reject specific agents\n *\n * Two implementations:\n *   - tuiPreflightConfirm()     — blessed screen (default, rich UI)\n *   - consolePreflightConfirm() — plain console fallback\n *\n * The preflight screen is destroyed before the monitoring TUI starts.\n */\n\nimport blessed from \"neo-blessed\";\nimport type { AgentResolution, ResolvedAgent } from \"./agent-registry.js\";\nimport { isSpecializedAgent } from \"./agent-registry.js\";\nimport type { Task } from \"./tasks.js\";","truncated":false,"loaded":[]},"time":{"start":1773433296377,"end":1773433296471}}}}
