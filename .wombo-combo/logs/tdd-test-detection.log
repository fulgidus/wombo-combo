{"type":"tool_use","timestamp":1773433288995,"sessionID":"ses_31723c315ffeTdWKv3RfQTSDr6","part":{"id":"prt_ce8dc77bc001LJAYlKzfpgdYkf","sessionID":"ses_31723c315ffeTdWKv3RfQTSDr6","messageID":"msg_ce8dc6b94001hpGOh4fBLb0XWV","type":"tool","callID":"toolu_vrtx_017hBRF9YoufEk3A9MQWp7nB","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-tdd-test-detection/src/lib/output.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-tdd-test-detection/src/lib/output.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * output.ts — Shared output helpers for agent-ready CLI.\n3:  *\n4:  * Provides a centralized way for commands to emit structured data that\n5:  * renders as human-readable text on TTY or as JSON when --output json\n6:  * is specified (or when stdout is not a TTY).\n7:  *\n8:  * Usage in commands:\n9:  *   import { output, OutputFormat } from \"../lib/output.js\";\n10:  *\n11:  *   // At the end of a command:\n12:  *   output(format, data);           // emits JSON or human text\n13:  *   outputError(format, message);   // emits error in the right format\n14:  */\n15: \n16: // ---------------------------------------------------------------------------\n17: // Types\n18: // ---------------------------------------------------------------------------\n19: \n20: export type OutputFormat = \"text\" | \"json\";\n21: \n22: // ---------------------------------------------------------------------------\n23: // Helpers\n24: // ---------------------------------------------------------------------------\n25: \n26: /**\n27:  * Determine the output format. Priority:\n28:  *   1. Explicit --output flag value\n29:  *   2. WOMBO_OUTPUT env var (for agent pipelines)\n30:  *   3. Default to \"text\"\n31:  *\n32:  * Note: We intentionally do NOT auto-detect based on TTY. Many legitimate\n33:  * use cases (bun dev, piped to less/grep, CI) have non-TTY stdout but still\n34:  * want human output. Agents should explicitly pass --output json or set\n35:  * WOMBO_OUTPUT=json.\n36:  */\n37: export function resolveOutputFormat(explicit?: string): OutputFormat {\n38:   if (explicit === \"json\") return \"json\";\n39:   if (explicit === \"text\") return \"text\";\n40:   // Check env var for agent pipelines\n41:   const env = process.env.WOMBO_OUTPUT;\n42:   if (env === \"json\") return \"json\";\n43:   return \"text\";\n44: }\n45: \n46: /**\n47:  * Emit structured data. In JSON mode, outputs a single JSON line to stdout.\n48:  * In text mode, calls the provided textRenderer callback.\n49:  */\n50: export function output(\n51:   format: OutputFormat,\n52:   data: unknown,\n53:   textRenderer: () => void\n54: ): void {\n55:   if (format === \"json\") {\n56:     console.log(JSON.stringify(data));\n57:   } else {\n58:     textRenderer();\n59:   }\n60: }\n61: \n62: /**\n63:  * Emit an error. In JSON mode, outputs {\"error\": message} to stderr.\n64:  * In text mode, outputs the message to stderr normally.\n65:  */\n66: export function outputError(format: OutputFormat, message: string, exitCode: number = 1): never {\n67:   if (format === \"json\") {\n68:     console.error(JSON.stringify({ error: message }));\n69:   } else {\n70:     console.error(message);\n71:   }\n72:   process.exit(exitCode);\n73: }\n74: \n75: /**\n76:  * Emit a success/info message. In JSON mode, outputs {\"message\": msg, ...extra}.\n77:  * In text mode, outputs the message to stdout normally.\n78:  */\n79: export function outputMessage(\n80:   format: OutputFormat,\n81:   message: string,\n82:   extra?: Record<string, unknown>\n83: ): void {\n84:   if (format === \"json\") {\n85:     console.log(JSON.stringify({ message, ...extra }));\n86:   } else {\n87:     console.log(message);\n88:   }\n89: }\n90: \n91: // ---------------------------------------------------------------------------\n92: // Field filtering for compact output (--fields)\n93: // ---------------------------------------------------------------------------\n94: \n95: /**\n96:  * Filter an object to only include the specified fields.\n97:  * If fields is undefined/empty, returns the object unchanged.\n98:  */\n99: export function filterFields<T extends Record<string, unknown>>(\n100:   obj: T,\n101:   fields?: string[]\n102: ): Partial<T> {\n103:   if (!fields || fields.length === 0) return obj;\n104:   const result: Partial<T> = {};\n105:   for (const field of fields) {\n106:     if (field in obj) {\n107:       (result as any)[field] = (obj as any)[field];\n108:     }\n109:   }\n110:   return result;\n111: }\n112: \n113: /**\n114:  * Filter an array of objects to only include specified fields per object.\n115:  * If fields is undefined/empty, returns the array unchanged.\n116:  */\n117: export function filterFieldsArray<T extends Record<string, unknown>>(\n118:   arr: T[],\n119:   fields?: string[]\n120: ): Partial<T>[] {\n121:   if (!fields || fields.length === 0) return arr;\n122:   return arr.map((obj) => filterFields(obj, fields));\n123: }\n124: \n125: /**\n126:  * Render a compact text table from an array of objects with selected fields.\n127:  * Used for text-mode --fields output.\n128:  */\n129: export function renderCompactTable(\n130:   items: Record<string, unknown>[],\n131:   fields: string[]\n132: ): void {\n133:   if (items.length === 0) return;\n134: \n135:   // Calculate column widths\n136:   const widths: Record<string, number> = {};\n137:   for (const field of fields) {\n138:     widths[field] = field.length;\n139:     for (const item of items) {\n140:       const val = String(item[field] ?? \"\");\n141:       widths[field] = Math.max(widths[field], val.length);\n142:     }\n143:   }\n144: \n145:   // Header\n146:   const header = fields.map((f) => f.padEnd(widths[f])).join(\"  \");\n147:   console.log(header);\n148:   console.log(fields.map((f) => \"─\".repeat(widths[f])).join(\"  \"));\n149: \n150:   // Rows\n151:   for (const item of items) {\n152:     const row = fields.map((f) => String(item[f] ?? \"\").padEnd(widths[f])).join(\"  \");\n153:     console.log(row);\n154:   }\n155: }\n\n(End of file - total 155 lines)\n</content>","title":"src/lib/output.ts","metadata":{"preview":"/**\n * output.ts — Shared output helpers for agent-ready CLI.\n *\n * Provides a centralized way for commands to emit structured data that\n * renders as human-readable text on TTY or as JSON when --output json\n * is specified (or when stdout is not a TTY).\n *\n * Usage in commands:\n *   import { output, OutputFormat } from \"../lib/output.js\";\n *\n *   // At the end of a command:\n *   output(format, data);           // emits JSON or human text\n *   outputError(format, message);   // emits error in the right format\n */\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type OutputFormat = \"text\" | \"json\";","truncated":false,"loaded":[]},"time":{"start":1773433288943,"end":1773433288987}}}}
{"type":"tool_use","timestamp":1773433289443,"sessionID":"ses_31723c315ffeTdWKv3RfQTSDr6","part":{"id":"prt_ce8dc7904001xvS1MbiiaNR5zM","sessionID":"ses_31723c315ffeTdWKv3RfQTSDr6","messageID":"msg_ce8dc6b94001hpGOh4fBLb0XWV","type":"tool","callID":"toolu_vrtx_01KHmQxz4jPeShHdK6FswuQs","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-tdd-test-detection/src/config.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-tdd-test-detection/src/config.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * config.ts — Load .wombo-combo/config.json, merge with defaults, validate, expose typed config.\n3:  *\n4:  * The config file lives at .wombo-combo/config.json inside the target project root.\n5:  * All values have sensible defaults so minimal config works out of the box.\n6:  */\n7: \n8: import { readFileSync, existsSync } from \"node:fs\";\n9: import { resolve } from \"node:path\";\n10: import type { MultiplexerPreference } from \"./lib/multiplexer.js\";\n11: \n12: // ---------------------------------------------------------------------------\n13: // .wombo-combo directory constant\n14: // ---------------------------------------------------------------------------\n15: \n16: /** Name of the directory that holds all wombo-combo files */\n17: export const WOMBO_DIR = \".wombo-combo\";\n18: \n19: // ---------------------------------------------------------------------------\n20: // Types\n21: // ---------------------------------------------------------------------------\n22: \n23: /** Agent registry download mode */\n24: export type AgentRegistryMode = \"auto\" | \"monitored\" | \"disabled\";\n25: \n26: export interface WomboConfig {\n27:   /** Directory name for task files relative to .wombo-combo/ (folder-based storage) */\n28:   tasksDir: string;\n29:   /** Directory name for archived task files relative to .wombo-combo/ */\n30:   archiveDir: string;\n31:   /** @deprecated Use tasksDir. Legacy single-file path relative to .wombo-combo/ */\n32:   tasksFile?: string;\n33:   /** @deprecated Use archiveDir. Legacy single-file path relative to .wombo-combo/ */\n34:   archiveFile?: string;\n35:   /** Base branch to create feature branches from */\n36:   baseBranch: string;\n37:   /** Build configuration */\n38:   build: {\n39:     /** Build command to run in worktrees */\n40:     command: string;\n41:     /** Build timeout in milliseconds */\n42:     timeout: number;\n43:     /** Build artifact directory (for quick \"did it build?\" checks) */\n44:     artifactDir: string;\n45:   };\n46:   /** Install configuration */\n47:   install: {\n48:     /** Install command to run in worktrees */\n49:     command: string;\n50:     /** Install timeout in milliseconds */\n51:     timeout: number;\n52:   };\n53:   /** Git configuration */\n54:   git: {\n55:     /** Branch name prefix for feature branches */\n56:     branchPrefix: string;\n57:     /** Worktree directory name prefix */\n58:     worktreePrefix: string;\n59:     /** Git remote name */\n60:     remote: string;\n61:     /** Merge strategy flag */\n62:     mergeStrategy: string;\n63:   };\n64:   /** Agent configuration */\n65:   agent: {\n66:     /** Path to agent binary (null = auto-detect) */\n67:     bin: string | null;\n68:     /** Agent name to pass via --agent flag */\n69:     name: string;\n70:     /** Config files/dirs to copy into worktrees */\n71:     configFiles: string[];\n72:     /** Session name prefix for terminal multiplexer */\n73:     tmuxPrefix: string;\n74:     /** Terminal multiplexer preference: \"auto\" (prefer dmux), \"dmux\", or \"tmux\" */\n75:     multiplexer: MultiplexerPreference;\n76:   };\n77:   /** Portless integration for localhost server testing */\n78:   portless: {\n79:     /** Whether portless is enabled for agent worktrees */\n80:     enabled: boolean;\n81:     /** Path to portless binary (null = auto-detect via PATH) */\n82:     bin: string | null;\n83:     /** Proxy port (portless default is 1355) */\n84:     proxyPort: number;\n85:     /** Whether to use HTTPS mode */\n86:     https: boolean;\n87:   };\n88:   /** Backup configuration for tasks file */\n89:   backup: {\n90:     /** Maximum number of timestamped backups to keep */\n91:     maxBackups: number;\n92:   };\n93:   /** Default runtime values */\n94:   defaults: {\n95:     /** Max concurrent agents */\n96:     maxConcurrent: number;\n97:     /** Max retries per agent */\n98:     maxRetries: number;\n99:   };\n100:   /** Browser testing configuration */\n101:   browser: BrowserConfig;\n102:   /** Agent registry configuration for specialized agent downloads */\n103:   agentRegistry: AgentRegistryConfig;\n104: }\n105: \n106: /** Configuration for browser-based verification and testing */\n107: export interface BrowserConfig {\n108:   /** Enable browser testing in the verify pipeline */\n109:   enabled: boolean;\n110:   /** Path to browser binary (null = auto-detect) */\n111:   bin: string | null;\n112:   /** Run browser in headless mode (required for CI) */\n113:   headless: boolean;\n114:   /** Custom test command to run browser tests (overrides script discovery) */\n115:   testCommand: string | null;\n116:   /** Timeout for launching a browser instance (ms) */\n117:   launchTimeout: number;\n118:   /** Timeout for each browser test script (ms) */\n119:   testTimeout: number;\n120:   /** Default viewport size */\n121:   defaultViewport: {\n122:     width: number;\n123:     height: number;\n124:   };\n125: }\n126: \n127: /** Configuration for the external agent registry (e.g. agency-agents) */\n128: export interface AgentRegistryConfig {\n129:   /**\n130:    * Download mode:\n131:    * - \"auto\"      — download agents without asking (default)\n132:    * - \"monitored\" — user reviews/edits/rejects each agent before launch\n133:    * - \"disabled\"  — always use the generalist agent\n134:    */\n135:   mode: AgentRegistryMode;\n136:   /** GitHub repo in \"owner/repo\" format to pull agent definitions from */\n137:   source: string;\n138:   /** Cache directory name (relative to .wombo-combo/) */\n139:   cacheDir: string;\n140: }\n141: \n142: // ---------------------------------------------------------------------------\n143: // Defaults\n144: // ---------------------------------------------------------------------------\n145: \n146: export const DEFAULT_CONFIG: WomboConfig = {\n147:   tasksDir: \"tasks\",\n148:   archiveDir: \"archive\",\n149:   baseBranch: \"develop\",\n150:   build: {\n151:     command: \"bun run build\",\n152:     timeout: 300_000,\n153:     artifactDir: \"dist\",\n154:   },\n155:   install: {\n156:     command: \"bun install\",\n157:     timeout: 120_000,\n158:   },\n159:   git: {\n160:     branchPrefix: \"feature/\",\n161:     worktreePrefix: \"wombo-\",\n162:     remote: \"origin\",\n163:     mergeStrategy: \"--no-ff\",\n164:   },\n165:   agent: {\n166:     bin: null,\n167:     name: \"generalist-agent\",\n168:     configFiles: [\".opencode/\", \"opencode.json\", \"AGENTS.md\"],\n169:     tmuxPrefix: \"wombo\",\n170:     multiplexer: \"auto\",\n171:   },\n172:   portless: {\n173:     enabled: true,\n174:     bin: null,\n175:     proxyPort: 1355,\n176:     https: false,\n177:   },\n178:   backup: {\n179:     maxBackups: 5,\n180:   },\n181:   defaults: {\n182:     maxConcurrent: 6,\n183:     maxRetries: 2,\n184:   },\n185:   browser: {\n186:     enabled: false,\n187:     bin: null,\n188:     headless: true,\n189:     testCommand: null,\n190:     launchTimeout: 30_000,\n191:     testTimeout: 60_000,\n192:     defaultViewport: {\n193:       width: 1280,\n194:       height: 720,\n195:     },\n196:   },\n197:   agentRegistry: {\n198:     mode: \"auto\",\n199:     source: \"msitarzewski/agency-agents\",\n200:     cacheDir: \"agents-cache\",\n201:   },\n202: };\n203: \n204: // ---------------------------------------------------------------------------\n205: // Config File Name\n206: // ---------------------------------------------------------------------------\n207: \n208: export const CONFIG_FILE = `${WOMBO_DIR}/config.json`;\n209: \n210: // ---------------------------------------------------------------------------\n211: // Loader\n212: // ---------------------------------------------------------------------------\n213: \n214: /**\n215:  * Deep-merge source into target. Only merges plain objects, not arrays.\n216:  */\n217: function deepMerge<T extends Record<string, any>>(target: T, source: Partial<T>): T {\n218:   const result = { ...target };\n219:   for (const key of Object.keys(source) as (keyof T)[]) {\n220:     const srcVal = source[key];\n221:     const tgtVal = target[key];\n222:     if (\n223:       srcVal !== undefined &&\n224:       srcVal !== null &&\n225:       typeof srcVal === \"object\" &&\n226:       !Array.isArray(srcVal) &&\n227:       typeof tgtVal === \"object\" &&\n228:       !Array.isArray(tgtVal) &&\n229:       tgtVal !== null\n230:     ) {\n231:       result[key] = deepMerge(tgtVal as any, srcVal as any);\n232:     } else if (srcVal !== undefined) {\n233:       result[key] = srcVal as T[keyof T];\n234:     }\n235:   }\n236:   return result;\n237: }\n238: \n239: /**\n240:  * Load .wombo-combo/config.json from the given project root and merge with defaults.\n241:  * Returns the full config. If no config file exists, returns defaults.\n242:  */\n243: export function loadConfig(projectRoot: string): WomboConfig {\n244:   const configPath = resolve(projectRoot, CONFIG_FILE);\n245: \n246:   if (!existsSync(configPath)) {\n247:     return { ...DEFAULT_CONFIG };\n248:   }\n249: \n250:   try {\n251:     const raw = readFileSync(configPath, \"utf-8\");\n252:     const partial = JSON.parse(raw) as Partial<WomboConfig>;\n253: \n254:     // Migrate legacy single-file config keys to folder-based\n255:     if ((partial as any).tasksFile && !partial.tasksDir) {\n256:       // Legacy \"tasks.yml\" → strip extension for dir name, or use as-is\n257:       const legacy = (partial as any).tasksFile as string;\n258:       partial.tasksDir = legacy.replace(/\\.ya?ml$/i, \"\") || \"tasks\";\n259:       delete (partial as any).tasksFile;\n260:     }\n261:     if ((partial as any).archiveFile && !partial.archiveDir) {\n262:       const legacy = (partial as any).archiveFile as string;\n263:       partial.archiveDir = legacy.replace(/\\.ya?ml$/i, \"\") || \"archive\";\n264:       delete (partial as any).archiveFile;\n265:     }\n266: \n267:     return deepMerge(DEFAULT_CONFIG, partial);\n268:   } catch (err: any) {\n269:     throw new Error(`Failed to load ${CONFIG_FILE}: ${err.message}`);\n270:   }\n271: }\n272: \n273: /**\n274:  * Resolve the agent binary path. Priority:\n275:  *   1. config.agent.bin (explicit)\n276:  *   2. OPENCODE_BIN env var\n277:  *   3. ~/.opencode/bin/opencode (default install location)\n278:  */\n279: export function resolveAgentBin(config: WomboConfig): string {\n280:   if (config.agent.bin) return config.agent.bin;\n281:   if (process.env.OPENCODE_BIN) return process.env.OPENCODE_BIN;\n282:   return resolve(process.env.HOME || \"~\", \".opencode/bin/opencode\");\n283: }\n284: \n285: /**\n286:  * Validate the config for obvious issues. Throws on error.\n287:  */\n288: export function validateConfig(config: WomboConfig): void {\n289:   if (!config.tasksDir) {\n290:     throw new Error(\"config.tasksDir must be a non-empty string\");\n291:   }\n292:   if (!config.archiveDir) {\n293:     throw new Error(\"config.archiveDir must be a non-empty string\");\n294:   }\n295:   if (!config.baseBranch) {\n296:     throw new Error(\"config.baseBranch must be a non-empty string\");\n297:   }\n298:   if (!config.build.command) {\n299:     throw new Error(\"config.build.command must be a non-empty string\");\n300:   }\n301:   if (!config.install.command) {\n302:     throw new Error(\"config.install.command must be a non-empty string\");\n303:   }\n304:   if (!config.git.branchPrefix) {\n305:     throw new Error(\"config.git.branchPrefix must be a non-empty string\");\n306:   }\n307:   if (!config.git.worktreePrefix) {\n308:     throw new Error(\"config.git.worktreePrefix must be a non-empty string\");\n309:   }\n310:   if (config.defaults.maxConcurrent < 1) {\n311:     throw new Error(\"config.defaults.maxConcurrent must be >= 1\");\n312:   }\n313:   if (config.defaults.maxRetries < 0) {\n314:     throw new Error(\"config.defaults.maxRetries must be >= 0\");\n315:   }\n316:   if (config.backup.maxBackups < 0) {\n317:     throw new Error(\"config.backup.maxBackups must be >= 0\");\n318:   }\n319:   const validModes: AgentRegistryMode[] = [\"auto\", \"monitored\", \"disabled\"];\n320:   if (!validModes.includes(config.agentRegistry.mode)) {\n321:     throw new Error(`config.agentRegistry.mode must be one of: ${validModes.join(\", \")}`);\n322:   }\n323:   if (!config.agentRegistry.source) {\n324:     throw new Error(\"config.agentRegistry.source must be a non-empty string\");\n325:   }\n326:   if (!config.agentRegistry.cacheDir) {\n327:     throw new Error(\"config.agentRegistry.cacheDir must be a non-empty string\");\n328:   }\n329: }\n330: \n331: /**\n332:  * Generate the default .wombo-combo/config.json content string (for `woco init`).\n333:  */\n334: export function generateDefaultConfig(): string {\n335:   return JSON.stringify(DEFAULT_CONFIG, null, 2) + \"\\n\";\n336: }\n\n(End of file - total 336 lines)\n</content>","title":"src/config.ts","metadata":{"preview":"/**\n * config.ts — Load .wombo-combo/config.json, merge with defaults, validate, expose typed config.\n *\n * The config file lives at .wombo-combo/config.json inside the target project root.\n * All values have sensible defaults so minimal config works out of the box.\n */\n\nimport { readFileSync, existsSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\nimport type { MultiplexerPreference } from \"./lib/multiplexer.js\";\n\n// ---------------------------------------------------------------------------\n// .wombo-combo directory constant\n// ---------------------------------------------------------------------------\n\n/** Name of the directory that holds all wombo-combo files */\nexport const WOMBO_DIR = \".wombo-combo\";\n\n// ---------------------------------------------------------------------------\n// Types","truncated":false,"loaded":[]},"time":{"start":1773433289336,"end":1773433289440}}}}
{"type":"tool_use","timestamp":1773433289834,"sessionID":"ses_31723c315ffeTdWKv3RfQTSDr6","part":{"id":"prt_ce8dc7a88001y6IcZXVJ8Koa0p","sessionID":"ses_31723c315ffeTdWKv3RfQTSDr6","messageID":"msg_ce8dc6b94001hpGOh4fBLb0XWV","type":"tool","callID":"toolu_vrtx_01S2U6ufAXTPdgwqTxDzNjUP","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-tdd-test-detection/src/lib/worktree.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-tdd-test-detection/src/lib/worktree.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * worktree.ts — Git worktree lifecycle management.\n3:  *\n4:  * Responsibilities:\n5:  *   - Create feature branches from a base branch\n6:  *   - Create git worktrees for each feature branch\n7:  *   - Run install command in worktrees\n8:  *   - List and remove worktrees\n9:  *   - Copy agent config files into worktrees\n10:  *\n11:  * IMPORTANT: Heavy operations (createWorktree, installDeps) are async\n12:  * to allow true parallelism with Promise.all.\n13:  */\n14: \n15: import { exec, execSync } from \"node:child_process\";\n16: import { existsSync, cpSync, statSync } from \"node:fs\";\n17: import { resolve, dirname, basename } from \"node:path\";\n18: import type { WomboConfig } from \"../config.js\";\n19: \n20: // ---------------------------------------------------------------------------\n21: // Types\n22: // ---------------------------------------------------------------------------\n23: \n24: export interface WorktreeInfo {\n25:   path: string;\n26:   branch: string;\n27:   head: string;\n28:   bare: boolean;\n29: }\n30: \n31: // ---------------------------------------------------------------------------\n32: // Diagnostic Logger\n33: // ---------------------------------------------------------------------------\n34: \n35: function ts(): string {\n36:   return new Date().toISOString().slice(11, 19); // HH:MM:SS\n37: }\n38: \n39: export function log(featureId: string, msg: string): void {\n40:   console.log(`  [${ts()}] ${featureId}: ${msg}`);\n41: }\n42: \n43: // ---------------------------------------------------------------------------\n44: // Async Command Runner\n45: // ---------------------------------------------------------------------------\n46: \n47: /**\n48:  * Run a command asynchronously. Returns stdout on success, throws on failure.\n49:  */\n50: function runAsync(\n51:   cmd: string,\n52:   opts?: { cwd?: string; timeoutMs?: number }\n53: ): Promise<string> {\n54:   return new Promise((resolve, reject) => {\n55:     exec(\n56:       cmd,\n57:       {\n58:         cwd: opts?.cwd,\n59:         encoding: \"utf-8\",\n60:         timeout: opts?.timeoutMs ?? 0,\n61:         maxBuffer: 10 * 1024 * 1024,\n62:       },\n63:       (error, stdout, stderr) => {\n64:         if (error) {\n65:           const errMsg = stderr?.trim() || stdout?.trim() || error.message;\n66:           reject(new Error(`Command failed: ${cmd}\\n${errMsg}`));\n67:         } else {\n68:           resolve((stdout ?? \"\").trim());\n69:         }\n70:       }\n71:     );\n72:   });\n73: }\n74: \n75: /**\n76:  * Synchronous run — only for quick, non-blocking operations.\n77:  */\n78: function runSync(\n79:   cmd: string,\n80:   opts?: { cwd?: string; silent?: boolean; timeoutMs?: number }\n81: ): string {\n82:   try {\n83:     return execSync(cmd, {\n84:       cwd: opts?.cwd,\n85:       encoding: \"utf-8\",\n86:       stdio: opts?.silent ? \"pipe\" : [\"pipe\", \"pipe\", \"pipe\"],\n87:       timeout: opts?.timeoutMs,\n88:       maxBuffer: 10 * 1024 * 1024,\n89:     }).trim();\n90:   } catch (err: any) {\n91:     const stderr = err.stderr?.toString().trim() || \"\";\n92:     const stdout = err.stdout?.toString().trim() || \"\";\n93:     throw new Error(\n94:       `Command failed: ${cmd}\\n${stderr || stdout || err.message}`\n95:     );\n96:   }\n97: }\n98: \n99: // ---------------------------------------------------------------------------\n100: // Branch Management\n101: // ---------------------------------------------------------------------------\n102: \n103: /**\n104:  * Create a feature branch from the base branch.\n105:  * If it already exists and is NOT checked out in a worktree, reset it.\n106:  * If it's checked out in a worktree, leave it alone (resume case).\n107:  */\n108: async function createBranch(\n109:   projectRoot: string,\n110:   branchName: string,\n111:   baseBranch: string\n112: ): Promise<void> {\n113:   const existing = await runAsync(\n114:     `git branch --list \"${branchName}\"`,\n115:     { cwd: projectRoot }\n116:   );\n117:   if (existing.trim()) {\n118:     // Branch exists — try to delete and recreate.\n119:     // If deletion fails (e.g. checked out in worktree), that's fine —\n120:     // we'll reuse the existing branch with its work intact.\n121:     try {\n122:       await runAsync(`git branch -D \"${branchName}\"`, { cwd: projectRoot });\n123:     } catch {\n124:       // Branch is checked out in a worktree — reuse as-is\n125:       return;\n126:     }\n127:   }\n128:   await runAsync(`git branch \"${branchName}\" \"${baseBranch}\"`, {\n129:     cwd: projectRoot,\n130:   });\n131: }\n132: \n133: /**\n134:  * Generate the branch name for a feature using config prefix.\n135:  */\n136: export function featureBranchName(\n137:   featureId: string,\n138:   config: WomboConfig\n139: ): string {\n140:   return `${config.git.branchPrefix}${featureId}`;\n141: }\n142: \n143: /**\n144:  * Generate the worktree path for a feature (sibling directory to project root).\n145:  */\n146: export function worktreePath(\n147:   projectRoot: string,\n148:   featureId: string,\n149:   config: WomboConfig\n150: ): string {\n151:   const parentDir = dirname(projectRoot);\n152:   return resolve(parentDir, `${config.git.worktreePrefix}${featureId}`);\n153: }\n154: \n155: // ---------------------------------------------------------------------------\n156: // Worktree Lifecycle (async)\n157: // ---------------------------------------------------------------------------\n158: \n159: /**\n160:  * Create a git worktree for a feature branch.\n161:  * Returns the absolute path to the worktree.\n162:  *\n163:  * If a valid worktree already exists at the expected path (has .git file),\n164:  * reuses it — this is essential for the resume case where worktrees have\n165:  * real work but may be missing node_modules.\n166:  */\n167: export async function createWorktree(\n168:   projectRoot: string,\n169:   featureId: string,\n170:   baseBranch: string,\n171:   config: WomboConfig\n172: ): Promise<string> {\n173:   const branch = featureBranchName(featureId, config);\n174:   const wtPath = worktreePath(projectRoot, featureId, config);\n175: \n176:   // If a valid worktree already exists, reuse it (resume case).\n177:   // A git worktree has a .git *file* (not directory) pointing to the main repo.\n178:   if (existsSync(wtPath) && existsSync(resolve(wtPath, \".git\"))) {\n179:     log(featureId, \"reusing existing worktree (has work)\");\n180:     // Still copy config files in case they're missing\n181:     copyConfigFiles(projectRoot, wtPath, featureId, config);\n182:     return wtPath;\n183:   }\n184: \n185:   // Create the branch if it doesn't exist\n186:   log(featureId, \"creating branch...\");\n187:   await createBranch(projectRoot, branch, baseBranch);\n188: \n189:   // Remove existing worktree directory if present but invalid\n190:   if (existsSync(wtPath)) {\n191:     log(featureId, \"removing old worktree...\");\n192:     try {\n193:       await runAsync(`git worktree remove --force \"${wtPath}\"`, {\n194:         cwd: projectRoot,\n195:       });\n196:     } catch {\n197:       await runAsync(`rm -rf \"${wtPath}\"`);\n198:       await runAsync(`git worktree prune`, { cwd: projectRoot });\n199:     }\n200:   }\n201: \n202:   // Create the worktree\n203:   log(featureId, \"creating worktree...\");\n204:   await runAsync(`git worktree add \"${wtPath}\" \"${branch}\"`, {\n205:     cwd: projectRoot,\n206:   });\n207: \n208:   // Copy agent config files into worktree\n209:   copyConfigFiles(projectRoot, wtPath, featureId, config);\n210: \n211:   log(featureId, \"worktree ready\");\n212:   return wtPath;\n213: }\n214: \n215: /**\n216:  * Copy agent config files from project root into a worktree.\n217:  * Best-effort — logs warnings but doesn't throw.\n218:  */\n219: function copyConfigFiles(\n220:   projectRoot: string,\n221:   wtPath: string,\n222:   featureId: string,\n223:   config: WomboConfig\n224: ): void {\n225:   for (const configFile of config.agent.configFiles) {\n226:     const srcPath = resolve(projectRoot, configFile);\n227:     if (!existsSync(srcPath)) continue;\n228: \n229:     const destPath = resolve(wtPath, configFile);\n230:     try {\n231:       const stat = statSync(srcPath);\n232:       if (stat.isDirectory()) {\n233:         cpSync(srcPath, destPath, { recursive: true });\n234:       } else {\n235:         cpSync(srcPath, destPath);\n236:       }\n237:     } catch {\n238:       // Non-critical — best effort\n239:     }\n240:   }\n241: \n242:   // Verify all config files were copied successfully\n243:   verifyConfigFiles(projectRoot, wtPath, featureId, config);\n244: }\n245: \n246: // ---------------------------------------------------------------------------\n247: // Config File Verification\n248: // ---------------------------------------------------------------------------\n249: \n250: /**\n251:  * Verify that all expected config files were copied into the worktree.\n252:  * Logs a warning for any that are missing. This is a safety net on top\n253:  * of the best-effort cpSync logic in createWorktree.\n254:  */\n255: function verifyConfigFiles(\n256:   projectRoot: string,\n257:   wtPath: string,\n258:   featureId: string,\n259:   config: WomboConfig\n260: ): void {\n261:   const missing: string[] = [];\n262: \n263:   for (const configFile of config.agent.configFiles) {\n264:     const srcPath = resolve(projectRoot, configFile);\n265:     const destPath = resolve(wtPath, configFile);\n266: \n267:     // Only check files/dirs that exist in the source project\n268:     if (!existsSync(srcPath)) continue;\n269: \n270:     if (!existsSync(destPath)) {\n271:       missing.push(configFile);\n272:     }\n273:   }\n274: \n275:   if (missing.length > 0) {\n276:     log(\n277:       featureId,\n278:       `\\x1b[33mWARNING\\x1b[0m: config files missing in worktree: ${missing.join(\", \")}`\n279:     );\n280:   }\n281: }\n282: \n283: /**\n284:  * Install dependencies in a worktree.\n285:  */\n286: export async function installDeps(\n287:   wtPath: string,\n288:   featureId: string,\n289:   config: WomboConfig\n290: ): Promise<void> {\n291:   log(featureId, `running ${config.install.command}...`);\n292:   const start = Date.now();\n293:   await runAsync(config.install.command, {\n294:     cwd: wtPath,\n295:     timeoutMs: config.install.timeout,\n296:   });\n297:   const elapsed = ((Date.now() - start) / 1000).toFixed(1);\n298:   log(featureId, `install done (${elapsed}s)`);\n299: }\n300: \n301: /**\n302:  * Check if a worktree already exists and has node_modules (fully ready).\n303:  */\n304: export function worktreeReady(wtPath: string): boolean {\n305:   return (\n306:     existsSync(wtPath) &&\n307:     existsSync(resolve(wtPath, \"node_modules\"))\n308:   );\n309: }\n310: \n311: /**\n312:  * Check if a valid git worktree exists at the path (may lack node_modules).\n313:  * A git worktree has a .git *file* (not directory) pointing to the main repo.\n314:  */\n315: export function worktreeExists(wtPath: string): boolean {\n316:   return existsSync(wtPath) && existsSync(resolve(wtPath, \".git\"));\n317: }\n318: \n319: /**\n320:  * Check if a local branch exists in the repository.\n321:  * Uses `git rev-parse --verify` which is the canonical way to check branch existence.\n322:  */\n323: export function branchExists(projectRoot: string, branchName: string): boolean {\n324:   try {\n325:     runSync(`git rev-parse --verify \"refs/heads/${branchName}\"`, {\n326:       cwd: projectRoot,\n327:       silent: true,\n328:     });\n329:     return true;\n330:   } catch {\n331:     return false;\n332:   }\n333: }\n334: \n335: // ---------------------------------------------------------------------------\n336: // Worktree Listing / Cleanup (sync)\n337: // ---------------------------------------------------------------------------\n338: \n339: /**\n340:  * List all git worktrees.\n341:  */\n342: export function listWorktrees(projectRoot: string): WorktreeInfo[] {\n343:   const output = runSync(\"git worktree list --porcelain\", {\n344:     cwd: projectRoot,\n345:     silent: true,\n346:   });\n347:   if (!output) return [];\n348: \n349:   const worktrees: WorktreeInfo[] = [];\n350:   let current: Partial<WorktreeInfo> = {};\n351: \n352:   for (const line of output.split(\"\\n\")) {\n353:     if (line.startsWith(\"worktree \")) {\n354:       if (current.path) worktrees.push(current as WorktreeInfo);\n355:       current = { path: line.slice(9), bare: false };\n356:     } else if (line.startsWith(\"HEAD \")) {\n357:       current.head = line.slice(5);\n358:     } else if (line.startsWith(\"branch \")) {\n359:       current.branch = line.slice(7).replace(\"refs/heads/\", \"\");\n360:     } else if (line === \"bare\") {\n361:       current.bare = true;\n362:     } else if (line === \"\" && current.path) {\n363:       worktrees.push(current as WorktreeInfo);\n364:       current = {};\n365:     }\n366:   }\n367:   if (current.path) worktrees.push(current as WorktreeInfo);\n368: \n369:   return worktrees;\n370: }\n371: \n372: /**\n373:  * List only wombo-related worktrees.\n374:  *\n375:  * SAFETY: Filters by checking that the *basename* of the worktree path\n376:  * starts with the worktreePrefix. A naive `.includes()` on the full path\n377:  * would match the main repo itself if its directory name contained the\n378:  * prefix (e.g. \"wombo-combo\" contains \"wombo-\"), causing cleanup to\n379:  * destroy the project root.\n380:  *\n381:  * Additionally, the main repo worktree (projectRoot) is always excluded\n382:  * as a defensive guard.\n383:  */\n384: export function listWomboWorktrees(\n385:   projectRoot: string,\n386:   config: WomboConfig\n387: ): WorktreeInfo[] {\n388:   const resolvedRoot = resolve(projectRoot);\n389:   return listWorktrees(projectRoot).filter((wt) => {\n390:     // Never include the main project root\n391:     if (resolve(wt.path) === resolvedRoot) return false;\n392:     // Match only worktrees whose directory name starts with the prefix\n393:     return basename(wt.path).startsWith(config.git.worktreePrefix);\n394:   });\n395: }\n396: \n397: /**\n398:  * Remove a worktree and optionally delete its branch.\n399:  *\n400:  * SAFETY: Refuses to remove the project root itself. This is a hard guard\n401:  * against bugs in worktree filtering that could otherwise destroy the main repo.\n402:  */\n403: export function removeWorktree(\n404:   projectRoot: string,\n405:   wtPath: string,\n406:   deleteBranchToo: boolean = true\n407: ): void {\n408:   // Hard safety check: never remove the main project root\n409:   if (resolve(wtPath) === resolve(projectRoot)) {\n410:     throw new Error(\n411:       `SAFETY: refusing to remove project root as worktree: ${wtPath}`\n412:     );\n413:   }\n414: \n415:   const worktrees = listWorktrees(projectRoot);\n416:   const wt = worktrees.find((w) => w.path === wtPath);\n417: \n418:   try {\n419:     runSync(`git worktree remove --force \"${wtPath}\"`, { cwd: projectRoot });\n420:   } catch {\n421:     if (existsSync(wtPath)) {\n422:       runSync(`rm -rf \"${wtPath}\"`);\n423:     }\n424:     runSync(\"git worktree prune\", { cwd: projectRoot });\n425:   }\n426: \n427:   if (deleteBranchToo && wt?.branch) {\n428:     try {\n429:       runSync(`git branch -D \"${wt.branch}\"`, {\n430:         cwd: projectRoot,\n431:         silent: true,\n432:       });\n433:     } catch {\n434:       // Branch may have been merged or already deleted\n435:     }\n436:   }\n437: }\n438: \n439: /**\n440:  * Check if a feature branch has any commits beyond the base branch.\n441:  * Returns true if the branch has diverged (i.e., the agent made commits).\n442:  */\n443: export function branchHasChanges(\n444:   projectRoot: string,\n445:   branch: string,\n446:   baseBranch: string\n447: ): boolean {\n448:   try {\n449:     const count = runSync(\n450:       `git rev-list --count \"${baseBranch}..${branch}\"`,\n451:       { cwd: projectRoot, silent: true }\n452:     );\n453:     return parseInt(count, 10) > 0;\n454:   } catch {\n455:     // If the branch doesn't exist or git fails, assume no changes\n456:     return false;\n457:   }\n458: }\n459: \n460: /**\n461:  * Remove all wombo-related worktrees and prune.\n462:  */\n463: export function cleanupAllWorktrees(\n464:   projectRoot: string,\n465:   config: WomboConfig\n466: ): number {\n467:   const womboWorktrees = listWomboWorktrees(projectRoot, config);\n468:   let removed = 0;\n469:   for (const wt of womboWorktrees) {\n470:     try {\n471:       removeWorktree(projectRoot, wt.path, false);\n472:       removed++;\n473:     } catch (err: any) {\n474:       console.error(`Failed to remove worktree ${wt.path}: ${err.message}`);\n475:     }\n476:   }\n477:   try {\n478:     runSync(\"git worktree prune\", { cwd: projectRoot });\n479:   } catch {\n480:     // Prune is best-effort — may fail if repo state is already clean\n481:   }\n482:   return removed;\n483: }\n\n(End of file - total 483 lines)\n</content>","title":"src/lib/worktree.ts","metadata":{"preview":"/**\n * worktree.ts — Git worktree lifecycle management.\n *\n * Responsibilities:\n *   - Create feature branches from a base branch\n *   - Create git worktrees for each feature branch\n *   - Run install command in worktrees\n *   - List and remove worktrees\n *   - Copy agent config files into worktrees\n *\n * IMPORTANT: Heavy operations (createWorktree, installDeps) are async\n * to allow true parallelism with Promise.all.\n */\n\nimport { exec, execSync } from \"node:child_process\";\nimport { existsSync, cpSync, statSync } from \"node:fs\";\nimport { resolve, dirname, basename } from \"node:path\";\nimport type { WomboConfig } from \"../config.js\";\n\n// ---------------------------------------------------------------------------","truncated":false,"loaded":[]},"time":{"start":1773433289797,"end":1773433289826}}}}
{"type":"text","timestamp":1773433290417,"sessionID":"ses_31723c315ffeTdWKv3RfQTSDr6","part":{"id":"prt_ce8dc7661001ZJYNGtJi82q2yv","sessionID":"ses_31723c315ffeTdWKv3RfQTSDr6","messageID":"msg_ce8dc6b94001hpGOh4fBLb0XWV","type":"text","text":"Now let me read the key lib files to understand patterns used in the codebase:","time":{"start":1773433290415,"end":1773433290415}}}
{"type":"tool_use","timestamp":1773433290458,"sessionID":"ses_31723c315ffeTdWKv3RfQTSDr6","part":{"id":"prt_ce8dc7ca1001r8Bzf352l0AY1O","sessionID":"ses_31723c315ffeTdWKv3RfQTSDr6","messageID":"msg_ce8dc6b94001hpGOh4fBLb0XWV","type":"tool","callID":"toolu_vrtx_01PA6UVXJzb1fZnjDSmFnaEt","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-tdd-test-detection/src/lib/verifier.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-tdd-test-detection/src/lib/verifier.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * verifier.ts — Build verification in worktrees.\n3:  *\n4:  * Responsibilities:\n5:  *   - Run the project build command in a worktree\n6:  *   - Capture and parse build output\n7:  *   - Determine pass/fail\n8:  *   - Extract error messages for retry prompts\n9:  *   - Run browser-based verification when enabled\n10:  *\n11:  * IMPORTANT: runBuild is ASYNC — does not block the event loop.\n12:  */\n13: \n14: import { exec } from \"node:child_process\";\n15: import { existsSync } from \"node:fs\";\n16: import { resolve } from \"node:path\";\n17: import type { WomboConfig } from \"../config.js\";\n18: import {\n19:   runBrowserVerification,\n20:   extractBrowserErrorSummary,\n21:   type BrowserVerificationResult,\n22: } from \"./browser-verifier.js\";\n23: \n24: // ---------------------------------------------------------------------------\n25: // Types\n26: // ---------------------------------------------------------------------------\n27: \n28: export interface BuildResult {\n29:   passed: boolean;\n30:   exitCode: number;\n31:   stdout: string;\n32:   stderr: string;\n33:   /** Combined output, truncated for use in retry prompts */\n34:   errorSummary: string;\n35:   /** Duration in milliseconds */\n36:   durationMs: number;\n37: }\n38: \n39: /**\n40:  * Combined result of build verification + browser verification.\n41:  */\n42: export interface FullVerificationResult {\n43:   /** Build result (always runs) */\n44:   build: BuildResult;\n45:   /** Browser verification result (may be skipped) */\n46:   browser: BrowserVerificationResult;\n47:   /** Overall pass: build passed AND browser passed (or was skipped) */\n48:   overallPassed: boolean;\n49:   /** Combined error summary for retry prompts */\n50:   combinedErrorSummary: string;\n51: }\n52: \n53: // ---------------------------------------------------------------------------\n54: // Build Verification\n55: // ---------------------------------------------------------------------------\n56: \n57: /**\n58:  * Run the build command in a worktree directory.\n59:  * Uses config for the build command and timeout.\n60:  */\n61: export function runBuild(\n62:   worktreePath: string,\n63:   config: WomboConfig\n64: ): Promise<BuildResult> {\n65:   return new Promise((resolvePromise) => {\n66:     const start = Date.now();\n67: \n68:     exec(\n69:       config.build.command,\n70:       {\n71:         cwd: worktreePath,\n72:         encoding: \"utf-8\",\n73:         timeout: config.build.timeout,\n74:         maxBuffer: 10 * 1024 * 1024,\n75:       },\n76:       (error, stdout, stderr) => {\n77:         const durationMs = Date.now() - start;\n78:         const exitCode = error ? (error as any).code ?? 1 : 0;\n79:         const passed = !error;\n80: \n81:         let errorSummary = \"\";\n82:         if (!passed) {\n83:           errorSummary = extractErrorSummary(stdout ?? \"\", stderr ?? \"\");\n84:         }\n85: \n86:         resolvePromise({\n87:           passed,\n88:           exitCode,\n89:           stdout: stdout ?? \"\",\n90:           stderr: stderr ?? \"\",\n91:           errorSummary,\n92:           durationMs,\n93:         });\n94:       }\n95:     );\n96:   });\n97: }\n98: \n99: // ---------------------------------------------------------------------------\n100: // Error Extraction\n101: // ---------------------------------------------------------------------------\n102: \n103: /**\n104:  * Extract a concise error summary from build output.\n105:  */\n106: function extractErrorSummary(stdout: string, stderr: string): string {\n107:   const combined = stdout + \"\\n\" + stderr;\n108:   const lines = combined.split(\"\\n\");\n109: \n110:   const errorLines: string[] = [];\n111:   let capturing = false;\n112:   let contextLines = 0;\n113: \n114:   for (const line of lines) {\n115:     const isError =\n116:       /error/i.test(line) &&\n117:       !/warning/i.test(line) &&\n118:       !/^info/i.test(line);\n119:     const isTypeError = /TS\\d+/.test(line);\n120: \n121:     if (isError || isTypeError) {\n122:       capturing = true;\n123:       contextLines = 0;\n124:       errorLines.push(line);\n125:     } else if (capturing) {\n126:       contextLines++;\n127:       if (contextLines <= 3) {\n128:         errorLines.push(line);\n129:       } else {\n130:         capturing = false;\n131:       }\n132:     }\n133:   }\n134: \n135:   if (errorLines.length === 0) {\n136:     const tail = lines.slice(-50).join(\"\\n\");\n137:     return truncate(tail, 4000);\n138:   }\n139: \n140:   return truncate(errorLines.join(\"\\n\"), 4000);\n141: }\n142: \n143: /**\n144:  * Truncate a string to maxLen characters.\n145:  */\n146: function truncate(s: string, maxLen: number): string {\n147:   if (s.length <= maxLen) return s;\n148:   return s.slice(0, maxLen) + \"\\n\\n[... truncated, showing first 4000 chars]\";\n149: }\n150: \n151: // ---------------------------------------------------------------------------\n152: // Quick Check\n153: // ---------------------------------------------------------------------------\n154: \n155: /**\n156:  * Quick check if the build artifacts exist.\n157:  */\n158: export function hasBuildArtifacts(\n159:   worktreePath: string,\n160:   config: WomboConfig\n161: ): boolean {\n162:   try {\n163:     return existsSync(resolve(worktreePath, config.build.artifactDir));\n164:   } catch {\n165:     return false;\n166:   }\n167: }\n168: \n169: // ---------------------------------------------------------------------------\n170: // Full Verification (Build + Browser)\n171: // ---------------------------------------------------------------------------\n172: \n173: /**\n174:  * Run the complete verification pipeline:\n175:  *   1. Run the build command\n176:  *   2. If build passes and browser testing is enabled, run browser tests\n177:  *\n178:  * Browser testing is additive — it runs AFTER the build passes and is\n179:  * skipped if the build fails (no point testing a broken build in browser).\n180:  */\n181: export async function runFullVerification(\n182:   worktreePath: string,\n183:   featureId: string,\n184:   config: WomboConfig\n185: ): Promise<FullVerificationResult> {\n186:   // Step 1: Build verification (always runs)\n187:   const buildResult = await runBuild(worktreePath, config);\n188: \n189:   // If build failed, skip browser testing\n190:   if (!buildResult.passed) {\n191:     return {\n192:       build: buildResult,\n193:       browser: {\n194:         ran: false,\n195:         skipReason: \"Skipped because build failed\",\n196:         browserResult: null,\n197:       },\n198:       overallPassed: false,\n199:       combinedErrorSummary: buildResult.errorSummary,\n200:     };\n201:   }\n202: \n203:   // Step 2: Browser verification (runs only if build passed and browser enabled)\n204:   const browserResult = await runBrowserVerification({\n205:     worktreePath,\n206:     featureId,\n207:     config,\n208:   });\n209: \n210:   // Determine overall pass\n211:   const browserPassed = !browserResult.ran || (browserResult.browserResult?.allPassed ?? true);\n212:   const overallPassed = buildResult.passed && browserPassed;\n213: \n214:   // Combine error summaries\n215:   let combinedErrorSummary = \"\";\n216:   if (!buildResult.passed) {\n217:     combinedErrorSummary = buildResult.errorSummary;\n218:   }\n219:   if (browserResult.ran && browserResult.browserResult && !browserResult.browserResult.allPassed) {\n220:     const browserErrors = extractBrowserErrorSummary(browserResult.browserResult);\n221:     combinedErrorSummary = combinedErrorSummary\n222:       ? `${combinedErrorSummary}\\n\\n--- Browser Test Errors ---\\n\\n${browserErrors}`\n223:       : browserErrors;\n224:   }\n225: \n226:   return {\n227:     build: buildResult,\n228:     browser: browserResult,\n229:     overallPassed,\n230:     combinedErrorSummary,\n231:   };\n232: }\n\n(End of file - total 232 lines)\n</content>","title":"src/lib/verifier.ts","metadata":{"preview":"/**\n * verifier.ts — Build verification in worktrees.\n *\n * Responsibilities:\n *   - Run the project build command in a worktree\n *   - Capture and parse build output\n *   - Determine pass/fail\n *   - Extract error messages for retry prompts\n *   - Run browser-based verification when enabled\n *\n * IMPORTANT: runBuild is ASYNC — does not block the event loop.\n */\n\nimport { exec } from \"node:child_process\";\nimport { existsSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\nimport type { WomboConfig } from \"../config.js\";\nimport {\n  runBrowserVerification,\n  extractBrowserErrorSummary,","truncated":false,"loaded":[]},"time":{"start":1773433290393,"end":1773433290441}}}}
