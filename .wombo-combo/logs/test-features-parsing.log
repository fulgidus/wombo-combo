).toBe(\"help\");\n37:   });\n38: \n39:   test(\"parses launch command\", () => {\n40:     const result = parseArgs(argv(\"launch\"));\n41:     expect(result.command).toBe(\"launch\");\n42:   });\n43: \n44:   test(\"parses status command\", () => {\n45:     const result = parseArgs(argv(\"status\"));\n46:     expect(result.command).toBe(\"status\");\n47:   });\n48: \n49:   test(\"parses cleanup command\", () => {\n50:     const result = parseArgs(argv(\"cleanup\"));\n\n(Showing lines 1-50 of 414. Use offset=51 to continue.)\n</content>","title":"tests/arg-parsing.test.ts","metadata":{"preview":"/**\n * arg-parsing.test.ts — Unit tests for CLI argument parsing.\n *\n * Coverage:\n *   - Basic command parsing\n *   - Features subcommand routing\n *   - Flag parsing (boolean flags, value flags)\n *   - Trailing flags after positional args\n *   - Missing values for value-expecting flags\n *   - Flag collisions and priority\n *   - Positional argument handling (featureId, title)\n *   - Edge cases: empty args, unknown flags, repeated flags\n */\n\nimport { describe, test, expect } from \"bun:test\";\nimport { parseArgs } from \"../src/index.js\";\n\n// Helper to simulate argv from CLI input. We need to prepend \"bun\" and \"script\"\n// since parseArgs does argv.slice(2).\nfunction argv(...args: string[]): string[] {","truncated":true,"loaded":[]},"time":{"start":1773433302363,"end":1773433302422}}}}
