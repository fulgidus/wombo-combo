{"type":"tool_use","timestamp":1773433295514,"sessionID":"ses_31723c3afffeEcJRyyogDgXrE8","part":{"id":"prt_ce8dc8e69001G9hSBfGj3IM08u","sessionID":"ses_31723c3afffeEcJRyyogDgXrE8","messageID":"msg_ce8dc838d001UfuJhCVniCYejq","type":"tool","callID":"toolu_vrtx_01VmycPKcFC3kWcGpu2Z1NYW","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-test-features-parsing/tests/features.test.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-test-features-parsing/tests/features.test.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * features.test.ts — Unit tests for tasks YAML parsing, validation,\n3:  * duration parsing, and dependency resolution.\n4:  *\n5:  * Coverage:\n6:  *   - loadFeatures with null tasks, empty arrays, valid data\n7:  *   - parseDurationMinutes for ISO 8601 durations\n8:  *   - formatDuration for human-readable output\n9:  *   - Dependency resolution (areDependenciesMet, getReadyFeatures)\n10:  *   - normalizeTask defaults\n11:  *   - createBlankFeature\n12:  *   - findFeatureById (recursive search)\n13:  *   - selectFeatures strategies\n14:  *   - YAML schema edge cases\n15:  */\n16: \n17: import { describe, test, expect, beforeEach, afterEach } from \"bun:test\";\n18: import { mkdtempSync, writeFileSync, rmSync, mkdirSync } from \"node:fs\";\n19: import { join } from \"node:path\";\n20: import { tmpdir } from \"node:os\";\n21: import type { WomboConfig } from \"../src/config.js\";\n22: import {\n23:   loadFeatures,\n24:   parseDurationMinutes,\n25:   formatDuration,\n26:   areDependenciesMet,\n27:   getReadyFeatures,\n28:   getDoneFeatureIds,\n29:   selectFeatures,\n30:   createBlankFeature,\n31:   findFeatureById,\n32:   allFeatureIds,\n33:   featureSummary,\n34:   PRIORITY_ORDER,\n35:   DIFFICULTY_ORDER,\n36: } from \"../src/lib/tasks.js\";\n37: import type {\n38:   Feature,\n39:   FeaturesFile,\n40:   Subtask,\n41:   Priority,\n42:   Difficulty,\n43: } from \"../src/lib/tasks.js\";\n44: \n45: // ---------------------------------------------------------------------------\n46: // Helpers\n47: // ---------------------------------------------------------------------------\n48: \n49: function makeConfig(overrides?: Partial<WomboConfig>): WomboConfig {\n50:   return {\n51:     tasksDir: \"tasks\",\n52:     archiveDir: \"archive\",\n53:     baseBranch: \"main\",\n54:     build: { command: \"bun run build\", timeout: 300_000, artifactDir: \"dist\" },\n55:     install: { command: \"bun install\", timeout: 120_000 },\n56:     git: {\n57:       branchPrefix: \"feature/\",\n58:       worktreePrefix: \"wombo-\",\n59:       remote: \"origin\",\n60:       mergeStrategy: \"--no-ff\",\n61:     },\n62:     agent: {\n63:       bin: null,\n64:       name: \"generalist-agent\",\n65:       configFiles: [],\n66:       tmuxPrefix: \"wombo\",\n67:       multiplexer: \"auto\",\n68:     },\n69:     portless: {\n70:       enabled: true,\n71:       bin: null,\n72:       proxyPort: 1355,\n73:       https: false,\n74:     },\n75:     backup: { maxBackups: 5 },\n76:     defaults: { maxConcurrent: 6, maxRetries: 2 },\n77:     browser: {\n78:       enabled: false,\n79:       bin: null,\n80:       headless: true,\n81:       testCommand: null,\n82:       launchTimeout: 30_000,\n83:       testTimeout: 60_000,\n84:       defaultViewport: { width: 1280, height: 720 },\n85:     },\n86:     agentRegistry: {\n87:       mode: \"auto\",\n88:       source: \"msitarzewski/agency-agents\",\n89:       cacheDir: \"agents-cache\",\n90:     },\n91:     ...overrides,\n92:   };\n93: }\n94: \n95: function makeFeature(overrides?: Partial<Feature>): Feature {\n96:   return {\n97:     id: \"test-feature\",\n98:     title: \"Test Feature\",\n99:     description: \"A test feature\",\n100:     status: \"backlog\",\n101:     completion: 0,\n102:     difficulty: \"medium\",\n103:     priority: \"medium\",\n104:     depends_on: [],\n105:     effort: \"PT1H\",\n106:     started_at: null,\n107:     ended_at: null,\n108:     constraints: [],\n109:     forbidden: [],\n110:     references: [],\n111:     notes: [],\n112:     subtasks: [],\n113:     ...overrides,\n114:   };\n115: }\n116: \n117: function makeFeaturesFile(\n118:   tasks: Feature[] = [],\n119:   archive: Feature[] = []\n120: ): FeaturesFile {\n121:   return {\n122:     version: \"1\",\n123:     meta: {\n124:       created_at: \"2025-01-01T00:00:00Z\",\n125:       updated_at: \"2025-01-01T00:00:00Z\",\n126:       project: \"test-project\",\n127:       generator: \"test\",\n128:       maintainer: \"tester\",\n129:     },\n130:     tasks,\n131:     archive,\n132:   };\n133: }\n134: \n135: /**\n136:  * Write a YAML string to the .wombo-combo/tasks.yml inside the given tmpDir.\n137:  * Also creates the .wombo-combo directory.\n138:  */\n139: function writeTasksYaml(dir: string, yaml: string): void {\n140:   mkdirSync(join(dir, \".wombo-combo\"), { recursive: true });\n141:   writeFileSync(join(dir, \".wombo-combo\", \"tasks.yml\"), yaml);\n142: }\n143: \n144: /**\n145:  * Write archive YAML to .wombo-combo/archive.yml.\n146:  */\n147: function writeArchiveYaml(dir: string, yaml: string): void {\n148:   mkdirSync(join(dir, \".wombo-combo\"), { recursive: true });\n149:   writeFileSync(join(dir, \".wombo-combo\", \"archive.yml\"), yaml);\n150: }\n151: \n152: let tmpDir: string;\n153: \n154: beforeEach(() => {\n155:   tmpDir = mkdtempSync(join(tmpdir(), \"wombo-test-features-\"));\n156: });\n157: \n158: afterEach(() => {\n159:   rmSync(tmpDir, { recursive: true, force: true });\n160: });\n161: \n162: // ---------------------------------------------------------------------------\n163: // ISO 8601 Duration Parsing\n164: // ---------------------------------------------------------------------------\n165: \n166: describe(\"parseDurationMinutes\", () => {\n167:   test(\"parses hours only\", () => {\n168:     expect(parseDurationMinutes(\"PT1H\")).toBe(60);\n169:     expect(parseDurationMinutes(\"PT2H\")).toBe(120);\n170:     expect(parseDurationMinutes(\"PT0H\")).toBe(0);\n171:   });\n172: \n173:   test(\"parses minutes only\", () => {\n174:     expect(parseDurationMinutes(\"PT30M\")).toBe(30);\n175:     expect(parseDurationMinutes(\"PT1M\")).toBe(1);\n176:     expect(parseDurationMinutes(\"PT90M\")).toBe(90);\n177:   });\n178: \n179:   test(\"parses days only\", () => {\n180:     expect(parseDurationMinutes(\"P1D\")).toBe(1440);\n181:     expect(parseDurationMinutes(\"P2D\")).toBe(2880);\n182:   });\n183: \n184:   test(\"parses combined durations\", () => {\n185:     expect(parseDurationMinutes(\"PT1H30M\")).toBe(90);\n186:     expect(parseDurationMinutes(\"P1DT4H\")).toBe(1680);\n187:     expect(parseDurationMinutes(\"P2DT4H\")).toBe(3120);\n188:     expect(parseDurationMinutes(\"P1DT2H30M\")).toBe(1590);\n189:   });\n190: \n191:   test(\"parses seconds (rounds up to minutes)\", () => {\n192:     expect(parseDurationMinutes(\"PT30S\")).toBe(1); // ceil(30/60) = 1\n193:     expect(parseDurationMinutes(\"PT60S\")).toBe(1); // ceil(60/60) = 1\n194:     expect(parseDurationMinutes(\"PT61S\")).toBe(2); // ceil(61/60) = 2\n195:     expect(parseDurationMinutes(\"PT1H30S\")).toBe(61); // 60 + ceil(30/60)\n196:   });\n197: \n198:   test(\"returns Infinity for unparseable strings\", () => {\n199:     expect(parseDurationMinutes(\"\")).toBe(Infinity);\n200:     expect(parseDurationMinutes(\"invalid\")).toBe(Infinity);\n201:     expect(parseDurationMinutes(\"1H\")).toBe(Infinity); // missing P\n202:     expect(parseDurationMinutes(\"hello world\")).toBe(Infinity);\n203:   });\n204: \n205:   test(\"handles edge case: PT alone parses as zero duration\", () => {\n206:     // \"PT\" matches the regex: P with T but all time groups are optional\n207:     expect(parseDurationMinutes(\"PT\")).toBe(0);\n208:   });\n209: \n210:   test(\"handles P alone (zero duration)\", () => {\n211:     // P with no components - the regex should handle this\n212:     const result = parseDurationMinutes(\"P\");\n213:     // P alone matches /^P(?:(\\d+)D)?(?:T(?:(\\d+)H)?(?:(\\d+)M)?(?:(\\d+)S)?)?$/\n214:     // All groups are undefined, defaults to 0\n215:     expect(result).toBe(0);\n216:   });\n217: });\n218: \n219: // ---------------------------------------------------------------------------\n220: // Duration Formatting\n221: // ---------------------------------------------------------------------------\n222: \n223: describe(\"formatDuration\", () => {\n224:   test(\"formats minutes only\", () => {\n225:     expect(formatDuration(30)).toBe(\"30m\");\n226:     expect(formatDuration(1)).toBe(\"1m\");\n227:     expect(formatDuration(59)).toBe(\"59m\");\n228:   });\n229: \n230:   test(\"formats hours only\", () => {\n231:     expect(formatDuration(60)).toBe(\"1h\");\n232:     expect(formatDuration(120)).toBe(\"2h\");\n233:   });\n234: \n235:   test(\"formats hours and minutes\", () => {\n236:     expect(formatDuration(90)).toBe(\"1h 30m\");\n237:     expect(formatDuration(150)).toBe(\"2h 30m\");\n238:   });\n239: \n240:   test(\"formats days\", () => {\n241:     expect(formatDuration(1440)).toBe(\"1d\");\n242:     expect(formatDuration(2880)).toBe(\"2d\");\n243:   });\n244: \n245:   test(\"formats days and hours\", () => {\n246:     expect(formatDuration(1500)).toBe(\"1d 1h\");\n247:     expect(formatDuration(1560)).toBe(\"1d 2h\");\n248:   });\n249: \n250:   test(\"formats days, hours, and minutes\", () => {\n251:     expect(formatDuration(1530)).toBe(\"1d 1h 30m\");\n252:   });\n253: \n254:   test(\"formats Infinity as unknown\", () => {\n255:     expect(formatDuration(Infinity)).toBe(\"unknown\");\n256:   });\n257: \n258:   test(\"formats zero\", () => {\n259:     expect(formatDuration(0)).toBe(\"0m\");\n260:   });\n261: });\n262: \n263: // ---------------------------------------------------------------------------\n264: // loadFeatures — YAML parsing edge cases\n265: // ---------------------------------------------------------------------------\n266: \n267: describe(\"loadFeatures\", () => {\n268:   const config = makeConfig();\n269: \n270:   test(\"loads valid tasks file\", () => {\n271:     const yaml = `\n272: version: \"1\"\n273: meta:\n274:   created_at: \"2025-01-01T00:00:00Z\"\n275:   updated_at: \"2025-01-01T00:00:00Z\"\n276:   project: test\n277:   generator: test\n278:   maintainer: tester\n279: tasks:\n280:   - id: feat-a\n281:     title: Feature A\n282:     description: Description of A\n283:     status: backlog\n284:     completion: 0\n285:     difficulty: medium\n286:     priority: high\n287:     depends_on: []\n288:     effort: PT2H\n289:     started_at: null\n290:     ended_at: null\n291:     constraints: []\n292:     forbidden: []\n293:     references: []\n294:     notes: []\n295:     subtasks: []\n296: `;\n297:     writeTasksYaml(tmpDir, yaml);\n298:     const data = loadFeatures(tmpDir, config);\n299:     expect(data.tasks).toHaveLength(1);\n300:     expect(data.tasks[0].id).toBe(\"feat-a\");\n301:     expect(data.tasks[0].priority).toBe(\"high\");\n302:     expect(data.archive).toHaveLength(0);\n303:   });\n304: \n305:   test(\"handles null tasks (empty YAML key)\", () => {\n306:     const yaml = `\n307: version: \"1\"\n308: meta:\n309:   created_at: \"2025-01-01T00:00:00Z\"\n310:   updated_at: \"2025-01-01T00:00:00Z\"\n311:   project: test\n312:   generator: test\n313:   maintainer: tester\n314: tasks:\n315: `;\n316:     writeTasksYaml(tmpDir, yaml);\n317:     const data = loadFeatures(tmpDir, config);\n318:     expect(data.tasks).toBeArray();\n319:     expect(data.tasks).toHaveLength(0);\n320:     expect(data.archive).toBeArray();\n321:     expect(data.archive).toHaveLength(0);\n322:   });\n323: \n324:   test(\"handles tasks with null depends_on and arrays\", () => {\n325:     const yaml = `\n326: version: \"1\"\n327: meta:\n328:   created_at: \"2025-01-01T00:00:00Z\"\n329:   updated_at: \"2025-01-01T00:00:00Z\"\n330:   project: test\n331:   generator: test\n332:   maintainer: tester\n333: tasks:\n334:   - id: feat-a\n335:     title: Feature A\n336:     description: \"\"\n337:     status: backlog\n338:     completion: 0\n339:     difficulty: medium\n340:     priority: medium\n341:     effort: PT1H\n342:     started_at: null\n343:     ended_at: null\n344: `;\n345:     writeTasksYaml(tmpDir, yaml);\n346:     const data = loadFeatures(tmpDir, config);\n347:     expect(data.tasks).toHaveLength(1);\n348:     // normalizeTask should default null arrays to []\n349:     const f = data.tasks[0];\n350:     expect(f.depends_on).toBeArray();\n351:     expect(f.depends_on).toHaveLength(0);\n352:     expect(f.constraints).toBeArray();\n353:     expect(f.forbidden).toBeArray();\n354:     expect(f.references).toBeArray();\n355:     expect(f.notes).toBeArray();\n356:     expect(f.subtasks).toBeArray();\n357:   });\n358: \n359:   test(\"handles nested subtasks normalization\", () => {\n360:     const yaml = `\n361: version: \"1\"\n362: meta:\n363:   created_at: \"2025-01-01T00:00:00Z\"\n364:   updated_at: \"2025-01-01T00:00:00Z\"\n365:   project: test\n366:   generator: test\n367:   maintainer: tester\n368: tasks:\n369:   - id: feat-a\n370:     title: Feature A\n371:     description: \"\"\n372:     status: backlog\n373:     completion: 0\n374:     difficulty: medium\n375:     priority: medium\n376:     effort: PT1H\n377:     started_at: null\n378:     ended_at: null\n379:     subtasks:\n380:       - id: sub-1\n381:         title: Subtask 1\n382:         description: \"\"\n383:         status: backlog\n384:         completion: 0\n385:         difficulty: easy\n386:         priority: medium\n387:         effort: PT30M\n388:         started_at: null\n389:         ended_at: null\n390: `;\n391:     writeTasksYaml(tmpDir, yaml);\n392:     const data = loadFeatures(tmpDir, config);\n393:     const subtask = data.tasks[0].subtasks[0];\n394:     expect(subtask.id).toBe(\"sub-1\");\n395:     expect(subtask.depends_on).toBeArray();\n396:     expect(subtask.constraints).toBeArray();\n397:     expect(subtask.subtasks).toBeArray();\n398:   });\n399: \n400:   test(\"throws on corrupted YAML\", () => {\n401:     writeTasksYaml(tmpDir, \"{{{{not valid yaml::::\");\n402:     expect(() => loadFeatures(tmpDir, config)).toThrow();\n403:   });\n404: \n405:   test(\"throws on missing file\", () => {\n406:     expect(() => loadFeatures(\"/nonexistent/path\", config)).toThrow();\n407:   });\n408: \n409:   test(\"handles custom tasks file path\", () => {\n410:     const customConfig = makeConfig({ tasksFile: \"custom-tasks.yml\" });\n411:     const yaml = `\n412: version: \"1\"\n413: meta:\n414:   created_at: \"2025-01-01T00:00:00Z\"\n415:   updated_at: \"2025-01-01T00:00:00Z\"\n416:   project: test\n417:   generator: test\n418:   maintainer: tester\n419: tasks: []\n420: `;\n421:     mkdirSync(join(tmpDir, \".wombo-combo\"), { recursive: true });\n422:     writeFileSync(join(tmpDir, \".wombo-combo\", \"custom-tasks.yml\"), yaml);\n423:     const data = loadFeatures(tmpDir, customConfig);\n424:     expect(data.tasks).toHaveLength(0);\n425:   });\n426: \n427:   test(\"supports legacy 'features' YAML key\", () => {\n428:     const yaml = `\n429: version: \"1\"\n430: meta:\n431:   created_at: \"2025-01-01T00:00:00Z\"\n432:   updated_at: \"2025-01-01T00:00:00Z\"\n433:   project: test\n434:   generator: test\n435:   maintainer: tester\n436: features:\n437:   - id: legacy-feat\n438:     title: Legacy Feature\n439:     description: Loaded via features key\n440:     status: backlog\n441:     completion: 0\n442:     difficulty: medium\n443:     priority: medium\n444:     depends_on: []\n445:     effort: PT1H\n446:     started_at: null\n447:     ended_at: null\n448:     constraints: []\n449:     forbidden: []\n450:     references: []\n451:     notes: []\n452:     subtasks: []\n453: `;\n454:     writeTasksYaml(tmpDir, yaml);\n455:     const data = loadFeatures(tmpDir, config);\n456:     expect(data.tasks).toHaveLength(1);\n457:     expect(data.tasks[0].id).toBe(\"legacy-feat\");\n458:   });\n459: });\n460: \n461: // ---------------------------------------------------------------------------\n462: // Dependency Resolution\n463: // ---------------------------------------------------------------------------\n464: \n465: describe(\"areDependenciesMet\", () => {\n466:   test(\"returns true when feature has no dependencies\", () => {\n467:     const feature = makeFeature({ depends_on: [] });\n468:     const doneIds = new Set<string>();\n469:     expect(areDependenciesMet(feature, doneIds)).toBe(true);\n470:   });\n471: \n472:   test(\"returns true when all dependencies are done\", () => {\n473:     const feature = makeFeature({ depends_on: [\"dep-a\", \"dep-b\"] });\n474:     const doneIds = new Set([\"dep-a\", \"dep-b\", \"dep-c\"]);\n475:     expect(areDependenciesMet(feature, doneIds)).toBe(true);\n476:   });\n477: \n478:   test(\"returns false when some dependencies are not done\", () => {\n479:     const feature = makeFeature({ depends_on: [\"dep-a\", \"dep-b\"] });\n480:     const doneIds = new Set([\"dep-a\"]);\n481:     expect(areDependenciesMet(feature, doneIds)).toBe(false);\n482:   });\n483: \n484:   test(\"returns false when no dependencies are done\", () => {\n485:     const feature = makeFeature({ depends_on: [\"dep-a\", \"dep-b\"] });\n486:     const doneIds = new Set<string>();\n487:     expect(areDependenciesMet(feature, doneIds)).toBe(false);\n488:   });\n489: });\n490: \n491: describe(\"getDoneFeatureIds\", () => {\n492:   test(\"identifies features with done status\", () => {\n493:     const data = makeFeaturesFile([\n494:       makeFeature({ id: \"feat-done\", status: \"done\", completion: 100 }),\n495:       makeFeature({ id: \"feat-wip\", status: \"in_progress\", completion: 50 }),\n496:     ]);\n497:     const doneIds = getDoneFeatureIds(data);\n498:     expect(doneIds.has(\"feat-done\")).toBe(true);\n499:     expect(doneIds.has(\"feat-wip\")).toBe(false);\n500:   });\n501: \n502:   test(\"identifies features with 100% completion as done\", () => {\n503:     const data = makeFeaturesFile([\n504:       makeFeature({\n505:         id: \"feat-complete\",\n506:         status: \"in_review\",\n507:         completion: 100,\n508:       }),\n509:     ]);\n510:     const doneIds = getDoneFeatureIds(data);\n511:     expect(doneIds.has(\"feat-complete\")).toBe(true);\n512:   });\n513: \n514:   test(\"includes archived features as done\", () => {\n515:     const data = makeFeaturesFile(\n516:       [],\n517:       [makeFeature({ id: \"archived-feat\", status: \"done\", completion: 100 })]\n518:     );\n519:     const doneIds = getDoneFeatureIds(data);\n520:     expect(doneIds.has(\"archived-feat\")).toBe(true);\n521:   });\n522: \n523:   test(\"includes done subtasks\", () => {\n524:     const data = makeFeaturesFile([\n525:       makeFeature({\n526:         id: \"parent\",\n527:         status: \"in_progress\",\n528:         subtasks: [\n529:           {\n530:             id: \"sub-done\",\n531:             title: \"Done sub\",\n532:             description: \"\",\n533:             status: \"done\",\n534:             completion: 100,\n535:             difficulty: \"easy\",\n536:             priority: \"medium\",\n537:             depends_on: [],\n538:             effort: \"PT30M\",\n539:             started_at: null,\n540:             ended_at: null,\n541:             constraints: [],\n542:             forbidden: [],\n543:             references: [],\n544:             notes: [],\n545:             subtasks: [],\n546:           },\n547:         ],\n548:       }),\n549:     ]);\n550:     const doneIds = getDoneFeatureIds(data);\n551:     expect(doneIds.has(\"sub-done\")).toBe(true);\n552:     expect(doneIds.has(\"parent\")).toBe(false);\n553:   });\n554: });\n555: \n556: describe(\"getReadyFeatures\", () => {\n557:   test(\"returns backlog features with deps met\", () => {\n558:     const data = makeFeaturesFile([\n559:       makeFeature({ id: \"ready\", status: \"backlog\", depends_on: [] }),\n560:       makeFeature({\n561:         id: \"blocked\",\n562:         status: \"backlog\",\n563:         depends_on: [\"not-done\"],\n564:       }),\n565:       makeFeature({ id: \"in-progress\", status: \"in_progress\" }),\n566:     ]);\n567:     const ready = getReadyFeatures(data);\n568:     expect(ready).toHaveLength(1);\n569:     expect(ready[0].id).toBe(\"ready\");\n570:   });\n571: \n572:   test(\"considers archived deps as met\", () => {\n573:     const data = makeFeaturesFile(\n574:       [\n575:         makeFeature({\n576:           id: \"waiting\",\n577:           status: \"backlog\",\n578:           depends_on: [\"archived-dep\"],\n579:         }),\n580:       ],\n581:       [\n582:         makeFeature({\n583:           id: \"archived-dep\",\n584:           status: \"done\",\n585:           completion: 100,\n586:         }),\n587:       ]\n588:     );\n589:     const ready = getReadyFeatures(data);\n590:     expect(ready).toHaveLength(1);\n591:     expect(ready[0].id).toBe(\"waiting\");\n592:   });\n593: \n594:   test(\"excludes features with non-zero completion\", () => {\n595:     const data = makeFeaturesFile([\n596:       makeFeature({ id: \"partial\", status: \"backlog\", completion: 50 }),\n597:     ]);\n598:     const ready = getReadyFeatures(data);\n599:     expect(ready).toHaveLength(0);\n600:   });\n601: \n602:   test(\"returns empty array when no features are ready\", () => {\n603:     const data = makeFeaturesFile([\n604:       makeFeature({\n605:         id: \"blocked\",\n606:         status: \"backlog\",\n607:         depends_on: [\"missing\"],\n608:       }),\n609:     ]);\n610:     const ready = getReadyFeatures(data);\n611:     expect(ready).toHaveLength(0);\n612:   });\n613: });\n614: \n615: // ---------------------------------------------------------------------------\n616: // selectFeatures strategies\n617: // ---------------------------------------------------------------------------\n618: \n619: describe(\"selectFeatures\", () => {\n620:   const highPriority = makeFeature({\n621:     id: \"high-pri\",\n622:     priority: \"high\",\n623:     effort: \"PT2H\",\n624:   });\n625:   const criticalSmall = makeFeature({\n626:     id: \"critical-small\",\n627:     priority: \"critical\",\n628:     effort: \"PT30M\",\n629:   });\n630:   const mediumLong = makeFeature({\n631:     id: \"medium-long\",\n632:     priority: \"medium\",\n633:     effort: \"P1D\",\n634:   });\n635:   const lowQuick = makeFeature({\n636:     id: \"low-quick\",\n637:     priority: \"low\",\n638:     effort: \"PT15M\",\n639:     difficulty: \"easy\",\n640:   });\n641: \n642:   const data = makeFeaturesFile([highPriority, criticalSmall, mediumLong, lowQuick]);\n643: \n644:   test(\"allReady returns all ready features sorted by priority\", () => {\n645:     const selected = selectFeatures(data, { allReady: true });\n646:     expect(selected).toHaveLength(4);\n647:     expect(selected[0].id).toBe(\"critical-small\");\n648:     expect(selected[1].id).toBe(\"high-pri\");\n649:   });\n650: \n651:   test(\"topPriority selects top N by priority\", () => {\n652:     const selected = selectFeatures(data, { topPriority: 2 });\n653:     expect(selected).toHaveLength(2);\n654:     expect(selected[0].id).toBe(\"critical-small\");\n655:     expect(selected[1].id).toBe(\"high-pri\");\n656:   });\n657: \n658:   test(\"quickestWins selects N lowest effort\", () => {\n659:     const selected = selectFeatures(data, { quickestWins: 2 });\n660:     expect(selected).toHaveLength(2);\n661:     // Sorted by effort: 15m, 30m, 2h, 1d\n662:     expect(selected[0].id).toBe(\"low-quick\");\n663:     expect(selected[1].id).toBe(\"critical-small\");\n664:   });\n665: \n666:   test(\"priority filter selects matching priority\", () => {\n667:     const selected = selectFeatures(data, { priority: \"high\" });\n668:     expect(selected).toHaveLength(1);\n669:     expect(selected[0].id).toBe(\"high-pri\");\n670:   });\n671: \n672:   test(\"difficulty filter selects matching difficulty\", () => {\n673:     const selected = selectFeatures(data, { difficulty: \"easy\" });\n674:     expect(selected).toHaveLength(1);\n675:     expect(selected[0].id).toBe(\"low-quick\");\n676:   });\n677: \n678:   test(\"featureIds selects specific features (backward compat)\", () => {\n679:     const selected = selectFeatures(data, {\n680:       featureIds: [\"high-pri\", \"low-quick\"],\n681:     });\n682:     expect(selected).toHaveLength(2);\n683:   });\n684: \n685:   test(\"featureIds with nonexistent IDs still returns valid ones\", () => {\n686:     const selected = selectFeatures(data, {\n687:       featureIds: [\"high-pri\", \"nonexistent\"],\n688:     });\n689:     expect(selected).toHaveLength(1);\n690:     expect(selected[0].id).toBe(\"high-pri\");\n691:   });\n692: \n693:   test(\"default returns all ready sorted by priority\", () => {\n694:     const selected = selectFeatures(data, {});\n695:     expect(selected).toHaveLength(4);\n696:     expect(selected[0].id).toBe(\"critical-small\");\n697:   });\n698: });\n699: \n700: // ---------------------------------------------------------------------------\n701: // createBlankFeature\n702: // ---------------------------------------------------------------------------\n703: \n704: describe(\"createBlankFeature\", () => {\n705:   test(\"creates feature with default values\", () => {\n706:     const f = createBlankFeature(\"my-feat\", \"My Feature\");\n707:     expect(f.id).toBe(\"my-feat\");\n708:     expect(f.title).toBe(\"My Feature\");\n709:     expect(f.status).toBe(\"backlog\");\n710:     expect(f.completion).toBe(0);\n711:     expect(f.difficulty).toBe(\"medium\");\n712:     expect(f.priority).toBe(\"medium\");\n713:     expect(f.effort).toBe(\"PT1H\");\n714:     expect(f.depends_on).toEqual([]);\n715:     expect(f.subtasks).toEqual([]);\n716:   });\n717: \n718:   test(\"creates feature with custom options\", () => {\n719:     const f = createBlankFeature(\"my-feat\", \"My Feature\", \"Description\", {\n720:       priority: \"critical\",\n721:       difficulty: \"hard\",\n722:       effort: \"P2D\",\n723:     });\n724:     expect(f.priority).toBe(\"critical\");\n725:     expect(f.difficulty).toBe(\"hard\");\n726:     expect(f.effort).toBe(\"P2D\");\n727:     expect(f.description).toBe(\"Description\");\n728:   });\n729: });\n730: \n731: // ---------------------------------------------------------------------------\n732: // findFeatureById\n733: // ---------------------------------------------------------------------------\n734: \n735: describe(\"findFeatureById\", () => {\n736:   test(\"finds top-level feature\", () => {\n737:     const data = makeFeaturesFile([makeFeature({ id: \"target\" })]);\n738:     const found = findFeatureById(data, \"target\");\n739:     expect(found).toBeDefined();\n740:     expect(found!.id).toBe(\"target\");\n741:   });\n742: \n743:   test(\"finds feature in archive\", () => {\n744:     const data = makeFeaturesFile(\n745:       [],\n746:       [makeFeature({ id: \"archived\" })]\n747:     );\n748:     const found = findFeatureById(data, \"archived\");\n749:     expect(found).toBeDefined();\n750:     expect(found!.id).toBe(\"archived\");\n751:   });\n752: \n753:   test(\"finds nested subtask\", () => {\n754:     const data = makeFeaturesFile([\n755:       makeFeature({\n756:         id: \"parent\",\n757:         subtasks: [\n758:           {\n759:             id: \"nested-sub\",\n760:             title: \"Nested\",\n761:             description: \"\",\n762:             status: \"backlog\",\n763:             completion: 0,\n764:             difficulty: \"easy\",\n765:             priority: \"medium\",\n766:             depends_on: [],\n767:             effort: \"PT30M\",\n768:             started_at: null,\n769:             ended_at: null,\n770:             constraints: [],\n771:             forbidden: [],\n772:             references: [],\n773:             notes: [],\n774:             subtasks: [],\n775:           },\n776:         ],\n777:       }),\n778:     ]);\n779:     const found = findFeatureById(data, \"nested-sub\");\n780:     expect(found).toBeDefined();\n781:     expect(found!.id).toBe(\"nested-sub\");\n782:   });\n783: \n784:   test(\"returns undefined for nonexistent ID\", () => {\n785:     const data = makeFeaturesFile([makeFeature({ id: \"exists\" })]);\n786:     const found = findFeatureById(data, \"nonexistent\");\n787:     expect(found).toBeUndefined();\n788:   });\n789: });\n790: \n791: // ---------------------------------------------------------------------------\n792: // allFeatureIds\n793: // ---------------------------------------------------------------------------\n794: \n795: describe(\"allFeatureIds\", () => {\n796:   test(\"collects all IDs including subtasks and archive\", () => {\n797:     const data = makeFeaturesFile(\n798:       [\n799:         makeFeature({\n800:           id: \"feat-a\",\n801:           subtasks: [\n802:             {\n803:               id: \"sub-1\",\n804:               title: \"Sub\",\n805:               description: \"\",\n806:               status: \"backlog\",\n807:               completion: 0,\n808:               difficulty: \"easy\",\n809:               priority: \"medium\",\n810:               depends_on: [],\n811:               effort: \"PT30M\",\n812:               started_at: null,\n813:               ended_at: null,\n814:               constraints: [],\n815:               forbidden: [],\n816:               references: [],\n817:               notes: [],\n818:               subtasks: [],\n819:             },\n820:           ],\n821:         }),\n822:       ],\n823:       [makeFeature({ id: \"archived\" })]\n824:     );\n825:     const ids = allFeatureIds(data);\n826:     expect(ids).toContain(\"feat-a\");\n827:     expect(ids).toContain(\"sub-1\");\n828:     expect(ids).toContain(\"archived\");\n829:   });\n830: });\n831: \n832: // ---------------------------------------------------------------------------\n833: // featureSummary\n834: // ---------------------------------------------------------------------------\n835: \n836: describe(\"featureSummary\", () => {\n837:   test(\"produces formatted summary string\", () => {\n838:     const f = makeFeature({\n839:       id: \"auth-flow\",\n840:       title: \"Auth Flow\",\n841:       priority: \"high\",\n842:       difficulty: \"medium\",\n843:       effort: \"PT2H\",\n844:     });\n845:     const summary = featureSummary(f);\n846:     expect(summary).toContain(\"[high/medium]\");\n847:     expect(summary).toContain(\"auth-flow\");\n848:     expect(summary).toContain(\"Auth Flow\");\n849:     expect(summary).toContain(\"2h\");\n850:   });\n851: });\n852: \n853: // ---------------------------------------------------------------------------\n854: // Priority and Difficulty orderings\n855: // ---------------------------------------------------------------------------\n856: \n857: describe(\"PRIORITY_ORDER\", () => {\n858:   test(\"critical < high < medium < low < wishlist\", () => {\n859:     expect(PRIORITY_ORDER.critical).toBeLessThan(PRIORITY_ORDER.high);\n860:     expect(PRIORITY_ORDER.high).toBeLessThan(PRIORITY_ORDER.medium);\n861:     expect(PRIORITY_ORDER.medium).toBeLessThan(PRIORITY_ORDER.low);\n862:     expect(PRIORITY_ORDER.low).toBeLessThan(PRIORITY_ORDER.wishlist);\n863:   });\n864: });\n865: \n866: describe(\"DIFFICULTY_ORDER\", () => {\n867:   test(\"trivial < easy < medium < hard < very_hard\", () => {\n868:     expect(DIFFICULTY_ORDER.trivial).toBeLessThan(DIFFICULTY_ORDER.easy);\n869:     expect(DIFFICULTY_ORDER.easy).toBeLessThan(DIFFICULTY_ORDER.medium);\n870:     expect(DIFFICULTY_ORDER.medium).toBeLessThan(DIFFICULTY_ORDER.hard);\n871:     expect(DIFFICULTY_ORDER.hard).toBeLessThan(DIFFICULTY_ORDER.very_hard);\n872:   });\n873: });\n\n(End of file - total 873 lines)\n</content>","title":"tests/features.test.ts","metadata":{"preview":"/**\n * features.test.ts — Unit tests for tasks YAML parsing, validation,\n * duration parsing, and dependency resolution.\n *\n * Coverage:\n *   - loadFeatures with null tasks, empty arrays, valid data\n *   - parseDurationMinutes for ISO 8601 durations\n *   - formatDuration for human-readable output\n *   - Dependency resolution (areDependenciesMet, getReadyFeatures)\n *   - normalizeTask defaults\n *   - createBlankFeature\n *   - findFeatureById (recursive search)\n *   - selectFeatures strategies\n *   - YAML schema edge cases\n */\n\nimport { describe, test, expect, beforeEach, afterEach } from \"bun:test\";\nimport { mkdtempSync, writeFileSync, rmSync, mkdirSync } from \"node:fs\";\nimport { join } from \"node:path\";\nimport { tmpdir } from \"node:os\";","truncated":false,"loaded":[]},"time":{"start":1773433295414,"end":1773433295510}}}}
{"type":"tool_use","timestamp":1773433296111,"sessionID":"ses_31723c3afffeEcJRyyogDgXrE8","part":{"id":"prt_ce8dc924e001c9cJKcerJ3kELT","sessionID":"ses_31723c3afffeEcJRyyogDgXrE8","messageID":"msg_ce8dc838d001UfuJhCVniCYejq","type":"tool","callID":"toolu_vrtx_01Y63XUXncUAfsqiaDypKFNK","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-test-features-parsing/tests/state.test.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-test-features-parsing/tests/state.test.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * state.test.ts — Unit tests for wave state persistence and mutations.\n3:  *\n4:  * Coverage:\n5:  *   - saveState / loadState round-trip\n6:  *   - Atomic write (write to .tmp then rename)\n7:  *   - State file corruption recovery (returns null)\n8:  *   - createWaveState / createAgentState\n9:  *   - updateAgent with valid/invalid feature IDs\n10:  *   - agentCounts\n11:  *   - activeAgents / queuedAgents\n12:  *   - isWaveComplete\n13:  *   - generateWaveId format\n14:  *   - Concurrent mutation patterns\n15:  */\n16: \n17: import { describe, test, expect, beforeEach, afterEach } from \"bun:test\";\n18: import { mkdtempSync, mkdirSync, writeFileSync, readFileSync, rmSync, existsSync } from \"node:fs\";\n19: import { join } from \"node:path\";\n20: import { tmpdir } from \"node:os\";\n21: import {\n22:   loadState,\n23:   saveState,\n24:   createWaveState,\n25:   createAgentState,\n26:   getAgent,\n27:   updateAgent,\n28:   agentCounts,\n29:   activeAgents,\n30:   queuedAgents,\n31:   isWaveComplete,\n32:   generateWaveId,\n33: } from \"../src/lib/state.js\";\n34: import type { WaveState, AgentState, AgentStatus } from \"../src/lib/state.js\";\n35: \n36: // ---------------------------------------------------------------------------\n37: // Helpers\n38: // ---------------------------------------------------------------------------\n39: \n40: let tmpDir: string;\n41: \n42: beforeEach(() => {\n43:   tmpDir = mkdtempSync(join(tmpdir(), \"wombo-test-state-\"));\n44: });\n45: \n46: afterEach(() => {\n47:   rmSync(tmpDir, { recursive: true, force: true });\n48: });\n49: \n50: function makeWaveState(overrides?: Partial<WaveState>): WaveState {\n51:   return {\n52:     wave_id: \"wave-2025-01-01-000\",\n53:     base_branch: \"main\",\n54:     started_at: \"2025-01-01T00:00:00Z\",\n55:     updated_at: \"2025-01-01T00:00:00Z\",\n56:     max_concurrent: 4,\n57:     model: null,\n58:     interactive: false,\n59:     agents: [],\n60:     ...overrides,\n61:   };\n62: }\n63: \n64: function makeAgentState(overrides?: Partial<AgentState>): AgentState {\n65:   return {\n66:     feature_id: \"test-feature\",\n67:     branch: \"feature/test-feature\",\n68:     worktree: \"/tmp/wombo-test-feature\",\n69:     session_id: null,\n70:     pid: null,\n71:     status: \"queued\",\n72:     activity: null,\n73:     activity_updated_at: null,\n74:     retries: 0,\n75:     max_retries: 2,\n76:     started_at: null,\n77:     completed_at: null,\n78:     build_passed: null,\n79:     build_output: null,\n80:     error: null,\n81:     effort_estimate_ms: null,\n82:     ...overrides,\n83:   };\n84: }\n85: \n86: // ---------------------------------------------------------------------------\n87: // generateWaveId\n88: // ---------------------------------------------------------------------------\n89: \n90: describe(\"generateWaveId\", () => {\n91:   test(\"produces wave ID in expected format\", () => {\n92:     const id = generateWaveId();\n93:     // The sequence part is hours*60+minutes, padStart(3, \"0\"), so can be 3-4 digits\n94:     expect(id).toMatch(/^wave-\\d{4}-\\d{2}-\\d{2}-\\d{3,4}$/);\n95:   });\n96: \n97:   test(\"includes current date\", () => {\n98:     const id = generateWaveId();\n99:     const today = new Date().toISOString().slice(0, 10);\n100:     expect(id).toContain(today);\n101:   });\n102: \n103:   test(\"produces consistent format on repeated calls\", () => {\n104:     const id1 = generateWaveId();\n105:     const id2 = generateWaveId();\n106:     // Both should match the format (though values may differ slightly)\n107:     expect(id1).toMatch(/^wave-\\d{4}-\\d{2}-\\d{2}-\\d{3,4}$/);\n108:     expect(id2).toMatch(/^wave-\\d{4}-\\d{2}-\\d{2}-\\d{3,4}$/);\n109:   });\n110: });\n111: \n112: // ---------------------------------------------------------------------------\n113: // createWaveState\n114: // ---------------------------------------------------------------------------\n115: \n116: describe(\"createWaveState\", () => {\n117:   test(\"creates state with provided options\", () => {\n118:     const state = createWaveState({\n119:       baseBranch: \"develop\",\n120:       maxConcurrent: 3,\n121:       model: \"gpt-4\",\n122:       interactive: true,\n123:     });\n124:     expect(state.base_branch).toBe(\"develop\");\n125:     expect(state.max_concurrent).toBe(3);\n126:     expect(state.model).toBe(\"gpt-4\");\n127:     expect(state.interactive).toBe(true);\n128:     expect(state.agents).toEqual([]);\n129:     expect(state.wave_id).toMatch(/^wave-/);\n130:   });\n131: \n132:   test(\"creates state with null model\", () => {\n133:     const state = createWaveState({\n134:       baseBranch: \"main\",\n135:       maxConcurrent: 6,\n136:       model: null,\n137:       interactive: false,\n138:     });\n139:     expect(state.model).toBeNull();\n140:   });\n141: \n142:   test(\"sets started_at and updated_at timestamps\", () => {\n143:     const before = new Date().toISOString();\n144:     const state = createWaveState({\n145:       baseBranch: \"main\",\n146:       maxConcurrent: 1,\n147:       model: null,\n148:       interactive: false,\n149:     });\n150:     const after = new Date().toISOString();\n151:     expect(state.started_at >= before).toBe(true);\n152:     expect(state.started_at <= after).toBe(true);\n153:   });\n154: });\n155: \n156: // ---------------------------------------------------------------------------\n157: // createAgentState\n158: // ---------------------------------------------------------------------------\n159: \n160: describe(\"createAgentState\", () => {\n161:   test(\"creates agent with default max retries\", () => {\n162:     const agent = createAgentState(\"my-feat\", \"feature/my-feat\", \"/tmp/wt\");\n163:     expect(agent.feature_id).toBe(\"my-feat\");\n164:     expect(agent.branch).toBe(\"feature/my-feat\");\n165:     expect(agent.worktree).toBe(\"/tmp/wt\");\n166:     expect(agent.status).toBe(\"queued\");\n167:     expect(agent.max_retries).toBe(2);\n168:     expect(agent.retries).toBe(0);\n169:     expect(agent.pid).toBeNull();\n170:     expect(agent.session_id).toBeNull();\n171:     expect(agent.build_passed).toBeNull();\n172:   });\n173: \n174:   test(\"creates agent with custom max retries\", () => {\n175:     const agent = createAgentState(\"my-feat\", \"feature/my-feat\", \"/tmp/wt\", 5);\n176:     expect(agent.max_retries).toBe(5);\n177:   });\n178: });\n179: \n180: // ---------------------------------------------------------------------------\n181: // saveState / loadState round-trip\n182: // ---------------------------------------------------------------------------\n183: \n184: describe(\"saveState / loadState\", () => {\n185:   test(\"round-trips state through file system\", () => {\n186:     const state = makeWaveState({\n187:       agents: [makeAgentState({ feature_id: \"feat-a\" })],\n188:     });\n189:     saveState(tmpDir, state);\n190:     const loaded = loadState(tmpDir);\n191:     expect(loaded).not.toBeNull();\n192:     expect(loaded!.wave_id).toBe(state.wave_id);\n193:     expect(loaded!.agents).toHaveLength(1);\n194:     expect(loaded!.agents[0].feature_id).toBe(\"feat-a\");\n195:   });\n196: \n197:   test(\"updates updated_at timestamp on save\", () => {\n198:     const state = makeWaveState();\n199:     const oldTimestamp = state.updated_at;\n200:     // Wait a tiny bit to ensure timestamp differs\n201:     saveState(tmpDir, state);\n202:     const loaded = loadState(tmpDir);\n203:     expect(loaded).not.toBeNull();\n204:     // The saved state should have a newer (or equal) timestamp\n205:     expect(loaded!.updated_at >= oldTimestamp).toBe(true);\n206:   });\n207: \n208:   test(\"writes valid JSON\", () => {\n209:     const state = makeWaveState({\n210:       agents: [\n211:         makeAgentState({ feature_id: \"feat-a\", status: \"running\" }),\n212:         makeAgentState({ feature_id: \"feat-b\", status: \"completed\" }),\n213:       ],\n214:     });\n215:     saveState(tmpDir, state);\n216:     const raw = readFileSync(join(tmpDir, \".wombo-combo\", \"state.json\"), \"utf-8\");\n217:     const parsed = JSON.parse(raw);\n218:     expect(parsed.wave_id).toBe(state.wave_id);\n219:     expect(parsed.agents).toHaveLength(2);\n220:   });\n221: \n222:   test(\"atomic write: tmp file is cleaned up after rename\", () => {\n223:     const state = makeWaveState();\n224:     saveState(tmpDir, state);\n225:     // The .tmp file should not exist after a successful save\n226:     expect(existsSync(join(tmpDir, \".wombo-combo\", \"state.json.tmp\"))).toBe(false);\n227:     // The actual file should exist\n228:     expect(existsSync(join(tmpDir, \".wombo-combo\", \"state.json\"))).toBe(true);\n229:   });\n230: \n231:   test(\"returns null when no state file exists\", () => {\n232:     const loaded = loadState(tmpDir);\n233:     expect(loaded).toBeNull();\n234:   });\n235: \n236:   test(\"returns null on corrupted JSON\", () => {\n237:     mkdirSync(join(tmpDir, \".wombo-combo\"), { recursive: true });\n238:     writeFileSync(\n239:       join(tmpDir, \".wombo-combo\", \"state.json\"),\n240:       \"{{not valid json!!!\",\n241:       \"utf-8\"\n242:     );\n243:     const loaded = loadState(tmpDir);\n244:     expect(loaded).toBeNull();\n245:   });\n246: \n247:   test(\"returns null on empty file\", () => {\n248:     mkdirSync(join(tmpDir, \".wombo-combo\"), { recursive: true });\n249:     writeFileSync(join(tmpDir, \".wombo-combo\", \"state.json\"), \"\", \"utf-8\");\n250:     const loaded = loadState(tmpDir);\n251:     expect(loaded).toBeNull();\n252:   });\n253: \n254:   test(\"handles state with many agents\", () => {\n255:     const agents: AgentState[] = [];\n256:     for (let i = 0; i < 50; i++) {\n257:       agents.push(\n258:         makeAgentState({\n259:           feature_id: `feat-${i}`,\n260:           branch: `feature/feat-${i}`,\n261:         })\n262:       );\n263:     }\n264:     const state = makeWaveState({ agents });\n265:     saveState(tmpDir, state);\n266:     const loaded = loadState(tmpDir);\n267:     expect(loaded!.agents).toHaveLength(50);\n268:   });\n269: \n270:   test(\"preserves all agent fields through round-trip\", () => {\n271:     const agent = makeAgentState({\n272:       feature_id: \"full-agent\",\n273:       branch: \"feature/full\",\n274:       worktree: \"/tmp/wt-full\",\n275:       session_id: \"tmux-session-123\",\n276:       pid: 12345,\n277:       status: \"running\",\n278:       activity: \"Building project\",\n279:       activity_updated_at: \"2025-01-01T12:00:00Z\",\n280:       retries: 1,\n281:       max_retries: 3,\n282:       started_at: \"2025-01-01T10:00:00Z\",\n283:       completed_at: null,\n284:       build_passed: null,\n285:       build_output: null,\n286:       error: null,\n287:       effort_estimate_ms: 3600000,\n288:     });\n289:     const state = makeWaveState({ agents: [agent] });\n290:     saveState(tmpDir, state);\n291:     const loaded = loadState(tmpDir);\n292:     const loadedAgent = loaded!.agents[0];\n293:     expect(loadedAgent.feature_id).toBe(\"full-agent\");\n294:     expect(loadedAgent.session_id).toBe(\"tmux-session-123\");\n295:     expect(loadedAgent.pid).toBe(12345);\n296:     expect(loadedAgent.status).toBe(\"running\");\n297:     expect(loadedAgent.activity).toBe(\"Building project\");\n298:     expect(loadedAgent.retries).toBe(1);\n299:     expect(loadedAgent.max_retries).toBe(3);\n300:     expect(loadedAgent.effort_estimate_ms).toBe(3600000);\n301:   });\n302: });\n303: \n304: // ---------------------------------------------------------------------------\n305: // getAgent\n306: // ---------------------------------------------------------------------------\n307: \n308: describe(\"getAgent\", () => {\n309:   test(\"finds agent by feature ID\", () => {\n310:     const state = makeWaveState({\n311:       agents: [\n312:         makeAgentState({ feature_id: \"feat-a\" }),\n313:         makeAgentState({ feature_id: \"feat-b\" }),\n314:       ],\n315:     });\n316:     const agent = getAgent(state, \"feat-b\");\n317:     expect(agent).toBeDefined();\n318:     expect(agent!.feature_id).toBe(\"feat-b\");\n319:   });\n320: \n321:   test(\"returns undefined for nonexistent feature ID\", () => {\n322:     const state = makeWaveState({\n323:       agents: [makeAgentState({ feature_id: \"feat-a\" })],\n324:     });\n325:     const agent = getAgent(state, \"nonexistent\");\n326:     expect(agent).toBeUndefined();\n327:   });\n328: \n329:   test(\"returns undefined when agents list is empty\", () => {\n330:     const state = makeWaveState({ agents: [] });\n331:     const agent = getAgent(state, \"any\");\n332:     expect(agent).toBeUndefined();\n333:   });\n334: });\n335: \n336: // ---------------------------------------------------------------------------\n337: // updateAgent\n338: // ---------------------------------------------------------------------------\n339: \n340: describe(\"updateAgent\", () => {\n341:   test(\"updates agent status\", () => {\n342:     const state = makeWaveState({\n343:       agents: [makeAgentState({ feature_id: \"feat-a\", status: \"queued\" })],\n344:     });\n345:     updateAgent(state, \"feat-a\", { status: \"running\" });\n346:     expect(state.agents[0].status).toBe(\"running\");\n347:   });\n348: \n349:   test(\"updates multiple fields at once\", () => {\n350:     const state = makeWaveState({\n351:       agents: [makeAgentState({ feature_id: \"feat-a\" })],\n352:     });\n353:     updateAgent(state, \"feat-a\", {\n354:       status: \"running\",\n355:       pid: 12345,\n356:       started_at: \"2025-01-01T00:00:00Z\",\n357:       activity: \"Installing dependencies\",\n358:     });\n359:     expect(state.agents[0].status).toBe(\"running\");\n360:     expect(state.agents[0].pid).toBe(12345);\n361:     expect(state.agents[0].started_at).toBe(\"2025-01-01T00:00:00Z\");\n362:     expect(state.agents[0].activity).toBe(\"Installing dependencies\");\n363:   });\n364: \n365:   test(\"throws for nonexistent feature ID\", () => {\n366:     const state = makeWaveState({\n367:       agents: [makeAgentState({ feature_id: \"feat-a\" })],\n368:     });\n369:     expect(() => updateAgent(state, \"nonexistent\", { status: \"running\" })).toThrow(\n370:       \"Agent not found for feature: nonexistent\"\n371:     );\n372:   });\n373: \n374:   test(\"throws when agents list is empty\", () => {\n375:     const state = makeWaveState({ agents: [] });\n376:     expect(() => updateAgent(state, \"any\", { status: \"running\" })).toThrow(\n377:       \"Agent not found for feature: any\"\n378:     );\n379:   });\n380: \n381:   test(\"only updates the targeted agent\", () => {\n382:     const state = makeWaveState({\n383:       agents: [\n384:         makeAgentState({ feature_id: \"feat-a\", status: \"queued\" }),\n385:         makeAgentState({ feature_id: \"feat-b\", status: \"queued\" }),\n386:       ],\n387:     });\n388:     updateAgent(state, \"feat-a\", { status: \"running\" });\n389:     expect(state.agents[0].status).toBe(\"running\");\n390:     expect(state.agents[1].status).toBe(\"queued\");\n391:   });\n392: \n393:   test(\"sequential updates accumulate correctly\", () => {\n394:     const state = makeWaveState({\n395:       agents: [makeAgentState({ feature_id: \"feat-a\" })],\n396:     });\n397:     updateAgent(state, \"feat-a\", { status: \"installing\" });\n398:     updateAgent(state, \"feat-a\", { status: \"running\", pid: 1234 });\n399:     updateAgent(state, \"feat-a\", {\n400:       status: \"completed\",\n401:       completed_at: \"2025-01-01T01:00:00Z\",\n402:       build_passed: true,\n403:     });\n404:     const agent = state.agents[0];\n405:     expect(agent.status).toBe(\"completed\");\n406:     expect(agent.pid).toBe(1234);\n407:     expect(agent.build_passed).toBe(true);\n408:     expect(agent.completed_at).toBe(\"2025-01-01T01:00:00Z\");\n409:   });\n410: });\n411: \n412: // ---------------------------------------------------------------------------\n413: // agentCounts\n414: // ---------------------------------------------------------------------------\n415: \n416: describe(\"agentCounts\", () => {\n417:   test(\"counts agents by status\", () => {\n418:     const state = makeWaveState({\n419:       agents: [\n420:         makeAgentState({ feature_id: \"a\", status: \"queued\" }),\n421:         makeAgentState({ feature_id: \"b\", status: \"queued\" }),\n422:         makeAgentState({ feature_id: \"c\", status: \"running\" }),\n423:         makeAgentState({ feature_id: \"d\", status: \"completed\" }),\n424:         makeAgentState({ feature_id: \"e\", status: \"failed\" }),\n425:       ],\n426:     });\n427:     const counts = agentCounts(state);\n428:     expect(counts.queued).toBe(2);\n429:     expect(counts.running).toBe(1);\n430:     expect(counts.completed).toBe(1);\n431:     expect(counts.failed).toBe(1);\n432:     expect(counts.installing).toBe(0);\n433:     expect(counts.verified).toBe(0);\n434:     expect(counts.merged).toBe(0);\n435:     expect(counts.retry).toBe(0);\n436:     expect(counts.resolving_conflict).toBe(0);\n437:   });\n438: \n439:   test(\"returns all zeros for empty agents list\", () => {\n440:     const state = makeWaveState({ agents: [] });\n441:     const counts = agentCounts(state);\n442:     expect(counts.queued).toBe(0);\n443:     expect(counts.running).toBe(0);\n444:     expect(counts.completed).toBe(0);\n445:   });\n446: });\n447: \n448: // ---------------------------------------------------------------------------\n449: // activeAgents\n450: // ---------------------------------------------------------------------------\n451: \n452: describe(\"activeAgents\", () => {\n453:   test(\"returns running, installing, and resolving_conflict agents\", () => {\n454:     const state = makeWaveState({\n455:       agents: [\n456:         makeAgentState({ feature_id: \"a\", status: \"running\" }),\n457:         makeAgentState({ feature_id: \"b\", status: \"installing\" }),\n458:         makeAgentState({ feature_id: \"c\", status: \"resolving_conflict\" }),\n459:         makeAgentState({ feature_id: \"d\", status: \"queued\" }),\n460:         makeAgentState({ feature_id: \"e\", status: \"completed\" }),\n461:       ],\n462:     });\n463:     const active = activeAgents(state);\n464:     expect(active).toHaveLength(3);\n465:     const ids = active.map((a) => a.feature_id);\n466:     expect(ids).toContain(\"a\");\n467:     expect(ids).toContain(\"b\");\n468:     expect(ids).toContain(\"c\");\n469:   });\n470: \n471:   test(\"returns empty array when no agents are active\", () => {\n472:     const state = makeWaveState({\n473:       agents: [\n474:         makeAgentState({ feature_id: \"a\", status: \"queued\" }),\n475:         makeAgentState({ feature_id: \"b\", status: \"completed\" }),\n476:       ],\n477:     });\n478:     expect(activeAgents(state)).toHaveLength(0);\n479:   });\n480: });\n481: \n482: // ---------------------------------------------------------------------------\n483: // queuedAgents\n484: // ---------------------------------------------------------------------------\n485: \n486: describe(\"queuedAgents\", () => {\n487:   test(\"returns only queued agents\", () => {\n488:     const state = makeWaveState({\n489:       agents: [\n490:         makeAgentState({ feature_id: \"a\", status: \"queued\" }),\n491:         makeAgentState({ feature_id: \"b\", status: \"running\" }),\n492:         makeAgentState({ feature_id: \"c\", status: \"queued\" }),\n493:       ],\n494:     });\n495:     const queued = queuedAgents(state);\n496:     expect(queued).toHaveLength(2);\n497:     expect(queued[0].feature_id).toBe(\"a\");\n498:     expect(queued[1].feature_id).toBe(\"c\");\n499:   });\n500: });\n501: \n502: // ---------------------------------------------------------------------------\n503: // isWaveComplete\n504: // ---------------------------------------------------------------------------\n505: \n506: describe(\"isWaveComplete\", () => {\n507:   test(\"returns true when all agents are in terminal states\", () => {\n508:     const state = makeWaveState({\n509:       agents: [\n510:         makeAgentState({ feature_id: \"a\", status: \"completed\" }),\n511:         makeAgentState({ feature_id: \"b\", status: \"verified\" }),\n512:         makeAgentState({ feature_id: \"c\", status: \"failed\" }),\n513:         makeAgentState({ feature_id: \"d\", status: \"merged\" }),\n514:       ],\n515:     });\n516:     expect(isWaveComplete(state)).toBe(true);\n517:   });\n518: \n519:   test(\"returns false when some agents are still queued\", () => {\n520:     const state = makeWaveState({\n521:       agents: [\n522:         makeAgentState({ feature_id: \"a\", status: \"completed\" }),\n523:         makeAgentState({ feature_id: \"b\", status: \"queued\" }),\n524:       ],\n525:     });\n526:     expect(isWaveComplete(state)).toBe(false);\n527:   });\n528: \n529:   test(\"returns false when some agents are still running\", () => {\n530:     const state = makeWaveState({\n531:       agents: [\n532:         makeAgentState({ feature_id: \"a\", status: \"completed\" }),\n533:         makeAgentState({ feature_id: \"b\", status: \"running\" }),\n534:       ],\n535:     });\n536:     expect(isWaveComplete(state)).toBe(false);\n537:   });\n538: \n539:   test(\"returns false when some agents are installing\", () => {\n540:     const state = makeWaveState({\n541:       agents: [\n542:         makeAgentState({ feature_id: \"a\", status: \"installing\" }),\n543:       ],\n544:     });\n545:     expect(isWaveComplete(state)).toBe(false);\n546:   });\n547: \n548:   test(\"returns false when some agents are in retry\", () => {\n549:     const state = makeWaveState({\n550:       agents: [\n551:         makeAgentState({ feature_id: \"a\", status: \"retry\" }),\n552:       ],\n553:     });\n554:     expect(isWaveComplete(state)).toBe(false);\n555:   });\n556: \n557:   test(\"returns true for empty agents list\", () => {\n558:     const state = makeWaveState({ agents: [] });\n559:     expect(isWaveComplete(state)).toBe(true);\n560:   });\n561: });\n562: \n563: // ---------------------------------------------------------------------------\n564: // Concurrent mutation patterns (save-load-modify-save cycles)\n565: // ---------------------------------------------------------------------------\n566: \n567: describe(\"concurrent mutation patterns\", () => {\n568:   test(\"multiple save-load cycles preserve data integrity\", () => {\n569:     const state = makeWaveState({\n570:       agents: [\n571:         makeAgentState({ feature_id: \"feat-a\", status: \"queued\" }),\n572:         makeAgentState({ feature_id: \"feat-b\", status: \"queued\" }),\n573:       ],\n574:     });\n575: \n576:     // Save initial state\n577:     saveState(tmpDir, state);\n578: \n579:     // Simulate agent A starting: load, modify, save\n580:     const s1 = loadState(tmpDir)!;\n581:     updateAgent(s1, \"feat-a\", { status: \"running\", pid: 1001 });\n582:     saveState(tmpDir, s1);\n583: \n584:     // Simulate agent B starting: load, modify, save\n585:     const s2 = loadState(tmpDir)!;\n586:     expect(s2.agents[0].status).toBe(\"running\"); // A's change persisted\n587:     updateAgent(s2, \"feat-b\", { status: \"running\", pid: 1002 });\n588:     saveState(tmpDir, s2);\n589: \n590:     // Final verification\n591:     const final = loadState(tmpDir)!;\n592:     expect(final.agents[0].status).toBe(\"running\");\n593:     expect(final.agents[0].pid).toBe(1001);\n594:     expect(final.agents[1].status).toBe(\"running\");\n595:     expect(final.agents[1].pid).toBe(1002);\n596:   });\n597: \n598:   test(\"rapid sequential updates don't corrupt state\", () => {\n599:     const state = makeWaveState({\n600:       agents: [makeAgentState({ feature_id: \"feat-a\", status: \"queued\" })],\n601:     });\n602: \n603:     // Rapid fire updates\n604:     const statuses: AgentStatus[] = [\n605:       \"queued\",\n606:       \"installing\",\n607:       \"running\",\n608:       \"completed\",\n609:     ];\n610:     for (const status of statuses) {\n611:       updateAgent(state, \"feat-a\", { status });\n612:       saveState(tmpDir, state);\n613:     }\n614: \n615:     const loaded = loadState(tmpDir)!;\n616:     expect(loaded.agents[0].status).toBe(\"completed\");\n617:   });\n618: \n619:   test(\"save and load with all possible agent statuses\", () => {\n620:     const allStatuses: AgentStatus[] = [\n621:       \"queued\",\n622:       \"installing\",\n623:       \"running\",\n624:       \"completed\",\n625:       \"verified\",\n626:       \"failed\",\n627:       \"merged\",\n628:       \"retry\",\n629:       \"resolving_conflict\",\n630:     ];\n631: \n632:     const agents = allStatuses.map((status, i) =>\n633:       makeAgentState({ feature_id: `feat-${i}`, status })\n634:     );\n635:     const state = makeWaveState({ agents });\n636:     saveState(tmpDir, state);\n637: \n638:     const loaded = loadState(tmpDir)!;\n639:     for (let i = 0; i < allStatuses.length; i++) {\n640:       expect(loaded.agents[i].status).toBe(allStatuses[i]);\n641:     }\n642:   });\n643: });\n\n(End of file - total 643 lines)\n</content>","title":"tests/state.test.ts","metadata":{"preview":"/**\n * state.test.ts — Unit tests for wave state persistence and mutations.\n *\n * Coverage:\n *   - saveState / loadState round-trip\n *   - Atomic write (write to .tmp then rename)\n *   - State file corruption recovery (returns null)\n *   - createWaveState / createAgentState\n *   - updateAgent with valid/invalid feature IDs\n *   - agentCounts\n *   - activeAgents / queuedAgents\n *   - isWaveComplete\n *   - generateWaveId format\n *   - Concurrent mutation patterns\n */\n\nimport { describe, test, expect, beforeEach, afterEach } from \"bun:test\";\nimport { mkdtempSync, mkdirSync, writeFileSync, readFileSync, rmSync, existsSync } from \"node:fs\";\nimport { join } from \"node:path\";\nimport { tmpdir } from \"node:os\";","truncated":false,"loaded":[]},"time":{"start":1773433296031,"end":1773433296091}}}}
{"type":"text","timestamp":1773433297482,"sessionID":"ses_31723c3afffeEcJRyyogDgXrE8","part":{"id":"prt_ce8dc8da5001JjNI1iMkogeHXm","sessionID":"ses_31723c3afffeEcJRyyogDgXrE8","messageID":"msg_ce8dc838d001UfuJhCVniCYejq","type":"text","text":"Now let me read the existing test files to understand the patterns and the validate module:","time":{"start":1773433297479,"end":1773433297479}}}
{"type":"tool_use","timestamp":1773433297537,"sessionID":"ses_31723c3afffeEcJRyyogDgXrE8","part":{"id":"prt_ce8dc94b90011gesu7S6OlFuwr","sessionID":"ses_31723c3afffeEcJRyyogDgXrE8","messageID":"msg_ce8dc838d001UfuJhCVniCYejq","type":"tool","callID":"toolu_vrtx_019hAUe7hfg7WiYdg5dekRWT","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-test-features-parsing/src/lib/validate.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-test-features-parsing/src/lib/validate.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * validate.ts — Input validation / hardening for agent-ready CLI.\n3:  *\n4:  * All user/agent-supplied inputs pass through these validators at the CLI\n5:  * boundary. This prevents hallucinated inputs from corrupting state.\n6:  *\n7:  * Rules:\n8:  *   - Feature IDs: kebab-case only, no path traversals, no query params\n9:  *   - Branch names: no control chars, no \"..\", no spaces\n10:  *   - Free-text (titles, descriptions): no control chars except \\n \\t\n11:  *   - Effort strings: ISO 8601 duration pattern only\n12:  */\n13: \n14: // ---------------------------------------------------------------------------\n15: // Patterns\n16: // ---------------------------------------------------------------------------\n17: \n18: /** Valid feature/subtask ID: lowercase alphanumeric + hyphens, 1-128 chars */\n19: const ID_PATTERN = /^[a-z0-9][a-z0-9-]{0,127}$/;\n20: \n21: /** Control characters below space, excluding \\t (0x09) and \\n (0x0a) */\n22: const CONTROL_CHARS = /[\\x00-\\x08\\x0b\\x0c\\x0e-\\x1f\\x7f]/;\n23: \n24: /** Path traversal sequences */\n25: const PATH_TRAVERSAL = /\\.\\.\\//;\n26: \n27: /** Embedded query params or fragments */\n28: const QUERY_FRAGMENT = /[?#]/;\n29: \n30: /** Percent-encoded sequences (indicates double-encoding risk) */\n31: const PERCENT_ENCODED = /%[0-9a-fA-F]{2}/;\n32: \n33: /** ISO 8601 duration: P[nY][nM][nD][T[nH][nM][nS]] */\n34: const DURATION_PATTERN = /^P(?:\\d+Y)?(?:\\d+M)?(?:\\d+D)?(?:T(?:\\d+H)?(?:\\d+M)?(?:\\d+S)?)?$/;\n35: \n36: // ---------------------------------------------------------------------------\n37: // Result type\n38: // ---------------------------------------------------------------------------\n39: \n40: export interface ValidationResult {\n41:   valid: boolean;\n42:   error?: string;\n43: }\n44: \n45: function ok(): ValidationResult {\n46:   return { valid: true };\n47: }\n48: \n49: function fail(error: string): ValidationResult {\n50:   return { valid: false, error };\n51: }\n52: \n53: // ---------------------------------------------------------------------------\n54: // Validators\n55: // ---------------------------------------------------------------------------\n56: \n57: /**\n58:  * Validate a feature or subtask ID.\n59:  * Must be kebab-case, no traversals, no query params, no encoded chars.\n60:  */\n61: export function validateId(value: string, label: string = \"ID\"): ValidationResult {\n62:   if (!value || value.length === 0) {\n63:     return fail(`${label} must not be empty.`);\n64:   }\n65: \n66:   if (CONTROL_CHARS.test(value)) {\n67:     return fail(`${label} contains control characters.`);\n68:   }\n69: \n70:   if (PATH_TRAVERSAL.test(value)) {\n71:     return fail(`${label} contains path traversal sequence \"../\".`);\n72:   }\n73: \n74:   if (QUERY_FRAGMENT.test(value)) {\n75:     return fail(`${label} contains query/fragment characters (? or #).`);\n76:   }\n77: \n78:   if (PERCENT_ENCODED.test(value)) {\n79:     return fail(`${label} contains percent-encoded characters — possible double-encoding.`);\n80:   }\n81: \n82:   if (!ID_PATTERN.test(value)) {\n83:     return fail(\n84:       `${label} \"${value}\" is invalid. IDs must be kebab-case ` +\n85:       `(lowercase letters, digits, hyphens), 1–128 characters, starting with a letter or digit.`\n86:     );\n87:   }\n88: \n89:   return ok();\n90: }\n91: \n92: /**\n93:  * Validate free-text input (titles, descriptions, notes).\n94:  * Rejects control chars except \\t and \\n.\n95:  */\n96: export function validateText(value: string, label: string = \"text\"): ValidationResult {\n97:   if (CONTROL_CHARS.test(value)) {\n98:     return fail(`${label} contains control characters (non-printable bytes).`);\n99:   }\n100:   return ok();\n101: }\n102: \n103: /**\n104:  * Validate a branch name.\n105:  * No control chars, no \"..\", no spaces, no ~, ^, :, \\, ?, *, [\n106:  */\n107: export function validateBranchName(value: string, label: string = \"branch name\"): ValidationResult {\n108:   if (!value || value.length === 0) {\n109:     return fail(`${label} must not be empty.`);\n110:   }\n111: \n112:   if (CONTROL_CHARS.test(value)) {\n113:     return fail(`${label} contains control characters.`);\n114:   }\n115: \n116:   if (/\\.\\./.test(value)) {\n117:     return fail(`${label} contains \"..\" which is not allowed in git branch names.`);\n118:   }\n119: \n120:   if (/[ ~^:\\\\?*\\[]/.test(value)) {\n121:     return fail(`${label} contains characters not allowed in git branch names.`);\n122:   }\n123: \n124:   return ok();\n125: }\n126: \n127: /**\n128:  * Validate an ISO 8601 duration string.\n129:  */\n130: export function validateDuration(value: string, label: string = \"effort\"): ValidationResult {\n131:   if (!value || value.length === 0) {\n132:     return fail(`${label} must not be empty.`);\n133:   }\n134: \n135:   if (!DURATION_PATTERN.test(value)) {\n136:     return fail(\n137:       `${label} \"${value}\" is not a valid ISO 8601 duration. ` +\n138:       `Expected format: P[nY][nM][nD][T[nH][nM][nS]] (e.g., \"PT2H\", \"P1D\", \"P1DT4H30M\").`\n139:     );\n140:   }\n141: \n142:   return ok();\n143: }\n144: \n145: /**\n146:  * Validate a status value against the allowed set.\n147:  */\n148: export function validateEnum(\n149:   value: string,\n150:   allowed: readonly string[],\n151:   label: string = \"value\"\n152: ): ValidationResult {\n153:   if (!allowed.includes(value)) {\n154:     return fail(`${label} \"${value}\" is not valid. Allowed values: ${allowed.join(\", \")}`);\n155:   }\n156:   return ok();\n157: }\n158: \n159: // ---------------------------------------------------------------------------\n160: // Convenience: validate and exit on failure\n161: // ---------------------------------------------------------------------------\n162: \n163: /**\n164:  * Run a validation and exit with error message if invalid.\n165:  * For use at the CLI boundary.\n166:  */\n167: export function assertValid(result: ValidationResult): void {\n168:   if (!result.valid) {\n169:     console.error(`Validation error: ${result.error}`);\n170:     process.exit(1);\n171:   }\n172: }\n\n(End of file - total 172 lines)\n</content>","title":"src/lib/validate.ts","metadata":{"preview":"/**\n * validate.ts — Input validation / hardening for agent-ready CLI.\n *\n * All user/agent-supplied inputs pass through these validators at the CLI\n * boundary. This prevents hallucinated inputs from corrupting state.\n *\n * Rules:\n *   - Feature IDs: kebab-case only, no path traversals, no query params\n *   - Branch names: no control chars, no \"..\", no spaces\n *   - Free-text (titles, descriptions): no control chars except \\n \\t\n *   - Effort strings: ISO 8601 duration pattern only\n */\n\n// ---------------------------------------------------------------------------\n// Patterns\n// ---------------------------------------------------------------------------\n\n/** Valid feature/subtask ID: lowercase alphanumeric + hyphens, 1-128 chars */\nconst ID_PATTERN = /^[a-z0-9][a-z0-9-]{0,127}$/;\n","truncated":false,"loaded":[]},"time":{"start":1773433297386,"end":1773433297535}}}}
{"type":"tool_use","timestamp":1773433297594,"sessionID":"ses_31723c3afffeEcJRyyogDgXrE8","part":{"id":"prt_ce8dc9a09001UM5bB7BPUZfoae","sessionID":"ses_31723c3afffeEcJRyyogDgXrE8","messageID":"msg_ce8dc838d001UfuJhCVniCYejq","type":"tool","callID":"toolu_vrtx_01JSTyLi9cDFT8nmNZf2cqmm","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-test-features-parsing/src/config.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-test-features-parsing/src/config.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * config.ts — Load .wombo-combo/config.json, merge with defaults, validate, expose typed config.\n3:  *\n4:  * The config file lives at .wombo-combo/config.json inside the target project root.\n5:  * All values have sensible defaults so minimal config works out of the box.\n6:  */\n7: \n8: import { readFileSync, existsSync } from \"node:fs\";\n9: import { resolve } from \"node:path\";\n10: import type { MultiplexerPreference } from \"./lib/multiplexer.js\";\n11: \n12: // ---------------------------------------------------------------------------\n13: // .wombo-combo directory constant\n14: // ---------------------------------------------------------------------------\n15: \n16: /** Name of the directory that holds all wombo-combo files */\n17: export const WOMBO_DIR = \".wombo-combo\";\n18: \n19: // ---------------------------------------------------------------------------\n20: // Types\n21: // ---------------------------------------------------------------------------\n22: \n23: /** Agent registry download mode */\n24: export type AgentRegistryMode = \"auto\" | \"monitored\" | \"disabled\";\n25: \n26: export interface WomboConfig {\n27:   /** Directory name for task files relative to .wombo-combo/ (folder-based storage) */\n28:   tasksDir: string;\n29:   /** Directory name for archived task files relative to .wombo-combo/ */\n30:   archiveDir: string;\n31:   /** @deprecated Use tasksDir. Legacy single-file path relative to .wombo-combo/ */\n32:   tasksFile?: string;\n33:   /** @deprecated Use archiveDir. Legacy single-file path relative to .wombo-combo/ */\n34:   archiveFile?: string;\n35:   /** Base branch to create feature branches from */\n36:   baseBranch: string;\n37:   /** Build configuration */\n38:   build: {\n39:     /** Build command to run in worktrees */\n40:     command: string;\n41:     /** Build timeout in milliseconds */\n42:     timeout: number;\n43:     /** Build artifact directory (for quick \"did it build?\" checks) */\n44:     artifactDir: string;\n45:   };\n46:   /** Install configuration */\n47:   install: {\n48:     /** Install command to run in worktrees */\n49:     command: string;\n50:     /** Install timeout in milliseconds */\n51:     timeout: number;\n52:   };\n53:   /** Git configuration */\n54:   git: {\n55:     /** Branch name prefix for feature branches */\n56:     branchPrefix: string;\n57:     /** Worktree directory name prefix */\n58:     worktreePrefix: string;\n59:     /** Git remote name */\n60:     remote: string;\n61:     /** Merge strategy flag */\n62:     mergeStrategy: string;\n63:   };\n64:   /** Agent configuration */\n65:   agent: {\n66:     /** Path to agent binary (null = auto-detect) */\n67:     bin: string | null;\n68:     /** Agent name to pass via --agent flag */\n69:     name: string;\n70:     /** Config files/dirs to copy into worktrees */\n71:     configFiles: string[];\n72:     /** Session name prefix for terminal multiplexer */\n73:     tmuxPrefix: string;\n74:     /** Terminal multiplexer preference: \"auto\" (prefer dmux), \"dmux\", or \"tmux\" */\n75:     multiplexer: MultiplexerPreference;\n76:   };\n77:   /** Portless integration for localhost server testing */\n78:   portless: {\n79:     /** Whether portless is enabled for agent worktrees */\n80:     enabled: boolean;\n81:     /** Path to portless binary (null = auto-detect via PATH) */\n82:     bin: string | null;\n83:     /** Proxy port (portless default is 1355) */\n84:     proxyPort: number;\n85:     /** Whether to use HTTPS mode */\n86:     https: boolean;\n87:   };\n88:   /** Backup configuration for tasks file */\n89:   backup: {\n90:     /** Maximum number of timestamped backups to keep */\n91:     maxBackups: number;\n92:   };\n93:   /** Default runtime values */\n94:   defaults: {\n95:     /** Max concurrent agents */\n96:     maxConcurrent: number;\n97:     /** Max retries per agent */\n98:     maxRetries: number;\n99:   };\n100:   /** Browser testing configuration */\n101:   browser: BrowserConfig;\n102:   /** Agent registry configuration for specialized agent downloads */\n103:   agentRegistry: AgentRegistryConfig;\n104: }\n105: \n106: /** Configuration for browser-based verification and testing */\n107: export interface BrowserConfig {\n108:   /** Enable browser testing in the verify pipeline */\n109:   enabled: boolean;\n110:   /** Path to browser binary (null = auto-detect) */\n111:   bin: string | null;\n112:   /** Run browser in headless mode (required for CI) */\n113:   headless: boolean;\n114:   /** Custom test command to run browser tests (overrides script discovery) */\n115:   testCommand: string | null;\n116:   /** Timeout for launching a browser instance (ms) */\n117:   launchTimeout: number;\n118:   /** Timeout for each browser test script (ms) */\n119:   testTimeout: number;\n120:   /** Default viewport size */\n121:   defaultViewport: {\n122:     width: number;\n123:     height: number;\n124:   };\n125: }\n126: \n127: /** Configuration for the external agent registry (e.g. agency-agents) */\n128: export interface AgentRegistryConfig {\n129:   /**\n130:    * Download mode:\n131:    * - \"auto\"      — download agents without asking (default)\n132:    * - \"monitored\" — user reviews/edits/rejects each agent before launch\n133:    * - \"disabled\"  — always use the generalist agent\n134:    */\n135:   mode: AgentRegistryMode;\n136:   /** GitHub repo in \"owner/repo\" format to pull agent definitions from */\n137:   source: string;\n138:   /** Cache directory name (relative to .wombo-combo/) */\n139:   cacheDir: string;\n140: }\n141: \n142: // ---------------------------------------------------------------------------\n143: // Defaults\n144: // ---------------------------------------------------------------------------\n145: \n146: export const DEFAULT_CONFIG: WomboConfig = {\n147:   tasksDir: \"tasks\",\n148:   archiveDir: \"archive\",\n149:   baseBranch: \"develop\",\n150:   build: {\n151:     command: \"bun run build\",\n152:     timeout: 300_000,\n153:     artifactDir: \"dist\",\n154:   },\n155:   install: {\n156:     command: \"bun install\",\n157:     timeout: 120_000,\n158:   },\n159:   git: {\n160:     branchPrefix: \"feature/\",\n161:     worktreePrefix: \"wombo-\",\n162:     remote: \"origin\",\n163:     mergeStrategy: \"--no-ff\",\n164:   },\n165:   agent: {\n166:     bin: null,\n167:     name: \"generalist-agent\",\n168:     configFiles: [\".opencode/\", \"opencode.json\", \"AGENTS.md\"],\n169:     tmuxPrefix: \"wombo\",\n170:     multiplexer: \"auto\",\n171:   },\n172:   portless: {\n173:     enabled: true,\n174:     bin: null,\n175:     proxyPort: 1355,\n176:     https: false,\n177:   },\n178:   backup: {\n179:     maxBackups: 5,\n180:   },\n181:   defaults: {\n182:     maxConcurrent: 6,\n183:     maxRetries: 2,\n184:   },\n185:   browser: {\n186:     enabled: false,\n187:     bin: null,\n188:     headless: true,\n189:     testCommand: null,\n190:     launchTimeout: 30_000,\n191:     testTimeout: 60_000,\n192:     defaultViewport: {\n193:       width: 1280,\n194:       height: 720,\n195:     },\n196:   },\n197:   agentRegistry: {\n198:     mode: \"auto\",\n199:     source: \"msitarzewski/agency-agents\",\n200:     cacheDir: \"agents-cache\",\n201:   },\n202: };\n203: \n204: // ---------------------------------------------------------------------------\n205: // Config File Name\n206: // ---------------------------------------------------------------------------\n207: \n208: export const CONFIG_FILE = `${WOMBO_DIR}/config.json`;\n209: \n210: // ---------------------------------------------------------------------------\n211: // Loader\n212: // ---------------------------------------------------------------------------\n213: \n214: /**\n215:  * Deep-merge source into target. Only merges plain objects, not arrays.\n216:  */\n217: function deepMerge<T extends Record<string, any>>(target: T, source: Partial<T>): T {\n218:   const result = { ...target };\n219:   for (const key of Object.keys(source) as (keyof T)[]) {\n220:     const srcVal = source[key];\n221:     const tgtVal = target[key];\n222:     if (\n223:       srcVal !== undefined &&\n224:       srcVal !== null &&\n225:       typeof srcVal === \"object\" &&\n226:       !Array.isArray(srcVal) &&\n227:       typeof tgtVal === \"object\" &&\n228:       !Array.isArray(tgtVal) &&\n229:       tgtVal !== null\n230:     ) {\n231:       result[key] = deepMerge(tgtVal as any, srcVal as any);\n232:     } else if (srcVal !== undefined) {\n233:       result[key] = srcVal as T[keyof T];\n234:     }\n235:   }\n236:   return result;\n237: }\n238: \n239: /**\n240:  * Load .wombo-combo/config.json from the given project root and merge with defaults.\n241:  * Returns the full config. If no config file exists, returns defaults.\n242:  */\n243: export function loadConfig(projectRoot: string): WomboConfig {\n244:   const configPath = resolve(projectRoot, CONFIG_FILE);\n245: \n246:   if (!existsSync(configPath)) {\n247:     return { ...DEFAULT_CONFIG };\n248:   }\n249: \n250:   try {\n251:     const raw = readFileSync(configPath, \"utf-8\");\n252:     const partial = JSON.parse(raw) as Partial<WomboConfig>;\n253: \n254:     // Migrate legacy single-file config keys to folder-based\n255:     if ((partial as any).tasksFile && !partial.tasksDir) {\n256:       // Legacy \"tasks.yml\" → strip extension for dir name, or use as-is\n257:       const legacy = (partial as any).tasksFile as string;\n258:       partial.tasksDir = legacy.replace(/\\.ya?ml$/i, \"\") || \"tasks\";\n259:       delete (partial as any).tasksFile;\n260:     }\n261:     if ((partial as any).archiveFile && !partial.archiveDir) {\n262:       const legacy = (partial as any).archiveFile as string;\n263:       partial.archiveDir = legacy.replace(/\\.ya?ml$/i, \"\") || \"archive\";\n264:       delete (partial as any).archiveFile;\n265:     }\n266: \n267:     return deepMerge(DEFAULT_CONFIG, partial);\n268:   } catch (err: any) {\n269:     throw new Error(`Failed to load ${CONFIG_FILE}: ${err.message}`);\n270:   }\n271: }\n272: \n273: /**\n274:  * Resolve the agent binary path. Priority:\n275:  *   1. config.agent.bin (explicit)\n276:  *   2. OPENCODE_BIN env var\n277:  *   3. ~/.opencode/bin/opencode (default install location)\n278:  */\n279: export function resolveAgentBin(config: WomboConfig): string {\n280:   if (config.agent.bin) return config.agent.bin;\n281:   if (process.env.OPENCODE_BIN) return process.env.OPENCODE_BIN;\n282:   return resolve(process.env.HOME || \"~\", \".opencode/bin/opencode\");\n283: }\n284: \n285: /**\n286:  * Validate the config for obvious issues. Throws on error.\n287:  */\n288: export function validateConfig(config: WomboConfig): void {\n289:   if (!config.tasksDir) {\n290:     throw new Error(\"config.tasksDir must be a non-empty string\");\n291:   }\n292:   if (!config.archiveDir) {\n293:     throw new Error(\"config.archiveDir must be a non-empty string\");\n294:   }\n295:   if (!config.baseBranch) {\n296:     throw new Error(\"config.baseBranch must be a non-empty string\");\n297:   }\n298:   if (!config.build.command) {\n299:     throw new Error(\"config.build.command must be a non-empty string\");\n300:   }\n301:   if (!config.install.command) {\n302:     throw new Error(\"config.install.command must be a non-empty string\");\n303:   }\n304:   if (!config.git.branchPrefix) {\n305:     throw new Error(\"config.git.branchPrefix must be a non-empty string\");\n306:   }\n307:   if (!config.git.worktreePrefix) {\n308:     throw new Error(\"config.git.worktreePrefix must be a non-empty string\");\n309:   }\n310:   if (config.defaults.maxConcurrent < 1) {\n311:     throw new Error(\"config.defaults.maxConcurrent must be >= 1\");\n312:   }\n313:   if (config.defaults.maxRetries < 0) {\n314:     throw new Error(\"config.defaults.maxRetries must be >= 0\");\n315:   }\n316:   if (config.backup.maxBackups < 0) {\n317:     throw new Error(\"config.backup.maxBackups must be >= 0\");\n318:   }\n319:   const validModes: AgentRegistryMode[] = [\"auto\", \"monitored\", \"disabled\"];\n320:   if (!validModes.includes(config.agentRegistry.mode)) {\n321:     throw new Error(`config.agentRegistry.mode must be one of: ${validModes.join(\", \")}`);\n322:   }\n323:   if (!config.agentRegistry.source) {\n324:     throw new Error(\"config.agentRegistry.source must be a non-empty string\");\n325:   }\n326:   if (!config.agentRegistry.cacheDir) {\n327:     throw new Error(\"config.agentRegistry.cacheDir must be a non-empty string\");\n328:   }\n329: }\n330: \n331: /**\n332:  * Generate the default .wombo-combo/config.json content string (for `woco init`).\n333:  */\n334: export function generateDefaultConfig(): string {\n335:   return JSON.stringify(DEFAULT_CONFIG, null, 2) + \"\\n\";\n336: }\n\n(End of file - total 336 lines)\n</content>","title":"src/config.ts","metadata":{"preview":"/**\n * config.ts — Load .wombo-combo/config.json, merge with defaults, validate, expose typed config.\n *\n * The config file lives at .wombo-combo/config.json inside the target project root.\n * All values have sensible defaults so minimal config works out of the box.\n */\n\nimport { readFileSync, existsSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\nimport type { MultiplexerPreference } from \"./lib/multiplexer.js\";\n\n// ---------------------------------------------------------------------------\n// .wombo-combo directory constant\n// ---------------------------------------------------------------------------\n\n/** Name of the directory that holds all wombo-combo files */\nexport const WOMBO_DIR = \".wombo-combo\";\n\n// ---------------------------------------------------------------------------\n// Types","truncated":false,"loaded":[]},"time":{"start":1773433297473,"end":1773433297587}}}}
