{"type":"tool_use","timestamp":1773433427081,"sessionID":"ses_31721ba8fffeXD00hbThRJI7PX","part":{"id":"prt_ce8de8fa5001Q7HczkaTHP8ZtV","sessionID":"ses_31721ba8fffeXD00hbThRJI7PX","messageID":"msg_ce8de838d001LkeCV7if6aUuu2","type":"tool","callID":"toolu_vrtx_01JnD5ERJZ9dyDQKSuYMCrTC","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-toon-format-spec/src/lib/schema.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-toon-format-spec/src/lib/schema.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * schema.ts — Declarative command/flag registry for schema introspection.\n3:  *\n4:  * Every command and flag is described in a single registry. This registry is\n5:  * the source of truth for:\n6:  *   1. `woco describe <command>` — emits a JSON schema of accepted args\n7:  *   2. Future help text generation\n8:  *\n9:  * The registry is NOT used for actual arg parsing (that's still the hand-rolled\n10:  * switch in index.ts), but the two must stay in sync. If they drift, `woco\n11:  * tasks check` should eventually catch it.\n12:  */\n13: \n14: import { readFileSync } from \"node:fs\";\n15: import { resolve } from \"node:path\";\n16: import { VALID_STATUSES, VALID_PRIORITIES, VALID_DIFFICULTIES } from \"./task-schema.js\";\n17: \n18: // ---------------------------------------------------------------------------\n19: // Dynamic version reader\n20: // ---------------------------------------------------------------------------\n21: \n22: function getVersion(): string {\n23:   try {\n24:     const pkgPath = resolve(import.meta.dir, \"../../package.json\");\n25:     const raw = readFileSync(pkgPath, \"utf-8\");\n26:     return JSON.parse(raw).version as string;\n27:   } catch {\n28:     return \"unknown\";\n29:   }\n30: }\n31: \n32: // ---------------------------------------------------------------------------\n33: // Types\n34: // ---------------------------------------------------------------------------\n35: \n36: export interface FlagDef {\n37:   /** Primary flag name, e.g. \"--dry-run\" */\n38:   name: string;\n39:   /** Short alias, e.g. \"-o\" */\n40:   alias?: string;\n41:   /** Description shown in help / schema */\n42:   description: string;\n43:   /** Type of the value: \"boolean\" flags take no value, others consume next arg */\n44:   type: \"string\" | \"number\" | \"boolean\" | \"string[]\";\n45:   /** Default value (undefined = required or absent) */\n46:   default?: unknown;\n47:   /** For enum-like flags, the set of allowed values */\n48:   enum?: readonly string[];\n49:   /** If true, this flag is required */\n50:   required?: boolean;\n51: }\n52: \n53: export interface PositionalDef {\n54:   /** Name used in usage strings, e.g. \"feature-id\" */\n55:   name: string;\n56:   description: string;\n57:   required?: boolean;\n58: }\n59: \n60: export interface CommandDef {\n61:   /** Command name as typed by the user, e.g. \"launch\" or \"features list\" */\n62:   name: string;\n63:   /** One-line summary */\n64:   summary: string;\n65:   /** Longer description */\n66:   description?: string;\n67:   /** Positional arguments */\n68:   positionals: PositionalDef[];\n69:   /** Named flags */\n70:   flags: FlagDef[];\n71:   /** Whether this command mutates state (used for dry-run indication) */\n72:   mutating: boolean;\n73:   /** Whether this command supports --dry-run */\n74:   supportsDryRun: boolean;\n75:   /** Subcommands (for \"tasks\" parent) */\n76:   subcommands?: CommandDef[];\n77: }\n78: \n79: // ---------------------------------------------------------------------------\n80: // Global flags (available on every command)\n81: // ---------------------------------------------------------------------------\n82: \n83: const GLOBAL_FLAGS: FlagDef[] = [\n84:   {\n85:     name: \"--output\",\n86:     alias: \"-o\",\n87:     description: \"Output format: text (default) or json\",\n88:     type: \"string\",\n89:     default: \"text\",\n90:     enum: [\"text\", \"json\"],\n91:   },\n92:   {\n93:     name: \"--force\",\n94:     description: \"Force overwrite / skip safety prompts\",\n95:     type: \"boolean\",\n96:     default: false,\n97:   },\n98: ];\n99: \n100: // ---------------------------------------------------------------------------\n101: // Command Registry\n102: // ---------------------------------------------------------------------------\n103: \n104: export const COMMAND_REGISTRY: CommandDef[] = [\n105:   // --- init ---------------------------------------------------------------\n106:   {\n107:     name: \"init\",\n108:     summary: \"Generate .wombo-combo/config.json in the current project\",\n109:     description:\n110:       \"Interactive guided setup that walks through every config section. \" +\n111:       \"Creates .wombo-combo/config.json and .wombo-combo/tasks.yml from template.\",\n112:     positionals: [],\n113:     flags: [\n114:       {\n115:         name: \"--force\",\n116:         description: \"Overwrite existing config files\",\n117:         type: \"boolean\",\n118:         default: false,\n119:       },\n120:       {\n121:         name: \"--dry-run\",\n122:         description: \"Show what would be created without writing files\",\n123:         type: \"boolean\",\n124:         default: false,\n125:       },\n126:     ],\n127:     mutating: true,\n128:     supportsDryRun: true,\n129:   },\n130: \n131:   // --- launch -------------------------------------------------------------\n132:   {\n133:     name: \"launch\",\n134:     summary: \"Launch a wave of agents to implement features\",\n135:     description:\n136:       \"Select features from the tasks file, create worktrees, and spawn agents. \" +\n137:       \"Supports multiple selection strategies.\",\n138:     positionals: [],\n139:     flags: [\n140:       { name: \"--top-priority\", description: \"Select top N features by priority\", type: \"number\" },\n141:       { name: \"--quickest-wins\", description: \"Select N features with lowest effort\", type: \"number\" },\n142:       { name: \"--priority\", description: \"Filter by priority level\", type: \"string\", enum: VALID_PRIORITIES },\n143:       { name: \"--difficulty\", description: \"Filter by difficulty level\", type: \"string\", enum: VALID_DIFFICULTIES },\n144:       { name: \"--features\", description: \"Select specific features by comma-separated IDs (alias for --tasks)\", type: \"string\" },\n145:       { name: \"--tasks\", description: \"Select specific tasks by comma-separated IDs\", type: \"string\" },\n146:       { name: \"--all-ready\", description: \"Select all features whose dependencies are met\", type: \"boolean\", default: false },\n147:       { name: \"--max-concurrent\", description: \"Max agents running in parallel\", type: \"number\" },\n148:       { name: \"--model\", alias: \"-m\", description: \"Model to use (e.g., anthropic/claude-sonnet-4-20250514)\", type: \"string\" },\n149:       { name: \"--interactive\", description: \"Use multiplexer (dmux/tmux) TUI mode instead of headless\", type: \"boolean\", default: false },\n150:       { name: \"--no-tui\", description: \"Headless mode without neo-blessed TUI\", type: \"boolean\", default: false },\n151:       { name: \"--auto-push\", description: \"Push base branch to remote after all merges\", type: \"boolean\", default: false },\n152:       { name: \"--dry-run\", description: \"Show what would be launched without launching\", type: \"boolean\", default: false },\n153:       { name: \"--base-branch\", description: \"Base branch (default: from config)\", type: \"string\" },\n154:       { name: \"--max-retries\", description: \"Max retries per agent\", type: \"number\" },\n155:       { name: \"--browser\", description: \"Enable browser-based verification after build passes\", type: \"boolean\", default: false },\n156:     ],\n157:     mutating: true,\n158:     supportsDryRun: true,\n159:   },\n160: \n161:   // --- resume -------------------------------------------------------------\n162:   {\n163:     name: \"resume\",\n164:     summary: \"Resume a previously stopped wave\",\n165:     positionals: [],\n166:     flags: [\n167:       { name: \"--max-concurrent\", description: \"Max agents running in parallel\", type: \"number\" },\n168:       { name: \"--model\", alias: \"-m\", description: \"Model to use\", type: \"string\" },\n169:       { name: \"--interactive\", description: \"Use multiplexer (dmux/tmux) TUI mode\", type: \"boolean\", default: false },\n170:       { name: \"--no-tui\", description: \"Headless mode without neo-blessed TUI\", type: \"boolean\", default: false },\n171:       { name: \"--auto-push\", description: \"Push base branch to remote after merges\", type: \"boolean\", default: false },\n172:       { name: \"--base-branch\", description: \"Base branch override\", type: \"string\" },\n173:       { name: \"--max-retries\", description: \"Max retries per agent\", type: \"number\" },\n174:     ],\n175:     mutating: true,\n176:     supportsDryRun: false,\n177:   },\n178: \n179:   // --- status -------------------------------------------------------------\n180:   {\n181:     name: \"status\",\n182:     summary: \"Show the status of the current wave\",\n183:     positionals: [],\n184:     flags: [],\n185:     mutating: false,\n186:     supportsDryRun: false,\n187:   },\n188: \n189:   // --- verify -------------------------------------------------------------\n190:   {\n191:     name: \"verify\",\n192:     summary: \"Run build verification on completed agents\",\n193:     positionals: [\n194:       { name: \"feature-id\", description: \"Specific feature to verify (optional)\", required: false },\n195:     ],\n196:     flags: [\n197:       { name: \"--model\", alias: \"-m\", description: \"Model to use for verification\", type: \"string\" },\n198:       { name: \"--max-retries\", description: \"Max retries\", type: \"number\" },\n199:       { name: \"--browser\", description: \"Enable browser-based verification after build passes\", type: \"boolean\", default: false },\n200:     ],\n201:     mutating: true,\n202:     supportsDryRun: false,\n203:   },\n204: \n205:   // --- merge --------------------------------------------------------------\n206:   {\n207:     name: \"merge\",\n208:     summary: \"Merge verified branches into the base branch\",\n209:     positionals: [\n210:       { name: \"feature-id\", description: \"Specific feature to merge (optional)\", required: false },\n211:     ],\n212:     flags: [\n213:       { name: \"--auto-push\", description: \"Push base branch to remote after merge\", type: \"boolean\", default: false },\n214:       { name: \"--dry-run\", description: \"Show what would be merged without merging\", type: \"boolean\", default: false },\n215:     ],\n216:     mutating: true,\n217:     supportsDryRun: true,\n218:   },\n219: \n220:   // --- retry --------------------------------------------------------------\n221:   {\n222:     name: \"retry\",\n223:     summary: \"Retry a failed agent\",\n224:     positionals: [\n225:       { name: \"feature-id\", description: \"Feature ID of the failed agent\", required: true },\n226:     ],\n227:     flags: [\n228:       { name: \"--model\", alias: \"-m\", description: \"Model to use\", type: \"string\" },\n229:       { name: \"--interactive\", description: \"Use multiplexer (dmux/tmux) TUI mode\", type: \"boolean\", default: false },\n230:       { name: \"--dry-run\", description: \"Show what would be retried without retrying\", type: \"boolean\", default: false },\n231:     ],\n232:     mutating: true,\n233:     supportsDryRun: true,\n234:   },\n235: \n236:   // --- cleanup ------------------------------------------------------------\n237:   {\n238:     name: \"cleanup\",\n239:     summary: \"Remove all wave worktrees and multiplexer sessions\",\n240:     description: \"Kills multiplexer sessions, removes worktrees, removes state and log files.\",\n241:     positionals: [],\n242:     flags: [\n243:       { name: \"--dry-run\", description: \"Show what would be cleaned up without removing\", type: \"boolean\", default: false },\n244:     ],\n245:     mutating: true,\n246:     supportsDryRun: true,\n247:   },\n248: \n249:   // --- history ------------------------------------------------------------\n250:   {\n251:     name: \"history\",\n252:     summary: \"List/view past wave results from .wombo-combo/history/\",\n253:     description:\n254:       \"Wave history is auto-exported when a wave completes. Records are stored \" +\n255:       \"separately from .wombo-combo/state.json and survive cleanup. Use without arguments \" +\n256:       \"to list all waves, or pass a wave ID to see detailed results.\",\n257:     positionals: [\n258:       { name: \"wave-id\", description: \"Specific wave ID to show details for (optional)\", required: false },\n259:     ],\n260:     flags: [],\n261:     mutating: false,\n262:     supportsDryRun: false,\n263:   },\n264: \n265:   // --- abort --------------------------------------------------------------\n266:   {\n267:     name: \"abort\",\n268:     summary: \"Kill a single running agent without affecting the rest of the wave\",\n269:     description:\n270:       \"Kills the multiplexer session and agent process for a specific feature, then \" +\n271:       \"marks the agent as failed. Use --requeue to return the feature to the \" +\n272:       \"queue instead of marking it failed.\",\n273:     positionals: [\n274:       { name: \"feature-id\", description: \"Feature ID of the agent to abort\", required: true },\n275:     ],\n276:     flags: [\n277:       { name: \"--requeue\", description: \"Return the feature to queued instead of marking it failed\", type: \"boolean\", default: false },\n278:     ],\n279:     mutating: true,\n280:     supportsDryRun: false,\n281:   },\n282: \n283:   // --- upgrade ------------------------------------------------------------\n284:   {\n285:     name: \"upgrade\",\n286:     summary: \"Check for updates and upgrade wombo\",\n287:     positionals: [],\n288:     flags: [\n289:       { name: \"--check\", description: \"Only check for updates, don't install\", type: \"boolean\", default: false },\n290:       { name: \"--tag\", alias: \"--release\", description: \"Install a specific version (e.g., v0.1.0)\", type: \"string\" },\n291:       { name: \"--force\", description: \"Force reinstall even if up to date\", type: \"boolean\", default: false },\n292:     ],\n293:     mutating: true,\n294:     supportsDryRun: false,\n295:   },\n296: \n297:   // --- logs ---------------------------------------------------------------\n298:   {\n299:     name: \"logs\",\n300:     summary: \"Pretty-print agent logs from .wombo-combo/logs/<feature-id>.log\",\n301:     description:\n302:       \"Reads log files written by agents during headless runs and displays \" +\n303:       \"them with colorized output. Supports tailing and following.\",\n304:     positionals: [\n305:       { name: \"feature-id\", description: \"Feature ID whose logs to display\", required: true },\n306:     ],\n307:     flags: [\n308:       { name: \"--tail\", description: \"Show only the last N lines\", type: \"number\" },\n309:       { name: \"--follow\", alias: \"-f\", description: \"Stream new output as it arrives (like tail -f)\", type: \"boolean\", default: false },\n310:     ],\n311:     mutating: false,\n312:     supportsDryRun: false,\n313:   },\n314: \n315:   // --- tasks (parent with subcommands) — also accepts \"features\" as alias ---\n316:   {\n317:     name: \"tasks\",\n318:     summary: \"Manage tasks file\",\n319:     positionals: [],\n320:     flags: [],\n321:     mutating: false,\n322:     supportsDryRun: false,\n323:     subcommands: [\n324:       {\n325:         name: \"tasks list\",\n326:         summary: \"List tasks with optional filtering\",\n327:         positionals: [],\n328:         flags: [\n329:           { name: \"--status\", description: \"Filter by status\", type: \"string\", enum: VALID_STATUSES },\n330:           { name: \"--priority\", description: \"Filter by priority\", type: \"string\", enum: VALID_PRIORITIES },\n331:           { name: \"--difficulty\", description: \"Filter by difficulty\", type: \"string\", enum: VALID_DIFFICULTIES },\n332:           { name: \"--ready\", description: \"Show only ready tasks (backlog + deps met)\", type: \"boolean\", default: false },\n333:           { name: \"--include-archive\", description: \"Include archived tasks\", type: \"boolean\", default: false },\n334:           { name: \"--fields\", description: \"Comma-separated list of fields to include in output\", type: \"string\" },\n335:         ],\n336:         mutating: false,\n337:         supportsDryRun: false,\n338:       },\n339:       {\n340:         name: \"tasks add\",\n341:         summary: \"Add a new task\",\n342:         positionals: [\n343:           { name: \"id\", description: \"Task ID (kebab-case)\", required: true },\n344:           { name: \"title\", description: \"Task title\", required: true },\n345:         ],\n346:         flags: [\n347:           { name: \"--description\", alias: \"--desc\", description: \"Task description\", type: \"string\" },\n348:           { name: \"--priority\", description: \"Priority level\", type: \"string\", default: \"medium\", enum: VALID_PRIORITIES },\n349:           { name: \"--difficulty\", description: \"Difficulty level\", type: \"string\", default: \"medium\", enum: VALID_DIFFICULTIES },\n350:           { name: \"--effort\", description: \"Effort estimate (ISO 8601 duration, e.g. PT2H)\", type: \"string\", default: \"PT1H\" },\n351:           { name: \"--depends-on\", description: \"Comma-separated dependency IDs\", type: \"string\" },\n352:           { name: \"--dry-run\", description: \"Show what would be added without writing\", type: \"boolean\", default: false },\n353:         ],\n354:         mutating: true,\n355:         supportsDryRun: true,\n356:       },\n357:       {\n358:         name: \"tasks set-status\",\n359:         summary: \"Change a task's status\",\n360:         positionals: [\n361:           { name: \"task-id\", description: \"Task ID to update\", required: true },\n362:           { name: \"status\", description: \"New status value\", required: true },\n363:         ],\n364:         flags: [\n365:           { name: \"--dry-run\", description: \"Show what would change without writing\", type: \"boolean\", default: false },\n366:         ],\n367:         mutating: true,\n368:         supportsDryRun: true,\n369:       },\n370:       {\n371:         name: \"tasks set-priority\",\n372:         summary: \"Change a task's priority\",\n373:         positionals: [\n374:           { name: \"task-id\", description: \"Task ID to update\", required: true },\n375:           { name: \"priority\", description: \"New priority value\", required: true },\n376:         ],\n377:         flags: [\n378:           { name: \"--dry-run\", description: \"Show what would change without writing\", type: \"boolean\", default: false },\n379:         ],\n380:         mutating: true,\n381:         supportsDryRun: true,\n382:       },\n383:       {\n384:         name: \"tasks set-difficulty\",\n385:         summary: \"Change a task's difficulty\",\n386:         positionals: [\n387:           { name: \"task-id\", description: \"Task ID to update\", required: true },\n388:           { name: \"difficulty\", description: \"New difficulty value\", required: true },\n389:         ],\n390:         flags: [\n391:           { name: \"--dry-run\", description: \"Show what would change without writing\", type: \"boolean\", default: false },\n392:         ],\n393:         mutating: true,\n394:         supportsDryRun: true,\n395:       },\n396:       {\n397:         name: \"tasks check\",\n398:         summary: \"Validate tasks file (schema, deps, duplicates, cycles)\",\n399:         positionals: [],\n400:         flags: [],\n401:         mutating: false,\n402:         supportsDryRun: false,\n403:       },\n404:       {\n405:         name: \"tasks archive\",\n406:         summary: \"Move done/cancelled tasks to archive section\",\n407:         positionals: [\n408:           { name: \"task-id\", description: \"Specific task to archive (optional)\", required: false },\n409:         ],\n410:         flags: [\n411:           { name: \"--dry-run\", description: \"Show what would be archived without moving\", type: \"boolean\", default: false },\n412:         ],\n413:         mutating: true,\n414:         supportsDryRun: true,\n415:       },\n416:       {\n417:         name: \"tasks show\",\n418:         summary: \"Show detailed information about a specific task\",\n419:         positionals: [\n420:           { name: \"task-id\", description: \"Task ID to display\", required: true },\n421:         ],\n422:         flags: [\n423:           { name: \"--fields\", description: \"Comma-separated list of fields to include in output\", type: \"string\" },\n424:         ],\n425:         mutating: false,\n426:         supportsDryRun: false,\n427:       },\n428:       {\n429:         name: \"tasks graph\",\n430:         summary: \"Visualize the task dependency graph as a terminal diagram\",\n431:         description:\n432:           \"Builds a Mermaid flowchart from the tasks dependency graph and renders \" +\n433:           \"it as a Unicode box diagram. Shows dependency edges, status badges, orphan \" +\n434:           \"detection, dangling dependency warnings, and cycle detection.\",\n435:         positionals: [],\n436:         flags: [\n437:           { name: \"--status\", description: \"Filter graph to tasks with this status\", type: \"string\", enum: VALID_STATUSES },\n438:           { name: \"--ascii\", description: \"Use ASCII-only rendering (no Unicode box chars)\", type: \"boolean\", default: false },\n439:           { name: \"--mermaid\", description: \"Emit raw Mermaid source instead of rendered graph\", type: \"boolean\", default: false },\n440:           { name: \"--subtasks\", description: \"Include subtask-level nodes in the graph\", type: \"boolean\", default: false },\n441:         ],\n442:         mutating: false,\n443:         supportsDryRun: false,\n444:       },\n445:     ],\n446:   },\n447: \n448:   // --- help ---------------------------------------------------------------\n449:   {\n450:     name: \"help\",\n451:     summary: \"Show help text\",\n452:     positionals: [],\n453:     flags: [],\n454:     mutating: false,\n455:     supportsDryRun: false,\n456:   },\n457: \n458:   // --- version -----------------------------------------------------------\n459:   {\n460:     name: \"version\",\n461:     summary: \"Print version and exit (also: -v, -V)\",\n462:     positionals: [],\n463:     flags: [],\n464:     mutating: false,\n465:     supportsDryRun: false,\n466:   },\n467: \n468:   // --- describe -----------------------------------------------------------\n469:   {\n470:     name: \"describe\",\n471:     summary: \"Emit JSON schema of a command's arguments and flags\",\n472:     description:\n473:       \"Machine-readable introspection for AI agents. Outputs the accepted \" +\n474:       \"positionals, flags, types, defaults, and constraints for a command.\",\n475:     positionals: [\n476:       { name: \"command\", description: \"Command to describe (e.g. 'launch', 'features add')\", required: false },\n477:     ],\n478:     flags: [],\n479:     mutating: false,\n480:     supportsDryRun: false,\n481:   },\n482: ];\n483: \n484: // ---------------------------------------------------------------------------\n485: // Lookup helpers\n486: // ---------------------------------------------------------------------------\n487: \n488: /**\n489:  * Find a command definition by name. Supports compound names like \"tasks list\".\n490:  * Also supports \"features\" as a backward-compat alias for \"tasks\".\n491:  */\n492: export function findCommandDef(name: string): CommandDef | undefined {\n493:   // Normalize \"features\" -> \"tasks\" for backward compatibility\n494:   const normalized = name.replace(/^features(\\s|$)/, \"tasks$1\");\n495: \n496:   // Try direct match first\n497:   const direct = COMMAND_REGISTRY.find((c) => c.name === normalized);\n498:   if (direct) return direct;\n499: \n500:   // Try compound: \"tasks list\" -> look in tasks subcommands\n501:   const parts = normalized.split(/\\s+/);\n502:   if (parts.length === 2) {\n503:     const parent = COMMAND_REGISTRY.find((c) => c.name === parts[0]);\n504:     if (parent?.subcommands) {\n505:       return parent.subcommands.find((sc) => sc.name === normalized || sc.name === parts[1]);\n506:     }\n507:   }\n508: \n509:   return undefined;\n510: }\n511: \n512: /**\n513:  * Produce the JSON schema object for a command, suitable for agent consumption.\n514:  */\n515: export function commandToSchema(cmd: CommandDef): Record<string, unknown> {\n516:   const schema: Record<string, unknown> = {\n517:     command: cmd.name,\n518:     summary: cmd.summary,\n519:     mutating: cmd.mutating,\n520:     supports_dry_run: cmd.supportsDryRun,\n521:   };\n522: \n523:   if (cmd.description) {\n524:     schema.description = cmd.description;\n525:   }\n526: \n527:   if (cmd.positionals.length > 0) {\n528:     schema.positionals = cmd.positionals.map((p) => ({\n529:       name: p.name,\n530:       description: p.description,\n531:       required: p.required ?? false,\n532:     }));\n533:   }\n534: \n535:   const allFlags = [...cmd.flags, ...GLOBAL_FLAGS];\n536:   schema.flags = allFlags.map((f) => {\n537:     const entry: Record<string, unknown> = {\n538:       name: f.name,\n539:       type: f.type,\n540:       description: f.description,\n541:     };\n542:     if (f.alias) entry.alias = f.alias;\n543:     if (f.default !== undefined) entry.default = f.default;\n544:     if (f.enum) entry.enum = f.enum;\n545:     if (f.required) entry.required = true;\n546:     return entry;\n547:   });\n548: \n549:   if (cmd.subcommands?.length) {\n550:     schema.subcommands = cmd.subcommands.map((sc) => sc.name);\n551:   }\n552: \n553:   return schema;\n554: }\n555: \n556: /**\n557:  * Produce a listing of all commands (for `woco describe` with no args).\n558:  */\n559: export function allCommandSchemas(): Record<string, unknown> {\n560:   const commands: Record<string, unknown>[] = [];\n561: \n562:   for (const cmd of COMMAND_REGISTRY) {\n563:     const entry: Record<string, unknown> = {\n564:       name: cmd.name,\n565:       summary: cmd.summary,\n566:       mutating: cmd.mutating,\n567:       supports_dry_run: cmd.supportsDryRun,\n568:     };\n569:     if (cmd.subcommands) {\n570:       entry.subcommands = cmd.subcommands.map((sc) => ({\n571:         name: sc.name,\n572:         summary: sc.summary,\n573:         mutating: sc.mutating,\n574:         supports_dry_run: sc.supportsDryRun,\n575:       }));\n576:     }\n577:     commands.push(entry);\n578:   }\n579: \n580:   return {\n581:     tool: \"wombo-combo\",\n582:     version: getVersion(),\n583:     global_flags: GLOBAL_FLAGS.map((f) => ({\n584:       name: f.name,\n585:       alias: f.alias,\n586:       type: f.type,\n587:       description: f.description,\n588:       default: f.default,\n589:     })),\n590:     commands,\n591:   };\n592: }\n\n(End of file - total 592 lines)\n</content>","title":"src/lib/schema.ts","metadata":{"preview":"/**\n * schema.ts — Declarative command/flag registry for schema introspection.\n *\n * Every command and flag is described in a single registry. This registry is\n * the source of truth for:\n *   1. `woco describe <command>` — emits a JSON schema of accepted args\n *   2. Future help text generation\n *\n * The registry is NOT used for actual arg parsing (that's still the hand-rolled\n * switch in index.ts), but the two must stay in sync. If they drift, `woco\n * tasks check` should eventually catch it.\n */\n\nimport { readFileSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\nimport { VALID_STATUSES, VALID_PRIORITIES, VALID_DIFFICULTIES } from \"./task-schema.js\";\n\n// ---------------------------------------------------------------------------\n// Dynamic version reader\n// ---------------------------------------------------------------------------","truncated":false,"loaded":[]},"time":{"start":1773433427047,"end":1773433427059}}}}
{"type":"tool_use","timestamp":1773433427665,"sessionID":"ses_31721ba8fffeXD00hbThRJI7PX","part":{"id":"prt_ce8de946c001FCDufZP1W1SZGU","sessionID":"ses_31721ba8fffeXD00hbThRJI7PX","messageID":"msg_ce8de838d001LkeCV7if6aUuu2","type":"tool","callID":"toolu_vrtx_016JvJT3irw1X3jp4uTtpLyt","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-toon-format-spec/src/lib/task-schema.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-toon-format-spec/src/lib/task-schema.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * task-schema.ts — Single source of truth for task field enums, ordering,\n3:  * required fields, and validation.\n4:  *\n5:  * Every command that needs to validate or enumerate task field values should\n6:  * import from here. No more duplicated VALID_* arrays.\n7:  */\n8: \n9: import type { TaskStatus, Priority, Difficulty, Task } from \"./tasks.js\";\n10: import { parseDurationMinutes } from \"./tasks.js\";\n11: import { validateId, type ValidationResult } from \"./validate.js\";\n12: \n13: // ---------------------------------------------------------------------------\n14: // Canonical enum arrays (order matters: used for display and sorting)\n15: // ---------------------------------------------------------------------------\n16: \n17: export const VALID_STATUSES: readonly TaskStatus[] = [\n18:   \"backlog\",\n19:   \"planned\",\n20:   \"in_progress\",\n21:   \"blocked\",\n22:   \"in_review\",\n23:   \"done\",\n24:   \"cancelled\",\n25: ] as const;\n26: \n27: export const VALID_PRIORITIES: readonly Priority[] = [\n28:   \"critical\",\n29:   \"high\",\n30:   \"medium\",\n31:   \"low\",\n32:   \"wishlist\",\n33: ] as const;\n34: \n35: export const VALID_DIFFICULTIES: readonly Difficulty[] = [\n36:   \"trivial\",\n37:   \"easy\",\n38:   \"medium\",\n39:   \"hard\",\n40:   \"very_hard\",\n41: ] as const;\n42: \n43: // ---------------------------------------------------------------------------\n44: // Ordering maps (lower = more important / easier)\n45: // ---------------------------------------------------------------------------\n46: \n47: export const PRIORITY_ORDER: Readonly<Record<Priority, number>> = {\n48:   critical: 0,\n49:   high: 1,\n50:   medium: 2,\n51:   low: 3,\n52:   wishlist: 4,\n53: };\n54: \n55: export const DIFFICULTY_ORDER: Readonly<Record<Difficulty, number>> = {\n56:   trivial: 0,\n57:   easy: 1,\n58:   medium: 2,\n59:   hard: 3,\n60:   very_hard: 4,\n61: };\n62: \n63: // ---------------------------------------------------------------------------\n64: // _meta.yml schema\n65: // ---------------------------------------------------------------------------\n66: \n67: export interface MetaSchema {\n68:   version: string;\n69:   meta: {\n70:     created_at: string;\n71:     updated_at: string;\n72:     project: string;\n73:     generator: string;\n74:     maintainer: string;\n75:   };\n76: }\n77: \n78: export const META_REQUIRED_FIELDS = [\"version\", \"meta\"] as const;\n79: export const META_INNER_REQUIRED_FIELDS = [\n80:   \"created_at\",\n81:   \"updated_at\",\n82:   \"project\",\n83:   \"generator\",\n84:   \"maintainer\",\n85: ] as const;\n86: \n87: // ---------------------------------------------------------------------------\n88: // Task schema — required fields and array-defaulted fields\n89: // ---------------------------------------------------------------------------\n90: \n91: export const TASK_REQUIRED_FIELDS = [\"id\", \"title\", \"status\"] as const;\n92: \n93: /** Fields that must be arrays; YAML may parse absent values as null */\n94: export const TASK_ARRAY_FIELDS = [\n95:   \"depends_on\",\n96:   \"constraints\",\n97:   \"forbidden\",\n98:   \"references\",\n99:   \"notes\",\n100:   \"subtasks\",\n101: ] as const;\n102: \n103: // ---------------------------------------------------------------------------\n104: // Validation result\n105: // ---------------------------------------------------------------------------\n106: \n107: export interface SchemaIssue {\n108:   level: \"error\" | \"warning\";\n109:   taskId: string;\n110:   message: string;\n111: }\n112: \n113: // ---------------------------------------------------------------------------\n114: // Validate a single task object\n115: // ---------------------------------------------------------------------------\n116: \n117: /**\n118:  * Validate a task against the schema. Returns a list of issues (errors and\n119:  * warnings). Does NOT throw — callers decide how to handle issues.\n120:  *\n121:  * Checks:\n122:  *   - Required fields: id, title, status\n123:  *   - id format (kebab-case via validateId)\n124:  *   - status is a valid enum\n125:  *   - priority is a valid enum (if present)\n126:  *   - difficulty is a valid enum (if present)\n127:  *   - effort is a parseable ISO 8601 duration (warning if not)\n128:  *   - completion is 0-100 (warning if out of range)\n129:  *   - depends_on entries are strings (structural check only; cross-ref is\n130:  *     done by check.ts which has access to the full task set)\n131:  */\n132: export function validateTask(task: unknown): SchemaIssue[] {\n133:   const issues: SchemaIssue[] = [];\n134:   const t = task as Record<string, unknown>;\n135:   const id = typeof t?.id === \"string\" ? t.id : \"<unknown>\";\n136: \n137:   // Required fields\n138:   for (const field of TASK_REQUIRED_FIELDS) {\n139:     if (!t?.[field]) {\n140:       issues.push({ level: \"error\", taskId: id, message: `Missing required field: ${field}` });\n141:     }\n142:   }\n143: \n144:   // id format\n145:   if (typeof t?.id === \"string\") {\n146:     const idResult: ValidationResult = validateId(t.id, \"Task ID\");\n147:     if (!idResult.valid) {\n148:       issues.push({ level: \"error\", taskId: id, message: idResult.error! });\n149:     }\n150:   }\n151: \n152:   // status enum\n153:   if (t?.status && !(VALID_STATUSES as readonly string[]).includes(t.status as string)) {\n154:     issues.push({ level: \"error\", taskId: id, message: `Invalid status: \"${t.status}\"` });\n155:   }\n156: \n157:   // priority enum\n158:   if (t?.priority && !(VALID_PRIORITIES as readonly string[]).includes(t.priority as string)) {\n159:     issues.push({ level: \"error\", taskId: id, message: `Invalid priority: \"${t.priority}\"` });\n160:   }\n161: \n162:   // difficulty enum\n163:   if (t?.difficulty && !(VALID_DIFFICULTIES as readonly string[]).includes(t.difficulty as string)) {\n164:     issues.push({ level: \"error\", taskId: id, message: `Invalid difficulty: \"${t.difficulty}\"` });\n165:   }\n166: \n167:   // effort duration\n168:   if (typeof t?.effort === \"string\" && t.effort.length > 0) {\n169:     const minutes = parseDurationMinutes(t.effort);\n170:     if (minutes === Infinity) {\n171:       issues.push({ level: \"warning\", taskId: id, message: `Unparseable effort duration: \"${t.effort}\"` });\n172:     }\n173:   } else if (!t?.effort || t.effort === \"PT0S\") {\n174:     issues.push({ level: \"warning\", taskId: id, message: \"No effort estimate\" });\n175:   }\n176: \n177:   // completion range\n178:   if (typeof t?.completion === \"number\" && (t.completion < 0 || t.completion > 100)) {\n179:     issues.push({ level: \"warning\", taskId: id, message: `Completion ${t.completion} is out of range 0-100` });\n180:   }\n181: \n182:   // depends_on structural check\n183:   if (t?.depends_on != null && !Array.isArray(t.depends_on)) {\n184:     issues.push({ level: \"error\", taskId: id, message: \"depends_on must be an array\" });\n185:   }\n186: \n187:   return issues;\n188: }\n189: \n190: // ---------------------------------------------------------------------------\n191: // Validate _meta.yml\n192: // ---------------------------------------------------------------------------\n193: \n194: /**\n195:  * Validate a parsed _meta.yml object. Returns issues.\n196:  */\n197: export function validateMeta(meta: unknown): SchemaIssue[] {\n198:   const issues: SchemaIssue[] = [];\n199:   const m = meta as Record<string, unknown>;\n200:   const id = \"_meta.yml\";\n201: \n202:   if (!m?.version) {\n203:     issues.push({ level: \"error\", taskId: id, message: \"Missing required field: version\" });\n204:   }\n205: \n206:   if (!m?.meta || typeof m.meta !== \"object\") {\n207:     issues.push({ level: \"error\", taskId: id, message: \"Missing required field: meta\" });\n208:     return issues; // Can't check inner fields\n209:   }\n210: \n211:   const inner = m.meta as Record<string, unknown>;\n212:   for (const field of META_INNER_REQUIRED_FIELDS) {\n213:     if (!inner[field]) {\n214:       issues.push({ level: \"warning\", taskId: id, message: `Missing meta field: ${field}` });\n215:     }\n216:   }\n217: \n218:   return issues;\n219: }\n\n(End of file - total 219 lines)\n</content>","title":"src/lib/task-schema.ts","metadata":{"preview":"/**\n * task-schema.ts — Single source of truth for task field enums, ordering,\n * required fields, and validation.\n *\n * Every command that needs to validate or enumerate task field values should\n * import from here. No more duplicated VALID_* arrays.\n */\n\nimport type { TaskStatus, Priority, Difficulty, Task } from \"./tasks.js\";\nimport { parseDurationMinutes } from \"./tasks.js\";\nimport { validateId, type ValidationResult } from \"./validate.js\";\n\n// ---------------------------------------------------------------------------\n// Canonical enum arrays (order matters: used for display and sorting)\n// ---------------------------------------------------------------------------\n\nexport const VALID_STATUSES: readonly TaskStatus[] = [\n  \"backlog\",\n  \"planned\",\n  \"in_progress\",","truncated":false,"loaded":[]},"time":{"start":1773433427655,"end":1773433427663}}}}
