"status":"in_progress"},{"content":"Add 'toon' to OutputFormat type and resolveOutputFormat in src/lib/output.ts","priority":"high","status":"pending"},{"content":"Update the describe command in src/index.ts to support --output toon and emit the TOON legend","priority":"high","status":"pending"},{"content":"Update the --output flag enum in schema.ts to include 'toon'","priority":"medium","status":"pending"},{"content":"Run typecheck and build to verify","priority":"high","status":"pending"}],"truncated":false},"time":{"start":1773433444264,"end":1773433444266}}}}
