{"type":"tool_use","timestamp":1773433431998,"sessionID":"ses_31721ba8fffeXD00hbThRJI7PX","part":{"id":"prt_ce8dea4db001vXxsZ05J9dYaWf","sessionID":"ses_31721ba8fffeXD00hbThRJI7PX","messageID":"msg_ce8de98be001EoLFp7bMRk6C75","type":"tool","callID":"toolu_vrtx_01SKgpEoBXWKZots8zZxrgLX","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-toon-format-spec/src/commands/tasks/list.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-toon-format-spec/src/commands/tasks/list.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tasks/list.ts — List and filter tasks from the tasks file.\n3:  *\n4:  * Usage:\n5:  *   woco tasks list                     # list all tasks\n6:  *   woco tasks list --status backlog    # filter by status\n7:  *   woco tasks list --priority high     # filter by priority\n8:  *   woco tasks list --ready             # show only ready tasks\n9:  *   woco tasks list --archive           # include archived tasks\n10:  */\n11: \n12: import type { WomboConfig } from \"../../config.js\";\n13: import {\n14:   loadFeatures,\n15:   getReadyFeatures,\n16:   featureSummary,\n17:   formatDuration,\n18:   parseDurationMinutes,\n19:   type Feature,\n20:   type FeatureStatus,\n21:   type Priority,\n22:   type Difficulty,\n23:   type FeaturesFile,\n24: } from \"../../lib/tasks.js\";\n25: import { output, filterFieldsArray, renderCompactTable, type OutputFormat } from \"../../lib/output.js\";\n26: \n27: // ---------------------------------------------------------------------------\n28: // Types\n29: // ---------------------------------------------------------------------------\n30: \n31: export interface TasksListOptions {\n32:   projectRoot: string;\n33:   config: WomboConfig;\n34:   status?: FeatureStatus;\n35:   priority?: Priority;\n36:   difficulty?: Difficulty;\n37:   ready?: boolean;\n38:   includeArchive?: boolean;\n39:   outputFmt?: OutputFormat;\n40:   fields?: string[];\n41: }\n42: \n43: // ---------------------------------------------------------------------------\n44: // ANSI Helpers\n45: // ---------------------------------------------------------------------------\n46: \n47: const RESET = \"\\x1b[0m\";\n48: const BOLD = \"\\x1b[1m\";\n49: const DIM = \"\\x1b[2m\";\n50: \n51: const STATUS_COLOR: Record<FeatureStatus, string> = {\n52:   backlog: \"\\x1b[37m\",     // white\n53:   planned: \"\\x1b[36m\",     // cyan\n54:   in_progress: \"\\x1b[34m\", // blue\n55:   blocked: \"\\x1b[31m\",     // red\n56:   in_review: \"\\x1b[33m\",   // yellow\n57:   done: \"\\x1b[32m\",        // green\n58:   cancelled: \"\\x1b[90m\",   // gray\n59: };\n60: \n61: // ---------------------------------------------------------------------------\n62: // Command\n63: // ---------------------------------------------------------------------------\n64: \n65: export async function cmdTasksList(opts: TasksListOptions): Promise<void> {\n66:   const { projectRoot, config } = opts;\n67:   const data = loadFeatures(projectRoot, config);\n68: \n69:   let features: Feature[] = [...data.tasks];\n70: \n71:   // Include archive if requested\n72:   if (opts.includeArchive && data.archive?.length) {\n73:     features = [...features, ...data.archive];\n74:   }\n75: \n76:   // Filter by status\n77:   if (opts.status) {\n78:     features = features.filter((f) => f.status === opts.status);\n79:   }\n80: \n81:   // Filter by priority\n82:   if (opts.priority) {\n83:     features = features.filter((f) => f.priority === opts.priority);\n84:   }\n85: \n86:   // Filter by difficulty\n87:   if (opts.difficulty) {\n88:     features = features.filter((f) => f.difficulty === opts.difficulty);\n89:   }\n90: \n91:   // Filter to ready-only\n92:   if (opts.ready) {\n93:     const readyFeatures = getReadyFeatures(data);\n94:     const readyIds = new Set(readyFeatures.map((f) => f.id));\n95:     features = features.filter((f) => readyIds.has(f.id));\n96:   }\n97: \n98:   if (features.length === 0) {\n99:     output(opts.outputFmt ?? \"text\", { features: [], total: 0, effort: \"0m\" }, () => {\n100:       console.log(\"No tasks match the given filters.\");\n101:     });\n102:     return;\n103:   }\n104: \n105:   // Group by status for display\n106:   const byStatus = new Map<FeatureStatus, Feature[]>();\n107:   for (const f of features) {\n108:     const list = byStatus.get(f.status) ?? [];\n109:     list.push(f);\n110:     byStatus.set(f.status, list);\n111:   }\n112: \n113:   // Display\n114:   const totalEffort = features.reduce(\n115:     (sum, f) => sum + parseDurationMinutes(f.effort),\n116:     0\n117:   );\n118: \n119:   const fmt = opts.outputFmt ?? \"text\";\n120: \n121:   // Build the structured data for each feature\n122:   const featureData = features.map((f) => ({\n123:     id: f.id,\n124:     title: f.title,\n125:     status: f.status,\n126:     priority: f.priority,\n127:     difficulty: f.difficulty,\n128:     effort: f.effort,\n129:     completion: f.completion,\n130:     depends_on: f.depends_on,\n131:   }));\n132: \n133:   // If --fields is specified, use compact output mode\n134:   if (opts.fields?.length) {\n135:     const filtered = filterFieldsArray(featureData, opts.fields);\n136:     output(\n137:       fmt,\n138:       { features: filtered, total: features.length, effort: formatDuration(totalEffort) },\n139:       () => {\n140:         renderCompactTable(\n141:           featureData as Record<string, unknown>[],\n142:           opts.fields!\n143:         );\n144:       }\n145:     );\n146:     return;\n147:   }\n148: \n149:   output(\n150:     fmt,\n151:     {\n152:       features: featureData,\n153:       total: features.length,\n154:       effort: formatDuration(totalEffort),\n155:     },\n156:     () => {\n157:       console.log(`\\n${BOLD}Tasks (${features.length} total, ~${formatDuration(totalEffort)} effort)${RESET}\\n`);\n158: \n159:       const statusOrder: FeatureStatus[] = [\n160:         \"in_progress\",\n161:         \"planned\",\n162:         \"backlog\",\n163:         \"blocked\",\n164:         \"in_review\",\n165:         \"done\",\n166:         \"cancelled\",\n167:       ];\n168: \n169:       for (const status of statusOrder) {\n170:         const group = byStatus.get(status);\n171:         if (!group?.length) continue;\n172: \n173:         const color = STATUS_COLOR[status] ?? \"\";\n174:         console.log(`  ${color}${BOLD}${status.toUpperCase()}${RESET} (${group.length})`);\n175: \n176:         for (const f of group) {\n177:           const effort = formatDuration(parseDurationMinutes(f.effort));\n178:           const deps = f.depends_on.length > 0 ? ` ${DIM}deps: ${f.depends_on.join(\", \")}${RESET}` : \"\";\n179:           const completion = f.completion > 0 ? ` ${DIM}${f.completion}%${RESET}` : \"\";\n180:           console.log(\n181:             `    ${color}${f.id}${RESET} — ${f.title} [${f.priority}/${f.difficulty}] (${effort})${completion}${deps}`\n182:           );\n183:         }\n184:         console.log(\"\");\n185:       }\n186:     }\n187:   );\n188: }\n\n(End of file - total 188 lines)\n</content>","title":"src/commands/tasks/list.ts","metadata":{"preview":"/**\n * tasks/list.ts — List and filter tasks from the tasks file.\n *\n * Usage:\n *   woco tasks list                     # list all tasks\n *   woco tasks list --status backlog    # filter by status\n *   woco tasks list --priority high     # filter by priority\n *   woco tasks list --ready             # show only ready tasks\n *   woco tasks list --archive           # include archived tasks\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  getReadyFeatures,\n  featureSummary,\n  formatDuration,\n  parseDurationMinutes,\n  type Feature,\n  type FeatureStatus,","truncated":false,"loaded":[]},"time":{"start":1773433431972,"end":1773433431993}}}}
{"type":"tool_use","timestamp":1773433432386,"sessionID":"ses_31721ba8fffeXD00hbThRJI7PX","part":{"id":"prt_ce8dea7a8001jSTaqw3ou9mAIM","sessionID":"ses_31721ba8fffeXD00hbThRJI7PX","messageID":"msg_ce8de98be001EoLFp7bMRk6C75","type":"tool","callID":"toolu_vrtx_019PsBH9ZAEnPSREKDqp3KE5","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-toon-format-spec/src/commands/tasks/show.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-toon-format-spec/src/commands/tasks/show.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tasks/show.ts — Show detailed information about a specific task.\n3:  *\n4:  * Usage:\n5:  *   woco tasks show <task-id>\n6:  */\n7: \n8: import type { WomboConfig } from \"../../config.js\";\n9: import {\n10:   loadFeatures,\n11:   findFeatureById,\n12:   formatDuration,\n13:   parseDurationMinutes,\n14:   areDependenciesMet,\n15:   getDoneFeatureIds,\n16:   type Feature,\n17:   type Subtask,\n18: } from \"../../lib/tasks.js\";\n19: import { output, outputError, filterFields, type OutputFormat } from \"../../lib/output.js\";\n20: \n21: // ---------------------------------------------------------------------------\n22: // Types\n23: // ---------------------------------------------------------------------------\n24: \n25: export interface TasksShowOptions {\n26:   projectRoot: string;\n27:   config: WomboConfig;\n28:   featureId: string;\n29:   outputFmt?: OutputFormat;\n30:   fields?: string[];\n31: }\n32: \n33: // ---------------------------------------------------------------------------\n34: // ANSI Helpers\n35: // ---------------------------------------------------------------------------\n36: \n37: const RESET = \"\\x1b[0m\";\n38: const BOLD = \"\\x1b[1m\";\n39: const DIM = \"\\x1b[2m\";\n40: const GREEN = \"\\x1b[32m\";\n41: const RED = \"\\x1b[31m\";\n42: const YELLOW = \"\\x1b[33m\";\n43: const CYAN = \"\\x1b[36m\";\n44: \n45: // ---------------------------------------------------------------------------\n46: // Display Helpers\n47: // ---------------------------------------------------------------------------\n48: \n49: function statusColor(status: string): string {\n50:   switch (status) {\n51:     case \"done\": return GREEN;\n52:     case \"in_progress\": return CYAN;\n53:     case \"blocked\":\n54:     case \"failed\": return RED;\n55:     case \"cancelled\": return DIM;\n56:     default: return \"\";\n57:   }\n58: }\n59: \n60: function renderSubtask(st: Subtask, indent: number): void {\n61:   const pad = \"  \".repeat(indent);\n62:   const color = statusColor(st.status);\n63:   const effort = formatDuration(parseDurationMinutes(st.effort));\n64:   const completionStr = st.completion > 0 ? ` (${st.completion}%)` : \"\";\n65:   console.log(\n66:     `${pad}${color}[${st.status}]${RESET} ${st.id} — ${st.title} [${st.priority}/${st.difficulty}] (${effort})${completionStr}`\n67:   );\n68:   if (st.subtasks?.length) {\n69:     for (const sub of st.subtasks) {\n70:       renderSubtask(sub, indent + 1);\n71:     }\n72:   }\n73: }\n74: \n75: // ---------------------------------------------------------------------------\n76: // Command\n77: // ---------------------------------------------------------------------------\n78: \n79: export async function cmdTasksShow(opts: TasksShowOptions): Promise<void> {\n80:   const { projectRoot, config } = opts;\n81:   const fmt = opts.outputFmt ?? \"text\";\n82: \n83:   if (!opts.featureId) {\n84:     outputError(fmt, \"Usage: woco tasks show <task-id>\");\n85:     return;\n86:   }\n87: \n88:   const data = loadFeatures(projectRoot, config);\n89:   const feature = findFeatureById(data, opts.featureId);\n90: \n91:   if (!feature) {\n92:     outputError(fmt, `Task \"${opts.featureId}\" not found.`);\n93:     return;\n94:   }\n95: \n96:   const doneIds = getDoneFeatureIds(data);\n97:   const depsMet = areDependenciesMet(feature, doneIds);\n98:   const effort = formatDuration(parseDurationMinutes(feature.effort));\n99: \n100:   const fullData = {\n101:     ...feature,\n102:     deps_met: depsMet,\n103:     effort_formatted: effort,\n104:   };\n105: \n106:   // If --fields is specified, emit only those fields\n107:   if (opts.fields?.length) {\n108:     const filtered = filterFields(fullData as Record<string, unknown>, opts.fields);\n109:     output(fmt, filtered, () => {\n110:       for (const [key, val] of Object.entries(filtered)) {\n111:         const display = Array.isArray(val) ? val.join(\", \") : String(val ?? \"\");\n112:         console.log(`${key}: ${display}`);\n113:       }\n114:     });\n115:     return;\n116:   }\n117: \n118:   output(\n119:     fmt,\n120:     fullData,\n121:     () => {\n122:       console.log(`\\n${BOLD}Task: ${feature.title}${RESET}`);\n123:       console.log(`  ID:          ${feature.id}`);\n124:       console.log(`  Status:      ${statusColor(feature.status)}${feature.status}${RESET}`);\n125:       console.log(`  Priority:    ${feature.priority}`);\n126:       console.log(`  Difficulty:  ${feature.difficulty}`);\n127:       console.log(`  Effort:      ${effort}`);\n128:       console.log(`  Completion:  ${feature.completion}%`);\n129:       console.log(`  Deps met:    ${depsMet ? `${GREEN}yes${RESET}` : `${RED}no${RESET}`}`);\n130: \n131:       if (feature.started_at) {\n132:         console.log(`  Started:     ${feature.started_at}`);\n133:       }\n134:       if (feature.ended_at) {\n135:         console.log(`  Ended:       ${feature.ended_at}`);\n136:       }\n137: \n138:       if (feature.description) {\n139:         console.log(`\\n  ${BOLD}Description:${RESET}`);\n140:         for (const line of feature.description.split(\"\\n\")) {\n141:           console.log(`    ${line}`);\n142:         }\n143:       }\n144: \n145:       if (feature.depends_on.length > 0) {\n146:         console.log(`\\n  ${BOLD}Dependencies:${RESET}`);\n147:         for (const dep of feature.depends_on) {\n148:           const met = doneIds.has(dep);\n149:           const icon = met ? `${GREEN}✓${RESET}` : `${RED}✗${RESET}`;\n150:           console.log(`    ${icon} ${dep}`);\n151:         }\n152:       }\n153: \n154:       if (feature.constraints.length > 0) {\n155:         console.log(`\\n  ${BOLD}Constraints:${RESET}`);\n156:         for (const c of feature.constraints) {\n157:           console.log(`    - ${c}`);\n158:         }\n159:       }\n160: \n161:       if (feature.forbidden.length > 0) {\n162:         console.log(`\\n  ${BOLD}Forbidden:${RESET}`);\n163:         for (const f of feature.forbidden) {\n164:           console.log(`    - ${RED}${f}${RESET}`);\n165:         }\n166:       }\n167: \n168:       if (feature.references.length > 0) {\n169:         console.log(`\\n  ${BOLD}References:${RESET}`);\n170:         for (const r of feature.references) {\n171:           console.log(`    - ${DIM}${r}${RESET}`);\n172:         }\n173:       }\n174: \n175:       if (feature.notes.length > 0) {\n176:         console.log(`\\n  ${BOLD}Notes:${RESET}`);\n177:         for (const n of feature.notes) {\n178:           console.log(`    - ${n}`);\n179:         }\n180:       }\n181: \n182:       if (feature.subtasks.length > 0) {\n183:         console.log(`\\n  ${BOLD}Subtasks (${feature.subtasks.length}):${RESET}`);\n184:         for (const st of feature.subtasks) {\n185:           renderSubtask(st, 2);\n186:         }\n187:       }\n188: \n189:       console.log(\"\");\n190:     }\n191:   );\n192: }\n\n(End of file - total 192 lines)\n</content>","title":"src/commands/tasks/show.ts","metadata":{"preview":"/**\n * tasks/show.ts — Show detailed information about a specific task.\n *\n * Usage:\n *   woco tasks show <task-id>\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  findFeatureById,\n  formatDuration,\n  parseDurationMinutes,\n  areDependenciesMet,\n  getDoneFeatureIds,\n  type Feature,\n  type Subtask,\n} from \"../../lib/tasks.js\";\nimport { output, outputError, filterFields, type OutputFormat } from \"../../lib/output.js\";\n","truncated":false,"loaded":[]},"time":{"start":1773433432369,"end":1773433432384}}}}
