{"type":"tool_use","timestamp":1773433421463,"sessionID":"ses_31721ba8fffeXD00hbThRJI7PX","part":{"id":"prt_ce8de7d93001zhzKQ8XZBUPrFP","sessionID":"ses_31721ba8fffeXD00hbThRJI7PX","messageID":"msg_ce8de7245001ziF9Vv3hqrMxR0","type":"tool","callID":"toolu_vrtx_012Y98DP6SXPuujbBAyMZn2N","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-toon-format-spec/src/index.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-toon-format-spec/src/index.ts</path>\n<type>file</type>\n<content>1: #!/usr/bin/env bun\n2: /**\n3:  * index.ts — CLI entry point for the wombo-combo agent orchestration system.\n4:  *\n5:  * Every command has a short alias (e.g., woco i = woco init, woco t ls = woco tasks list).\n6:  *\n7:  * Usage:\n8:  *   woco init                                         (alias: i)\n9:  *   woco launch --top-priority 3                      (alias: l)\n10:  *   woco launch --quickest-wins 5\n11:  *   woco launch --priority high\n12:  *   woco launch --difficulty easy\n13:  *   woco launch --tasks \"feat-a,feat-b\"\n14:  *   woco launch --all-ready\n15:  *   woco launch ... --max-concurrent 3 --model \"anthropic/claude-sonnet-4-20250514\"\n16:  *   woco launch ... --interactive\n17:  *   woco resume                                       (alias: r)\n18:  *   woco status                                       (alias: s)\n19:  *   woco verify [feature-id]                          (alias: v)\n20:  *   woco merge [feature-id]                           (alias: m)\n21:  *   woco retry <feature-id>                           (alias: re)\n22:  *   woco abort <feature-id> [--requeue] [--output json]  (alias: a)\n23:  *   woco logs <feature-id> [--tail N] [--follow]      (alias: lo)\n24:  *   woco cleanup                                      (alias: c)\n25:  *   woco history [wave-id] [--output json]            (alias: h)\n26:  *   woco tasks list [--status <s>] [--priority <p>]   (alias: t ls)\n27:  *   woco tasks add <id> <title> [options]             (alias: t a)\n28:  *   woco tasks set-status <task-id> <status>          (alias: t ss)\n29:  *   woco tasks set-priority <task-id> <priority>      (alias: t sp)\n30:  *   woco tasks set-difficulty <task-id> <difficulty>   (alias: t sd)\n31:  *   woco tasks check                                  (alias: t ch)\n32:  *   woco tasks archive [task-id] [--dry-run]          (alias: t ar)\n33:  *   woco tasks show <task-id>                         (alias: t sh)\n34:  *   woco tasks graph [--ascii] [--mermaid]            (alias: t g)\n35:  *   woco completion <bash|zsh|fish>                   (alias: comp)\n36:  *   woco help\n37:  *   woco version\n38:  *   woco -v\n39:  */\n40: \n41: import { resolve } from \"node:path\";\n42: import { existsSync, readFileSync } from \"node:fs\";\n43: import { loadConfig, validateConfig } from \"./config.js\";\n44: import { loadState, saveState } from \"./lib/state.js\";\n45: \n46: // ---------------------------------------------------------------------------\n47: // Dev-mode guard: warn if running the global binary inside the wombo-combo repo\n48: // ---------------------------------------------------------------------------\n49: \n50: function checkDevModeGuard(): void {\n51:   const cwd = process.cwd();\n52:   const pkgPath = resolve(cwd, \"package.json\");\n53: \n54:   // Are we inside the wombo-combo repo?\n55:   if (!existsSync(pkgPath)) return;\n56: \n57:   let pkgName: string | undefined;\n58:   try {\n59:     const raw = readFileSync(pkgPath, \"utf-8\");\n60:     pkgName = JSON.parse(raw).name;\n61:   } catch {\n62:     return;\n63:   }\n64:   if (pkgName !== \"wombo-combo\") return;\n65: \n66:   // We're in the wombo-combo repo. Is the source being run from a different location?\n67:   // import.meta.dir = directory of THIS file (index.ts). If it's under cwd,\n68:   // we're running local source (bun dev). If it's elsewhere (e.g. ~/.bun/install),\n69:   // we're running the globally installed binary.\n70:   const sourceDir = resolve(import.meta.dir);\n71:   const projectSrc = resolve(cwd, \"src\");\n72: \n73:   if (!sourceDir.startsWith(projectSrc)) {\n74:     console.warn(\n75:       \"\\x1b[33m[WARNING]\\x1b[0m You are running the globally installed woco binary \" +\n76:       \"inside the wombo-combo repo.\\n\" +\n77:       \"  Use \\x1b[1mbun dev <command>\\x1b[0m instead to run from local source.\\n\" +\n78:       \"  See AGENTS.md for details.\\n\"\n79:     );\n80:   }\n81: }\n82: \n83: import { cmdInit } from \"./commands/init.js\";\n84: import { cmdLaunch } from \"./commands/launch.js\";\n85: import { cmdResume } from \"./commands/resume.js\";\n86: import { cmdStatus } from \"./commands/status.js\";\n87: import { cmdVerify } from \"./commands/verify.js\";\n88: import { cmdMerge } from \"./commands/merge.js\";\n89: import { cmdRetry } from \"./commands/retry.js\";\n90: import { cmdCleanup } from \"./commands/cleanup.js\";\n91: import { cmdAbort } from \"./commands/abort.js\";\n92: import { cmdLogs } from \"./commands/logs.js\";\n93: import { cmdUpgrade } from \"./commands/upgrade.js\";\n94: import { cmdHistory } from \"./commands/history.js\";\n95: import { cmdCompletion } from \"./commands/completion.js\";\n96: import { cmdTasksList } from \"./commands/tasks/list.js\";\n97: import { cmdTasksAdd } from \"./commands/tasks/add.js\";\n98: import { cmdTasksSetStatus } from \"./commands/tasks/set-status.js\";\n99: import { cmdTasksSetPriority } from \"./commands/tasks/set-priority.js\";\n100: import { cmdTasksSetDifficulty } from \"./commands/tasks/set-difficulty.js\";\n101: import { cmdTasksCheck } from \"./commands/tasks/check.js\";\n102: import { cmdTasksArchive } from \"./commands/tasks/archive.js\";\n103: import { cmdTasksShow } from \"./commands/tasks/show.js\";\n104: import { cmdTasksGraph } from \"./commands/tasks/graph.js\";\n105: \n106: import { ensureTasksFile } from \"./lib/tasks.js\";\n107: import type { Priority, Difficulty, FeatureStatus } from \"./lib/tasks.js\";\n108: import { resolveOutputFormat, type OutputFormat } from \"./lib/output.js\";\n109: import { validateId, validateText, validateBranchName, validateDuration, assertValid } from \"./lib/validate.js\";\n110: import { findCommandDef, commandToSchema, allCommandSchemas } from \"./lib/schema.js\";\n111: \n112: // ---------------------------------------------------------------------------\n113: // Types\n114: // ---------------------------------------------------------------------------\n115: \n116: export interface CLIArgs {\n117:   command: string;\n118:   subcommand?: string;\n119:   // Selection options (launch)\n120:   topPriority?: number;\n121:   quickestWins?: number;\n122:   priority?: Priority;\n123:   difficulty?: Difficulty;\n124:   tasks?: string[];\n125:   allReady?: boolean;\n126:   // Launch / runtime options\n127:   maxConcurrent?: number;\n128:   model?: string;\n129:   interactive: boolean;\n130:   dryRun: boolean;\n131:   baseBranch?: string;\n132:   maxRetries?: number;\n133:   noTui: boolean;\n134:   autoPush: boolean;\n135:   // Abort options\n136:   requeue: boolean;\n137:   // General\n138:   featureId?: string;\n139:   force: boolean;\n140:   // Output format\n141:   outputFmt: OutputFormat;\n142:   // Upgrade options\n143:   checkOnly: boolean;\n144:   tag?: string;\n145:   // Features subcommand extras\n146:   status?: string;\n147:   ready?: boolean;\n148:   includeArchive?: boolean;\n149:   title?: string;\n150:   description?: string;\n151:   effort?: string;\n152:   dependsOn?: string[];\n153:   // Logs options\n154:   tail?: number;\n155:   follow?: boolean;\n156:   // Compact output\n157:   fields?: string[];\n158:   // Graph options\n159:   ascii?: boolean;\n160:   mermaidRaw?: boolean;\n161:   graphSubtasks?: boolean;\n162:   // Browser verification\n163:   browser?: boolean;\n164: }\n165: \n166: // ---------------------------------------------------------------------------\n167: // Command & Subcommand Aliases\n168: // ---------------------------------------------------------------------------\n169: \n170: /** Map of short aliases → canonical top-level command names. */\n171: export const COMMAND_ALIASES: Record<string, string> = {\n172:   i: \"init\",\n173:   l: \"launch\",\n174:   r: \"resume\",\n175:   s: \"status\",\n176:   v: \"verify\",\n177:   m: \"merge\",\n178:   re: \"retry\",\n179:   a: \"abort\",\n180:   c: \"cleanup\",\n181:   h: \"history\",\n182:   lo: \"logs\",\n183:   t: \"tasks\",\n184:   features: \"tasks\", // backward-compat full-word alias\n185:   u: \"upgrade\",\n186:   d: \"describe\",\n187:   comp: \"completion\",\n188: };\n189: \n190: /** Map of short aliases → canonical tasks subcommand names. */\n191: export const SUBCOMMAND_ALIASES: Record<string, string> = {\n192:   ls: \"list\",\n193:   a: \"add\",\n194:   ss: \"set-status\",\n195:   sp: \"set-priority\",\n196:   sd: \"set-difficulty\",\n197:   ch: \"check\",\n198:   validate: \"check\", // backward-compat full-word alias\n199:   ar: \"archive\",\n200:   sh: \"show\",\n201:   g: \"graph\",\n202: };\n203: \n204: // ---------------------------------------------------------------------------\n205: // Arg Parsing\n206: // ---------------------------------------------------------------------------\n207: \n208: export function parseArgs(argv: string[]): CLIArgs {\n209:   const args = argv.slice(2); // skip 'bun' and script path\n210:   const result: CLIArgs = {\n211:     command: args[0] || \"help\",\n212:     interactive: false,\n213:     dryRun: false,\n214:     noTui: false,\n215:     autoPush: false,\n216:     requeue: false,\n217:     force: false,\n218:     checkOnly: false,\n219:     outputFmt: resolveOutputFormat(undefined), // auto-detect until --output overrides\n220:   };\n221: \n222:   // Resolve top-level command alias (e.g., \"i\" → \"init\", \"t\" → \"tasks\")\n223:   result.command = COMMAND_ALIASES[result.command] ?? result.command;\n224: \n225:   // If the command is \"tasks\", treat the second positional as the subcommand\n226:   let startIdx = 1;\n227:   if (result.command === \"tasks\") {\n228:     result.subcommand = args[1] || \"list\";\n229:     // Resolve subcommand alias (e.g., \"ls\" → \"list\", \"ss\" → \"set-status\")\n230:     result.subcommand = SUBCOMMAND_ALIASES[result.subcommand] ?? result.subcommand;\n231:     startIdx = 2;\n232:   }\n233: \n234:   for (let i = startIdx; i < args.length; i++) {\n235:     const arg = args[i];\n236: \n237:     // Helper: consume the next argument, or exit with a clear error\n238:     function requireValue(flag: string): string {\n239:       if (i + 1 >= args.length) {\n240:         console.error(`Flag ${flag} requires a value.`);\n241:         process.exit(1);\n242:       }\n243:       return args[++i];\n244:     }\n245: \n246:     switch (arg) {\n247:       // --- Selection options ---\n248:       case \"--top-priority\":\n249:         result.topPriority = parseInt(requireValue(arg), 10);\n250:         break;\n251:       case \"--quickest-wins\":\n252:         result.quickestWins = parseInt(requireValue(arg), 10);\n253:         break;\n254:       case \"--priority\":\n255:         result.priority = requireValue(arg) as Priority;\n256:         break;\n257:       case \"--difficulty\":\n258:         result.difficulty = requireValue(arg) as Difficulty;\n259:         break;\n260:       case \"--tasks\":\n261:       case \"--features\": // backward-compat alias\n262:         result.tasks = requireValue(arg).split(\",\").map((s) => s.trim());\n263:         break;\n264:       case \"--all-ready\":\n265:         result.allReady = true;\n266:         break;\n267: \n268:       // --- Launch / runtime options ---\n269:       case \"--max-concurrent\":\n270:         result.maxConcurrent = parseInt(requireValue(arg), 10);\n271:         break;\n272:       case \"--model\":\n273:       case \"-m\":\n274:         result.model = requireValue(arg);\n275:         break;\n276:       case \"--interactive\":\n277:         result.interactive = true;\n278:         break;\n279:       case \"--dry-run\":\n280:         result.dryRun = true;\n281:         break;\n282:       case \"--no-tui\":\n283:         result.noTui = true;\n284:         break;\n285:       case \"--auto-push\":\n286:         result.autoPush = true;\n287:         break;\n288:       case \"--requeue\":\n289:         result.requeue = true;\n290:         break;\n291:       case \"--base-branch\":\n292:         result.baseBranch = requireValue(arg);\n293:         break;\n294:       case \"--max-retries\":\n295:         result.maxRetries = parseInt(requireValue(arg), 10);\n296:         break;\n297: \n298:       // --- General flags ---\n299:       case \"--force\":\n300:         result.force = true;\n301:         break;\n302:       case \"--check\":\n303:         result.checkOnly = true;\n304:         break;\n305:       case \"--tag\":\n306:       case \"--release\":\n307:         result.tag = requireValue(arg);\n308:         break;\n309:       case \"--output\":\n310:       case \"-o\":\n311:         result.outputFmt = resolveOutputFormat(requireValue(arg));\n312:         break;\n313: \n314:       // --- Tasks subcommand options ---\n315:       case \"--status\":\n316:         result.status = requireValue(arg);\n317:         break;\n318:       case \"--ready\":\n319:         result.ready = true;\n320:         break;\n321:       case \"--include-archive\":\n322:         result.includeArchive = true;\n323:         break;\n324:       case \"--title\":\n325:         result.title = requireValue(arg);\n326:         break;\n327:       case \"--description\":\n328:       case \"--desc\":\n329:         result.description = requireValue(arg);\n330:         break;\n331:       case \"--effort\":\n332:         result.effort = requireValue(arg);\n333:         break;\n334:       case \"--depends-on\":\n335:         result.dependsOn = requireValue(arg).split(\",\").map((s) => s.trim());\n336:         break;\n337:       case \"--fields\":\n338:         result.fields = requireValue(arg).split(\",\").map((s) => s.trim());\n339:         break;\n340: \n341:       // --- Graph options ---\n342:       case \"--ascii\":\n343:         result.ascii = true;\n344:         break;\n345:       case \"--mermaid\":\n346:         result.mermaidRaw = true;\n347:         break;\n348:       case \"--subtasks\":\n349:         result.graphSubtasks = true;\n350:         break;\n351: \n352:       // --- Logs options ---\n353:       case \"--tail\":\n354:         result.tail = parseInt(args[++i], 10);\n355:         break;\n356:       case \"--follow\":\n357:       case \"-f\":\n358:         result.follow = true;\n359:         break;\n360: \n361:       // --- Browser verification ---\n362:       case \"--browser\":\n363:         result.browser = true;\n364:         break;\n365: \n366:       // --- Positional (feature-id, title for add, etc.) ---\n367:       default:\n368:         if (!arg.startsWith(\"-\")) {\n369:           if (!result.featureId) {\n370:             result.featureId = arg;\n371:           } else if (!result.title) {\n372:             result.title = arg;\n373:           }\n374:         }\n375:         break;\n376:     }\n377:   }\n378: \n379:   return result;\n380: }\n381: \n382: // ---------------------------------------------------------------------------\n383: // Help\n384: // ---------------------------------------------------------------------------\n385: \n386: function cmdHelp(): void {\n387:   console.log(`\n388: wombo-combo — AI Agent Orchestration System\n389: \n390:   WOMBO COMBO! Parallel feature development with AI agents.\n391: \n392: Commands:                        (alias)\n393:   init                           (i)     Generate .wombo-combo/config.json in the current project\n394:   launch                         (l)     Launch a wave of agents to implement features\n395:   resume                         (r)     Resume a previously stopped wave\n396:   status                         (s)     Show the status of the current wave\n397:   verify                         (v)     Run build verification on completed agents\n398:   merge                          (m)     Merge verified branches into the base branch\n399:   retry                          (re)    Retry a failed agent\n400:   abort                          (a)     Kill a single running agent (--requeue to return to queue)\n401:   logs                           (lo)    Pretty-print agent logs for a feature\n402:   cleanup                        (c)     Remove all wave worktrees and multiplexer sessions\n403:   history                        (h)     List/view past wave results (stored in .wombo-combo/history/)\n404:   tasks                          (t)     Manage tasks file (see below; 'features' also accepted)\n405:   upgrade                        (u)     Check for updates and upgrade wombo-combo\n406:   describe                       (d)     Emit JSON schema of a command (for AI agents)\n407:   completion                     (comp)  Generate shell completions (bash, zsh, fish)\n408:   version                                Print version and exit\n409:   help                                   Show this help\n410: \n411: Tasks Subcommands:               (alias)\n412:   tasks list                     (ls)    List tasks (--status, --priority, --difficulty, --ready, --include-archive)\n413:   tasks add <id> <title>         (a)     Add a new task (--desc, --priority, --difficulty, --effort, --depends-on)\n414:   tasks set-status <id> <s>      (ss)    Change a task's status\n415:   tasks set-priority <id> <p>    (sp)    Change a task's priority (critical/high/medium/low/wishlist)\n416:   tasks set-difficulty <id> <d>  (sd)    Change a task's difficulty (trivial/easy/medium/hard/very_hard)\n417:   tasks check                    (ch)    Validate tasks file (schema, deps, duplicates, cycles)\n418:   tasks archive [id]             (ar)    Move done/cancelled to archive (--dry-run)\n419:   tasks show <id>                (sh)    Show task details\n420:   tasks graph                    (g)     Visualize dependency graph (--ascii, --mermaid, --subtasks)\n421: \n422: Selection Options (for launch):\n423:   --top-priority N         Select top N tasks by priority\n424:   --quickest-wins N        Select N tasks with lowest effort\n425:   --priority <level>       Filter by priority (critical/high/medium/low/wishlist)\n426:   --difficulty <level>     Filter by difficulty (trivial/easy/medium/hard/very_hard)\n427:   --tasks \"id1,id2\"        Select specific tasks by ID (--features also accepted)\n428:   --all-ready              Select all tasks whose dependencies are met\n429: \n430: Launch Options:\n431:   --max-concurrent N       Max agents running in parallel (default: from config)\n432:   --model <model>          Model to use (e.g., \"anthropic/claude-sonnet-4-20250514\")\n433:   --interactive            Use multiplexer (dmux/tmux) TUI mode instead of headless\n434:   --no-tui                 Headless mode without neo-blessed TUI (periodic console dashboard)\n435:   --auto-push              Push base branch to remote after all merges complete\n436:   --dry-run                Show what would be launched without launching\n437:   --base-branch <branch>   Base branch (default: from config)\n438:   --max-retries N          Max retries per agent (default: from config)\n439:   --browser                Enable browser-based verification (run after build passes)\n440: \n441: General:\n442:   --force                  Force overwrite (e.g., for init) / skip prompts (e.g., for upgrade)\n443:   --output <fmt>           Output format: text (default on TTY) or json (default when piped)\n444:   -o <fmt>                 Alias for --output\n445:   --dry-run                Show what would happen without performing the action\n446:   --fields <list>          Comma-separated fields to include (e.g., id,status,priority)\n447: \n448: Upgrade Options:\n449:   --check                  Only check for updates, don't install\n450:   --tag <tag>              Install a specific version (e.g., v0.1.0)\n451: \n452: Logs Options:\n453:   --tail N                 Show only the last N lines\n454:   --follow, -f             Stream new output as it arrives (like tail -f)\n455: \n456: Aliases (every command has a short form):\n457:   woco i                         woco init\n458:   woco l --all-ready             woco launch --all-ready\n459:   woco t ls                      woco tasks list\n460:   woco t a my-task \"Title\"       woco tasks add my-task \"Title\"\n461:   woco t ss my-task done         woco tasks set-status my-task done\n462: \n463: Shell Completion:\n464:   eval \"$(woco completion bash)\"    # Bash: add to ~/.bashrc\n465:   eval \"$(woco completion zsh)\"     # Zsh:  add to ~/.zshrc\n466:   woco completion fish | source     # Fish (or save to ~/.config/fish/completions/woco.fish)\n467: \n468: Examples:\n469:   woco init\n470:   woco launch --quickest-wins 3\n471:   woco launch --priority high --interactive\n472:   woco launch --tasks \"auth-flow,search-api\" --max-concurrent 2\n473:   woco resume\n474:   woco status\n475:   woco verify\n476:   woco merge\n477:   woco retry auth-flow\n478:   woco abort auth-flow\n479:   woco abort auth-flow --requeue\n480:   woco abort auth-flow --output json\n481:   woco logs auth-flow\n482:   woco logs auth-flow --tail 50\n483:   woco logs auth-flow --follow\n484:   woco logs auth-flow --output json\n485:   woco cleanup\n486:   woco tasks list --status ready --priority high\n487:   woco tasks list --fields id,status,priority --output json\n488:   woco tasks add my-task \"My Cool Task\" --priority high --difficulty easy\n489:   woco tasks set-status my-task in-progress\n490:   woco tasks check\n491:   woco tasks archive --dry-run\n492:   woco tasks show my-task\n493:   woco history\n494:   woco history wave-2026-03-12-420\n495:   woco history --output json\n496:   woco describe                           # list all commands as JSON\n497:   woco describe launch                    # describe a specific command\n498:   woco describe tasks add                 # describe a subcommand\n499: `);\n500: }\n501: \n502: // ---------------------------------------------------------------------------\n503: // Main\n504: // ---------------------------------------------------------------------------\n505: \n506: async function main(): Promise<void> {\n507:   checkDevModeGuard();\n508: \n509:   const PROJECT_ROOT = resolve(process.cwd());\n510:   const args = parseArgs(process.argv);\n511: \n512:   // -----------------------------------------------------------------------\n513:   // Input validation at the CLI boundary\n514:   // -----------------------------------------------------------------------\n515:   if (args.featureId) {\n516:     assertValid(validateId(args.featureId, \"feature ID\"));\n517:   }\n518:   if (args.title) {\n519:     assertValid(validateText(args.title, \"title\"));\n520:   }\n521:   if (args.description) {\n522:     assertValid(validateText(args.description, \"description\"));\n523:   }\n524:   if (args.baseBranch) {\n525:     assertValid(validateBranchName(args.baseBranch, \"base branch\"));\n526:   }\n527:   if (args.effort) {\n528:     assertValid(validateDuration(args.effort, \"effort\"));\n529:   }\n530:   if (args.tasks) {\n531:     for (const fid of args.tasks) {\n532:       assertValid(validateId(fid, \"task ID in --tasks\"));\n533:     }\n534:   }\n535:   if (args.dependsOn) {\n536:     for (const dep of args.dependsOn) {\n537:       assertValid(validateId(dep, \"dependency ID in --depends-on\"));\n538:     }\n539:   }\n540: \n541:   // Commands that don't need config loading\n542:   if (args.command === \"version\" || args.command === \"-v\" || args.command === \"-V\") {\n543:     const pkgPath = resolve(import.meta.dir, \"..\", \"package.json\");\n544:     const pkgFile = Bun.file(pkgPath);\n545:     try {\n546:       const pkg = await pkgFile.json();\n547:       console.log(`wombo-combo ${pkg.version ?? \"(unknown version)\"}`);\n548:     } catch {\n549:       console.log(\"wombo-combo (unknown version)\");\n550:     }\n551:     return;\n552:   }\n553: \n554:   if (args.command === \"help\" || args.command === \"--help\" || args.command === \"-h\") {\n555:     cmdHelp();\n556:     return;\n557:   }\n558: \n559:   if (args.command === \"describe\") {\n560:     // Schema introspection: `woco describe [command]`\n561:     if (!args.featureId) {\n562:       // No command specified — list all commands\n563:       console.log(JSON.stringify(allCommandSchemas(), null, 2));\n564:     } else {\n565:       // Describe a specific command. Handle compound names: \"features list\"\n566:       const cmdName = args.title\n567:         ? `${args.featureId} ${args.title}`\n568:         : args.featureId;\n569:       const def = findCommandDef(cmdName);\n570:       if (!def) {\n571:         console.error(`Unknown command: \"${cmdName}\"`);\n572:         console.error(\"Run 'woco describe' to list all commands.\");\n573:         process.exit(1);\n574:         return;\n575:       }\n576:       console.log(JSON.stringify(commandToSchema(def), null, 2));\n577:     }\n578:     return;\n579:   }\n580: \n581:   if (args.command === \"init\") {\n582:     await cmdInit({ projectRoot: PROJECT_ROOT, force: args.force });\n583:     return;\n584:   }\n585: \n586:   if (args.command === \"upgrade\") {\n587:     await cmdUpgrade({\n588:       force: args.force,\n589:       tag: args.tag,\n590:       checkOnly: args.checkOnly,\n591:     });\n592:     return;\n593:   }\n594: \n595:   if (args.command === \"completion\") {\n596:     cmdCompletion({ shell: args.featureId }); // first positional = shell name\n597:     return;\n598:   }\n599: \n600:   if (args.command === \"logs\") {\n601:     if (!args.featureId) {\n602:       console.error(\"Usage: woco logs <feature-id> [--tail N] [--follow] [--output json]\");\n603:       process.exit(1);\n604:       return;\n605:     }\n606:     await cmdLogs({\n607:       projectRoot: PROJECT_ROOT,\n608:       featureId: args.featureId,\n609:       tail: args.tail,\n610:       follow: args.follow,\n611:       outputFmt: args.outputFmt,\n612:     });\n613:     return;\n614:   }\n615: \n616:   // Everything else requires config\n617:   const config = loadConfig(PROJECT_ROOT);\n618:   validateConfig(config);\n619: \n620:   // Commands that operate on the tasks file — ensure it exists first\n621:   const needsTasksFile = new Set([\"launch\", \"resume\", \"verify\", \"retry\", \"tasks\"]);\n622:   if (needsTasksFile.has(args.command)) {\n623:     await ensureTasksFile(PROJECT_ROOT, config);\n624:   }\n625: \n626:   switch (args.command) {\n627:     case \"launch\":\n628:       // Apply browser verification override if --browser flag was passed\n629:       if (args.browser !== undefined) {\n630:         config.browser.enabled = args.browser;\n631:       }\n632:       await cmdLaunch({\n633:         projectRoot: PROJECT_ROOT,\n634:         config,\n635:         topPriority: args.topPriority,\n636:         quickestWins: args.quickestWins,\n637:         priority: args.priority,\n638:         difficulty: args.difficulty,\n639:         features: args.tasks,\n640:         allReady: args.allReady,\n641:         maxConcurrent: args.maxConcurrent ?? config.defaults.maxConcurrent,\n642:         model: args.model,\n643:         interactive: args.interactive,\n644:         dryRun: args.dryRun,\n645:         baseBranch: args.baseBranch ?? config.baseBranch,\n646:         maxRetries: args.maxRetries ?? config.defaults.maxRetries,\n647:         noTui: args.noTui,\n648:         autoPush: args.autoPush,\n649:         outputFmt: args.outputFmt,\n650:       });\n651:       break;\n652: \n653:     case \"resume\":\n654:       await cmdResume({\n655:         projectRoot: PROJECT_ROOT,\n656:         config,\n657:         maxConcurrent: args.maxConcurrent,\n658:         model: args.model,\n659:         interactive: args.interactive,\n660:         noTui: args.noTui,\n661:         autoPush: args.autoPush,\n662:         baseBranch: args.baseBranch,\n663:         maxRetries: args.maxRetries,\n664:       });\n665:       break;\n666: \n667:     case \"status\":\n668:       await cmdStatus({ projectRoot: PROJECT_ROOT, config, outputFmt: args.outputFmt });\n669:       break;\n670: \n671:     case \"verify\":\n672:       await cmdVerify({\n673:         projectRoot: PROJECT_ROOT,\n674:         config,\n675:         featureId: args.featureId,\n676:         model: args.model,\n677:         maxRetries: args.maxRetries,\n678:         browserVerify: args.browser,\n679:       });\n680:       break;\n681: \n682:     case \"merge\":\n683:       await cmdMerge({\n684:         projectRoot: PROJECT_ROOT,\n685:         config,\n686:         featureId: args.featureId,\n687:         autoPush: args.autoPush,\n688:         dryRun: args.dryRun,\n689:         model: args.model,\n690:       });\n691:       break;\n692: \n693:     case \"retry\": {\n694:       if (!args.featureId) {\n695:         console.error(\"Usage: woco retry <feature-id>\");\n696:         process.exit(1);\n697:         return;\n698:       }\n699:       await cmdRetry({\n700:         projectRoot: PROJECT_ROOT,\n701:         config,\n702:         featureId: args.featureId,\n703:         model: args.model,\n704:         interactive: args.interactive,\n705:         dryRun: args.dryRun,\n706:       });\n707:       break;\n708:     }\n709: \n710:     case \"cleanup\":\n711:       await cmdCleanup({ projectRoot: PROJECT_ROOT, config, dryRun: args.dryRun });\n712:       break;\n713: \n714:     case \"history\":\n715:       await cmdHistory({\n716:         projectRoot: PROJECT_ROOT,\n717:         config,\n718:         waveId: args.featureId,\n719:         outputFmt: args.outputFmt,\n720:       });\n721:       break;\n722: \n723:     case \"abort\": {\n724:       if (!args.featureId) {\n725:         console.error(\"Usage: woco abort <feature-id> [--requeue] [--output json]\");\n726:         process.exit(1);\n727:         return;\n728:       }\n729:       await cmdAbort({\n730:         projectRoot: PROJECT_ROOT,\n731:         config,\n732:         featureId: args.featureId,\n733:         requeue: args.requeue,\n734:         outputFmt: args.outputFmt,\n735:       });\n736:       break;\n737:     }\n738: \n739:     case \"tasks\":\n740:       await handleTasksSubcommand(args, PROJECT_ROOT, config);\n741:       break;\n742: \n743:     default:\n744:       console.error(`Unknown command: ${args.command}`);\n745:       cmdHelp();\n746:       process.exit(1);\n747:       return;\n748:   }\n749: }\n750: \n751: // ---------------------------------------------------------------------------\n752: // Tasks Subcommand Router\n753: // ---------------------------------------------------------------------------\n754: \n755: async function handleTasksSubcommand(\n756:   args: CLIArgs,\n757:   projectRoot: string,\n758:   config: import(\"./config.js\").WomboConfig\n759: ): Promise<void> {\n760:   switch (args.subcommand) {\n761:     case \"list\":\n762:       await cmdTasksList({\n763:         projectRoot,\n764:         config,\n765:         status: args.status as FeatureStatus | undefined,\n766:         priority: args.priority,\n767:         difficulty: args.difficulty,\n768:         ready: args.ready,\n769:         includeArchive: args.includeArchive,\n770:         outputFmt: args.outputFmt,\n771:         fields: args.fields,\n772:       });\n773:       break;\n774: \n775:     case \"add\": {\n776:       if (!args.featureId || !args.title) {\n777:         console.error(\"Usage: woco tasks add <id> <title> [--desc <desc>] [--priority <p>] [--difficulty <d>] [--effort <e>] [--depends-on <ids>]\");\n778:         process.exit(1);\n779:         return;\n780:       }\n781:       await cmdTasksAdd({\n782:         projectRoot,\n783:         config,\n784:         id: args.featureId,\n785:         title: args.title,\n786:         description: args.description,\n787:         priority: args.priority,\n788:         difficulty: args.difficulty,\n789:         effort: args.effort,\n790:         dependsOn: args.dependsOn,\n791:         outputFmt: args.outputFmt,\n792:         dryRun: args.dryRun,\n793:       });\n794:       break;\n795:     }\n796: \n797:     case \"set-status\": {\n798:       if (!args.featureId || !args.title) {\n799:         // title holds the second positional arg (the status value)\n800:         // If not provided via positional, check --status flag\n801:         const newStatus = args.title || args.status;\n802:         if (!args.featureId || !newStatus) {\n803:           console.error(\"Usage: woco tasks set-status <task-id> <status>\");\n804:           process.exit(1);\n805:           return;\n806:         }\n807:         await cmdTasksSetStatus({\n808:           projectRoot,\n809:           config,\n810:           featureId: args.featureId,\n811:           newStatus,\n812:           outputFmt: args.outputFmt,\n813:           dryRun: args.dryRun,\n814:         });\n815:       } else {\n816:         await cmdTasksSetStatus({\n817:           projectRoot,\n818:           config,\n819:           featureId: args.featureId,\n820:           newStatus: args.title, // second positional = new status\n821:           outputFmt: args.outputFmt,\n822:           dryRun: args.dryRun,\n823:         });\n824:       }\n825:       break;\n826:     }\n827: \n828:     case \"set-priority\": {\n829:       if (!args.featureId || !args.title) {\n830:         // title holds the second positional arg (the priority value)\n831:         // If not provided via positional, check --priority flag\n832:         const newPriority = args.title || (args.priority as string | undefined);\n833:         if (!args.featureId || !newPriority) {\n834:           console.error(\"Usage: woco tasks set-priority <task-id> <priority>\");\n835:           process.exit(1);\n836:           return;\n837:         }\n838:         await cmdTasksSetPriority({\n839:           projectRoot,\n840:           config,\n841:           featureId: args.featureId,\n842:           newPriority,\n843:           outputFmt: args.outputFmt,\n844:           dryRun: args.dryRun,\n845:         });\n846:       } else {\n847:         await cmdTasksSetPriority({\n848:           projectRoot,\n849:           config,\n850:           featureId: args.featureId,\n851:           newPriority: args.title, // second positional = new priority\n852:           outputFmt: args.outputFmt,\n853:           dryRun: args.dryRun,\n854:         });\n855:       }\n856:       break;\n857:     }\n858: \n859:     case \"set-difficulty\": {\n860:       if (!args.featureId || !args.title) {\n861:         // title holds the second positional arg (the difficulty value)\n862:         // If not provided via positional, check --difficulty flag\n863:         const newDifficulty = args.title || (args.difficulty as string | undefined);\n864:         if (!args.featureId || !newDifficulty) {\n865:           console.error(\"Usage: woco tasks set-difficulty <task-id> <difficulty>\");\n866:           process.exit(1);\n867:           return;\n868:         }\n869:         await cmdTasksSetDifficulty({\n870:           projectRoot,\n871:           config,\n872:           featureId: args.featureId,\n873:           newDifficulty,\n874:           outputFmt: args.outputFmt,\n875:           dryRun: args.dryRun,\n876:         });\n877:       } else {\n878:         await cmdTasksSetDifficulty({\n879:           projectRoot,\n880:           config,\n881:           featureId: args.featureId,\n882:           newDifficulty: args.title, // second positional = new difficulty\n883:           outputFmt: args.outputFmt,\n884:           dryRun: args.dryRun,\n885:         });\n886:       }\n887:       break;\n888:     }\n889: \n890:     case \"check\":\n891:       await cmdTasksCheck({ projectRoot, config });\n892:       break;\n893: \n894:     case \"archive\":\n895:       await cmdTasksArchive({\n896:         projectRoot,\n897:         config,\n898:         featureId: args.featureId,\n899:         dryRun: args.dryRun,\n900:         outputFmt: args.outputFmt,\n901:       });\n902:       break;\n903: \n904:     case \"show\": {\n905:       if (!args.featureId) {\n906:         console.error(\"Usage: woco tasks show <task-id>\");\n907:         process.exit(1);\n908:         return;\n909:       }\n910:       await cmdTasksShow({\n911:         projectRoot,\n912:         config,\n913:         featureId: args.featureId,\n914:         outputFmt: args.outputFmt,\n915:         fields: args.fields,\n916:       });\n917:       break;\n918:     }\n919: \n920:     case \"graph\":\n921:       await cmdTasksGraph({\n922:         projectRoot,\n923:         config,\n924:         status: args.status as FeatureStatus | undefined,\n925:         ascii: args.ascii,\n926:         mermaid: args.mermaidRaw,\n927:         subtasks: args.graphSubtasks,\n928:         outputFmt: args.outputFmt,\n929:       });\n930:       break;\n931: \n932:     case \"help\":\n933:     case \"--help\":\n934:     case \"-h\":\n935:       cmdHelp();\n936:       break;\n937: \n938:     default:\n939:       console.error(`Unknown tasks subcommand: ${args.subcommand}`);\n940:       console.error(\"Run 'woco tasks help' or 'woco help' for usage.\");\n941:       process.exit(1);\n942:       return;\n943:   }\n944: }\n945: \n946: // ---------------------------------------------------------------------------\n947: // Error Handlers & Entry\n948: // ---------------------------------------------------------------------------\n949: \n950: // Global error handlers — prevent silent crashes\n951: process.on(\"uncaughtException\", (err) => {\n952:   console.error(`\\n[FATAL] Uncaught exception: ${err.message}`);\n953:   console.error(err.stack);\n954:   try {\n955:     const state = loadState(process.cwd());\n956:     if (state) saveState(process.cwd(), state);\n957:   } catch {}\n958:   process.exit(1);\n959: });\n960: \n961: process.on(\"unhandledRejection\", (reason: any) => {\n962:   console.error(`\\n[FATAL] Unhandled rejection: ${reason?.message || reason}`);\n963:   if (reason?.stack) console.error(reason.stack);\n964:   try {\n965:     const state = loadState(process.cwd());\n966:     if (state) saveState(process.cwd(), state);\n967:   } catch {}\n968:   process.exit(1);\n969: });\n970: \n971: main().catch((err) => {\n972:   console.error(\"Fatal error:\", err.message);\n973:   process.exit(1);\n974: });\n\n(End of file - total 974 lines)\n</content>","title":"src/index.ts","metadata":{"preview":"#!/usr/bin/env bun\n/**\n * index.ts — CLI entry point for the wombo-combo agent orchestration system.\n *\n * Every command has a short alias (e.g., woco i = woco init, woco t ls = woco tasks list).\n *\n * Usage:\n *   woco init                                         (alias: i)\n *   woco launch --top-priority 3                      (alias: l)\n *   woco launch --quickest-wins 5\n *   woco launch --priority high\n *   woco launch --difficulty easy\n *   woco launch --tasks \"feat-a,feat-b\"\n *   woco launch --all-ready\n *   woco launch ... --max-concurrent 3 --model \"anthropic/claude-sonnet-4-20250514\"\n *   woco launch ... --interactive\n *   woco resume                                       (alias: r)\n *   woco status                                       (alias: s)\n *   woco verify [feature-id]                          (alias: v)\n *   woco merge [feature-id]                           (alias: m)","truncated":false,"loaded":[]},"time":{"start":1773433421421,"end":1773433421438}}}}
{"type":"tool_use","timestamp":1773433421933,"sessionID":"ses_31721ba8fffeXD00hbThRJI7PX","part":{"id":"prt_ce8de7e71001LYYVeXb5JrFDUB","sessionID":"ses_31721ba8fffeXD00hbThRJI7PX","messageID":"msg_ce8de7245001ziF9Vv3hqrMxR0","type":"tool","callID":"toolu_vrtx_01Wp3TwRCd8wmvWWvXjFdAJX","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-toon-format-spec/src/lib/output.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-toon-format-spec/src/lib/output.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * output.ts — Shared output helpers for agent-ready CLI.\n3:  *\n4:  * Provides a centralized way for commands to emit structured data that\n5:  * renders as human-readable text on TTY or as JSON when --output json\n6:  * is specified (or when stdout is not a TTY).\n7:  *\n8:  * Usage in commands:\n9:  *   import { output, OutputFormat } from \"../lib/output.js\";\n10:  *\n11:  *   // At the end of a command:\n12:  *   output(format, data);           // emits JSON or human text\n13:  *   outputError(format, message);   // emits error in the right format\n14:  */\n15: \n16: // ---------------------------------------------------------------------------\n17: // Types\n18: // ---------------------------------------------------------------------------\n19: \n20: export type OutputFormat = \"text\" | \"json\";\n21: \n22: // ---------------------------------------------------------------------------\n23: // Helpers\n24: // ---------------------------------------------------------------------------\n25: \n26: /**\n27:  * Determine the output format. Priority:\n28:  *   1. Explicit --output flag value\n29:  *   2. WOMBO_OUTPUT env var (for agent pipelines)\n30:  *   3. Default to \"text\"\n31:  *\n32:  * Note: We intentionally do NOT auto-detect based on TTY. Many legitimate\n33:  * use cases (bun dev, piped to less/grep, CI) have non-TTY stdout but still\n34:  * want human output. Agents should explicitly pass --output json or set\n35:  * WOMBO_OUTPUT=json.\n36:  */\n37: export function resolveOutputFormat(explicit?: string): OutputFormat {\n38:   if (explicit === \"json\") return \"json\";\n39:   if (explicit === \"text\") return \"text\";\n40:   // Check env var for agent pipelines\n41:   const env = process.env.WOMBO_OUTPUT;\n42:   if (env === \"json\") return \"json\";\n43:   return \"text\";\n44: }\n45: \n46: /**\n47:  * Emit structured data. In JSON mode, outputs a single JSON line to stdout.\n48:  * In text mode, calls the provided textRenderer callback.\n49:  */\n50: export function output(\n51:   format: OutputFormat,\n52:   data: unknown,\n53:   textRenderer: () => void\n54: ): void {\n55:   if (format === \"json\") {\n56:     console.log(JSON.stringify(data));\n57:   } else {\n58:     textRenderer();\n59:   }\n60: }\n61: \n62: /**\n63:  * Emit an error. In JSON mode, outputs {\"error\": message} to stderr.\n64:  * In text mode, outputs the message to stderr normally.\n65:  */\n66: export function outputError(format: OutputFormat, message: string, exitCode: number = 1): never {\n67:   if (format === \"json\") {\n68:     console.error(JSON.stringify({ error: message }));\n69:   } else {\n70:     console.error(message);\n71:   }\n72:   process.exit(exitCode);\n73: }\n74: \n75: /**\n76:  * Emit a success/info message. In JSON mode, outputs {\"message\": msg, ...extra}.\n77:  * In text mode, outputs the message to stdout normally.\n78:  */\n79: export function outputMessage(\n80:   format: OutputFormat,\n81:   message: string,\n82:   extra?: Record<string, unknown>\n83: ): void {\n84:   if (format === \"json\") {\n85:     console.log(JSON.stringify({ message, ...extra }));\n86:   } else {\n87:     console.log(message);\n88:   }\n89: }\n90: \n91: // ---------------------------------------------------------------------------\n92: // Field filtering for compact output (--fields)\n93: // ---------------------------------------------------------------------------\n94: \n95: /**\n96:  * Filter an object to only include the specified fields.\n97:  * If fields is undefined/empty, returns the object unchanged.\n98:  */\n99: export function filterFields<T extends Record<string, unknown>>(\n100:   obj: T,\n101:   fields?: string[]\n102: ): Partial<T> {\n103:   if (!fields || fields.length === 0) return obj;\n104:   const result: Partial<T> = {};\n105:   for (const field of fields) {\n106:     if (field in obj) {\n107:       (result as any)[field] = (obj as any)[field];\n108:     }\n109:   }\n110:   return result;\n111: }\n112: \n113: /**\n114:  * Filter an array of objects to only include specified fields per object.\n115:  * If fields is undefined/empty, returns the array unchanged.\n116:  */\n117: export function filterFieldsArray<T extends Record<string, unknown>>(\n118:   arr: T[],\n119:   fields?: string[]\n120: ): Partial<T>[] {\n121:   if (!fields || fields.length === 0) return arr;\n122:   return arr.map((obj) => filterFields(obj, fields));\n123: }\n124: \n125: /**\n126:  * Render a compact text table from an array of objects with selected fields.\n127:  * Used for text-mode --fields output.\n128:  */\n129: export function renderCompactTable(\n130:   items: Record<string, unknown>[],\n131:   fields: string[]\n132: ): void {\n133:   if (items.length === 0) return;\n134: \n135:   // Calculate column widths\n136:   const widths: Record<string, number> = {};\n137:   for (const field of fields) {\n138:     widths[field] = field.length;\n139:     for (const item of items) {\n140:       const val = String(item[field] ?? \"\");\n141:       widths[field] = Math.max(widths[field], val.length);\n142:     }\n143:   }\n144: \n145:   // Header\n146:   const header = fields.map((f) => f.padEnd(widths[f])).join(\"  \");\n147:   console.log(header);\n148:   console.log(fields.map((f) => \"─\".repeat(widths[f])).join(\"  \"));\n149: \n150:   // Rows\n151:   for (const item of items) {\n152:     const row = fields.map((f) => String(item[f] ?? \"\").padEnd(widths[f])).join(\"  \");\n153:     console.log(row);\n154:   }\n155: }\n\n(End of file - total 155 lines)\n</content>","title":"src/lib/output.ts","metadata":{"preview":"/**\n * output.ts — Shared output helpers for agent-ready CLI.\n *\n * Provides a centralized way for commands to emit structured data that\n * renders as human-readable text on TTY or as JSON when --output json\n * is specified (or when stdout is not a TTY).\n *\n * Usage in commands:\n *   import { output, OutputFormat } from \"../lib/output.js\";\n *\n *   // At the end of a command:\n *   output(format, data);           // emits JSON or human text\n *   outputError(format, message);   // emits error in the right format\n */\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type OutputFormat = \"text\" | \"json\";","truncated":false,"loaded":[]},"time":{"start":1773433421873,"end":1773433421920}}}}
{"type":"text","timestamp":1773433422374,"sessionID":"ses_31721ba8fffeXD00hbThRJI7PX","part":{"id":"prt_ce8de79070016279Il0TJnxtd9","sessionID":"ses_31721ba8fffeXD00hbThRJI7PX","messageID":"msg_ce8de7245001ziF9Vv3hqrMxR0","type":"text","text":"No existing toon files. Let me explore the key files - the index.ts for command routing, the output.ts (likely related to output formatting), and the existing task types:","time":{"start":1773433422373,"end":1773433422373}}}
{"type":"tool_use","timestamp":1773433422389,"sessionID":"ses_31721ba8fffeXD00hbThRJI7PX","part":{"id":"prt_ce8de8039001pZvy03m7yuU0Pv","sessionID":"ses_31721ba8fffeXD00hbThRJI7PX","messageID":"msg_ce8de7245001ziF9Vv3hqrMxR0","type":"tool","callID":"toolu_vrtx_01FyAk9t7mgg81VNg9rWq14J","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-toon-format-spec/src/lib/tasks.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-toon-format-spec/src/lib/tasks.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tasks.ts -- Parse tasks YAML and provide task selection/filtering.\n3:  *\n4:  * Responsibilities:\n5:  *   - Load and parse the tasks file with full type safety\n6:  *   - Load and parse the archive file separately\n7:  *   - Parse ISO 8601 durations into comparable minutes\n8:  *   - Filter tasks by status, priority, difficulty, dependency readiness\n9:  *   - Select tasks by various strategies (top-priority, quickest-wins, etc.)\n10:  *   - Resolve dependency graphs to determine which tasks are ready to start\n11:  *   - Write-back capability for task management commands\n12:  */\n13: \n14: import { existsSync, mkdirSync } from \"node:fs\";\n15: import { resolve, dirname, join } from \"node:path\";\n16: import { createInterface } from \"node:readline\";\n17: import type { WomboConfig } from \"../config.js\";\n18: import { WOMBO_DIR } from \"../config.js\";\n19: import {\n20:   loadTasksFromStore,\n21:   loadArchiveFromStore,\n22:   saveAllTasksToStore,\n23:   saveAllArchiveToStore,\n24:   saveTaskToStore,\n25:   saveTaskToArchive,\n26:   removeTaskFromStore,\n27:   tasksStoreExists,\n28:   saveTasksMetaToStore,\n29:   saveArchiveMetaToStore,\n30:   getTasksDir,\n31:   getArchiveDir,\n32:   saveTaskFile,\n33:   deleteTaskFile,\n34: } from \"./task-store.js\";\n35: \n36: // ---------------------------------------------------------------------------\n37: // Template path (resolved relative to this source file)\n38: // ---------------------------------------------------------------------------\n39: \n40: export const META_TEMPLATE_PATH = join(dirname(import.meta.dir), \"templates\", \"_meta.yml\");\n41: /** @deprecated Use META_TEMPLATE_PATH — the old monolithic template no longer exists. */\n42: export const TASKS_TEMPLATE_PATH = META_TEMPLATE_PATH;\n43: \n44: // ---------------------------------------------------------------------------\n45: // Types\n46: // ---------------------------------------------------------------------------\n47: \n48: export type TaskStatus =\n49:   | \"backlog\"\n50:   | \"planned\"\n51:   | \"in_progress\"\n52:   | \"blocked\"\n53:   | \"in_review\"\n54:   | \"done\"\n55:   | \"cancelled\";\n56: \n57: export type Priority = \"critical\" | \"high\" | \"medium\" | \"low\" | \"wishlist\";\n58: \n59: export type Difficulty = \"trivial\" | \"easy\" | \"medium\" | \"hard\" | \"very_hard\";\n60: \n61: /**\n62:  * Unified task type. Previously split into Feature and Subtask, but the shapes\n63:  * are identical so there is no reason to maintain two names.\n64:  */\n65: export interface Task {\n66:   id: string;\n67:   title: string;\n68:   description: string;\n69:   status: TaskStatus;\n70:   completion: number;\n71:   difficulty: Difficulty;\n72:   priority: Priority;\n73:   depends_on: string[];\n74:   effort: string;\n75:   started_at: string | null;\n76:   ended_at: string | null;\n77:   constraints: string[];\n78:   forbidden: string[];\n79:   references: string[];\n80:   notes: string[];\n81:   subtasks: Task[];\n82:   /**\n83:    * Optional agent type from an external registry (e.g. agency-agents).\n84:    * Format: \"category/agent-name\" (e.g. \"engineering/engineering-frontend-developer\").\n85:    * When set, wombo downloads and patches the specified agent definition\n86:    * instead of using the default generalist agent.\n87:    */\n88:   agent_type?: string;\n89: }\n90: \n91: /**\n92:  * Shape of tasks.yml (active tasks).\n93:  */\n94: export interface TasksFile {\n95:   version: string;\n96:   meta: {\n97:     created_at: string;\n98:     updated_at: string;\n99:     project: string;\n100:     generator: string;\n101:     maintainer: string;\n102:   };\n103:   tasks: Task[];\n104: }\n105: \n106: /**\n107:  * Shape of archive.yml (archived tasks). Same structure as TasksFile.\n108:  */\n109: export type ArchiveFile = TasksFile;\n110: \n111: // Backward-compat aliases (ease migration in consuming code)\n112: export type Feature = Task;\n113: export type Subtask = Task;\n114: export type FeatureStatus = TaskStatus;\n115: export type FeaturesFile = TasksFile & { archive: Task[] };\n116: \n117: // Re-export ordering maps from the canonical source (task-schema.ts)\n118: import { PRIORITY_ORDER, DIFFICULTY_ORDER } from \"./task-schema.js\";\n119: export { PRIORITY_ORDER, DIFFICULTY_ORDER };\n120: \n121: // ---------------------------------------------------------------------------\n122: // ISO 8601 Duration Parser\n123: // ---------------------------------------------------------------------------\n124: \n125: /**\n126:  * Parse an ISO 8601 duration string into total minutes.\n127:  * Supports: P[nY][nM][nD][T[nH][nM][nS]]\n128:  * Examples: PT1H -> 60, PT30M -> 30, P1D -> 1440, P2DT4H -> 3360, PT1H30M -> 90\n129:  *           P1Y -> 525600, P2M -> 86400\n130:  * Year/month approximations: 1Y = 365D, 1M = 30D\n131:  */\n132: export function parseDurationMinutes(iso: string): number {\n133:   const match = iso.match(\n134:     /^P(?:(\\d+)Y)?(?:(\\d+)M)?(?:(\\d+)D)?(?:T(?:(\\d+)H)?(?:(\\d+)M)?(?:(\\d+)S)?)?$/\n135:   );\n136:   if (!match) return Infinity; // unparseable -> sort to end\n137:   const years = parseInt(match[1] || \"0\", 10);\n138:   const months = parseInt(match[2] || \"0\", 10);\n139:   const days = parseInt(match[3] || \"0\", 10);\n140:   const hours = parseInt(match[4] || \"0\", 10);\n141:   const minutes = parseInt(match[5] || \"0\", 10);\n142:   const seconds = parseInt(match[6] || \"0\", 10);\n143:   const totalDays = years * 365 + months * 30 + days;\n144:   return totalDays * 24 * 60 + hours * 60 + minutes + Math.ceil(seconds / 60);\n145: }\n146: \n147: /**\n148:  * Format minutes into a human-readable string.\n149:  */\n150: export function formatDuration(minutes: number): string {\n151:   if (minutes === Infinity) return \"unknown\";\n152:   if (minutes < 60) return `${minutes}m`;\n153:   const h = Math.floor(minutes / 60);\n154:   const m = minutes % 60;\n155:   if (h >= 24) {\n156:     const d = Math.floor(h / 24);\n157:     const rh = h % 24;\n158:     if (rh === 0 && m === 0) return `${d}d`;\n159:     if (m === 0) return `${d}d ${rh}h`;\n160:     return `${d}d ${rh}h ${m}m`;\n161:   }\n162:   return m === 0 ? `${h}h` : `${h}h ${m}m`;\n163: }\n164: \n165: // ---------------------------------------------------------------------------\n166: // .wombo-combo directory helpers\n167: // ---------------------------------------------------------------------------\n168: \n169: /**\n170:  * Ensure the .wombo-combo directory exists.\n171:  */\n172: export function ensureWomboDir(projectRoot: string): string {\n173:   const dir = resolve(projectRoot, WOMBO_DIR);\n174:   if (!existsSync(dir)) {\n175:     mkdirSync(dir, { recursive: true });\n176:   }\n177:   return dir;\n178: }\n179: \n180: /**\n181:  * Resolve a file path within the .wombo-combo directory.\n182:  */\n183: function womboPath(projectRoot: string, filename: string): string {\n184:   return resolve(projectRoot, WOMBO_DIR, filename);\n185: }\n186: \n187: // ---------------------------------------------------------------------------\n188: // Tasks File Existence Guard\n189: // ---------------------------------------------------------------------------\n190: \n191: /**\n192:  * Prompt the user with a yes/no question via stdin.\n193:  */\n194: function promptYesNo(question: string): Promise<boolean> {\n195:   const rl = createInterface({ input: process.stdin, output: process.stdout });\n196:   return new Promise((resolve) => {\n197:     rl.question(question, (answer) => {\n198:       rl.close();\n199:       resolve(answer.trim().toLowerCase().startsWith(\"y\"));\n200:     });\n201:   });\n202: }\n203: \n204: /**\n205:  * Ensure the tasks store exists before any command that needs it.\n206:  * If the folder is missing, prompt the user to generate one from scratch\n207:  * or auto-migrate from a legacy single-file tasks.yml.\n208:  */\n209: export async function ensureTasksFile(\n210:   projectRoot: string,\n211:   config: WomboConfig\n212: ): Promise<void> {\n213:   if (tasksStoreExists(projectRoot, config)) return;\n214: \n215:   // Try loading — this triggers auto-migration from legacy files\n216:   const data = loadTasksFromStore(projectRoot, config);\n217:   if (data.tasks.length > 0 || tasksStoreExists(projectRoot, config)) return;\n218: \n219:   console.log(`\\nTasks store not found: ${WOMBO_DIR}/${config.tasksDir}/`);\n220: \n221:   const generate = await promptYesNo(\n222:     \"Generate a new tasks store from template? (y/N): \"\n223:   );\n224: \n225:   if (!generate) {\n226:     console.error(\n227:       `Cannot proceed without a tasks store. Create one manually or run again and accept the prompt.`\n228:     );\n229:     process.exit(1);\n230:   }\n231: \n232:   // Ensure .wombo-combo/ directory exists\n233:   ensureWomboDir(projectRoot);\n234: \n235:   const now = new Date().toISOString();\n236:   saveTasksMetaToStore(projectRoot, config, {\n237:     version: \"1.0\",\n238:     meta: {\n239:       created_at: now,\n240:       updated_at: now,\n241:       project: \"unknown\",\n242:       generator: \"wombo-combo\",\n243:       maintainer: \"unknown\",\n244:     },\n245:   });\n246:   console.log(`Created ${WOMBO_DIR}/${config.tasksDir}/ with empty task store.\\n`);\n247: \n248:   // Also create empty archive store\n249:   saveArchiveMetaToStore(projectRoot, config, {\n250:     version: \"1.0\",\n251:     meta: {\n252:       created_at: now,\n253:       updated_at: now,\n254:       project: \"unknown\",\n255:       generator: \"wombo-combo\",\n256:       maintainer: \"unknown\",\n257:     },\n258:   });\n259:   console.log(`Created ${WOMBO_DIR}/${config.archiveDir}/.\\n`);\n260: }\n261: \n262: // Backward-compat alias\n263: export const ensureFeaturesFile = ensureTasksFile;\n264: \n265: // ---------------------------------------------------------------------------\n266: // Loader\n267: // ---------------------------------------------------------------------------\n268: \n269: /**\n270:  * Load and parse tasks from the folder-based store.\n271:  */\n272: export function loadTasks(\n273:   projectRoot: string,\n274:   config: WomboConfig\n275: ): TasksFile {\n276:   return loadTasksFromStore(projectRoot, config);\n277: }\n278: \n279: /**\n280:  * Load archived tasks from the folder-based store.\n281:  * Returns an empty ArchiveFile if the store doesn't exist.\n282:  */\n283: export function loadArchive(\n284:   projectRoot: string,\n285:   config: WomboConfig\n286: ): ArchiveFile {\n287:   return loadArchiveFromStore(projectRoot, config);\n288: }\n289: \n290: /**\n291:  * Backward-compat: load tasks + archive merged into a single FeaturesFile shape.\n292:  * This eases migration — callers that used loadFeatures() keep working.\n293:  */\n294: export function loadFeatures(\n295:   projectRoot: string,\n296:   config: WomboConfig\n297: ): FeaturesFile {\n298:   const tasksData = loadTasks(projectRoot, config);\n299:   const archiveData = loadArchive(projectRoot, config);\n300:   return {\n301:     ...tasksData,\n302:     // Map \"tasks\" to \"features\" for backward compat (FeaturesFile has .features)\n303:     // Actually FeaturesFile extends TasksFile which has .tasks, but add .archive\n304:     archive: archiveData.tasks,\n305:   };\n306: }\n307: \n308: // ---------------------------------------------------------------------------\n309: // Writer\n310: // ---------------------------------------------------------------------------\n311: \n312: /**\n313:  * Save all tasks to the folder-based store.\n314:  * Writes _meta.yml + one file per task.\n315:  */\n316: export function saveTasks(\n317:   projectRoot: string,\n318:   config: WomboConfig,\n319:   data: TasksFile\n320: ): void {\n321:   saveAllTasksToStore(projectRoot, config, data);\n322: }\n323: \n324: /**\n325:  * Save all archived tasks to the folder-based store.\n326:  */\n327: export function saveArchive(\n328:   projectRoot: string,\n329:   config: WomboConfig,\n330:   data: ArchiveFile\n331: ): void {\n332:   saveAllArchiveToStore(projectRoot, config, data);\n333: }\n334: \n335: /**\n336:  * Backward-compat: save a FeaturesFile (tasks + archive in one object).\n337:  * Splits and writes to both tasks.yml and archive.yml.\n338:  */\n339: export function saveFeatures(\n340:   projectRoot: string,\n341:   config: WomboConfig,\n342:   data: FeaturesFile\n343: ): void {\n344:   const tasksData: TasksFile = {\n345:     version: data.version,\n346:     meta: { ...data.meta },\n347:     tasks: data.tasks,\n348:   };\n349:   saveTasks(projectRoot, config, tasksData);\n350: \n351:   if (data.archive && data.archive.length > 0) {\n352:     const archiveData: ArchiveFile = {\n353:       version: data.version,\n354:       meta: { ...data.meta },\n355:       tasks: data.archive,\n356:     };\n357:     saveArchive(projectRoot, config, archiveData);\n358:   }\n359: }\n360: \n361: \n362: // ---------------------------------------------------------------------------\n363: // Dependency Resolution\n364: // ---------------------------------------------------------------------------\n365: \n366: /**\n367:  * Get all task IDs that are done (status === \"done\" or completion === 100).\n368:  */\n369: function getDoneIds(tasks: Task[], archive: Task[]): Set<string> {\n370:   const done = new Set<string>();\n371:   const collectDone = (items: Task[]) => {\n372:     for (const item of items) {\n373:       if (item.status === \"done\" || item.completion === 100) {\n374:         done.add(item.id);\n375:       }\n376:       if (item.subtasks?.length) {\n377:         collectDone(item.subtasks);\n378:       }\n379:     }\n380:   };\n381:   collectDone(tasks);\n382:   collectDone(archive);\n383:   return done;\n384: }\n385: \n386: /**\n387:  * Check if a task's dependencies are all satisfied.\n388:  */\n389: export function areDependenciesMet(\n390:   task: Task,\n391:   doneIds: Set<string>\n392: ): boolean {\n393:   return task.depends_on.every((dep) => doneIds.has(dep));\n394: }\n395: \n396: /**\n397:  * Get all tasks that are ready to start (backlog + deps met).\n398:  */\n399: export function getReadyTasks(data: TasksFile, archive?: Task[]): Task[] {\n400:   const doneIds = getDoneIds(data.tasks, archive ?? []);\n401:   return data.tasks.filter(\n402:     (t) =>\n403:       t.status === \"backlog\" &&\n404:       t.completion === 0 &&\n405:       areDependenciesMet(t, doneIds)\n406:   );\n407: }\n408: \n409: /**\n410:  * Get done IDs (exported for use in selection error messages).\n411:  */\n412: export function getDoneTaskIds(data: TasksFile, archive?: Task[]): Set<string> {\n413:   return getDoneIds(data.tasks, archive ?? []);\n414: }\n415: \n416: // Backward-compat aliases\n417: export function getReadyFeatures(data: FeaturesFile): Task[] {\n418:   return getReadyTasks(data, data.archive);\n419: }\n420: \n421: export function getDoneFeatureIds(data: FeaturesFile): Set<string> {\n422:   return getDoneTaskIds(data, data.archive);\n423: }\n424: \n425: // ---------------------------------------------------------------------------\n426: // Selection Strategies\n427: // ---------------------------------------------------------------------------\n428: \n429: export interface SelectionOptions {\n430:   /** Select top N by priority (highest priority first, then lowest effort) */\n431:   topPriority?: number;\n432:   /** Select N quickest wins (lowest effort first) */\n433:   quickestWins?: number;\n434:   /** Select all tasks matching this priority level */\n435:   priority?: Priority;\n436:   /** Select all tasks matching this difficulty level */\n437:   difficulty?: Difficulty;\n438:   /** Select specific task IDs (comma-separated) */\n439:   taskIds?: string[];\n440:   /** Select all ready tasks */\n441:   allReady?: boolean;\n442: }\n443: \n444: /**\n445:  * Select tasks based on the given strategy.\n446:  * Always filters to only ready tasks (backlog + deps met) first.\n447:  */\n448: export function selectTasks(\n449:   data: TasksFile,\n450:   options: SelectionOptions,\n451:   archive?: Task[]\n452: ): Task[] {\n453:   const ready = getReadyTasks(data, archive);\n454: \n455:   if (options.allReady) {\n456:     return sortByPriorityThenEffort(ready);\n457:   }\n458: \n459:   if (options.taskIds?.length) {\n460:     const idSet = new Set(options.taskIds);\n461:     const selected = ready.filter((t) => idSet.has(t.id));\n462:     const missing = options.taskIds.filter(\n463:       (id) => !selected.find((t) => t.id === id)\n464:     );\n465:     if (missing.length) {\n466:       const allIds = data.tasks.map((t) => t.id);\n467:       const doneIds = getDoneIds(data.tasks, archive ?? []);\n468:       for (const m of missing) {\n469:         if (!allIds.includes(m)) {\n470:           console.error(`  Task \"${m}\" does not exist in the tasks file`);\n471:         } else {\n472:           const task = data.tasks.find((t) => t.id === m)!;\n473:           console.error(\n474:             `  Task \"${m}\" is not ready (status: ${task.status}, deps met: ${areDependenciesMet(task, doneIds)})`\n475:           );\n476:         }\n477:       }\n478:     }\n479:     return sortByPriorityThenEffort(selected);\n480:   }\n481: \n482:   if (options.priority) {\n483:     return sortByPriorityThenEffort(\n484:       ready.filter((t) => t.priority === options.priority)\n485:     );\n486:   }\n487: \n488:   if (options.difficulty) {\n489:     return sortByEffort(ready.filter((t) => t.difficulty === options.difficulty));\n490:   }\n491: \n492:   if (options.topPriority) {\n493:     return sortByPriorityThenEffort(ready).slice(0, options.topPriority);\n494:   }\n495: \n496:   if (options.quickestWins) {\n497:     return sortByEffort(ready).slice(0, options.quickestWins);\n498:   }\n499: \n500:   // Default: return all ready, sorted by priority\n501:   return sortByPriorityThenEffort(ready);\n502: }\n503: \n504: // Backward-compat alias\n505: export function selectFeatures(\n506:   data: FeaturesFile,\n507:   options: SelectionOptions & { featureIds?: string[] }\n508: ): Task[] {\n509:   // Map featureIds -> taskIds for backward compat\n510:   const opts: SelectionOptions = {\n511:     ...options,\n512:     taskIds: options.taskIds ?? options.featureIds,\n513:   };\n514:   return selectTasks(data, opts, data.archive);\n515: }\n516: \n517: // ---------------------------------------------------------------------------\n518: // Sorting Helpers\n519: // ---------------------------------------------------------------------------\n520: \n521: function sortByPriorityThenEffort(tasks: Task[]): Task[] {\n522:   return [...tasks].sort((a, b) => {\n523:     const pDiff = PRIORITY_ORDER[a.priority] - PRIORITY_ORDER[b.priority];\n524:     if (pDiff !== 0) return pDiff;\n525:     return parseDurationMinutes(a.effort) - parseDurationMinutes(b.effort);\n526:   });\n527: }\n528: \n529: function sortByEffort(tasks: Task[]): Task[] {\n530:   return [...tasks].sort(\n531:     (a, b) => parseDurationMinutes(a.effort) - parseDurationMinutes(b.effort)\n532:   );\n533: }\n534: \n535: // ---------------------------------------------------------------------------\n536: // Utility Exports\n537: // ---------------------------------------------------------------------------\n538: \n539: /**\n540:  * Get a compact summary of a task for display.\n541:  */\n542: export function taskSummary(t: Task): string {\n543:   const effort = formatDuration(parseDurationMinutes(t.effort));\n544:   return `[${t.priority}/${t.difficulty}] ${t.id} -- ${t.title} (${effort})`;\n545: }\n546: \n547: // Backward-compat alias\n548: export const featureSummary = taskSummary;\n549: \n550: /**\n551:  * Recursively search a list of tasks (and their subtasks) for a matching ID.\n552:  */\n553: function findInList(tasks: Task[], id: string): Task | undefined {\n554:   for (const t of tasks) {\n555:     if (t.id === id) return t;\n556:     if (t.subtasks?.length) {\n557:       const found = findInList(t.subtasks, id);\n558:       if (found) return found;\n559:     }\n560:   }\n561:   return undefined;\n562: }\n563: \n564: /**\n565:  * Find a task by ID across active tasks, their subtasks\n566:  * (recursively), and the archive list.\n567:  */\n568: export function findTaskById(\n569:   data: TasksFile,\n570:   id: string,\n571:   archive?: Task[]\n572: ): Task | undefined {\n573:   return (\n574:     findInList(data.tasks, id) ??\n575:     (archive ? findInList(archive, id) : undefined)\n576:   );\n577: }\n578: \n579: // Backward-compat alias\n580: export function findFeatureById(\n581:   data: FeaturesFile,\n582:   id: string\n583: ): Task | undefined {\n584:   return findTaskById(data, id, data.archive);\n585: }\n586: \n587: /**\n588:  * Create a blank task with all required fields initialized.\n589:  */\n590: export function createBlankTask(\n591:   id: string,\n592:   title: string,\n593:   description: string = \"\",\n594:   opts?: {\n595:     priority?: Priority;\n596:     difficulty?: Difficulty;\n597:     effort?: string;\n598:   }\n599: ): Task {\n600:   return {\n601:     id,\n602:     title,\n603:     description,\n604:     status: \"backlog\",\n605:     completion: 0,\n606:     difficulty: opts?.difficulty ?? \"medium\",\n607:     priority: opts?.priority ?? \"medium\",\n608:     depends_on: [],\n609:     effort: opts?.effort ?? \"PT1H\",\n610:     started_at: null,\n611:     ended_at: null,\n612:     constraints: [],\n613:     forbidden: [],\n614:     references: [],\n615:     notes: [],\n616:     subtasks: [],\n617:   };\n618: }\n619: \n620: // Backward-compat alias\n621: export const createBlankFeature = createBlankTask;\n622: \n623: /**\n624:  * Get all task IDs (active + archive), useful for validation.\n625:  */\n626: export function allTaskIds(data: TasksFile, archive?: Task[]): string[] {\n627:   const ids: string[] = [];\n628:   const collect = (items: Task[]) => {\n629:     for (const item of items) {\n630:       ids.push(item.id);\n631:       if (item.subtasks?.length) collect(item.subtasks);\n632:     }\n633:   };\n634:   collect(data.tasks);\n635:   collect(archive ?? []);\n636:   return ids;\n637: }\n638: \n639: // Backward-compat alias\n640: export function allFeatureIds(data: FeaturesFile): string[] {\n641:   return allTaskIds(data, data.archive);\n642: }\n643: \n644: // Re-export the old template path name for migration\n645: export const FEATURES_TEMPLATE_PATH = TASKS_TEMPLATE_PATH;\n646: \n647: // Re-export store functions for single-task operations\n648: export {\n649:   saveTaskToStore,\n650:   saveTaskToArchive,\n651:   removeTaskFromStore,\n652:   getTasksDir,\n653:   getArchiveDir,\n654: } from \"./task-store.js\";\n\n(End of file - total 654 lines)\n</content>","title":"src/lib/tasks.ts","metadata":{"preview":"/**\n * tasks.ts -- Parse tasks YAML and provide task selection/filtering.\n *\n * Responsibilities:\n *   - Load and parse the tasks file with full type safety\n *   - Load and parse the archive file separately\n *   - Parse ISO 8601 durations into comparable minutes\n *   - Filter tasks by status, priority, difficulty, dependency readiness\n *   - Select tasks by various strategies (top-priority, quickest-wins, etc.)\n *   - Resolve dependency graphs to determine which tasks are ready to start\n *   - Write-back capability for task management commands\n */\n\nimport { existsSync, mkdirSync } from \"node:fs\";\nimport { resolve, dirname, join } from \"node:path\";\nimport { createInterface } from \"node:readline\";\nimport type { WomboConfig } from \"../config.js\";\nimport { WOMBO_DIR } from \"../config.js\";\nimport {\n  loadTasksFromStore,","truncated":false,"loaded":[]},"time":{"start":1773433422362,"end":1773433422385}}}}
