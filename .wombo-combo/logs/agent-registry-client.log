{"type":"tool_use","timestamp":1773433343224,"sessionID":"ses_31723c3edffeZ3kLyww6Ny5sNi","part":{"id":"prt_ce8dd4c5f00134Lcod19DLaisV","sessionID":"ses_31723c3edffeZ3kLyww6Ny5sNi","messageID":"msg_ce8dd3ecb00148u2XhGbc433dt","type":"tool","callID":"toolu_vrtx_016GEmyYEdCS93bUKsEzLCgs","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-agent-registry-client/src/lib/agent-registry.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-agent-registry-client/src/lib/agent-registry.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * agent-registry.ts — Fetch, cache, and resolve specialized agent definitions\n3:  * from an external registry (e.g. github.com/msitarzewski/agency-agents).\n4:  *\n5:  * Flow:\n6:  *   1. Task has `agent_type: \"engineering/engineering-frontend-developer\"`\n7:  *   2. resolveAgentForTask() checks cache, fetches if missing, returns raw md\n8:  *   3. At launch time, raw md is patched via patchImportedAgent() and written\n9:  *      into the worktree's .opencode/agents/ directory\n10:  *\n11:  * Cache layout:\n12:  *   .wombo-combo/agents-cache/engineering/engineering-frontend-developer.md\n13:  *\n14:  * Raw downloads are cached. Patching is done at launch time (not cached)\n15:  * because patches depend on runtime config (portless, placeholders, etc.).\n16:  */\n17: \n18: import { resolve, dirname } from \"node:path\";\n19: import { existsSync, readFileSync, writeFileSync, mkdirSync } from \"node:fs\";\n20: import { WOMBO_DIR, type WomboConfig, type AgentRegistryMode } from \"../config.js\";\n21: import type { Task } from \"./tasks.js\";\n22: \n23: // ---------------------------------------------------------------------------\n24: // Types\n25: // ---------------------------------------------------------------------------\n26: \n27: /** Result of resolving an agent for a task */\n28: export interface ResolvedAgent {\n29:   /** Task ID this agent is resolved for */\n30:   taskId: string;\n31:   /**\n32:    * Agent name (last path segment of agent_type).\n33:    * e.g. \"engineering-frontend-developer\" from \"engineering/engineering-frontend-developer\"\n34:    */\n35:   name: string;\n36:   /** Raw markdown content from the registry (before patching) */\n37:   rawContent: string;\n38:   /** Whether this was loaded from cache (true) or freshly fetched (false) */\n39:   fromCache: boolean;\n40:   /** The agent_type string from the task */\n41:   agentType: string;\n42: }\n43: \n44: /** Generalist fallback — no specialized agent, use default */\n45: export interface GeneralistFallback {\n46:   taskId: string;\n47:   name: null;\n48:   rawContent: null;\n49:   fromCache: false;\n50:   agentType: null;\n51: }\n52: \n53: export type AgentResolution = ResolvedAgent | GeneralistFallback;\n54: \n55: // ---------------------------------------------------------------------------\n56: // Agent Name Derivation\n57: // ---------------------------------------------------------------------------\n58: \n59: /**\n60:  * Derive the agent name from an agent_type string.\n61:  * \"engineering/engineering-frontend-developer\" → \"engineering-frontend-developer\"\n62:  */\n63: export function agentNameFromType(agentType: string): string {\n64:   const segments = agentType.split(\"/\");\n65:   return segments[segments.length - 1];\n66: }\n67: \n68: // ---------------------------------------------------------------------------\n69: // Cache Operations\n70: // ---------------------------------------------------------------------------\n71: \n72: /**\n73:  * Resolve the cache file path for an agent type.\n74:  * e.g. \"engineering/engineering-frontend-developer\"\n75:  *   → \".wombo-combo/agents-cache/engineering/engineering-frontend-developer.md\"\n76:  */\n77: function cachePath(projectRoot: string, config: WomboConfig, agentType: string): string {\n78:   return resolve(projectRoot, WOMBO_DIR, config.agentRegistry.cacheDir, `${agentType}.md`);\n79: }\n80: \n81: /**\n82:  * Read a cached agent definition. Returns null if not cached.\n83:  */\n84: export function getCachedAgent(\n85:   projectRoot: string,\n86:   config: WomboConfig,\n87:   agentType: string\n88: ): string | null {\n89:   const path = cachePath(projectRoot, config, agentType);\n90:   if (!existsSync(path)) return null;\n91:   try {\n92:     return readFileSync(path, \"utf-8\");\n93:   } catch {\n94:     return null;\n95:   }\n96: }\n97: \n98: /**\n99:  * Write an agent definition to the cache.\n100:  */\n101: export function cacheAgent(\n102:   projectRoot: string,\n103:   config: WomboConfig,\n104:   agentType: string,\n105:   content: string\n106: ): void {\n107:   const path = cachePath(projectRoot, config, agentType);\n108:   mkdirSync(dirname(path), { recursive: true });\n109:   writeFileSync(path, content, \"utf-8\");\n110: }\n111: \n112: // ---------------------------------------------------------------------------\n113: // Fetch from Registry\n114: // ---------------------------------------------------------------------------\n115: \n116: /**\n117:  * Build the raw GitHub URL for an agent definition.\n118:  * Source: \"msitarzewski/agency-agents\"\n119:  * Agent type: \"engineering/engineering-frontend-developer\"\n120:  * → \"https://raw.githubusercontent.com/msitarzewski/agency-agents/main/engineering/engineering-frontend-developer.md\"\n121:  */\n122: function rawUrl(source: string, agentType: string): string {\n123:   return `https://raw.githubusercontent.com/${source}/main/${agentType}.md`;\n124: }\n125: \n126: /**\n127:  * Fetch an agent definition from the registry.\n128:  * Returns the raw markdown content or throws on failure.\n129:  */\n130: export async function fetchAgent(\n131:   agentType: string,\n132:   source: string\n133: ): Promise<string> {\n134:   const url = rawUrl(source, agentType);\n135:   const response = await fetch(url);\n136: \n137:   if (!response.ok) {\n138:     if (response.status === 404) {\n139:       throw new Error(\n140:         `Agent \"${agentType}\" not found in registry \"${source}\". ` +\n141:         `Looked at: ${url}`\n142:       );\n143:     }\n144:     throw new Error(\n145:       `Failed to fetch agent \"${agentType}\" from registry: ` +\n146:       `HTTP ${response.status} ${response.statusText}`\n147:     );\n148:   }\n149: \n150:   return await response.text();\n151: }\n152: \n153: // ---------------------------------------------------------------------------\n154: // Resolution\n155: // ---------------------------------------------------------------------------\n156: \n157: /**\n158:  * Resolve the agent definition for a single task.\n159:  *\n160:  * If the task has no agent_type or registry mode is disabled, returns a\n161:  * generalist fallback. Otherwise fetches from cache or registry.\n162:  */\n163: export async function resolveAgentForTask(\n164:   task: Task,\n165:   config: WomboConfig,\n166:   projectRoot: string\n167: ): Promise<AgentResolution> {\n168:   // No agent_type specified or registry disabled → generalist\n169:   if (!task.agent_type || config.agentRegistry.mode === \"disabled\") {\n170:     return {\n171:       taskId: task.id,\n172:       name: null,\n173:       rawContent: null,\n174:       fromCache: false,\n175:       agentType: null,\n176:     };\n177:   }\n178: \n179:   const agentType = task.agent_type;\n180:   const name = agentNameFromType(agentType);\n181: \n182:   // Check cache first\n183:   const cached = getCachedAgent(projectRoot, config, agentType);\n184:   if (cached !== null) {\n185:     return {\n186:       taskId: task.id,\n187:       name,\n188:       rawContent: cached,\n189:       fromCache: true,\n190:       agentType,\n191:     };\n192:   }\n193: \n194:   // Fetch from registry\n195:   const rawContent = await fetchAgent(agentType, config.agentRegistry.source);\n196: \n197:   // Cache the raw download\n198:   cacheAgent(projectRoot, config, agentType, rawContent);\n199: \n200:   return {\n201:     taskId: task.id,\n202:     name,\n203:     rawContent,\n204:     fromCache: false,\n205:     agentType,\n206:   };\n207: }\n208: \n209: /**\n210:  * Resolve agent definitions for all tasks in a launch wave.\n211:  *\n212:  * Returns a Map from task ID to agent resolution. Fetches are parallelized.\n213:  * Individual fetch failures are caught and logged — the task falls back to\n214:  * the generalist agent rather than blocking the entire wave.\n215:  */\n216: export async function prepareAgentDefinitions(\n217:   tasks: Task[],\n218:   config: WomboConfig,\n219:   projectRoot: string\n220: ): Promise<Map<string, AgentResolution>> {\n221:   const results = new Map<string, AgentResolution>();\n222: \n223:   // Resolve all tasks in parallel\n224:   const resolutions = await Promise.allSettled(\n225:     tasks.map(async (task) => {\n226:       const resolution = await resolveAgentForTask(task, config, projectRoot);\n227:       return { taskId: task.id, resolution };\n228:     })\n229:   );\n230: \n231:   for (const result of resolutions) {\n232:     if (result.status === \"fulfilled\") {\n233:       results.set(result.value.taskId, result.value.resolution);\n234:     } else {\n235:       // Extract task ID from the error context — find the task that failed\n236:       // by checking which tasks don't have results yet\n237:       const resolvedIds = new Set(results.keys());\n238:       const failedTask = tasks.find((t) => !resolvedIds.has(t.id));\n239:       if (failedTask) {\n240:         console.warn(\n241:           `\\x1b[33m[WARNING]\\x1b[0m Failed to resolve agent for task \"${failedTask.id}\": ${result.reason?.message ?? result.reason}`\n242:         );\n243:         console.warn(`  Falling back to generalist agent.\\n`);\n244:         results.set(failedTask.id, {\n245:           taskId: failedTask.id,\n246:           name: null,\n247:           rawContent: null,\n248:           fromCache: false,\n249:           agentType: null,\n250:         });\n251:       }\n252:     }\n253:   }\n254: \n255:   return results;\n256: }\n257: \n258: /**\n259:  * Write a patched agent definition into a worktree's agent/ directory.\n260:  *\n261:  * @param worktreePath — absolute path to the worktree root\n262:  * @param agentName    — derived name (e.g. \"engineering-frontend-developer\")\n263:  * @param patchedContent — fully patched markdown content\n264:  */\n265: export function writeAgentToWorktree(\n266:   worktreePath: string,\n267:   agentName: string,\n268:   patchedContent: string\n269: ): void {\n270:   const agentDir = resolve(worktreePath, \".opencode\", \"agents\");\n271:   mkdirSync(agentDir, { recursive: true });\n272:   const agentPath = resolve(agentDir, `${agentName}.md`);\n273:   writeFileSync(agentPath, patchedContent, \"utf-8\");\n274: }\n275: \n276: /**\n277:  * Check if a resolution is a specialized agent (not generalist fallback).\n278:  */\n279: export function isSpecializedAgent(resolution: AgentResolution): resolution is ResolvedAgent {\n280:   return resolution.name !== null && resolution.rawContent !== null;\n281: }\n\n(End of file - total 281 lines)\n</content>","title":"src/lib/agent-registry.ts","metadata":{"preview":"/**\n * agent-registry.ts — Fetch, cache, and resolve specialized agent definitions\n * from an external registry (e.g. github.com/msitarzewski/agency-agents).\n *\n * Flow:\n *   1. Task has `agent_type: \"engineering/engineering-frontend-developer\"`\n *   2. resolveAgentForTask() checks cache, fetches if missing, returns raw md\n *   3. At launch time, raw md is patched via patchImportedAgent() and written\n *      into the worktree's .opencode/agents/ directory\n *\n * Cache layout:\n *   .wombo-combo/agents-cache/engineering/engineering-frontend-developer.md\n *\n * Raw downloads are cached. Patching is done at launch time (not cached)\n * because patches depend on runtime config (portless, placeholders, etc.).\n */\n\nimport { resolve, dirname } from \"node:path\";\nimport { existsSync, readFileSync, writeFileSync, mkdirSync } from \"node:fs\";\nimport { WOMBO_DIR, type WomboConfig, type AgentRegistryMode } from \"../config.js\";","truncated":false,"loaded":[]},"time":{"start":1773433343214,"end":1773433343221}}}}
