{"type":"tool_use","timestamp":1773435228642,"sessionID":"ses_3170615afffe9yXhPnqCvGyAra","part":{"id":"prt_ce8fa0eac001VdPXYAIYkunDTb","sessionID":"ses_3170615afffe9yXhPnqCvGyAra","messageID":"msg_ce8f9fd8b001wAmqMUs0D6UdXN","type":"tool","callID":"toolu_vrtx_01My3QqkkZWhE7SkaAtfgsR5","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-tdd-agent-prompt-integration/src/lib/prompt.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-tdd-agent-prompt-integration/src/lib/prompt.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * prompt.ts — Generate agent prompts from feature specs.\n3:  *\n4:  * Responsibilities:\n5:  *   - Transform a Feature into a structured prompt for the agent\n6:  *   - Include feature spec, subtasks, constraints, forbidden items, references\n7:  *   - Generate the build command and success criteria\n8:  *   - All project-specific values come from config (no hardcoded Astro references)\n9:  */\n10: \n11: import type { Feature, Subtask } from \"./tasks.js\";\n12: import { formatDuration, parseDurationMinutes } from \"./tasks.js\";\n13: import type { WomboConfig } from \"../config.js\";\n14: import { isPortlessAvailable, portlessUrl } from \"./portless.js\";\n15: \n16: // ---------------------------------------------------------------------------\n17: // Prompt Generation\n18: // ---------------------------------------------------------------------------\n19: \n20: /**\n21:  * Generate the full prompt for an autonomous agent working on a feature.\n22:  */\n23: export function generatePrompt(\n24:   feature: Feature,\n25:   baseBranch: string,\n26:   config: WomboConfig\n27: ): string {\n28:   const sections: string[] = [];\n29: \n30:   // Header\n31:   sections.push(`# Feature Implementation: ${feature.title}`);\n32:   sections.push(`**Feature ID:** \\`${feature.id}\\``);\n33:   sections.push(`**Branch:** \\`${config.git.branchPrefix}${feature.id}\\``);\n34:   sections.push(`**Base:** \\`${baseBranch}\\``);\n35:   sections.push(\n36:     `**Estimated Effort:** ${formatDuration(parseDurationMinutes(feature.effort))}`\n37:   );\n38:   sections.push(\n39:     `**Difficulty:** ${feature.difficulty} | **Priority:** ${feature.priority}`\n40:   );\n41: \n42:   // Description\n43:   sections.push(`\\n## Description\\n`);\n44:   sections.push(feature.description.trim());\n45: \n46:   // Subtasks\n47:   if (feature.subtasks.length > 0) {\n48:     sections.push(`\\n## Subtasks\\n`);\n49:     sections.push(\n50:       \"Complete these in order. Mark each done with a commit when finished.\\n\"\n51:     );\n52:     for (let i = 0; i < feature.subtasks.length; i++) {\n53:       sections.push(formatSubtask(feature.subtasks[i], i + 1, 0));\n54:     }\n55:   }\n56: \n57:   // Constraints\n58:   if (feature.constraints.length > 0) {\n59:     sections.push(`\\n## Constraints\\n`);\n60:     sections.push(\n61:       \"You MUST follow these constraints. Violating any is a failure.\\n\"\n62:     );\n63:     for (const c of feature.constraints) {\n64:       sections.push(`- ${c}`);\n65:     }\n66:   }\n67: \n68:   // Forbidden\n69:   if (feature.forbidden.length > 0) {\n70:     sections.push(`\\n## Forbidden\\n`);\n71:     sections.push(\n72:       \"You MUST NOT do any of the following. Violating any is a failure.\\n\"\n73:     );\n74:     for (const f of feature.forbidden) {\n75:       sections.push(`- ${f}`);\n76:     }\n77:   }\n78: \n79:   // References (files to explore)\n80:   if (feature.references.length > 0) {\n81:     sections.push(`\\n## Key Files to Explore\\n`);\n82:     sections.push(\n83:       \"Start by reading these files to understand the current state:\\n\"\n84:     );\n85:     for (const r of feature.references) {\n86:       sections.push(`- \\`${r}\\``);\n87:     }\n88:   }\n89: \n90:   // Notes\n91:   if (feature.notes.length > 0) {\n92:     sections.push(`\\n## Planning Notes\\n`);\n93:     for (const n of feature.notes) {\n94:       sections.push(`- ${n}`);\n95:     }\n96:   }\n97: \n98:   // Build verification — uses config, no hardcoded Astro command\n99:   sections.push(`\\n## Build Verification\\n`);\n100:   sections.push(\n101:     \"After completing all changes, run the build to verify everything works:\\n\"\n102:   );\n103:   sections.push(\"```bash\");\n104:   sections.push(config.build.command);\n105:   sections.push(\"```\\n\");\n106:   sections.push(\n107:     \"If the build fails, fix the errors before considering the task complete.\"\n108:   );\n109: \n110:   // Browser testing — inform agents about browser verification capabilities\n111:   if (config.browser.enabled) {\n112:     sections.push(`\\n## Browser Testing\\n`);\n113:     sections.push(\n114:       \"This project has browser-based verification enabled. After the build passes, \" +\n115:       \"browser tests will run automatically as part of the verification pipeline.\\n\"\n116:     );\n117:     sections.push(\"To add browser tests for this feature:\\n\");\n118:     sections.push(\"1. Create the directory `.wombo-browser/tests/` in the worktree root\");\n119:     sections.push(\"2. Add test scripts (`.sh`, `.ts`, or `.js` files) that will be executed in order\");\n120:     sections.push(\"3. Each test script receives these environment variables:\");\n121:     sections.push(\"   - `BROWSER_DEBUG_PORT` — Chrome DevTools Protocol port\");\n122:     sections.push(\"   - `BROWSER_WS_ENDPOINT` — WebSocket endpoint for the browser\");\n123:     sections.push(\"   - `BROWSER_HEADLESS` — whether the browser is running headless\");\n124:     sections.push(\"   - `BROWSER_SCREENSHOT_PATH` — path to save a screenshot for this test\");\n125:     sections.push(\"4. A test passes if it exits with code 0, fails otherwise\\n\");\n126:     if (config.browser.testCommand) {\n127:       sections.push(\n128:         `Alternatively, the project uses a custom browser test command: \\`${config.browser.testCommand}\\``\n129:       );\n130:     }\n131:     sections.push(\n132:       \"\\nBrowser tests are optional — if no tests are found, browser verification is skipped.\"\n133:     );\n134:   }\n135: \n136:   // Portless server testing instructions\n137:   if (config.portless.enabled && isPortlessAvailable(config)) {\n138:     sections.push(`\\n## Server Testing (portless)\\n`);\n139:     sections.push(\n140:       \"This worktree is configured with **portless** to prevent port collisions \" +\n141:       \"between concurrent agents. When starting any localhost server for testing:\\n\"\n142:     );\n143:     sections.push(\"```bash\");\n144:     sections.push(\"# Instead of running a server directly:\");\n145:     sections.push(\"#   npm run dev\");\n146:     sections.push(\"#   bun run dev\");\n147:     sections.push(\"#   node server.js\");\n148:     sections.push(\"\");\n149:     sections.push(\"# Wrap it with portless:\");\n150:     sections.push(`portless run npm run dev`);\n151:     sections.push(`portless run bun run dev`);\n152:     sections.push(`portless run node server.js`);\n153:     sections.push(\"```\\n\");\n154:     sections.push(\n155:       `Your dev server will be available at: \\`${portlessUrl(feature.id, config)}\\``\n156:     );\n157:     sections.push(\"\");\n158:     sections.push(\"**Rules:**\");\n159:     sections.push(\"- ALWAYS use `portless run <command>` when starting any server that listens on a port\");\n160:     sections.push(\"- Do NOT hardcode port numbers — portless assigns ports automatically via the `PORT` env var\");\n161:     sections.push(\"- The `PORT` and `PORTLESS_URL` environment variables are set automatically\");\n162:     sections.push(\"- If you need to reference the server URL in tests or config, use the `PORTLESS_URL` env var\");\n163:   }\n164: \n165:   // Commit guidelines\n166:   sections.push(`\\n## Commit Guidelines\\n`);\n167:   sections.push(\"- Use conventional commits: `feat(scope):`, `fix(scope):`, `refactor(scope):`, `docs(scope):`\");\n168:   sections.push(`- Scope should be: \\`${feature.id}\\` or a relevant module name`);\n169:   sections.push(\"- Commit after each logical unit of work (roughly per subtask)\");\n170:   sections.push(\"- Do NOT squash all changes into one commit\");\n171:   sections.push(\"- Do NOT push to remote -- the orchestrator handles that\");\n172:   sections.push(`- Do NOT modify \\`${config.tasksFile}\\` -- the orchestrator handles that`);\n173: \n174:   // Final instruction\n175:   sections.push(`\\n## Execution\\n`);\n176:   sections.push(\"1. Read the key files listed above to understand the codebase\");\n177:   sections.push(\"2. Create a plan (use the TodoWrite tool)\");\n178:   sections.push(\"3. Implement each subtask, committing as you go\");\n179:   sections.push(`4. Run \\`${config.build.command}\\` to verify`);\n180:   sections.push(\"5. If the build passes, you are done\");\n181:   sections.push(\"6. If the build fails, fix the errors and re-run until it passes\");\n182: \n183:   return sections.join(\"\\n\");\n184: }\n185: \n186: // ---------------------------------------------------------------------------\n187: // Subtask Formatting\n188: // ---------------------------------------------------------------------------\n189: \n190: // ---------------------------------------------------------------------------\n191: // Conflict Resolution Prompt\n192: // ---------------------------------------------------------------------------\n193: \n194: /**\n195:  * Generate a prompt for an agent that resolves merge conflicts.\n196:  *\n197:  * The agent is launched in the feature worktree AFTER `git merge <baseBranch>`\n198:  * has been run there, leaving conflict markers in the working tree.\n199:  */\n200: export function generateConflictResolutionPrompt(\n201:   feature: Feature,\n202:   baseBranch: string,\n203:   mergeError: string,\n204:   config: WomboConfig\n205: ): string {\n206:   const sections: string[] = [];\n207: \n208:   sections.push(`# Merge Conflict Resolution: ${feature.title}`);\n209:   sections.push(`**Feature ID:** \\`${feature.id}\\``);\n210:   sections.push(`**Feature Branch:** \\`${config.git.branchPrefix}${feature.id}\\``);\n211:   sections.push(`**Base Branch:** \\`${baseBranch}\\``);\n212: \n213:   sections.push(`\\n## Situation\\n`);\n214:   sections.push(\n215:     `The feature branch \\`${config.git.branchPrefix}${feature.id}\\` has been completed and build-verified, ` +\n216:     `but merging it into \\`${baseBranch}\\` produced conflicts. The base branch (\\`${baseBranch}\\`) has been ` +\n217:     `merged INTO this feature branch's worktree, so the conflict markers are present in the working tree right now.`\n218:   );\n219: \n220:   sections.push(`\\n## Merge Error Output\\n`);\n221:   sections.push(\"```\");\n222:   sections.push(mergeError);\n223:   sections.push(\"```\");\n224: \n225:   sections.push(`\\n## Feature Description\\n`);\n226:   sections.push(feature.description.trim());\n227: \n228:   sections.push(`\\n## Your Task\\n`);\n229:   sections.push(\"1. Find all files with conflict markers (`<<<<<<<`, `=======`, `>>>>>>>`)\");\n230:   sections.push(\"2. Resolve each conflict by combining both sides intelligently:\");\n231:   sections.push(`   - The \\`HEAD\\` side is the feature's work (keep this intent)`);\n232:   sections.push(`   - The \\`${baseBranch}\\` side is upstream changes (integrate these)`);\n233:   sections.push(\"3. Remove ALL conflict markers — no `<<<<<<<`, `=======`, or `>>>>>>>` should remain\");\n234:   sections.push(\"4. Run the build to verify everything compiles:\");\n235:   sections.push(\"   ```bash\");\n236:   sections.push(`   ${config.build.command}`);\n237:   sections.push(\"   ```\");\n238:   sections.push(\"5. If the build fails, fix the errors\");\n239:   sections.push(\"6. Stage all resolved files and commit the merge:\");\n240:   sections.push(\"   ```bash\");\n241:   sections.push(\"   git add -A\");\n242:   sections.push('   git commit --no-edit');\n243:   sections.push(\"   ```\");\n244: \n245:   sections.push(`\\n## Rules\\n`);\n246:   sections.push(\"- Do NOT abort the merge (`git merge --abort`)\");\n247:   sections.push(\"- Do NOT create new branches or rebase\");\n248:   sections.push(\"- Do NOT push to remote\");\n249:   sections.push(`- Do NOT modify \\`${config.tasksFile}\\``);\n250:   sections.push(\"- Keep BOTH the feature's changes and the upstream changes where possible\");\n251:   sections.push(\"- If in doubt, prefer the feature's implementation but ensure upstream additions are not lost\");\n252: \n253:   return sections.join(\"\\n\");\n254: }\n255: \n256: // ---------------------------------------------------------------------------\n257: // Subtask Formatting\n258: // ---------------------------------------------------------------------------\n259: \n260: function formatSubtask(\n261:   subtask: Subtask,\n262:   index: number,\n263:   depth: number\n264: ): string {\n265:   const indent = \"  \".repeat(depth);\n266:   const lines: string[] = [];\n267: \n268:   lines.push(\n269:     `${indent}${index}. **${subtask.title}** (\\`${subtask.id}\\`, ${formatDuration(parseDurationMinutes(subtask.effort))})`\n270:   );\n271:   lines.push(`${indent}   ${subtask.description.trim()}`);\n272: \n273:   if (subtask.constraints.length > 0) {\n274:     for (const c of subtask.constraints) {\n275:       lines.push(`${indent}   - Constraint: ${c}`);\n276:     }\n277:   }\n278:   if (subtask.forbidden.length > 0) {\n279:     for (const f of subtask.forbidden) {\n280:       lines.push(`${indent}   - Forbidden: ${f}`);\n281:     }\n282:   }\n283:   if (subtask.references.length > 0) {\n284:     lines.push(\n285:       `${indent}   - Files: ${subtask.references.map((r) => `\\`${r}\\``).join(\", \")}`\n286:     );\n287:   }\n288:   if (subtask.depends_on.length > 0) {\n289:     lines.push(\n290:       `${indent}   - Depends on: ${subtask.depends_on.map((d) => `\\`${d}\\``).join(\", \")}`\n291:     );\n292:   }\n293: \n294:   // Nested subtasks\n295:   if (subtask.subtasks.length > 0) {\n296:     for (let i = 0; i < subtask.subtasks.length; i++) {\n297:       lines.push(formatSubtask(subtask.subtasks[i], i + 1, depth + 1));\n298:     }\n299:   }\n300: \n301:   return lines.join(\"\\n\");\n302: }\n\n(End of file - total 302 lines)\n</content>","title":"src/lib/prompt.ts","metadata":{"preview":"/**\n * prompt.ts — Generate agent prompts from feature specs.\n *\n * Responsibilities:\n *   - Transform a Feature into a structured prompt for the agent\n *   - Include feature spec, subtasks, constraints, forbidden items, references\n *   - Generate the build command and success criteria\n *   - All project-specific values come from config (no hardcoded Astro references)\n */\n\nimport type { Feature, Subtask } from \"./tasks.js\";\nimport { formatDuration, parseDurationMinutes } from \"./tasks.js\";\nimport type { WomboConfig } from \"../config.js\";\nimport { isPortlessAvailable, portlessUrl } from \"./portless.js\";\n\n// ---------------------------------------------------------------------------\n// Prompt Generation\n// ---------------------------------------------------------------------------\n\n/**","truncated":false,"loaded":[]},"time":{"start":1773435228636,"end":1773435228641}}}}
