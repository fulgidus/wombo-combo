{"type":"tool_use","timestamp":1773435231984,"sessionID":"ses_3170615afffe9yXhPnqCvGyAra","part":{"id":"prt_ce8fa1c36001kw1AmgUaTJvZQe","sessionID":"ses_3170615afffe9yXhPnqCvGyAra","messageID":"msg_ce8fa1213001jtma9E0UA3R7tP","type":"tool","callID":"toolu_vrtx_01JX44PZvdRJeM9xSixMZ96t","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-tdd-agent-prompt-integration/src/lib/templates.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-tdd-agent-prompt-integration/src/lib/templates.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * templates.ts — Resolve paths to bundled template files, render agent\n3:  * definitions, and compose patched agent definitions from imported agents.\n4:  *\n5:  * Template architecture:\n6:  *\n7:  *   generalist-agent.md          — standalone agent definition (no imported base)\n8:  *   wc-patch.description.end.md  — appended to imported agent's frontmatter description\n9:  *   wc-patch.body.start.md       — prepended to imported agent's body\n10:  *   wc-patch.body.end.md         — appended to imported agent's body\n11:  *\n12:  * Conditional blocks (portless, browser testing) are injected programmatically\n13:  * by the render/patch functions based on config — never left as \"if enabled\"\n14:  * prose for the LLM to interpret.\n15:  */\n16: \n17: import { join, dirname, resolve } from \"node:path\";\n18: import { existsSync, readFileSync, writeFileSync, mkdirSync } from \"node:fs\";\n19: import YAML from \"yaml\";\n20: import type { WomboConfig } from \"../config.js\";\n21: import { isPortlessAvailable } from \"./portless.js\";\n22: \n23: // ---------------------------------------------------------------------------\n24: // Template Directory & Paths\n25: // ---------------------------------------------------------------------------\n26: \n27: const TEMPLATES_DIR = join(dirname(import.meta.dir), \"templates\");\n28: \n29: /** Standalone generalist agent template. */\n30: export const GENERALIST_TEMPLATE_PATH = join(TEMPLATES_DIR, \"generalist-agent.md\");\n31: \n32: /** Patch: text appended to an imported agent's frontmatter `description` field. */\n33: export const PATCH_DESCRIPTION_END_PATH = join(TEMPLATES_DIR, \"wc-patch.description.end.md\");\n34: \n35: /** Patch: markdown prepended to an imported agent's body. */\n36: export const PATCH_BODY_START_PATH = join(TEMPLATES_DIR, \"wc-patch.body.start.md\");\n37: \n38: /** Patch: markdown appended to an imported agent's body. */\n39: export const PATCH_BODY_END_PATH = join(TEMPLATES_DIR, \"wc-patch.body.end.md\");\n40: \n41: /**\n42:  * Backward-compatible alias. Code that referenced `AGENT_TEMPLATE_PATH`\n43:  * continues to work — it now points to the generalist template.\n44:  */\n45: export const AGENT_TEMPLATE_PATH = GENERALIST_TEMPLATE_PATH;\n46: \n47: // ---------------------------------------------------------------------------\n48: // Deterministic Conditional Blocks\n49: // ---------------------------------------------------------------------------\n50: \n51: /**\n52:  * Portless server-testing block. Injected by render/patch functions ONLY when\n53:  * `config.portless.enabled` is true. The agent never sees \"if portless is\n54:  * enabled\" — it either gets these instructions or it doesn't.\n55:  */\n56: const PORTLESS_BLOCK = `\n57: ## Server Testing (portless)\n58: \n59: Your environment is preconfigured with **portless** for collision-free localhost servers:\n60: \n61: - **\\`PORTLESS_ENABLED=1\\`** is set in your environment.\n62: - **Do NOT hardcode port numbers.** Use \\`process.env.PORT\\` or let your framework pick a port automatically.\n63: - **Use \\`portless run <cmd>\\`** to start dev servers (e.g., \\`portless run bun start\\`). This auto-assigns a port and gives you a stable \\`.localhost\\` URL via \\`PORTLESS_URL\\`.\n64: - **Check \\`PORTLESS_URL\\`** in your environment for the stable URL assigned to your worktree's server.\n65: - Multiple agents can run dev servers simultaneously without port conflicts — portless handles routing through its proxy.\n66: - **Never hardcode port numbers.** Always use the portless-assigned port.\n67: `;\n68: \n69: // ---------------------------------------------------------------------------\n70: // Placeholder Substitution\n71: // ---------------------------------------------------------------------------\n72: \n73: /**\n74:  * Default runtime description used when no project-specific value is available.\n75:  */\n76: const DEFAULT_RUNTIME = \"Bun (not Node). TypeScript, strict mode, ESM only.\";\n77: \n78: /**\n79:  * Replace {{placeholders}} in template content with config-derived values.\n80:  *\n81:  * Supported placeholders:\n82:  *   - {{tasksFile}}      — tasks YAML filename (e.g. \"tasks.yml\")\n83:  *   - {{branchPrefix}}   — git branch prefix (e.g. \"feature/\")\n84:  *   - {{buildCommand}}   — build command (e.g. \"bun run build\")\n85:  *   - {{runtime}}        — project runtime description\n86:  *   - {{project}}        — project directory name\n87:  */\n88: function applyPlaceholders(\n89:   content: string,\n90:   config: WomboConfig,\n91:   projectRoot: string\n92: ): string {\n93:   const projectName = projectRoot.split(\"/\").pop() ?? \"project\";\n94:   return content\n95:     .replace(/\\{\\{tasksDir\\}\\}/g, config.tasksDir)\n96:     .replace(/\\{\\{branchPrefix\\}\\}/g, config.git.branchPrefix)\n97:     .replace(/\\{\\{buildCommand\\}\\}/g, config.build.command)\n98:     .replace(/\\{\\{runtime\\}\\}/g, DEFAULT_RUNTIME)\n99:     .replace(/\\{\\{project\\}\\}/g, projectName);\n100: }\n101: \n102: // ---------------------------------------------------------------------------\n103: // Frontmatter Parsing\n104: // ---------------------------------------------------------------------------\n105: \n106: /**\n107:  * Split a markdown file with YAML frontmatter into its two parts.\n108:  * Returns the raw YAML string (without delimiters) and the body.\n109:  */\n110: function splitFrontmatter(md: string): { yaml: string; body: string } {\n111:   const match = md.match(/^---\\r?\\n([\\s\\S]*?)\\r?\\n---\\r?\\n?([\\s\\S]*)$/);\n112:   if (!match) {\n113:     return { yaml: \"\", body: md };\n114:   }\n115:   return { yaml: match[1], body: match[2] };\n116: }\n117: \n118: /**\n119:  * Reassemble frontmatter YAML and body into a markdown string.\n120:  */\n121: function joinFrontmatter(yaml: string, body: string): string {\n122:   if (!yaml.trim()) return body;\n123:   return `---\\n${yaml.trimEnd()}\\n---\\n${body}`;\n124: }\n125: \n126: // ---------------------------------------------------------------------------\n127: // Generalist Agent Rendering\n128: // ---------------------------------------------------------------------------\n129: \n130: /**\n131:  * Render the standalone generalist agent template.\n132:  *\n133:  * This is the default agent definition for projects that don't import a\n134:  * specialized agent from an external registry. Portless instructions are\n135:  * injected deterministically based on config.\n136:  */\n137: export function renderGeneralistAgent(\n138:   config: WomboConfig,\n139:   projectRoot: string\n140: ): string {\n141:   let raw = readFileSync(GENERALIST_TEMPLATE_PATH, \"utf-8\");\n142: \n143:   // Deterministic portless injection\n144:   if (config.portless.enabled && isPortlessAvailable(config)) {\n145:     // Insert portless block before \"## What You Must Never Do\" (or at end)\n146:     const neverDoMarker = \"## What You Must Never Do\";\n147:     const idx = raw.indexOf(neverDoMarker);\n148:     if (idx !== -1) {\n149:       raw = raw.slice(0, idx) + PORTLESS_BLOCK + \"\\n\" + raw.slice(idx);\n150:     } else {\n151:       raw += \"\\n\" + PORTLESS_BLOCK;\n152:     }\n153:   }\n154: \n155:   return applyPlaceholders(raw, config, projectRoot);\n156: }\n157: \n158: // ---------------------------------------------------------------------------\n159: // Imported Agent Patching\n160: // ---------------------------------------------------------------------------\n161: \n162: /**\n163:  * Patch an imported agent definition (e.g. from agency-agents) with\n164:  * wombo-combo operational context.\n165:  *\n166:  * Composition order:\n167:  *   1. Parse the imported agent's frontmatter and body\n168:  *   2. Append wc-patch.description.end to the `description` frontmatter field\n169:  *   3. Prepend wc-patch.body.start to the body\n170:  *   4. Append wc-patch.body.end to the body\n171:  *   5. Conditionally inject portless block (deterministic, based on config)\n172:  *   6. Apply {{placeholder}} substitution to the entire result\n173:  *\n174:  * @param rawAgentMd  — raw markdown content of the imported agent file\n175:  * @param config      — wombo-combo project config\n176:  * @param projectRoot — absolute path to the project root\n177:  */\n178: export function patchImportedAgent(\n179:   rawAgentMd: string,\n180:   config: WomboConfig,\n181:   projectRoot: string\n182: ): string {\n183:   const { yaml: rawYaml, body: rawBody } = splitFrontmatter(rawAgentMd);\n184: \n185:   // --- Patch frontmatter description ---\n186:   let patchedYaml = rawYaml;\n187:   if (rawYaml) {\n188:     try {\n189:       const descPatchRaw = readFileSync(PATCH_DESCRIPTION_END_PATH, \"utf-8\").trim();\n190:       if (descPatchRaw) {\n191:         const doc = YAML.parseDocument(rawYaml);\n192:         const currentDesc = doc.get(\"description\");\n193:         if (typeof currentDesc === \"string\") {\n194:           doc.set(\"description\", currentDesc.trimEnd() + \"\\n\\n\" + descPatchRaw);\n195:         } else {\n196:           // No description field — add one\n197:           doc.set(\"description\", descPatchRaw);\n198:         }\n199:         // Ensure mode is set for wombo-combo compatibility\n200:         if (!doc.has(\"mode\")) {\n201:           doc.set(\"mode\", \"primary\");\n202:         }\n203:         patchedYaml = YAML.stringify(doc, { lineWidth: 0 }).trimEnd();\n204:       }\n205:     } catch {\n206:       // Patch file missing or YAML parse error — proceed without patching\n207:     }\n208:   }\n209: \n210:   // --- Patch body ---\n211:   let patchedBody = rawBody;\n212: \n213:   // Prepend body.start\n214:   try {\n215:     const bodyStart = readFileSync(PATCH_BODY_START_PATH, \"utf-8\");\n216:     if (bodyStart.trim()) {\n217:       patchedBody = bodyStart + patchedBody;\n218:     }\n219:   } catch {\n220:     // Patch file missing — skip\n221:   }\n222: \n223:   // Append body.end\n224:   try {\n225:     const bodyEnd = readFileSync(PATCH_BODY_END_PATH, \"utf-8\");\n226:     if (bodyEnd.trim()) {\n227:       patchedBody = patchedBody.trimEnd() + \"\\n\" + bodyEnd;\n228:     }\n229:   } catch {\n230:     // Patch file missing — skip\n231:   }\n232: \n233:   // Deterministic portless injection (appended after body.end)\n234:   if (config.portless.enabled && isPortlessAvailable(config)) {\n235:     patchedBody = patchedBody.trimEnd() + \"\\n\" + PORTLESS_BLOCK;\n236:   }\n237: \n238:   // --- Reassemble & substitute placeholders ---\n239:   const composed = joinFrontmatter(patchedYaml, patchedBody);\n240:   return applyPlaceholders(composed, config, projectRoot);\n241: }\n242: \n243: // ---------------------------------------------------------------------------\n244: // Backward Compatibility\n245: // ---------------------------------------------------------------------------\n246: \n247: /**\n248:  * Render the agent template. Backward-compatible wrapper around\n249:  * `renderGeneralistAgent` — existing code that calls this function\n250:  * continues to work unchanged.\n251:  */\n252: export function renderAgentTemplate(\n253:   config: WomboConfig,\n254:   projectRoot: string\n255: ): string {\n256:   return renderGeneralistAgent(config, projectRoot);\n257: }\n258: \n259: // ---------------------------------------------------------------------------\n260: // Agent Definition Guard\n261: // ---------------------------------------------------------------------------\n262: \n263: /**\n264:  * Ensure the agent definition file exists at the expected path.\n265:  * If missing, reinstall from the bundled generalist template and warn.\n266:  *\n267:  * Called at the start of `woco launch` to prevent the failure mode where\n268:  * agents spawn without their agent definition file.\n269:  *\n270:  * @returns true if the file was reinstalled, false if it already existed.\n271:  */\n272: export function ensureAgentDefinition(\n273:   projectRoot: string,\n274:   config: WomboConfig\n275: ): boolean {\n276:   const agentDir = resolve(projectRoot, \".opencode\", \"agents\");\n277:   const agentDefPath = resolve(agentDir, `${config.agent.name}.md`);\n278: \n279:   if (existsSync(agentDefPath)) {\n280:     return false;\n281:   }\n282: \n283:   // Agent definition missing — reinstall from bundled template\n284:   console.warn(\n285:     `\\x1b[33m[WARNING]\\x1b[0m Agent definition not found: .opencode/agents/${config.agent.name}.md`\n286:   );\n287:   console.warn(`  Reinstalling from bundled generalist template...`);\n288: \n289:   try {\n290:     mkdirSync(agentDir, { recursive: true });\n291:     const content = renderGeneralistAgent(config, projectRoot);\n292:     writeFileSync(agentDefPath, content, \"utf-8\");\n293:     console.warn(`  Restored .opencode/agents/${config.agent.name}.md\\n`);\n294:     return true;\n295:   } catch (err: any) {\n296:     console.error(\n297:       `  Failed to restore agent definition: ${err.message}`\n298:     );\n299:     console.error(\n300:       `  Agents may launch without their definition file.\\n`\n301:     );\n302:     return false;\n303:   }\n304: }\n\n(End of file - total 304 lines)\n</content>","title":"src/lib/templates.ts","metadata":{"preview":"/**\n * templates.ts — Resolve paths to bundled template files, render agent\n * definitions, and compose patched agent definitions from imported agents.\n *\n * Template architecture:\n *\n *   generalist-agent.md          — standalone agent definition (no imported base)\n *   wc-patch.description.end.md  — appended to imported agent's frontmatter description\n *   wc-patch.body.start.md       — prepended to imported agent's body\n *   wc-patch.body.end.md         — appended to imported agent's body\n *\n * Conditional blocks (portless, browser testing) are injected programmatically\n * by the render/patch functions based on config — never left as \"if enabled\"\n * prose for the LLM to interpret.\n */\n\nimport { join, dirname, resolve } from \"node:path\";\nimport { existsSync, readFileSync, writeFileSync, mkdirSync } from \"node:fs\";\nimport YAML from \"yaml\";\nimport type { WomboConfig } from \"../config.js\";","truncated":false,"loaded":[]},"time":{"start":1773435231981,"end":1773435231983}}}}
{"type":"tool_use","timestamp":1773435232816,"sessionID":"ses_3170615afffe9yXhPnqCvGyAra","part":{"id":"prt_ce8fa1eee001Z1Vx7GC9jVbc9F","sessionID":"ses_3170615afffe9yXhPnqCvGyAra","messageID":"msg_ce8fa1213001jtma9E0UA3R7tP","type":"tool","callID":"toolu_vrtx_01EoWwPQ3so98UiJ4tMqc3wR","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-tdd-agent-prompt-integration/src/templates/generalist-agent.md"},"output":"<path>/home/fulgidus/Documents/wt-wombo-tdd-agent-prompt-integration/src/templates/generalist-agent.md</path>\n<type>file</type>\n<content>1: ---\n2: description: >-\n3:   Autonomous generalist coding agent launched by wombo-combo into isolated git\n4:   worktrees to implement tasks from {{tasksFile}}. Operates headlessly with\n5:   zero human interaction. Each task is a node in a recursive tree of identical\n6:   atomic jobs — the agent receives one task with its full subtree and implements\n7:   all subtasks depth-first.\n8: \n9:   Examples:\n10: \n11:   - user: \"Implement task cli-bugs from the backlog\"\n12:     assistant: \"I'll read the task spec from {{tasksFile}} and implement all subtasks.\"\n13: \n14:   - user: \"Fix the build errors from the last run\"\n15:     assistant: \"I'll read the build output, identify the failures, and fix them.\"\n16: mode: primary\n17: ---\n18: You are an autonomous coding agent launched by wombo-combo into an isolated git worktree.\n19: You implement tasks defined in `{{tasksFile}}` with zero human interaction.\n20: \n21: ## Task Structure\n22: \n23: Tasks form a **recursive tree**. Every node — whether a top-level task or a deeply\n24: nested subtask — has the identical schema: id, title, description, status, subtasks,\n25: constraints, forbidden, references, notes, effort, difficulty, priority, and\n26: dependencies. You receive one task with its full subtree and implement all nodes\n27: depth-first.\n28: \n29: ## Your Environment\n30: \n31: - You are in a **git worktree**, not the main repository. Your branch is `{{branchPrefix}}<task-id>`.\n32: - The task you must implement was passed to you as a prompt. It includes the full spec: description, subtasks, constraints, forbidden items, references, and build command.\n33: - Config files from the main repo (AGENTS.md, opencode config, this agent definition) have been copied into your worktree.\n34: - **Runtime:** {{runtime}}\n35: \n36: ## Operational Rules\n37: \n38: **You run headlessly. You MUST:**\n39: - NEVER ask questions or request clarification. Make reasonable decisions from context and code conventions.\n40: - NEVER enter plan mode or propose plans for approval. Execute directly.\n41: - NEVER wait for confirmation. Act decisively.\n42: - If ambiguity exists, examine the codebase for patterns and follow them.\n43: - If you encounter an error, debug and fix it yourself (up to 3 attempts per issue).\n44: \n45: ## Workflow\n46: \n47: 1. **Read the prompt** — it contains the full task spec from `{{tasksFile}}` including subtasks, constraints, and forbidden items.\n48: 2. **Read AGENTS.md** if present — it contains project-specific hard constraints and conventions.\n49: 3. **Explore the codebase** — understand the architecture before writing code. Read key files, follow imports, understand patterns.\n50: 4. **Plan with TodoWrite** — break the work into concrete steps.\n51: 5. **Implement subtasks in order** — commit after each logical unit of work.\n52: 6. **Typecheck** — run `bun run typecheck` (or the project's equivalent).\n53: 7. **Build** — run the build command from the prompt to verify everything compiles.\n54: 8. **Fix any failures** — if typecheck or build fails, fix and re-run until it passes.\n55: \n56: ## Commit Guidelines\n57: \n58: - Use conventional commits: `feat(scope):`, `fix(scope):`, `refactor(scope):`\n59: - Scope should be the task ID or a relevant module name\n60: - Commit after each logical unit of work (roughly per subtask)\n61: - Do NOT squash everything into one commit\n62: - Do NOT push to remote — the orchestrator handles that\n63: - Do NOT modify `{{tasksFile}}` — the orchestrator handles status updates\n64: \n65: ## Constraints\n66: \n67: - **Stay in scope.** Only implement the task you were assigned. Do not modify unrelated code.\n68: - **Respect the task's constraints and forbidden lists.** These are non-negotiable.\n69: - **Build must pass.** The orchestrator will verify your build. If it fails, you'll be retried with the error output.\n70: - **No new dependencies** unless the task spec explicitly requires them.\n71: - **Follow existing code style** — indentation, naming, patterns, module structure.\n72: \n73: ## Error Recovery\n74: \n75: If something fails:\n76: 1. Read error messages carefully and diagnose the root cause.\n77: 2. Check if the error is in your new code or pre-existing.\n78: 3. Attempt up to 3 fix-and-retry iterations per issue.\n79: 4. If truly blocked by an external factor, document the blocker in a commit message, implement what you can, and move on.\n80: 5. Never leave the worktree in a broken state — if you cannot complete a task, revert partial changes and document why.\n81: \n82: ## What You Must Never Do\n83: \n84: - Never ask for human input or confirmation\n85: - Never enter plan mode\n86: - Never modify files outside the scope of the current task\n87: - Never commit code that breaks the build\n88: - Never ignore errors without investigation\n89: - Never push to remote\n\n(End of file - total 89 lines)\n</content>","title":"src/templates/generalist-agent.md","metadata":{"preview":"---\ndescription: >-\n  Autonomous generalist coding agent launched by wombo-combo into isolated git\n  worktrees to implement tasks from {{tasksFile}}. Operates headlessly with\n  zero human interaction. Each task is a node in a recursive tree of identical\n  atomic jobs — the agent receives one task with its full subtree and implements\n  all subtasks depth-first.\n\n  Examples:\n\n  - user: \"Implement task cli-bugs from the backlog\"\n    assistant: \"I'll read the task spec from {{tasksFile}} and implement all subtasks.\"\n\n  - user: \"Fix the build errors from the last run\"\n    assistant: \"I'll read the build output, identify the failures, and fix them.\"\nmode: primary\n---\nYou are an autonomous coding agent launched by wombo-combo into an isolated git worktree.\nYou implement tasks defined in `{{tasksFile}}` with zero human interaction.\n","truncated":false,"loaded":[]},"time":{"start":1773435232810,"end":1773435232815}}}}
{"type":"tool_use","timestamp":1773435233214,"sessionID":"ses_3170615afffe9yXhPnqCvGyAra","part":{"id":"prt_ce8fa222d001R46nb3YKAxfNav","sessionID":"ses_3170615afffe9yXhPnqCvGyAra","messageID":"msg_ce8fa1213001jtma9E0UA3R7tP","type":"tool","callID":"toolu_vrtx_01478YsUJmwhrbgMVXvpBkFk","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-tdd-agent-prompt-integration/src/templates/_meta.yml"},"output":"<path>/home/fulgidus/Documents/wt-wombo-tdd-agent-prompt-integration/src/templates/_meta.yml</path>\n<type>file</type>\n<content>1: # =============================================================================\n2: # WOMBO COMBO! — Task Store Metadata (_meta.yml)\n3: # =============================================================================\n4: #\n5: # This file lives at: .wombo-combo/<tasks|archive>/_meta.yml\n6: # Sibling files: one <task-id>.yml per task (see TASK SCHEMA below).\n7: #\n8: # REQUIRED FIELDS:\n9: #   version    : string — Schema version (currently \"1.0\").\n10: #   meta       : object — Metadata about this task store.\n11: #     created_at  : string — ISO 8601 datetime when the store was created.\n12: #     updated_at  : string — ISO 8601 datetime, auto-updated on every write.\n13: #     project     : string — Project name.\n14: #     generator   : string — Tool that created this file (always \"wombo-combo\").\n15: #     maintainer  : string — Primary maintainer handle or email.\n16: #\n17: # TASK FILE SCHEMA (<task-id>.yml):\n18: #   Each task file is a plain YAML mapping with these fields:\n19: #\n20: #   id          : string        — Unique kebab-case identifier (1-128 chars).\n21: #   title       : string        — Human-readable short name.\n22: #   description : string        — Detailed explanation of the task's goal.\n23: #   status      : enum          — backlog | planned | in_progress | blocked |\n24: #                                  in_review | done | cancelled\n25: #   completion  : integer       — Percentage 0-100.\n26: #   difficulty  : enum          — trivial | easy | medium | hard | very_hard\n27: #   priority    : enum          — critical | high | medium | low | wishlist\n28: #   depends_on  : list[string]  — IDs of tasks that must complete first.\n29: #   effort      : string        — ISO 8601 duration (e.g. \"PT2H\", \"P1D\").\n30: #   started_at  : string|null   — ISO 8601 datetime or null.\n31: #   ended_at    : string|null   — ISO 8601 datetime or null.\n32: #   constraints : list[string]  — Technical or process constraints.\n33: #   forbidden   : list[string]  — Explicitly forbidden approaches.\n34: #   references  : list[string]  — URLs or file paths for relevant docs.\n35: #   notes       : list[string]  — Free-form updates (newest first).\n36: #   subtasks    : list[task]    — Always [] in folder-based storage (legacy).\n37: #   agent_type  : string|null   — Optional agent type from registry.\n38: #\n39: # =============================================================================\n40: \n41: version: \"1.0\"\n42: \n43: meta:\n44:   created_at: \"{{created_at}}\"\n45:   updated_at: \"{{updated_at}}\"\n46:   project: \"{{project}}\"\n47:   generator: \"wombo-combo\"\n48:   maintainer: \"{{maintainer}}\"\n\n(End of file - total 48 lines)\n</content>","title":"src/templates/_meta.yml","metadata":{"preview":"# =============================================================================\n# WOMBO COMBO! — Task Store Metadata (_meta.yml)\n# =============================================================================\n#\n# This file lives at: .wombo-combo/<tasks|archive>/_meta.yml\n# Sibling files: one <task-id>.yml per task (see TASK SCHEMA below).\n#\n# REQUIRED FIELDS:\n#   version    : string — Schema version (currently \"1.0\").\n#   meta       : object — Metadata about this task store.\n#     created_at  : string — ISO 8601 datetime when the store was created.\n#     updated_at  : string — ISO 8601 datetime, auto-updated on every write.\n#     project     : string — Project name.\n#     generator   : string — Tool that created this file (always \"wombo-combo\").\n#     maintainer  : string — Primary maintainer handle or email.\n#\n# TASK FILE SCHEMA (<task-id>.yml):\n#   Each task file is a plain YAML mapping with these fields:\n#\n#   id          : string        — Unique kebab-case identifier (1-128 chars).","truncated":false,"loaded":[]},"time":{"start":1773435233210,"end":1773435233213}}}}
