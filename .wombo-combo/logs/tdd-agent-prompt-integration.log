status\": \"pending\"\n  },\n  {\n    \"content\": \"Add TDD validation to validateConfig in src/config.ts\",\n    \"priority\": \"low\",\n    \"status\": \"completed\"\n  },\n  {\n    \"content\": \"Run typecheck and build to verify\",\n    \"priority\": \"high\",\n    \"status\": \"pending\"\n  }\n]","title":"5 todos","metadata":{"todos":[{"content":"Add TDD config type to WomboConfig interface and DEFAULT_CONFIG in src/config.ts","priority":"high","status":"completed"},{"content":"Add TDD section to generalist-agent.md template with red-green-refactor workflow","priority":"high","status":"in_progress"},{"content":"Add TDD block injection logic in src/lib/templates.ts (renderGeneralistAgent + patchImportedAgent)","priority":"high","status":"pending"},{"content":"Add TDD section to wc-patch.body.end.md for imported agents","priority":"medium","status":"pending"},{"content":"Add TDD config prompt to init.ts setup wizard","priority":"medium","status":"pending"},{"content":"Add TDD validation to validateConfig in src/config.ts","priority":"low","status":"completed"},{"content":"Run typecheck and build to verify","priority":"high","status":"pending"}],"truncated":false},"time":{"start":1773435288665,"end":1773435288666}}}}
