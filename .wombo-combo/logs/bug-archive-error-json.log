{"type":"tool_use","timestamp":1773433280469,"sessionID":"ses_31723c478ffe7uxAauRAAXY9ho","part":{"id":"prt_ce8dc55ad001ehIN7NBnwYB0kg","sessionID":"ses_31723c478ffe7uxAauRAAXY9ho","messageID":"msg_ce8dc3d750018N11rXTZwAhqXN","type":"tool","callID":"toolu_vrtx_01FYB4yEfM4jiToMas8Ju6Ng","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-bug-archive-error-json/src/commands/tasks/archive.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-bug-archive-error-json/src/commands/tasks/archive.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tasks/archive.ts — Move done/cancelled tasks to the archive section.\n3:  *\n4:  * Usage:\n5:  *   woco tasks archive              # archive all done + cancelled\n6:  *   woco tasks archive <task-id>    # archive a specific task\n7:  *   woco tasks archive --dry-run    # show what would be archived\n8:  */\n9: \n10: import type { WomboConfig } from \"../../config.js\";\n11: import {\n12:   loadFeatures,\n13:   saveFeatures,\n14:   findFeatureById,\n15:   type Feature,\n16: } from \"../../lib/tasks.js\";\n17: import { outputError, outputMessage, type OutputFormat } from \"../../lib/output.js\";\n18: \n19: // ---------------------------------------------------------------------------\n20: // Types\n21: // ---------------------------------------------------------------------------\n22: \n23: export interface TasksArchiveOptions {\n24:   projectRoot: string;\n25:   config: WomboConfig;\n26:   featureId?: string;\n27:   dryRun?: boolean;\n28:   outputFmt?: OutputFormat;\n29: }\n30: \n31: // ---------------------------------------------------------------------------\n32: // Command\n33: // ---------------------------------------------------------------------------\n34: \n35: export async function cmdTasksArchive(opts: TasksArchiveOptions): Promise<void> {\n36:   const { projectRoot, config } = opts;\n37:   const fmt = opts.outputFmt ?? \"text\";\n38: \n39:   const data = loadFeatures(projectRoot, config);\n40: \n41:   // Ensure archive array exists\n42:   if (!data.archive) {\n43:     data.archive = [];\n44:   }\n45: \n46:   let toArchive: Feature[];\n47: \n48:   if (opts.featureId) {\n49:     // Archive a specific feature\n50:     const idx = data.tasks.findIndex((f: Feature) => f.id === opts.featureId);\n51:     if (idx === -1) {\n52:       // Check if already in archive\n53:       if (data.archive.find((f) => f.id === opts.featureId)) {\n54:         outputMessage(fmt, `Task \"${opts.featureId}\" is already in the archive.`, {\n55:           already_archived: true,\n56:           id: opts.featureId,\n57:         });\n58:         return;\n59:       }\n60:       outputError(fmt, `Task \"${opts.featureId}\" not found.`);\n61:       return;\n62:     }\n63:     toArchive = [data.tasks[idx]];\n64:   } else {\n65:     // Archive all done + cancelled features\n66:     toArchive = data.tasks.filter(\n67:       (f: Feature) => f.status === \"done\" || f.status === \"cancelled\"\n68:     );\n69:   }\n70: \n71:   if (toArchive.length === 0) {\n72:     outputMessage(fmt, \"No tasks to archive.\", { count: 0 });\n73:     return;\n74:   }\n75: \n76:   if (opts.dryRun) {\n77:     outputMessage(fmt, `Would archive ${toArchive.length} task(s)`, {\n78:       dry_run: true,\n79:       count: toArchive.length,\n80:       features: toArchive.map((f) => ({ id: f.id, title: f.title, status: f.status })),\n81:     });\n82:     if (fmt === \"text\") {\n83:       console.log(\"\");\n84:       for (const f of toArchive) {\n85:         console.log(`  ${f.id} — ${f.title} (${f.status})`);\n86:       }\n87:     }\n88:     return;\n89:   }\n90: \n91:   // Move features from active to archive\n92:   const archiveIds = new Set(toArchive.map((f) => f.id));\n93:   data.tasks = data.tasks.filter((f: Feature) => !archiveIds.has(f.id));\n94:   data.archive.push(...toArchive);\n95: \n96:   saveFeatures(projectRoot, config, data);\n97: \n98:   outputMessage(fmt, `Archived ${toArchive.length} task(s)`, {\n99:     count: toArchive.length,\n100:     features: toArchive.map((f) => ({ id: f.id, title: f.title, status: f.status })),\n101:   });\n102:   if (fmt === \"text\") {\n103:     for (const f of toArchive) {\n104:       console.log(`  ${f.id} — ${f.title} (${f.status})`);\n105:     }\n106:   }\n107: }\n\n(End of file - total 107 lines)\n</content>","title":"src/commands/tasks/archive.ts","metadata":{"preview":"/**\n * tasks/archive.ts — Move done/cancelled tasks to the archive section.\n *\n * Usage:\n *   woco tasks archive              # archive all done + cancelled\n *   woco tasks archive <task-id>    # archive a specific task\n *   woco tasks archive --dry-run    # show what would be archived\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  saveFeatures,\n  findFeatureById,\n  type Feature,\n} from \"../../lib/tasks.js\";\nimport { outputError, outputMessage, type OutputFormat } from \"../../lib/output.js\";\n\n// ---------------------------------------------------------------------------\n// Types","truncated":false,"loaded":[]},"time":{"start":1773433280445,"end":1773433280466}}}}
{"type":"text","timestamp":1773433280871,"sessionID":"ses_31723c478ffe7uxAauRAAXY9ho","part":{"id":"prt_ce8dc4f49001COOKjDu2wQoLh0","sessionID":"ses_31723c478ffe7uxAauRAAXY9ho","messageID":"msg_ce8dc3d750018N11rXTZwAhqXN","type":"text","text":"\n\nI'll start by reading the AGENTS.md and exploring the relevant code files to understand the codebase before implementing the fix.","time":{"start":1773433280866,"end":1773433280866}}}
{"type":"tool_use","timestamp":1773433280918,"sessionID":"ses_31723c478ffe7uxAauRAAXY9ho","part":{"id":"prt_ce8dc57c1001yBba91iELHV3N9","sessionID":"ses_31723c478ffe7uxAauRAAXY9ho","messageID":"msg_ce8dc3d750018N11rXTZwAhqXN","type":"tool","callID":"toolu_vrtx_01A8GgQzkpTUxXEUZmivzVz2","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-bug-archive-error-json/src/lib/output.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-bug-archive-error-json/src/lib/output.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * output.ts — Shared output helpers for agent-ready CLI.\n3:  *\n4:  * Provides a centralized way for commands to emit structured data that\n5:  * renders as human-readable text on TTY or as JSON when --output json\n6:  * is specified (or when stdout is not a TTY).\n7:  *\n8:  * Usage in commands:\n9:  *   import { output, OutputFormat } from \"../lib/output.js\";\n10:  *\n11:  *   // At the end of a command:\n12:  *   output(format, data);           // emits JSON or human text\n13:  *   outputError(format, message);   // emits error in the right format\n14:  */\n15: \n16: // ---------------------------------------------------------------------------\n17: // Types\n18: // ---------------------------------------------------------------------------\n19: \n20: export type OutputFormat = \"text\" | \"json\";\n21: \n22: // ---------------------------------------------------------------------------\n23: // Helpers\n24: // ---------------------------------------------------------------------------\n25: \n26: /**\n27:  * Determine the output format. Priority:\n28:  *   1. Explicit --output flag value\n29:  *   2. WOMBO_OUTPUT env var (for agent pipelines)\n30:  *   3. Default to \"text\"\n31:  *\n32:  * Note: We intentionally do NOT auto-detect based on TTY. Many legitimate\n33:  * use cases (bun dev, piped to less/grep, CI) have non-TTY stdout but still\n34:  * want human output. Agents should explicitly pass --output json or set\n35:  * WOMBO_OUTPUT=json.\n36:  */\n37: export function resolveOutputFormat(explicit?: string): OutputFormat {\n38:   if (explicit === \"json\") return \"json\";\n39:   if (explicit === \"text\") return \"text\";\n40:   // Check env var for agent pipelines\n41:   const env = process.env.WOMBO_OUTPUT;\n42:   if (env === \"json\") return \"json\";\n43:   return \"text\";\n44: }\n45: \n46: /**\n47:  * Emit structured data. In JSON mode, outputs a single JSON line to stdout.\n48:  * In text mode, calls the provided textRenderer callback.\n49:  */\n50: export function output(\n51:   format: OutputFormat,\n52:   data: unknown,\n53:   textRenderer: () => void\n54: ): void {\n55:   if (format === \"json\") {\n56:     console.log(JSON.stringify(data));\n57:   } else {\n58:     textRenderer();\n59:   }\n60: }\n61: \n62: /**\n63:  * Emit an error. In JSON mode, outputs {\"error\": message} to stderr.\n64:  * In text mode, outputs the message to stderr normally.\n65:  */\n66: export function outputError(format: OutputFormat, message: string, exitCode: number = 1): never {\n67:   if (format === \"json\") {\n68:     console.error(JSON.stringify({ error: message }));\n69:   } else {\n70:     console.error(message);\n71:   }\n72:   process.exit(exitCode);\n73: }\n74: \n75: /**\n76:  * Emit a success/info message. In JSON mode, outputs {\"message\": msg, ...extra}.\n77:  * In text mode, outputs the message to stdout normally.\n78:  */\n79: export function outputMessage(\n80:   format: OutputFormat,\n81:   message: string,\n82:   extra?: Record<string, unknown>\n83: ): void {\n84:   if (format === \"json\") {\n85:     console.log(JSON.stringify({ message, ...extra }));\n86:   } else {\n87:     console.log(message);\n88:   }\n89: }\n90: \n91: // ---------------------------------------------------------------------------\n92: // Field filtering for compact output (--fields)\n93: // ---------------------------------------------------------------------------\n94: \n95: /**\n96:  * Filter an object to only include the specified fields.\n97:  * If fields is undefined/empty, returns the object unchanged.\n98:  */\n99: export function filterFields<T extends Record<string, unknown>>(\n100:   obj: T,\n101:   fields?: string[]\n102: ): Partial<T> {\n103:   if (!fields || fields.length === 0) return obj;\n104:   const result: Partial<T> = {};\n105:   for (const field of fields) {\n106:     if (field in obj) {\n107:       (result as any)[field] = (obj as any)[field];\n108:     }\n109:   }\n110:   return result;\n111: }\n112: \n113: /**\n114:  * Filter an array of objects to only include specified fields per object.\n115:  * If fields is undefined/empty, returns the array unchanged.\n116:  */\n117: export function filterFieldsArray<T extends Record<string, unknown>>(\n118:   arr: T[],\n119:   fields?: string[]\n120: ): Partial<T>[] {\n121:   if (!fields || fields.length === 0) return arr;\n122:   return arr.map((obj) => filterFields(obj, fields));\n123: }\n124: \n125: /**\n126:  * Render a compact text table from an array of objects with selected fields.\n127:  * Used for text-mode --fields output.\n128:  */\n129: export function renderCompactTable(\n130:   items: Record<string, unknown>[],\n131:   fields: string[]\n132: ): void {\n133:   if (items.length === 0) return;\n134: \n135:   // Calculate column widths\n136:   const widths: Record<string, number> = {};\n137:   for (const field of fields) {\n138:     widths[field] = field.length;\n139:     for (const item of items) {\n140:       const val = String(item[field] ?? \"\");\n141:       widths[field] = Math.max(widths[field], val.length);\n142:     }\n143:   }\n144: \n145:   // Header\n146:   const header = fields.map((f) => f.padEnd(widths[f])).join(\"  \");\n147:   console.log(header);\n148:   console.log(fields.map((f) => \"─\".repeat(widths[f])).join(\"  \"));\n149: \n150:   // Rows\n151:   for (const item of items) {\n152:     const row = fields.map((f) => String(item[f] ?? \"\").padEnd(widths[f])).join(\"  \");\n153:     console.log(row);\n154:   }\n155: }\n\n(End of file - total 155 lines)\n</content>","title":"src/lib/output.ts","metadata":{"preview":"/**\n * output.ts — Shared output helpers for agent-ready CLI.\n *\n * Provides a centralized way for commands to emit structured data that\n * renders as human-readable text on TTY or as JSON when --output json\n * is specified (or when stdout is not a TTY).\n *\n * Usage in commands:\n *   import { output, OutputFormat } from \"../lib/output.js\";\n *\n *   // At the end of a command:\n *   output(format, data);           // emits JSON or human text\n *   outputError(format, message);   // emits error in the right format\n */\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type OutputFormat = \"text\" | \"json\";","truncated":false,"loaded":[]},"time":{"start":1773433280855,"end":1773433280913}}}}
