{"type":"tool_use","timestamp":1773433286796,"sessionID":"ses_31723c478ffe7uxAauRAAXY9ho","part":{"id":"prt_ce8dc6b09001N8IUC7EyvBUgZt","sessionID":"ses_31723c478ffe7uxAauRAAXY9ho","messageID":"msg_ce8dc5b13001fpujdvcGLyUwWZ","type":"tool","callID":"toolu_vrtx_01AF1yJZqmUCJTVPsdSiBEyy","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-bug-archive-error-json/src/lib/tasks.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-bug-archive-error-json/src/lib/tasks.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tasks.ts -- Parse tasks YAML and provide task selection/filtering.\n3:  *\n4:  * Responsibilities:\n5:  *   - Load and parse the tasks file with full type safety\n6:  *   - Load and parse the archive file separately\n7:  *   - Parse ISO 8601 durations into comparable minutes\n8:  *   - Filter tasks by status, priority, difficulty, dependency readiness\n9:  *   - Select tasks by various strategies (top-priority, quickest-wins, etc.)\n10:  *   - Resolve dependency graphs to determine which tasks are ready to start\n11:  *   - Write-back capability for task management commands\n12:  */\n13: \n14: import { existsSync, mkdirSync } from \"node:fs\";\n15: import { resolve, dirname, join } from \"node:path\";\n16: import { createInterface } from \"node:readline\";\n17: import type { WomboConfig } from \"../config.js\";\n18: import { WOMBO_DIR } from \"../config.js\";\n19: import {\n20:   loadTasksFromStore,\n21:   loadArchiveFromStore,\n22:   saveAllTasksToStore,\n23:   saveAllArchiveToStore,\n24:   saveTaskToStore,\n25:   saveTaskToArchive,\n26:   removeTaskFromStore,\n27:   tasksStoreExists,\n28:   saveTasksMetaToStore,\n29:   saveArchiveMetaToStore,\n30:   getTasksDir,\n31:   getArchiveDir,\n32:   saveTaskFile,\n33:   deleteTaskFile,\n34: } from \"./task-store.js\";\n35: \n36: // ---------------------------------------------------------------------------\n37: // Template path (resolved relative to this source file)\n38: // ---------------------------------------------------------------------------\n39: \n40: export const META_TEMPLATE_PATH = join(dirname(import.meta.dir), \"templates\", \"_meta.yml\");\n41: /** @deprecated Use META_TEMPLATE_PATH — the old monolithic template no longer exists. */\n42: export const TASKS_TEMPLATE_PATH = META_TEMPLATE_PATH;\n43: \n44: // ---------------------------------------------------------------------------\n45: // Types\n46: // ---------------------------------------------------------------------------\n47: \n48: export type TaskStatus =\n49:   | \"backlog\"\n50:   | \"planned\"\n51:   | \"in_progress\"\n52:   | \"blocked\"\n53:   | \"in_review\"\n54:   | \"done\"\n55:   | \"cancelled\";\n56: \n57: export type Priority = \"critical\" | \"high\" | \"medium\" | \"low\" | \"wishlist\";\n58: \n59: export type Difficulty = \"trivial\" | \"easy\" | \"medium\" | \"hard\" | \"very_hard\";\n60: \n61: /**\n62:  * Unified task type. Previously split into Feature and Subtask, but the shapes\n63:  * are identical so there is no reason to maintain two names.\n64:  */\n65: export interface Task {\n66:   id: string;\n67:   title: string;\n68:   description: string;\n69:   status: TaskStatus;\n70:   completion: number;\n71:   difficulty: Difficulty;\n72:   priority: Priority;\n73:   depends_on: string[];\n74:   effort: string;\n75:   started_at: string | null;\n76:   ended_at: string | null;\n77:   constraints: string[];\n78:   forbidden: string[];\n79:   references: string[];\n80:   notes: string[];\n81:   subtasks: Task[];\n82:   /**\n83:    * Optional agent type from an external registry (e.g. agency-agents).\n84:    * Format: \"category/agent-name\" (e.g. \"engineering/engineering-frontend-developer\").\n85:    * When set, wombo downloads and patches the specified agent definition\n86:    * instead of using the default generalist agent.\n87:    */\n88:   agent_type?: string;\n89: }\n90: \n91: /**\n92:  * Shape of tasks.yml (active tasks).\n93:  */\n94: export interface TasksFile {\n95:   version: string;\n96:   meta: {\n97:     created_at: string;\n98:     updated_at: string;\n99:     project: string;\n100:     generator: string;\n101:     maintainer: string;\n102:   };\n103:   tasks: Task[];\n104: }\n105: \n106: /**\n107:  * Shape of archive.yml (archived tasks). Same structure as TasksFile.\n108:  */\n109: export type ArchiveFile = TasksFile;\n110: \n111: // Backward-compat aliases (ease migration in consuming code)\n112: export type Feature = Task;\n113: export type Subtask = Task;\n114: export type FeatureStatus = TaskStatus;\n115: export type FeaturesFile = TasksFile & { archive: Task[] };\n116: \n117: // Re-export ordering maps from the canonical source (task-schema.ts)\n118: import { PRIORITY_ORDER, DIFFICULTY_ORDER } from \"./task-schema.js\";\n119: export { PRIORITY_ORDER, DIFFICULTY_ORDER };\n120: \n121: // ---------------------------------------------------------------------------\n122: // ISO 8601 Duration Parser\n123: // ---------------------------------------------------------------------------\n124: \n125: /**\n126:  * Parse an ISO 8601 duration string into total minutes.\n127:  * Supports: P[nY][nM][nD][T[nH][nM][nS]]\n128:  * Examples: PT1H -> 60, PT30M -> 30, P1D -> 1440, P2DT4H -> 3360, PT1H30M -> 90\n129:  *           P1Y -> 525600, P2M -> 86400\n130:  * Year/month approximations: 1Y = 365D, 1M = 30D\n131:  */\n132: export function parseDurationMinutes(iso: string): number {\n133:   const match = iso.match(\n134:     /^P(?:(\\d+)Y)?(?:(\\d+)M)?(?:(\\d+)D)?(?:T(?:(\\d+)H)?(?:(\\d+)M)?(?:(\\d+)S)?)?$/\n135:   );\n136:   if (!match) return Infinity; // unparseable -> sort to end\n137:   const years = parseInt(match[1] || \"0\", 10);\n138:   const months = parseInt(match[2] || \"0\", 10);\n139:   const days = parseInt(match[3] || \"0\", 10);\n140:   const hours = parseInt(match[4] || \"0\", 10);\n141:   const minutes = parseInt(match[5] || \"0\", 10);\n142:   const seconds = parseInt(match[6] || \"0\", 10);\n143:   const totalDays = years * 365 + months * 30 + days;\n144:   return totalDays * 24 * 60 + hours * 60 + minutes + Math.ceil(seconds / 60);\n145: }\n146: \n147: /**\n148:  * Format minutes into a human-readable string.\n149:  */\n150: export function formatDuration(minutes: number): string {\n151:   if (minutes === Infinity) return \"unknown\";\n152:   if (minutes < 60) return `${minutes}m`;\n153:   const h = Math.floor(minutes / 60);\n154:   const m = minutes % 60;\n155:   if (h >= 24) {\n156:     const d = Math.floor(h / 24);\n157:     const rh = h % 24;\n158:     if (rh === 0 && m === 0) return `${d}d`;\n159:     if (m === 0) return `${d}d ${rh}h`;\n160:     return `${d}d ${rh}h ${m}m`;\n161:   }\n162:   return m === 0 ? `${h}h` : `${h}h ${m}m`;\n163: }\n164: \n165: // ---------------------------------------------------------------------------\n166: // .wombo-combo directory helpers\n167: // ---------------------------------------------------------------------------\n168: \n169: /**\n170:  * Ensure the .wombo-combo directory exists.\n171:  */\n172: export function ensureWomboDir(projectRoot: string): string {\n173:   const dir = resolve(projectRoot, WOMBO_DIR);\n174:   if (!existsSync(dir)) {\n175:     mkdirSync(dir, { recursive: true });\n176:   }\n177:   return dir;\n178: }\n179: \n180: /**\n181:  * Resolve a file path within the .wombo-combo directory.\n182:  */\n183: function womboPath(projectRoot: string, filename: string): string {\n184:   return resolve(projectRoot, WOMBO_DIR, filename);\n185: }\n186: \n187: // ---------------------------------------------------------------------------\n188: // Tasks File Existence Guard\n189: // ---------------------------------------------------------------------------\n190: \n191: /**\n192:  * Prompt the user with a yes/no question via stdin.\n193:  */\n194: function promptYesNo(question: string): Promise<boolean> {\n195:   const rl = createInterface({ input: process.stdin, output: process.stdout });\n196:   return new Promise((resolve) => {\n197:     rl.question(question, (answer) => {\n198:       rl.close();\n199:       resolve(answer.trim().toLowerCase().startsWith(\"y\"));\n200:     });\n201:   });\n202: }\n203: \n204: /**\n205:  * Ensure the tasks store exists before any command that needs it.\n206:  * If the folder is missing, prompt the user to generate one from scratch\n207:  * or auto-migrate from a legacy single-file tasks.yml.\n208:  */\n209: export async function ensureTasksFile(\n210:   projectRoot: string,\n211:   config: WomboConfig\n212: ): Promise<void> {\n213:   if (tasksStoreExists(projectRoot, config)) return;\n214: \n215:   // Try loading — this triggers auto-migration from legacy files\n216:   const data = loadTasksFromStore(projectRoot, config);\n217:   if (data.tasks.length > 0 || tasksStoreExists(projectRoot, config)) return;\n218: \n219:   console.log(`\\nTasks store not found: ${WOMBO_DIR}/${config.tasksDir}/`);\n220: \n221:   const generate = await promptYesNo(\n222:     \"Generate a new tasks store from template? (y/N): \"\n223:   );\n224: \n225:   if (!generate) {\n226:     console.error(\n227:       `Cannot proceed without a tasks store. Create one manually or run again and accept the prompt.`\n228:     );\n229:     process.exit(1);\n230:   }\n231: \n232:   // Ensure .wombo-combo/ directory exists\n233:   ensureWomboDir(projectRoot);\n234: \n235:   const now = new Date().toISOString();\n236:   saveTasksMetaToStore(projectRoot, config, {\n237:     version: \"1.0\",\n238:     meta: {\n239:       created_at: now,\n240:       updated_at: now,\n241:       project: \"unknown\",\n242:       generator: \"wombo-combo\",\n243:       maintainer: \"unknown\",\n244:     },\n245:   });\n246:   console.log(`Created ${WOMBO_DIR}/${config.tasksDir}/ with empty task store.\\n`);\n247: \n248:   // Also create empty archive store\n249:   saveArchiveMetaToStore(projectRoot, config, {\n250:     version: \"1.0\",\n251:     meta: {\n252:       created_at: now,\n253:       updated_at: now,\n254:       project: \"unknown\",\n255:       generator: \"wombo-combo\",\n256:       maintainer: \"unknown\",\n257:     },\n258:   });\n259:   console.log(`Created ${WOMBO_DIR}/${config.archiveDir}/.\\n`);\n260: }\n261: \n262: // Backward-compat alias\n263: export const ensureFeaturesFile = ensureTasksFile;\n264: \n265: // ---------------------------------------------------------------------------\n266: // Loader\n267: // ---------------------------------------------------------------------------\n268: \n269: /**\n270:  * Load and parse tasks from the folder-based store.\n271:  */\n272: export function loadTasks(\n273:   projectRoot: string,\n274:   config: WomboConfig\n275: ): TasksFile {\n276:   return loadTasksFromStore(projectRoot, config);\n277: }\n278: \n279: /**\n280:  * Load archived tasks from the folder-based store.\n281:  * Returns an empty ArchiveFile if the store doesn't exist.\n282:  */\n283: export function loadArchive(\n284:   projectRoot: string,\n285:   config: WomboConfig\n286: ): ArchiveFile {\n287:   return loadArchiveFromStore(projectRoot, config);\n288: }\n289: \n290: /**\n291:  * Backward-compat: load tasks + archive merged into a single FeaturesFile shape.\n292:  * This eases migration — callers that used loadFeatures() keep working.\n293:  */\n294: export function loadFeatures(\n295:   projectRoot: string,\n296:   config: WomboConfig\n297: ): FeaturesFile {\n298:   const tasksData = loadTasks(projectRoot, config);\n299:   const archiveData = loadArchive(projectRoot, config);\n300:   return {\n301:     ...tasksData,\n302:     // Map \"tasks\" to \"features\" for backward compat (FeaturesFile has .features)\n303:     // Actually FeaturesFile extends TasksFile which has .tasks, but add .archive\n304:     archive: archiveData.tasks,\n305:   };\n306: }\n307: \n308: // ---------------------------------------------------------------------------\n309: // Writer\n310: // ---------------------------------------------------------------------------\n311: \n312: /**\n313:  * Save all tasks to the folder-based store.\n314:  * Writes _meta.yml + one file per task.\n315:  */\n316: export function saveTasks(\n317:   projectRoot: string,\n318:   config: WomboConfig,\n319:   data: TasksFile\n320: ): void {\n321:   saveAllTasksToStore(projectRoot, config, data);\n322: }\n323: \n324: /**\n325:  * Save all archived tasks to the folder-based store.\n326:  */\n327: export function saveArchive(\n328:   projectRoot: string,\n329:   config: WomboConfig,\n330:   data: ArchiveFile\n331: ): void {\n332:   saveAllArchiveToStore(projectRoot, config, data);\n333: }\n334: \n335: /**\n336:  * Backward-compat: save a FeaturesFile (tasks + archive in one object).\n337:  * Splits and writes to both tasks.yml and archive.yml.\n338:  */\n339: export function saveFeatures(\n340:   projectRoot: string,\n341:   config: WomboConfig,\n342:   data: FeaturesFile\n343: ): void {\n344:   const tasksData: TasksFile = {\n345:     version: data.version,\n346:     meta: { ...data.meta },\n347:     tasks: data.tasks,\n348:   };\n349:   saveTasks(projectRoot, config, tasksData);\n350: \n351:   if (data.archive && data.archive.length > 0) {\n352:     const archiveData: ArchiveFile = {\n353:       version: data.version,\n354:       meta: { ...data.meta },\n355:       tasks: data.archive,\n356:     };\n357:     saveArchive(projectRoot, config, archiveData);\n358:   }\n359: }\n360: \n361: \n362: // ---------------------------------------------------------------------------\n363: // Dependency Resolution\n364: // ---------------------------------------------------------------------------\n365: \n366: /**\n367:  * Get all task IDs that are done (status === \"done\" or completion === 100).\n368:  */\n369: function getDoneIds(tasks: Task[], archive: Task[]): Set<string> {\n370:   const done = new Set<string>();\n371:   const collectDone = (items: Task[]) => {\n372:     for (const item of items) {\n373:       if (item.status === \"done\" || item.completion === 100) {\n374:         done.add(item.id);\n375:       }\n376:       if (item.subtasks?.length) {\n377:         collectDone(item.subtasks);\n378:       }\n379:     }\n380:   };\n381:   collectDone(tasks);\n382:   collectDone(archive);\n383:   return done;\n384: }\n385: \n386: /**\n387:  * Check if a task's dependencies are all satisfied.\n388:  */\n389: export function areDependenciesMet(\n390:   task: Task,\n391:   doneIds: Set<string>\n392: ): boolean {\n393:   return task.depends_on.every((dep) => doneIds.has(dep));\n394: }\n395: \n396: /**\n397:  * Get all tasks that are ready to start (backlog + deps met).\n398:  */\n399: export function getReadyTasks(data: TasksFile, archive?: Task[]): Task[] {\n400:   const doneIds = getDoneIds(data.tasks, archive ?? []);\n401:   return data.tasks.filter(\n402:     (t) =>\n403:       t.status === \"backlog\" &&\n404:       t.completion === 0 &&\n405:       areDependenciesMet(t, doneIds)\n406:   );\n407: }\n408: \n409: /**\n410:  * Get done IDs (exported for use in selection error messages).\n411:  */\n412: export function getDoneTaskIds(data: TasksFile, archive?: Task[]): Set<string> {\n413:   return getDoneIds(data.tasks, archive ?? []);\n414: }\n415: \n416: // Backward-compat aliases\n417: export function getReadyFeatures(data: FeaturesFile): Task[] {\n418:   return getReadyTasks(data, data.archive);\n419: }\n420: \n421: export function getDoneFeatureIds(data: FeaturesFile): Set<string> {\n422:   return getDoneTaskIds(data, data.archive);\n423: }\n424: \n425: // ---------------------------------------------------------------------------\n426: // Selection Strategies\n427: // ---------------------------------------------------------------------------\n428: \n429: export interface SelectionOptions {\n430:   /** Select top N by priority (highest priority first, then lowest effort) */\n431:   topPriority?: number;\n432:   /** Select N quickest wins (lowest effort first) */\n433:   quickestWins?: number;\n434:   /** Select all tasks matching this priority level */\n435:   priority?: Priority;\n436:   /** Select all tasks matching this difficulty level */\n437:   difficulty?: Difficulty;\n438:   /** Select specific task IDs (comma-separated) */\n439:   taskIds?: string[];\n440:   /** Select all ready tasks */\n441:   allReady?: boolean;\n442: }\n443: \n444: /**\n445:  * Select tasks based on the given strategy.\n446:  * Always filters to only ready tasks (backlog + deps met) first.\n447:  */\n448: export function selectTasks(\n449:   data: TasksFile,\n450:   options: SelectionOptions,\n451:   archive?: Task[]\n452: ): Task[] {\n453:   const ready = getReadyTasks(data, archive);\n454: \n455:   if (options.allReady) {\n456:     return sortByPriorityThenEffort(ready);\n457:   }\n458: \n459:   if (options.taskIds?.length) {\n460:     const idSet = new Set(options.taskIds);\n461:     const selected = ready.filter((t) => idSet.has(t.id));\n462:     const missing = options.taskIds.filter(\n463:       (id) => !selected.find((t) => t.id === id)\n464:     );\n465:     if (missing.length) {\n466:       const allIds = data.tasks.map((t) => t.id);\n467:       const doneIds = getDoneIds(data.tasks, archive ?? []);\n468:       for (const m of missing) {\n469:         if (!allIds.includes(m)) {\n470:           console.error(`  Task \"${m}\" does not exist in the tasks file`);\n471:         } else {\n472:           const task = data.tasks.find((t) => t.id === m)!;\n473:           console.error(\n474:             `  Task \"${m}\" is not ready (status: ${task.status}, deps met: ${areDependenciesMet(task, doneIds)})`\n475:           );\n476:         }\n477:       }\n478:     }\n479:     return sortByPriorityThenEffort(selected);\n480:   }\n481: \n482:   if (options.priority) {\n483:     return sortByPriorityThenEffort(\n484:       ready.filter((t) => t.priority === options.priority)\n485:     );\n486:   }\n487: \n488:   if (options.difficulty) {\n489:     return sortByEffort(ready.filter((t) => t.difficulty === options.difficulty));\n490:   }\n491: \n492:   if (options.topPriority) {\n493:     return sortByPriorityThenEffort(ready).slice(0, options.topPriority);\n494:   }\n495: \n496:   if (options.quickestWins) {\n497:     return sortByEffort(ready).slice(0, options.quickestWins);\n498:   }\n499: \n500:   // Default: return all ready, sorted by priority\n501:   return sortByPriorityThenEffort(ready);\n502: }\n503: \n504: // Backward-compat alias\n505: export function selectFeatures(\n506:   data: FeaturesFile,\n507:   options: SelectionOptions & { featureIds?: string[] }\n508: ): Task[] {\n509:   // Map featureIds -> taskIds for backward compat\n510:   const opts: SelectionOptions = {\n511:     ...options,\n512:     taskIds: options.taskIds ?? options.featureIds,\n513:   };\n514:   return selectTasks(data, opts, data.archive);\n515: }\n516: \n517: // ---------------------------------------------------------------------------\n518: // Sorting Helpers\n519: // ---------------------------------------------------------------------------\n520: \n521: function sortByPriorityThenEffort(tasks: Task[]): Task[] {\n522:   return [...tasks].sort((a, b) => {\n523:     const pDiff = PRIORITY_ORDER[a.priority] - PRIORITY_ORDER[b.priority];\n524:     if (pDiff !== 0) return pDiff;\n525:     return parseDurationMinutes(a.effort) - parseDurationMinutes(b.effort);\n526:   });\n527: }\n528: \n529: function sortByEffort(tasks: Task[]): Task[] {\n530:   return [...tasks].sort(\n531:     (a, b) => parseDurationMinutes(a.effort) - parseDurationMinutes(b.effort)\n532:   );\n533: }\n534: \n535: // ---------------------------------------------------------------------------\n536: // Utility Exports\n537: // ---------------------------------------------------------------------------\n538: \n539: /**\n540:  * Get a compact summary of a task for display.\n541:  */\n542: export function taskSummary(t: Task): string {\n543:   const effort = formatDuration(parseDurationMinutes(t.effort));\n544:   return `[${t.priority}/${t.difficulty}] ${t.id} -- ${t.title} (${effort})`;\n545: }\n546: \n547: // Backward-compat alias\n548: export const featureSummary = taskSummary;\n549: \n550: /**\n551:  * Recursively search a list of tasks (and their subtasks) for a matching ID.\n552:  */\n553: function findInList(tasks: Task[], id: string): Task | undefined {\n554:   for (const t of tasks) {\n555:     if (t.id === id) return t;\n556:     if (t.subtasks?.length) {\n557:       const found = findInList(t.subtasks, id);\n558:       if (found) return found;\n559:     }\n560:   }\n561:   return undefined;\n562: }\n563: \n564: /**\n565:  * Find a task by ID across active tasks, their subtasks\n566:  * (recursively), and the archive list.\n567:  */\n568: export function findTaskById(\n569:   data: TasksFile,\n570:   id: string,\n571:   archive?: Task[]\n572: ): Task | undefined {\n573:   return (\n574:     findInList(data.tasks, id) ??\n575:     (archive ? findInList(archive, id) : undefined)\n576:   );\n577: }\n578: \n579: // Backward-compat alias\n580: export function findFeatureById(\n581:   data: FeaturesFile,\n582:   id: string\n583: ): Task | undefined {\n584:   return findTaskById(data, id, data.archive);\n585: }\n586: \n587: /**\n588:  * Create a blank task with all required fields initialized.\n589:  */\n590: export function createBlankTask(\n591:   id: string,\n592:   title: string,\n593:   description: string = \"\",\n594:   opts?: {\n595:     priority?: Priority;\n596:     difficulty?: Difficulty;\n597:     effort?: string;\n598:   }\n599: ): Task {\n600:   return {\n601:     id,\n602:     title,\n603:     description,\n604:     status: \"backlog\",\n605:     completion: 0,\n606:     difficulty: opts?.difficulty ?? \"medium\",\n607:     priority: opts?.priority ?? \"medium\",\n608:     depends_on: [],\n609:     effort: opts?.effort ?? \"PT1H\",\n610:     started_at: null,\n611:     ended_at: null,\n612:     constraints: [],\n613:     forbidden: [],\n614:     references: [],\n615:     notes: [],\n616:     subtasks: [],\n617:   };\n618: }\n619: \n620: // Backward-compat alias\n621: export const createBlankFeature = createBlankTask;\n622: \n623: /**\n624:  * Get all task IDs (active + archive), useful for validation.\n625:  */\n626: export function allTaskIds(data: TasksFile, archive?: Task[]): string[] {\n627:   const ids: string[] = [];\n628:   const collect = (items: Task[]) => {\n629:     for (const item of items) {\n630:       ids.push(item.id);\n631:       if (item.subtasks?.length) collect(item.subtasks);\n632:     }\n633:   };\n634:   collect(data.tasks);\n635:   collect(archive ?? []);\n636:   return ids;\n637: }\n638: \n639: // Backward-compat alias\n640: export function allFeatureIds(data: FeaturesFile): string[] {\n641:   return allTaskIds(data, data.archive);\n642: }\n643: \n644: // Re-export the old template path name for migration\n645: export const FEATURES_TEMPLATE_PATH = TASKS_TEMPLATE_PATH;\n646: \n647: // Re-export store functions for single-task operations\n648: export {\n649:   saveTaskToStore,\n650:   saveTaskToArchive,\n651:   removeTaskFromStore,\n652:   getTasksDir,\n653:   getArchiveDir,\n654: } from \"./task-store.js\";\n\n(End of file - total 654 lines)\n</content>","title":"src/lib/tasks.ts","metadata":{"preview":"/**\n * tasks.ts -- Parse tasks YAML and provide task selection/filtering.\n *\n * Responsibilities:\n *   - Load and parse the tasks file with full type safety\n *   - Load and parse the archive file separately\n *   - Parse ISO 8601 durations into comparable minutes\n *   - Filter tasks by status, priority, difficulty, dependency readiness\n *   - Select tasks by various strategies (top-priority, quickest-wins, etc.)\n *   - Resolve dependency graphs to determine which tasks are ready to start\n *   - Write-back capability for task management commands\n */\n\nimport { existsSync, mkdirSync } from \"node:fs\";\nimport { resolve, dirname, join } from \"node:path\";\nimport { createInterface } from \"node:readline\";\nimport type { WomboConfig } from \"../config.js\";\nimport { WOMBO_DIR } from \"../config.js\";\nimport {\n  loadTasksFromStore,","truncated":false,"loaded":[]},"time":{"start":1773433286707,"end":1773433286783}}}}
