tion: ${reason?.message || reason}`);\n  if (reason?.stack) console.error(reason.stack);\n  try {\n    const state = loadState(process.cwd());\n    if (state) saveState(process.cwd(), state);\n  } catch {}\n  process.exit(1);","truncated":false,"loaded":[]},"time":{"start":1773433393755,"end":1773433393764}}}}
