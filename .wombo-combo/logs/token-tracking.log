{"type":"tool_use","timestamp":1773484482703,"sessionID":"ses_31416915cffeaA1eCO5cj4ROyq","part":{"id":"prt_cebe99e23001R2FD1EP6fYCu34","sessionID":"ses_31416915cffeaA1eCO5cj4ROyq","messageID":"msg_cebe99502001sad4Cy4X1m97Mt","type":"tool","callID":"toolu_vrtx_015WavJyDiJHPQJGRrzXj3Go","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/token-tracking/src/lib/token-usage.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/token-tracking/src/lib/token-usage.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * token-usage.ts — Persist and aggregate token usage data.\n3:  *\n4:  * Responsibilities:\n5:  *   - Append UsageRecords to .wombo-combo/usage.jsonl (one JSON object per line)\n6:  *   - Load all records from the JSONL file\n7:  *   - Aggregate: groupBy(field), filterByDateRange(since, until), totalUsage()\n8:  *   - Create a UsageStore that wires into TokenCollector's onUsage callback\n9:  *\n10:  * The JSONL format is append-only and human-readable. Each line is a complete\n11:  * JSON object representing one UsageRecord (one step_finish event). This makes\n12:  * it safe for concurrent writes (append is atomic on most filesystems for\n13:  * small writes) and easy to process with standard unix tools (grep, jq, etc.).\n14:  */\n15: \n16: import { existsSync, mkdirSync, readFileSync, appendFileSync } from \"node:fs\";\n17: import { resolve, dirname } from \"node:path\";\n18: import { WOMBO_DIR } from \"../config.js\";\n19: import type { UsageRecord } from \"./token-collector.js\";\n20: \n21: // ---------------------------------------------------------------------------\n22: // Constants\n23: // ---------------------------------------------------------------------------\n24: \n25: /** Path to the usage JSONL file relative to project root */\n26: const USAGE_FILE = `${WOMBO_DIR}/usage.jsonl`;\n27: \n28: // ---------------------------------------------------------------------------\n29: // Persistence — Append\n30: // ---------------------------------------------------------------------------\n31: \n32: /**\n33:  * Append a single UsageRecord to the usage.jsonl file.\n34:  *\n35:  * Creates the .wombo-combo/ directory and the file if they don't exist.\n36:  * Each record is written as a single JSON line terminated by a newline.\n37:  *\n38:  * @param projectRoot  The project root directory\n39:  * @param record       The UsageRecord to persist\n40:  */\n41: export function appendUsageRecord(\n42:   projectRoot: string,\n43:   record: UsageRecord\n44: ): void {\n45:   const filePath = resolve(projectRoot, USAGE_FILE);\n46:   const dir = dirname(filePath);\n47: \n48:   if (!existsSync(dir)) {\n49:     mkdirSync(dir, { recursive: true });\n50:   }\n51: \n52:   const line = JSON.stringify(record) + \"\\n\";\n53:   appendFileSync(filePath, line, \"utf-8\");\n54: }\n55: \n56: // ---------------------------------------------------------------------------\n57: // Persistence — Load\n58: // ---------------------------------------------------------------------------\n59: \n60: /**\n61:  * Load all UsageRecords from the usage.jsonl file.\n62:  *\n63:  * Skips malformed lines silently (defensive against partial writes or\n64:  * corruption). Returns an empty array if the file doesn't exist.\n65:  *\n66:  * @param projectRoot  The project root directory\n67:  * @returns Array of UsageRecords in chronological order\n68:  */\n69: export function loadUsageRecords(projectRoot: string): UsageRecord[] {\n70:   const filePath = resolve(projectRoot, USAGE_FILE);\n71: \n72:   if (!existsSync(filePath)) return [];\n73: \n74:   const raw = readFileSync(filePath, \"utf-8\");\n75:   const records: UsageRecord[] = [];\n76: \n77:   for (const line of raw.split(\"\\n\")) {\n78:     const trimmed = line.trim();\n79:     if (!trimmed) continue;\n80: \n81:     try {\n82:       const record = JSON.parse(trimmed) as UsageRecord;\n83:       // Basic validation: must have task_id and timestamp\n84:       if (record.task_id && record.timestamp) {\n85:         records.push(record);\n86:       }\n87:     } catch {\n88:       // Skip malformed lines\n89:     }\n90:   }\n91: \n92:   return records;\n93: }\n94: \n95: // ---------------------------------------------------------------------------\n96: // Aggregation — Total Usage\n97: // ---------------------------------------------------------------------------\n98: \n99: /** Aggregated totals across a set of usage records */\n100: export interface UsageTotals {\n101:   /** Total input tokens */\n102:   input_tokens: number;\n103:   /** Total output tokens */\n104:   output_tokens: number;\n105:   /** Total cache read tokens */\n106:   cache_read: number;\n107:   /** Total cache write tokens */\n108:   cache_write: number;\n109:   /** Total reasoning tokens */\n110:   reasoning_tokens: number;\n111:   /** Grand total tokens */\n112:   total_tokens: number;\n113:   /** Total cost */\n114:   total_cost: number;\n115:   /** Number of records (steps) */\n116:   record_count: number;\n117: }\n118: \n119: /**\n120:  * Compute total usage across a set of records.\n121:  *\n122:  * @param records  The records to sum\n123:  * @returns Aggregated totals\n124:  */\n125: export function totalUsage(records: UsageRecord[]): UsageTotals {\n126:   return {\n127:     input_tokens: records.reduce((sum, r) => sum + r.input_tokens, 0),\n128:     output_tokens: records.reduce((sum, r) => sum + r.output_tokens, 0),\n129:     cache_read: records.reduce((sum, r) => sum + r.cache_read, 0),\n130:     cache_write: records.reduce((sum, r) => sum + r.cache_write, 0),\n131:     reasoning_tokens: records.reduce((sum, r) => sum + r.reasoning_tokens, 0),\n132:     total_tokens: records.reduce((sum, r) => sum + r.total_tokens, 0),\n133:     total_cost: records.reduce((sum, r) => sum + r.cost, 0),\n134:     record_count: records.length,\n135:   };\n136: }\n137: \n138: // ---------------------------------------------------------------------------\n139: // Aggregation — Filter by Date Range\n140: // ---------------------------------------------------------------------------\n141: \n142: /**\n143:  * Filter records to those within a date range.\n144:  *\n145:  * Both `since` and `until` are inclusive. If either is omitted, that side\n146:  * of the range is unbounded.\n147:  *\n148:  * @param records  The records to filter\n149:  * @param since    Start of range (ISO 8601 string or Date). Inclusive.\n150:  * @param until    End of range (ISO 8601 string or Date). Inclusive.\n151:  * @returns Filtered records\n152:  */\n153: export function filterByDateRange(\n154:   records: UsageRecord[],\n155:   since?: string | Date,\n156:   until?: string | Date\n157: ): UsageRecord[] {\n158:   const sinceMs = since ? new Date(since).getTime() : -Infinity;\n159:   const untilMs = until ? new Date(until).getTime() : Infinity;\n160: \n161:   if (isNaN(sinceMs) && since) {\n162:     throw new Error(`Invalid 'since' date: ${since}`);\n163:   }\n164:   if (isNaN(untilMs) && until) {\n165:     throw new Error(`Invalid 'until' date: ${until}`);\n166:   }\n167: \n168:   return records.filter((r) => {\n169:     const ts = new Date(r.timestamp).getTime();\n170:     if (isNaN(ts)) return false;\n171:     return ts >= sinceMs && ts <= untilMs;\n172:   });\n173: }\n174: \n175: // ---------------------------------------------------------------------------\n176: // Aggregation — Group By\n177: // ---------------------------------------------------------------------------\n178: \n179: /** Fields that can be used as groupBy keys */\n180: export type GroupableField =\n181:   | \"task_id\"\n182:   | \"quest_id\"\n183:   | \"model\"\n184:   | \"provider\"\n185:   | \"harness\";\n186: \n187: /**\n188:  * Group records by a specified field and compute totals for each group.\n189:  *\n190:  * The grouping key is the string value of the specified field. Null values\n191:  * are grouped under the key \"(unknown)\".\n192:  *\n193:  * @param records  The records to group\n194:  * @param field    The field to group by\n195:  * @returns Map from group key to aggregated totals\n196:  */\n197: export function groupBy(\n198:   records: UsageRecord[],\n199:   field: GroupableField\n200: ): Map<string, UsageTotals> {\n201:   const groups = new Map<string, UsageRecord[]>();\n202: \n203:   for (const record of records) {\n204:     const key = String(record[field] ?? \"(unknown)\");\n205:     if (!groups.has(key)) {\n206:       groups.set(key, []);\n207:     }\n208:     groups.get(key)!.push(record);\n209:   }\n210: \n211:   const result = new Map<string, UsageTotals>();\n212:   for (const [key, groupRecords] of groups) {\n213:     result.set(key, totalUsage(groupRecords));\n214:   }\n215: \n216:   return result;\n217: }\n218: \n219: // ---------------------------------------------------------------------------\n220: // UsageStore — High-level persistence wrapper\n221: // ---------------------------------------------------------------------------\n222: \n223: /**\n224:  * UsageStore provides a high-level interface for persisting token usage data.\n225:  *\n226:  * It is designed to be used as the onUsage callback for TokenCollector, so that\n227:  * every parsed UsageRecord is immediately persisted to the JSONL file.\n228:  *\n229:  * Usage:\n230:  *   const store = new UsageStore(projectRoot);\n231:  *\n232:  *   // Wire into TokenCollector\n233:  *   const collector = new TokenCollector((record) => {\n234:  *     store.append(record);\n235:  *   });\n236:  *\n237:  *   // Or wire into ProcessMonitor callbacks\n238:  *   const monitor = new ProcessMonitor(projectRoot, {\n239:  *     onUsage: (_featureId, record) => store.append(record),\n240:  *   });\n241:  *\n242:  *   // Query historical data\n243:  *   const allRecords = store.load();\n244:  *   const totals = store.totalUsage();\n245:  *   const byModel = store.groupBy(\"model\");\n246:  *   const lastWeek = store.filterByDateRange(weekAgo, now);\n247:  */\n248: export class UsageStore {\n249:   private projectRoot: string;\n250: \n251:   constructor(projectRoot: string) {\n252:     this.projectRoot = projectRoot;\n253:   }\n254: \n255:   /**\n256:    * Append a single UsageRecord to the JSONL file.\n257:    * This is the primary write method — designed to be called from\n258:    * TokenCollector's onUsage callback.\n259:    */\n260:   append(record: UsageRecord): void {\n261:     appendUsageRecord(this.projectRoot, record);\n262:   }\n263: \n264:   /**\n265:    * Load all usage records from the JSONL file.\n266:    */\n267:   load(): UsageRecord[] {\n268:     return loadUsageRecords(this.projectRoot);\n269:   }\n270: \n271:   /**\n272:    * Compute total usage across all persisted records.\n273:    */\n274:   totalUsage(): UsageTotals {\n275:     return totalUsage(this.load());\n276:   }\n277: \n278:   /**\n279:    * Filter persisted records by date range and return totals.\n280:    */\n281:   filterByDateRange(\n282:     since?: string | Date,\n283:     until?: string | Date\n284:   ): UsageRecord[] {\n285:     return filterByDateRange(this.load(), since, until);\n286:   }\n287: \n288:   /**\n289:    * Group persisted records by a field and compute per-group totals.\n290:    */\n291:   groupBy(field: GroupableField): Map<string, UsageTotals> {\n292:     return groupBy(this.load(), field);\n293:   }\n294: }\n\n(End of file - total 294 lines)\n</content>","title":"src/lib/token-usage.ts","metadata":{"preview":"/**\n * token-usage.ts — Persist and aggregate token usage data.\n *\n * Responsibilities:\n *   - Append UsageRecords to .wombo-combo/usage.jsonl (one JSON object per line)\n *   - Load all records from the JSONL file\n *   - Aggregate: groupBy(field), filterByDateRange(since, until), totalUsage()\n *   - Create a UsageStore that wires into TokenCollector's onUsage callback\n *\n * The JSONL format is append-only and human-readable. Each line is a complete\n * JSON object representing one UsageRecord (one step_finish event). This makes\n * it safe for concurrent writes (append is atomic on most filesystems for\n * small writes) and easy to process with standard unix tools (grep, jq, etc.).\n */\n\nimport { existsSync, mkdirSync, readFileSync, appendFileSync } from \"node:fs\";\nimport { resolve, dirname } from \"node:path\";\nimport { WOMBO_DIR } from \"../config.js\";\nimport type { UsageRecord } from \"./token-collector.js\";\n","truncated":false,"loaded":[]},"time":{"start":1773484482700,"end":1773484482703}}}}
{"type":"tool_use","timestamp":1773484483216,"sessionID":"ses_31416915cffeaA1eCO5cj4ROyq","part":{"id":"prt_cebe9a08d001nsbgo29gwalzaS","sessionID":"ses_31416915cffeaA1eCO5cj4ROyq","messageID":"msg_cebe99502001sad4Cy4X1m97Mt","type":"tool","callID":"toolu_vrtx_01Q1BxTHh9XaZ3EZWhkJccTM","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/token-tracking/src/lib/token-collector.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/token-tracking/src/lib/token-collector.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * token-collector.ts — Parse and collect token usage data from agent events.\n3:  *\n4:  * Responsibilities:\n5:  *   - Define the UsageRecord type for structured token usage data\n6:  *   - Parse step_finish events to extract per-step token counts\n7:  *   - Accumulate usage records per agent (task_id)\n8:  *   - Emit parsed records via callback (storage is handled elsewhere)\n9:  *\n10:  * OpenCode emits step_finish events with this token structure:\n11:  *   {\n12:  *     type: \"step_finish\",\n13:  *     part: {\n14:  *       reason: \"tool-calls\" | \"stop\",\n15:  *       cost: number,\n16:  *       tokens: {\n17:  *         total: number,\n18:  *         input: number,\n19:  *         output: number,\n20:  *         reasoning: number,\n21:  *         cache: { read: number, write: number }\n22:  *       }\n23:  *     }\n24:  *   }\n25:  */\n26: \n27: import type { OpenCodeEvent } from \"./monitor.js\";\n28: \n29: // ---------------------------------------------------------------------------\n30: // Types\n31: // ---------------------------------------------------------------------------\n32: \n33: /**\n34:  * A single token usage record extracted from an agent's step_finish event.\n35:  *\n36:  * Each record represents one step's token consumption. Multiple records\n37:  * are emitted per agent session (one per step_finish event).\n38:  */\n39: export interface UsageRecord {\n40:   /** The task/feature ID this usage belongs to */\n41:   task_id: string;\n42:   /** Optional quest ID if the agent is working within a quest */\n43:   quest_id: string | null;\n44:   /** Model identifier (e.g. \"claude-sonnet-4-20250514\") — from launch context */\n45:   model: string | null;\n46:   /** Provider name (e.g. \"anthropic\", \"openai\") — from launch context */\n47:   provider: string | null;\n48:   /** Agent harness name (e.g. \"opencode\") — from launch context */\n49:   harness: string | null;\n50:   /** Input tokens consumed in this step */\n51:   input_tokens: number;\n52:   /** Output tokens generated in this step */\n53:   output_tokens: number;\n54:   /** Tokens read from cache in this step */\n55:   cache_read: number;\n56:   /** Tokens written to cache in this step */\n57:   cache_write: number;\n58:   /** Reasoning tokens used in this step (e.g. for o1-style models) */\n59:   reasoning_tokens: number;\n60:   /** Total tokens for this step (input + output + reasoning) */\n61:   total_tokens: number;\n62:   /** Cost reported by the agent harness (may be 0 if not available) */\n63:   cost: number;\n64:   /** Whether this was the final step (reason === \"stop\") */\n65:   is_final_step: boolean;\n66:   /** ISO 8601 timestamp when this usage was recorded */\n67:   timestamp: string;\n68: }\n69: \n70: /**\n71:  * Aggregated usage summary for a single agent session.\n72:  */\n73: export interface UsageSummary {\n74:   /** The task/feature ID */\n75:   task_id: string;\n76:   /** Total input tokens across all steps */\n77:   total_input: number;\n78:   /** Total output tokens across all steps */\n79:   total_output: number;\n80:   /** Total cache read tokens across all steps */\n81:   total_cache_read: number;\n82:   /** Total cache write tokens across all steps */\n83:   total_cache_write: number;\n84:   /** Total reasoning tokens across all steps */\n85:   total_reasoning: number;\n86:   /** Grand total tokens across all steps */\n87:   total_tokens: number;\n88:   /** Total cost across all steps */\n89:   total_cost: number;\n90:   /** Number of steps recorded */\n91:   step_count: number;\n92: }\n93: \n94: // ---------------------------------------------------------------------------\n95: // Parsing\n96: // ---------------------------------------------------------------------------\n97: \n98: /**\n99:  * Check if an OpenCode event is a step_finish with token data.\n100:  */\n101: export function isTokenEvent(event: OpenCodeEvent): boolean {\n102:   return (\n103:     event.type === \"step_finish\" &&\n104:     event.part?.tokens != null &&\n105:     typeof event.part.tokens.input === \"number\"\n106:   );\n107: }\n108: \n109: /**\n110:  * Extract a UsageRecord from a step_finish event.\n111:  *\n112:  * Returns null if the event doesn't contain valid token data.\n113:  *\n114:  * @param event     The OpenCode JSON event (must be type \"step_finish\")\n115:  * @param taskId    The task/feature ID this agent is working on\n116:  * @param context   Optional context from the launch environment\n117:  */\n118: export function parseUsageFromEvent(\n119:   event: OpenCodeEvent,\n120:   taskId: string,\n121:   context?: {\n122:     quest_id?: string | null;\n123:     model?: string | null;\n124:     provider?: string | null;\n125:     harness?: string | null;\n126:   }\n127: ): UsageRecord | null {\n128:   if (!isTokenEvent(event)) return null;\n129: \n130:   const tokens = event.part!.tokens!;\n131:   const cache = tokens.cache ?? { read: 0, write: 0 };\n132: \n133:   return {\n134:     task_id: taskId,\n135:     quest_id: context?.quest_id ?? null,\n136:     model: context?.model ?? null,\n137:     provider: context?.provider ?? null,\n138:     harness: context?.harness ?? \"opencode\",\n139:     input_tokens: tokens.input,\n140:     output_tokens: tokens.output,\n141:     cache_read: cache.read,\n142:     cache_write: cache.write,\n143:     reasoning_tokens: tokens.reasoning ?? 0,\n144:     total_tokens: tokens.total,\n145:     cost: event.part?.cost ?? 0,\n146:     is_final_step: event.part?.reason === \"stop\",\n147:     timestamp: new Date(event.timestamp ?? Date.now()).toISOString(),\n148:   };\n149: }\n150: \n151: // ---------------------------------------------------------------------------\n152: // Collector\n153: // ---------------------------------------------------------------------------\n154: \n155: /** Callback invoked when a new usage record is parsed */\n156: export type UsageCallback = (record: UsageRecord) => void;\n157: \n158: /**\n159:  * TokenCollector accumulates usage records for multiple agents.\n160:  *\n161:  * Usage:\n162:  *   const collector = new TokenCollector((record) => {\n163:  *     console.log(\"Usage:\", record);\n164:  *   });\n165:  *\n166:  *   // Register context for an agent before it starts\n167:  *   collector.registerAgent(\"my-feature\", {\n168:  *     quest_id: \"quest-1\",\n169:  *     model: \"claude-sonnet-4-20250514\",\n170:  *   });\n171:  *\n172:  *   // Feed events as they arrive\n173:  *   collector.ingestEvent(\"my-feature\", event);\n174:  *\n175:  *   // Get aggregated summary\n176:  *   const summary = collector.getSummary(\"my-feature\");\n177:  */\n178: export class TokenCollector {\n179:   /** Per-agent usage records */\n180:   private records: Map<string, UsageRecord[]> = new Map();\n181: \n182:   /** Per-agent context (model, provider, quest, etc.) */\n183:   private contexts: Map<\n184:     string,\n185:     {\n186:       quest_id?: string | null;\n187:       model?: string | null;\n188:       provider?: string | null;\n189:       harness?: string | null;\n190:     }\n191:   > = new Map();\n192: \n193:   /** Callback invoked for each new usage record */\n194:   private onUsage: UsageCallback | null;\n195: \n196:   constructor(onUsage?: UsageCallback) {\n197:     this.onUsage = onUsage ?? null;\n198:   }\n199: \n200:   /**\n201:    * Register context for an agent before events start flowing.\n202:    * This context (model, provider, quest_id) is attached to every\n203:    * UsageRecord emitted for this agent.\n204:    */\n205:   registerAgent(\n206:     taskId: string,\n207:     context?: {\n208:       quest_id?: string | null;\n209:       model?: string | null;\n210:       provider?: string | null;\n211:       harness?: string | null;\n212:     }\n213:   ): void {\n214:     this.contexts.set(taskId, context ?? {});\n215:     if (!this.records.has(taskId)) {\n216:       this.records.set(taskId, []);\n217:     }\n218:   }\n219: \n220:   /**\n221:    * Feed an OpenCode event for a specific agent.\n222:    * If the event is a step_finish with token data, a UsageRecord\n223:    * is created and the onUsage callback is invoked.\n224:    *\n225:    * @returns The parsed UsageRecord, or null if the event had no token data\n226:    */\n227:   ingestEvent(taskId: string, event: OpenCodeEvent): UsageRecord | null {\n228:     if (!isTokenEvent(event)) return null;\n229: \n230:     const context = this.contexts.get(taskId);\n231:     const record = parseUsageFromEvent(event, taskId, context);\n232:     if (!record) return null;\n233: \n234:     if (!this.records.has(taskId)) {\n235:       this.records.set(taskId, []);\n236:     }\n237:     this.records.get(taskId)!.push(record);\n238: \n239:     this.onUsage?.(record);\n240: \n241:     return record;\n242:   }\n243: \n244:   /**\n245:    * Get all usage records for an agent.\n246:    */\n247:   getRecords(taskId: string): UsageRecord[] {\n248:     return this.records.get(taskId) ?? [];\n249:   }\n250: \n251:   /**\n252:    * Get all usage records across all agents.\n253:    */\n254:   getAllRecords(): UsageRecord[] {\n255:     const all: UsageRecord[] = [];\n256:     for (const records of this.records.values()) {\n257:       all.push(...records);\n258:     }\n259:     return all;\n260:   }\n261: \n262:   /**\n263:    * Get an aggregated usage summary for an agent.\n264:    * Returns null if no records exist for the agent.\n265:    */\n266:   getSummary(taskId: string): UsageSummary | null {\n267:     const records = this.records.get(taskId);\n268:     if (!records || records.length === 0) return null;\n269: \n270:     return {\n271:       task_id: taskId,\n272:       total_input: records.reduce((sum, r) => sum + r.input_tokens, 0),\n273:       total_output: records.reduce((sum, r) => sum + r.output_tokens, 0),\n274:       total_cache_read: records.reduce((sum, r) => sum + r.cache_read, 0),\n275:       total_cache_write: records.reduce((sum, r) => sum + r.cache_write, 0),\n276:       total_reasoning: records.reduce((sum, r) => sum + r.reasoning_tokens, 0),\n277:       total_tokens: records.reduce((sum, r) => sum + r.total_tokens, 0),\n278:       total_cost: records.reduce((sum, r) => sum + r.cost, 0),\n279:       step_count: records.length,\n280:     };\n281:   }\n282: \n283:   /**\n284:    * Get aggregated summaries for all tracked agents.\n285:    */\n286:   getAllSummaries(): UsageSummary[] {\n287:     const summaries: UsageSummary[] = [];\n288:     for (const taskId of this.records.keys()) {\n289:       const summary = this.getSummary(taskId);\n290:       if (summary) summaries.push(summary);\n291:     }\n292:     return summaries;\n293:   }\n294: \n295:   /**\n296:    * Remove all records for an agent (e.g. after archiving).\n297:    */\n298:   clear(taskId: string): void {\n299:     this.records.delete(taskId);\n300:     this.contexts.delete(taskId);\n301:   }\n302: \n303:   /**\n304:    * Remove all records for all agents.\n305:    */\n306:   clearAll(): void {\n307:     this.records.clear();\n308:     this.contexts.clear();\n309:   }\n310: }\n\n(End of file - total 310 lines)\n</content>","title":"src/lib/token-collector.ts","metadata":{"preview":"/**\n * token-collector.ts — Parse and collect token usage data from agent events.\n *\n * Responsibilities:\n *   - Define the UsageRecord type for structured token usage data\n *   - Parse step_finish events to extract per-step token counts\n *   - Accumulate usage records per agent (task_id)\n *   - Emit parsed records via callback (storage is handled elsewhere)\n *\n * OpenCode emits step_finish events with this token structure:\n *   {\n *     type: \"step_finish\",\n *     part: {\n *       reason: \"tool-calls\" | \"stop\",\n *       cost: number,\n *       tokens: {\n *         total: number,\n *         input: number,\n *         output: number,\n *         reasoning: number,","truncated":false,"loaded":[]},"time":{"start":1773484483211,"end":1773484483215}}}}
{"type":"tool_use","timestamp":1773484483591,"sessionID":"ses_31416915cffeaA1eCO5cj4ROyq","part":{"id":"prt_cebe9a28d00197w4TrnR1feWpL","sessionID":"ses_31416915cffeaA1eCO5cj4ROyq","messageID":"msg_cebe99502001sad4Cy4X1m97Mt","type":"tool","callID":"toolu_vrtx_01UF2o1YcNwbU8V7L9kWTGLS","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/token-tracking/src/commands/usage.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/token-tracking/src/commands/usage.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * usage.ts — Show token usage statistics.\n3:  *\n4:  * Usage:\n5:  *   woco usage                                          Show total usage\n6:  *   woco usage --by task                                Group by task\n7:  *   woco usage --by model                               Group by model\n8:  *   woco usage --by provider                            Group by provider\n9:  *   woco usage --by quest                               Group by quest\n10:  *   woco usage --by harness                             Group by harness\n11:  *   woco usage --since 2026-01-01                       Filter by start date\n12:  *   woco usage --until 2026-03-01                       Filter by end date\n13:  *   woco usage --format json                            Output as JSON\n14:  *   woco usage --format table                           Output as aligned table (default)\n15:  *\n16:  * Reads from .wombo-combo/usage.jsonl and aggregates token counts.\n17:  */\n18: \n19: import type { WomboConfig } from \"../config.js\";\n20: import {\n21:   loadUsageRecords,\n22:   filterByDateRange,\n23:   groupBy,\n24:   totalUsage,\n25:   type UsageTotals,\n26:   type GroupableField,\n27: } from \"../lib/token-usage.js\";\n28: import { output, outputError, type OutputFormat } from \"../lib/output.js\";\n29: \n30: // ---------------------------------------------------------------------------\n31: // Types\n32: // ---------------------------------------------------------------------------\n33: \n34: /** CLI-facing grouping key names (mapped to internal GroupableField) */\n35: export type UsageGroupBy = \"task\" | \"quest\" | \"model\" | \"provider\" | \"harness\";\n36: \n37: /** Valid --by values for validation */\n38: export const VALID_USAGE_GROUP_BY: readonly string[] = [\n39:   \"task\",\n40:   \"quest\",\n41:   \"model\",\n42:   \"provider\",\n43:   \"harness\",\n44: ];\n45: \n46: export interface UsageCommandOptions {\n47:   projectRoot: string;\n48:   config: WomboConfig;\n49:   /** Grouping key (default: total — no grouping) */\n50:   by?: UsageGroupBy;\n51:   /** Start of date range filter (ISO 8601) */\n52:   since?: string;\n53:   /** End of date range filter (ISO 8601) */\n54:   until?: string;\n55:   /** Output format: table or json (maps from the CLI's --format flag) */\n56:   usageFormat: \"table\" | \"json\";\n57:   /** Global output format (--output text|json|toon) */\n58:   outputFmt: OutputFormat;\n59: }\n60: \n61: // ---------------------------------------------------------------------------\n62: // Helpers — CLI group name → internal GroupableField\n63: // ---------------------------------------------------------------------------\n64: \n65: function toGroupableField(by: UsageGroupBy): GroupableField {\n66:   switch (by) {\n67:     case \"task\":\n68:       return \"task_id\";\n69:     case \"quest\":\n70:       return \"quest_id\";\n71:     case \"model\":\n72:       return \"model\";\n73:     case \"provider\":\n74:       return \"provider\";\n75:     case \"harness\":\n76:       return \"harness\";\n77:   }\n78: }\n79: \n80: // ---------------------------------------------------------------------------\n81: // Formatting — Table Output\n82: // ---------------------------------------------------------------------------\n83: \n84: const RESET = \"\\x1b[0m\";\n85: const BOLD = \"\\x1b[1m\";\n86: const DIM = \"\\x1b[2m\";\n87: const FG = {\n88:   cyan: \"\\x1b[36m\",\n89:   green: \"\\x1b[32m\",\n90:   yellow: \"\\x1b[33m\",\n91:   gray: \"\\x1b[90m\",\n92: };\n93: \n94: function formatNumber(n: number): string {\n95:   return n.toLocaleString(\"en-US\");\n96: }\n97: \n98: function formatCost(cost: number): string {\n99:   if (cost === 0) return \"-\";\n100:   return `$${cost.toFixed(4)}`;\n101: }\n102: \n103: function pad(text: string, width: number): string {\n104:   if (text.length >= width) return text.slice(0, width);\n105:   return text + \" \".repeat(width - text.length);\n106: }\n107: \n108: function padLeft(text: string, width: number): string {\n109:   if (text.length >= width) return text.slice(0, width);\n110:   return \" \".repeat(width - text.length) + text;\n111: }\n112: \n113: /**\n114:  * Render total usage as a summary block.\n115:  */\n116: function renderTotalUsage(totals: UsageTotals): void {\n117:   console.log(\"\");\n118:   console.log(`${BOLD}Token Usage — Total${RESET}`);\n119:   console.log(\"\");\n120:   console.log(`  Input tokens:     ${FG.cyan}${formatNumber(totals.input_tokens)}${RESET}`);\n121:   console.log(`  Output tokens:    ${FG.green}${formatNumber(totals.output_tokens)}${RESET}`);\n122:   console.log(`  Cache read:       ${FG.gray}${formatNumber(totals.cache_read)}${RESET}`);\n123:   console.log(`  Cache write:      ${FG.gray}${formatNumber(totals.cache_write)}${RESET}`);\n124:   console.log(`  Reasoning:        ${FG.yellow}${formatNumber(totals.reasoning_tokens)}${RESET}`);\n125:   console.log(`  ${BOLD}Total tokens:     ${formatNumber(totals.total_tokens)}${RESET}`);\n126:   console.log(`  Total cost:       ${formatCost(totals.total_cost)}`);\n127:   console.log(`  Steps recorded:   ${totals.record_count}`);\n128:   console.log(\"\");\n129: }\n130: \n131: /**\n132:  * Render grouped usage as an aligned table.\n133:  */\n134: function renderGroupedTable(\n135:   groups: Map<string, UsageTotals>,\n136:   groupLabel: string\n137: ): void {\n138:   if (groups.size === 0) {\n139:     console.log(\"\\nNo usage data found.\\n\");\n140:     return;\n141:   }\n142: \n143:   console.log(\"\");\n144:   console.log(`${BOLD}Token Usage — by ${groupLabel}${RESET}`);\n145:   console.log(\"\");\n146: \n147:   // Build column widths\n148:   const keyWidth = Math.max(\n149:     groupLabel.length,\n150:     ...Array.from(groups.keys()).map((k) => k.length),\n151:     8\n152:   );\n153: \n154:   const header = [\n155:     pad(groupLabel.charAt(0).toUpperCase() + groupLabel.slice(1), keyWidth),\n156:     padLeft(\"Input\", 12),\n157:     padLeft(\"Output\", 12),\n158:     padLeft(\"Cache Read\", 12),\n159:     padLeft(\"Cache Write\", 12),\n160:     padLeft(\"Total\", 14),\n161:     padLeft(\"Cost\", 10),\n162:   ].join(\"  \");\n163: \n164:   console.log(`${BOLD}${header}${RESET}`);\n165:   console.log(\"-\".repeat(header.length));\n166: \n167:   // Sort by total tokens descending for readability\n168:   const sorted = Array.from(groups.entries()).sort(\n169:     (a, b) => b[1].total_tokens - a[1].total_tokens\n170:   );\n171: \n172:   for (const [key, totals] of sorted) {\n173:     const row = [\n174:       pad(key, keyWidth),\n175:       padLeft(formatNumber(totals.input_tokens), 12),\n176:       padLeft(formatNumber(totals.output_tokens), 12),\n177:       padLeft(formatNumber(totals.cache_read), 12),\n178:       padLeft(formatNumber(totals.cache_write), 12),\n179:       padLeft(formatNumber(totals.total_tokens), 14),\n180:       padLeft(formatCost(totals.total_cost), 10),\n181:     ].join(\"  \");\n182: \n183:     console.log(row);\n184:   }\n185: \n186:   // Grand total row\n187:   const grandTotal: UsageTotals = {\n188:     input_tokens: 0,\n189:     output_tokens: 0,\n190:     cache_read: 0,\n191:     cache_write: 0,\n192:     reasoning_tokens: 0,\n193:     total_tokens: 0,\n194:     total_cost: 0,\n195:     record_count: 0,\n196:   };\n197:   for (const totals of groups.values()) {\n198:     grandTotal.input_tokens += totals.input_tokens;\n199:     grandTotal.output_tokens += totals.output_tokens;\n200:     grandTotal.cache_read += totals.cache_read;\n201:     grandTotal.cache_write += totals.cache_write;\n202:     grandTotal.total_tokens += totals.total_tokens;\n203:     grandTotal.total_cost += totals.total_cost;\n204:     grandTotal.record_count += totals.record_count;\n205:   }\n206: \n207:   console.log(\"-\".repeat(header.length));\n208:   const totalRow = [\n209:     pad(`${BOLD}TOTAL${RESET}`, keyWidth + BOLD.length + RESET.length),\n210:     padLeft(formatNumber(grandTotal.input_tokens), 12),\n211:     padLeft(formatNumber(grandTotal.output_tokens), 12),\n212:     padLeft(formatNumber(grandTotal.cache_read), 12),\n213:     padLeft(formatNumber(grandTotal.cache_write), 12),\n214:     padLeft(formatNumber(grandTotal.total_tokens), 14),\n215:     padLeft(formatCost(grandTotal.total_cost), 10),\n216:   ].join(\"  \");\n217:   console.log(totalRow);\n218: \n219:   console.log(\"\");\n220: }\n221: \n222: // ---------------------------------------------------------------------------\n223: // JSON Output Helpers\n224: // ---------------------------------------------------------------------------\n225: \n226: function totalsToJSON(totals: UsageTotals): Record<string, unknown> {\n227:   return {\n228:     input_tokens: totals.input_tokens,\n229:     output_tokens: totals.output_tokens,\n230:     cache_read: totals.cache_read,\n231:     cache_write: totals.cache_write,\n232:     reasoning_tokens: totals.reasoning_tokens,\n233:     total_tokens: totals.total_tokens,\n234:     total_cost: totals.total_cost,\n235:     record_count: totals.record_count,\n236:   };\n237: }\n238: \n239: function groupedToJSON(\n240:   groups: Map<string, UsageTotals>,\n241:   groupLabel: string\n242: ): Record<string, unknown> {\n243:   const entries: Record<string, unknown>[] = [];\n244:   for (const [key, totals] of groups) {\n245:     entries.push({\n246:       [groupLabel]: key,\n247:       ...totalsToJSON(totals),\n248:     });\n249:   }\n250:   return { by: groupLabel, groups: entries };\n251: }\n252: \n253: // ---------------------------------------------------------------------------\n254: // Command\n255: // ---------------------------------------------------------------------------\n256: \n257: export async function cmdUsage(opts: UsageCommandOptions): Promise<void> {\n258:   const { projectRoot, outputFmt, usageFormat } = opts;\n259: \n260:   // Load all records\n261:   let records = loadUsageRecords(projectRoot);\n262: \n263:   // Apply date range filter\n264:   if (opts.since || opts.until) {\n265:     try {\n266:       records = filterByDateRange(records, opts.since, opts.until);\n267:     } catch (err: any) {\n268:       outputError(outputFmt, err.message);\n269:       return; // unreachable\n270:     }\n271:   }\n272: \n273:   if (records.length === 0) {\n274:     if (usageFormat === \"json\" || outputFmt === \"json\") {\n275:       console.log(JSON.stringify({ message: \"No usage data found.\", groups: [] }));\n276:     } else {\n277:       console.log(\"\\nNo usage data found.\");\n278:       console.log(\"Usage data is recorded when agents run via 'woco launch'.\\n\");\n279:     }\n280:     return;\n281:   }\n282: \n283:   // Grouped or total?\n284:   if (opts.by) {\n285:     const byLabel = opts.by;\n286:     const field = toGroupableField(byLabel);\n287:     const groups = groupBy(records, field);\n288:     const jsonData = groupedToJSON(groups, byLabel);\n289: \n290:     if (usageFormat === \"json\" || outputFmt === \"json\") {\n291:       // JSON output\n292:       output(outputFmt, jsonData, () => {\n293:         console.log(JSON.stringify(jsonData, null, 2));\n294:       });\n295:     } else {\n296:       // Table output\n297:       output(outputFmt, jsonData, () => {\n298:         renderGroupedTable(groups, byLabel);\n299:       });\n300:     }\n301:   } else {\n302:     // Total (no grouping)\n303:     const totals = totalUsage(records);\n304: \n305:     if (usageFormat === \"json\" || outputFmt === \"json\") {\n306:       output(outputFmt, totalsToJSON(totals), () => {\n307:         console.log(JSON.stringify(totalsToJSON(totals), null, 2));\n308:       });\n309:     } else {\n310:       output(outputFmt, totalsToJSON(totals), () => {\n311:         renderTotalUsage(totals);\n312:       });\n313:     }\n314:   }\n315: }\n\n(End of file - total 315 lines)\n</content>","title":"src/commands/usage.ts","metadata":{"preview":"/**\n * usage.ts — Show token usage statistics.\n *\n * Usage:\n *   woco usage                                          Show total usage\n *   woco usage --by task                                Group by task\n *   woco usage --by model                               Group by model\n *   woco usage --by provider                            Group by provider\n *   woco usage --by quest                               Group by quest\n *   woco usage --by harness                             Group by harness\n *   woco usage --since 2026-01-01                       Filter by start date\n *   woco usage --until 2026-03-01                       Filter by end date\n *   woco usage --format json                            Output as JSON\n *   woco usage --format table                           Output as aligned table (default)\n *\n * Reads from .wombo-combo/usage.jsonl and aggregates token counts.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport {","truncated":false,"loaded":[]},"time":{"start":1773484483588,"end":1773484483590}}}}
{"type":"text","timestamp":1773484484035,"sessionID":"ses_31416915cffeaA1eCO5cj4ROyq","part":{"id":"prt_cebe99c900026okIHaTjmCy3hW","sessionID":"ses_31416915cffeaA1eCO5cj4ROyq","messageID":"msg_cebe99502001sad4Cy4X1m97Mt","type":"text","text":"I can see there are token-tracking related files already. Let me explore them:","time":{"start":1773484484035,"end":1773484484035}}}
{"type":"tool_use","timestamp":1773484484039,"sessionID":"ses_31416915cffeaA1eCO5cj4ROyq","part":{"id":"prt_cebe9a405001eCNW0TONjBkEeV","sessionID":"ses_31416915cffeaA1eCO5cj4ROyq","messageID":"msg_cebe99502001sad4Cy4X1m97Mt","type":"tool","callID":"toolu_vrtx_01416HiqobFuZTRecFoERk3n","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/token-tracking/src/lib/tui-usage-overlay.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/token-tracking/src/lib/tui-usage-overlay.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tui-usage-overlay.ts -- Token usage overlay for the wombo-combo TUI.\n3:  *\n4:  * Shows a modal overlay with overall token usage statistics and a per-task\n5:  * breakdown. Accessible via the U keybind in the Task Browser.\n6:  *\n7:  * Layout:\n8:  *   +--------------------------------------------------+\n9:  *   | Token Usage                      Total: $12.34   |\n10:  *   +--------------------------------------------------+\n11:  *   | Overall:                                          |\n12:  *   |   Input: 1.2M  Output: 450.3k  Cache: 800.0k    |\n13:  *   |   Reasoning: 50.2k  Total: 2.5M  Steps: 42      |\n14:  *   +--------------------------------------------------+\n15:  *   | Per Task:                                         |\n16:  *   | > auth-service     In: 200k Out: 100k  $2.50     |\n17:  *   |   search-api       In: 150k Out:  80k  $1.80     |\n18:  *   |   perf-optim       In:  50k Out:  30k  $0.60     |\n19:  *   +--------------------------------------------------+\n20:  *   | Tab:group by  Esc/U:close                        |\n21:  *   +--------------------------------------------------+\n22:  *\n23:  * Keybinds:\n24:  *   Up/Down   -- navigate per-task list\n25:  *   Tab       -- cycle grouping (task_id → quest_id → model → provider)\n26:  *   Escape/U  -- close the overlay\n27:  */\n28: \n29: import blessed from \"neo-blessed\";\n30: import type { Widgets } from \"neo-blessed\";\n31: import { loadUsageRecords, totalUsage, groupBy } from \"./token-usage.js\";\n32: import type { UsageTotals, GroupableField } from \"./token-usage.js\";\n33: \n34: // ---------------------------------------------------------------------------\n35: // Types\n36: // ---------------------------------------------------------------------------\n37: \n38: export interface UsageOverlayCallbacks {\n39:   /** Called when the overlay is closed (Esc or U). */\n40:   onClose: () => void;\n41: }\n42: \n43: // ---------------------------------------------------------------------------\n44: // Helpers\n45: // ---------------------------------------------------------------------------\n46: \n47: function escapeBlessedTags(text: string): string {\n48:   return text.replace(/\\{/g, \"\\uFF5B\").replace(/\\}/g, \"\\uFF5D\");\n49: }\n50: \n51: /**\n52:  * Format a token count with k/M suffixes for compact display.\n53:  */\n54: function formatTokenCount(n: number): string {\n55:   if (n === 0) return \"0\";\n56:   if (n < 1000) return String(n);\n57:   if (n < 1_000_000) return `${(n / 1000).toFixed(1)}k`;\n58:   return `${(n / 1_000_000).toFixed(2)}M`;\n59: }\n60: \n61: /**\n62:  * Format a cost value as a dollar string.\n63:  */\n64: function formatCost(cost: number): string {\n65:   if (cost === 0) return \"$0.00\";\n66:   if (cost < 0.01) return `$${cost.toFixed(4)}`;\n67:   return `$${cost.toFixed(2)}`;\n68: }\n69: \n70: /** The grouping fields available for cycling */\n71: const GROUPING_FIELDS: GroupableField[] = [\n72:   \"task_id\",\n73:   \"quest_id\",\n74:   \"model\",\n75:   \"provider\",\n76: ];\n77: \n78: /** Human-readable labels for grouping fields */\n79: const GROUPING_LABELS: Record<GroupableField, string> = {\n80:   task_id: \"Task\",\n81:   quest_id: \"Quest\",\n82:   model: \"Model\",\n83:   provider: \"Provider\",\n84:   harness: \"Harness\",\n85: };\n86: \n87: // ---------------------------------------------------------------------------\n88: // UsageOverlay Class\n89: // ---------------------------------------------------------------------------\n90: \n91: export class UsageOverlay {\n92:   private modal: Widgets.BoxElement;\n93:   private summaryBox: Widgets.BoxElement;\n94:   private groupList: Widgets.ListElement;\n95:   private footerBox: Widgets.BoxElement;\n96: \n97:   private screen: Widgets.Screen;\n98:   private projectRoot: string;\n99:   private callbacks: UsageOverlayCallbacks;\n100:   private destroyed: boolean = false;\n101: \n102:   /** Overall usage totals */\n103:   private overall: UsageTotals | null = null;\n104:   /** Grouped usage data (sorted by total_tokens descending) */\n105:   private groups: Array<{ key: string; totals: UsageTotals }> = [];\n106:   /** Current grouping field */\n107:   private groupField: GroupableField = \"task_id\";\n108:   /** Selected index in the group list */\n109:   private selectedIndex: number = 0;\n110: \n111:   constructor(\n112:     screen: Widgets.Screen,\n113:     projectRoot: string,\n114:     callbacks: UsageOverlayCallbacks\n115:   ) {\n116:     this.screen = screen;\n117:     this.projectRoot = projectRoot;\n118:     this.callbacks = callbacks;\n119: \n120:     // Load data\n121:     this.loadData();\n122: \n123:     // --- Modal container ---\n124:     this.modal = blessed.box({\n125:       parent: screen,\n126:       top: \"center\",\n127:       left: \"center\",\n128:       width: \"80%\",\n129:       height: \"85%\",\n130:       tags: true,\n131:       border: { type: \"line\" },\n132:       style: {\n133:         border: { fg: \"yellow\" },\n134:         fg: \"white\",\n135:         bg: \"black\",\n136:       },\n137:       label: this.buildLabel(),\n138:       shadow: true,\n139:     });\n140: \n141:     // --- Summary box (overall totals) ---\n142:     this.summaryBox = blessed.box({\n143:       parent: this.modal,\n144:       top: 0,\n145:       left: 1,\n146:       right: 1,\n147:       height: 5,\n148:       tags: true,\n149:       style: { fg: \"white\", bg: \"black\" },\n150:     });\n151: \n152:     // --- Scrollable group list ---\n153:     this.groupList = blessed.list({\n154:       parent: this.modal,\n155:       top: 5,\n156:       left: 1,\n157:       right: 1,\n158:       height: \"100%-9\",\n159:       tags: true,\n160:       scrollable: true,\n161:       mouse: true,\n162:       keys: true,\n163:       vi: true,\n164:       scrollbar: {\n165:         ch: \"\\u2502\",\n166:         style: { fg: \"yellow\" },\n167:       },\n168:       border: { type: \"line\" },\n169:       style: {\n170:         border: { fg: \"gray\" },\n171:         selected: { bg: \"blue\", fg: \"white\", bold: true },\n172:         item: { fg: \"white\" },\n173:         bg: \"black\",\n174:       },\n175:       label: ` By ${GROUPING_LABELS[this.groupField]} `,\n176:     });\n177: \n178:     // --- Footer: keybind hints ---\n179:     this.footerBox = blessed.box({\n180:       parent: this.modal,\n181:       bottom: 0,\n182:       left: 1,\n183:       right: 1,\n184:       height: 1,\n185:       tags: true,\n186:       style: { fg: \"gray\", bg: \"black\" },\n187:     });\n188: \n189:     this.refreshSummary();\n190:     this.refreshGroupList();\n191:     this.refreshFooter();\n192:     this.bindKeys();\n193:     this.groupList.focus();\n194:     this.screen.render();\n195:   }\n196: \n197:   // -------------------------------------------------------------------------\n198:   // Data Loading\n199:   // -------------------------------------------------------------------------\n200: \n201:   private loadData(): void {\n202:     try {\n203:       const records = loadUsageRecords(this.projectRoot);\n204:       if (records.length > 0) {\n205:         this.overall = totalUsage(records);\n206:         this.buildGroups(records);\n207:       } else {\n208:         this.overall = null;\n209:         this.groups = [];\n210:       }\n211:     } catch {\n212:       this.overall = null;\n213:       this.groups = [];\n214:     }\n215:   }\n216: \n217:   private buildGroups(records: ReturnType<typeof loadUsageRecords>): void {\n218:     const grouped = groupBy(records, this.groupField);\n219:     this.groups = [];\n220:     for (const [key, totals] of grouped) {\n221:       this.groups.push({ key, totals });\n222:     }\n223:     // Sort by total_tokens descending (most expensive first)\n224:     this.groups.sort((a, b) => b.totals.total_tokens - a.totals.total_tokens);\n225:   }\n226: \n227:   // -------------------------------------------------------------------------\n228:   // Key Bindings\n229:   // -------------------------------------------------------------------------\n230: \n231:   private bindKeys(): void {\n232:     // Navigate — track selection changes\n233:     this.groupList.on(\"select item\", (_item: any, index: number) => {\n234:       this.selectedIndex = index;\n235:     });\n236: \n237:     // Close overlay with Escape or U\n238:     this.groupList.key([\"escape\", \"u\"], () => {\n239:       this.close();\n240:     });\n241: \n242:     // Tab — cycle grouping\n243:     this.groupList.key([\"tab\"], () => {\n244:       this.cycleGrouping();\n245:     });\n246:   }\n247: \n248:   // -------------------------------------------------------------------------\n249:   // Actions\n250:   // -------------------------------------------------------------------------\n251: \n252:   private cycleGrouping(): void {\n253:     const idx = GROUPING_FIELDS.indexOf(this.groupField);\n254:     this.groupField =\n255:       GROUPING_FIELDS[(idx + 1) % GROUPING_FIELDS.length];\n256:     this.selectedIndex = 0;\n257: \n258:     // Reload grouped data\n259:     try {\n260:       const records = loadUsageRecords(this.projectRoot);\n261:       this.buildGroups(records);\n262:     } catch {\n263:       this.groups = [];\n264:     }\n265: \n266:     this.groupList.setLabel(` By ${GROUPING_LABELS[this.groupField]} `);\n267:     this.refreshGroupList();\n268:     this.refreshFooter();\n269:     this.screen.render();\n270:   }\n271: \n272:   // -------------------------------------------------------------------------\n273:   // Rendering\n274:   // -------------------------------------------------------------------------\n275: \n276:   private buildLabel(): string {\n277:     const costStr = this.overall\n278:       ? `  Total: {yellow-fg}${formatCost(this.overall.total_cost)}{/yellow-fg}`\n279:       : \"\";\n280:     return ` {yellow-fg}Token Usage{/yellow-fg}${costStr} `;\n281:   }\n282: \n283:   private refreshSummary(): void {\n284:     if (!this.overall) {\n285:       this.summaryBox.setContent(\n286:         \"{gray-fg}No token usage data found.\\n\" +\n287:         \"Usage data is recorded when agents run and produce step_finish events.{/gray-fg}\"\n288:       );\n289:       return;\n290:     }\n291: \n292:     const u = this.overall;\n293:     const lines: string[] = [];\n294: \n295:     lines.push(\"{bold}{yellow-fg}Overall Usage:{/yellow-fg}{/bold}\");\n296: \n297:     // Row 1: Input, Output, Cache\n298:     let row1 = `  Input: {cyan-fg}${formatTokenCount(u.input_tokens)}{/cyan-fg}`;\n299:     row1 += `    Output: {cyan-fg}${formatTokenCount(u.output_tokens)}{/cyan-fg}`;\n300:     if (u.cache_read > 0) {\n301:       row1 += `    Cache: {gray-fg}${formatTokenCount(u.cache_read)}{/gray-fg}`;\n302:     }\n303:     lines.push(row1);\n304: \n305:     // Row 2: Reasoning, Total, Cost, Steps\n306:     let row2 = \"\";\n307:     if (u.reasoning_tokens > 0) {\n308:       row2 += `  Reasoning: {magenta-fg}${formatTokenCount(u.reasoning_tokens)}{/magenta-fg}    `;\n309:     } else {\n310:       row2 += \"  \";\n311:     }\n312:     row2 += `Total: {white-fg}${formatTokenCount(u.total_tokens)}{/white-fg}`;\n313:     if (u.total_cost > 0) {\n314:       row2 += `    Cost: {yellow-fg}${formatCost(u.total_cost)}{/yellow-fg}`;\n315:     }\n316:     row2 += `    Steps: ${u.record_count}`;\n317:     lines.push(row2);\n318: \n319:     this.summaryBox.setContent(lines.join(\"\\n\"));\n320:   }\n321: \n322:   private refreshGroupList(): void {\n323:     if (this.groups.length === 0) {\n324:       this.groupList.setItems([\n325:         \" {gray-fg}No usage data to group.{/gray-fg}\",\n326:       ] as any);\n327:       return;\n328:     }\n329: \n330:     const listItems: string[] = [];\n331: \n332:     for (const { key, totals } of this.groups) {\n333:       // Truncate key for display\n334:       const maxKeyLen = 24;\n335:       const displayKey = key.length > maxKeyLen\n336:         ? key.slice(0, maxKeyLen - 1) + \"\\u2026\"\n337:         : key.padEnd(maxKeyLen);\n338: \n339:       // Format columns\n340:       const input = `In: ${formatTokenCount(totals.input_tokens)}`.padEnd(12);\n341:       const output = `Out: ${formatTokenCount(totals.output_tokens)}`.padEnd(13);\n342:       const cost = totals.total_cost > 0 ? formatCost(totals.total_cost) : \"\";\n343:       const steps = `${totals.record_count}st`;\n344: \n345:       listItems.push(\n346:         ` ${escapeBlessedTags(displayKey)}  {cyan-fg}${input}{/cyan-fg} {cyan-fg}${output}{/cyan-fg} {yellow-fg}${cost}{/yellow-fg}  {gray-fg}${steps}{/gray-fg}`\n347:       );\n348:     }\n349: \n350:     const prevSelected = this.selectedIndex;\n351:     this.groupList.setItems(listItems as any);\n352:     if (prevSelected < listItems.length) {\n353:       this.groupList.select(prevSelected);\n354:     } else if (listItems.length > 0) {\n355:       this.groupList.select(0);\n356:       this.selectedIndex = 0;\n357:     }\n358:   }\n359: \n360:   private refreshFooter(): void {\n361:     const nextIdx = (GROUPING_FIELDS.indexOf(this.groupField) + 1) %\n362:       GROUPING_FIELDS.length;\n363:     const nextLabel = GROUPING_LABELS[GROUPING_FIELDS[nextIdx]];\n364: \n365:     this.footerBox.setContent(\n366:       ` {gray-fg}Tab{/gray-fg} group by ${nextLabel}  {gray-fg}Esc/U{/gray-fg} close` +\n367:       `  {gray-fg}|{/gray-fg}  Grouped by: {yellow-fg}${GROUPING_LABELS[this.groupField]}{/yellow-fg}`\n368:     );\n369:   }\n370: \n371:   // -------------------------------------------------------------------------\n372:   // Public API\n373:   // -------------------------------------------------------------------------\n374: \n375:   /**\n376:    * Close and destroy the overlay.\n377:    */\n378:   close(): void {\n379:     if (this.destroyed) return;\n380:     this.destroyed = true;\n381:     this.modal.destroy();\n382:     this.callbacks.onClose();\n383:     this.screen.render();\n384:   }\n385: \n386:   /**\n387:    * Whether the overlay has been destroyed.\n388:    */\n389:   isDestroyed(): boolean {\n390:     return this.destroyed;\n391:   }\n392: }\n\n(End of file - total 392 lines)\n</content>","title":"src/lib/tui-usage-overlay.ts","metadata":{"preview":"/**\n * tui-usage-overlay.ts -- Token usage overlay for the wombo-combo TUI.\n *\n * Shows a modal overlay with overall token usage statistics and a per-task\n * breakdown. Accessible via the U keybind in the Task Browser.\n *\n * Layout:\n *   +--------------------------------------------------+\n *   | Token Usage                      Total: $12.34   |\n *   +--------------------------------------------------+\n *   | Overall:                                          |\n *   |   Input: 1.2M  Output: 450.3k  Cache: 800.0k    |\n *   |   Reasoning: 50.2k  Total: 2.5M  Steps: 42      |\n *   +--------------------------------------------------+\n *   | Per Task:                                         |\n *   | > auth-service     In: 200k Out: 100k  $2.50     |\n *   |   search-api       In: 150k Out:  80k  $1.80     |\n *   |   perf-optim       In:  50k Out:  30k  $0.60     |\n *   +--------------------------------------------------+\n *   | Tab:group by  Esc/U:close                        |","truncated":false,"loaded":[]},"time":{"start":1773484484033,"end":1773484484037}}}}
