`${selected.length - specialized.length} generalist`\n1567:         );\n1568:       }\n1569:     }\n1570:   }\n1571: \n1572:   // ---------------------------------------------------------------------------\n1573:   // Preflight confirmation\n1574:   // ---------------------------------------------------------------------------\n1575:   if (agentResolutions && agentResolutions.size > 0) {\n1576:     const isTTY = process.stdout.isTTY && process.stdin.isTTY;\n1577:     const preflight = isTTY && !opts.noTui\n1578:       ? await tuiPreflightConfirm(selected, agentResolutions, config)\n1579:       : await consolePreflightConfirm(selected, agentResolutions, config);\n1580: \n1581:     if (!preflight.proceed) {\n1582:       outputMessage(fmt, \"Launch cancelled.\");\n1583:       return;\n1584:     }\n1585: \n1586:     // Apply user's changes (rejected agents, mode changes)\n1587:     agentResolutions = preflight.agents;\n1588:   }\n1589: \n1590:   // Create wave state\n1591:   const state = createWaveState({\n1592:     baseBranch: opts.baseBranch,\n1593:     maxConcurrent: opts.maxConcurrent,\n1594:     model: opts.model ?? null,\n1595:     interactive: opts.interactive,\n1596:   });\n1597: \n1598:   // Store serialized schedule plan in wave state\n1599:   if (schedulePlan) {\n1600:     state.schedule_plan = {\n1601:       streams: schedulePlan.streams.map((s) => s.featureIds),\n1602:       merge_gates: schedulePlan.mergeGates.map((g) => ({\n1603:         feature_id: g.featureId,\n1604:         wait_for: g.waitFor,\n1605:       })),\n1606:       topological_order: schedulePlan.topologicalOrder,\n1607:     };\n1608:   }\n1609: \n1610:   // Create agent entries for all selected features\n1611:   const selectedIds = new Set(selected.map((f) => f.id));\n1612: \n1613:   // Build a map from feature ID → shared worktree path for chain reuse.\n1614:   // All features in the same chain share the worktree of the chain's first feature.\n1615:   const chainWorktreeMap = new Map<string, string>();\n1616:   if (schedulePlan) {\n1617:     for (const stream of schedulePlan.streams) {\n1618:       if (stream.featureIds.length > 1) {\n1619:         // All features in this chain share the first feature's worktree\n1620:         const sharedWtPath = worktreePath(projectRoot, stream.featureIds[0], config);\n1621:         for (const featureId of stream.featureIds) {\n1622:           chainWorktreeMap.set(featureId, sharedWtPath);\n1623:         }\n1624:       }\n1625:     }\n1626:   }\n1627: \n1628:   for (const feature of selected) {\n1629:     const branch = featureBranchName(feature.id, config);\n1630:     // Use shared worktree path for chain members, or individual path otherwise\n1631:     const wtPath = chainWorktreeMap.get(feature.id) ?? worktreePath(projectRoot, feature.id, config);\n1632:     const agent = createAgentState(feature.id, branch, wtPath, opts.maxRetries);\n1633: \n1634:     // Set effort estimate from feature spec\n1635:     const effortMinutes = parseDurationMinutes(feature.effort);\n1636:     agent.effort_estimate_ms = effortMinutes === Infinity ? null : effortMinutes * 60 * 1000;\n1637: \n1638:     // Populate dependency fields from the graph\n1639:     const graphNode = depGraph.nodes.get(feature.id);\n1640:     if (graphNode) {\n1641:       // Only track internal deps (within the selected set)\n1642:       agent.depends_on = graphNode.dependsOn.filter((d) => selectedIds.has(d));\n1643:       agent.depended_on_by = graphNode.dependedOnBy.filter((d) => selectedIds.has(d));\n1644:     }\n1645: \n1646:     // Set stream index\n1647:     if (schedulePlan) {\n1648:       agent.stream_index = getStreamForFeature(schedulePlan, feature.id);\n1649:     }\n1650: \n1651:     // Set specialized agent info from resolution\n1652:     const resolution = agentResolutions?.get(feature.id);\n1653:     if (resolution && isSpecializedAgent(resolution)) {\n1654:       agent.agent_name = resolution.name;\n1655:       agent.agent_type = resolution.agentType;\n1656:     }\n1657: \n1658:     state.agents.push(agent);\n1659:   }\n1660: \n1661:   saveState(projectRoot, state);\n1662:   if (fmt === \"text\") console.log(`Wave ${state.wave_id} created with ${selected.length} agents.`);\n1663: \n1664:   // Launch agents up to max_concurrent\n1665:   if (opts.interactive) {\n1666:     await launchWaveInteractive(projectRoot, state, selected, opts, agentResolutions);\n1667:   } else {\n1668:     await launchWaveHeadless(projectRoot, state, selected, opts, agentResolutions);\n1669:   }\n1670: }\n\n(End of file - total 1670 lines)\n</content>","title":"src/commands/launch.ts","metadata":{"preview":"        topological_order: schedulePlan.topologicalOrder,\n      } : null,\n    };\n\n    output(fmt, dryRunResult, () => {\n      console.log(\"Dry run — not launching agents.\");\n    });\n    return;\n  }\n\n  // ---------------------------------------------------------------------------\n  // Agent registry: resolve specialized agents for tasks with agent_type\n  // ---------------------------------------------------------------------------\n  let agentResolutions: Map<string, AgentResolution> | undefined;\n\n  if (config.agentRegistry.mode !== \"disabled\") {\n    const tasksWithAgentType = selected.filter((t) => t.agent_type);\n    if (tasksWithAgentType.length > 0) {\n      if (fmt === \"text\") console.log(`\\nResolving ${tasksWithAgentType.length} specialized agent(s) from registry...`);\n      agentResolutions = await prepareAgentDefinitions(selected, config, projectRoot);","truncated":false,"loaded":[]},"time":{"start":1773437556167,"end":1773437556169}}}}
