{"type":"tool_use","timestamp":1773437427965,"sessionID":"ses_316e48f3cffeGrhJEXdprD247G","part":{"id":"prt_ce91b9d82001n3v7znG8HHXC2v","sessionID":"ses_316e48f3cffeGrhJEXdprD247G","messageID":"msg_ce91b94b6001v7gvjMd1Rd7l0z","type":"tool","callID":"toolu_vrtx_018Pwx8hfRK2D1dXbVFtqzTj","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-agent-selection-per-feature/src/lib/task-schema.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-agent-selection-per-feature/src/lib/task-schema.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * task-schema.ts — Single source of truth for task field enums, ordering,\n3:  * required fields, and validation.\n4:  *\n5:  * Every command that needs to validate or enumerate task field values should\n6:  * import from here. No more duplicated VALID_* arrays.\n7:  */\n8: \n9: import type { TaskStatus, Priority, Difficulty, Task } from \"./tasks.js\";\n10: import { parseDurationMinutes } from \"./tasks.js\";\n11: import { validateId, type ValidationResult } from \"./validate.js\";\n12: \n13: // ---------------------------------------------------------------------------\n14: // Canonical enum arrays (order matters: used for display and sorting)\n15: // ---------------------------------------------------------------------------\n16: \n17: export const VALID_STATUSES: readonly TaskStatus[] = [\n18:   \"backlog\",\n19:   \"planned\",\n20:   \"in_progress\",\n21:   \"blocked\",\n22:   \"in_review\",\n23:   \"done\",\n24:   \"cancelled\",\n25: ] as const;\n26: \n27: export const VALID_PRIORITIES: readonly Priority[] = [\n28:   \"critical\",\n29:   \"high\",\n30:   \"medium\",\n31:   \"low\",\n32:   \"wishlist\",\n33: ] as const;\n34: \n35: export const VALID_DIFFICULTIES: readonly Difficulty[] = [\n36:   \"trivial\",\n37:   \"easy\",\n38:   \"medium\",\n39:   \"hard\",\n40:   \"very_hard\",\n41: ] as const;\n42: \n43: // ---------------------------------------------------------------------------\n44: // Ordering maps (lower = more important / easier)\n45: // ---------------------------------------------------------------------------\n46: \n47: export const PRIORITY_ORDER: Readonly<Record<Priority, number>> = {\n48:   critical: 0,\n49:   high: 1,\n50:   medium: 2,\n51:   low: 3,\n52:   wishlist: 4,\n53: };\n54: \n55: export const DIFFICULTY_ORDER: Readonly<Record<Difficulty, number>> = {\n56:   trivial: 0,\n57:   easy: 1,\n58:   medium: 2,\n59:   hard: 3,\n60:   very_hard: 4,\n61: };\n62: \n63: // ---------------------------------------------------------------------------\n64: // _meta.yml schema\n65: // ---------------------------------------------------------------------------\n66: \n67: export interface MetaSchema {\n68:   version: string;\n69:   meta: {\n70:     created_at: string;\n71:     updated_at: string;\n72:     project: string;\n73:     generator: string;\n74:     maintainer: string;\n75:   };\n76: }\n77: \n78: export const META_REQUIRED_FIELDS = [\"version\", \"meta\"] as const;\n79: export const META_INNER_REQUIRED_FIELDS = [\n80:   \"created_at\",\n81:   \"updated_at\",\n82:   \"project\",\n83:   \"generator\",\n84:   \"maintainer\",\n85: ] as const;\n86: \n87: // ---------------------------------------------------------------------------\n88: // Task schema — required fields and array-defaulted fields\n89: // ---------------------------------------------------------------------------\n90: \n91: export const TASK_REQUIRED_FIELDS = [\"id\", \"title\", \"status\"] as const;\n92: \n93: /** Fields that must be arrays; YAML may parse absent values as null */\n94: export const TASK_ARRAY_FIELDS = [\n95:   \"depends_on\",\n96:   \"constraints\",\n97:   \"forbidden\",\n98:   \"references\",\n99:   \"notes\",\n100:   \"subtasks\",\n101: ] as const;\n102: \n103: // ---------------------------------------------------------------------------\n104: // Validation result\n105: // ---------------------------------------------------------------------------\n106: \n107: export interface SchemaIssue {\n108:   level: \"error\" | \"warning\";\n109:   taskId: string;\n110:   message: string;\n111: }\n112: \n113: // ---------------------------------------------------------------------------\n114: // Validate a single task object\n115: // ---------------------------------------------------------------------------\n116: \n117: /**\n118:  * Validate a task against the schema. Returns a list of issues (errors and\n119:  * warnings). Does NOT throw — callers decide how to handle issues.\n120:  *\n121:  * Checks:\n122:  *   - Required fields: id, title, status\n123:  *   - id format (kebab-case via validateId)\n124:  *   - status is a valid enum\n125:  *   - priority is a valid enum (if present)\n126:  *   - difficulty is a valid enum (if present)\n127:  *   - effort is a parseable ISO 8601 duration (warning if not)\n128:  *   - completion is 0-100 (warning if out of range)\n129:  *   - depends_on entries are strings (structural check only; cross-ref is\n130:  *     done by check.ts which has access to the full task set)\n131:  */\n132: export function validateTask(task: unknown): SchemaIssue[] {\n133:   const issues: SchemaIssue[] = [];\n134:   const t = task as Record<string, unknown>;\n135:   const id = typeof t?.id === \"string\" ? t.id : \"<unknown>\";\n136: \n137:   // Required fields\n138:   for (const field of TASK_REQUIRED_FIELDS) {\n139:     if (!t?.[field]) {\n140:       issues.push({ level: \"error\", taskId: id, message: `Missing required field: ${field}` });\n141:     }\n142:   }\n143: \n144:   // id format\n145:   if (typeof t?.id === \"string\") {\n146:     const idResult: ValidationResult = validateId(t.id, \"Task ID\");\n147:     if (!idResult.valid) {\n148:       issues.push({ level: \"error\", taskId: id, message: idResult.error! });\n149:     }\n150:   }\n151: \n152:   // status enum\n153:   if (t?.status && !(VALID_STATUSES as readonly string[]).includes(t.status as string)) {\n154:     issues.push({ level: \"error\", taskId: id, message: `Invalid status: \"${t.status}\"` });\n155:   }\n156: \n157:   // priority enum\n158:   if (t?.priority && !(VALID_PRIORITIES as readonly string[]).includes(t.priority as string)) {\n159:     issues.push({ level: \"error\", taskId: id, message: `Invalid priority: \"${t.priority}\"` });\n160:   }\n161: \n162:   // difficulty enum\n163:   if (t?.difficulty && !(VALID_DIFFICULTIES as readonly string[]).includes(t.difficulty as string)) {\n164:     issues.push({ level: \"error\", taskId: id, message: `Invalid difficulty: \"${t.difficulty}\"` });\n165:   }\n166: \n167:   // effort duration\n168:   if (typeof t?.effort === \"string\" && t.effort.length > 0) {\n169:     const minutes = parseDurationMinutes(t.effort);\n170:     if (minutes === Infinity) {\n171:       issues.push({ level: \"warning\", taskId: id, message: `Unparseable effort duration: \"${t.effort}\"` });\n172:     }\n173:   } else if (!t?.effort || t.effort === \"PT0S\") {\n174:     issues.push({ level: \"warning\", taskId: id, message: \"No effort estimate\" });\n175:   }\n176: \n177:   // completion range\n178:   if (typeof t?.completion === \"number\" && (t.completion < 0 || t.completion > 100)) {\n179:     issues.push({ level: \"warning\", taskId: id, message: `Completion ${t.completion} is out of range 0-100` });\n180:   }\n181: \n182:   // depends_on structural check\n183:   if (t?.depends_on != null && !Array.isArray(t.depends_on)) {\n184:     issues.push({ level: \"error\", taskId: id, message: \"depends_on must be an array\" });\n185:   }\n186: \n187:   return issues;\n188: }\n189: \n190: // ---------------------------------------------------------------------------\n191: // Validate _meta.yml\n192: // ---------------------------------------------------------------------------\n193: \n194: /**\n195:  * Validate a parsed _meta.yml object. Returns issues.\n196:  */\n197: export function validateMeta(meta: unknown): SchemaIssue[] {\n198:   const issues: SchemaIssue[] = [];\n199:   const m = meta as Record<string, unknown>;\n200:   const id = \"_meta.yml\";\n201: \n202:   if (!m?.version) {\n203:     issues.push({ level: \"error\", taskId: id, message: \"Missing required field: version\" });\n204:   }\n205: \n206:   if (!m?.meta || typeof m.meta !== \"object\") {\n207:     issues.push({ level: \"error\", taskId: id, message: \"Missing required field: meta\" });\n208:     return issues; // Can't check inner fields\n209:   }\n210: \n211:   const inner = m.meta as Record<string, unknown>;\n212:   for (const field of META_INNER_REQUIRED_FIELDS) {\n213:     if (!inner[field]) {\n214:       issues.push({ level: \"warning\", taskId: id, message: `Missing meta field: ${field}` });\n215:     }\n216:   }\n217: \n218:   return issues;\n219: }\n\n(End of file - total 219 lines)\n</content>","title":"src/lib/task-schema.ts","metadata":{"preview":"/**\n * task-schema.ts — Single source of truth for task field enums, ordering,\n * required fields, and validation.\n *\n * Every command that needs to validate or enumerate task field values should\n * import from here. No more duplicated VALID_* arrays.\n */\n\nimport type { TaskStatus, Priority, Difficulty, Task } from \"./tasks.js\";\nimport { parseDurationMinutes } from \"./tasks.js\";\nimport { validateId, type ValidationResult } from \"./validate.js\";\n\n// ---------------------------------------------------------------------------\n// Canonical enum arrays (order matters: used for display and sorting)\n// ---------------------------------------------------------------------------\n\nexport const VALID_STATUSES: readonly TaskStatus[] = [\n  \"backlog\",\n  \"planned\",\n  \"in_progress\",","truncated":false,"loaded":[]},"time":{"start":1773437427961,"end":1773437427964}}}}
{"type":"tool_use","timestamp":1773437428307,"sessionID":"ses_316e48f3cffeGrhJEXdprD247G","part":{"id":"prt_ce91ba0fa001WhLnEGtSlpWDYo","sessionID":"ses_316e48f3cffeGrhJEXdprD247G","messageID":"msg_ce91b94b6001v7gvjMd1Rd7l0z","type":"tool","callID":"toolu_vrtx_01AKaucU8hXpSRxtZhxpWnBY","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-agent-selection-per-feature/src/lib/templates.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-agent-selection-per-feature/src/lib/templates.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * templates.ts — Resolve paths to bundled template files, render agent\n3:  * definitions, and compose patched agent definitions from imported agents.\n4:  *\n5:  * Template architecture:\n6:  *\n7:  *   generalist-agent.md          — standalone agent definition (no imported base)\n8:  *   wc-patch.description.end.md  — appended to imported agent's frontmatter description\n9:  *   wc-patch.body.start.md       — prepended to imported agent's body\n10:  *   wc-patch.body.end.md         — appended to imported agent's body\n11:  *\n12:  * Conditional blocks (portless, browser testing) are injected programmatically\n13:  * by the render/patch functions based on config — never left as \"if enabled\"\n14:  * prose for the LLM to interpret.\n15:  */\n16: \n17: import { join, dirname, resolve } from \"node:path\";\n18: import { existsSync, readFileSync, writeFileSync, mkdirSync } from \"node:fs\";\n19: import YAML from \"yaml\";\n20: import type { WomboConfig } from \"../config.js\";\n21: import { isPortlessAvailable } from \"./portless.js\";\n22: import { normalizeAgentFormat } from \"./format-converter.js\";\n23: \n24: // ---------------------------------------------------------------------------\n25: // Template Directory & Paths\n26: // ---------------------------------------------------------------------------\n27: \n28: const TEMPLATES_DIR = join(dirname(import.meta.dir), \"templates\");\n29: \n30: /** Standalone generalist agent template. */\n31: export const GENERALIST_TEMPLATE_PATH = join(TEMPLATES_DIR, \"generalist-agent.md\");\n32: \n33: /** Patch: text appended to an imported agent's frontmatter `description` field. */\n34: export const PATCH_DESCRIPTION_END_PATH = join(TEMPLATES_DIR, \"wc-patch.description.end.md\");\n35: \n36: /** Patch: markdown prepended to an imported agent's body. */\n37: export const PATCH_BODY_START_PATH = join(TEMPLATES_DIR, \"wc-patch.body.start.md\");\n38: \n39: /** Patch: markdown appended to an imported agent's body. */\n40: export const PATCH_BODY_END_PATH = join(TEMPLATES_DIR, \"wc-patch.body.end.md\");\n41: \n42: /**\n43:  * Backward-compatible alias. Code that referenced `AGENT_TEMPLATE_PATH`\n44:  * continues to work — it now points to the generalist template.\n45:  */\n46: export const AGENT_TEMPLATE_PATH = GENERALIST_TEMPLATE_PATH;\n47: \n48: // ---------------------------------------------------------------------------\n49: // Deterministic Conditional Blocks\n50: // ---------------------------------------------------------------------------\n51: \n52: /**\n53:  * Portless server-testing block. Injected by render/patch functions ONLY when\n54:  * `config.portless.enabled` is true. The agent never sees \"if portless is\n55:  * enabled\" — it either gets these instructions or it doesn't.\n56:  */\n57: const PORTLESS_BLOCK = `\n58: ## Server Testing (portless)\n59: \n60: Your environment is preconfigured with **portless** for collision-free localhost servers:\n61: \n62: - **\\`PORTLESS_ENABLED=1\\`** is set in your environment.\n63: - **Do NOT hardcode port numbers.** Use \\`process.env.PORT\\` or let your framework pick a port automatically.\n64: - **Use \\`portless run <cmd>\\`** to start dev servers (e.g., \\`portless run bun start\\`). This auto-assigns a port and gives you a stable \\`.localhost\\` URL via \\`PORTLESS_URL\\`.\n65: - **Check \\`PORTLESS_URL\\`** in your environment for the stable URL assigned to your worktree's server.\n66: - Multiple agents can run dev servers simultaneously without port conflicts — portless handles routing through its proxy.\n67: - **Never hardcode port numbers.** Always use the portless-assigned port.\n68: `;\n69: \n70: /**\n71:  * TDD red-green-refactor block. Injected by render/patch functions ONLY when\n72:  * `config.tdd.enabled` is true. The agent never sees \"if TDD is enabled\" —\n73:  * it either gets these instructions or it doesn't.\n74:  *\n75:  * The `{{testCommand}}` placeholder is replaced at render time.\n76:  */\n77: const TDD_BLOCK = `\n78: ## Test-Driven Development (TDD)\n79: \n80: You MUST follow the **red-green-refactor** TDD cycle for all implementation work:\n81: \n82: ### The TDD Cycle\n83: \n84: 1. **🔴 Red — Write a failing test first**\n85:    - Before writing any implementation code, write a test that describes the desired behavior.\n86:    - Use Bun's built-in test runner. Create test files alongside source files using the \\`.test.ts\\` naming convention.\n87:    - The test MUST fail initially — this proves the test is actually testing something.\n88: \n89: 2. **🔴 Verify the test fails**\n90:    - Run \\`{{testCommand}}\\` and confirm the new test fails with the expected error.\n91:    - If the test passes without implementation, the test is not testing the right thing — rewrite it.\n92: \n93: 3. **🟢 Green — Write minimal code to pass**\n94:    - Implement just enough production code to make the failing test pass.\n95:    - Do NOT write more code than necessary to satisfy the test.\n96:    - Do NOT add features or handle edge cases not covered by a test yet.\n97: \n98: 4. **🟢 Verify the test passes**\n99:    - Run \\`{{testCommand}}\\` and confirm ALL tests pass (both new and existing).\n100:    - If any test fails, fix the implementation — do NOT modify the test to make it pass (unless the test itself is wrong).\n101: \n102: 5. **🔵 Refactor**\n103:    - Clean up the implementation while keeping all tests green.\n104:    - Extract helpers, rename variables, simplify logic — but run \\`{{testCommand}}\\` after each change.\n105:    - If a refactor breaks a test, undo the refactor and try a different approach.\n106: \n107: ### TDD Rules\n108: \n109: - **Never skip the red step.** Every new behavior starts with a failing test.\n110: - **One behavior per cycle.** Each red-green-refactor iteration should cover exactly one small behavior or edge case.\n111: - **Tests are first-class code.** Keep them readable, well-named, and focused.\n112: - **Run tests frequently.** Run \\`{{testCommand}}\\` after every meaningful change — not just at the end.\n113: - **Commit at green.** Each commit should have all tests passing. Use the cycle boundaries as natural commit points.\n114: \n115: ### Test File Conventions\n116: \n117: - Place test files next to the source: \\`src/foo.ts\\` → \\`src/foo.test.ts\\` (or \\`tests/foo.test.ts\\`)\n118: - Use descriptive test names: \\`test(\"returns empty array when input is null\", ...)\\`\n119: - Import from \\`bun:test\\`: \\`import { describe, test, expect } from \"bun:test\";\\`\n120: `;\n121: \n122: /**\n123:  * Build the TDD block with the configured test command substituted in.\n124:  */\n125: function buildTddBlock(config: WomboConfig): string {\n126:   return TDD_BLOCK.replace(/\\{\\{testCommand\\}\\}/g, config.tdd.testCommand);\n127: }\n128: \n129: // ---------------------------------------------------------------------------\n130: // Placeholder Substitution\n131: // ---------------------------------------------------------------------------\n132: \n133: /**\n134:  * Default runtime description used when no project-specific value is available.\n135:  */\n136: const DEFAULT_RUNTIME = \"Bun (not Node). TypeScript, strict mode, ESM only.\";\n137: \n138: /**\n139:  * Replace {{placeholders}} in template content with config-derived values.\n140:  *\n141:  * Supported placeholders:\n142:  *   - {{tasksDir}}       — tasks directory name (e.g. \"tasks\")\n143:  *   - {{branchPrefix}}   — git branch prefix (e.g. \"feature/\")\n144:  *   - {{buildCommand}}   — build command (e.g. \"bun run build\")\n145:  *   - {{runtime}}        — project runtime description\n146:  *   - {{project}}        — project directory name\n147:  */\n148: function applyPlaceholders(\n149:   content: string,\n150:   config: WomboConfig,\n151:   projectRoot: string\n152: ): string {\n153:   const projectName = projectRoot.split(\"/\").pop() ?? \"project\";\n154:   return content\n155:     .replace(/\\{\\{tasksDir\\}\\}/g, config.tasksDir)\n156:     .replace(/\\{\\{branchPrefix\\}\\}/g, config.git.branchPrefix)\n157:     .replace(/\\{\\{buildCommand\\}\\}/g, config.build.command)\n158:     .replace(/\\{\\{runtime\\}\\}/g, DEFAULT_RUNTIME)\n159:     .replace(/\\{\\{project\\}\\}/g, projectName);\n160: }\n161: \n162: // ---------------------------------------------------------------------------\n163: // Frontmatter Parsing\n164: // ---------------------------------------------------------------------------\n165: \n166: /**\n167:  * Split a markdown file with YAML frontmatter into its two parts.\n168:  * Returns the raw YAML string (without delimiters) and the body.\n169:  */\n170: function splitFrontmatter(md: string): { yaml: string; body: string } {\n171:   const match = md.match(/^---\\r?\\n([\\s\\S]*?)\\r?\\n---\\r?\\n?([\\s\\S]*)$/);\n172:   if (!match) {\n173:     return { yaml: \"\", body: md };\n174:   }\n175:   return { yaml: match[1], body: match[2] };\n176: }\n177: \n178: /**\n179:  * Reassemble frontmatter YAML and body into a markdown string.\n180:  */\n181: function joinFrontmatter(yaml: string, body: string): string {\n182:   if (!yaml.trim()) return body;\n183:   return `---\\n${yaml.trimEnd()}\\n---\\n${body}`;\n184: }\n185: \n186: // ---------------------------------------------------------------------------\n187: // Generalist Agent Rendering\n188: // ---------------------------------------------------------------------------\n189: \n190: /**\n191:  * Render the standalone generalist agent template.\n192:  *\n193:  * This is the default agent definition for projects that don't import a\n194:  * specialized agent from an external registry. Portless instructions are\n195:  * injected deterministically based on config.\n196:  */\n197: export function renderGeneralistAgent(\n198:   config: WomboConfig,\n199:   projectRoot: string\n200: ): string {\n201:   let raw = readFileSync(GENERALIST_TEMPLATE_PATH, \"utf-8\");\n202: \n203:   // Deterministic portless injection\n204:   if (config.portless.enabled && isPortlessAvailable(config)) {\n205:     // Insert portless block before \"## What You Must Never Do\" (or at end)\n206:     const neverDoMarker = \"## What You Must Never Do\";\n207:     const idx = raw.indexOf(neverDoMarker);\n208:     if (idx !== -1) {\n209:       raw = raw.slice(0, idx) + PORTLESS_BLOCK + \"\\n\" + raw.slice(idx);\n210:     } else {\n211:       raw += \"\\n\" + PORTLESS_BLOCK;\n212:     }\n213:   }\n214: \n215:   // Deterministic TDD injection\n216:   if (config.tdd.enabled) {\n217:     const tddContent = buildTddBlock(config);\n218:     const neverDoMarker = \"## What You Must Never Do\";\n219:     const idx = raw.indexOf(neverDoMarker);\n220:     if (idx !== -1) {\n221:       raw = raw.slice(0, idx) + tddContent + \"\\n\" + raw.slice(idx);\n222:     } else {\n223:       raw += \"\\n\" + tddContent;\n224:     }\n225:   }\n226: \n227:   return applyPlaceholders(raw, config, projectRoot);\n228: }\n229: \n230: // ---------------------------------------------------------------------------\n231: // Imported Agent Patching\n232: // ---------------------------------------------------------------------------\n233: \n234: /**\n235:  * Patch an imported agent definition (e.g. from agency-agents) with\n236:  * wombo-combo operational context.\n237:  *\n238:  * Composition order:\n239:  *   1. Parse the imported agent's frontmatter and body\n240:  *   2. Append wc-patch.description.end to the `description` frontmatter field\n241:  *   3. Prepend wc-patch.body.start to the body\n242:  *   4. Append wc-patch.body.end to the body\n243:  *   5. Conditionally inject portless block (deterministic, based on config)\n244:  *   6. Apply {{placeholder}} substitution to the entire result\n245:  *\n246:  * @param rawAgentMd  — raw markdown content of the imported agent file\n247:  * @param config      — wombo-combo project config\n248:  * @param projectRoot — absolute path to the project root\n249:  */\n250: export function patchImportedAgent(\n251:   rawAgentMd: string,\n252:   config: WomboConfig,\n253:   projectRoot: string\n254: ): string {\n255:   // Normalize agency-agents format to woco-compatible format before patching.\n256:   // If the content is already in woco format, this is a no-op.\n257:   const normalizedMd = normalizeAgentFormat(rawAgentMd);\n258: \n259:   const { yaml: rawYaml, body: rawBody } = splitFrontmatter(normalizedMd);\n260: \n261:   // --- Patch frontmatter description ---\n262:   let patchedYaml = rawYaml;\n263:   if (rawYaml) {\n264:     try {\n265:       const descPatchRaw = readFileSync(PATCH_DESCRIPTION_END_PATH, \"utf-8\").trim();\n266:       if (descPatchRaw) {\n267:         const doc = YAML.parseDocument(rawYaml);\n268:         const currentDesc = doc.get(\"description\");\n269:         if (typeof currentDesc === \"string\") {\n270:           doc.set(\"description\", currentDesc.trimEnd() + \"\\n\\n\" + descPatchRaw);\n271:         } else {\n272:           // No description field — add one\n273:           doc.set(\"description\", descPatchRaw);\n274:         }\n275:         // Ensure mode is set for wombo-combo compatibility\n276:         if (!doc.has(\"mode\")) {\n277:           doc.set(\"mode\", \"primary\");\n278:         }\n279:         patchedYaml = YAML.stringify(doc, { lineWidth: 0 }).trimEnd();\n280:       }\n281:     } catch {\n282:       // Patch file missing or YAML parse error — proceed without patching\n283:     }\n284:   }\n285: \n286:   // --- Patch body ---\n287:   let patchedBody = rawBody;\n288: \n289:   // Prepend body.start\n290:   try {\n291:     const bodyStart = readFileSync(PATCH_BODY_START_PATH, \"utf-8\");\n292:     if (bodyStart.trim()) {\n293:       patchedBody = bodyStart + patchedBody;\n294:     }\n295:   } catch {\n296:     // Patch file missing — skip\n297:   }\n298: \n299:   // Append body.end\n300:   try {\n301:     const bodyEnd = readFileSync(PATCH_BODY_END_PATH, \"utf-8\");\n302:     if (bodyEnd.trim()) {\n303:       patchedBody = patchedBody.trimEnd() + \"\\n\" + bodyEnd;\n304:     }\n305:   } catch {\n306:     // Patch file missing — skip\n307:   }\n308: \n309:   // Deterministic portless injection (appended after body.end)\n310:   if (config.portless.enabled && isPortlessAvailable(config)) {\n311:     patchedBody = patchedBody.trimEnd() + \"\\n\" + PORTLESS_BLOCK;\n312:   }\n313: \n314:   // Deterministic TDD injection (appended after portless or body.end)\n315:   if (config.tdd.enabled) {\n316:     patchedBody = patchedBody.trimEnd() + \"\\n\" + buildTddBlock(config);\n317:   }\n318: \n319:   // --- Reassemble & substitute placeholders ---\n320:   const composed = joinFrontmatter(patchedYaml, patchedBody);\n321:   return applyPlaceholders(composed, config, projectRoot);\n322: }\n323: \n324: // ---------------------------------------------------------------------------\n325: // Backward Compatibility\n326: // ---------------------------------------------------------------------------\n327: \n328: /**\n329:  * Render the agent template. Backward-compatible wrapper around\n330:  * `renderGeneralistAgent` — existing code that calls this function\n331:  * continues to work unchanged.\n332:  */\n333: export function renderAgentTemplate(\n334:   config: WomboConfig,\n335:   projectRoot: string\n336: ): string {\n337:   return renderGeneralistAgent(config, projectRoot);\n338: }\n339: \n340: // ---------------------------------------------------------------------------\n341: // Agent Definition Guard\n342: // ---------------------------------------------------------------------------\n343: \n344: /**\n345:  * Ensure the agent definition file exists at the expected path.\n346:  * If missing, reinstall from the bundled generalist template and warn.\n347:  *\n348:  * Called at the start of `woco launch` to prevent the failure mode where\n349:  * agents spawn without their agent definition file.\n350:  *\n351:  * @returns true if the file was reinstalled, false if it already existed.\n352:  */\n353: export function ensureAgentDefinition(\n354:   projectRoot: string,\n355:   config: WomboConfig\n356: ): boolean {\n357:   const agentDir = resolve(projectRoot, \".opencode\", \"agents\");\n358:   const agentDefPath = resolve(agentDir, `${config.agent.name}.md`);\n359: \n360:   if (existsSync(agentDefPath)) {\n361:     return false;\n362:   }\n363: \n364:   // Agent definition missing — reinstall from bundled template\n365:   console.warn(\n366:     `\\x1b[33m[WARNING]\\x1b[0m Agent definition not found: .opencode/agents/${config.agent.name}.md`\n367:   );\n368:   console.warn(`  Reinstalling from bundled generalist template...`);\n369: \n370:   try {\n371:     mkdirSync(agentDir, { recursive: true });\n372:     const content = renderGeneralistAgent(config, projectRoot);\n373:     writeFileSync(agentDefPath, content, \"utf-8\");\n374:     console.warn(`  Restored .opencode/agents/${config.agent.name}.md\\n`);\n375:     return true;\n376:   } catch (err: any) {\n377:     console.error(\n378:       `  Failed to restore agent definition: ${err.message}`\n379:     );\n380:     console.error(\n381:       `  Agents may launch without their definition file.\\n`\n382:     );\n383:     return false;\n384:   }\n385: }\n\n(End of file - total 385 lines)\n</content>","title":"src/lib/templates.ts","metadata":{"preview":"/**\n * templates.ts — Resolve paths to bundled template files, render agent\n * definitions, and compose patched agent definitions from imported agents.\n *\n * Template architecture:\n *\n *   generalist-agent.md          — standalone agent definition (no imported base)\n *   wc-patch.description.end.md  — appended to imported agent's frontmatter description\n *   wc-patch.body.start.md       — prepended to imported agent's body\n *   wc-patch.body.end.md         — appended to imported agent's body\n *\n * Conditional blocks (portless, browser testing) are injected programmatically\n * by the render/patch functions based on config — never left as \"if enabled\"\n * prose for the LLM to interpret.\n */\n\nimport { join, dirname, resolve } from \"node:path\";\nimport { existsSync, readFileSync, writeFileSync, mkdirSync } from \"node:fs\";\nimport YAML from \"yaml\";\nimport type { WomboConfig } from \"../config.js\";","truncated":false,"loaded":[]},"time":{"start":1773437428302,"end":1773437428306}}}}
{"type":"tool_use","timestamp":1773437428660,"sessionID":"ses_316e48f3cffeGrhJEXdprD247G","part":{"id":"prt_ce91ba2500016Hs3I3PP9gUBo8","sessionID":"ses_316e48f3cffeGrhJEXdprD247G","messageID":"msg_ce91b94b6001v7gvjMd1Rd7l0z","type":"tool","callID":"toolu_vrtx_013EC4mzYNQuayfcG45brPrc","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-agent-selection-per-feature/src/commands/launch.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-agent-selection-per-feature/src/commands/launch.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * launch.ts — Launch a wave of agents.\n3:  *\n4:  * Usage: woco launch [selection options] [launch options]\n5:  *\n6:  * This is the primary entry point for starting a new wave. It selects features\n7:  * from the features file, creates a wave state, sets up worktrees, and launches\n8:  * agent processes (either headless or interactive via dmux/tmux).\n9:  *\n10:  * IMPORTANT: This file also exports shared helper functions that are reused\n11:  * by resume.ts and other commands:\n12:  *   - launchSingleHeadless\n13:  *   - handleBuildVerification\n14:  *   - handleRetry\n15:  *   - launchNextQueued\n16:  */\n17: \n18: import { execSync } from \"node:child_process\";\n19: import { existsSync, readFileSync } from \"node:fs\";\n20: import { resolve } from \"node:path\";\n21: import type { WomboConfig } from \"../config.js\";\n22: import type { Feature, SelectionOptions, Priority, Difficulty } from \"../lib/tasks.js\";\n23: import { loadFeatures, selectFeatures, parseDurationMinutes, saveFeatures } from \"../lib/tasks.js\";\n24: import {\n25:   loadState,\n26:   saveState,\n27:   createWaveState,\n28:   createAgentState,\n29:   updateAgent,\n30:   activeAgents,\n31:   queuedAgents,\n32:   readyToLaunchAgents,\n33:   areAgentDepsReady,\n34:   cancelDownstream,\n35:   isWaveComplete,\n36:   type WaveState,\n37:   type AgentState,\n38:   type SerializedSchedulePlan,\n39: } from \"../lib/state.js\";\n40: import {\n41:   createWorktree,\n42:   installDeps,\n43:   featureBranchName,\n44:   worktreePath,\n45:   worktreeReady,\n46:   branchHasChanges,\n47:   branchExists,\n48:   removeWorktree,\n49:   log as wtLog,\n50: } from \"../lib/worktree.js\";\n51: import { generatePrompt, generateConflictResolutionPrompt } from \"../lib/prompt.js\";\n52: import {\n53:   launchHeadless,\n54:   retryHeadless,\n55:   launchInteractive,\n56:   retryInteractive,\n57:   launchConflictResolver,\n58:   isProcessRunning,\n59:   getMultiplexerName,\n60: } from \"../lib/launcher.js\";\n61: import { ProcessMonitor } from \"../lib/monitor.js\";\n62: import { runBuild, runFullVerification, type FullVerificationOptions } from \"../lib/verifier.js\";\n63: import { mergeBranch, mergeBaseIntoFeature, pushBaseBranch, canMerge, enqueueMerge } from \"../lib/merger.js\";\n64: import {\n65:   printDashboard,\n66:   printFeatureSelection,\n67:   printAgentUpdate,\n68: } from \"../lib/ui.js\";\n69: import { WomboTUI } from \"../lib/tui.js\";\n70: import { ensureAgentDefinition } from \"../lib/templates.js\";\n71: import {\n72:   buildDepGraph,\n73:   validateDepGraph,\n74:   buildSchedulePlan,\n75:   formatSchedulePlan,\n76:   getStreamForFeature,\n77:   type DepGraph,\n78:   type SchedulePlan,\n79: } from \"../lib/dependency-graph.js\";\n80: import { ensureProxyRunning, isPortlessAvailable, portlessUrl } from \"../lib/portless.js\";\n81: import { output, outputError, outputMessage, type OutputFormat } from \"../lib/output.js\";\n82: import {\n83:   detectMultiplexer,\n84:   muxAttachCommand,\n85:   muxListCommand,\n86: } from \"../lib/multiplexer.js\";\n87: import { exportWaveHistory } from \"../lib/history.js\";\n88: import {\n89:   prepareAgentDefinitions,\n90:   isSpecializedAgent,\n91:   writeAgentToWorktree,\n92:   type AgentResolution,\n93: } from \"../lib/agent-registry.js\";\n94: import { patchImportedAgent } from \"../lib/templates.js\";\n95: import {\n96:   tuiPreflightConfirm,\n97:   consolePreflightConfirm,\n98: } from \"../lib/preflight.js\";\n99: \n100: // ---------------------------------------------------------------------------\n101: // Constants\n102: // ---------------------------------------------------------------------------\n103: \n104: /**\n105:  * Delay (ms) between sequential agent launches to avoid SQLite race conditions.\n106:  * Each agent spawns its own process which runs DB migrations on startup.\n107:  * Launching them simultaneously causes `CREATE TABLE` collisions.\n108:  */\n109: const LAUNCH_STAGGER_MS = 500;\n110: \n111: // ---------------------------------------------------------------------------\n112: // Types\n113: // ---------------------------------------------------------------------------\n114: \n115: export interface LaunchCommandOptions {\n116:   projectRoot: string;\n117:   config: WomboConfig;\n118:   // Selection\n119:   topPriority?: number;\n120:   quickestWins?: number;\n121:   priority?: Priority;\n122:   difficulty?: Difficulty;\n123:   features?: string[];\n124:   allReady?: boolean;\n125:   // Launch\n126:   maxConcurrent: number;\n127:   model?: string;\n128:   interactive: boolean;\n129:   dryRun: boolean;\n130:   baseBranch: string;\n131:   maxRetries: number;\n132:   noTui: boolean;\n133:   autoPush: boolean;\n134:   // Output\n135:   outputFmt?: OutputFormat;\n136: }\n137: \n138: // ---------------------------------------------------------------------------\n139: // Shared Helpers (exported for resume.ts and others)\n140: // ---------------------------------------------------------------------------\n141: \n142: /**\n143:  * Mark a feature as done in the features file after a successful merge.\n144:  * Updates status to \"done\", completion to 100, and sets ended_at.\n145:  *\n146:  * GUARD: Verifies that the feature branch has actually been merged into\n147:  * baseBranch before allowing the status change. This prevents callers\n148:  * from accidentally marking verified-but-unmerged features as done.\n149:  */\n150: export function markFeatureDone(\n151:   projectRoot: string,\n152:   featureId: string,\n153:   config: WomboConfig,\n154:   baseBranch: string\n155: ): void {\n156:   try {\n157:     // Verify the feature branch was actually merged into base\n158:     const branch = featureBranchName(featureId, config);\n159:     try {\n160:       execSync(`git merge-base --is-ancestor \"${branch}\" \"${baseBranch}\"`, {\n161:         cwd: projectRoot,\n162:         stdio: \"pipe\",\n163:       });\n164:     } catch {\n165:       // git merge-base --is-ancestor exits non-zero if NOT an ancestor\n166:       console.error(\n167:         `Warning: ${featureId} branch \"${branch}\" is not merged into \"${baseBranch}\" — refusing to mark as done`\n168:       );\n169:       return;\n170:     }\n171: \n172:     const data = loadFeatures(projectRoot, config);\n173:     const feature = data.tasks.find((f: Feature) => f.id === featureId);\n174:     if (feature && feature.status !== \"done\") {\n175:       feature.status = \"done\";\n176:       feature.completion = 100;\n177:       feature.ended_at = new Date().toISOString();\n178:       saveFeatures(projectRoot, config, data);\n179:     }\n180:   } catch (err: any) {\n181:     // Non-fatal — log but don't crash the wave\n182:     console.error(`Warning: failed to update feature status for ${featureId}: ${err.message}`);\n183:   }\n184: }\n185: \n186: /**\n187:  * Launch a single agent in headless mode.\n188:  * Sets up worktree, installs deps, generates prompt, launches agent process.\n189:  * If agentResolutions is provided and contains a specialized agent for this\n190:  * feature, the patched agent definition is written into the worktree.\n191:  */\n192: export async function launchSingleHeadless(\n193:   projectRoot: string,\n194:   state: WaveState,\n195:   agent: AgentState,\n196:   feature: Feature,\n197:   monitor: ProcessMonitor,\n198:   config: WomboConfig,\n199:   model?: string,\n200:   agentResolutions?: Map<string, AgentResolution>\n201: ): Promise<void> {\n202:   updateAgent(state, agent.feature_id, {\n203:     status: \"installing\",\n204:     started_at: new Date().toISOString(),\n205:     activity: \"setting up worktree...\",\n206:   });\n207:   saveState(projectRoot, state);\n208: \n209:   try {\n210:     // Check if this agent is reusing a chain predecessor's worktree\n211:     const isChainReuse = agent.depends_on.some((depId) => {\n212:       const depAgent = state.agents.find((a) => a.feature_id === depId);\n213:       return depAgent && depAgent.worktree === agent.worktree;\n214:     });\n215: \n216:     if (isChainReuse && worktreeReady(agent.worktree)) {\n217:       // Chain worktree reuse: the worktree already exists from a predecessor.\n218:       // Create a new branch for this feature and switch the worktree to it.\n219:       wtLog(agent.feature_id, \"reusing chain worktree — switching branch...\");\n220:       updateAgent(state, agent.feature_id, { activity: \"switching branch (chain reuse)...\" });\n221: \n222:       try {\n223:         // Create the new feature branch from base (in the worktree)\n224:         execSync(`git checkout -B \"${agent.branch}\" \"${state.base_branch}\"`, {\n225:           cwd: agent.worktree,\n226:           stdio: \"pipe\",\n227:         });\n228:         wtLog(agent.feature_id, `switched to branch ${agent.branch}`);\n229:       } catch (branchErr: any) {\n230:         wtLog(agent.feature_id, `branch switch failed: ${branchErr.message}`);\n231:         // Fall through to normal worktree creation\n232:         await createWorktree(projectRoot, feature.id, state.base_branch, config);\n233:       }\n234:     } else if (worktreeReady(agent.worktree)) {\n235:       // Skip worktree setup if already ready (resume case)\n236:       wtLog(agent.feature_id, \"worktree already exists, skipping setup\");\n237:     } else {\n238:       // Create worktree (async — doesn't block other agents)\n239:       await createWorktree(projectRoot, feature.id, state.base_branch, config);\n240: \n241:       // Install dependencies (async)\n242:       updateAgent(state, agent.feature_id, { activity: \"installing deps...\" });\n243:       await installDeps(agent.worktree, feature.id, config);\n244:     }\n245: \n246:     // Generate prompt\n247:     const prompt = generatePrompt(feature, state.base_branch, config);\n248: \n249:     // Write specialized agent to worktree if applicable\n250:     const resolution = agentResolutions?.get(feature.id);\n251:     const agentName = agent.agent_name ?? undefined;\n252:     if (resolution && isSpecializedAgent(resolution)) {\n253:       try {\n254:         const patchedContent = patchImportedAgent(resolution.rawContent, config, projectRoot);\n255:         writeAgentToWorktree(agent.worktree, resolution.name, patchedContent);\n256:         wtLog(agent.feature_id, `wrote specialized agent: ${resolution.name}`);\n257:       } catch (err: any) {\n258:         wtLog(agent.feature_id, `WARN: failed to write specialized agent, using generalist: ${err.message}`);\n259:       }\n260:     }\n261: \n262:     // Launch agent\n263:     wtLog(agent.feature_id, \"launching agent...\");\n264:     const result = launchHeadless({\n265:       worktreePath: agent.worktree,\n266:       featureId: feature.id,\n267:       prompt,\n268:       model,\n269:       config,\n270:       agentName,\n271:     });\n272: \n273:     updateAgent(state, agent.feature_id, {\n274:       status: \"running\",\n275:       pid: result.pid,\n276:       activity: \"starting...\",\n277:     });\n278:     saveState(projectRoot, state);\n279: \n280:     monitor.addProcess(feature.id, result.process);\n281:     wtLog(agent.feature_id, `running (PID: ${result.pid})`);\n282:   } catch (err: any) {\n283:     updateAgent(state, agent.feature_id, {\n284:       status: \"failed\",\n285:       error: err.message,\n286:       activity: null,\n287:       completed_at: new Date().toISOString(),\n288:     });\n289:     saveState(projectRoot, state);\n290:     wtLog(agent.feature_id, `SETUP FAILED: ${err.message.split(\"\\n\")[0]}`);\n291:   }\n292: }\n293: \n294: /**\n295:  * Handle build verification after agent completion.\n296:  * Runs build, auto-merges on pass, retries on failure if retries remain.\n297:  *\n298:  * ASYNC — runs build and merge without blocking the event loop.\n299:  */\n300: export async function handleBuildVerification(\n301:   projectRoot: string,\n302:   state: WaveState,\n303:   agent: AgentState,\n304:   feature: Feature,\n305:   config: WomboConfig,\n306:   model?: string,\n307:   monitor?: ProcessMonitor,\n308:   tddOpts?: FullVerificationOptions\n309: ): Promise<void> {\n310:   try {\n311:     printAgentUpdate(agent, \"verifying build...\");\n312: \n313:     // Use full verification pipeline (build + optional browser tests + optional TDD)\n314:     const fullResult = await runFullVerification(agent.worktree, agent.feature_id, config, tddOpts);\n315:     const buildResult = fullResult.build;\n316: \n317:     // Report browser test status if they ran\n318:     if (fullResult.browser.ran && fullResult.browser.browserResult) {\n319:       const br = fullResult.browser.browserResult;\n320:       printAgentUpdate(\n321:         agent,\n322:         `BROWSER: ${br.summary} (${Math.round(br.totalDurationMs / 1000)}s)`\n323:       );\n324:     } else if (fullResult.browser.skipReason && config.browser.enabled) {\n325:       printAgentUpdate(agent, `BROWSER: skipped — ${fullResult.browser.skipReason}`);\n326:     }\n327: \n328:     // Report TDD verification status if it ran\n329:     if (fullResult.tdd.ran) {\n330:       const tdd = fullResult.tdd;\n331:       const tddIcon = tdd.passed ? \"✓\" : \"✗\";\n332:       printAgentUpdate(agent, `TDD: ${tddIcon} ${tdd.summary}`);\n333:       if (tdd.hasWarnings) {\n334:         printAgentUpdate(agent, `TDD: ⚠ Missing tests detected (non-blocking)`);\n335:       }\n336:     } else if (fullResult.tdd.skipReason && config.tdd?.enabled) {\n337:       printAgentUpdate(agent, `TDD: skipped — ${fullResult.tdd.skipReason}`);\n338:     }\n339: \n340:     if (fullResult.overallPassed) {\n341:       updateAgent(state, agent.feature_id, {\n342:         status: \"verified\",\n343:         build_passed: true,\n344:         build_output: null,\n345:       });\n346:       saveState(projectRoot, state);\n347:       printAgentUpdate(agent, `BUILD PASSED (${Math.round(buildResult.durationMs / 1000)}s)`);\n348: \n349:       // Auto-merge: attempt merge + conflict resolution\n350:       await attemptMerge(projectRoot, state, agent, feature, config, model);\n351:     } else {\n352:       const errorSummary = fullResult.combinedErrorSummary;\n353: \n354:       if (agent.retries < agent.max_retries) {\n355:         updateAgent(state, agent.feature_id, {\n356:           status: \"retry\",\n357:           retries: agent.retries + 1,\n358:           build_passed: false,\n359:           build_output: errorSummary,\n360:         });\n361:         saveState(projectRoot, state);\n362:         printAgentUpdate(\n363:           agent,\n364:           `VERIFICATION FAILED — retrying (${agent.retries}/${agent.max_retries})`\n365:         );\n366: \n367:         // Retry with error details\n368:         if (agent.session_id) {\n369:           const retryResult = retryHeadless({\n370:             worktreePath: agent.worktree,\n371:             featureId: agent.feature_id,\n372:             sessionId: agent.session_id,\n373:             buildErrors: errorSummary,\n374:             model,\n375:             config,\n376:           });\n377: \n378:           updateAgent(state, agent.feature_id, {\n379:             status: \"running\",\n380:             pid: retryResult.pid,\n381:           });\n382:           saveState(projectRoot, state);\n383: \n384:           // Add retry process to monitor so events are tracked\n385:           if (monitor) {\n386:             monitor.addProcess(agent.feature_id, retryResult.process);\n387:           }\n388:         } else {\n389:           // Agent has no session — reset to queued for a fresh launch\n390:           wtLog(agent.feature_id, `no session — resetting to queued for fresh launch (retry ${agent.retries}/${agent.max_retries})`);\n391:           updateAgent(state, agent.feature_id, {\n392:             status: \"queued\",\n393:             error: null,\n394:             activity: \"waiting for relaunch...\",\n395:           });\n396:           saveState(projectRoot, state);\n397:         }\n398:       } else {\n399:         updateAgent(state, agent.feature_id, {\n400:           status: \"failed\",\n401:           build_passed: false,\n402:           build_output: errorSummary,\n403:           error: `Verification failed after ${agent.max_retries} retries`,\n404:           completed_at: new Date().toISOString(),\n405:         });\n406:         saveState(projectRoot, state);\n407:         printAgentUpdate(agent, \"VERIFICATION FAILED — max retries reached\");\n408: \n409:         // Cascade failure to downstream agents\n410:         const cancelled = cancelDownstream(state, agent.feature_id);\n411:         if (cancelled.length > 0) {\n412:           printAgentUpdate(agent, `downstream cancelled: ${cancelled.join(\", \")}`);\n413:           saveState(projectRoot, state);\n414:         }\n415:       }\n416:     }\n417:   } catch (err: any) {\n418:     // Catch-all — never let build verification crash the process\n419:     printAgentUpdate(agent, `VERIFY ERROR: ${err.message?.slice(0, 100)}`);\n420:     updateAgent(state, agent.feature_id, {\n421:       status: \"failed\",\n422:       error: `Build verification error: ${err.message}`,\n423:       completed_at: new Date().toISOString(),\n424:     });\n425:     saveState(projectRoot, state);\n426:   }\n427: }\n428: \n429: /**\n430:  * Attempt to merge a verified agent's branch into the base branch.\n431:  *\n432:  * Handles conflict detection, base-into-feature merge, and resolver agent\n433:  * launch. Extracted from handleBuildVerification so it can be called\n434:  * independently (e.g., from resume's sequential merge phase).\n435:  *\n436:  * All merge operations are serialized via enqueueMerge() to prevent\n437:  * concurrent checkout races on the project root.\n438:  */\n439: export async function attemptMerge(\n440:   projectRoot: string,\n441:   state: WaveState,\n442:   agent: AgentState,\n443:   feature: Feature,\n444:   config: WomboConfig,\n445:   model?: string,\n446: ): Promise<void> {\n447:   return enqueueMerge(async () => {\n448:     printAgentUpdate(agent, \"auto-merging...\");\n449:     try {\n450:       // Pre-flight check: detect conflicts before attempting the real merge.\n451:       // This avoids the expensive merge-then-abort dance for known conflicts.\n452:       const preCheck = await canMerge(projectRoot, agent.branch, state.base_branch);\n453:       if (!preCheck.canMerge) {\n454:         printAgentUpdate(agent, `conflict detected (pre-flight) — attempting resolution...`);\n455:         await handleMergeConflict(\n456:           projectRoot, state, agent, feature, config, model,\n457:           preCheck.reason\n458:         );\n459:         return;\n460:       }\n461: \n462:       const mergeResult = await mergeBranch(projectRoot, agent.branch, state.base_branch, config);\n463: \n464:       if (mergeResult.success) {\n465:         handleMergeSuccess(projectRoot, state, agent, config, mergeResult.commitHash);\n466:         return;\n467:       }\n468: \n469:       // Merge failed despite clean pre-flight — race with another merge or\n470:       // a git state issue. Fall through to conflict resolution.\n471:       printAgentUpdate(agent, `MERGE CONFLICT — attempting resolution...`);\n472:       await handleMergeConflict(\n473:         projectRoot, state, agent, feature, config, model,\n474:         mergeResult.error ?? \"Unknown merge error\"\n475:       );\n476:     } catch (mergeErr: any) {\n477:       // Unexpected exception — stay in \"verified\" (retryable) but record the\n478:       // error so the user can see what went wrong instead of silent stalling.\n479:       printAgentUpdate(agent, `AUTO-MERGE ERROR: ${mergeErr.message?.slice(0, 100)}`);\n480:       updateAgent(state, agent.feature_id, {\n481:         error: `Auto-merge error: ${mergeErr.message}`,\n482:       });\n483:       saveState(projectRoot, state);\n484:     }\n485:   });\n486: }\n487: \n488: /**\n489:  * Handle a successful merge: update state, mark feature done, clean up.\n490:  */\n491: function handleMergeSuccess(\n492:   projectRoot: string,\n493:   state: WaveState,\n494:   agent: AgentState,\n495:   config: WomboConfig,\n496:   commitHash: string | null,\n497:   label = \"MERGED\",\n498: ): void {\n499:   updateAgent(state, agent.feature_id, {\n500:     status: \"merged\",\n501:     completed_at: new Date().toISOString(),\n502:   });\n503:   saveState(projectRoot, state);\n504:   printAgentUpdate(agent, `${label} (${commitHash?.slice(0, 7)})`);\n505: \n506:   markFeatureDone(projectRoot, agent.feature_id, config, state.base_branch);\n507: \n508:   // Clean up worktree — but preserve it if downstream agents in the same\n509:   // chain share this worktree.\n510:   const hasChainSuccessor = agent.depended_on_by.some((depId) => {\n511:     const depAgent = state.agents.find((a) => a.feature_id === depId);\n512:     return depAgent && depAgent.worktree === agent.worktree;\n513:   });\n514: \n515:   if (hasChainSuccessor) {\n516:     printAgentUpdate(agent, \"worktree preserved for chain successor\");\n517:   } else {\n518:     try {\n519:       removeWorktree(projectRoot, agent.worktree, true);\n520:       printAgentUpdate(agent, \"worktree and branch removed\");\n521:     } catch (err: any) {\n522:       // Log the failure so it's visible — stale worktrees waste disk space\n523:       printAgentUpdate(agent, `WARN: worktree cleanup failed: ${err.message?.split(\"\\n\")[0]}`);\n524:     }\n525:   }\n526: }\n527: \n528: /**\n529:  * Handle a merge conflict: merge base into feature, then either retry the\n530:  * direct merge (if base merged cleanly) or launch a resolver agent.\n531:  *\n532:  * All failure paths record the error on the agent (which stays \"verified\")\n533:  * so the merge can be retried without silently stalling.\n534:  */\n535: async function handleMergeConflict(\n536:   projectRoot: string,\n537:   state: WaveState,\n538:   agent: AgentState,\n539:   feature: Feature,\n540:   config: WomboConfig,\n541:   model: string | undefined,\n542:   mergeError: string,\n543: ): Promise<void> {\n544:   try {\n545:     // Merge base INTO the feature worktree to create conflict markers\n546:     const conflictResult = await mergeBaseIntoFeature(\n547:       agent.worktree,\n548:       state.base_branch,\n549:       config\n550:     );\n551: \n552:     if (conflictResult.error && !conflictResult.conflicting) {\n553:       // Setup itself failed — stay as \"verified\" (retryable) with error\n554:       printAgentUpdate(agent, `CONFLICT SETUP FAILED: ${conflictResult.error.slice(0, 100)}`);\n555:       updateAgent(state, agent.feature_id, {\n556:         error: `Conflict setup failed: ${conflictResult.error}`,\n557:       });\n558:       saveState(projectRoot, state);\n559:       return;\n560:     }\n561: \n562:     if (!conflictResult.conflicting) {\n563:       // Base merged cleanly into feature — retry merge into base.\n564:       printAgentUpdate(agent, \"base merged cleanly into feature — retrying merge...\");\n565:       const retryMerge = await mergeBranch(projectRoot, agent.branch, state.base_branch, config);\n566:       if (retryMerge.success) {\n567:         handleMergeSuccess(projectRoot, state, agent, config, retryMerge.commitHash, \"MERGED after rebase\");\n568:         return;\n569:       }\n570: \n571:       // Retry still failed — need conflict resolution.\n572:       // Merge base into feature again to get conflict files for the resolver.\n573:       printAgentUpdate(agent, `retry merge still failed — launching resolver agent...`);\n574:       const secondConflict = await mergeBaseIntoFeature(\n575:         agent.worktree,\n576:         state.base_branch,\n577:         config\n578:       );\n579: \n580:       const conflictFiles = secondConflict.conflicting\n581:         ? secondConflict.files\n582:         : [\"(unknown — merge direction mismatch)\"];\n583: \n584:       await launchResolverAndRetryMerge(\n585:         projectRoot, state, agent, feature, config, model,\n586:         retryMerge.error ?? mergeError, conflictFiles\n587:       );\n588:       return;\n589:     }\n590: \n591:     // There are real conflicts — launch a resolver agent\n592:     printAgentUpdate(\n593:       agent,\n594:       `${conflictResult.files.length} conflicting file(s): ${conflictResult.files.join(\", \")}`\n595:     );\n596: \n597:     await launchResolverAndRetryMerge(\n598:       projectRoot, state, agent, feature, config, model,\n599:       mergeError, conflictResult.files\n600:     );\n601:   } catch (conflictErr: any) {\n602:     // Unexpected error during conflict handling — stay \"verified\" with error\n603:     printAgentUpdate(agent, `CONFLICT RESOLUTION ERROR: ${conflictErr.message?.slice(0, 100)}`);\n604:     updateAgent(state, agent.feature_id, {\n605:       error: `Conflict resolution error: ${conflictErr.message}`,\n606:     });\n607:     saveState(projectRoot, state);\n608:   }\n609: }\n610: \n611: /**\n612:  * Launch a conflict resolver agent, wait for it to finish, re-verify build,\n613:  * and retry the merge. Supports configurable retry attempts (defaults to 1,\n614:  * up to config.defaults.maxRetries + 1).\n615:  *\n616:  * The resolver is re-launched with updated conflict state on each attempt,\n617:  * so it sees the current conflict markers, not stale ones.\n618:  */\n619: async function launchResolverAndRetryMerge(\n620:   projectRoot: string,\n621:   state: WaveState,\n622:   agent: AgentState,\n623:   feature: Feature,\n624:   config: WomboConfig,\n625:   model: string | undefined,\n626:   mergeError: string,\n627:   conflictFiles: string[]\n628: ): Promise<void> {\n629:   const maxResolverAttempts = Math.max(1, (config.defaults.maxRetries ?? 0) + 1);\n630: \n631:   for (let attempt = 1; attempt <= maxResolverAttempts; attempt++) {\n632:     const conflictPrompt = generateConflictResolutionPrompt(\n633:       feature,\n634:       state.base_branch,\n635:       mergeError,\n636:       config\n637:     );\n638: \n639:     const attemptLabel = maxResolverAttempts > 1\n640:       ? ` (attempt ${attempt}/${maxResolverAttempts})`\n641:       : \"\";\n642: \n643:     updateAgent(state, agent.feature_id, {\n644:       status: \"resolving_conflict\",\n645:       activity: `resolving ${conflictFiles.length} conflict(s)${attemptLabel}...`,\n646:     });\n647:     saveState(projectRoot, state);\n648: \n649:     const resolverResult = launchConflictResolver({\n650:       worktreePath: agent.worktree,\n651:       featureId: agent.feature_id,\n652:       prompt: conflictPrompt,\n653:       model,\n654:       config,\n655:     });\n656: \n657:     updateAgent(state, agent.feature_id, {\n658:       pid: resolverResult.pid,\n659:     });\n660:     saveState(projectRoot, state);\n661: \n662:     // Wait for the resolver process to complete, then re-verify and retry merge.\n663:     // We intentionally do NOT add the resolver to the ProcessMonitor because\n664:     // the monitor's onComplete callback would trigger handleBuildVerification\n665:     // again, causing infinite recursion. Instead we await the process directly.\n666:     const resolverExitCode = await new Promise<number | null>((resolve) => {\n667:       resolverResult.process.on(\"exit\", (code) => resolve(code));\n668:       resolverResult.process.on(\"error\", () => resolve(null));\n669:     });\n670: \n671:     printAgentUpdate(\n672:       agent,\n673:       `conflict resolver exited (code ${resolverExitCode})${attemptLabel} — re-verifying build...`\n674:     );\n675: \n676:     // Re-verify build after conflict resolution\n677:     const rebuildResult = await runBuild(agent.worktree, config);\n678: \n679:     if (!rebuildResult.passed) {\n680:       if (attempt < maxResolverAttempts) {\n681:         printAgentUpdate(agent, `POST-CONFLICT BUILD FAILED${attemptLabel} — retrying resolver...`);\n682:         continue; // Try again with a fresh resolver\n683:       }\n684:       printAgentUpdate(agent, `POST-CONFLICT BUILD FAILED (all ${maxResolverAttempts} attempts exhausted)`);\n685:       updateAgent(state, agent.feature_id, {\n686:         status: \"failed\",\n687:         build_passed: false,\n688:         build_output: rebuildResult.errorSummary,\n689:         error: \"Build failed after conflict resolution\",\n690:         completed_at: new Date().toISOString(),\n691:       });\n692:       saveState(projectRoot, state);\n693:       cancelDownstream(state, agent.feature_id);\n694:       saveState(projectRoot, state);\n695:       return;\n696:     }\n697: \n698:     printAgentUpdate(agent, \"post-conflict build passed — retrying merge...\");\n699: \n700:     const retryMerge = await mergeBranch(\n701:       projectRoot,\n702:       agent.branch,\n703:       state.base_branch,\n704:       config\n705:     );\n706: \n707:     if (retryMerge.success) {\n708:       handleMergeSuccess(\n709:         projectRoot, state, agent, config,\n710:         retryMerge.commitHash, \"MERGED after conflict resolution\"\n711:       );\n712:       return;\n713:     }\n714: \n715:     // Merge still failed after resolver. If we have attempts left, re-merge\n716:     // base into feature to refresh conflict markers and try again.\n717:     if (attempt < maxResolverAttempts) {\n718:       printAgentUpdate(agent, `POST-CONFLICT MERGE FAILED${attemptLabel} — retrying resolver...`);\n719:       const refreshConflict = await mergeBaseIntoFeature(\n720:         agent.worktree,\n721:         state.base_branch,\n722:         config\n723:       );\n724:       conflictFiles = refreshConflict.conflicting\n725:         ? refreshConflict.files\n726:         : conflictFiles;\n727:       mergeError = retryMerge.error ?? mergeError;\n728:       continue;\n729:     }\n730: \n731:     // All attempts exhausted\n732:     printAgentUpdate(agent, `POST-CONFLICT MERGE FAILED (all ${maxResolverAttempts} attempts exhausted): ${retryMerge.error}`);\n733:     updateAgent(state, agent.feature_id, {\n734:       status: \"failed\",\n735:       error: `Merge still failed after ${maxResolverAttempts} conflict resolution attempt(s): ${retryMerge.error}`,\n736:       completed_at: new Date().toISOString(),\n737:     });\n738:     saveState(projectRoot, state);\n739:     cancelDownstream(state, agent.feature_id);\n740:     saveState(projectRoot, state);\n741:     return;\n742:   }\n743: }\n744: \n745: /**\n746:  * Handle retry of a failed agent (error-based, not build-based).\n747:  *\n748:  * If the agent has a session_id, resumes the existing session with error context.\n749:  * If the agent crashed before establishing a session (session_id is null),\n750:  * resets it to \"queued\" so it gets relaunched from scratch on the next\n751:  * launchAllReady() cycle. This prevents the \"stuck retry\" state where an\n752:  * agent sits in \"retry\" forever with no process running.\n753:  */\n754: export function handleRetry(\n755:   projectRoot: string,\n756:   state: WaveState,\n757:   agent: AgentState,\n758:   monitor: ProcessMonitor,\n759:   config: WomboConfig,\n760:   model?: string\n761: ): void {\n762:   if (!agent.session_id) {\n763:     // Agent crashed before establishing a session (e.g. SQLite race condition).\n764:     // Reset to queued so it gets a fresh launch on the next cycle.\n765:     wtLog(agent.feature_id, `no session — resetting to queued for fresh launch (retry ${agent.retries}/${agent.max_retries})`);\n766:     updateAgent(state, agent.feature_id, {\n767:       status: \"queued\",\n768:       error: null,\n769:       activity: \"waiting for relaunch...\",\n770:     });\n771:     saveState(projectRoot, state);\n772:     return;\n773:   }\n774: \n775:   if (!agent.error) return;\n776: \n777:   const retryResult = retryHeadless({\n778:     worktreePath: agent.worktree,\n779:     featureId: agent.feature_id,\n780:     sessionId: agent.session_id,\n781:     buildErrors: agent.error,\n782:     model,\n783:     config,\n784:   });\n785: \n786:   updateAgent(state, agent.feature_id, {\n787:     status: \"running\",\n788:     pid: retryResult.pid,\n789:   });\n790:   saveState(projectRoot, state);\n791: \n792:   monitor.addProcess(agent.feature_id, retryResult.process);\n793: }\n794: \n795: /**\n796:  * Launch the next queued agent if capacity allows.\n797:  * Dependency-aware: only launches agents whose dependencies are satisfied.\n798:  */\n799: export async function launchNextQueued(\n800:   projectRoot: string,\n801:   state: WaveState,\n802:   featureMap: Map<string, Feature>,\n803:   monitor: ProcessMonitor,\n804:   config: WomboConfig,\n805:   model?: string,\n806:   agentResolutions?: Map<string, AgentResolution>\n807: ): Promise<void> {\n808:   const active = activeAgents(state);\n809:   const ready = readyToLaunchAgents(state);\n810: \n811:   if (active.length < state.max_concurrent && ready.length > 0) {\n812:     const next = ready[0];\n813:     const feature = featureMap.get(next.feature_id);\n814:     if (feature) {\n815:       await launchSingleHeadless(projectRoot, state, next, feature, monitor, config, model, agentResolutions);\n816:     }\n817:   }\n818: }\n819: \n820: /**\n821:  * Launch ALL ready agents up to capacity.\n822:  * After a dependency completes, multiple downstream agents may become unblocked.\n823:  * This launches as many as capacity allows, not just one.\n824:  *\n825:  * Launches are staggered to avoid SQLite race conditions.\n826:  *\n827:  * Also logs merge gate events when diamond-dependency features become unblocked.\n828:  */\n829: export async function launchAllReady(\n830:   projectRoot: string,\n831:   state: WaveState,\n832:   featureMap: Map<string, Feature>,\n833:   monitor: ProcessMonitor,\n834:   config: WomboConfig,\n835:   model?: string,\n836:   agentResolutions?: Map<string, AgentResolution>\n837: ): Promise<void> {\n838:   const active = activeAgents(state);\n839:   const ready = readyToLaunchAgents(state);\n840:   const available = state.max_concurrent - active.length;\n841: \n842:   if (available <= 0 || ready.length === 0) return;\n843: \n844:   const toLaunch = ready.slice(0, available);\n845:   for (let i = 0; i < toLaunch.length; i++) {\n846:     const next = toLaunch[i];\n847:     const feature = featureMap.get(next.feature_id);\n848:     if (!feature) continue;\n849: \n850:     // Log merge gate opening for diamond dependencies\n851:     if (next.depends_on.length > 1 && state.schedule_plan) {\n852:       const isMergeGate = state.schedule_plan.merge_gates.some(\n853:         (g) => g.feature_id === next.feature_id\n854:       );\n855:       if (isMergeGate) {\n856:         wtLog(\n857:           next.feature_id,\n858:           `merge gate opened — all ${next.depends_on.length} dependencies satisfied`\n859:         );\n860:       }\n861:     }\n862: \n863:     await launchSingleHeadless(projectRoot, state, next, feature, monitor, config, model, agentResolutions);\n864:     // Stagger between launches to avoid SQLite race conditions\n865:     if (i < toLaunch.length - 1) {\n866:       await new Promise((r) => setTimeout(r, LAUNCH_STAGGER_MS));\n867:     }\n868:   }\n869: }\n870: \n871: // ---------------------------------------------------------------------------\n872: // Post-mortem: dump failed agent logs\n873: // ---------------------------------------------------------------------------\n874: \n875: /**\n876:  * Print full log contents for every failed agent so the user can diagnose\n877:  * issues after the wave finishes. Handles missing log files gracefully.\n878:  */\n879: export function dumpFailedAgentLogs(projectRoot: string, state: WaveState): void {\n880:   const failed = state.agents.filter((a) => a.status === \"failed\");\n881:   if (failed.length === 0) return;\n882: \n883:   const logDir = resolve(projectRoot, \".wombo-combo/logs\");\n884: \n885:   console.log(\n886:     `\\n${\"=\".repeat(72)}\\n` +\n887:     `  FAILED AGENT LOGS (${failed.length} agent${failed.length > 1 ? \"s\" : \"\"})\\n` +\n888:     `${\"=\".repeat(72)}`\n889:   );\n890: \n891:   for (const agent of failed) {\n892:     const logFile = resolve(logDir, `${agent.feature_id}.log`);\n893: \n894:     console.log(\n895:       `\\n${\"─\".repeat(72)}\\n` +\n896:       `  Feature: ${agent.feature_id}\\n` +\n897:       (agent.error ? `  Error:   ${agent.error}\\n` : \"\") +\n898:       `${\"─\".repeat(72)}`\n899:     );\n900: \n901:     if (!existsSync(logFile)) {\n902:       console.log(\"  (no log file found)\");\n903:       continue;\n904:     }\n905: \n906:     try {\n907:       const contents = readFileSync(logFile, \"utf-8\");\n908:       if (contents.trim().length === 0) {\n909:         console.log(\"  (log file is empty)\");\n910:       } else {\n911:         console.log(contents);\n912:       }\n913:     } catch (err: any) {\n914:       console.log(`  (error reading log: ${err.message})`);\n915:     }\n916:   }\n917: \n918:   console.log(`\\n${\"=\".repeat(72)}\\n`);\n919: }\n920: \n921: // ---------------------------------------------------------------------------\n922: // Headless Wave Launch\n923: // ---------------------------------------------------------------------------\n924: \n925: async function launchWaveHeadless(\n926:   projectRoot: string,\n927:   state: WaveState,\n928:   features: Feature[],\n929:   opts: LaunchCommandOptions,\n930:   agentResolutions?: Map<string, AgentResolution>\n931: ): Promise<void> {\n932:   const { config, model } = opts;\n933:   const featureMap = new Map(features.map((f) => [f.id, f]));\n934: \n935:   const monitor = new ProcessMonitor(projectRoot, {\n936:     onSessionId: (featureId, sessionId) => {\n937:       updateAgent(state, featureId, { session_id: sessionId });\n938:       saveState(projectRoot, state);\n939:     },\n940:     onComplete: (featureId) => {\n941:       updateAgent(state, featureId, {\n942:         status: \"completed\",\n943:         completed_at: new Date().toISOString(),\n944:       });\n945:       saveState(projectRoot, state);\n946: \n947:       // Run build verification — fire-and-forget\n948:       const agent = state.agents.find((a) => a.feature_id === featureId)!;\n949:       handleBuildVerification(projectRoot, state, agent, featureMap.get(featureId)!, config, model, monitor)\n950:         .then(() => {\n951:           // After verification/merge, try to launch dependency-ready agents\n952:           // Multiple queued agents may now be unblocked\n953:           launchAllReady(projectRoot, state, featureMap, monitor, config, model, agentResolutions)\n954:             .catch((err) => wtLog(featureId, `LAUNCH ERROR: ${err.message}`));\n955:         })\n956:         .catch((err) => {\n957:           wtLog(featureId, `BUILD VERIFICATION UNHANDLED ERROR: ${err.message}`);\n958:           launchAllReady(projectRoot, state, featureMap, monitor, config, model, agentResolutions)\n959:             .catch((err2) => wtLog(featureId, `LAUNCH ERROR: ${err2.message}`));\n960:         });\n961:     },\n962:     onError: (featureId, error) => {\n963:       const agent = state.agents.find((a) => a.feature_id === featureId)!;\n964:       if (agent.retries < agent.max_retries) {\n965:         updateAgent(state, featureId, {\n966:           status: \"retry\",\n967:           retries: agent.retries + 1,\n968:           error,\n969:         });\n970:         saveState(projectRoot, state);\n971: \n972:         // Retry\n973:         handleRetry(projectRoot, state, agent, monitor, config, model);\n974:       } else {\n975:         updateAgent(state, featureId, {\n976:           status: \"failed\",\n977:           error,\n978:           completed_at: new Date().toISOString(),\n979:         });\n980:         saveState(projectRoot, state);\n981: \n982:         // Cascade failure to downstream agents\n983:         const cancelled = cancelDownstream(state, featureId);\n984:         if (cancelled.length > 0) {\n985:           wtLog(featureId, `downstream cancelled: ${cancelled.join(\", \")}`);\n986:           saveState(projectRoot, state);\n987:         }\n988:       }\n989: \n990:       // Try to launch dependency-ready agents\n991:       launchAllReady(projectRoot, state, featureMap, monitor, config, model, agentResolutions)\n992:         .catch((err) => wtLog(featureId, `LAUNCH ERROR: ${err.message}`));\n993:     },\n994:     onOutput: (_featureId, _data) => {\n995:       // Raw output — logged to file by ProcessMonitor\n996:     },\n997:     onActivity: (featureId, activity) => {\n998:       updateAgent(state, featureId, {\n999:         activity,\n1000:         activity_updated_at: new Date().toISOString(),\n1001:       });\n1002:       // Don't save to disk on every activity — too frequent.\n1003:     },\n1004:   });\n1005: \n1006:   // Create the TUI — it will auto-refresh and show activity from the monitor\n1007:   const tuiRef = { current: null as WomboTUI | null };\n1008:   const startTUI = () => {\n1009:     tuiRef.current = new WomboTUI({\n1010:       state,\n1011:       monitor,\n1012:       projectRoot,\n1013:       interactive: false,\n1014:       config,\n1015:       onQuit: () => {\n1016:         // Same as SIGINT — save state and exit\n1017:         for (const agent of state.agents) {\n1018:           if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n1019:             updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n1020:           }\n1021:         }\n1022:         monitor.killAll();\n1023:         saveState(projectRoot, state);\n1024:         console.log(\"State saved. Use 'woco resume' to continue.\");\n1025:         process.exit(0);\n1026:       },\n1027:       onRetry: (featureId: string) => {\n1028:         const agent = state.agents.find((a) => a.feature_id === featureId);\n1029:         if (!agent) return;\n1030:         if (agent.status !== \"failed\" && agent.status !== \"retry\") return;\n1031: \n1032:         // Reset retries if exhausted, give it one more shot\n1033:         if (agent.retries >= agent.max_retries) {\n1034:           updateAgent(state, featureId, { max_retries: agent.retries + 1 });\n1035:         }\n1036: \n1037:         wtLog(featureId, `manual retry requested from TUI — resetting to queued`);\n1038:         updateAgent(state, featureId, {\n1039:           status: \"queued\",\n1040:           error: null,\n1041:           activity: \"waiting for relaunch (manual retry)...\",\n1042:         });\n1043:         saveState(projectRoot, state);\n1044:         // The polling loop will call launchAllReady() and pick this up\n1045:       },\n1046:     });\n1047:     tuiRef.current.start();\n1048:   };\n1049: \n1050:   // Handle graceful shutdown\n1051:   process.on(\"SIGINT\", () => {\n1052:     if (tuiRef.current) tuiRef.current.stop();\n1053:     for (const agent of state.agents) {\n1054:       if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n1055:         updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n1056:       }\n1057:     }\n1058:     monitor.killAll();\n1059:     saveState(projectRoot, state);\n1060:     console.log(\"\\nState saved. Use 'woco resume' to continue.\");\n1061:     process.exit(0);\n1062:   });\n1063: \n1064:   // Launch initial batch — only agents whose dependencies are already satisfied\n1065:   // Stagger launches to avoid SQLite race conditions in agent processes:\n1066:   // each agent spawns its own DB, and simultaneous CREATE TABLE calls collide.\n1067:   const ready = readyToLaunchAgents(state);\n1068:   const tolaunch = ready.slice(0, opts.maxConcurrent);\n1069:   console.log(`Setting up ${tolaunch.length} agent(s) (staggered)...\\n`);\n1070: \n1071:   for (let i = 0; i < tolaunch.length; i++) {\n1072:     await launchSingleHeadless(\n1073:       projectRoot,\n1074:       state,\n1075:       tolaunch[i],\n1076:       featureMap.get(tolaunch[i].feature_id)!,\n1077:       monitor,\n1078:       config,\n1079:       model,\n1080:       agentResolutions\n1081:     );\n1082:     // Brief delay between spawns so each agent's DB migration settles\n1083:     if (i < tolaunch.length - 1) {\n1084:       await new Promise((r) => setTimeout(r, LAUNCH_STAGGER_MS));\n1085:     }\n1086:   }\n1087: \n1088:   const launched = state.agents.filter((a) => a.status === \"running\").length;\n1089: \n1090:   // Start the TUI dashboard (or skip if --no-tui)\n1091:   if (opts.noTui) {\n1092:     console.log(`${launched} agent(s) running. (--no-tui mode, dashboard prints every 15s)\\n`);\n1093:     printDashboard(state);\n1094:   } else {\n1095:     console.log(`${launched} agent(s) running. Launching TUI...\\n`);\n1096:     startTUI();\n1097:   }\n1098: \n1099:   // Background monitoring loop — checks for dead processes and launches queued\n1100:   const POLL_INTERVAL = 5000;\n1101:   let dashboardCounter = 0;\n1102:   while (!isWaveComplete(state)) {\n1103:     await new Promise((r) => setTimeout(r, POLL_INTERVAL));\n1104: \n1105:     // Check for completed processes that weren't caught by event handlers\n1106:     for (const agent of state.agents) {\n1107:       if (\n1108:         (agent.status === \"running\" || agent.status === \"resolving_conflict\") &&\n1109:         agent.pid &&\n1110:         !isProcessRunning(agent.pid) &&\n1111:         !monitor.isRunning(agent.feature_id)\n1112:       ) {\n1113:         if (agent.status === \"resolving_conflict\") {\n1114:           // Conflict resolver died — the await in handleBuildVerification\n1115:           // will resolve via the 'exit' event, so nothing to do here\n1116:           continue;\n1117:         }\n1118:         // Process exited but we didn't get a callback\n1119:         // Check if the agent actually made any commits\n1120:         if (!branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n1121:           // Agent died without producing any code — mark as failed, not completed\n1122:           updateAgent(state, agent.feature_id, {\n1123:             status: \"failed\",\n1124:             error: \"Agent process exited without making any commits\",\n1125:             activity: null,\n1126:             completed_at: new Date().toISOString(),\n1127:           });\n1128:           saveState(projectRoot, state);\n1129:           wtLog(agent.feature_id, \"process died with no code changes — marked failed\");\n1130: \n1131:           // Cascade failure to downstream agents\n1132:           const cancelled = cancelDownstream(state, agent.feature_id);\n1133:           if (cancelled.length > 0) {\n1134:             wtLog(agent.feature_id, `downstream cancelled: ${cancelled.join(\", \")}`);\n1135:             saveState(projectRoot, state);\n1136:           }\n1137:         } else {\n1138:           updateAgent(state, agent.feature_id, {\n1139:             status: \"completed\",\n1140:             completed_at: new Date().toISOString(),\n1141:             activity: \"done\",\n1142:           });\n1143:           saveState(projectRoot, state);\n1144:           try {\n1145:             await handleBuildVerification(projectRoot, state, agent, featureMap.get(agent.feature_id)!, config, model, monitor);\n1146:           } catch (err: any) {\n1147:             wtLog(agent.feature_id, `POLL VERIFY ERROR: ${err.message}`);\n1148:           }\n1149:         }\n1150:         await launchAllReady(projectRoot, state, featureMap, monitor, config, model, agentResolutions);\n1151:       }\n1152:     }\n1153: \n1154:     // Safety net: detect agents stuck in \"retry\" with no running process.\n1155:     // This catches edge cases where handleRetry() wasn't called or failed\n1156:     // to reset the agent (e.g. race between onError callback and poll loop).\n1157:     for (const agent of state.agents) {\n1158:       if (\n1159:         agent.status === \"retry\" &&\n1160:         (!agent.pid || !isProcessRunning(agent.pid)) &&\n1161:         !monitor.isRunning(agent.feature_id)\n1162:       ) {\n1163:         if (agent.retries >= agent.max_retries) {\n1164:           // Out of retries — mark as failed and cascade\n1165:           wtLog(agent.feature_id, `stuck in retry with no process and retries exhausted (${agent.retries}/${agent.max_retries}) — marking failed`);\n1166:           updateAgent(state, agent.feature_id, {\n1167:             status: \"failed\",\n1168:             error: agent.error ?? \"Agent stuck in retry state with no running process\",\n1169:             activity: null,\n1170:             completed_at: new Date().toISOString(),\n1171:           });\n1172:           saveState(projectRoot, state);\n1173:           const cancelled = cancelDownstream(state, agent.feature_id);\n1174:           if (cancelled.length > 0) {\n1175:             wtLog(agent.feature_id, `downstream cancelled: ${cancelled.join(\", \")}`);\n1176:             saveState(projectRoot, state);\n1177:           }\n1178:         } else {\n1179:           // Has retries left — reset to queued for a fresh launch\n1180:           wtLog(agent.feature_id, `stuck in retry with no process — resetting to queued (retry ${agent.retries}/${agent.max_retries})`);\n1181:           updateAgent(state, agent.feature_id, {\n1182:             status: \"queued\",\n1183:             error: null,\n1184:             activity: \"waiting for relaunch...\",\n1185:           });\n1186:           saveState(projectRoot, state);\n1187:         }\n1188:       }\n1189:     }\n1190: \n1191:     // After recovering stuck agents, try launching any that are now ready\n1192:     await launchAllReady(projectRoot, state, featureMap, monitor, config, model, agentResolutions);\n1193: \n1194:     // Persist state periodically\n1195:     saveState(projectRoot, state);\n1196: \n1197:     // Update TUI state reference (or print dashboard in --no-tui mode)\n1198:     if (tuiRef.current) {\n1199:       tuiRef.current.updateState(state);\n1200:     } else if (opts.noTui) {\n1201:       dashboardCounter++;\n1202:       if (dashboardCounter % 3 === 0) {\n1203:         printDashboard(state);\n1204: \n1205:         // Auto-push base branch if requested\n1206:         if (opts.autoPush) {\n1207:           const anyMerged = state.agents.some((a) => a.status === \"merged\");\n1208:           if (anyMerged) {\n1209:             await pushBaseBranch(projectRoot, state.base_branch, config);\n1210:           } else {\n1211:             console.log(\"No branches were merged — skipping push.\");\n1212:           }\n1213:         }\n1214:       }\n1215:     }\n1216:   }\n1217: \n1218:   // Wave complete — keep TUI open for post-mortem browsing\n1219:   if (tuiRef.current) {\n1220:     tuiRef.current.updateState(state);\n1221:     tuiRef.current.markWaveComplete();\n1222:     // Wait for the user to press q to exit the TUI\n1223:     await tuiRef.current.waitForQuit();\n1224:   }\n1225: \n1226:   // Print final dashboard after TUI is closed\n1227:   printDashboard(state);\n1228: \n1229:   // Dump full logs for failed agents (post-mortem)\n1230:   dumpFailedAgentLogs(projectRoot, state);\n1231: \n1232:   // Auto-export wave history\n1233:   try {\n1234:     const historyPath = exportWaveHistory(projectRoot, state);\n1235:     console.log(`Wave history exported to ${historyPath}`);\n1236:   } catch (err: any) {\n1237:     console.error(`Warning: failed to export wave history: ${err.message}`);\n1238:   }\n1239: \n1240:   // Auto-push base branch if requested\n1241:   if (opts.autoPush) {\n1242:     await pushBaseBranch(projectRoot, state.base_branch, config);\n1243:   }\n1244: \n1245:   console.log(\"Wave complete.\");\n1246: }\n1247: \n1248: // ---------------------------------------------------------------------------\n1249: // Interactive Wave Launch\n1250: // ---------------------------------------------------------------------------\n1251: \n1252: async function launchWaveInteractive(\n1253:   projectRoot: string,\n1254:   state: WaveState,\n1255:   features: Feature[],\n1256:   opts: LaunchCommandOptions,\n1257:   agentResolutions?: Map<string, AgentResolution>\n1258: ): Promise<void> {\n1259:   const { config, model } = opts;\n1260:   const featureMap = new Map(features.map((f) => [f.id, f]));\n1261: \n1262:   // Show dashboard immediately\n1263:   printDashboard(state);\n1264: \n1265:   // Launch initial batch — parallelize setup\n1266:   const tolaunch = queuedAgents(state).slice(0, opts.maxConcurrent);\n1267:   console.log(`Setting up ${tolaunch.length} agent(s) in parallel...\\n`);\n1268: \n1269:   await Promise.all(\n1270:     tolaunch.map(async (agent) => {\n1271:       updateAgent(state, agent.feature_id, {\n1272:         status: \"installing\",\n1273:         started_at: new Date().toISOString(),\n1274:         activity: \"setting up worktree...\",\n1275:       });\n1276:       saveState(projectRoot, state);\n1277: \n1278:       try {\n1279:         if (worktreeReady(agent.worktree)) {\n1280:           wtLog(agent.feature_id, \"worktree already exists, skipping setup\");\n1281:         } else {\n1282:           await createWorktree(projectRoot, agent.feature_id, state.base_branch, config);\n1283:           updateAgent(state, agent.feature_id, { activity: \"installing deps...\" });\n1284:           await installDeps(agent.worktree, agent.feature_id, config);\n1285:         }\n1286: \n1287:         const prompt = generatePrompt(\n1288:           featureMap.get(agent.feature_id)!,\n1289:           state.base_branch,\n1290:           config\n1291:         );\n1292: \n1293:         // Write specialized agent to worktree if applicable\n1294:         const resolution = agentResolutions?.get(agent.feature_id);\n1295:         const agentName = agent.agent_name ?? undefined;\n1296:         if (resolution && isSpecializedAgent(resolution)) {\n1297:           try {\n1298:             const patchedContent = patchImportedAgent(resolution.rawContent, config, projectRoot);\n1299:             writeAgentToWorktree(agent.worktree, resolution.name, patchedContent);\n1300:             wtLog(agent.feature_id, `wrote specialized agent: ${resolution.name}`);\n1301:           } catch (err: any) {\n1302:             wtLog(agent.feature_id, `WARN: failed to write specialized agent, using generalist: ${err.message}`);\n1303:           }\n1304:         }\n1305: \n1306:         wtLog(agent.feature_id, \"launching interactive session...\");\n1307:         const result = launchInteractive({\n1308:           worktreePath: agent.worktree,\n1309:           featureId: agent.feature_id,\n1310:           prompt,\n1311:           model,\n1312:           interactive: true,\n1313:           config,\n1314:           agentName,\n1315:         });\n1316: \n1317:         const muxName = getMultiplexerName(config);\n1318:         updateAgent(state, agent.feature_id, {\n1319:           status: \"running\",\n1320:           pid: result.pid,\n1321:           activity: `${muxName} session active`,\n1322:         });\n1323:         saveState(projectRoot, state);\n1324:         wtLog(agent.feature_id, `${muxName} session: ${config.agent.tmuxPrefix}-${agent.feature_id}`);\n1325:       } catch (err: any) {\n1326:         updateAgent(state, agent.feature_id, {\n1327:           status: \"failed\",\n1328:           error: err.message,\n1329:           activity: null,\n1330:           completed_at: new Date().toISOString(),\n1331:         });\n1332:         saveState(projectRoot, state);\n1333:         wtLog(agent.feature_id, `SETUP FAILED: ${err.message.split(\"\\n\")[0]}`);\n1334:       }\n1335:     })\n1336:   );\n1337: \n1338:   const mux = detectMultiplexer(config.agent.multiplexer);\n1339:   const muxName = getMultiplexerName(config);\n1340:   console.log(\"\\nInteractive sessions launched. Use these commands:\");\n1341:   console.log(`  ${muxAttachCommand(mux, `${config.agent.tmuxPrefix}-<feature-id>`)}   # attach to a session`);\n1342:   console.log(`  ${muxListCommand(mux)}${\" \".repeat(Math.max(1, 54 - muxListCommand(mux).length))}# list sessions`);\n1343:   console.log(\"  woco status                                             # check status\");\n1344:   console.log(\"  woco verify                                             # verify builds\");\n1345:   console.log(\"  woco merge                                              # merge verified\");\n1346:   console.log(\"  woco cleanup                                            # remove worktrees\");\n1347: \n1348:   printDashboard(state);\n1349: }\n1350: \n1351: // ---------------------------------------------------------------------------\n1352: // Main Command\n1353: // ---------------------------------------------------------------------------\n1354: \n1355: export async function cmdLaunch(opts: LaunchCommandOptions): Promise<void> {\n1356:   const { projectRoot, config } = opts;\n1357:   const fmt = opts.outputFmt ?? \"text\";\n1358: \n1359:   if (fmt === \"text\") console.log(\"\\n--- wombo-combo: Launch ---\\n\");\n1360: \n1361:   // Ensure agent definition exists — reinstall from template if missing\n1362:   ensureAgentDefinition(projectRoot, config);\n1363: \n1364:   // Ensure portless proxy is running (if enabled) to prevent port collisions\n1365:   if (config.portless.enabled) {\n1366:     if (isPortlessAvailable(config)) {\n1367:       const proxyOk = ensureProxyRunning(config);\n1368:       if (!proxyOk && fmt === \"text\") {\n1369:         console.warn(\n1370:           \"\\x1b[33m[portless]\\x1b[0m proxy could not be started — agents may encounter port collisions\"\n1371:         );\n1372:       }\n1373:     } else if (fmt === \"text\") {\n1374:       console.warn(\n1375:         \"\\x1b[33m[portless]\\x1b[0m enabled but not installed. Install with: npm install -g portless\"\n1376:       );\n1377:       console.warn(\n1378:         \"  Agents will run without portless — concurrent dev servers may have port collisions.\\n\"\n1379:       );\n1380:     }\n1381:   }\n1382: \n1383:   // -------------------------------------------------------------------------\n1384:   // Validate that the configured baseBranch exists as a local branch\n1385:   // -------------------------------------------------------------------------\n1386:   if (!branchExists(projectRoot, opts.baseBranch)) {\n1387:     const msg = `Base branch \"${opts.baseBranch}\" does not exist as a local branch. ` +\n1388:       `Create it first (e.g. \"git checkout -b ${opts.baseBranch}\") or specify ` +\n1389:       `a different branch with --base-branch.`;\n1390:     outputError(fmt, msg);\n1391:   }\n1392: \n1393:   // -------------------------------------------------------------------------\n1394:   // Check for existing wave state — don't overwrite work in progress\n1395:   // -------------------------------------------------------------------------\n1396:   const existingState = loadState(projectRoot);\n1397:   if (existingState) {\n1398:     const merged = existingState.agents.filter((a) => a.status === \"merged\");\n1399:     const verified = existingState.agents.filter((a) => a.status === \"verified\");\n1400:     const completed = existingState.agents.filter((a) => a.status === \"completed\");\n1401:     const running = existingState.agents.filter((a) => a.status === \"running\");\n1402:     const queued = existingState.agents.filter((a) => a.status === \"queued\");\n1403:     const failed = existingState.agents.filter((a) => a.status === \"failed\");\n1404: \n1405:     const hasWork = merged.length > 0 || verified.length > 0 || completed.length > 0 || running.length > 0;\n1406: \n1407:     if (hasWork) {\n1408:       if (fmt === \"text\") {\n1409:         console.log(`Existing wave found: ${existingState.wave_id}`);\n1410:         console.log(`  ${merged.length} merged, ${verified.length} verified, ${completed.length} completed, ${running.length} running, ${queued.length} queued, ${failed.length} failed`);\n1411:       }\n1412: \n1413:       // Finalize any merged agents by marking their features as done\n1414:       if (merged.length > 0) {\n1415:         if (fmt === \"text\") console.log(\"\\nFinalizing merged tasks in tasks file...\");\n1416:         for (const agent of merged) {\n1417:           markFeatureDone(projectRoot, agent.feature_id, config, existingState.base_branch);\n1418:           // Clean up worktree and branch (already merged, safe to delete)\n1419:           try {\n1420:             removeWorktree(projectRoot, agent.worktree, true);\n\n(Output capped at 50 KB. Showing lines 1-1420. Use offset=1421 to continue.)\n</content>","title":"src/commands/launch.ts","metadata":{"preview":"/**\n * launch.ts — Launch a wave of agents.\n *\n * Usage: woco launch [selection options] [launch options]\n *\n * This is the primary entry point for starting a new wave. It selects features\n * from the features file, creates a wave state, sets up worktrees, and launches\n * agent processes (either headless or interactive via dmux/tmux).\n *\n * IMPORTANT: This file also exports shared helper functions that are reused\n * by resume.ts and other commands:\n *   - launchSingleHeadless\n *   - handleBuildVerification\n *   - handleRetry\n *   - launchNextQueued\n */\n\nimport { execSync } from \"node:child_process\";\nimport { existsSync, readFileSync } from \"node:fs\";\nimport { resolve } from \"node:path\";","truncated":true,"loaded":[]},"time":{"start":1773437428650,"end":1773437428657}}}}
