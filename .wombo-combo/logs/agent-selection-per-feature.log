n359: \n360:   if (existsSync(agentDefPath)) {\n361:     return false;\n362:   }\n363: \n364:   // Agent definition missing — reinstall from bundled template\n365:   console.warn(\n366:     `\\x1b[33m[WARNING]\\x1b[0m Agent definition not found: .opencode/agents/${config.agent.name}.md`\n367:   );\n368:   console.warn(`  Reinstalling from bundled generalist template...`);\n369: \n370:   try {\n371:     mkdirSync(agentDir, { recursive: true });\n372:     const content = renderGeneralistAgent(config, projectRoot);\n373:     writeFileSync(agentDefPath, content, \"utf-8\");\n374:     console.warn(`  Restored .opencode/agents/${config.agent.name}.md\\n`);\n375:     return true;\n376:   } catch (err: any) {\n377:     console.error(\n378:       `  Failed to restore agent definition: ${err.message}`\n379:     );\n380:     console.error(\n381:       `  Agents may launch without their definition file.\\n`\n382:     );\n383:     return false;\n384:   }\n385: }\n\n(End of file - total 385 lines)\n</content>","title":"src/lib/templates.ts","metadata":{"preview":"// Backward Compatibility\n// ---------------------------------------------------------------------------\n\n/**\n * Render the agent template. Backward-compatible wrapper around\n * `renderGeneralistAgent` — existing code that calls this function\n * continues to work unchanged.\n */\nexport function renderAgentTemplate(\n  config: WomboConfig,\n  projectRoot: string\n): string {\n  return renderGeneralistAgent(config, projectRoot);\n}\n\n// ---------------------------------------------------------------------------\n// Agent Definition Guard\n// ---------------------------------------------------------------------------\n\n/**","truncated":false,"loaded":[]},"time":{"start":1773437529672,"end":1773437529675}}}}
