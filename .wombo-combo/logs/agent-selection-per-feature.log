`switched to branch ${agent.branch}`);\n229:       } catch (branchErr: any) {\n230:         wtLog(agent.feature_id, `branch switch failed: ${branchErr.message}`);\n231:         // Fall through to normal worktree creation\n232:         await createWorktree(projectRoot, feature.id, state.base_branch, config);\n233:       }\n234:     } else if (worktreeReady(agent.worktree)) {\n235:       // Skip worktree setup if already ready (resume case)\n236:       wtLog(agent.feature_id, \"worktree already exists, skipping setup\");\n237:     } else {\n238:       // Create worktree (async — doesn't block other agents)\n239:       await createWorktree(projectRoot, feature.id, state.base_branch, config);\n240: \n241:       // Install dependencies (async)\n242:       updateAgent(state, agent.feature_id, { activity: \"installing deps...\" });\n243:       await installDeps(agent.worktree, feature.id, config);\n244:     }\n245: \n246:     // Generate prompt\n247:     const prompt = generatePrompt(feature, state.base_branch, config);\n248: \n249:     // Write specialized agent to worktree if applicable\n250:     const resolution = agentResolutions?.get(feature.id);\n251:     const agentName = agent.agent_name ?? undefined;\n252:     if (resolution && isSpecializedAgent(resolution)) {\n253:       try {\n254:         const patchedContent = patchImportedAgent(resolution.rawContent, config, projectRoot);\n255:         writeAgentToWorktree(agent.worktree, resolution.name, patchedContent);\n256:         wtLog(agent.feature_id, `wrote specialized agent: ${resolution.name}`);\n257:       } catch (err: any) {\n258:         wtLog(agent.feature_id, `WARN: failed to write specialized agent, using generalist: ${err.message}`);\n259:       }\n260:     }\n261: \n262:     // Launch agent\n263:     wtLog(agent.feature_id, \"launching agent...\");\n264:     const result = launchHeadless({\n265:       worktreePath: agent.worktree,\n266:       featureId: feature.id,\n267:       prompt,\n268:       model,\n269:       config,\n270:       agentName,\n271:     });\n272: \n273:     updateAgent(state, agent.feature_id, {\n274:       status: \"running\",\n275:       pid: result.pid,\n276:       activity: \"starting...\",\n277:     });\n278:     saveState(projectRoot, state);\n279: \n280:     monitor.addProcess(feature.id, result.process);\n281:     wtLog(agent.feature_id, `running (PID: ${result.pid})`);\n282:   } catch (err: any) {\n283:     updateAgent(state, agent.feature_id, {\n284:       status: \"failed\",\n285:       error: err.message,\n286:       activity: null,\n287:       completed_at: new Date().toISOString(),\n288:     });\n289:     saveState(projectRoot, state);\n290:     wtLog(agent.feature_id, `SETUP FAILED: ${err.message.split(\"\\n\")[0]}`);\n291:   }\n292: }\n293: \n294: /**\n295:  * Handle build verification after agent completion.\n296:  * Runs build, auto-merges on pass, retries on failure if retries remain.\n297:  *\n298:  * ASYNC — runs build and merge without blocking the event loop.\n299:  */\n300: export async function handleBuildVerification(\n301:   projectRoot: string,\n302:   state: WaveState,\n303:   agent: AgentState,\n304:   feature: Feature,\n305:   config: WomboConfig,\n306:   model?: string,\n307:   monitor?: ProcessMonitor,\n308:   tddOpts?: FullVerificationOptions\n309: ): Promise<void> {\n310:   try {\n311:     printAgentUpdate(agent, \"verifying build...\");\n312: \n313:     // Use full verification pipeline (build + optional browser tests + optional TDD)\n314:     const fullResult = await runFullVerification(agent.worktree, agent.feature_id, config, tddOpts);\n315:     const buildResult = fullResult.build;\n316: \n317:     // Report browser test status if they ran\n318:     if (fullResult.browser.ran && fullResult.browser.browserResult) {\n\n(Showing lines 199-318 of 1670. Use offset=319 to continue.)\n</content>","title":"src/commands/launch.ts","metadata":{"preview":"  model?: string,\n  agentResolutions?: Map<string, AgentResolution>\n): Promise<void> {\n  updateAgent(state, agent.feature_id, {\n    status: \"installing\",\n    started_at: new Date().toISOString(),\n    activity: \"setting up worktree...\",\n  });\n  saveState(projectRoot, state);\n\n  try {\n    // Check if this agent is reusing a chain predecessor's worktree\n    const isChainReuse = agent.depends_on.some((depId) => {\n      const depAgent = state.agents.find((a) => a.feature_id === depId);\n      return depAgent && depAgent.worktree === agent.worktree;\n    });\n\n    if (isChainReuse && worktreeReady(agent.worktree)) {\n      // Chain worktree reuse: the worktree already exists from a predecessor.\n      // Create a new branch for this feature and switch the worktree to it.","truncated":true,"loaded":[]},"time":{"start":1773437536221,"end":1773437536224}}}}
