{"type":"tool_use","timestamp":1773437440276,"sessionID":"ses_316e48f3cffeGrhJEXdprD247G","part":{"id":"prt_ce91bd042001dZNicBrt7DwJyf","sessionID":"ses_316e48f3cffeGrhJEXdprD247G","messageID":"msg_ce91bba74001KhgM2uKj13ltgZ","type":"tool","callID":"toolu_vrtx_0126u8QCEqhWeTqctNkJBF93","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-agent-selection-per-feature/src/index.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-agent-selection-per-feature/src/index.ts</path>\n<type>file</type>\n<content>1: #!/usr/bin/env bun\n2: /**\n3:  * index.ts — CLI entry point for the wombo-combo agent orchestration system.\n4:  *\n5:  * Every command has a short alias (e.g., woco i = woco init, woco t ls = woco tasks list).\n6:  *\n7:  * Usage:\n8:  *   woco init                                         (alias: i)\n9:  *   woco launch --top-priority 3                      (alias: l)\n10:  *   woco launch --quickest-wins 5\n11:  *   woco launch --priority high\n12:  *   woco launch --difficulty easy\n13:  *   woco launch --tasks \"feat-a,feat-b\"\n14:  *   woco launch --all-ready\n15:  *   woco launch ... --max-concurrent 3 --model \"anthropic/claude-sonnet-4-20250514\"\n16:  *   woco launch ... --interactive\n17:  *   woco resume                                       (alias: r)\n18:  *   woco status                                       (alias: s)\n19:  *   woco verify [feature-id]                          (alias: v)\n20:  *   woco merge [feature-id]                           (alias: m)\n21:  *   woco retry <feature-id>                           (alias: re)\n22:  *   woco abort <feature-id> [--requeue] [--output json]  (alias: a)\n23:  *   woco logs <feature-id> [--tail N] [--follow]      (alias: lo)\n24:  *   woco cleanup                                      (alias: c)\n25:  *   woco history [wave-id] [--output json]            (alias: h)\n26:  *   woco tasks list [--status <s>] [--priority <p>]   (alias: t ls)\n27:  *   woco tasks add <id> <title> [options]             (alias: t a)\n28:  *   woco tasks set-status <task-id> <status>          (alias: t ss)\n29:  *   woco tasks set-priority <task-id> <priority>      (alias: t sp)\n30:  *   woco tasks set-difficulty <task-id> <difficulty>   (alias: t sd)\n31:  *   woco tasks check                                  (alias: t ch)\n32:  *   woco tasks archive [task-id] [--dry-run]          (alias: t ar)\n33:  *   woco tasks show <task-id>                         (alias: t sh)\n34:  *   woco tasks graph [--ascii] [--mermaid]            (alias: t g)\n35:  *   woco completion <bash|zsh|fish>                   (alias: comp)\n36:  *   woco help\n37:  *   woco version\n38:  *   woco -v\n39:  */\n40: \n41: import { resolve } from \"node:path\";\n42: import { existsSync, readFileSync } from \"node:fs\";\n43: import { loadConfig, validateConfig } from \"./config.js\";\n44: import { loadState, saveState } from \"./lib/state.js\";\n45: \n46: // ---------------------------------------------------------------------------\n47: // Dev-mode guard: warn if running the global binary inside the wombo-combo repo\n48: // ---------------------------------------------------------------------------\n49: \n50: function checkDevModeGuard(): void {\n51:   const cwd = process.cwd();\n52:   const pkgPath = resolve(cwd, \"package.json\");\n53: \n54:   // Are we inside the wombo-combo repo?\n55:   if (!existsSync(pkgPath)) return;\n56: \n57:   let pkgName: string | undefined;\n58:   try {\n59:     const raw = readFileSync(pkgPath, \"utf-8\");\n60:     pkgName = JSON.parse(raw).name;\n61:   } catch {\n62:     return;\n63:   }\n64:   if (pkgName !== \"wombo-combo\") return;\n65: \n66:   // We're in the wombo-combo repo. Is the source being run from a different location?\n67:   // import.meta.dir = directory of THIS file (index.ts). If it's under cwd,\n68:   // we're running local source (bun dev). If it's elsewhere (e.g. ~/.bun/install),\n69:   // we're running the globally installed binary.\n70:   const sourceDir = resolve(import.meta.dir);\n71:   const projectSrc = resolve(cwd, \"src\");\n72: \n73:   if (!sourceDir.startsWith(projectSrc)) {\n74:     console.warn(\n75:       \"\\x1b[33m[WARNING]\\x1b[0m You are running the globally installed woco binary \" +\n76:       \"inside the wombo-combo repo.\\n\" +\n77:       \"  Use \\x1b[1mbun dev <command>\\x1b[0m instead to run from local source.\\n\" +\n78:       \"  See AGENTS.md for details.\\n\"\n79:     );\n80:   }\n81: }\n82: \n83: import { cmdInit } from \"./commands/init.js\";\n84: import { cmdLaunch } from \"./commands/launch.js\";\n85: import { cmdResume } from \"./commands/resume.js\";\n86: import { cmdStatus } from \"./commands/status.js\";\n87: import { cmdVerify } from \"./commands/verify.js\";\n88: import { cmdMerge } from \"./commands/merge.js\";\n89: import { cmdRetry } from \"./commands/retry.js\";\n90: import { cmdCleanup } from \"./commands/cleanup.js\";\n91: import { cmdAbort } from \"./commands/abort.js\";\n92: import { cmdLogs } from \"./commands/logs.js\";\n93: import { cmdUpgrade } from \"./commands/upgrade.js\";\n94: import { cmdHistory } from \"./commands/history.js\";\n95: import { cmdCompletion } from \"./commands/completion.js\";\n96: import { cmdTasksList } from \"./commands/tasks/list.js\";\n97: import { cmdTasksAdd } from \"./commands/tasks/add.js\";\n98: import { cmdTasksSetStatus } from \"./commands/tasks/set-status.js\";\n99: import { cmdTasksSetPriority } from \"./commands/tasks/set-priority.js\";\n100: import { cmdTasksSetDifficulty } from \"./commands/tasks/set-difficulty.js\";\n101: import { cmdTasksCheck } from \"./commands/tasks/check.js\";\n102: import { cmdTasksArchive } from \"./commands/tasks/archive.js\";\n103: import { cmdTasksShow } from \"./commands/tasks/show.js\";\n104: import { cmdTasksGraph } from \"./commands/tasks/graph.js\";\n105: \n106: import { ensureTasksFile } from \"./lib/tasks.js\";\n107: import type { Priority, Difficulty, FeatureStatus } from \"./lib/tasks.js\";\n108: import { resolveOutputFormat, type OutputFormat } from \"./lib/output.js\";\n109: import { validateId, validateText, validateBranchName, validateDuration, assertValid } from \"./lib/validate.js\";\n110: import { findCommandDef, commandToSchema, allCommandSchemas } from \"./lib/schema.js\";\n111: import { buildToonSpec, renderToonLegend } from \"./lib/toon-spec.js\";\n112: \n113: // ---------------------------------------------------------------------------\n114: // Types\n115: // ---------------------------------------------------------------------------\n116: \n117: export interface CLIArgs {\n118:   command: string;\n119:   subcommand?: string;\n120:   // Selection options (launch)\n121:   topPriority?: number;\n122:   quickestWins?: number;\n123:   priority?: Priority;\n124:   difficulty?: Difficulty;\n125:   tasks?: string[];\n126:   allReady?: boolean;\n127:   // Launch / runtime options\n128:   maxConcurrent?: number;\n129:   model?: string;\n130:   interactive: boolean;\n131:   dryRun: boolean;\n132:   baseBranch?: string;\n133:   maxRetries?: number;\n134:   noTui: boolean;\n135:   autoPush: boolean;\n136:   // Abort options\n137:   requeue: boolean;\n138:   // General\n139:   featureId?: string;\n140:   force: boolean;\n141:   // Output format\n142:   outputFmt: OutputFormat;\n143:   // Upgrade options\n144:   checkOnly: boolean;\n145:   tag?: string;\n146:   // Features subcommand extras\n147:   status?: string;\n148:   ready?: boolean;\n149:   includeArchive?: boolean;\n150:   title?: string;\n151:   description?: string;\n152:   effort?: string;\n153:   dependsOn?: string[];\n154:   // Logs options\n155:   tail?: number;\n156:   follow?: boolean;\n157:   // Compact output\n158:   fields?: string[];\n159:   // Graph options\n160:   ascii?: boolean;\n161:   mermaidRaw?: boolean;\n162:   graphSubtasks?: boolean;\n163:   // Browser verification\n164:   browser?: boolean;\n165:   // TDD verification\n166:   skipTests?: boolean;\n167:   strictTdd?: boolean;\n168: }\n169: \n170: // ---------------------------------------------------------------------------\n171: // Command & Subcommand Aliases\n172: // ---------------------------------------------------------------------------\n173: \n174: /** Map of short aliases → canonical top-level command names. */\n175: export const COMMAND_ALIASES: Record<string, string> = {\n176:   i: \"init\",\n177:   l: \"launch\",\n178:   r: \"resume\",\n179:   s: \"status\",\n180:   v: \"verify\",\n181:   m: \"merge\",\n182:   re: \"retry\",\n183:   a: \"abort\",\n184:   c: \"cleanup\",\n185:   h: \"history\",\n186:   lo: \"logs\",\n187:   t: \"tasks\",\n188:   features: \"tasks\", // backward-compat full-word alias\n189:   u: \"upgrade\",\n190:   d: \"describe\",\n191:   comp: \"completion\",\n192: };\n193: \n194: /** Map of short aliases → canonical tasks subcommand names. */\n195: export const SUBCOMMAND_ALIASES: Record<string, string> = {\n196:   ls: \"list\",\n197:   a: \"add\",\n198:   ss: \"set-status\",\n199:   sp: \"set-priority\",\n200:   sd: \"set-difficulty\",\n201:   ch: \"check\",\n202:   validate: \"check\", // backward-compat full-word alias\n203:   ar: \"archive\",\n204:   sh: \"show\",\n205:   g: \"graph\",\n206: };\n207: \n208: // ---------------------------------------------------------------------------\n209: // Arg Parsing\n210: // ---------------------------------------------------------------------------\n211: \n212: export function parseArgs(argv: string[]): CLIArgs {\n213:   const args = argv.slice(2); // skip 'bun' and script path\n214:   const result: CLIArgs = {\n215:     command: args[0] || \"help\",\n216:     interactive: false,\n217:     dryRun: false,\n218:     noTui: false,\n219:     autoPush: false,\n220:     requeue: false,\n221:     force: false,\n222:     checkOnly: false,\n223:     outputFmt: resolveOutputFormat(undefined), // auto-detect until --output overrides\n224:   };\n225: \n226:   // Resolve top-level command alias (e.g., \"i\" → \"init\", \"t\" → \"tasks\")\n227:   result.command = COMMAND_ALIASES[result.command] ?? result.command;\n228: \n229:   // If the command is \"tasks\", treat the second positional as the subcommand\n230:   let startIdx = 1;\n231:   if (result.command === \"tasks\") {\n232:     result.subcommand = args[1] || \"list\";\n233:     // Resolve subcommand alias (e.g., \"ls\" → \"list\", \"ss\" → \"set-status\")\n234:     result.subcommand = SUBCOMMAND_ALIASES[result.subcommand] ?? result.subcommand;\n235:     startIdx = 2;\n236:   }\n237: \n238:   for (let i = startIdx; i < args.length; i++) {\n239:     const arg = args[i];\n240: \n241:     // Helper: consume the next argument, or exit with a clear error\n242:     function requireValue(flag: string): string {\n243:       if (i + 1 >= args.length) {\n244:         console.error(`Flag ${flag} requires a value.`);\n245:         process.exit(1);\n246:       }\n247:       return args[++i];\n248:     }\n249: \n250:     switch (arg) {\n251:       // --- Selection options ---\n252:       case \"--top-priority\":\n253:         result.topPriority = parseInt(requireValue(arg), 10);\n254:         break;\n255:       case \"--quickest-wins\":\n256:         result.quickestWins = parseInt(requireValue(arg), 10);\n257:         break;\n258:       case \"--priority\":\n259:         result.priority = requireValue(arg) as Priority;\n260:         break;\n261:       case \"--difficulty\":\n262:         result.difficulty = requireValue(arg) as Difficulty;\n263:         break;\n264:       case \"--tasks\":\n265:       case \"--features\": // backward-compat alias\n266:         result.tasks = requireValue(arg).split(\",\").map((s) => s.trim());\n267:         break;\n268:       case \"--all-ready\":\n269:         result.allReady = true;\n270:         break;\n271: \n272:       // --- Launch / runtime options ---\n273:       case \"--max-concurrent\":\n274:         result.maxConcurrent = parseInt(requireValue(arg), 10);\n275:         break;\n276:       case \"--model\":\n277:       case \"-m\":\n278:         result.model = requireValue(arg);\n279:         break;\n280:       case \"--interactive\":\n281:         result.interactive = true;\n282:         break;\n283:       case \"--dry-run\":\n284:         result.dryRun = true;\n285:         break;\n286:       case \"--no-tui\":\n287:         result.noTui = true;\n288:         break;\n289:       case \"--auto-push\":\n290:         result.autoPush = true;\n291:         break;\n292:       case \"--requeue\":\n293:         result.requeue = true;\n294:         break;\n295:       case \"--base-branch\":\n296:         result.baseBranch = requireValue(arg);\n297:         break;\n298:       case \"--max-retries\":\n299:         result.maxRetries = parseInt(requireValue(arg), 10);\n300:         break;\n301: \n302:       // --- General flags ---\n303:       case \"--force\":\n304:         result.force = true;\n305:         break;\n306:       case \"--check\":\n307:         result.checkOnly = true;\n308:         break;\n309:       case \"--tag\":\n310:       case \"--release\":\n311:         result.tag = requireValue(arg);\n312:         break;\n313:       case \"--output\":\n314:       case \"-o\":\n315:         result.outputFmt = resolveOutputFormat(requireValue(arg));\n316:         break;\n317: \n318:       // --- Tasks subcommand options ---\n319:       case \"--status\":\n320:         result.status = requireValue(arg);\n321:         break;\n322:       case \"--ready\":\n323:         result.ready = true;\n324:         break;\n325:       case \"--include-archive\":\n326:         result.includeArchive = true;\n327:         break;\n328:       case \"--title\":\n329:         result.title = requireValue(arg);\n330:         break;\n331:       case \"--description\":\n332:       case \"--desc\":\n333:         result.description = requireValue(arg);\n334:         break;\n335:       case \"--effort\":\n336:         result.effort = requireValue(arg);\n337:         break;\n338:       case \"--depends-on\":\n339:         result.dependsOn = requireValue(arg).split(\",\").map((s) => s.trim());\n340:         break;\n341:       case \"--fields\":\n342:         result.fields = requireValue(arg).split(\",\").map((s) => s.trim());\n343:         break;\n344: \n345:       // --- Graph options ---\n346:       case \"--ascii\":\n347:         result.ascii = true;\n348:         break;\n349:       case \"--mermaid\":\n350:         result.mermaidRaw = true;\n351:         break;\n352:       case \"--subtasks\":\n353:         result.graphSubtasks = true;\n354:         break;\n355: \n356:       // --- Logs options ---\n357:       case \"--tail\":\n358:         result.tail = parseInt(requireValue(arg), 10);\n359:         break;\n360:       case \"--follow\":\n361:       case \"-f\":\n362:         result.follow = true;\n363:         break;\n364: \n365:       // --- Browser verification ---\n366:       case \"--browser\":\n367:         result.browser = true;\n368:         break;\n369: \n370:       // --- TDD verification ---\n371:       case \"--skip-tests\":\n372:         result.skipTests = true;\n373:         break;\n374:       case \"--strict-tdd\":\n375:         result.strictTdd = true;\n376:         break;\n377: \n378:       // --- Positional (feature-id, title for add, etc.) ---\n379:       default:\n380:         if (!arg.startsWith(\"-\")) {\n381:           if (!result.featureId) {\n382:             result.featureId = arg;\n383:           } else if (!result.title) {\n384:             result.title = arg;\n385:           }\n386:         }\n387:         break;\n388:     }\n389:   }\n390: \n391:   return result;\n392: }\n393: \n394: // ---------------------------------------------------------------------------\n395: // Help\n396: // ---------------------------------------------------------------------------\n397: \n398: function cmdHelp(): void {\n399:   console.log(`\n400: wombo-combo — AI Agent Orchestration System\n401: \n402:   WOMBO COMBO! Parallel feature development with AI agents.\n403: \n404: Commands:                        (alias)\n405:   init                           (i)     Generate .wombo-combo/config.json in the current project\n406:   launch                         (l)     Launch a wave of agents to implement features\n407:   resume                         (r)     Resume a previously stopped wave\n408:   status                         (s)     Show the status of the current wave\n409:   verify                         (v)     Run build verification on completed agents\n410:   merge                          (m)     Merge verified branches into the base branch\n411:   retry                          (re)    Retry a failed agent\n412:   abort                          (a)     Kill a single running agent (--requeue to return to queue)\n413:   logs                           (lo)    Pretty-print agent logs for a feature\n414:   cleanup                        (c)     Remove all wave worktrees and multiplexer sessions\n415:   history                        (h)     List/view past wave results (stored in .wombo-combo/history/)\n416:   tasks                          (t)     Manage tasks file (see below; 'features' also accepted)\n417:   upgrade                        (u)     Check for updates and upgrade wombo-combo\n418:   describe                       (d)     Emit JSON schema of a command (for AI agents)\n419:   completion                     (comp)  Generate shell completions (bash, zsh, fish)\n420:   version                                Print version and exit\n421:   help                                   Show this help\n422: \n423: Tasks Subcommands:               (alias)\n424:   tasks list                     (ls)    List tasks (--status, --priority, --difficulty, --ready, --include-archive)\n425:   tasks add <id> <title>         (a)     Add a new task (--desc, --priority, --difficulty, --effort, --depends-on)\n426:   tasks set-status <id> <s>      (ss)    Change a task's status\n427:   tasks set-priority <id> <p>    (sp)    Change a task's priority (critical/high/medium/low/wishlist)\n428:   tasks set-difficulty <id> <d>  (sd)    Change a task's difficulty (trivial/easy/medium/hard/very_hard)\n429:   tasks check                    (ch)    Validate tasks file (schema, deps, duplicates, cycles)\n430:   tasks archive [id]             (ar)    Move done/cancelled to archive (--dry-run)\n431:   tasks show <id>                (sh)    Show task details\n432:   tasks graph                    (g)     Visualize dependency graph (--ascii, --mermaid, --subtasks)\n433: \n434: Selection Options (for launch):\n435:   --top-priority N         Select top N tasks by priority\n436:   --quickest-wins N        Select N tasks with lowest effort\n437:   --priority <level>       Filter by priority (critical/high/medium/low/wishlist)\n438:   --difficulty <level>     Filter by difficulty (trivial/easy/medium/hard/very_hard)\n439:   --tasks \"id1,id2\"        Select specific tasks by ID (--features also accepted)\n440:   --all-ready              Select all tasks whose dependencies are met\n441: \n442: Launch Options:\n443:   --max-concurrent N       Max agents running in parallel (default: from config)\n444:   --model <model>          Model to use (e.g., \"anthropic/claude-sonnet-4-20250514\")\n445:   --interactive            Use multiplexer (dmux/tmux) TUI mode instead of headless\n446:   --no-tui                 Headless mode without neo-blessed TUI (periodic console dashboard)\n447:   --auto-push              Push base branch to remote after all merges complete\n448:   --dry-run                Show what would be launched without launching\n449:   --base-branch <branch>   Base branch (default: from config)\n450:   --max-retries N          Max retries per agent (default: from config)\n451:   --browser                Enable browser-based verification (run after build passes)\n452:   --skip-tests             Skip running tests during TDD verification\n453:   --strict-tdd             Strict TDD: fail verification if new files are missing tests\n454: \n455: General:\n456:   --force                  Force overwrite (e.g., for init) / skip prompts (e.g., for upgrade)\n457:   --output <fmt>           Output format: text (default on TTY) or json (default when piped)\n458:   -o <fmt>                 Alias for --output\n459:   --dry-run                Show what would happen without performing the action\n460:   --fields <list>          Comma-separated fields to include (e.g., id,status,priority)\n461: \n462: Upgrade Options:\n463:   --check                  Only check for updates, don't install\n464:   --tag <tag>              Install a specific version (e.g., v0.1.0)\n465: \n466: Logs Options:\n467:   --tail N                 Show only the last N lines\n468:   --follow, -f             Stream new output as it arrives (like tail -f)\n469: \n470: Aliases (every command has a short form):\n471:   woco i                         woco init\n472:   woco l --all-ready             woco launch --all-ready\n473:   woco t ls                      woco tasks list\n474:   woco t a my-task \"Title\"       woco tasks add my-task \"Title\"\n475:   woco t ss my-task done         woco tasks set-status my-task done\n476: \n477: Shell Completion:\n478:   eval \"$(woco completion bash)\"    # Bash: add to ~/.bashrc\n479:   eval \"$(woco completion zsh)\"     # Zsh:  add to ~/.zshrc\n480:   woco completion fish | source     # Fish (or save to ~/.config/fish/completions/woco.fish)\n481: \n482: Examples:\n483:   woco init\n484:   woco launch --quickest-wins 3\n485:   woco launch --priority high --interactive\n486:   woco launch --tasks \"auth-flow,search-api\" --max-concurrent 2\n487:   woco resume\n488:   woco status\n489:   woco verify\n490:   woco merge\n491:   woco retry auth-flow\n492:   woco abort auth-flow\n493:   woco abort auth-flow --requeue\n494:   woco abort auth-flow --output json\n495:   woco logs auth-flow\n496:   woco logs auth-flow --tail 50\n497:   woco logs auth-flow --follow\n498:   woco logs auth-flow --output json\n499:   woco cleanup\n500:   woco tasks list --status ready --priority high\n501:   woco tasks list --fields id,status,priority --output json\n502:   woco tasks add my-task \"My Cool Task\" --priority high --difficulty easy\n503:   woco tasks set-status my-task in-progress\n504:   woco tasks check\n505:   woco tasks archive --dry-run\n506:   woco tasks show my-task\n507:   woco history\n508:   woco history wave-2026-03-12-420\n509:   woco history --output json\n510:   woco describe                           # list all commands as JSON\n511:   woco describe launch                    # describe a specific command\n512:   woco describe tasks add                 # describe a subcommand\n513: `);\n514: }\n515: \n516: // ---------------------------------------------------------------------------\n517: // Main\n518: // ---------------------------------------------------------------------------\n519: \n520: async function main(): Promise<void> {\n521:   checkDevModeGuard();\n522: \n523:   const PROJECT_ROOT = resolve(process.cwd());\n524:   const args = parseArgs(process.argv);\n525: \n526:   // -----------------------------------------------------------------------\n527:   // Input validation at the CLI boundary\n528:   // -----------------------------------------------------------------------\n529:   if (args.featureId) {\n530:     assertValid(validateId(args.featureId, \"feature ID\"));\n531:   }\n532:   if (args.title) {\n533:     assertValid(validateText(args.title, \"title\"));\n534:   }\n535:   if (args.description) {\n536:     assertValid(validateText(args.description, \"description\"));\n537:   }\n538:   if (args.baseBranch) {\n539:     assertValid(validateBranchName(args.baseBranch, \"base branch\"));\n540:   }\n541:   if (args.effort) {\n542:     assertValid(validateDuration(args.effort, \"effort\"));\n543:   }\n544:   if (args.tasks) {\n545:     for (const fid of args.tasks) {\n546:       assertValid(validateId(fid, \"task ID in --tasks\"));\n547:     }\n548:   }\n549:   if (args.dependsOn) {\n550:     for (const dep of args.dependsOn) {\n551:       assertValid(validateId(dep, \"dependency ID in --depends-on\"));\n552:     }\n553:   }\n554: \n555:   // Validate numeric args are not NaN\n556:   const numericArgs: [string, number | undefined][] = [\n557:     [\"--top-priority\", args.topPriority],\n558:     [\"--quickest-wins\", args.quickestWins],\n559:     [\"--max-concurrent\", args.maxConcurrent],\n560:     [\"--max-retries\", args.maxRetries],\n561:     [\"--tail\", args.tail],\n562:   ];\n563:   for (const [flag, value] of numericArgs) {\n564:     if (value !== undefined && isNaN(value)) {\n565:       console.error(`${flag} requires a numeric value.`);\n566:       process.exit(1);\n567:     }\n568:   }\n569: \n570:   // Commands that don't need config loading\n571:   if (args.command === \"version\" || args.command === \"-v\" || args.command === \"-V\") {\n572:     const pkgPath = resolve(import.meta.dir, \"..\", \"package.json\");\n573:     const pkgFile = Bun.file(pkgPath);\n574:     try {\n575:       const pkg = await pkgFile.json();\n576:       console.log(`wombo-combo ${pkg.version ?? \"(unknown version)\"}`);\n577:     } catch {\n578:       console.log(\"wombo-combo (unknown version)\");\n579:     }\n580:     return;\n581:   }\n582: \n583:   if (args.command === \"help\" || args.command === \"--help\" || args.command === \"-h\") {\n584:     cmdHelp();\n585:     return;\n586:   }\n587: \n588:   if (args.command === \"describe\") {\n589:     // Schema introspection: `woco describe [command]`\n590:     if (args.outputFmt === \"toon\") {\n591:       // Emit TOON format legend — self-describing, cacheable by agents\n592:       const pkgPath = resolve(import.meta.dir, \"..\", \"package.json\");\n593:       let version = \"unknown\";\n594:       try {\n595:         const pkg = await Bun.file(pkgPath).json();\n596:         version = pkg.version ?? \"unknown\";\n597:       } catch {}\n598: \n599:       if (!args.featureId) {\n600:         // Full TOON spec (legend + all commands)\n601:         console.log(renderToonLegend(version));\n602:       } else {\n603:         // JSON structure for the full spec (--output toon with a specific command\n604:         // still emits JSON since TOON is a line-oriented data format, not a schema format)\n605:         const spec = buildToonSpec(version);\n606:         const cmdName = args.title\n607:           ? `${args.featureId} ${args.title}`\n608:           : args.featureId;\n609:         const cmdSpec = spec.commands.find((c) => c.command === cmdName);\n610:         if (!cmdSpec) {\n611:           console.error(`Unknown command: \"${cmdName}\"`);\n612:           console.error(\"Run 'woco describe --output toon' to see the full TOON spec.\");\n613:           process.exit(1);\n614:           return;\n615:         }\n616:         console.log(JSON.stringify(cmdSpec, null, 2));\n617:       }\n618:       return;\n619:     }\n620: \n621:     if (!args.featureId) {\n622:       // No command specified — list all commands\n623:       console.log(JSON.stringify(allCommandSchemas(), null, 2));\n624:     } else {\n625:       // Describe a specific command. Handle compound names: \"features list\"\n626:       const cmdName = args.title\n627:         ? `${args.featureId} ${args.title}`\n628:         : args.featureId;\n629:       const def = findCommandDef(cmdName);\n630:       if (!def) {\n631:         console.error(`Unknown command: \"${cmdName}\"`);\n632:         console.error(\"Run 'woco describe' to list all commands.\");\n633:         process.exit(1);\n634:         return;\n635:       }\n636:       console.log(JSON.stringify(commandToSchema(def), null, 2));\n637:     }\n638:     return;\n639:   }\n640: \n641:   if (args.command === \"init\") {\n642:     await cmdInit({ projectRoot: PROJECT_ROOT, force: args.force });\n643:     return;\n644:   }\n645: \n646:   if (args.command === \"upgrade\") {\n647:     await cmdUpgrade({\n648:       force: args.force,\n649:       tag: args.tag,\n650:       checkOnly: args.checkOnly,\n651:     });\n652:     return;\n653:   }\n654: \n655:   if (args.command === \"completion\") {\n656:     cmdCompletion({ shell: args.featureId }); // first positional = shell name\n657:     return;\n658:   }\n659: \n660:   if (args.command === \"logs\") {\n661:     if (!args.featureId) {\n662:       console.error(\"Usage: woco logs <feature-id> [--tail N] [--follow] [--output json]\");\n663:       process.exit(1);\n664:       return;\n665:     }\n666:     await cmdLogs({\n667:       projectRoot: PROJECT_ROOT,\n668:       featureId: args.featureId,\n669:       tail: args.tail,\n670:       follow: args.follow,\n671:       outputFmt: args.outputFmt,\n672:     });\n673:     return;\n674:   }\n675: \n676:   // Everything else requires config\n677:   const config = loadConfig(PROJECT_ROOT);\n678:   validateConfig(config);\n679: \n680:   // Commands that operate on the tasks file — ensure it exists first\n681:   const needsTasksFile = new Set([\"launch\", \"resume\", \"verify\", \"retry\", \"tasks\"]);\n682:   if (needsTasksFile.has(args.command)) {\n683:     await ensureTasksFile(PROJECT_ROOT, config);\n684:   }\n685: \n686:   switch (args.command) {\n687:     case \"launch\":\n688:       // Apply browser verification override if --browser flag was passed\n689:       if (args.browser !== undefined) {\n690:         config.browser.enabled = args.browser;\n691:       }\n692:       await cmdLaunch({\n693:         projectRoot: PROJECT_ROOT,\n694:         config,\n695:         topPriority: args.topPriority,\n696:         quickestWins: args.quickestWins,\n697:         priority: args.priority,\n698:         difficulty: args.difficulty,\n699:         features: args.tasks,\n700:         allReady: args.allReady,\n701:         maxConcurrent: args.maxConcurrent ?? config.defaults.maxConcurrent,\n702:         model: args.model,\n703:         interactive: args.interactive,\n704:         dryRun: args.dryRun,\n705:         baseBranch: args.baseBranch ?? config.baseBranch,\n706:         maxRetries: args.maxRetries ?? config.defaults.maxRetries,\n707:         noTui: args.noTui,\n708:         autoPush: args.autoPush,\n709:         outputFmt: args.outputFmt,\n710:       });\n711:       break;\n712: \n713:     case \"resume\":\n714:       await cmdResume({\n715:         projectRoot: PROJECT_ROOT,\n716:         config,\n717:         maxConcurrent: args.maxConcurrent,\n718:         model: args.model,\n719:         interactive: args.interactive,\n720:         noTui: args.noTui,\n721:         autoPush: args.autoPush,\n722:         baseBranch: args.baseBranch,\n723:         maxRetries: args.maxRetries,\n724:         outputFmt: args.outputFmt,\n725:       });\n726:       break;\n727: \n728:     case \"status\":\n729:       await cmdStatus({ projectRoot: PROJECT_ROOT, config, outputFmt: args.outputFmt });\n730:       break;\n731: \n732:     case \"verify\":\n733:       await cmdVerify({\n734:         projectRoot: PROJECT_ROOT,\n735:         config,\n736:         featureId: args.featureId,\n737:         model: args.model,\n738:         maxRetries: args.maxRetries,\n739:         browserVerify: args.browser,\n740:         skipTests: args.skipTests,\n741:         strictTdd: args.strictTdd,\n742:         outputFmt: args.outputFmt,\n743:       });\n744:       break;\n745: \n746:     case \"merge\":\n747:       await cmdMerge({\n748:         projectRoot: PROJECT_ROOT,\n749:         config,\n750:         featureId: args.featureId,\n751:         autoPush: args.autoPush,\n752:         dryRun: args.dryRun,\n753:         model: args.model,\n754:         outputFmt: args.outputFmt,\n755:       });\n756:       break;\n757: \n758:     case \"retry\": {\n759:       if (!args.featureId) {\n760:         console.error(\"Usage: woco retry <feature-id>\");\n761:         process.exit(1);\n762:         return;\n763:       }\n764:       await cmdRetry({\n765:         projectRoot: PROJECT_ROOT,\n766:         config,\n767:         featureId: args.featureId,\n768:         model: args.model,\n769:         interactive: args.interactive,\n770:         dryRun: args.dryRun,\n771:         outputFmt: args.outputFmt,\n772:       });\n773:       break;\n774:     }\n775: \n776:     case \"cleanup\":\n777:       await cmdCleanup({ projectRoot: PROJECT_ROOT, config, dryRun: args.dryRun, outputFmt: args.outputFmt });\n778:       break;\n779: \n780:     case \"history\":\n781:       await cmdHistory({\n782:         projectRoot: PROJECT_ROOT,\n783:         config,\n784:         waveId: args.featureId,\n785:         outputFmt: args.outputFmt,\n786:       });\n787:       break;\n788: \n789:     case \"abort\": {\n790:       if (!args.featureId) {\n791:         console.error(\"Usage: woco abort <feature-id> [--requeue] [--output json]\");\n792:         process.exit(1);\n793:         return;\n794:       }\n795:       await cmdAbort({\n796:         projectRoot: PROJECT_ROOT,\n797:         config,\n798:         featureId: args.featureId,\n799:         requeue: args.requeue,\n800:         outputFmt: args.outputFmt,\n801:       });\n802:       break;\n803:     }\n804: \n805:     case \"tasks\":\n806:       await handleTasksSubcommand(args, PROJECT_ROOT, config);\n807:       break;\n808: \n809:     default:\n810:       console.error(`Unknown command: ${args.command}`);\n811:       cmdHelp();\n812:       process.exit(1);\n813:       return;\n814:   }\n815: }\n816: \n817: // ---------------------------------------------------------------------------\n818: // Tasks Subcommand Router\n819: // ---------------------------------------------------------------------------\n820: \n821: async function handleTasksSubcommand(\n822:   args: CLIArgs,\n823:   projectRoot: string,\n824:   config: import(\"./config.js\").WomboConfig\n825: ): Promise<void> {\n826:   switch (args.subcommand) {\n827:     case \"list\":\n828:       await cmdTasksList({\n829:         projectRoot,\n830:         config,\n831:         status: args.status as FeatureStatus | undefined,\n832:         priority: args.priority,\n833:         difficulty: args.difficulty,\n834:         ready: args.ready,\n835:         includeArchive: args.includeArchive,\n836:         outputFmt: args.outputFmt,\n837:         fields: args.fields,\n838:       });\n839:       break;\n840: \n841:     case \"add\": {\n842:       if (!args.featureId || !args.title) {\n843:         console.error(\"Usage: woco tasks add <id> <title> [--desc <desc>] [--priority <p>] [--difficulty <d>] [--effort <e>] [--depends-on <ids>]\");\n844:         process.exit(1);\n845:         return;\n846:       }\n847:       await cmdTasksAdd({\n848:         projectRoot,\n849:         config,\n850:         id: args.featureId,\n851:         title: args.title,\n852:         description: args.description,\n853:         priority: args.priority,\n854:         difficulty: args.difficulty,\n855:         effort: args.effort,\n856:         dependsOn: args.dependsOn,\n857:         outputFmt: args.outputFmt,\n858:         dryRun: args.dryRun,\n859:       });\n860:       break;\n861:     }\n862: \n863:     case \"set-status\": {\n864:       // The new status can come from the second positional (stored in args.title)\n865:       // or from the --status flag\n866:       const newStatus = args.title || args.status;\n867:       if (!args.featureId || !newStatus) {\n868:         console.error(\"Usage: woco tasks set-status <task-id> <status>\");\n869:         process.exit(1);\n870:         return;\n871:       }\n872:       await cmdTasksSetStatus({\n873:         projectRoot,\n874:         config,\n875:         featureId: args.featureId,\n876:         newStatus,\n877:         outputFmt: args.outputFmt,\n878:         dryRun: args.dryRun,\n879:       });\n880:       break;\n881:     }\n882: \n883:     case \"set-priority\": {\n884:       // The new priority can come from the second positional (stored in args.title)\n885:       // or from the --priority flag\n886:       const newPriority = args.title || (args.priority as string | undefined);\n887:       if (!args.featureId || !newPriority) {\n888:         console.error(\"Usage: woco tasks set-priority <task-id> <priority>\");\n889:         process.exit(1);\n890:         return;\n891:       }\n892:       await cmdTasksSetPriority({\n893:         projectRoot,\n894:         config,\n895:         featureId: args.featureId,\n896:         newPriority,\n897:         outputFmt: args.outputFmt,\n898:         dryRun: args.dryRun,\n899:       });\n900:       break;\n901:     }\n902: \n903:     case \"set-difficulty\": {\n904:       // The new difficulty can come from the second positional (stored in args.title)\n905:       // or from the --difficulty flag\n906:       const newDifficulty = args.title || (args.difficulty as string | undefined);\n907:       if (!args.featureId || !newDifficulty) {\n908:         console.error(\"Usage: woco tasks set-difficulty <task-id> <difficulty>\");\n909:         process.exit(1);\n910:         return;\n911:       }\n912:       await cmdTasksSetDifficulty({\n913:         projectRoot,\n914:         config,\n915:         featureId: args.featureId,\n916:         newDifficulty,\n917:         outputFmt: args.outputFmt,\n918:         dryRun: args.dryRun,\n919:       });\n920:       break;\n921:     }\n922: \n923:     case \"check\":\n924:       await cmdTasksCheck({ projectRoot, config, outputFmt: args.outputFmt });\n925:       break;\n926: \n927:     case \"archive\":\n928:       await cmdTasksArchive({\n929:         projectRoot,\n930:         config,\n931:         featureId: args.featureId,\n932:         dryRun: args.dryRun,\n933:         outputFmt: args.outputFmt,\n934:       });\n935:       break;\n936: \n937:     case \"show\": {\n938:       if (!args.featureId) {\n939:         console.error(\"Usage: woco tasks show <task-id>\");\n940:         process.exit(1);\n941:         return;\n942:       }\n943:       await cmdTasksShow({\n944:         projectRoot,\n945:         config,\n946:         featureId: args.featureId,\n947:         outputFmt: args.outputFmt,\n948:         fields: args.fields,\n949:       });\n950:       break;\n951:     }\n952: \n953:     case \"graph\":\n954:       await cmdTasksGraph({\n955:         projectRoot,\n956:         config,\n957:         status: args.status as FeatureStatus | undefined,\n958:         ascii: args.ascii,\n959:         mermaid: args.mermaidRaw,\n960:         subtasks: args.graphSubtasks,\n961:         outputFmt: args.outputFmt,\n962:       });\n963:       break;\n964: \n965:     case \"help\":\n966:     case \"--help\":\n967:     case \"-h\":\n968:       cmdHelp();\n969:       break;\n970: \n971:     default:\n972:       console.error(`Unknown tasks subcommand: ${args.subcommand}`);\n973:       console.error(\"Run 'woco tasks help' or 'woco help' for usage.\");\n974:       process.exit(1);\n975:       return;\n976:   }\n977: }\n978: \n979: // ---------------------------------------------------------------------------\n980: // Error Handlers & Entry\n981: // ---------------------------------------------------------------------------\n982: \n983: // Global error handlers — prevent silent crashes\n984: process.on(\"uncaughtException\", (err) => {\n985:   console.error(`\\n[FATAL] Uncaught exception: ${err.message}`);\n986:   console.error(err.stack);\n987:   try {\n988:     const state = loadState(process.cwd());\n989:     if (state) saveState(process.cwd(), state);\n990:   } catch {}\n991:   process.exit(1);\n992: });\n993: \n994: process.on(\"unhandledRejection\", (reason: any) => {\n995:   console.error(`\\n[FATAL] Unhandled rejection: ${reason?.message || reason}`);\n996:   if (reason?.stack) console.error(reason.stack);\n997:   try {\n998:     const state = loadState(process.cwd());\n999:     if (state) saveState(process.cwd(), state);\n1000:   } catch {}\n1001:   process.exit(1);\n1002: });\n1003: \n1004: main().catch((err) => {\n1005:   console.error(\"Fatal error:\", err.message);\n1006:   process.exit(1);\n1007: });\n\n(End of file - total 1007 lines)\n</content>","title":"src/index.ts","metadata":{"preview":"#!/usr/bin/env bun\n/**\n * index.ts — CLI entry point for the wombo-combo agent orchestration system.\n *\n * Every command has a short alias (e.g., woco i = woco init, woco t ls = woco tasks list).\n *\n * Usage:\n *   woco init                                         (alias: i)\n *   woco launch --top-priority 3                      (alias: l)\n *   woco launch --quickest-wins 5\n *   woco launch --priority high\n *   woco launch --difficulty easy\n *   woco launch --tasks \"feat-a,feat-b\"\n *   woco launch --all-ready\n *   woco launch ... --max-concurrent 3 --model \"anthropic/claude-sonnet-4-20250514\"\n *   woco launch ... --interactive\n *   woco resume                                       (alias: r)\n *   woco status                                       (alias: s)\n *   woco verify [feature-id]                          (alias: v)\n *   woco merge [feature-id]                           (alias: m)","truncated":false,"loaded":[]},"time":{"start":1773437440272,"end":1773437440275}}}}
