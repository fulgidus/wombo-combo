{"type":"tool_use","timestamp":1773437439354,"sessionID":"ses_316e48f3cffeGrhJEXdprD247G","part":{"id":"prt_ce91bc8a7001pgcqW9p3VcqFBl","sessionID":"ses_316e48f3cffeGrhJEXdprD247G","messageID":"msg_ce91bba74001KhgM2uKj13ltgZ","type":"tool","callID":"toolu_vrtx_014R5hRPeLWZeJYtXd4qtgcN","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-agent-selection-per-feature/src/lib/prompt.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-agent-selection-per-feature/src/lib/prompt.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * prompt.ts — Generate agent prompts from feature specs.\n3:  *\n4:  * Responsibilities:\n5:  *   - Transform a Feature into a structured prompt for the agent\n6:  *   - Include feature spec, subtasks, constraints, forbidden items, references\n7:  *   - Generate the build command and success criteria\n8:  *   - All project-specific values come from config (no hardcoded Astro references)\n9:  */\n10: \n11: import type { Feature, Subtask } from \"./tasks.js\";\n12: import { formatDuration, parseDurationMinutes } from \"./tasks.js\";\n13: import type { WomboConfig } from \"../config.js\";\n14: import { isPortlessAvailable, portlessUrl } from \"./portless.js\";\n15: \n16: // ---------------------------------------------------------------------------\n17: // Prompt Generation\n18: // ---------------------------------------------------------------------------\n19: \n20: /**\n21:  * Generate the full prompt for an autonomous agent working on a feature.\n22:  */\n23: export function generatePrompt(\n24:   feature: Feature,\n25:   baseBranch: string,\n26:   config: WomboConfig\n27: ): string {\n28:   const sections: string[] = [];\n29: \n30:   // Header\n31:   sections.push(`# Feature Implementation: ${feature.title}`);\n32:   sections.push(`**Feature ID:** \\`${feature.id}\\``);\n33:   sections.push(`**Branch:** \\`${config.git.branchPrefix}${feature.id}\\``);\n34:   sections.push(`**Base:** \\`${baseBranch}\\``);\n35:   sections.push(\n36:     `**Estimated Effort:** ${formatDuration(parseDurationMinutes(feature.effort))}`\n37:   );\n38:   sections.push(\n39:     `**Difficulty:** ${feature.difficulty} | **Priority:** ${feature.priority}`\n40:   );\n41: \n42:   // Description\n43:   sections.push(`\\n## Description\\n`);\n44:   sections.push(feature.description.trim());\n45: \n46:   // Subtasks\n47:   if (feature.subtasks.length > 0) {\n48:     sections.push(`\\n## Subtasks\\n`);\n49:     sections.push(\n50:       \"Complete these in order. Mark each done with a commit when finished.\\n\"\n51:     );\n52:     for (let i = 0; i < feature.subtasks.length; i++) {\n53:       sections.push(formatSubtask(feature.subtasks[i], i + 1, 0));\n54:     }\n55:   }\n56: \n57:   // Constraints\n58:   if (feature.constraints.length > 0) {\n59:     sections.push(`\\n## Constraints\\n`);\n60:     sections.push(\n61:       \"You MUST follow these constraints. Violating any is a failure.\\n\"\n62:     );\n63:     for (const c of feature.constraints) {\n64:       sections.push(`- ${c}`);\n65:     }\n66:   }\n67: \n68:   // Forbidden\n69:   if (feature.forbidden.length > 0) {\n70:     sections.push(`\\n## Forbidden\\n`);\n71:     sections.push(\n72:       \"You MUST NOT do any of the following. Violating any is a failure.\\n\"\n73:     );\n74:     for (const f of feature.forbidden) {\n75:       sections.push(`- ${f}`);\n76:     }\n77:   }\n78: \n79:   // References (files to explore)\n80:   if (feature.references.length > 0) {\n81:     sections.push(`\\n## Key Files to Explore\\n`);\n82:     sections.push(\n83:       \"Start by reading these files to understand the current state:\\n\"\n84:     );\n85:     for (const r of feature.references) {\n86:       sections.push(`- \\`${r}\\``);\n87:     }\n88:   }\n89: \n90:   // Notes\n91:   if (feature.notes.length > 0) {\n92:     sections.push(`\\n## Planning Notes\\n`);\n93:     for (const n of feature.notes) {\n94:       sections.push(`- ${n}`);\n95:     }\n96:   }\n97: \n98:   // Build verification — uses config, no hardcoded Astro command\n99:   sections.push(`\\n## Build Verification\\n`);\n100:   sections.push(\n101:     \"After completing all changes, run the build to verify everything works:\\n\"\n102:   );\n103:   sections.push(\"```bash\");\n104:   sections.push(config.build.command);\n105:   sections.push(\"```\\n\");\n106:   sections.push(\n107:     \"If the build fails, fix the errors before considering the task complete.\"\n108:   );\n109: \n110:   // Browser testing — inform agents about browser verification capabilities\n111:   if (config.browser.enabled) {\n112:     sections.push(`\\n## Browser Testing\\n`);\n113:     sections.push(\n114:       \"This project has browser-based verification enabled. After the build passes, \" +\n115:       \"browser tests will run automatically as part of the verification pipeline.\\n\"\n116:     );\n117:     sections.push(\"To add browser tests for this feature:\\n\");\n118:     sections.push(\"1. Create the directory `.wombo-browser/tests/` in the worktree root\");\n119:     sections.push(\"2. Add test scripts (`.sh`, `.ts`, or `.js` files) that will be executed in order\");\n120:     sections.push(\"3. Each test script receives these environment variables:\");\n121:     sections.push(\"   - `BROWSER_DEBUG_PORT` — Chrome DevTools Protocol port\");\n122:     sections.push(\"   - `BROWSER_WS_ENDPOINT` — WebSocket endpoint for the browser\");\n123:     sections.push(\"   - `BROWSER_HEADLESS` — whether the browser is running headless\");\n124:     sections.push(\"   - `BROWSER_SCREENSHOT_PATH` — path to save a screenshot for this test\");\n125:     sections.push(\"4. A test passes if it exits with code 0, fails otherwise\\n\");\n126:     if (config.browser.testCommand) {\n127:       sections.push(\n128:         `Alternatively, the project uses a custom browser test command: \\`${config.browser.testCommand}\\``\n129:       );\n130:     }\n131:     sections.push(\n132:       \"\\nBrowser tests are optional — if no tests are found, browser verification is skipped.\"\n133:     );\n134:   }\n135: \n136:   // Portless server testing instructions\n137:   if (config.portless.enabled && isPortlessAvailable(config)) {\n138:     sections.push(`\\n## Server Testing (portless)\\n`);\n139:     sections.push(\n140:       \"This worktree is configured with **portless** to prevent port collisions \" +\n141:       \"between concurrent agents. When starting any localhost server for testing:\\n\"\n142:     );\n143:     sections.push(\"```bash\");\n144:     sections.push(\"# Instead of running a server directly:\");\n145:     sections.push(\"#   npm run dev\");\n146:     sections.push(\"#   bun run dev\");\n147:     sections.push(\"#   node server.js\");\n148:     sections.push(\"\");\n149:     sections.push(\"# Wrap it with portless:\");\n150:     sections.push(`portless run npm run dev`);\n151:     sections.push(`portless run bun run dev`);\n152:     sections.push(`portless run node server.js`);\n153:     sections.push(\"```\\n\");\n154:     sections.push(\n155:       `Your dev server will be available at: \\`${portlessUrl(feature.id, config)}\\``\n156:     );\n157:     sections.push(\"\");\n158:     sections.push(\"**Rules:**\");\n159:     sections.push(\"- ALWAYS use `portless run <command>` when starting any server that listens on a port\");\n160:     sections.push(\"- Do NOT hardcode port numbers — portless assigns ports automatically via the `PORT` env var\");\n161:     sections.push(\"- The `PORT` and `PORTLESS_URL` environment variables are set automatically\");\n162:     sections.push(\"- If you need to reference the server URL in tests or config, use the `PORTLESS_URL` env var\");\n163:   }\n164: \n165:   // TDD instructions — deterministic injection based on config\n166:   if (config.tdd?.enabled) {\n167:     const testCmd = config.tdd.testCommand || \"bun test\";\n168:     sections.push(`\\n## Test-Driven Development (TDD)\\n`);\n169:     sections.push(\n170:       \"You MUST follow the **red-green-refactor** TDD cycle for all implementation work:\\n\"\n171:     );\n172:     sections.push(\"### Workflow\\n\");\n173:     sections.push(`1. **🔴 Red** — Write a failing test first. Run \\`${testCmd}\\` to confirm it fails.`);\n174:     sections.push(`2. **🟢 Green** — Write minimal code to make the test pass. Run \\`${testCmd}\\` to confirm.`);\n175:     sections.push(`3. **🔵 Refactor** — Clean up while keeping tests green. Run \\`${testCmd}\\` after each change.`);\n176:     sections.push(`4. **Repeat** for each new behavior or edge case.\\n`);\n177:     sections.push(\"### Rules\\n\");\n178:     sections.push(\"- **Never skip the red step.** Every new behavior starts with a failing test.\");\n179:     sections.push(\"- **One behavior per cycle.** Each iteration covers exactly one small behavior.\");\n180:     sections.push(\"- **Commit at green.** Each commit should have all tests passing.\");\n181:     sections.push(`- **Run tests frequently.** Run \\`${testCmd}\\` after every meaningful change.`);\n182:     sections.push(\"- Use `import { describe, test, expect } from \\\"bun:test\\\";` for test files.\");\n183:     sections.push(\"- Place tests next to source: `src/foo.ts` → `src/foo.test.ts` (or `tests/foo.test.ts`).\");\n184:   }\n185: \n186:   // Commit guidelines\n187:   sections.push(`\\n## Commit Guidelines\\n`);\n188:   sections.push(\"- Use conventional commits: `feat(scope):`, `fix(scope):`, `refactor(scope):`, `docs(scope):`\");\n189:   sections.push(`- Scope should be: \\`${feature.id}\\` or a relevant module name`);\n190:   sections.push(\"- Commit after each logical unit of work (roughly per subtask)\");\n191:   sections.push(\"- Do NOT squash all changes into one commit\");\n192:   sections.push(\"- Do NOT push to remote -- the orchestrator handles that\");\n193:   sections.push(`- Do NOT modify \\`${config.tasksDir}\\` -- the orchestrator handles that`);\n194: \n195:   // Final instruction\n196:   sections.push(`\\n## Execution\\n`);\n197:   sections.push(\"1. Read the key files listed above to understand the codebase\");\n198:   sections.push(\"2. Create a plan (use the TodoWrite tool)\");\n199:   sections.push(\"3. Implement each subtask, committing as you go\");\n200:   sections.push(`4. Run \\`${config.build.command}\\` to verify`);\n201:   sections.push(\"5. If the build passes, you are done\");\n202:   sections.push(\"6. If the build fails, fix the errors and re-run until it passes\");\n203: \n204:   return sections.join(\"\\n\");\n205: }\n206: \n207: // ---------------------------------------------------------------------------\n208: // Subtask Formatting\n209: // ---------------------------------------------------------------------------\n210: \n211: // ---------------------------------------------------------------------------\n212: // Conflict Resolution Prompt\n213: // ---------------------------------------------------------------------------\n214: \n215: /**\n216:  * Generate a prompt for an agent that resolves merge conflicts.\n217:  *\n218:  * The agent is launched in the feature worktree AFTER `git merge <baseBranch>`\n219:  * has been run there, leaving conflict markers in the working tree.\n220:  */\n221: export function generateConflictResolutionPrompt(\n222:   feature: Feature,\n223:   baseBranch: string,\n224:   mergeError: string,\n225:   config: WomboConfig\n226: ): string {\n227:   const sections: string[] = [];\n228: \n229:   sections.push(`# Merge Conflict Resolution: ${feature.title}`);\n230:   sections.push(`**Feature ID:** \\`${feature.id}\\``);\n231:   sections.push(`**Feature Branch:** \\`${config.git.branchPrefix}${feature.id}\\``);\n232:   sections.push(`**Base Branch:** \\`${baseBranch}\\``);\n233: \n234:   sections.push(`\\n## Situation\\n`);\n235:   sections.push(\n236:     `The feature branch \\`${config.git.branchPrefix}${feature.id}\\` has been completed and build-verified, ` +\n237:     `but merging it into \\`${baseBranch}\\` produced conflicts. The base branch (\\`${baseBranch}\\`) has been ` +\n238:     `merged INTO this feature branch's worktree, so the conflict markers are present in the working tree right now.`\n239:   );\n240: \n241:   sections.push(`\\n## Merge Error Output\\n`);\n242:   sections.push(\"```\");\n243:   sections.push(mergeError);\n244:   sections.push(\"```\");\n245: \n246:   sections.push(`\\n## Feature Description\\n`);\n247:   sections.push(feature.description.trim());\n248: \n249:   sections.push(`\\n## Your Task\\n`);\n250:   sections.push(\"1. Find all files with conflict markers (`<<<<<<<`, `=======`, `>>>>>>>`)\");\n251:   sections.push(\"2. Resolve each conflict by combining both sides intelligently:\");\n252:   sections.push(`   - The \\`HEAD\\` side is the feature's work (keep this intent)`);\n253:   sections.push(`   - The \\`${baseBranch}\\` side is upstream changes (integrate these)`);\n254:   sections.push(\"3. Remove ALL conflict markers — no `<<<<<<<`, `=======`, or `>>>>>>>` should remain\");\n255:   sections.push(\"4. Run the build to verify everything compiles:\");\n256:   sections.push(\"   ```bash\");\n257:   sections.push(`   ${config.build.command}`);\n258:   sections.push(\"   ```\");\n259:   sections.push(\"5. If the build fails, fix the errors\");\n260:   sections.push(\"6. Stage all resolved files and commit the merge:\");\n261:   sections.push(\"   ```bash\");\n262:   sections.push(\"   git add -A\");\n263:   sections.push('   git commit --no-edit');\n264:   sections.push(\"   ```\");\n265: \n266:   sections.push(`\\n## Rules\\n`);\n267:   sections.push(\"- Do NOT abort the merge (`git merge --abort`)\");\n268:   sections.push(\"- Do NOT create new branches or rebase\");\n269:   sections.push(\"- Do NOT push to remote\");\n270:   sections.push(`- Do NOT modify \\`${config.tasksDir}\\``);\n271:   sections.push(\"- Keep BOTH the feature's changes and the upstream changes where possible\");\n272:   sections.push(\"- If in doubt, prefer the feature's implementation but ensure upstream additions are not lost\");\n273: \n274:   return sections.join(\"\\n\");\n275: }\n276: \n277: // ---------------------------------------------------------------------------\n278: // Subtask Formatting\n279: // ---------------------------------------------------------------------------\n280: \n281: function formatSubtask(\n282:   subtask: Subtask,\n283:   index: number,\n284:   depth: number\n285: ): string {\n286:   const indent = \"  \".repeat(depth);\n287:   const lines: string[] = [];\n288: \n289:   lines.push(\n290:     `${indent}${index}. **${subtask.title}** (\\`${subtask.id}\\`, ${formatDuration(parseDurationMinutes(subtask.effort))})`\n291:   );\n292:   lines.push(`${indent}   ${subtask.description.trim()}`);\n293: \n294:   if (subtask.constraints.length > 0) {\n295:     for (const c of subtask.constraints) {\n296:       lines.push(`${indent}   - Constraint: ${c}`);\n297:     }\n298:   }\n299:   if (subtask.forbidden.length > 0) {\n300:     for (const f of subtask.forbidden) {\n301:       lines.push(`${indent}   - Forbidden: ${f}`);\n302:     }\n303:   }\n304:   if (subtask.references.length > 0) {\n305:     lines.push(\n306:       `${indent}   - Files: ${subtask.references.map((r) => `\\`${r}\\``).join(\", \")}`\n307:     );\n308:   }\n309:   if (subtask.depends_on.length > 0) {\n310:     lines.push(\n311:       `${indent}   - Depends on: ${subtask.depends_on.map((d) => `\\`${d}\\``).join(\", \")}`\n312:     );\n313:   }\n314: \n315:   // Nested subtasks\n316:   if (subtask.subtasks.length > 0) {\n317:     for (let i = 0; i < subtask.subtasks.length; i++) {\n318:       lines.push(formatSubtask(subtask.subtasks[i], i + 1, depth + 1));\n319:     }\n320:   }\n321: \n322:   return lines.join(\"\\n\");\n323: }\n\n(End of file - total 323 lines)\n</content>","title":"src/lib/prompt.ts","metadata":{"preview":"/**\n * prompt.ts — Generate agent prompts from feature specs.\n *\n * Responsibilities:\n *   - Transform a Feature into a structured prompt for the agent\n *   - Include feature spec, subtasks, constraints, forbidden items, references\n *   - Generate the build command and success criteria\n *   - All project-specific values come from config (no hardcoded Astro references)\n */\n\nimport type { Feature, Subtask } from \"./tasks.js\";\nimport { formatDuration, parseDurationMinutes } from \"./tasks.js\";\nimport type { WomboConfig } from \"../config.js\";\nimport { isPortlessAvailable, portlessUrl } from \"./portless.js\";\n\n// ---------------------------------------------------------------------------\n// Prompt Generation\n// ---------------------------------------------------------------------------\n\n/**","truncated":false,"loaded":[]},"time":{"start":1773437439350,"end":1773437439353}}}}
{"type":"tool_use","timestamp":1773437440068,"sessionID":"ses_316e48f3cffeGrhJEXdprD247G","part":{"id":"prt_ce91bcd770011fJvVREUpvN5NS","sessionID":"ses_316e48f3cffeGrhJEXdprD247G","messageID":"msg_ce91bba74001KhgM2uKj13ltgZ","type":"tool","callID":"toolu_vrtx_01Jvw7izk9U6rzbznXYsMDf7","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-agent-selection-per-feature/src/lib/launcher.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-agent-selection-per-feature/src/lib/launcher.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * launcher.ts — Process spawning and terminal multiplexer session management.\n3:  *\n4:  * Responsibilities:\n5:  *   - Launch agent in headless mode (agent run --format json)\n6:  *   - Launch agent in interactive mode (dmux/tmux session with TUI)\n7:  *   - Resume sessions for auto-retry\n8:  *   - Manage multiplexer sessions (create, list, kill)\n9:  *\n10:  * Supports both dmux (preferred) and tmux (fallback) via the multiplexer\n11:  * abstraction layer. The active backend is determined by config.agent.multiplexer.\n12:  */\n13: \n14: import { spawn, execSync, type ChildProcess } from \"node:child_process\";\n15: import { writeFileSync, unlinkSync } from \"node:fs\";\n16: import type { WomboConfig } from \"../config.js\";\n17: import { resolveAgentBin } from \"../config.js\";\n18: import {\n19:   detectMultiplexer,\n20:   muxNewSession,\n21:   muxHasSession,\n22:   muxKillSession,\n23:   muxListSessions,\n24:   muxGetPanePid,\n25:   muxLoadBuffer,\n26:   muxPasteBuffer,\n27:   muxSendKeys,\n28:   muxDisplayName,\n29:   type MultiplexerInfo,\n30: } from \"./multiplexer.js\";\n31: import { portlessEnv } from \"./portless.js\";\n32: \n33: // ---------------------------------------------------------------------------\n34: // Types\n35: // ---------------------------------------------------------------------------\n36: \n37: export interface LaunchResult {\n38:   pid: number;\n39:   process: ChildProcess;\n40:   sessionId?: string;\n41: }\n42: \n43: export interface LaunchOptions {\n44:   worktreePath: string;\n45:   featureId: string;\n46:   prompt: string;\n47:   model?: string;\n48:   interactive?: boolean;\n49:   config: WomboConfig;\n50:   /** Override the agent name (for specialized agents from the registry) */\n51:   agentName?: string;\n52: }\n53: \n54: export interface RetryOptions {\n55:   worktreePath: string;\n56:   featureId: string;\n57:   sessionId: string;\n58:   buildErrors: string;\n59:   model?: string;\n60:   interactive?: boolean;\n61:   config: WomboConfig;\n62: }\n63: \n64: // ---------------------------------------------------------------------------\n65: // Helpers\n66: // ---------------------------------------------------------------------------\n67: \n68: function muxSessionName(featureId: string, config: WomboConfig): string {\n69:   return `${config.agent.tmuxPrefix}-${featureId}`;\n70: }\n71: \n72: /**\n73:  * Get the multiplexer info for this config.\n74:  * Caches detection per-process.\n75:  */\n76: function getMux(config: WomboConfig): MultiplexerInfo {\n77:   return detectMultiplexer(config.agent.multiplexer);\n78: }\n79: \n80: function runSilent(cmd: string): string {\n81:   try {\n82:     return execSync(cmd, { encoding: \"utf-8\", stdio: \"pipe\" }).trim();\n83:   } catch {\n84:     return \"\";\n85:   }\n86: }\n87: \n88: /**\n89:  * Build the environment for an agent process.\n90:  * Merges process.env with OPENCODE_DIR and portless env vars.\n91:  */\n92: function agentEnv(\n93:   worktreePath: string,\n94:   featureId: string,\n95:   config: WomboConfig\n96: ): Record<string, string | undefined> {\n97:   return {\n98:     ...process.env,\n99:     OPENCODE_DIR: worktreePath,\n100:     ...portlessEnv(featureId, config),\n101:   };\n102: }\n103: \n104: // ---------------------------------------------------------------------------\n105: // Headless Launch\n106: // ---------------------------------------------------------------------------\n107: \n108: /**\n109:  * Launch agent in headless mode with JSON output.\n110:  */\n111: export function launchHeadless(opts: LaunchOptions): LaunchResult {\n112:   const agentBin = resolveAgentBin(opts.config);\n113: \n114:   const args = [\n115:     \"run\",\n116:     \"--format\", \"json\",\n117:     \"--agent\", opts.agentName ?? opts.config.agent.name,\n118:     \"--dir\", opts.worktreePath,\n119:     \"--title\", `woco: ${opts.featureId}`,\n120:   ];\n121: \n122:   if (opts.model) {\n123:     args.push(\"--model\", opts.model);\n124:   }\n125: \n126:   args.push(opts.prompt);\n127: \n128:   const child = spawn(agentBin, args, {\n129:     stdio: [\"pipe\", \"pipe\", \"pipe\"],\n130:     detached: false,\n131:     env: agentEnv(opts.worktreePath, opts.featureId, opts.config),\n132:   });\n133: \n134:   // Close stdin so agent starts processing immediately\n135:   child.stdin?.end();\n136: \n137:   return {\n138:     pid: child.pid!,\n139:     process: child,\n140:   };\n141: }\n142: \n143: /**\n144:  * Resume a headless session with a retry message (build errors).\n145:  */\n146: export function retryHeadless(opts: RetryOptions): LaunchResult {\n147:   const agentBin = resolveAgentBin(opts.config);\n148: \n149:   const retryMessage = `The build failed. Please fix the following errors and run \\`${opts.config.build.command}\\` again:\\n\\n\\`\\`\\`\\n${opts.buildErrors}\\n\\`\\`\\`\\n\\nFix all errors, then verify the build passes.`;\n150: \n151:   const args = [\n152:     \"run\",\n153:     \"--format\", \"json\",\n154:     \"--session\", opts.sessionId,\n155:     \"--continue\",\n156:     \"--dir\", opts.worktreePath,\n157:   ];\n158: \n159:   if (opts.model) {\n160:     args.push(\"--model\", opts.model);\n161:   }\n162: \n163:   args.push(retryMessage);\n164: \n165:   const child = spawn(agentBin, args, {\n166:     stdio: [\"pipe\", \"pipe\", \"pipe\"],\n167:     detached: false,\n168:     env: agentEnv(opts.worktreePath, opts.featureId, opts.config),\n169:   });\n170: \n171:   child.stdin?.end();\n172: \n173:   return {\n174:     pid: child.pid!,\n175:     process: child,\n176:   };\n177: }\n178: \n179: // ---------------------------------------------------------------------------\n180: // Conflict Resolution Launch\n181: // ---------------------------------------------------------------------------\n182: \n183: export interface ConflictResolverOptions {\n184:   worktreePath: string;\n185:   featureId: string;\n186:   prompt: string;\n187:   model?: string;\n188:   config: WomboConfig;\n189: }\n190: \n191: /**\n192:  * Launch a headless agent to resolve merge conflicts.\n193:  *\n194:  * This is similar to `launchHeadless`, but the prompt is a conflict-resolution\n195:  * prompt generated by `generateConflictResolutionPrompt()`. The agent runs in\n196:  * the feature worktree where `git merge <baseBranch>` has already been run,\n197:  * leaving conflict markers in the working tree.\n198:  */\n199: export function launchConflictResolver(opts: ConflictResolverOptions): LaunchResult {\n200:   const agentBin = resolveAgentBin(opts.config);\n201: \n202:   const args = [\n203:     \"run\",\n204:     \"--format\", \"json\",\n205:     \"--agent\", opts.config.agent.name,\n206:     \"--dir\", opts.worktreePath,\n207:     \"--title\", `woco: conflict-resolve ${opts.featureId}`,\n208:   ];\n209: \n210:   if (opts.model) {\n211:     args.push(\"--model\", opts.model);\n212:   }\n213: \n214:   args.push(opts.prompt);\n215: \n216:   const child = spawn(agentBin, args, {\n217:     stdio: [\"pipe\", \"pipe\", \"pipe\"],\n218:     detached: false,\n219:     env: agentEnv(opts.worktreePath, opts.featureId, opts.config),\n220:   });\n221: \n222:   child.stdin?.end();\n223: \n224:   return {\n225:     pid: child.pid!,\n226:     process: child,\n227:   };\n228: }\n229: \n230: // ---------------------------------------------------------------------------\n231: // Interactive (multiplexer) Launch\n232: // ---------------------------------------------------------------------------\n233: \n234: /**\n235:  * Launch agent in a terminal multiplexer session (dmux or tmux) for interactive use.\n236:  */\n237: export function launchInteractive(opts: LaunchOptions): LaunchResult {\n238:   const agentBin = resolveAgentBin(opts.config);\n239:   const mux = getMux(opts.config);\n240:   const sessionName = muxSessionName(opts.featureId, opts.config);\n241: \n242:   // Kill existing session if any\n243:   killMuxSession(opts.featureId, opts.config);\n244: \n245:   // Build the agent command to run inside the multiplexer\n246:   // Include portless env vars so any server started in the session\n247:   // is routed through the portless proxy\n248:   const pEnv = portlessEnv(opts.featureId, opts.config);\n249:   const envPrefix = Object.entries(pEnv)\n250:     .map(([k, v]) => `${k}=${JSON.stringify(v)}`)\n251:     .join(\" \");\n252: \n253:   const ocArgs = [\n254:     agentBin,\n255:     \"--dir\", JSON.stringify(opts.worktreePath),\n256:   ];\n257: \n258:   if (opts.model) {\n259:     ocArgs.push(\"--model\", JSON.stringify(opts.model));\n260:   }\n261: \n262:   const muxCmd = envPrefix ? `${envPrefix} ${ocArgs.join(\" \")}` : ocArgs.join(\" \");\n263: \n264:   // Create a detached session running the agent\n265:   muxNewSession(mux, sessionName, opts.worktreePath, muxCmd);\n266: \n267:   // Send the prompt as initial message after a brief delay\n268:   setTimeout(() => {\n269:     try {\n270:       const tmpFile = `/tmp/woco-prompt-${opts.featureId}.txt`;\n271:       writeFileSync(tmpFile, opts.prompt);\n272:       muxLoadBuffer(mux, tmpFile);\n273:       muxPasteBuffer(mux, sessionName);\n274:       muxSendKeys(mux, sessionName, \"Enter\");\n275:       try { unlinkSync(tmpFile); } catch {}\n276:     } catch {\n277:       // If prompt sending fails, user can type manually\n278:     }\n279:   }, 3000);\n280: \n281:   // Get the PID of the pane process\n282:   const panePid = muxGetPanePid(mux, sessionName);\n283: \n284:   return {\n285:     pid: panePid,\n286:     process: null as any, // No direct process handle in multiplexer mode\n287:   };\n288: }\n289: \n290: /**\n291:  * Resume an interactive session with retry message.\n292:  */\n293: export function retryInteractive(opts: RetryOptions): LaunchResult {\n294:   const mux = getMux(opts.config);\n295:   const sessionName = muxSessionName(opts.featureId, opts.config);\n296: \n297:   const exists = muxSessionExists(opts.featureId, opts.config);\n298: \n299:   if (exists) {\n300:     const retryMsg = `The build failed. Fix these errors:\\n${opts.buildErrors}`;\n301:     const tmpFile = `/tmp/woco-retry-${opts.featureId}.txt`;\n302:     writeFileSync(tmpFile, retryMsg);\n303:     muxLoadBuffer(mux, tmpFile);\n304:     muxPasteBuffer(mux, sessionName);\n305:     muxSendKeys(mux, sessionName, \"Enter\");\n306:     try { unlinkSync(tmpFile); } catch {}\n307: \n308:     const panePid = muxGetPanePid(mux, sessionName);\n309: \n310:     return {\n311:       pid: panePid,\n312:       process: null as any,\n313:     };\n314:   }\n315: \n316:   // Session doesn't exist — launch a new interactive session\n317:   return launchInteractive({\n318:     worktreePath: opts.worktreePath,\n319:     featureId: opts.featureId,\n320:     prompt: `Continue from session ${opts.sessionId}. The build failed:\\n${opts.buildErrors}\\n\\nFix all errors and verify the build passes.`,\n321:     model: opts.model,\n322:     interactive: true,\n323:     config: opts.config,\n324:   });\n325: }\n326: \n327: // ---------------------------------------------------------------------------\n328: // Multiplexer Session Management\n329: // ---------------------------------------------------------------------------\n330: \n331: /**\n332:  * Check if a multiplexer session exists for a feature.\n333:  */\n334: export function muxSessionExists(\n335:   featureId: string,\n336:   config: WomboConfig\n337: ): boolean {\n338:   const mux = getMux(config);\n339:   const sessionName = muxSessionName(featureId, config);\n340:   return muxHasSession(mux, sessionName);\n341: }\n342: \n343: /**\n344:  * Kill a multiplexer session for a feature.\n345:  */\n346: export function killMuxSession(\n347:   featureId: string,\n348:   config: WomboConfig\n349: ): void {\n350:   const mux = getMux(config);\n351:   const sessionName = muxSessionName(featureId, config);\n352:   muxKillSession(mux, sessionName);\n353: }\n354: \n355: /**\n356:  * List all woco-related multiplexer sessions.\n357:  */\n358: export function listMuxSessions(config: WomboConfig): string[] {\n359:   const mux = getMux(config);\n360:   const sessions = muxListSessions(mux);\n361:   return sessions.filter((s) => s.startsWith(config.agent.tmuxPrefix + \"-\"));\n362: }\n363: \n364: /**\n365:  * Kill all woco-related multiplexer sessions.\n366:  */\n367: export function killAllMuxSessions(config: WomboConfig): number {\n368:   const mux = getMux(config);\n369:   const sessions = listMuxSessions(config);\n370:   for (const s of sessions) {\n371:     muxKillSession(mux, s);\n372:   }\n373:   return sessions.length;\n374: }\n375: \n376: /**\n377:  * Get the display name of the active multiplexer backend.\n378:  */\n379: export function getMultiplexerName(config: WomboConfig): string {\n380:   try {\n381:     const mux = getMux(config);\n382:     return muxDisplayName(mux);\n383:   } catch {\n384:     return \"tmux/dmux\";\n385:   }\n386: }\n387: \n388: // ---------------------------------------------------------------------------\n389: // Backward Compatibility Aliases\n390: // ---------------------------------------------------------------------------\n391: \n392: /** @deprecated Use muxSessionExists instead */\n393: export const tmuxSessionExists = muxSessionExists;\n394: /** @deprecated Use killMuxSession instead */\n395: export const killTmuxSession = killMuxSession;\n396: /** @deprecated Use listMuxSessions instead */\n397: export const listTmuxSessions = listMuxSessions;\n398: /** @deprecated Use killAllMuxSessions instead */\n399: export const killAllTmuxSessions = killAllMuxSessions;\n400: \n401: /**\n402:  * Check if a process is still running by PID.\n403:  */\n404: export function isProcessRunning(pid: number): boolean {\n405:   if (!pid || pid <= 0) return false;\n406:   try {\n407:     process.kill(pid, 0);\n408:     return true;\n409:   } catch {\n410:     return false;\n411:   }\n412: }\n\n(End of file - total 412 lines)\n</content>","title":"src/lib/launcher.ts","metadata":{"preview":"/**\n * launcher.ts — Process spawning and terminal multiplexer session management.\n *\n * Responsibilities:\n *   - Launch agent in headless mode (agent run --format json)\n *   - Launch agent in interactive mode (dmux/tmux session with TUI)\n *   - Resume sessions for auto-retry\n *   - Manage multiplexer sessions (create, list, kill)\n *\n * Supports both dmux (preferred) and tmux (fallback) via the multiplexer\n * abstraction layer. The active backend is determined by config.agent.multiplexer.\n */\n\nimport { spawn, execSync, type ChildProcess } from \"node:child_process\";\nimport { writeFileSync, unlinkSync } from \"node:fs\";\nimport type { WomboConfig } from \"../config.js\";\nimport { resolveAgentBin } from \"../config.js\";\nimport {\n  detectMultiplexer,\n  muxNewSession,","truncated":false,"loaded":[]},"time":{"start":1773437440065,"end":1773437440068}}}}
