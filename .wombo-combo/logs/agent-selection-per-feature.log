{"type":"tool_use","timestamp":1773437444671,"sessionID":"ses_316e48f3cffeGrhJEXdprD247G","part":{"id":"prt_ce91bdd7a0013n51pPEdNRwGqP","sessionID":"ses_316e48f3cffeGrhJEXdprD247G","messageID":"msg_ce91bd183001mtAclIxaVxtUds","type":"tool","callID":"toolu_vrtx_01JmhJiu4MkPkr1UxqFc7jFB","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-agent-selection-per-feature/src/config.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-agent-selection-per-feature/src/config.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * config.ts — Load .wombo-combo/config.json, merge with defaults, validate, expose typed config.\n3:  *\n4:  * The config file lives at .wombo-combo/config.json inside the target project root.\n5:  * All values have sensible defaults so minimal config works out of the box.\n6:  */\n7: \n8: import { readFileSync, existsSync } from \"node:fs\";\n9: import { resolve } from \"node:path\";\n10: import type { MultiplexerPreference } from \"./lib/multiplexer.js\";\n11: \n12: // ---------------------------------------------------------------------------\n13: // .wombo-combo directory constant\n14: // ---------------------------------------------------------------------------\n15: \n16: /** Name of the directory that holds all wombo-combo files */\n17: export const WOMBO_DIR = \".wombo-combo\";\n18: \n19: // ---------------------------------------------------------------------------\n20: // Types\n21: // ---------------------------------------------------------------------------\n22: \n23: /** Agent registry download mode */\n24: export type AgentRegistryMode = \"auto\" | \"monitored\" | \"disabled\";\n25: \n26: export interface WomboConfig {\n27:   /** Directory name for task files relative to .wombo-combo/ (folder-based storage) */\n28:   tasksDir: string;\n29:   /** Directory name for archived task files relative to .wombo-combo/ */\n30:   archiveDir: string;\n31:   /** @deprecated Use tasksDir. Legacy single-file path relative to .wombo-combo/ */\n32:   tasksFile?: string;\n33:   /** @deprecated Use archiveDir. Legacy single-file path relative to .wombo-combo/ */\n34:   archiveFile?: string;\n35:   /** Base branch to create feature branches from */\n36:   baseBranch: string;\n37:   /** Build configuration */\n38:   build: {\n39:     /** Build command to run in worktrees */\n40:     command: string;\n41:     /** Build timeout in milliseconds */\n42:     timeout: number;\n43:     /** Build artifact directory (for quick \"did it build?\" checks) */\n44:     artifactDir: string;\n45:   };\n46:   /** Install configuration */\n47:   install: {\n48:     /** Install command to run in worktrees */\n49:     command: string;\n50:     /** Install timeout in milliseconds */\n51:     timeout: number;\n52:   };\n53:   /** Git configuration */\n54:   git: {\n55:     /** Branch name prefix for feature branches */\n56:     branchPrefix: string;\n57:     /** Worktree directory name prefix */\n58:     worktreePrefix: string;\n59:     /** Git remote name */\n60:     remote: string;\n61:     /** Merge strategy flag */\n62:     mergeStrategy: string;\n63:   };\n64:   /** Agent configuration */\n65:   agent: {\n66:     /** Path to agent binary (null = auto-detect) */\n67:     bin: string | null;\n68:     /** Agent name to pass via --agent flag */\n69:     name: string;\n70:     /** Config files/dirs to copy into worktrees */\n71:     configFiles: string[];\n72:     /** Session name prefix for terminal multiplexer */\n73:     tmuxPrefix: string;\n74:     /** Terminal multiplexer preference: \"auto\" (prefer dmux), \"dmux\", or \"tmux\" */\n75:     multiplexer: MultiplexerPreference;\n76:   };\n77:   /** Portless integration for localhost server testing */\n78:   portless: {\n79:     /** Whether portless is enabled for agent worktrees */\n80:     enabled: boolean;\n81:     /** Path to portless binary (null = auto-detect via PATH) */\n82:     bin: string | null;\n83:     /** Proxy port (portless default is 1355) */\n84:     proxyPort: number;\n85:     /** Whether to use HTTPS mode */\n86:     https: boolean;\n87:   };\n88:   /** Backup configuration for tasks file */\n89:   backup: {\n90:     /** Maximum number of timestamped backups to keep */\n91:     maxBackups: number;\n92:   };\n93:   /** Default runtime values */\n94:   defaults: {\n95:     /** Max concurrent agents */\n96:     maxConcurrent: number;\n97:     /** Max retries per agent */\n98:     maxRetries: number;\n99:   };\n100:   /** Browser testing configuration */\n101:   browser: BrowserConfig;\n102:   /** Agent registry configuration for specialized agent downloads */\n103:   agentRegistry: AgentRegistryConfig;\n104:   /** Test-Driven Development configuration */\n105:   tdd: TddConfig;\n106: }\n107: \n108: /** Configuration for browser-based verification and testing */\n109: export interface BrowserConfig {\n110:   /** Enable browser testing in the verify pipeline */\n111:   enabled: boolean;\n112:   /** Path to browser binary (null = auto-detect) */\n113:   bin: string | null;\n114:   /** Run browser in headless mode (required for CI) */\n115:   headless: boolean;\n116:   /** Custom test command to run browser tests (overrides script discovery) */\n117:   testCommand: string | null;\n118:   /** Timeout for launching a browser instance (ms) */\n119:   launchTimeout: number;\n120:   /** Timeout for each browser test script (ms) */\n121:   testTimeout: number;\n122:   /** Default viewport size */\n123:   defaultViewport: {\n124:     width: number;\n125:     height: number;\n126:   };\n127: }\n128: \n129: /** Configuration for the external agent registry (e.g. agency-agents) */\n130: export interface AgentRegistryConfig {\n131:   /**\n132:    * Download mode:\n133:    * - \"auto\"      — download agents without asking (default)\n134:    * - \"monitored\" — user reviews/edits/rejects each agent before launch\n135:    * - \"disabled\"  — always use the generalist agent\n136:    */\n137:   mode: AgentRegistryMode;\n138:   /** GitHub repo in \"owner/repo\" format to pull agent definitions from */\n139:   source: string;\n140:   /** Cache directory name (relative to .wombo-combo/) */\n141:   cacheDir: string;\n142:   /** Cache TTL in milliseconds. Cached agents older than this are re-fetched. Default 24h. */\n143:   cacheTTL: number;\n144: }\n145: \n146: /** Configuration for Test-Driven Development workflow */\n147: export interface TddConfig {\n148:   /** Enable TDD red-green-refactor instructions in agent prompts */\n149:   enabled: boolean;\n150:   /** Test command to run (default: \"bun test\") */\n151:   testCommand: string;\n152:   /** Strict TDD mode: fail verification if new files are missing tests */\n153:   strictTdd: boolean;\n154:   /** Test command timeout in milliseconds (default: 120_000) */\n155:   testTimeout: number;\n156: }\n157: \n158: // ---------------------------------------------------------------------------\n159: // Defaults\n160: // ---------------------------------------------------------------------------\n161: \n162: export const DEFAULT_CONFIG: WomboConfig = {\n163:   tasksDir: \"tasks\",\n164:   archiveDir: \"archive\",\n165:   baseBranch: \"develop\",\n166:   build: {\n167:     command: \"bun run build\",\n168:     timeout: 300_000,\n169:     artifactDir: \"dist\",\n170:   },\n171:   install: {\n172:     command: \"bun install\",\n173:     timeout: 120_000,\n174:   },\n175:   git: {\n176:     branchPrefix: \"feature/\",\n177:     worktreePrefix: \"wombo-\",\n178:     remote: \"origin\",\n179:     mergeStrategy: \"--no-ff\",\n180:   },\n181:   agent: {\n182:     bin: null,\n183:     name: \"generalist-agent\",\n184:     configFiles: [\".opencode/\", \"opencode.json\", \"AGENTS.md\"],\n185:     tmuxPrefix: \"wombo\",\n186:     multiplexer: \"auto\",\n187:   },\n188:   portless: {\n189:     enabled: true,\n190:     bin: null,\n191:     proxyPort: 1355,\n192:     https: false,\n193:   },\n194:   backup: {\n195:     maxBackups: 5,\n196:   },\n197:   defaults: {\n198:     maxConcurrent: 6,\n199:     maxRetries: 2,\n200:   },\n201:   browser: {\n202:     enabled: false,\n203:     bin: null,\n204:     headless: true,\n205:     testCommand: null,\n206:     launchTimeout: 30_000,\n207:     testTimeout: 60_000,\n208:     defaultViewport: {\n209:       width: 1280,\n210:       height: 720,\n211:     },\n212:   },\n213:   agentRegistry: {\n214:     mode: \"auto\",\n215:     source: \"msitarzewski/agency-agents\",\n216:     cacheDir: \"agents-cache\",\n217:     cacheTTL: 24 * 60 * 60 * 1000, // 24 hours\n218:   },\n219:   tdd: {\n220:     enabled: false,\n221:     testCommand: \"bun test\",\n222:     strictTdd: false,\n223:     testTimeout: 120_000,\n224:   },\n225: };\n226: \n227: // ---------------------------------------------------------------------------\n228: // Config File Name\n229: // ---------------------------------------------------------------------------\n230: \n231: export const CONFIG_FILE = `${WOMBO_DIR}/config.json`;\n232: \n233: // ---------------------------------------------------------------------------\n234: // Loader\n235: // ---------------------------------------------------------------------------\n236: \n237: /**\n238:  * Deep-merge source into target. Only merges plain objects, not arrays.\n239:  */\n240: function deepMerge<T extends Record<string, any>>(target: T, source: Partial<T>): T {\n241:   const result = { ...target };\n242:   for (const key of Object.keys(source) as (keyof T)[]) {\n243:     const srcVal = source[key];\n244:     const tgtVal = target[key];\n245:     if (\n246:       srcVal !== undefined &&\n247:       srcVal !== null &&\n248:       typeof srcVal === \"object\" &&\n249:       !Array.isArray(srcVal) &&\n250:       typeof tgtVal === \"object\" &&\n251:       !Array.isArray(tgtVal) &&\n252:       tgtVal !== null\n253:     ) {\n254:       result[key] = deepMerge(tgtVal as any, srcVal as any);\n255:     } else if (srcVal !== undefined) {\n256:       result[key] = srcVal as T[keyof T];\n257:     }\n258:   }\n259:   return result;\n260: }\n261: \n262: /**\n263:  * Load .wombo-combo/config.json from the given project root and merge with defaults.\n264:  * Returns the full config. If no config file exists, returns defaults.\n265:  */\n266: export function loadConfig(projectRoot: string): WomboConfig {\n267:   const configPath = resolve(projectRoot, CONFIG_FILE);\n268: \n269:   if (!existsSync(configPath)) {\n270:     return { ...DEFAULT_CONFIG };\n271:   }\n272: \n273:   try {\n274:     const raw = readFileSync(configPath, \"utf-8\");\n275:     const partial = JSON.parse(raw) as Partial<WomboConfig>;\n276: \n277:     // Migrate legacy single-file config keys to folder-based\n278:     if ((partial as any).tasksFile && !partial.tasksDir) {\n279:       // Legacy \"tasks.yml\" → strip extension for dir name, or use as-is\n280:       const legacy = (partial as any).tasksFile as string;\n281:       partial.tasksDir = legacy.replace(/\\.ya?ml$/i, \"\") || \"tasks\";\n282:       delete (partial as any).tasksFile;\n283:     }\n284:     if ((partial as any).archiveFile && !partial.archiveDir) {\n285:       const legacy = (partial as any).archiveFile as string;\n286:       partial.archiveDir = legacy.replace(/\\.ya?ml$/i, \"\") || \"archive\";\n287:       delete (partial as any).archiveFile;\n288:     }\n289: \n290:     return deepMerge(DEFAULT_CONFIG, partial);\n291:   } catch (err: any) {\n292:     throw new Error(`Failed to load ${CONFIG_FILE}: ${err.message}`);\n293:   }\n294: }\n295: \n296: /**\n297:  * Resolve the agent binary path. Priority:\n298:  *   1. config.agent.bin (explicit)\n299:  *   2. OPENCODE_BIN env var\n300:  *   3. ~/.opencode/bin/opencode (default install location)\n301:  */\n302: export function resolveAgentBin(config: WomboConfig): string {\n303:   if (config.agent.bin) return config.agent.bin;\n304:   if (process.env.OPENCODE_BIN) return process.env.OPENCODE_BIN;\n305:   return resolve(process.env.HOME || \"~\", \".opencode/bin/opencode\");\n306: }\n307: \n308: /**\n309:  * Validate the config for obvious issues. Throws on error.\n310:  */\n311: export function validateConfig(config: WomboConfig): void {\n312:   if (!config.tasksDir) {\n313:     throw new Error(\"config.tasksDir must be a non-empty string\");\n314:   }\n315:   if (!config.archiveDir) {\n316:     throw new Error(\"config.archiveDir must be a non-empty string\");\n317:   }\n318:   if (!config.baseBranch) {\n319:     throw new Error(\"config.baseBranch must be a non-empty string\");\n320:   }\n321:   if (!config.build.command) {\n322:     throw new Error(\"config.build.command must be a non-empty string\");\n323:   }\n324:   if (!config.install.command) {\n325:     throw new Error(\"config.install.command must be a non-empty string\");\n326:   }\n327:   if (!config.git.branchPrefix) {\n328:     throw new Error(\"config.git.branchPrefix must be a non-empty string\");\n329:   }\n330:   if (!config.git.worktreePrefix) {\n331:     throw new Error(\"config.git.worktreePrefix must be a non-empty string\");\n332:   }\n333:   if (config.defaults.maxConcurrent < 1) {\n334:     throw new Error(\"config.defaults.maxConcurrent must be >= 1\");\n335:   }\n336:   if (config.defaults.maxRetries < 0) {\n337:     throw new Error(\"config.defaults.maxRetries must be >= 0\");\n338:   }\n339:   if (config.backup.maxBackups < 0) {\n340:     throw new Error(\"config.backup.maxBackups must be >= 0\");\n341:   }\n342:   const validModes: AgentRegistryMode[] = [\"auto\", \"monitored\", \"disabled\"];\n343:   if (!validModes.includes(config.agentRegistry.mode)) {\n344:     throw new Error(`config.agentRegistry.mode must be one of: ${validModes.join(\", \")}`);\n345:   }\n346:   if (!config.agentRegistry.source) {\n347:     throw new Error(\"config.agentRegistry.source must be a non-empty string\");\n348:   }\n349:   if (!config.agentRegistry.cacheDir) {\n350:     throw new Error(\"config.agentRegistry.cacheDir must be a non-empty string\");\n351:   }\n352:   if (config.tdd.enabled && !config.tdd.testCommand) {\n353:     throw new Error(\"config.tdd.testCommand must be a non-empty string when TDD is enabled\");\n354:   }\n355: }\n356: \n357: /**\n358:  * Generate the default .wombo-combo/config.json content string (for `woco init`).\n359:  */\n360: export function generateDefaultConfig(): string {\n361:   return JSON.stringify(DEFAULT_CONFIG, null, 2) + \"\\n\";\n362: }\n\n(End of file - total 362 lines)\n</content>","title":"src/config.ts","metadata":{"preview":"/**\n * config.ts — Load .wombo-combo/config.json, merge with defaults, validate, expose typed config.\n *\n * The config file lives at .wombo-combo/config.json inside the target project root.\n * All values have sensible defaults so minimal config works out of the box.\n */\n\nimport { readFileSync, existsSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\nimport type { MultiplexerPreference } from \"./lib/multiplexer.js\";\n\n// ---------------------------------------------------------------------------\n// .wombo-combo directory constant\n// ---------------------------------------------------------------------------\n\n/** Name of the directory that holds all wombo-combo files */\nexport const WOMBO_DIR = \".wombo-combo\";\n\n// ---------------------------------------------------------------------------\n// Types","truncated":false,"loaded":[]},"time":{"start":1773437444667,"end":1773437444670}}}}
{"type":"tool_use","timestamp":1773437445185,"sessionID":"ses_316e48f3cffeGrhJEXdprD247G","part":{"id":"prt_ce91be23c0016WmZy2PXicH5eX","sessionID":"ses_316e48f3cffeGrhJEXdprD247G","messageID":"msg_ce91bd183001mtAclIxaVxtUds","type":"tool","callID":"toolu_vrtx_01Ckgj4pnS8z1AFyg4tYTsod","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-agent-selection-per-feature/src/lib/state.ts","limit":100},"output":"<path>/home/fulgidus/Documents/wt-wombo-agent-selection-per-feature/src/lib/state.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * state.ts — Persistent wave state management.\n3:  *\n4:  * Responsibilities:\n5:  *   - Define the shape of .wombo-combo/state.json\n6:  *   - Read/write state atomically\n7:  *   - Generate wave IDs\n8:  *   - Update individual agent state within a wave\n9:  */\n10: \n11: import { readFileSync, writeFileSync, existsSync, renameSync, mkdirSync } from \"node:fs\";\n12: import { resolve } from \"node:path\";\n13: import { WOMBO_DIR } from \"../config.js\";\n14: \n15: // ---------------------------------------------------------------------------\n16: // Types\n17: // ---------------------------------------------------------------------------\n18: \n19: export type AgentStatus =\n20:   | \"queued\"\n21:   | \"installing\"\n22:   | \"running\"\n23:   | \"completed\"\n24:   | \"verified\"\n25:   | \"failed\"\n26:   | \"merged\"\n27:   | \"retry\"\n28:   | \"resolving_conflict\";\n29: \n30: export interface AgentState {\n31:   feature_id: string;\n32:   branch: string;\n33:   worktree: string;\n34:   session_id: string | null;\n35:   pid: number | null;\n36:   status: AgentStatus;\n37:   activity: string | null;\n38:   activity_updated_at: string | null;\n39:   retries: number;\n40:   max_retries: number;\n41:   started_at: string | null;\n42:   completed_at: string | null;\n43:   build_passed: boolean | null;\n44:   build_output: string | null;\n45:   error: string | null;\n46:   /** Estimated effort in milliseconds (from feature's ISO 8601 duration) */\n47:   effort_estimate_ms: number | null;\n48:   /** Stream index this agent belongs to (for dependency-aware scheduling) */\n49:   stream_index: number | null;\n50:   /** IDs of features this agent depends on (within the current wave) */\n51:   depends_on: string[];\n52:   /** IDs of features that depend on this agent (within the current wave) */\n53:   depended_on_by: string[];\n54:   /**\n55:    * Override agent name for this specific agent (from registry).\n56:    * When set, uses this agent definition instead of the default generalist.\n57:    * e.g. \"engineering-frontend-developer\"\n58:    */\n59:   agent_name: string | null;\n60:   /**\n61:    * The agent_type from the task (e.g. \"engineering/engineering-frontend-developer\").\n62:    * Stored for informational purposes and to support resume with re-fetch.\n63:    */\n64:   agent_type: string | null;\n65: }\n66: \n67: export interface WaveState {\n68:   wave_id: string;\n69:   base_branch: string;\n70:   started_at: string;\n71:   updated_at: string;\n72:   max_concurrent: number;\n73:   model: string | null;\n74:   interactive: boolean;\n75:   agents: AgentState[];\n76:   /** Dependency-aware scheduling plan (null if no dependencies exist) */\n77:   schedule_plan: SerializedSchedulePlan | null;\n78: }\n79: \n80: /**\n81:  * Serialized schedule plan stored in wave state JSON.\n82:  * Uses plain arrays instead of the rich SchedulePlan type for JSON compatibility.\n83:  */\n84: export interface SerializedSchedulePlan {\n85:   /** Streams: each is a list of feature IDs to execute sequentially */\n86:   streams: string[][];\n87:   /** Merge gates: features that must wait for multiple deps from different streams */\n88:   merge_gates: Array<{ feature_id: string; wait_for: string[] }>;\n89:   /** Topological order of all features */\n90:   topological_order: string[];\n91: }\n92: \n93: // ---------------------------------------------------------------------------\n94: // Constants\n95: // ---------------------------------------------------------------------------\n96: \n97: const STATE_FILE = \".wombo-combo/state.json\";\n98: \n99: // ---------------------------------------------------------------------------\n100: // Wave ID Generation\n\n(Showing lines 1-100 of 394. Use offset=101 to continue.)\n</content>","title":"src/lib/state.ts","metadata":{"preview":"/**\n * state.ts — Persistent wave state management.\n *\n * Responsibilities:\n *   - Define the shape of .wombo-combo/state.json\n *   - Read/write state atomically\n *   - Generate wave IDs\n *   - Update individual agent state within a wave\n */\n\nimport { readFileSync, writeFileSync, existsSync, renameSync, mkdirSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\nimport { WOMBO_DIR } from \"../config.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type AgentStatus =\n  | \"queued\"","truncated":true,"loaded":[]},"time":{"start":1773437445181,"end":1773437445184}}}}
