     started_at: null,\n77:     completed_at: null,\n78:     build_passed: null,\n79:     build_output: null,\n80:     error: null,\n81:     effort_estimate_ms: null,\n82:     ...overrides,\n83:   };\n84: }\n85: \n86: // ---------------------------------------------------------------------------\n87: // generateWaveId\n88: // ---------------------------------------------------------------------------\n89: \n\n(Showing lines 30-89 of 643. Use offset=90 to continue.)\n</content>","title":"tests/state.test.ts","metadata":{"preview":"  queuedAgents,\n  isWaveComplete,\n  generateWaveId,\n} from \"../src/lib/state.js\";\nimport type { WaveState, AgentState, AgentStatus } from \"../src/lib/state.js\";\n\n// ---------------------------------------------------------------------------\n// Helpers\n// ---------------------------------------------------------------------------\n\nlet tmpDir: string;\n\nbeforeEach(() => {\n  tmpDir = mkdtempSync(join(tmpdir(), \"wombo-test-state-\"));\n});\n\nafterEach(() => {\n  rmSync(tmpDir, { recursive: true, force: true });\n});\n","truncated":true,"loaded":[]},"time":{"start":1773436157491,"end":1773436157494}}}}
