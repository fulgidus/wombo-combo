epoDir);\n532:             } catch {\n533:               // best effort\n534:             }\n535:           }\n536:         }\n537:       } catch {\n538:         // repo may be gone\n539:       }\n540:       cleanupTempDir(resolve(repoDir, \"..\"));\n541:     }\n542:   });\n543: \n544:   test(\"no warnings when all config files are present\", () => {\n545:     repoDir = createTempGitRepo(\"my-project\");\n546:     const parentDir = resolve(repoDir, \"..\");\n547: \n548:     // Create config files in project root\n549:     mkdirSync(join(repoDir, \".opencode\", \"agents\"), { recursive: true });\n550:     writeFileSync(join(repoDir, \".opencode\", \"agents\", \"agent.json\"), \"{}\");\n551:     writeFileSync(join(repoDir, \"opencode.json\"), \"{}\");\n552:     writeFileSync(join(repoDir, \"AGENTS.md\"), \"# Agents\\n\");\n553: \n554:     // Commit them so they appear in the worktree\n555:     git(\"add .\", repoDir);\n556:     git('commit -m \"add config\"', repoDir);\n557: \n558:     // Create a worktree\n559:     git(\"branch feature/test main\", repoDir);\n560:     const wtPath = join(parentDir, \"woco-test\");\n561:     git(`worktree add \"${wtPath}\" feature/test`, repoDir);\n562: \n563:     const config = makeConfig(\n564:       {},\n565:       { configFiles: [\".opencode/\", \"opencode.json\", \"AGENTS.md\"] }\n566:     );\n567: \n568:     // Capture console.log to check for warnings\n569:     const logs: string[] = [];\n570:     const origLog = console.log;\n571:     console.log = (...args: any[]) => logs.push(args.join(\" \"));\n572: \n573:     try {\n574:       verifyConfigFiles(repoDir, wtPath, \"test\", config);\n575:     } finally {\n576:       console.log = origLog;\n577:     }\n578: \n579:     // Since files are in git, they should be present in the worktree\n580:     const warningLogs = logs.filter((l) => l.includes(\"WARNING\"));\n581:     expect(warningLogs).toHaveLength(0);\n582:   });\n583: \n584:   test(\"logs warning when config files are missing from worktree\", () => {\n585:     repoDir = createTempGitRepo(\"my-project\");\n586:     const parentDir = resolve(repoDir, \"..\");\n587: \n588:     // Create config files in project root (NOT committed to git)\n589:     mkdirSync(join(repoDir, \".opencode\"), { recursive: true });\n590:     writeFileSync(join(repoDir, \"opencode.json\"), \"{}\");\n591:     // Note: AGENTS.md exists in project root but NOT in worktree since not committed\n592: \n593:     // Create a worktree\n594:     git(\"branch feature/test main\", repoDir);\n595:     const wtPath = join(parentDir, \"woco-test\");\n596:     git(`worktree add \"${wtPath}\" feature/test`, repoDir);\n597: \n598:     const config = makeConfig(\n599:       {},\n600:       { configFiles: [\".opencode/\", \"opencode.json\", \"AGENTS.md\"] }\n601:     );\n602: \n603:     // The config files exist in projectRoot but NOT in the worktree\n604:     // (because they weren't committed to git)\n605:     const logs: string[] = [];\n606:     const origLog = console.log;\n607:     console.log = (...args: any[]) => logs.push(args.join(\" \"));\n608: \n609:     try {\n610:       verifyConfigFiles(repoDir, wtPath, \"test\", config);\n611:     } finally {\n612:       console.log = origLog;\n613:     }\n614: \n615:     // Should warn about missing files\n616:     const warningLogs = logs.filter((l) => l.includes(\"WARNING\"));\n617:     expect(warningLogs.length).toBeGreaterThan(0);\n618:     // The warning should mention the missing config files\n619:     const warningText = warningLogs.join(\" \");\n620:     expect(warningText).toContain(\"missing in worktree\");\n621:   });\n622: \n623:   test(\"skips files that don't exist in source project\", () => {\n624:     repoDir = createTempGitRepo(\"my-project\");\n625:     const parentDir = resolve(repoDir, \"..\");\n626: \n627:     // Create a worktree\n628:     git(\"branch feature/test main\", repoDir);\n629:     const wtPath = join(parentDir, \"woco-test\");\n630:     git(`worktree add \"${wtPath}\" feature/test`, repoDir);\n631: \n632:     // Config references files that don't exist in the source project\n633:     const config = makeConfig(\n634:       {},\n635:       { configFiles: [\"nonexistent-file.json\", \".nonexistent-dir/\"] }\n636:     );\n637: \n638:     const logs: string[] = [];\n639:     const origLog = console.log;\n640:     console.log = (...args: any[]) => logs.push(args.join(\" \"));\n641: \n642:     try {\n643:       verifyConfigFiles(repoDir, wtPath, \"test\", config);\n644:     } finally {\n645:       console.log = origLog;\n646:     }\n647: \n648:     // No warnings because the source files don't exist — nothing to verify\n649:     const warningLogs = logs.filter((l) => l.includes(\"WARNING\"));\n650:     expect(warningLogs).toHaveLength(0);\n651:   });\n652: \n653:   test(\"correctly handles empty configFiles list\", () => {\n654:     repoDir = createTempGitRepo(\"my-project\");\n655:     const parentDir = resolve(repoDir, \"..\");\n656: \n657:     git(\"branch feature/test main\", repoDir);\n658:     const wtPath = join(parentDir, \"woco-test\");\n659:     git(`worktree add \"${wtPath}\" feature/test`, repoDir);\n660: \n661:     const config = makeConfig({}, { configFiles: [] });\n662: \n663:     // Should not throw or warn with empty config list\n664:     const logs: string[] = [];\n665:     const origLog = console.log;\n666:     console.log = (...args: any[]) => logs.push(args.join(\" \"));\n667: \n668:     try {\n669:       verifyConfigFiles(repoDir, wtPath, \"test\", config);\n670:     } finally {\n671:       console.log = origLog;\n672:     }\n673: \n674:     const warningLogs = logs.filter((l) => l.includes(\"WARNING\"));\n675:     expect(warningLogs).toHaveLength(0);\n676:   });\n677: \n678:   test(\"detects missing directory config files\", () => {\n679:     repoDir = createTempGitRepo(\"my-project\");\n680:     const parentDir = resolve(repoDir, \"..\");\n681: \n682:     // Create a directory config in project root (not committed)\n683:     mkdirSync(join(repoDir, \".opencode\", \"agents\"), { recursive: true });\n684:     writeFileSync(\n685:       join(repoDir, \".opencode\", \"agents\", \"config.json\"),\n686:       '{\"name\":\"test\"}'\n687:     );\n688: \n689:     git(\"branch feature/test main\", repoDir);\n690:     const wtPath = join(parentDir, \"woco-test\");\n691:     git(`worktree add \"${wtPath}\" feature/test`, repoDir);\n692: \n693:     const config = makeConfig({}, { configFiles: [\".opencode/\"] });\n694: \n695:     const logs: string[] = [];\n696:     const origLog = console.log;\n697:     console.log = (...args: any[]) => logs.push(args.join(\" \"));\n698: \n699:     try {\n700:       verifyConfigFiles(repoDir, wtPath, \"test\", config);\n701:     } finally {\n702:       console.log = origLog;\n703:     }\n704: \n705:     // The directory exists in source but not worktree (not committed)\n706:     const warningLogs = logs.filter((l) => l.includes(\"WARNING\"));\n707:     expect(warningLogs.length).toBeGreaterThan(0);\n708:     expect(warningLogs[0]).toContain(\".opencode/\");\n709:   });\n710: });\n711: \n712: // ---------------------------------------------------------------------------\n713: // createWorktree — integration test that config files are actually copied\n714: // ---------------------------------------------------------------------------\n715: \n716: describe(\"createWorktree — config file copying integration\", () => {\n717:   let repoDir: string;\n718: \n719:   afterEach(() => {\n720:     if (repoDir) {\n721:       try {\n722:         const worktrees = listWorktrees(repoDir);\n723:         for (const wt of worktrees) {\n724:           if (resolve(wt.path) !== resolve(repoDir)) {\n725:             try {\n726:               git(`worktree remove --force \"${wt.path}\"`, repoDir);\n727:             } catch {\n728:               // best effort\n729:             }\n730:           }\n731:         }\n732:       } catch {\n733:         // repo may be gone\n734:       }\n735:       cleanupTempDir(resolve(repoDir, \"..\"));\n736:     }\n737:   });\n738: \n739:   test(\"copies config files into newly created worktree\", async () => {\n740:     repoDir = createTempGitRepo(\"my-project\");\n741: \n742:     // Create config files in project root (untracked)\n743:     mkdirSync(join(repoDir, \".opencode\", \"agents\"), { recursive: true });\n744:     writeFileSync(\n745:       join(repoDir, \".opencode\", \"agents\", \"agent.json\"),\n746:       '{\"name\":\"test-agent\"}'\n747:     );\n748:     writeFileSync(join(repoDir, \"AGENTS.md\"), \"# Agent Instructions\\n\");\n749: \n750:     const config = makeConfig(\n751:       {},\n752:       { configFiles: [\".opencode/\", \"AGENTS.md\"] }\n753:     );\n754: \n755:     const wtPath = await createWorktree(\n756:       repoDir,\n757:       \"my-feat\",\n758:       \"main\",\n759:       config\n760:     );\n761: \n762:     // Config files should have been copied into the worktree\n763:     expect(existsSync(join(wtPath, \".opencode\", \"agents\", \"agent.json\"))).toBe(\n764:       true\n765:     );\n766:     expect(existsSync(join(wtPath, \"AGENTS.md\"))).toBe(true);\n767: \n768:     // Verify content was copied correctly\n769:     const agentJson = readFileSync(\n770:       join(wtPath, \".opencode\", \"agents\", \"agent.json\"),\n771:       \"utf-8\"\n772:     );\n773:     expect(agentJson).toBe('{\"name\":\"test-agent\"}');\n774: \n775:     const agentsMd = readFileSync(join(wtPath, \"AGENTS.md\"), \"utf-8\");\n776:     expect(agentsMd).toBe(\"# Agent Instructions\\n\");\n777:   });\n778: });\n779: \n780: // ---------------------------------------------------------------------------\n781: // Edge case: prefix that is a substring of another prefix\n782: // ---------------------------------------------------------------------------\n783: \n784: describe(\"listWomboWorktrees — prefix substring edge cases\", () => {\n785:   let repoDir: string;\n786: \n787:   afterEach(() => {\n788:     if (repoDir) {\n789:       try {\n790:         const worktrees = listWorktrees(repoDir);\n791:         for (const wt of worktrees) {\n792:           if (resolve(wt.path) !== resolve(repoDir)) {\n793:             try {\n794:               git(`worktree remove --force \"${wt.path}\"`, repoDir);\n795:             } catch {\n796:               // best effort\n797:             }\n798:           }\n799:         }\n800:       } catch {\n801:         // repo may be gone\n802:       }\n803:       cleanupTempDir(resolve(repoDir, \"..\"));\n804:     }\n805:   });\n806: \n807:   test(\"prefix 'woco-' does not match 'woc-something'\", () => {\n808:     repoDir = createTempGitRepo(\"my-project\");\n809:     const parentDir = resolve(repoDir, \"..\");\n810:     const config = makeConfig({ worktreePrefix: \"woco-\" });\n811: \n812:     git(\"branch feature/x main\", repoDir);\n813:     const wtPath = join(parentDir, \"woc-something\");\n814:     git(`worktree add \"${wtPath}\" feature/x`, repoDir);\n815: \n816:     const result = listWomboWorktrees(repoDir, config);\n817:     expect(result).toHaveLength(0);\n818:   });\n819: \n820:   test(\"prefix 'woco-' matches 'woco-' exactly (e.g. woco-a)\", () => {\n821:     repoDir = createTempGitRepo(\"my-project\");\n822:     const parentDir = resolve(repoDir, \"..\");\n823:     const config = makeConfig({ worktreePrefix: \"woco-\" });\n824: \n825:     git(\"branch feature/a main\", repoDir);\n826:     const wtPath = join(parentDir, \"woco-a\");\n827:     git(`worktree add \"${wtPath}\" feature/a`, repoDir);\n828: \n829:     const result = listWomboWorktrees(repoDir, config);\n830:     expect(result).toHaveLength(1);\n831:   });\n832: \n833:   test(\"handles project root exactly matching prefix (edge case 'woco-')\", () => {\n834:     // What if the project dir is literally \"woco-\" (just the prefix, no suffix)?\n835:     repoDir = createTempGitRepo(\"woco-\");\n836:     const parentDir = resolve(repoDir, \"..\");\n837:     const config = makeConfig({ worktreePrefix: \"woco-\" });\n838: \n839:     git(\"branch feature/test main\", repoDir);\n840:     const wtPath = join(parentDir, \"woco-test\");\n841:     git(`worktree add \"${wtPath}\" feature/test`, repoDir);\n842: \n843:     const result = listWomboWorktrees(repoDir, config);\n844: \n845:     // Project root \"woco-\" must be excluded, only \"woco-test\" should match\n846:     expect(result).toHaveLength(1);\n847:     expect(result[0].path).toBe(wtPath);\n848:     expect(result.map((w) => resolve(w.path))).not.toContain(resolve(repoDir));\n849:   });\n850: });\n\n(End of file - total 850 lines)\n</content>","title":"tests/worktree-filtering.test.ts","metadata":{"preview":"/**\n * worktree-filtering.test.ts — Integration tests for worktree listing, filtering,\n * and safety guards using real temporary git repositories.\n *\n * Critical coverage:\n *   - listWomboWorktrees(): filters by config.git.worktreePrefix, excludes project root\n *     even when project dir name starts with the prefix (e.g. \"wombo-combo\" with prefix\n *     \"wombo-\", and the dangerous case \"woco-something\" with prefix \"woco-\")\n *   - removeWorktree(): safety guard must never remove project root or non-worktree dirs\n *   - cleanupAllWorktrees(): removes all woco worktrees, skips non-woco ones\n *   - verifyConfigFiles(): ensures config files are copied into worktrees\n */\n\nimport { describe, test, expect, beforeEach, afterEach } from \"bun:test\";\nimport {\n  mkdtempSync,\n  mkdirSync,\n  writeFileSync,\n  existsSync,\n  rmSync,","truncated":false,"loaded":[]},"time":{"start":1773435846149,"end":1773435846280}}}}
