{"type":"tool_use","timestamp":1773435838719,"sessionID":"ses_316fcc12bffeSBLLi3jBrbT2M4","part":{"id":"prt_ce9035f5c001drTV3MLy0HmFUC","sessionID":"ses_316fcc12bffeSBLLi3jBrbT2M4","messageID":"msg_ce903559e0012I5jfoZVY0Cr0j","type":"tool","callID":"toolu_vrtx_01Aht6nPM6n7k3qhByVMx6YR","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-unit-test-suite/src/lib/tasks.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-unit-test-suite/src/lib/tasks.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tasks.ts -- Parse tasks YAML and provide task selection/filtering.\n3:  *\n4:  * Responsibilities:\n5:  *   - Load and parse the tasks file with full type safety\n6:  *   - Load and parse the archive file separately\n7:  *   - Parse ISO 8601 durations into comparable minutes\n8:  *   - Filter tasks by status, priority, difficulty, dependency readiness\n9:  *   - Select tasks by various strategies (top-priority, quickest-wins, etc.)\n10:  *   - Resolve dependency graphs to determine which tasks are ready to start\n11:  *   - Write-back capability for task management commands\n12:  */\n13: \n14: import { existsSync, mkdirSync } from \"node:fs\";\n15: import { resolve, dirname, join } from \"node:path\";\n16: import { createInterface } from \"node:readline\";\n17: import type { WomboConfig } from \"../config.js\";\n18: import { WOMBO_DIR } from \"../config.js\";\n19: import {\n20:   loadTasksFromStore,\n21:   loadArchiveFromStore,\n22:   saveAllTasksToStore,\n23:   saveAllArchiveToStore,\n24:   saveTaskToStore,\n25:   saveTaskToArchive,\n26:   removeTaskFromStore,\n27:   tasksStoreExists,\n28:   saveTasksMetaToStore,\n29:   saveArchiveMetaToStore,\n30:   getTasksDir,\n31:   getArchiveDir,\n32:   saveTaskFile,\n33:   deleteTaskFile,\n34: } from \"./task-store.js\";\n35: \n36: // ---------------------------------------------------------------------------\n37: // Template path (resolved relative to this source file)\n38: // ---------------------------------------------------------------------------\n39: \n40: export const META_TEMPLATE_PATH = join(dirname(import.meta.dir), \"templates\", \"_meta.yml\");\n41: /** @deprecated Use META_TEMPLATE_PATH — the old monolithic template no longer exists. */\n42: export const TASKS_TEMPLATE_PATH = META_TEMPLATE_PATH;\n43: \n44: // ---------------------------------------------------------------------------\n45: // Types\n46: // ---------------------------------------------------------------------------\n47: \n48: export type TaskStatus =\n49:   | \"backlog\"\n50:   | \"planned\"\n51:   | \"in_progress\"\n52:   | \"blocked\"\n53:   | \"in_review\"\n54:   | \"done\"\n55:   | \"cancelled\";\n56: \n57: export type Priority = \"critical\" | \"high\" | \"medium\" | \"low\" | \"wishlist\";\n58: \n59: export type Difficulty = \"trivial\" | \"easy\" | \"medium\" | \"hard\" | \"very_hard\";\n60: \n61: /**\n62:  * Unified task type. Previously split into Feature and Subtask, but the shapes\n63:  * are identical so there is no reason to maintain two names.\n64:  */\n65: export interface Task {\n66:   id: string;\n67:   title: string;\n68:   description: string;\n69:   status: TaskStatus;\n70:   completion: number;\n71:   difficulty: Difficulty;\n72:   priority: Priority;\n73:   depends_on: string[];\n74:   effort: string;\n75:   started_at: string | null;\n76:   ended_at: string | null;\n77:   constraints: string[];\n78:   forbidden: string[];\n79:   references: string[];\n80:   notes: string[];\n81:   subtasks: Task[];\n82:   /**\n83:    * Optional agent type from an external registry (e.g. agency-agents).\n84:    * Format: \"category/agent-name\" (e.g. \"engineering/engineering-frontend-developer\").\n85:    * When set, wombo downloads and patches the specified agent definition\n86:    * instead of using the default generalist agent.\n87:    */\n88:   agent_type?: string;\n89: }\n90: \n91: /**\n92:  * Shape of tasks.yml (active tasks).\n93:  */\n94: export interface TasksFile {\n95:   version: string;\n96:   meta: {\n97:     created_at: string;\n98:     updated_at: string;\n99:     project: string;\n100:     generator: string;\n101:     maintainer: string;\n102:   };\n103:   tasks: Task[];\n104: }\n105: \n106: /**\n107:  * Shape of archive.yml (archived tasks). Same structure as TasksFile.\n108:  */\n109: export type ArchiveFile = TasksFile;\n110: \n111: // Backward-compat aliases (ease migration in consuming code)\n112: export type Feature = Task;\n113: export type Subtask = Task;\n114: export type FeatureStatus = TaskStatus;\n115: export type FeaturesFile = TasksFile & { archive: Task[] };\n116: \n117: // Re-export ordering maps from the canonical source (task-schema.ts)\n118: import { PRIORITY_ORDER, DIFFICULTY_ORDER } from \"./task-schema.js\";\n119: export { PRIORITY_ORDER, DIFFICULTY_ORDER };\n120: \n121: // ---------------------------------------------------------------------------\n122: // ISO 8601 Duration Parser\n123: // ---------------------------------------------------------------------------\n124: \n125: /**\n126:  * Parse an ISO 8601 duration string into total minutes.\n127:  * Supports: P[nY][nM][nD][T[nH][nM][nS]]\n128:  * Examples: PT1H -> 60, PT30M -> 30, P1D -> 1440, P2DT4H -> 3360, PT1H30M -> 90\n129:  *           P1Y -> 525600, P2M -> 86400\n130:  * Year/month approximations: 1Y = 365D, 1M = 30D\n131:  */\n132: export function parseDurationMinutes(iso: string): number {\n133:   const match = iso.match(\n134:     /^P(?:(\\d+)Y)?(?:(\\d+)M)?(?:(\\d+)D)?(?:T(?:(\\d+)H)?(?:(\\d+)M)?(?:(\\d+)S)?)?$/\n135:   );\n136:   if (!match) return Infinity; // unparseable -> sort to end\n137:   const years = parseInt(match[1] || \"0\", 10);\n138:   const months = parseInt(match[2] || \"0\", 10);\n139:   const days = parseInt(match[3] || \"0\", 10);\n140:   const hours = parseInt(match[4] || \"0\", 10);\n141:   const minutes = parseInt(match[5] || \"0\", 10);\n142:   const seconds = parseInt(match[6] || \"0\", 10);\n143:   const totalDays = years * 365 + months * 30 + days;\n144:   return totalDays * 24 * 60 + hours * 60 + minutes + Math.ceil(seconds / 60);\n145: }\n146: \n147: /**\n148:  * Format minutes into a human-readable string.\n149:  */\n150: export function formatDuration(minutes: number): string {\n151:   if (minutes === Infinity) return \"unknown\";\n152:   if (minutes < 60) return `${minutes}m`;\n153:   const h = Math.floor(minutes / 60);\n154:   const m = minutes % 60;\n155:   if (h >= 24) {\n156:     const d = Math.floor(h / 24);\n157:     const rh = h % 24;\n158:     if (rh === 0 && m === 0) return `${d}d`;\n159:     if (m === 0) return `${d}d ${rh}h`;\n160:     return `${d}d ${rh}h ${m}m`;\n161:   }\n162:   return m === 0 ? `${h}h` : `${h}h ${m}m`;\n163: }\n164: \n165: // ---------------------------------------------------------------------------\n166: // .wombo-combo directory helpers\n167: // ---------------------------------------------------------------------------\n168: \n169: /**\n170:  * Ensure the .wombo-combo directory exists.\n171:  */\n172: export function ensureWomboDir(projectRoot: string): string {\n173:   const dir = resolve(projectRoot, WOMBO_DIR);\n174:   if (!existsSync(dir)) {\n175:     mkdirSync(dir, { recursive: true });\n176:   }\n177:   return dir;\n178: }\n179: \n180: /**\n181:  * Resolve a file path within the .wombo-combo directory.\n182:  */\n183: function womboPath(projectRoot: string, filename: string): string {\n184:   return resolve(projectRoot, WOMBO_DIR, filename);\n185: }\n186: \n187: // ---------------------------------------------------------------------------\n188: // Tasks File Existence Guard\n189: // ---------------------------------------------------------------------------\n190: \n191: /**\n192:  * Prompt the user with a yes/no question via stdin.\n193:  */\n194: function promptYesNo(question: string): Promise<boolean> {\n195:   const rl = createInterface({ input: process.stdin, output: process.stdout });\n196:   return new Promise((resolve) => {\n197:     rl.question(question, (answer) => {\n198:       rl.close();\n199:       resolve(answer.trim().toLowerCase().startsWith(\"y\"));\n200:     });\n201:   });\n202: }\n203: \n204: /**\n205:  * Ensure the tasks store exists before any command that needs it.\n206:  * If the folder is missing, prompt the user to generate one from scratch\n207:  * or auto-migrate from a legacy single-file tasks.yml.\n208:  */\n209: export async function ensureTasksFile(\n210:   projectRoot: string,\n211:   config: WomboConfig\n212: ): Promise<void> {\n213:   if (tasksStoreExists(projectRoot, config)) return;\n214: \n215:   // Try loading — this triggers auto-migration from legacy files\n216:   const data = loadTasksFromStore(projectRoot, config);\n217:   if (data.tasks.length > 0 || tasksStoreExists(projectRoot, config)) return;\n218: \n219:   console.log(`\\nTasks store not found: ${WOMBO_DIR}/${config.tasksDir}/`);\n220: \n221:   const generate = await promptYesNo(\n222:     \"Generate a new tasks store from template? (y/N): \"\n223:   );\n224: \n225:   if (!generate) {\n226:     console.error(\n227:       `Cannot proceed without a tasks store. Create one manually or run again and accept the prompt.`\n228:     );\n229:     process.exit(1);\n230:   }\n231: \n232:   // Ensure .wombo-combo/ directory exists\n233:   ensureWomboDir(projectRoot);\n234: \n235:   const now = new Date().toISOString();\n236:   saveTasksMetaToStore(projectRoot, config, {\n237:     version: \"1.0\",\n238:     meta: {\n239:       created_at: now,\n240:       updated_at: now,\n241:       project: \"unknown\",\n242:       generator: \"wombo-combo\",\n243:       maintainer: \"unknown\",\n244:     },\n245:   });\n246:   console.log(`Created ${WOMBO_DIR}/${config.tasksDir}/ with empty task store.\\n`);\n247: \n248:   // Also create empty archive store\n249:   saveArchiveMetaToStore(projectRoot, config, {\n250:     version: \"1.0\",\n251:     meta: {\n252:       created_at: now,\n253:       updated_at: now,\n254:       project: \"unknown\",\n255:       generator: \"wombo-combo\",\n256:       maintainer: \"unknown\",\n257:     },\n258:   });\n259:   console.log(`Created ${WOMBO_DIR}/${config.archiveDir}/.\\n`);\n260: }\n261: \n262: // Backward-compat alias\n263: export const ensureFeaturesFile = ensureTasksFile;\n264: \n265: // ---------------------------------------------------------------------------\n266: // Loader\n267: // ---------------------------------------------------------------------------\n268: \n269: /**\n270:  * Load and parse tasks from the folder-based store.\n271:  */\n272: export function loadTasks(\n273:   projectRoot: string,\n274:   config: WomboConfig\n275: ): TasksFile {\n276:   return loadTasksFromStore(projectRoot, config);\n277: }\n278: \n279: /**\n280:  * Load archived tasks from the folder-based store.\n281:  * Returns an empty ArchiveFile if the store doesn't exist.\n282:  */\n283: export function loadArchive(\n284:   projectRoot: string,\n285:   config: WomboConfig\n286: ): ArchiveFile {\n287:   return loadArchiveFromStore(projectRoot, config);\n288: }\n289: \n290: /**\n291:  * Backward-compat: load tasks + archive merged into a single FeaturesFile shape.\n292:  * This eases migration — callers that used loadFeatures() keep working.\n293:  */\n294: export function loadFeatures(\n295:   projectRoot: string,\n296:   config: WomboConfig\n297: ): FeaturesFile {\n298:   const tasksData = loadTasks(projectRoot, config);\n299:   const archiveData = loadArchive(projectRoot, config);\n300:   return {\n301:     ...tasksData,\n302:     // Map \"tasks\" to \"features\" for backward compat (FeaturesFile has .features)\n303:     // Actually FeaturesFile extends TasksFile which has .tasks, but add .archive\n304:     archive: archiveData.tasks,\n305:   };\n306: }\n307: \n308: // ---------------------------------------------------------------------------\n309: // Writer\n310: // ---------------------------------------------------------------------------\n311: \n312: /**\n313:  * Save all tasks to the folder-based store.\n314:  * Writes _meta.yml + one file per task.\n315:  */\n316: export function saveTasks(\n317:   projectRoot: string,\n318:   config: WomboConfig,\n319:   data: TasksFile\n320: ): void {\n321:   saveAllTasksToStore(projectRoot, config, data);\n322: }\n323: \n324: /**\n325:  * Save all archived tasks to the folder-based store.\n326:  */\n327: export function saveArchive(\n328:   projectRoot: string,\n329:   config: WomboConfig,\n330:   data: ArchiveFile\n331: ): void {\n332:   saveAllArchiveToStore(projectRoot, config, data);\n333: }\n334: \n335: /**\n336:  * Backward-compat: save a FeaturesFile (tasks + archive in one object).\n337:  * Splits and writes to both tasks.yml and archive.yml.\n338:  */\n339: export function saveFeatures(\n340:   projectRoot: string,\n341:   config: WomboConfig,\n342:   data: FeaturesFile\n343: ): void {\n344:   const tasksData: TasksFile = {\n345:     version: data.version,\n346:     meta: { ...data.meta },\n347:     tasks: data.tasks,\n348:   };\n349:   saveTasks(projectRoot, config, tasksData);\n350: \n351:   if (data.archive && data.archive.length > 0) {\n352:     const archiveData: ArchiveFile = {\n353:       version: data.version,\n354:       meta: { ...data.meta },\n355:       tasks: data.archive,\n356:     };\n357:     saveArchive(projectRoot, config, archiveData);\n358:   }\n359: }\n360: \n361: \n362: // ---------------------------------------------------------------------------\n363: // Dependency Resolution\n364: // ---------------------------------------------------------------------------\n365: \n366: /**\n367:  * Get all task IDs that are done (status === \"done\" or completion === 100).\n368:  */\n369: function getDoneIds(tasks: Task[], archive: Task[]): Set<string> {\n370:   const done = new Set<string>();\n371:   const collectDone = (items: Task[]) => {\n372:     for (const item of items) {\n373:       if (item.status === \"done\" || item.completion === 100) {\n374:         done.add(item.id);\n375:       }\n376:       if (item.subtasks?.length) {\n377:         collectDone(item.subtasks);\n378:       }\n379:     }\n380:   };\n381:   collectDone(tasks);\n382:   collectDone(archive);\n383:   return done;\n384: }\n385: \n386: /**\n387:  * Check if a task's dependencies are all satisfied.\n388:  */\n389: export function areDependenciesMet(\n390:   task: Task,\n391:   doneIds: Set<string>\n392: ): boolean {\n393:   return task.depends_on.every((dep) => doneIds.has(dep));\n394: }\n395: \n396: /**\n397:  * Get all tasks that are ready to start (backlog + deps met).\n398:  */\n399: export function getReadyTasks(data: TasksFile, archive?: Task[]): Task[] {\n400:   const doneIds = getDoneIds(data.tasks, archive ?? []);\n401:   return data.tasks.filter(\n402:     (t) =>\n403:       t.status === \"backlog\" &&\n404:       t.completion === 0 &&\n405:       areDependenciesMet(t, doneIds)\n406:   );\n407: }\n408: \n409: /**\n410:  * Get done IDs (exported for use in selection error messages).\n411:  */\n412: export function getDoneTaskIds(data: TasksFile, archive?: Task[]): Set<string> {\n413:   return getDoneIds(data.tasks, archive ?? []);\n414: }\n415: \n416: // Backward-compat aliases\n417: export function getReadyFeatures(data: FeaturesFile): Task[] {\n418:   return getReadyTasks(data, data.archive);\n419: }\n420: \n421: export function getDoneFeatureIds(data: FeaturesFile): Set<string> {\n422:   return getDoneTaskIds(data, data.archive);\n423: }\n424: \n425: // ---------------------------------------------------------------------------\n426: // Selection Strategies\n427: // ---------------------------------------------------------------------------\n428: \n429: export interface SelectionOptions {\n430:   /** Select top N by priority (highest priority first, then lowest effort) */\n431:   topPriority?: number;\n432:   /** Select N quickest wins (lowest effort first) */\n433:   quickestWins?: number;\n434:   /** Select all tasks matching this priority level */\n435:   priority?: Priority;\n436:   /** Select all tasks matching this difficulty level */\n437:   difficulty?: Difficulty;\n438:   /** Select specific task IDs (comma-separated) */\n439:   taskIds?: string[];\n440:   /** Select all ready tasks */\n441:   allReady?: boolean;\n442: }\n443: \n444: /**\n445:  * Select tasks based on the given strategy.\n446:  * Always filters to only ready tasks (backlog + deps met) first.\n447:  */\n448: export function selectTasks(\n449:   data: TasksFile,\n450:   options: SelectionOptions,\n451:   archive?: Task[]\n452: ): Task[] {\n453:   const ready = getReadyTasks(data, archive);\n454: \n455:   if (options.allReady) {\n456:     return sortByPriorityThenEffort(ready);\n457:   }\n458: \n459:   if (options.taskIds?.length) {\n460:     const idSet = new Set(options.taskIds);\n461:     const selected = ready.filter((t) => idSet.has(t.id));\n462:     const missing = options.taskIds.filter(\n463:       (id) => !selected.find((t) => t.id === id)\n464:     );\n465:     if (missing.length) {\n466:       const allIds = data.tasks.map((t) => t.id);\n467:       const doneIds = getDoneIds(data.tasks, archive ?? []);\n468:       for (const m of missing) {\n469:         if (!allIds.includes(m)) {\n470:           console.error(`  Task \"${m}\" does not exist in the tasks file`);\n471:         } else {\n472:           const task = data.tasks.find((t) => t.id === m)!;\n473:           console.error(\n474:             `  Task \"${m}\" is not ready (status: ${task.status}, deps met: ${areDependenciesMet(task, doneIds)})`\n475:           );\n476:         }\n477:       }\n478:     }\n479:     return sortByPriorityThenEffort(selected);\n480:   }\n481: \n482:   if (options.priority) {\n483:     return sortByPriorityThenEffort(\n484:       ready.filter((t) => t.priority === options.priority)\n485:     );\n486:   }\n487: \n488:   if (options.difficulty) {\n489:     return sortByEffort(ready.filter((t) => t.difficulty === options.difficulty));\n490:   }\n491: \n492:   if (options.topPriority) {\n493:     return sortByPriorityThenEffort(ready).slice(0, options.topPriority);\n494:   }\n495: \n496:   if (options.quickestWins) {\n497:     return sortByEffort(ready).slice(0, options.quickestWins);\n498:   }\n499: \n500:   // Default: return all ready, sorted by priority\n501:   return sortByPriorityThenEffort(ready);\n502: }\n503: \n504: // Backward-compat alias\n505: export function selectFeatures(\n506:   data: FeaturesFile,\n507:   options: SelectionOptions & { featureIds?: string[] }\n508: ): Task[] {\n509:   // Map featureIds -> taskIds for backward compat\n510:   const opts: SelectionOptions = {\n511:     ...options,\n512:     taskIds: options.taskIds ?? options.featureIds,\n513:   };\n514:   return selectTasks(data, opts, data.archive);\n515: }\n516: \n517: // ---------------------------------------------------------------------------\n518: // Sorting Helpers\n519: // ---------------------------------------------------------------------------\n520: \n521: function sortByPriorityThenEffort(tasks: Task[]): Task[] {\n522:   return [...tasks].sort((a, b) => {\n523:     const pDiff = PRIORITY_ORDER[a.priority] - PRIORITY_ORDER[b.priority];\n524:     if (pDiff !== 0) return pDiff;\n525:     return parseDurationMinutes(a.effort) - parseDurationMinutes(b.effort);\n526:   });\n527: }\n528: \n529: function sortByEffort(tasks: Task[]): Task[] {\n530:   return [...tasks].sort(\n531:     (a, b) => parseDurationMinutes(a.effort) - parseDurationMinutes(b.effort)\n532:   );\n533: }\n534: \n535: // ---------------------------------------------------------------------------\n536: // Utility Exports\n537: // ---------------------------------------------------------------------------\n538: \n539: /**\n540:  * Get a compact summary of a task for display.\n541:  */\n542: export function taskSummary(t: Task): string {\n543:   const effort = formatDuration(parseDurationMinutes(t.effort));\n544:   return `[${t.priority}/${t.difficulty}] ${t.id} -- ${t.title} (${effort})`;\n545: }\n546: \n547: // Backward-compat alias\n548: export const featureSummary = taskSummary;\n549: \n550: /**\n551:  * Recursively search a list of tasks (and their subtasks) for a matching ID.\n552:  */\n553: function findInList(tasks: Task[], id: string): Task | undefined {\n554:   for (const t of tasks) {\n555:     if (t.id === id) return t;\n556:     if (t.subtasks?.length) {\n557:       const found = findInList(t.subtasks, id);\n558:       if (found) return found;\n559:     }\n560:   }\n561:   return undefined;\n562: }\n563: \n564: /**\n565:  * Find a task by ID across active tasks, their subtasks\n566:  * (recursively), and the archive list.\n567:  */\n568: export function findTaskById(\n569:   data: TasksFile,\n570:   id: string,\n571:   archive?: Task[]\n572: ): Task | undefined {\n573:   return (\n574:     findInList(data.tasks, id) ??\n575:     (archive ? findInList(archive, id) : undefined)\n576:   );\n577: }\n578: \n579: // Backward-compat alias\n580: export function findFeatureById(\n581:   data: FeaturesFile,\n582:   id: string\n583: ): Task | undefined {\n584:   return findTaskById(data, id, data.archive);\n585: }\n586: \n587: /**\n588:  * Create a blank task with all required fields initialized.\n589:  */\n590: export function createBlankTask(\n591:   id: string,\n592:   title: string,\n593:   description: string = \"\",\n594:   opts?: {\n595:     priority?: Priority;\n596:     difficulty?: Difficulty;\n597:     effort?: string;\n598:   }\n599: ): Task {\n600:   return {\n601:     id,\n602:     title,\n603:     description,\n604:     status: \"backlog\",\n605:     completion: 0,\n606:     difficulty: opts?.difficulty ?? \"medium\",\n607:     priority: opts?.priority ?? \"medium\",\n608:     depends_on: [],\n609:     effort: opts?.effort ?? \"PT1H\",\n610:     started_at: null,\n611:     ended_at: null,\n612:     constraints: [],\n613:     forbidden: [],\n614:     references: [],\n615:     notes: [],\n616:     subtasks: [],\n617:   };\n618: }\n619: \n620: // Backward-compat alias\n621: export const createBlankFeature = createBlankTask;\n622: \n623: /**\n624:  * Get all task IDs (active + archive), useful for validation.\n625:  */\n626: export function allTaskIds(data: TasksFile, archive?: Task[]): string[] {\n627:   const ids: string[] = [];\n628:   const collect = (items: Task[]) => {\n629:     for (const item of items) {\n630:       ids.push(item.id);\n631:       if (item.subtasks?.length) collect(item.subtasks);\n632:     }\n633:   };\n634:   collect(data.tasks);\n635:   collect(archive ?? []);\n636:   return ids;\n637: }\n638: \n639: // Backward-compat alias\n640: export function allFeatureIds(data: FeaturesFile): string[] {\n641:   return allTaskIds(data, data.archive);\n642: }\n643: \n644: // Re-export the old template path name for migration\n645: export const FEATURES_TEMPLATE_PATH = TASKS_TEMPLATE_PATH;\n646: \n647: // Re-export store functions for single-task operations\n648: export {\n649:   saveTaskToStore,\n650:   saveTaskToArchive,\n651:   removeTaskFromStore,\n652:   getTasksDir,\n653:   getArchiveDir,\n654: } from \"./task-store.js\";\n\n(End of file - total 654 lines)\n</content>","title":"src/lib/tasks.ts","metadata":{"preview":"/**\n * tasks.ts -- Parse tasks YAML and provide task selection/filtering.\n *\n * Responsibilities:\n *   - Load and parse the tasks file with full type safety\n *   - Load and parse the archive file separately\n *   - Parse ISO 8601 durations into comparable minutes\n *   - Filter tasks by status, priority, difficulty, dependency readiness\n *   - Select tasks by various strategies (top-priority, quickest-wins, etc.)\n *   - Resolve dependency graphs to determine which tasks are ready to start\n *   - Write-back capability for task management commands\n */\n\nimport { existsSync, mkdirSync } from \"node:fs\";\nimport { resolve, dirname, join } from \"node:path\";\nimport { createInterface } from \"node:readline\";\nimport type { WomboConfig } from \"../config.js\";\nimport { WOMBO_DIR } from \"../config.js\";\nimport {\n  loadTasksFromStore,","truncated":false,"loaded":[]},"time":{"start":1773435838715,"end":1773435838718}}}}
{"type":"tool_use","timestamp":1773435839253,"sessionID":"ses_316fcc12bffeSBLLi3jBrbT2M4","part":{"id":"prt_ce90360fc0014U9b0iZjiMQZ0Y","sessionID":"ses_316fcc12bffeSBLLi3jBrbT2M4","messageID":"msg_ce903559e0012I5jfoZVY0Cr0j","type":"tool","callID":"toolu_vrtx_01TAcYpYvxQK8f9Q5nPSEicB","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-unit-test-suite/src/lib/state.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-unit-test-suite/src/lib/state.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * state.ts — Persistent wave state management.\n3:  *\n4:  * Responsibilities:\n5:  *   - Define the shape of .wombo-combo/state.json\n6:  *   - Read/write state atomically\n7:  *   - Generate wave IDs\n8:  *   - Update individual agent state within a wave\n9:  */\n10: \n11: import { readFileSync, writeFileSync, existsSync, renameSync, mkdirSync } from \"node:fs\";\n12: import { resolve } from \"node:path\";\n13: import { WOMBO_DIR } from \"../config.js\";\n14: \n15: // ---------------------------------------------------------------------------\n16: // Types\n17: // ---------------------------------------------------------------------------\n18: \n19: export type AgentStatus =\n20:   | \"queued\"\n21:   | \"installing\"\n22:   | \"running\"\n23:   | \"completed\"\n24:   | \"verified\"\n25:   | \"failed\"\n26:   | \"merged\"\n27:   | \"retry\"\n28:   | \"resolving_conflict\";\n29: \n30: export interface AgentState {\n31:   feature_id: string;\n32:   branch: string;\n33:   worktree: string;\n34:   session_id: string | null;\n35:   pid: number | null;\n36:   status: AgentStatus;\n37:   activity: string | null;\n38:   activity_updated_at: string | null;\n39:   retries: number;\n40:   max_retries: number;\n41:   started_at: string | null;\n42:   completed_at: string | null;\n43:   build_passed: boolean | null;\n44:   build_output: string | null;\n45:   error: string | null;\n46:   /** Estimated effort in milliseconds (from feature's ISO 8601 duration) */\n47:   effort_estimate_ms: number | null;\n48:   /** Stream index this agent belongs to (for dependency-aware scheduling) */\n49:   stream_index: number | null;\n50:   /** IDs of features this agent depends on (within the current wave) */\n51:   depends_on: string[];\n52:   /** IDs of features that depend on this agent (within the current wave) */\n53:   depended_on_by: string[];\n54:   /**\n55:    * Override agent name for this specific agent (from registry).\n56:    * When set, uses this agent definition instead of the default generalist.\n57:    * e.g. \"engineering-frontend-developer\"\n58:    */\n59:   agent_name: string | null;\n60:   /**\n61:    * The agent_type from the task (e.g. \"engineering/engineering-frontend-developer\").\n62:    * Stored for informational purposes and to support resume with re-fetch.\n63:    */\n64:   agent_type: string | null;\n65: }\n66: \n67: export interface WaveState {\n68:   wave_id: string;\n69:   base_branch: string;\n70:   started_at: string;\n71:   updated_at: string;\n72:   max_concurrent: number;\n73:   model: string | null;\n74:   interactive: boolean;\n75:   agents: AgentState[];\n76:   /** Dependency-aware scheduling plan (null if no dependencies exist) */\n77:   schedule_plan: SerializedSchedulePlan | null;\n78: }\n79: \n80: /**\n81:  * Serialized schedule plan stored in wave state JSON.\n82:  * Uses plain arrays instead of the rich SchedulePlan type for JSON compatibility.\n83:  */\n84: export interface SerializedSchedulePlan {\n85:   /** Streams: each is a list of feature IDs to execute sequentially */\n86:   streams: string[][];\n87:   /** Merge gates: features that must wait for multiple deps from different streams */\n88:   merge_gates: Array<{ feature_id: string; wait_for: string[] }>;\n89:   /** Topological order of all features */\n90:   topological_order: string[];\n91: }\n92: \n93: // ---------------------------------------------------------------------------\n94: // Constants\n95: // ---------------------------------------------------------------------------\n96: \n97: const STATE_FILE = \".wombo-combo/state.json\";\n98: \n99: // ---------------------------------------------------------------------------\n100: // Wave ID Generation\n101: // ---------------------------------------------------------------------------\n102: \n103: /**\n104:  * Generate a unique wave ID based on current timestamp.\n105:  * Format: wave-YYYY-MM-DD-NNN\n106:  */\n107: export function generateWaveId(): string {\n108:   const now = new Date();\n109:   const date = now.toISOString().slice(0, 10);\n110:   const seq = String(now.getHours() * 60 + now.getMinutes()).padStart(3, \"0\");\n111:   return `wave-${date}-${seq}`;\n112: }\n113: \n114: // ---------------------------------------------------------------------------\n115: // State Path\n116: // ---------------------------------------------------------------------------\n117: \n118: function statePath(projectRoot: string): string {\n119:   return resolve(projectRoot, STATE_FILE);\n120: }\n121: \n122: // ---------------------------------------------------------------------------\n123: // Read State\n124: // ---------------------------------------------------------------------------\n125: \n126: /**\n127:  * Load the current wave state from disk. Returns null if no state file exists.\n128:  */\n129: export function loadState(projectRoot: string): WaveState | null {\n130:   const p = statePath(projectRoot);\n131:   if (!existsSync(p)) return null;\n132:   try {\n133:     const raw = readFileSync(p, \"utf-8\");\n134:     return JSON.parse(raw) as WaveState;\n135:   } catch {\n136:     return null;\n137:   }\n138: }\n139: \n140: // ---------------------------------------------------------------------------\n141: // Write State\n142: // ---------------------------------------------------------------------------\n143: \n144: /**\n145:  * Save wave state to disk atomically (write to tmp then rename).\n146:  */\n147: export function saveState(projectRoot: string, state: WaveState): void {\n148:   const dir = resolve(projectRoot, WOMBO_DIR);\n149:   if (!existsSync(dir)) mkdirSync(dir, { recursive: true });\n150:   state.updated_at = new Date().toISOString();\n151:   const p = statePath(projectRoot);\n152:   const tmp = p + \".tmp\";\n153:   writeFileSync(tmp, JSON.stringify(state, null, 2) + \"\\n\", \"utf-8\");\n154:   renameSync(tmp, p);\n155: }\n156: \n157: // ---------------------------------------------------------------------------\n158: // State Mutations\n159: // ---------------------------------------------------------------------------\n160: \n161: /**\n162:  * Create a fresh wave state.\n163:  */\n164: export function createWaveState(opts: {\n165:   baseBranch: string;\n166:   maxConcurrent: number;\n167:   model: string | null;\n168:   interactive: boolean;\n169: }): WaveState {\n170:   return {\n171:     wave_id: generateWaveId(),\n172:     base_branch: opts.baseBranch,\n173:     started_at: new Date().toISOString(),\n174:     updated_at: new Date().toISOString(),\n175:     max_concurrent: opts.maxConcurrent,\n176:     model: opts.model,\n177:     interactive: opts.interactive,\n178:     agents: [],\n179:     schedule_plan: null,\n180:   };\n181: }\n182: \n183: /**\n184:  * Create an initial agent state for a feature.\n185:  */\n186: export function createAgentState(\n187:   featureId: string,\n188:   branch: string,\n189:   worktreePath: string,\n190:   maxRetries: number = 2\n191: ): AgentState {\n192:   return {\n193:     feature_id: featureId,\n194:     branch,\n195:     worktree: worktreePath,\n196:     session_id: null,\n197:     pid: null,\n198:     status: \"queued\",\n199:     activity: null,\n200:     activity_updated_at: null,\n201:     retries: 0,\n202:     max_retries: maxRetries,\n203:     started_at: null,\n204:     completed_at: null,\n205:     build_passed: null,\n206:     build_output: null,\n207:     error: null,\n208:     effort_estimate_ms: null,\n209:     stream_index: null,\n210:     depends_on: [],\n211:     depended_on_by: [],\n212:     agent_name: null,\n213:     agent_type: null,\n214:   };\n215: }\n216: \n217: /**\n218:  * Find an agent state by feature ID.\n219:  */\n220: export function getAgent(\n221:   state: WaveState,\n222:   featureId: string\n223: ): AgentState | undefined {\n224:   return state.agents.find((a) => a.feature_id === featureId);\n225: }\n226: \n227: /**\n228:  * Update an agent's state fields.\n229:  */\n230: export function updateAgent(\n231:   state: WaveState,\n232:   featureId: string,\n233:   updates: Partial<AgentState>\n234: ): void {\n235:   const agent = state.agents.find((a) => a.feature_id === featureId);\n236:   if (!agent) throw new Error(`Agent not found for feature: ${featureId}`);\n237:   Object.assign(agent, updates);\n238: }\n239: \n240: /**\n241:  * Get counts of agents by status.\n242:  */\n243: export function agentCounts(state: WaveState): Record<AgentStatus, number> {\n244:   const counts: Record<AgentStatus, number> = {\n245:     queued: 0,\n246:     installing: 0,\n247:     running: 0,\n248:     completed: 0,\n249:     verified: 0,\n250:     failed: 0,\n251:     merged: 0,\n252:     retry: 0,\n253:     resolving_conflict: 0,\n254:   };\n255:   for (const a of state.agents) {\n256:     counts[a.status]++;\n257:   }\n258:   return counts;\n259: }\n260: \n261: /**\n262:  * Get agents that are currently running or installing.\n263:  */\n264: export function activeAgents(state: WaveState): AgentState[] {\n265:   return state.agents.filter(\n266:     (a) => a.status === \"running\" || a.status === \"installing\" || a.status === \"resolving_conflict\"\n267:   );\n268: }\n269: \n270: /**\n271:  * Get agents that are queued and ready to be launched.\n272:  */\n273: export function queuedAgents(state: WaveState): AgentState[] {\n274:   return state.agents.filter((a) => a.status === \"queued\");\n275: }\n276: \n277: /**\n278:  * Check if the wave is fully complete (no queued, installing, running, or retry agents).\n279:  */\n280: export function isWaveComplete(state: WaveState): boolean {\n281:   return state.agents.every(\n282:     (a) =>\n283:       a.status === \"completed\" ||\n284:       a.status === \"verified\" ||\n285:       a.status === \"failed\" ||\n286:       a.status === \"merged\"\n287:   );\n288: }\n289: \n290: // ---------------------------------------------------------------------------\n291: // Dependency-Aware Helpers\n292: // ---------------------------------------------------------------------------\n293: \n294: /**\n295:  * Terminal statuses that count as \"dependency satisfied\" for downstream features.\n296:  * A dependency is satisfied when it has been verified or merged.\n297:  */\n298: const DEP_SATISFIED_STATUSES: Set<AgentStatus> = new Set([\"verified\", \"merged\"]);\n299: \n300: /**\n301:  * Check if an agent's dependencies within the wave are all satisfied.\n302:  * Dependencies are satisfied when their agents reach \"verified\" or \"merged\" status.\n303:  *\n304:  * If the agent has no depends_on entries, it's always ready.\n305:  */\n306: export function areAgentDepsReady(\n307:   state: WaveState,\n308:   agent: AgentState\n309: ): boolean {\n310:   if (agent.depends_on.length === 0) return true;\n311: \n312:   for (const depId of agent.depends_on) {\n313:     const depAgent = state.agents.find((a) => a.feature_id === depId);\n314:     if (depAgent && !DEP_SATISFIED_STATUSES.has(depAgent.status)) {\n315:       return false;\n316:     }\n317:     // If depAgent doesn't exist in this wave, the dep is external — assumed satisfied\n318:   }\n319:   return true;\n320: }\n321: \n322: /**\n323:  * Get queued agents whose dependencies are all satisfied.\n324:  * This is the dependency-aware replacement for plain queuedAgents().\n325:  */\n326: export function readyToLaunchAgents(state: WaveState): AgentState[] {\n327:   return state.agents.filter(\n328:     (a) => a.status === \"queued\" && areAgentDepsReady(state, a)\n329:   );\n330: }\n331: \n332: /**\n333:  * Get all agents that are downstream (depend on) a given feature, directly or transitively.\n334:  * Used for failure cascading — when a feature fails, cancel all downstream.\n335:  */\n336: export function getDownstreamAgents(\n337:   state: WaveState,\n338:   featureId: string\n339: ): AgentState[] {\n340:   const visited = new Set<string>();\n341:   const result: AgentState[] = [];\n342: \n343:   function collect(id: string): void {\n344:     const agent = state.agents.find((a) => a.feature_id === id);\n345:     if (!agent) return;\n346: \n347:     for (const downstreamId of agent.depended_on_by) {\n348:       if (visited.has(downstreamId)) continue;\n349:       visited.add(downstreamId);\n350: \n351:       const downstream = state.agents.find((a) => a.feature_id === downstreamId);\n352:       if (downstream) {\n353:         result.push(downstream);\n354:         collect(downstreamId);\n355:       }\n356:     }\n357:   }\n358: \n359:   collect(featureId);\n360:   return result;\n361: }\n362: \n363: /**\n364:  * Cancel all downstream agents when an upstream dependency fails.\n365:  * Sets status to \"failed\" with an error explaining the dependency failure.\n366:  * Returns the list of cancelled agent IDs.\n367:  */\n368: export function cancelDownstream(\n369:   state: WaveState,\n370:   failedFeatureId: string\n371: ): string[] {\n372:   const downstream = getDownstreamAgents(state, failedFeatureId);\n373:   const cancelled: string[] = [];\n374: \n375:   for (const agent of downstream) {\n376:     // Only cancel agents that haven't already reached a terminal state\n377:     if (\n378:       agent.status === \"queued\" ||\n379:       agent.status === \"installing\" ||\n380:       agent.status === \"running\" ||\n381:       agent.status === \"retry\"\n382:     ) {\n383:       updateAgent(state, agent.feature_id, {\n384:         status: \"failed\",\n385:         error: `Dependency \"${failedFeatureId}\" failed — downstream cancelled`,\n386:         activity: null,\n387:         completed_at: new Date().toISOString(),\n388:       });\n389:       cancelled.push(agent.feature_id);\n390:     }\n391:   }\n392: \n393:   return cancelled;\n394: }\n\n(End of file - total 394 lines)\n</content>","title":"src/lib/state.ts","metadata":{"preview":"/**\n * state.ts — Persistent wave state management.\n *\n * Responsibilities:\n *   - Define the shape of .wombo-combo/state.json\n *   - Read/write state atomically\n *   - Generate wave IDs\n *   - Update individual agent state within a wave\n */\n\nimport { readFileSync, writeFileSync, existsSync, renameSync, mkdirSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\nimport { WOMBO_DIR } from \"../config.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type AgentStatus =\n  | \"queued\"","truncated":false,"loaded":[]},"time":{"start":1773435839242,"end":1773435839251}}}}
{"type":"tool_use","timestamp":1773435839782,"sessionID":"ses_316fcc12bffeSBLLi3jBrbT2M4","part":{"id":"prt_ce903630c001Ud1QSvwVfvYev4","sessionID":"ses_316fcc12bffeSBLLi3jBrbT2M4","messageID":"msg_ce903559e0012I5jfoZVY0Cr0j","type":"tool","callID":"toolu_vrtx_01WxT7HKAMnxNzgGBxjJ5rmS","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-unit-test-suite/src/lib/worktree.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-unit-test-suite/src/lib/worktree.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * worktree.ts — Git worktree lifecycle management.\n3:  *\n4:  * Responsibilities:\n5:  *   - Create feature branches from a base branch\n6:  *   - Create git worktrees for each feature branch\n7:  *   - Run install command in worktrees\n8:  *   - List and remove worktrees\n9:  *   - Copy agent config files into worktrees\n10:  *\n11:  * IMPORTANT: Heavy operations (createWorktree, installDeps) are async\n12:  * to allow true parallelism with Promise.all.\n13:  */\n14: \n15: import { exec, execSync } from \"node:child_process\";\n16: import { existsSync, cpSync, statSync } from \"node:fs\";\n17: import { resolve, dirname, basename } from \"node:path\";\n18: import type { WomboConfig } from \"../config.js\";\n19: \n20: // ---------------------------------------------------------------------------\n21: // Types\n22: // ---------------------------------------------------------------------------\n23: \n24: export interface WorktreeInfo {\n25:   path: string;\n26:   branch: string;\n27:   head: string;\n28:   bare: boolean;\n29: }\n30: \n31: // ---------------------------------------------------------------------------\n32: // Diagnostic Logger\n33: // ---------------------------------------------------------------------------\n34: \n35: function ts(): string {\n36:   return new Date().toISOString().slice(11, 19); // HH:MM:SS\n37: }\n38: \n39: export function log(featureId: string, msg: string): void {\n40:   console.log(`  [${ts()}] ${featureId}: ${msg}`);\n41: }\n42: \n43: // ---------------------------------------------------------------------------\n44: // Async Command Runner\n45: // ---------------------------------------------------------------------------\n46: \n47: /**\n48:  * Run a command asynchronously. Returns stdout on success, throws on failure.\n49:  */\n50: function runAsync(\n51:   cmd: string,\n52:   opts?: { cwd?: string; timeoutMs?: number }\n53: ): Promise<string> {\n54:   return new Promise((resolve, reject) => {\n55:     exec(\n56:       cmd,\n57:       {\n58:         cwd: opts?.cwd,\n59:         encoding: \"utf-8\",\n60:         timeout: opts?.timeoutMs ?? 0,\n61:         maxBuffer: 10 * 1024 * 1024,\n62:       },\n63:       (error, stdout, stderr) => {\n64:         if (error) {\n65:           const errMsg = stderr?.trim() || stdout?.trim() || error.message;\n66:           reject(new Error(`Command failed: ${cmd}\\n${errMsg}`));\n67:         } else {\n68:           resolve((stdout ?? \"\").trim());\n69:         }\n70:       }\n71:     );\n72:   });\n73: }\n74: \n75: /**\n76:  * Synchronous run — only for quick, non-blocking operations.\n77:  */\n78: function runSync(\n79:   cmd: string,\n80:   opts?: { cwd?: string; silent?: boolean; timeoutMs?: number }\n81: ): string {\n82:   try {\n83:     return execSync(cmd, {\n84:       cwd: opts?.cwd,\n85:       encoding: \"utf-8\",\n86:       stdio: opts?.silent ? \"pipe\" : [\"pipe\", \"pipe\", \"pipe\"],\n87:       timeout: opts?.timeoutMs,\n88:       maxBuffer: 10 * 1024 * 1024,\n89:     }).trim();\n90:   } catch (err: any) {\n91:     const stderr = err.stderr?.toString().trim() || \"\";\n92:     const stdout = err.stdout?.toString().trim() || \"\";\n93:     throw new Error(\n94:       `Command failed: ${cmd}\\n${stderr || stdout || err.message}`\n95:     );\n96:   }\n97: }\n98: \n99: // ---------------------------------------------------------------------------\n100: // Branch Management\n101: // ---------------------------------------------------------------------------\n102: \n103: /**\n104:  * Create a feature branch from the base branch.\n105:  * If it already exists and is NOT checked out in a worktree, reset it.\n106:  * If it's checked out in a worktree, leave it alone (resume case).\n107:  */\n108: async function createBranch(\n109:   projectRoot: string,\n110:   branchName: string,\n111:   baseBranch: string\n112: ): Promise<void> {\n113:   const existing = await runAsync(\n114:     `git branch --list \"${branchName}\"`,\n115:     { cwd: projectRoot }\n116:   );\n117:   if (existing.trim()) {\n118:     // Branch exists — try to delete and recreate.\n119:     // If deletion fails (e.g. checked out in worktree), that's fine —\n120:     // we'll reuse the existing branch with its work intact.\n121:     try {\n122:       await runAsync(`git branch -D \"${branchName}\"`, { cwd: projectRoot });\n123:     } catch {\n124:       // Branch is checked out in a worktree — reuse as-is\n125:       return;\n126:     }\n127:   }\n128:   await runAsync(`git branch \"${branchName}\" \"${baseBranch}\"`, {\n129:     cwd: projectRoot,\n130:   });\n131: }\n132: \n133: /**\n134:  * Generate the branch name for a feature using config prefix.\n135:  */\n136: export function featureBranchName(\n137:   featureId: string,\n138:   config: WomboConfig\n139: ): string {\n140:   return `${config.git.branchPrefix}${featureId}`;\n141: }\n142: \n143: /**\n144:  * Generate the worktree path for a feature (sibling directory to project root).\n145:  */\n146: export function worktreePath(\n147:   projectRoot: string,\n148:   featureId: string,\n149:   config: WomboConfig\n150: ): string {\n151:   const parentDir = dirname(projectRoot);\n152:   return resolve(parentDir, `${config.git.worktreePrefix}${featureId}`);\n153: }\n154: \n155: // ---------------------------------------------------------------------------\n156: // Worktree Lifecycle (async)\n157: // ---------------------------------------------------------------------------\n158: \n159: /**\n160:  * Create a git worktree for a feature branch.\n161:  * Returns the absolute path to the worktree.\n162:  *\n163:  * If a valid worktree already exists at the expected path (has .git file),\n164:  * reuses it — this is essential for the resume case where worktrees have\n165:  * real work but may be missing node_modules.\n166:  */\n167: export async function createWorktree(\n168:   projectRoot: string,\n169:   featureId: string,\n170:   baseBranch: string,\n171:   config: WomboConfig\n172: ): Promise<string> {\n173:   const branch = featureBranchName(featureId, config);\n174:   const wtPath = worktreePath(projectRoot, featureId, config);\n175: \n176:   // If a valid worktree already exists, reuse it (resume case).\n177:   // A git worktree has a .git *file* (not directory) pointing to the main repo.\n178:   if (existsSync(wtPath) && existsSync(resolve(wtPath, \".git\"))) {\n179:     log(featureId, \"reusing existing worktree (has work)\");\n180:     // Still copy config files in case they're missing\n181:     copyConfigFiles(projectRoot, wtPath, featureId, config);\n182:     return wtPath;\n183:   }\n184: \n185:   // Create the branch if it doesn't exist\n186:   log(featureId, \"creating branch...\");\n187:   await createBranch(projectRoot, branch, baseBranch);\n188: \n189:   // Remove existing worktree directory if present but invalid\n190:   if (existsSync(wtPath)) {\n191:     log(featureId, \"removing old worktree...\");\n192:     try {\n193:       await runAsync(`git worktree remove --force \"${wtPath}\"`, {\n194:         cwd: projectRoot,\n195:       });\n196:     } catch {\n197:       await runAsync(`rm -rf \"${wtPath}\"`);\n198:       await runAsync(`git worktree prune`, { cwd: projectRoot });\n199:     }\n200:   }\n201: \n202:   // Create the worktree\n203:   log(featureId, \"creating worktree...\");\n204:   await runAsync(`git worktree add \"${wtPath}\" \"${branch}\"`, {\n205:     cwd: projectRoot,\n206:   });\n207: \n208:   // Copy agent config files into worktree\n209:   copyConfigFiles(projectRoot, wtPath, featureId, config);\n210: \n211:   log(featureId, \"worktree ready\");\n212:   return wtPath;\n213: }\n214: \n215: /**\n216:  * Copy agent config files from project root into a worktree.\n217:  * Best-effort — logs warnings but doesn't throw.\n218:  */\n219: function copyConfigFiles(\n220:   projectRoot: string,\n221:   wtPath: string,\n222:   featureId: string,\n223:   config: WomboConfig\n224: ): void {\n225:   for (const configFile of config.agent.configFiles) {\n226:     const srcPath = resolve(projectRoot, configFile);\n227:     if (!existsSync(srcPath)) continue;\n228: \n229:     const destPath = resolve(wtPath, configFile);\n230:     try {\n231:       const stat = statSync(srcPath);\n232:       if (stat.isDirectory()) {\n233:         cpSync(srcPath, destPath, { recursive: true });\n234:       } else {\n235:         cpSync(srcPath, destPath);\n236:       }\n237:     } catch {\n238:       // Non-critical — best effort\n239:     }\n240:   }\n241: \n242:   // Verify all config files were copied successfully\n243:   verifyConfigFiles(projectRoot, wtPath, featureId, config);\n244: }\n245: \n246: // ---------------------------------------------------------------------------\n247: // Config File Verification\n248: // ---------------------------------------------------------------------------\n249: \n250: /**\n251:  * Verify that all expected config files were copied into the worktree.\n252:  * Logs a warning for any that are missing. This is a safety net on top\n253:  * of the best-effort cpSync logic in createWorktree.\n254:  */\n255: export function verifyConfigFiles(\n256:   projectRoot: string,\n257:   wtPath: string,\n258:   featureId: string,\n259:   config: WomboConfig\n260: ): void {\n261:   const missing: string[] = [];\n262: \n263:   for (const configFile of config.agent.configFiles) {\n264:     const srcPath = resolve(projectRoot, configFile);\n265:     const destPath = resolve(wtPath, configFile);\n266: \n267:     // Only check files/dirs that exist in the source project\n268:     if (!existsSync(srcPath)) continue;\n269: \n270:     if (!existsSync(destPath)) {\n271:       missing.push(configFile);\n272:     }\n273:   }\n274: \n275:   if (missing.length > 0) {\n276:     log(\n277:       featureId,\n278:       `\\x1b[33mWARNING\\x1b[0m: config files missing in worktree: ${missing.join(\", \")}`\n279:     );\n280:   }\n281: }\n282: \n283: /**\n284:  * Install dependencies in a worktree.\n285:  */\n286: export async function installDeps(\n287:   wtPath: string,\n288:   featureId: string,\n289:   config: WomboConfig\n290: ): Promise<void> {\n291:   log(featureId, `running ${config.install.command}...`);\n292:   const start = Date.now();\n293:   await runAsync(config.install.command, {\n294:     cwd: wtPath,\n295:     timeoutMs: config.install.timeout,\n296:   });\n297:   const elapsed = ((Date.now() - start) / 1000).toFixed(1);\n298:   log(featureId, `install done (${elapsed}s)`);\n299: }\n300: \n301: /**\n302:  * Check if a worktree already exists and has node_modules (fully ready).\n303:  */\n304: export function worktreeReady(wtPath: string): boolean {\n305:   return (\n306:     existsSync(wtPath) &&\n307:     existsSync(resolve(wtPath, \"node_modules\"))\n308:   );\n309: }\n310: \n311: /**\n312:  * Check if a valid git worktree exists at the path (may lack node_modules).\n313:  * A git worktree has a .git *file* (not directory) pointing to the main repo.\n314:  */\n315: export function worktreeExists(wtPath: string): boolean {\n316:   return existsSync(wtPath) && existsSync(resolve(wtPath, \".git\"));\n317: }\n318: \n319: /**\n320:  * Check if a local branch exists in the repository.\n321:  * Uses `git rev-parse --verify` which is the canonical way to check branch existence.\n322:  */\n323: export function branchExists(projectRoot: string, branchName: string): boolean {\n324:   try {\n325:     runSync(`git rev-parse --verify \"refs/heads/${branchName}\"`, {\n326:       cwd: projectRoot,\n327:       silent: true,\n328:     });\n329:     return true;\n330:   } catch {\n331:     return false;\n332:   }\n333: }\n334: \n335: // ---------------------------------------------------------------------------\n336: // Worktree Listing / Cleanup (sync)\n337: // ---------------------------------------------------------------------------\n338: \n339: /**\n340:  * List all git worktrees.\n341:  */\n342: export function listWorktrees(projectRoot: string): WorktreeInfo[] {\n343:   const output = runSync(\"git worktree list --porcelain\", {\n344:     cwd: projectRoot,\n345:     silent: true,\n346:   });\n347:   if (!output) return [];\n348: \n349:   const worktrees: WorktreeInfo[] = [];\n350:   let current: Partial<WorktreeInfo> = {};\n351: \n352:   for (const line of output.split(\"\\n\")) {\n353:     if (line.startsWith(\"worktree \")) {\n354:       if (current.path) worktrees.push(current as WorktreeInfo);\n355:       current = { path: line.slice(9), bare: false };\n356:     } else if (line.startsWith(\"HEAD \")) {\n357:       current.head = line.slice(5);\n358:     } else if (line.startsWith(\"branch \")) {\n359:       current.branch = line.slice(7).replace(\"refs/heads/\", \"\");\n360:     } else if (line === \"bare\") {\n361:       current.bare = true;\n362:     } else if (line === \"\" && current.path) {\n363:       worktrees.push(current as WorktreeInfo);\n364:       current = {};\n365:     }\n366:   }\n367:   if (current.path) worktrees.push(current as WorktreeInfo);\n368: \n369:   return worktrees;\n370: }\n371: \n372: /**\n373:  * List only wombo-related worktrees.\n374:  *\n375:  * SAFETY: Filters by checking that the *basename* of the worktree path\n376:  * starts with the worktreePrefix. A naive `.includes()` on the full path\n377:  * would match the main repo itself if its directory name contained the\n378:  * prefix (e.g. \"wombo-combo\" contains \"wombo-\"), causing cleanup to\n379:  * destroy the project root.\n380:  *\n381:  * Additionally, the main repo worktree (projectRoot) is always excluded\n382:  * as a defensive guard.\n383:  */\n384: export function listWomboWorktrees(\n385:   projectRoot: string,\n386:   config: WomboConfig\n387: ): WorktreeInfo[] {\n388:   const resolvedRoot = resolve(projectRoot);\n389:   return listWorktrees(projectRoot).filter((wt) => {\n390:     // Never include the main project root\n391:     if (resolve(wt.path) === resolvedRoot) return false;\n392:     // Match only worktrees whose directory name starts with the prefix\n393:     return basename(wt.path).startsWith(config.git.worktreePrefix);\n394:   });\n395: }\n396: \n397: /**\n398:  * Remove a worktree and optionally delete its branch.\n399:  *\n400:  * SAFETY: Refuses to remove the project root itself. This is a hard guard\n401:  * against bugs in worktree filtering that could otherwise destroy the main repo.\n402:  */\n403: export function removeWorktree(\n404:   projectRoot: string,\n405:   wtPath: string,\n406:   deleteBranchToo: boolean = true\n407: ): void {\n408:   // Hard safety check: never remove the main project root\n409:   if (resolve(wtPath) === resolve(projectRoot)) {\n410:     throw new Error(\n411:       `SAFETY: refusing to remove project root as worktree: ${wtPath}`\n412:     );\n413:   }\n414: \n415:   const worktrees = listWorktrees(projectRoot);\n416:   const wt = worktrees.find((w) => w.path === wtPath);\n417: \n418:   try {\n419:     runSync(`git worktree remove --force \"${wtPath}\"`, { cwd: projectRoot });\n420:   } catch {\n421:     if (existsSync(wtPath)) {\n422:       runSync(`rm -rf \"${wtPath}\"`);\n423:     }\n424:     runSync(\"git worktree prune\", { cwd: projectRoot });\n425:   }\n426: \n427:   if (deleteBranchToo && wt?.branch) {\n428:     try {\n429:       runSync(`git branch -D \"${wt.branch}\"`, {\n430:         cwd: projectRoot,\n431:         silent: true,\n432:       });\n433:     } catch {\n434:       // Branch may have been merged or already deleted\n435:     }\n436:   }\n437: }\n438: \n439: /**\n440:  * Check if a feature branch has any commits beyond the base branch.\n441:  * Returns true if the branch has diverged (i.e., the agent made commits).\n442:  */\n443: export function branchHasChanges(\n444:   projectRoot: string,\n445:   branch: string,\n446:   baseBranch: string\n447: ): boolean {\n448:   try {\n449:     const count = runSync(\n450:       `git rev-list --count \"${baseBranch}..${branch}\"`,\n451:       { cwd: projectRoot, silent: true }\n452:     );\n453:     return parseInt(count, 10) > 0;\n454:   } catch {\n455:     // If the branch doesn't exist or git fails, assume no changes\n456:     return false;\n457:   }\n458: }\n459: \n460: /**\n461:  * Remove all wombo-related worktrees and prune.\n462:  */\n463: export function cleanupAllWorktrees(\n464:   projectRoot: string,\n465:   config: WomboConfig\n466: ): number {\n467:   const womboWorktrees = listWomboWorktrees(projectRoot, config);\n468:   let removed = 0;\n469:   for (const wt of womboWorktrees) {\n470:     try {\n471:       removeWorktree(projectRoot, wt.path, false);\n472:       removed++;\n473:     } catch (err: any) {\n474:       console.error(`Failed to remove worktree ${wt.path}: ${err.message}`);\n475:     }\n476:   }\n477:   try {\n478:     runSync(\"git worktree prune\", { cwd: projectRoot });\n479:   } catch {\n480:     // Prune is best-effort — may fail if repo state is already clean\n481:   }\n482:   return removed;\n483: }\n\n(End of file - total 483 lines)\n</content>","title":"src/lib/worktree.ts","metadata":{"preview":"/**\n * worktree.ts — Git worktree lifecycle management.\n *\n * Responsibilities:\n *   - Create feature branches from a base branch\n *   - Create git worktrees for each feature branch\n *   - Run install command in worktrees\n *   - List and remove worktrees\n *   - Copy agent config files into worktrees\n *\n * IMPORTANT: Heavy operations (createWorktree, installDeps) are async\n * to allow true parallelism with Promise.all.\n */\n\nimport { exec, execSync } from \"node:child_process\";\nimport { existsSync, cpSync, statSync } from \"node:fs\";\nimport { resolve, dirname, basename } from \"node:path\";\nimport type { WomboConfig } from \"../config.js\";\n\n// ---------------------------------------------------------------------------","truncated":false,"loaded":[]},"time":{"start":1773435839763,"end":1773435839777}}}}
{"type":"tool_use","timestamp":1773435840040,"sessionID":"ses_316fcc12bffeSBLLi3jBrbT2M4","part":{"id":"prt_ce903651b0019wp45KHeXpVeF7","sessionID":"ses_316fcc12bffeSBLLi3jBrbT2M4","messageID":"msg_ce903559e0012I5jfoZVY0Cr0j","type":"tool","callID":"toolu_vrtx_01Cjmp3iZBPv6khPFpgLAjvd","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-unit-test-suite/src/index.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-unit-test-suite/src/index.ts</path>\n<type>file</type>\n<content>1: #!/usr/bin/env bun\n2: /**\n3:  * index.ts — CLI entry point for the wombo-combo agent orchestration system.\n4:  *\n5:  * Every command has a short alias (e.g., woco i = woco init, woco t ls = woco tasks list).\n6:  *\n7:  * Usage:\n8:  *   woco init                                         (alias: i)\n9:  *   woco launch --top-priority 3                      (alias: l)\n10:  *   woco launch --quickest-wins 5\n11:  *   woco launch --priority high\n12:  *   woco launch --difficulty easy\n13:  *   woco launch --tasks \"feat-a,feat-b\"\n14:  *   woco launch --all-ready\n15:  *   woco launch ... --max-concurrent 3 --model \"anthropic/claude-sonnet-4-20250514\"\n16:  *   woco launch ... --interactive\n17:  *   woco resume                                       (alias: r)\n18:  *   woco status                                       (alias: s)\n19:  *   woco verify [feature-id]                          (alias: v)\n20:  *   woco merge [feature-id]                           (alias: m)\n21:  *   woco retry <feature-id>                           (alias: re)\n22:  *   woco abort <feature-id> [--requeue] [--output json]  (alias: a)\n23:  *   woco logs <feature-id> [--tail N] [--follow]      (alias: lo)\n24:  *   woco cleanup                                      (alias: c)\n25:  *   woco history [wave-id] [--output json]            (alias: h)\n26:  *   woco tasks list [--status <s>] [--priority <p>]   (alias: t ls)\n27:  *   woco tasks add <id> <title> [options]             (alias: t a)\n28:  *   woco tasks set-status <task-id> <status>          (alias: t ss)\n29:  *   woco tasks set-priority <task-id> <priority>      (alias: t sp)\n30:  *   woco tasks set-difficulty <task-id> <difficulty>   (alias: t sd)\n31:  *   woco tasks check                                  (alias: t ch)\n32:  *   woco tasks archive [task-id] [--dry-run]          (alias: t ar)\n33:  *   woco tasks show <task-id>                         (alias: t sh)\n34:  *   woco tasks graph [--ascii] [--mermaid]            (alias: t g)\n35:  *   woco completion <bash|zsh|fish>                   (alias: comp)\n36:  *   woco help\n37:  *   woco version\n38:  *   woco -v\n39:  */\n40: \n41: import { resolve } from \"node:path\";\n42: import { existsSync, readFileSync } from \"node:fs\";\n43: import { loadConfig, validateConfig } from \"./config.js\";\n44: import { loadState, saveState } from \"./lib/state.js\";\n45: \n46: // ---------------------------------------------------------------------------\n47: // Dev-mode guard: warn if running the global binary inside the wombo-combo repo\n48: // ---------------------------------------------------------------------------\n49: \n50: function checkDevModeGuard(): void {\n51:   const cwd = process.cwd();\n52:   const pkgPath = resolve(cwd, \"package.json\");\n53: \n54:   // Are we inside the wombo-combo repo?\n55:   if (!existsSync(pkgPath)) return;\n56: \n57:   let pkgName: string | undefined;\n58:   try {\n59:     const raw = readFileSync(pkgPath, \"utf-8\");\n60:     pkgName = JSON.parse(raw).name;\n61:   } catch {\n62:     return;\n63:   }\n64:   if (pkgName !== \"wombo-combo\") return;\n65: \n66:   // We're in the wombo-combo repo. Is the source being run from a different location?\n67:   // import.meta.dir = directory of THIS file (index.ts). If it's under cwd,\n68:   // we're running local source (bun dev). If it's elsewhere (e.g. ~/.bun/install),\n69:   // we're running the globally installed binary.\n70:   const sourceDir = resolve(import.meta.dir);\n71:   const projectSrc = resolve(cwd, \"src\");\n72: \n73:   if (!sourceDir.startsWith(projectSrc)) {\n74:     console.warn(\n75:       \"\\x1b[33m[WARNING]\\x1b[0m You are running the globally installed woco binary \" +\n76:       \"inside the wombo-combo repo.\\n\" +\n77:       \"  Use \\x1b[1mbun dev <command>\\x1b[0m instead to run from local source.\\n\" +\n78:       \"  See AGENTS.md for details.\\n\"\n79:     );\n80:   }\n81: }\n82: \n83: import { cmdInit } from \"./commands/init.js\";\n84: import { cmdLaunch } from \"./commands/launch.js\";\n85: import { cmdResume } from \"./commands/resume.js\";\n86: import { cmdStatus } from \"./commands/status.js\";\n87: import { cmdVerify } from \"./commands/verify.js\";\n88: import { cmdMerge } from \"./commands/merge.js\";\n89: import { cmdRetry } from \"./commands/retry.js\";\n90: import { cmdCleanup } from \"./commands/cleanup.js\";\n91: import { cmdAbort } from \"./commands/abort.js\";\n92: import { cmdLogs } from \"./commands/logs.js\";\n93: import { cmdUpgrade } from \"./commands/upgrade.js\";\n94: import { cmdHistory } from \"./commands/history.js\";\n95: import { cmdCompletion } from \"./commands/completion.js\";\n96: import { cmdTasksList } from \"./commands/tasks/list.js\";\n97: import { cmdTasksAdd } from \"./commands/tasks/add.js\";\n98: import { cmdTasksSetStatus } from \"./commands/tasks/set-status.js\";\n99: import { cmdTasksSetPriority } from \"./commands/tasks/set-priority.js\";\n100: import { cmdTasksSetDifficulty } from \"./commands/tasks/set-difficulty.js\";\n101: import { cmdTasksCheck } from \"./commands/tasks/check.js\";\n102: import { cmdTasksArchive } from \"./commands/tasks/archive.js\";\n103: import { cmdTasksShow } from \"./commands/tasks/show.js\";\n104: import { cmdTasksGraph } from \"./commands/tasks/graph.js\";\n105: \n106: import { ensureTasksFile } from \"./lib/tasks.js\";\n107: import type { Priority, Difficulty, FeatureStatus } from \"./lib/tasks.js\";\n108: import { resolveOutputFormat, type OutputFormat } from \"./lib/output.js\";\n109: import { validateId, validateText, validateBranchName, validateDuration, assertValid } from \"./lib/validate.js\";\n110: import { findCommandDef, commandToSchema, allCommandSchemas } from \"./lib/schema.js\";\n111: import { buildToonSpec, renderToonLegend } from \"./lib/toon-spec.js\";\n112: \n113: // ---------------------------------------------------------------------------\n114: // Types\n115: // ---------------------------------------------------------------------------\n116: \n117: export interface CLIArgs {\n118:   command: string;\n119:   subcommand?: string;\n120:   // Selection options (launch)\n121:   topPriority?: number;\n122:   quickestWins?: number;\n123:   priority?: Priority;\n124:   difficulty?: Difficulty;\n125:   tasks?: string[];\n126:   allReady?: boolean;\n127:   // Launch / runtime options\n128:   maxConcurrent?: number;\n129:   model?: string;\n130:   interactive: boolean;\n131:   dryRun: boolean;\n132:   baseBranch?: string;\n133:   maxRetries?: number;\n134:   noTui: boolean;\n135:   autoPush: boolean;\n136:   // Abort options\n137:   requeue: boolean;\n138:   // General\n139:   featureId?: string;\n140:   force: boolean;\n141:   // Output format\n142:   outputFmt: OutputFormat;\n143:   // Upgrade options\n144:   checkOnly: boolean;\n145:   tag?: string;\n146:   // Features subcommand extras\n147:   status?: string;\n148:   ready?: boolean;\n149:   includeArchive?: boolean;\n150:   title?: string;\n151:   description?: string;\n152:   effort?: string;\n153:   dependsOn?: string[];\n154:   // Logs options\n155:   tail?: number;\n156:   follow?: boolean;\n157:   // Compact output\n158:   fields?: string[];\n159:   // Graph options\n160:   ascii?: boolean;\n161:   mermaidRaw?: boolean;\n162:   graphSubtasks?: boolean;\n163:   // Browser verification\n164:   browser?: boolean;\n165: }\n166: \n167: // ---------------------------------------------------------------------------\n168: // Command & Subcommand Aliases\n169: // ---------------------------------------------------------------------------\n170: \n171: /** Map of short aliases → canonical top-level command names. */\n172: export const COMMAND_ALIASES: Record<string, string> = {\n173:   i: \"init\",\n174:   l: \"launch\",\n175:   r: \"resume\",\n176:   s: \"status\",\n177:   v: \"verify\",\n178:   m: \"merge\",\n179:   re: \"retry\",\n180:   a: \"abort\",\n181:   c: \"cleanup\",\n182:   h: \"history\",\n183:   lo: \"logs\",\n184:   t: \"tasks\",\n185:   features: \"tasks\", // backward-compat full-word alias\n186:   u: \"upgrade\",\n187:   d: \"describe\",\n188:   comp: \"completion\",\n189: };\n190: \n191: /** Map of short aliases → canonical tasks subcommand names. */\n192: export const SUBCOMMAND_ALIASES: Record<string, string> = {\n193:   ls: \"list\",\n194:   a: \"add\",\n195:   ss: \"set-status\",\n196:   sp: \"set-priority\",\n197:   sd: \"set-difficulty\",\n198:   ch: \"check\",\n199:   validate: \"check\", // backward-compat full-word alias\n200:   ar: \"archive\",\n201:   sh: \"show\",\n202:   g: \"graph\",\n203: };\n204: \n205: // ---------------------------------------------------------------------------\n206: // Arg Parsing\n207: // ---------------------------------------------------------------------------\n208: \n209: export function parseArgs(argv: string[]): CLIArgs {\n210:   const args = argv.slice(2); // skip 'bun' and script path\n211:   const result: CLIArgs = {\n212:     command: args[0] || \"help\",\n213:     interactive: false,\n214:     dryRun: false,\n215:     noTui: false,\n216:     autoPush: false,\n217:     requeue: false,\n218:     force: false,\n219:     checkOnly: false,\n220:     outputFmt: resolveOutputFormat(undefined), // auto-detect until --output overrides\n221:   };\n222: \n223:   // Resolve top-level command alias (e.g., \"i\" → \"init\", \"t\" → \"tasks\")\n224:   result.command = COMMAND_ALIASES[result.command] ?? result.command;\n225: \n226:   // If the command is \"tasks\", treat the second positional as the subcommand\n227:   let startIdx = 1;\n228:   if (result.command === \"tasks\") {\n229:     result.subcommand = args[1] || \"list\";\n230:     // Resolve subcommand alias (e.g., \"ls\" → \"list\", \"ss\" → \"set-status\")\n231:     result.subcommand = SUBCOMMAND_ALIASES[result.subcommand] ?? result.subcommand;\n232:     startIdx = 2;\n233:   }\n234: \n235:   for (let i = startIdx; i < args.length; i++) {\n236:     const arg = args[i];\n237: \n238:     // Helper: consume the next argument, or exit with a clear error\n239:     function requireValue(flag: string): string {\n240:       if (i + 1 >= args.length) {\n241:         console.error(`Flag ${flag} requires a value.`);\n242:         process.exit(1);\n243:       }\n244:       return args[++i];\n245:     }\n246: \n247:     switch (arg) {\n248:       // --- Selection options ---\n249:       case \"--top-priority\":\n250:         result.topPriority = parseInt(requireValue(arg), 10);\n251:         break;\n252:       case \"--quickest-wins\":\n253:         result.quickestWins = parseInt(requireValue(arg), 10);\n254:         break;\n255:       case \"--priority\":\n256:         result.priority = requireValue(arg) as Priority;\n257:         break;\n258:       case \"--difficulty\":\n259:         result.difficulty = requireValue(arg) as Difficulty;\n260:         break;\n261:       case \"--tasks\":\n262:       case \"--features\": // backward-compat alias\n263:         result.tasks = requireValue(arg).split(\",\").map((s) => s.trim());\n264:         break;\n265:       case \"--all-ready\":\n266:         result.allReady = true;\n267:         break;\n268: \n269:       // --- Launch / runtime options ---\n270:       case \"--max-concurrent\":\n271:         result.maxConcurrent = parseInt(requireValue(arg), 10);\n272:         break;\n273:       case \"--model\":\n274:       case \"-m\":\n275:         result.model = requireValue(arg);\n276:         break;\n277:       case \"--interactive\":\n278:         result.interactive = true;\n279:         break;\n280:       case \"--dry-run\":\n281:         result.dryRun = true;\n282:         break;\n283:       case \"--no-tui\":\n284:         result.noTui = true;\n285:         break;\n286:       case \"--auto-push\":\n287:         result.autoPush = true;\n288:         break;\n289:       case \"--requeue\":\n290:         result.requeue = true;\n291:         break;\n292:       case \"--base-branch\":\n293:         result.baseBranch = requireValue(arg);\n294:         break;\n295:       case \"--max-retries\":\n296:         result.maxRetries = parseInt(requireValue(arg), 10);\n297:         break;\n298: \n299:       // --- General flags ---\n300:       case \"--force\":\n301:         result.force = true;\n302:         break;\n303:       case \"--check\":\n304:         result.checkOnly = true;\n305:         break;\n306:       case \"--tag\":\n307:       case \"--release\":\n308:         result.tag = requireValue(arg);\n309:         break;\n310:       case \"--output\":\n311:       case \"-o\":\n312:         result.outputFmt = resolveOutputFormat(requireValue(arg));\n313:         break;\n314: \n315:       // --- Tasks subcommand options ---\n316:       case \"--status\":\n317:         result.status = requireValue(arg);\n318:         break;\n319:       case \"--ready\":\n320:         result.ready = true;\n321:         break;\n322:       case \"--include-archive\":\n323:         result.includeArchive = true;\n324:         break;\n325:       case \"--title\":\n326:         result.title = requireValue(arg);\n327:         break;\n328:       case \"--description\":\n329:       case \"--desc\":\n330:         result.description = requireValue(arg);\n331:         break;\n332:       case \"--effort\":\n333:         result.effort = requireValue(arg);\n334:         break;\n335:       case \"--depends-on\":\n336:         result.dependsOn = requireValue(arg).split(\",\").map((s) => s.trim());\n337:         break;\n338:       case \"--fields\":\n339:         result.fields = requireValue(arg).split(\",\").map((s) => s.trim());\n340:         break;\n341: \n342:       // --- Graph options ---\n343:       case \"--ascii\":\n344:         result.ascii = true;\n345:         break;\n346:       case \"--mermaid\":\n347:         result.mermaidRaw = true;\n348:         break;\n349:       case \"--subtasks\":\n350:         result.graphSubtasks = true;\n351:         break;\n352: \n353:       // --- Logs options ---\n354:       case \"--tail\":\n355:         result.tail = parseInt(requireValue(arg), 10);\n356:         break;\n357:       case \"--follow\":\n358:       case \"-f\":\n359:         result.follow = true;\n360:         break;\n361: \n362:       // --- Browser verification ---\n363:       case \"--browser\":\n364:         result.browser = true;\n365:         break;\n366: \n367:       // --- Positional (feature-id, title for add, etc.) ---\n368:       default:\n369:         if (!arg.startsWith(\"-\")) {\n370:           if (!result.featureId) {\n371:             result.featureId = arg;\n372:           } else if (!result.title) {\n373:             result.title = arg;\n374:           }\n375:         }\n376:         break;\n377:     }\n378:   }\n379: \n380:   return result;\n381: }\n382: \n383: // ---------------------------------------------------------------------------\n384: // Help\n385: // ---------------------------------------------------------------------------\n386: \n387: function cmdHelp(): void {\n388:   console.log(`\n389: wombo-combo — AI Agent Orchestration System\n390: \n391:   WOMBO COMBO! Parallel feature development with AI agents.\n392: \n393: Commands:                        (alias)\n394:   init                           (i)     Generate .wombo-combo/config.json in the current project\n395:   launch                         (l)     Launch a wave of agents to implement features\n396:   resume                         (r)     Resume a previously stopped wave\n397:   status                         (s)     Show the status of the current wave\n398:   verify                         (v)     Run build verification on completed agents\n399:   merge                          (m)     Merge verified branches into the base branch\n400:   retry                          (re)    Retry a failed agent\n401:   abort                          (a)     Kill a single running agent (--requeue to return to queue)\n402:   logs                           (lo)    Pretty-print agent logs for a feature\n403:   cleanup                        (c)     Remove all wave worktrees and multiplexer sessions\n404:   history                        (h)     List/view past wave results (stored in .wombo-combo/history/)\n405:   tasks                          (t)     Manage tasks file (see below; 'features' also accepted)\n406:   upgrade                        (u)     Check for updates and upgrade wombo-combo\n407:   describe                       (d)     Emit JSON schema of a command (for AI agents)\n408:   completion                     (comp)  Generate shell completions (bash, zsh, fish)\n409:   version                                Print version and exit\n410:   help                                   Show this help\n411: \n412: Tasks Subcommands:               (alias)\n413:   tasks list                     (ls)    List tasks (--status, --priority, --difficulty, --ready, --include-archive)\n414:   tasks add <id> <title>         (a)     Add a new task (--desc, --priority, --difficulty, --effort, --depends-on)\n415:   tasks set-status <id> <s>      (ss)    Change a task's status\n416:   tasks set-priority <id> <p>    (sp)    Change a task's priority (critical/high/medium/low/wishlist)\n417:   tasks set-difficulty <id> <d>  (sd)    Change a task's difficulty (trivial/easy/medium/hard/very_hard)\n418:   tasks check                    (ch)    Validate tasks file (schema, deps, duplicates, cycles)\n419:   tasks archive [id]             (ar)    Move done/cancelled to archive (--dry-run)\n420:   tasks show <id>                (sh)    Show task details\n421:   tasks graph                    (g)     Visualize dependency graph (--ascii, --mermaid, --subtasks)\n422: \n423: Selection Options (for launch):\n424:   --top-priority N         Select top N tasks by priority\n425:   --quickest-wins N        Select N tasks with lowest effort\n426:   --priority <level>       Filter by priority (critical/high/medium/low/wishlist)\n427:   --difficulty <level>     Filter by difficulty (trivial/easy/medium/hard/very_hard)\n428:   --tasks \"id1,id2\"        Select specific tasks by ID (--features also accepted)\n429:   --all-ready              Select all tasks whose dependencies are met\n430: \n431: Launch Options:\n432:   --max-concurrent N       Max agents running in parallel (default: from config)\n433:   --model <model>          Model to use (e.g., \"anthropic/claude-sonnet-4-20250514\")\n434:   --interactive            Use multiplexer (dmux/tmux) TUI mode instead of headless\n435:   --no-tui                 Headless mode without neo-blessed TUI (periodic console dashboard)\n436:   --auto-push              Push base branch to remote after all merges complete\n437:   --dry-run                Show what would be launched without launching\n438:   --base-branch <branch>   Base branch (default: from config)\n439:   --max-retries N          Max retries per agent (default: from config)\n440:   --browser                Enable browser-based verification (run after build passes)\n441: \n442: General:\n443:   --force                  Force overwrite (e.g., for init) / skip prompts (e.g., for upgrade)\n444:   --output <fmt>           Output format: text (default on TTY) or json (default when piped)\n445:   -o <fmt>                 Alias for --output\n446:   --dry-run                Show what would happen without performing the action\n447:   --fields <list>          Comma-separated fields to include (e.g., id,status,priority)\n448: \n449: Upgrade Options:\n450:   --check                  Only check for updates, don't install\n451:   --tag <tag>              Install a specific version (e.g., v0.1.0)\n452: \n453: Logs Options:\n454:   --tail N                 Show only the last N lines\n455:   --follow, -f             Stream new output as it arrives (like tail -f)\n456: \n457: Aliases (every command has a short form):\n458:   woco i                         woco init\n459:   woco l --all-ready             woco launch --all-ready\n460:   woco t ls                      woco tasks list\n461:   woco t a my-task \"Title\"       woco tasks add my-task \"Title\"\n462:   woco t ss my-task done         woco tasks set-status my-task done\n463: \n464: Shell Completion:\n465:   eval \"$(woco completion bash)\"    # Bash: add to ~/.bashrc\n466:   eval \"$(woco completion zsh)\"     # Zsh:  add to ~/.zshrc\n467:   woco completion fish | source     # Fish (or save to ~/.config/fish/completions/woco.fish)\n468: \n469: Examples:\n470:   woco init\n471:   woco launch --quickest-wins 3\n472:   woco launch --priority high --interactive\n473:   woco launch --tasks \"auth-flow,search-api\" --max-concurrent 2\n474:   woco resume\n475:   woco status\n476:   woco verify\n477:   woco merge\n478:   woco retry auth-flow\n479:   woco abort auth-flow\n480:   woco abort auth-flow --requeue\n481:   woco abort auth-flow --output json\n482:   woco logs auth-flow\n483:   woco logs auth-flow --tail 50\n484:   woco logs auth-flow --follow\n485:   woco logs auth-flow --output json\n486:   woco cleanup\n487:   woco tasks list --status ready --priority high\n488:   woco tasks list --fields id,status,priority --output json\n489:   woco tasks add my-task \"My Cool Task\" --priority high --difficulty easy\n490:   woco tasks set-status my-task in-progress\n491:   woco tasks check\n492:   woco tasks archive --dry-run\n493:   woco tasks show my-task\n494:   woco history\n495:   woco history wave-2026-03-12-420\n496:   woco history --output json\n497:   woco describe                           # list all commands as JSON\n498:   woco describe launch                    # describe a specific command\n499:   woco describe tasks add                 # describe a subcommand\n500: `);\n501: }\n502: \n503: // ---------------------------------------------------------------------------\n504: // Main\n505: // ---------------------------------------------------------------------------\n506: \n507: async function main(): Promise<void> {\n508:   checkDevModeGuard();\n509: \n510:   const PROJECT_ROOT = resolve(process.cwd());\n511:   const args = parseArgs(process.argv);\n512: \n513:   // -----------------------------------------------------------------------\n514:   // Input validation at the CLI boundary\n515:   // -----------------------------------------------------------------------\n516:   if (args.featureId) {\n517:     assertValid(validateId(args.featureId, \"feature ID\"));\n518:   }\n519:   if (args.title) {\n520:     assertValid(validateText(args.title, \"title\"));\n521:   }\n522:   if (args.description) {\n523:     assertValid(validateText(args.description, \"description\"));\n524:   }\n525:   if (args.baseBranch) {\n526:     assertValid(validateBranchName(args.baseBranch, \"base branch\"));\n527:   }\n528:   if (args.effort) {\n529:     assertValid(validateDuration(args.effort, \"effort\"));\n530:   }\n531:   if (args.tasks) {\n532:     for (const fid of args.tasks) {\n533:       assertValid(validateId(fid, \"task ID in --tasks\"));\n534:     }\n535:   }\n536:   if (args.dependsOn) {\n537:     for (const dep of args.dependsOn) {\n538:       assertValid(validateId(dep, \"dependency ID in --depends-on\"));\n539:     }\n540:   }\n541: \n542:   // Commands that don't need config loading\n543:   if (args.command === \"version\" || args.command === \"-v\" || args.command === \"-V\") {\n544:     const pkgPath = resolve(import.meta.dir, \"..\", \"package.json\");\n545:     const pkgFile = Bun.file(pkgPath);\n546:     try {\n547:       const pkg = await pkgFile.json();\n548:       console.log(`wombo-combo ${pkg.version ?? \"(unknown version)\"}`);\n549:     } catch {\n550:       console.log(\"wombo-combo (unknown version)\");\n551:     }\n552:     return;\n553:   }\n554: \n555:   if (args.command === \"help\" || args.command === \"--help\" || args.command === \"-h\") {\n556:     cmdHelp();\n557:     return;\n558:   }\n559: \n560:   if (args.command === \"describe\") {\n561:     // Schema introspection: `woco describe [command]`\n562:     if (args.outputFmt === \"toon\") {\n563:       // Emit TOON format legend — self-describing, cacheable by agents\n564:       const pkgPath = resolve(import.meta.dir, \"..\", \"package.json\");\n565:       let version = \"unknown\";\n566:       try {\n567:         const pkg = await Bun.file(pkgPath).json();\n568:         version = pkg.version ?? \"unknown\";\n569:       } catch {}\n570: \n571:       if (!args.featureId) {\n572:         // Full TOON spec (legend + all commands)\n573:         console.log(renderToonLegend(version));\n574:       } else {\n575:         // JSON structure for the full spec (--output toon with a specific command\n576:         // still emits JSON since TOON is a line-oriented data format, not a schema format)\n577:         const spec = buildToonSpec(version);\n578:         const cmdName = args.title\n579:           ? `${args.featureId} ${args.title}`\n580:           : args.featureId;\n581:         const cmdSpec = spec.commands.find((c) => c.command === cmdName);\n582:         if (!cmdSpec) {\n583:           console.error(`Unknown command: \"${cmdName}\"`);\n584:           console.error(\"Run 'woco describe --output toon' to see the full TOON spec.\");\n585:           process.exit(1);\n586:           return;\n587:         }\n588:         console.log(JSON.stringify(cmdSpec, null, 2));\n589:       }\n590:       return;\n591:     }\n592: \n593:     if (!args.featureId) {\n594:       // No command specified — list all commands\n595:       console.log(JSON.stringify(allCommandSchemas(), null, 2));\n596:     } else {\n597:       // Describe a specific command. Handle compound names: \"features list\"\n598:       const cmdName = args.title\n599:         ? `${args.featureId} ${args.title}`\n600:         : args.featureId;\n601:       const def = findCommandDef(cmdName);\n602:       if (!def) {\n603:         console.error(`Unknown command: \"${cmdName}\"`);\n604:         console.error(\"Run 'woco describe' to list all commands.\");\n605:         process.exit(1);\n606:         return;\n607:       }\n608:       console.log(JSON.stringify(commandToSchema(def), null, 2));\n609:     }\n610:     return;\n611:   }\n612: \n613:   if (args.command === \"init\") {\n614:     await cmdInit({ projectRoot: PROJECT_ROOT, force: args.force });\n615:     return;\n616:   }\n617: \n618:   if (args.command === \"upgrade\") {\n619:     await cmdUpgrade({\n620:       force: args.force,\n621:       tag: args.tag,\n622:       checkOnly: args.checkOnly,\n623:     });\n624:     return;\n625:   }\n626: \n627:   if (args.command === \"completion\") {\n628:     cmdCompletion({ shell: args.featureId }); // first positional = shell name\n629:     return;\n630:   }\n631: \n632:   if (args.command === \"logs\") {\n633:     if (!args.featureId) {\n634:       console.error(\"Usage: woco logs <feature-id> [--tail N] [--follow] [--output json]\");\n635:       process.exit(1);\n636:       return;\n637:     }\n638:     await cmdLogs({\n639:       projectRoot: PROJECT_ROOT,\n640:       featureId: args.featureId,\n641:       tail: args.tail,\n642:       follow: args.follow,\n643:       outputFmt: args.outputFmt,\n644:     });\n645:     return;\n646:   }\n647: \n648:   // Everything else requires config\n649:   const config = loadConfig(PROJECT_ROOT);\n650:   validateConfig(config);\n651: \n652:   // Commands that operate on the tasks file — ensure it exists first\n653:   const needsTasksFile = new Set([\"launch\", \"resume\", \"verify\", \"retry\", \"tasks\"]);\n654:   if (needsTasksFile.has(args.command)) {\n655:     await ensureTasksFile(PROJECT_ROOT, config);\n656:   }\n657: \n658:   switch (args.command) {\n659:     case \"launch\":\n660:       // Apply browser verification override if --browser flag was passed\n661:       if (args.browser !== undefined) {\n662:         config.browser.enabled = args.browser;\n663:       }\n664:       await cmdLaunch({\n665:         projectRoot: PROJECT_ROOT,\n666:         config,\n667:         topPriority: args.topPriority,\n668:         quickestWins: args.quickestWins,\n669:         priority: args.priority,\n670:         difficulty: args.difficulty,\n671:         features: args.tasks,\n672:         allReady: args.allReady,\n673:         maxConcurrent: args.maxConcurrent ?? config.defaults.maxConcurrent,\n674:         model: args.model,\n675:         interactive: args.interactive,\n676:         dryRun: args.dryRun,\n677:         baseBranch: args.baseBranch ?? config.baseBranch,\n678:         maxRetries: args.maxRetries ?? config.defaults.maxRetries,\n679:         noTui: args.noTui,\n680:         autoPush: args.autoPush,\n681:         outputFmt: args.outputFmt,\n682:       });\n683:       break;\n684: \n685:     case \"resume\":\n686:       await cmdResume({\n687:         projectRoot: PROJECT_ROOT,\n688:         config,\n689:         maxConcurrent: args.maxConcurrent,\n690:         model: args.model,\n691:         interactive: args.interactive,\n692:         noTui: args.noTui,\n693:         autoPush: args.autoPush,\n694:         baseBranch: args.baseBranch,\n695:         maxRetries: args.maxRetries,\n696:       });\n697:       break;\n698: \n699:     case \"status\":\n700:       await cmdStatus({ projectRoot: PROJECT_ROOT, config, outputFmt: args.outputFmt });\n701:       break;\n702: \n703:     case \"verify\":\n704:       await cmdVerify({\n705:         projectRoot: PROJECT_ROOT,\n706:         config,\n707:         featureId: args.featureId,\n708:         model: args.model,\n709:         maxRetries: args.maxRetries,\n710:         browserVerify: args.browser,\n711:       });\n712:       break;\n713: \n714:     case \"merge\":\n715:       await cmdMerge({\n716:         projectRoot: PROJECT_ROOT,\n717:         config,\n718:         featureId: args.featureId,\n719:         autoPush: args.autoPush,\n720:         dryRun: args.dryRun,\n721:         model: args.model,\n722:       });\n723:       break;\n724: \n725:     case \"retry\": {\n726:       if (!args.featureId) {\n727:         console.error(\"Usage: woco retry <feature-id>\");\n728:         process.exit(1);\n729:         return;\n730:       }\n731:       await cmdRetry({\n732:         projectRoot: PROJECT_ROOT,\n733:         config,\n734:         featureId: args.featureId,\n735:         model: args.model,\n736:         interactive: args.interactive,\n737:         dryRun: args.dryRun,\n738:       });\n739:       break;\n740:     }\n741: \n742:     case \"cleanup\":\n743:       await cmdCleanup({ projectRoot: PROJECT_ROOT, config, dryRun: args.dryRun });\n744:       break;\n745: \n746:     case \"history\":\n747:       await cmdHistory({\n748:         projectRoot: PROJECT_ROOT,\n749:         config,\n750:         waveId: args.featureId,\n751:         outputFmt: args.outputFmt,\n752:       });\n753:       break;\n754: \n755:     case \"abort\": {\n756:       if (!args.featureId) {\n757:         console.error(\"Usage: woco abort <feature-id> [--requeue] [--output json]\");\n758:         process.exit(1);\n759:         return;\n760:       }\n761:       await cmdAbort({\n762:         projectRoot: PROJECT_ROOT,\n763:         config,\n764:         featureId: args.featureId,\n765:         requeue: args.requeue,\n766:         outputFmt: args.outputFmt,\n767:       });\n768:       break;\n769:     }\n770: \n771:     case \"tasks\":\n772:       await handleTasksSubcommand(args, PROJECT_ROOT, config);\n773:       break;\n774: \n775:     default:\n776:       console.error(`Unknown command: ${args.command}`);\n777:       cmdHelp();\n778:       process.exit(1);\n779:       return;\n780:   }\n781: }\n782: \n783: // ---------------------------------------------------------------------------\n784: // Tasks Subcommand Router\n785: // ---------------------------------------------------------------------------\n786: \n787: async function handleTasksSubcommand(\n788:   args: CLIArgs,\n789:   projectRoot: string,\n790:   config: import(\"./config.js\").WomboConfig\n791: ): Promise<void> {\n792:   switch (args.subcommand) {\n793:     case \"list\":\n794:       await cmdTasksList({\n795:         projectRoot,\n796:         config,\n797:         status: args.status as FeatureStatus | undefined,\n798:         priority: args.priority,\n799:         difficulty: args.difficulty,\n800:         ready: args.ready,\n801:         includeArchive: args.includeArchive,\n802:         outputFmt: args.outputFmt,\n803:         fields: args.fields,\n804:       });\n805:       break;\n806: \n807:     case \"add\": {\n808:       if (!args.featureId || !args.title) {\n809:         console.error(\"Usage: woco tasks add <id> <title> [--desc <desc>] [--priority <p>] [--difficulty <d>] [--effort <e>] [--depends-on <ids>]\");\n810:         process.exit(1);\n811:         return;\n812:       }\n813:       await cmdTasksAdd({\n814:         projectRoot,\n815:         config,\n816:         id: args.featureId,\n817:         title: args.title,\n818:         description: args.description,\n819:         priority: args.priority,\n820:         difficulty: args.difficulty,\n821:         effort: args.effort,\n822:         dependsOn: args.dependsOn,\n823:         outputFmt: args.outputFmt,\n824:         dryRun: args.dryRun,\n825:       });\n826:       break;\n827:     }\n828: \n829:     case \"set-status\": {\n830:       if (!args.featureId || !args.title) {\n831:         // title holds the second positional arg (the status value)\n832:         // If not provided via positional, check --status flag\n833:         const newStatus = args.title || args.status;\n834:         if (!args.featureId || !newStatus) {\n835:           console.error(\"Usage: woco tasks set-status <task-id> <status>\");\n836:           process.exit(1);\n837:           return;\n838:         }\n839:         await cmdTasksSetStatus({\n840:           projectRoot,\n841:           config,\n842:           featureId: args.featureId,\n843:           newStatus,\n844:           outputFmt: args.outputFmt,\n845:           dryRun: args.dryRun,\n846:         });\n847:       } else {\n848:         await cmdTasksSetStatus({\n849:           projectRoot,\n850:           config,\n851:           featureId: args.featureId,\n852:           newStatus: args.title, // second positional = new status\n853:           outputFmt: args.outputFmt,\n854:           dryRun: args.dryRun,\n855:         });\n856:       }\n857:       break;\n858:     }\n859: \n860:     case \"set-priority\": {\n861:       if (!args.featureId || !args.title) {\n862:         // title holds the second positional arg (the priority value)\n863:         // If not provided via positional, check --priority flag\n864:         const newPriority = args.title || (args.priority as string | undefined);\n865:         if (!args.featureId || !newPriority) {\n866:           console.error(\"Usage: woco tasks set-priority <task-id> <priority>\");\n867:           process.exit(1);\n868:           return;\n869:         }\n870:         await cmdTasksSetPriority({\n871:           projectRoot,\n872:           config,\n873:           featureId: args.featureId,\n874:           newPriority,\n875:           outputFmt: args.outputFmt,\n876:           dryRun: args.dryRun,\n877:         });\n878:       } else {\n879:         await cmdTasksSetPriority({\n880:           projectRoot,\n881:           config,\n882:           featureId: args.featureId,\n883:           newPriority: args.title, // second positional = new priority\n884:           outputFmt: args.outputFmt,\n885:           dryRun: args.dryRun,\n886:         });\n887:       }\n888:       break;\n889:     }\n890: \n891:     case \"set-difficulty\": {\n892:       if (!args.featureId || !args.title) {\n893:         // title holds the second positional arg (the difficulty value)\n894:         // If not provided via positional, check --difficulty flag\n895:         const newDifficulty = args.title || (args.difficulty as string | undefined);\n896:         if (!args.featureId || !newDifficulty) {\n897:           console.error(\"Usage: woco tasks set-difficulty <task-id> <difficulty>\");\n898:           process.exit(1);\n899:           return;\n900:         }\n901:         await cmdTasksSetDifficulty({\n902:           projectRoot,\n903:           config,\n904:           featureId: args.featureId,\n905:           newDifficulty,\n906:           outputFmt: args.outputFmt,\n907:           dryRun: args.dryRun,\n908:         });\n909:       } else {\n910:         await cmdTasksSetDifficulty({\n911:           projectRoot,\n912:           config,\n913:           featureId: args.featureId,\n914:           newDifficulty: args.title, // second positional = new difficulty\n915:           outputFmt: args.outputFmt,\n916:           dryRun: args.dryRun,\n917:         });\n918:       }\n919:       break;\n920:     }\n921: \n922:     case \"check\":\n923:       await cmdTasksCheck({ projectRoot, config, outputFmt: args.outputFmt });\n924:       break;\n925: \n926:     case \"archive\":\n927:       await cmdTasksArchive({\n928:         projectRoot,\n929:         config,\n930:         featureId: args.featureId,\n931:         dryRun: args.dryRun,\n932:         outputFmt: args.outputFmt,\n933:       });\n934:       break;\n935: \n936:     case \"show\": {\n937:       if (!args.featureId) {\n938:         console.error(\"Usage: woco tasks show <task-id>\");\n939:         process.exit(1);\n940:         return;\n941:       }\n942:       await cmdTasksShow({\n943:         projectRoot,\n944:         config,\n945:         featureId: args.featureId,\n946:         outputFmt: args.outputFmt,\n947:         fields: args.fields,\n948:       });\n949:       break;\n950:     }\n951: \n952:     case \"graph\":\n953:       await cmdTasksGraph({\n954:         projectRoot,\n955:         config,\n956:         status: args.status as FeatureStatus | undefined,\n957:         ascii: args.ascii,\n958:         mermaid: args.mermaidRaw,\n959:         subtasks: args.graphSubtasks,\n960:         outputFmt: args.outputFmt,\n961:       });\n962:       break;\n963: \n964:     case \"help\":\n965:     case \"--help\":\n966:     case \"-h\":\n967:       cmdHelp();\n968:       break;\n969: \n970:     default:\n971:       console.error(`Unknown tasks subcommand: ${args.subcommand}`);\n972:       console.error(\"Run 'woco tasks help' or 'woco help' for usage.\");\n973:       process.exit(1);\n974:       return;\n975:   }\n976: }\n977: \n978: // ---------------------------------------------------------------------------\n979: // Error Handlers & Entry\n980: // ---------------------------------------------------------------------------\n981: \n982: // Global error handlers — prevent silent crashes\n983: process.on(\"uncaughtException\", (err) => {\n984:   console.error(`\\n[FATAL] Uncaught exception: ${err.message}`);\n985:   console.error(err.stack);\n986:   try {\n987:     const state = loadState(process.cwd());\n988:     if (state) saveState(process.cwd(), state);\n989:   } catch {}\n990:   process.exit(1);\n991: });\n992: \n993: process.on(\"unhandledRejection\", (reason: any) => {\n994:   console.error(`\\n[FATAL] Unhandled rejection: ${reason?.message || reason}`);\n995:   if (reason?.stack) console.error(reason.stack);\n996:   try {\n997:     const state = loadState(process.cwd());\n998:     if (state) saveState(process.cwd(), state);\n999:   } catch {}\n1000:   process.exit(1);\n1001: });\n1002: \n1003: main().catch((err) => {\n1004:   console.error(\"Fatal error:\", err.message);\n1005:   process.exit(1);\n1006: });\n\n(End of file - total 1006 lines)\n</content>","title":"src/index.ts","metadata":{"preview":"#!/usr/bin/env bun\n/**\n * index.ts — CLI entry point for the wombo-combo agent orchestration system.\n *\n * Every command has a short alias (e.g., woco i = woco init, woco t ls = woco tasks list).\n *\n * Usage:\n *   woco init                                         (alias: i)\n *   woco launch --top-priority 3                      (alias: l)\n *   woco launch --quickest-wins 5\n *   woco launch --priority high\n *   woco launch --difficulty easy\n *   woco launch --tasks \"feat-a,feat-b\"\n *   woco launch --all-ready\n *   woco launch ... --max-concurrent 3 --model \"anthropic/claude-sonnet-4-20250514\"\n *   woco launch ... --interactive\n *   woco resume                                       (alias: r)\n *   woco status                                       (alias: s)\n *   woco verify [feature-id]                          (alias: v)\n *   woco merge [feature-id]                           (alias: m)","truncated":false,"loaded":[]},"time":{"start":1773435840023,"end":1773435840036}}}}
