{"type":"tool_use","timestamp":1773435844666,"sessionID":"ses_316fcc12bffeSBLLi3jBrbT2M4","part":{"id":"prt_ce90377ba001VzzdOrGrv5mjni","sessionID":"ses_316fcc12bffeSBLLi3jBrbT2M4","messageID":"msg_ce9036b1f001WQ3dj9eBiOriAQ","type":"tool","callID":"toolu_vrtx_01PmohjMAHeeTrNk8uDC667i","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-unit-test-suite/tests/arg-parsing.test.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-unit-test-suite/tests/arg-parsing.test.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * arg-parsing.test.ts — Unit tests for CLI argument parsing.\n3:  *\n4:  * Coverage:\n5:  *   - Basic command parsing\n6:  *   - Tasks subcommand routing (with \"features\" backward-compat alias)\n7:  *   - Command & subcommand alias resolution\n8:  *   - Flag parsing (boolean flags, value flags)\n9:  *   - Trailing flags / missing values (requireValue behavior)\n10:  *   - Boolean flags not consuming next positional arg\n11:  *   - Flag collisions (-v version vs commands)\n12:  *   - Unknown flags behavior\n13:  *   - Positional argument handling (featureId, title)\n14:  *   - Edge cases: empty args, repeated flags, OOB access\n15:  */\n16: \n17: import { describe, test, expect } from \"bun:test\";\n18: import { parseArgs, COMMAND_ALIASES, SUBCOMMAND_ALIASES } from \"../src/index.js\";\n19: \n20: // Helper to simulate argv from CLI input. We need to prepend \"bun\" and \"script\"\n21: // since parseArgs does argv.slice(2).\n22: function argv(...args: string[]): string[] {\n23:   return [\"bun\", \"script.ts\", ...args];\n24: }\n25: \n26: // ---------------------------------------------------------------------------\n27: // Basic command parsing\n28: // ---------------------------------------------------------------------------\n29: \n30: describe(\"parseArgs — basic commands\", () => {\n31:   test(\"parses help command\", () => {\n32:     const result = parseArgs(argv(\"help\"));\n33:     expect(result.command).toBe(\"help\");\n34:   });\n35: \n36:   test(\"defaults to help when no args given\", () => {\n37:     const result = parseArgs(argv());\n38:     expect(result.command).toBe(\"help\");\n39:   });\n40: \n41:   test(\"parses launch command\", () => {\n42:     const result = parseArgs(argv(\"launch\"));\n43:     expect(result.command).toBe(\"launch\");\n44:   });\n45: \n46:   test(\"parses status command\", () => {\n47:     const result = parseArgs(argv(\"status\"));\n48:     expect(result.command).toBe(\"status\");\n49:   });\n50: \n51:   test(\"parses cleanup command\", () => {\n52:     const result = parseArgs(argv(\"cleanup\"));\n53:     expect(result.command).toBe(\"cleanup\");\n54:   });\n55: \n56:   test(\"parses --version as command\", () => {\n57:     const result = parseArgs(argv(\"--version\"));\n58:     expect(result.command).toBe(\"--version\");\n59:   });\n60: \n61:   test(\"parses -V as command\", () => {\n62:     const result = parseArgs(argv(\"-V\"));\n63:     expect(result.command).toBe(\"-V\");\n64:   });\n65: });\n66: \n67: // ---------------------------------------------------------------------------\n68: // Features subcommand routing\n69: // ---------------------------------------------------------------------------\n70: \n71: describe(\"parseArgs — tasks subcommands\", () => {\n72:   test(\"defaults tasks subcommand to list\", () => {\n73:     const result = parseArgs(argv(\"tasks\"));\n74:     expect(result.command).toBe(\"tasks\");\n75:     expect(result.subcommand).toBe(\"list\");\n76:   });\n77: \n78:   test(\"parses tasks list\", () => {\n79:     const result = parseArgs(argv(\"tasks\", \"list\"));\n80:     expect(result.command).toBe(\"tasks\");\n81:     expect(result.subcommand).toBe(\"list\");\n82:   });\n83: \n84:   test(\"parses tasks add with positional args\", () => {\n85:     const result = parseArgs(argv(\"tasks\", \"add\", \"my-feat\", \"My Feature Title\"));\n86:     expect(result.command).toBe(\"tasks\");\n87:     expect(result.subcommand).toBe(\"add\");\n88:     expect(result.featureId).toBe(\"my-feat\");\n89:     expect(result.title).toBe(\"My Feature Title\");\n90:   });\n91: \n92:   test(\"parses tasks set-status with positional args\", () => {\n93:     const result = parseArgs(argv(\"tasks\", \"set-status\", \"my-feat\", \"done\"));\n94:     expect(result.command).toBe(\"tasks\");\n95:     expect(result.subcommand).toBe(\"set-status\");\n96:     expect(result.featureId).toBe(\"my-feat\");\n97:     expect(result.title).toBe(\"done\"); // title holds second positional\n98:   });\n99: \n100:   test(\"parses tasks show with feature ID\", () => {\n101:     const result = parseArgs(argv(\"tasks\", \"show\", \"my-feat\"));\n102:     expect(result.command).toBe(\"tasks\");\n103:     expect(result.subcommand).toBe(\"show\");\n104:     expect(result.featureId).toBe(\"my-feat\");\n105:   });\n106: \n107:   test(\"parses tasks check\", () => {\n108:     const result = parseArgs(argv(\"tasks\", \"check\"));\n109:     expect(result.command).toBe(\"tasks\");\n110:     expect(result.subcommand).toBe(\"check\");\n111:   });\n112: \n113:   test(\"parses tasks archive with --dry-run\", () => {\n114:     const result = parseArgs(argv(\"tasks\", \"archive\", \"--dry-run\"));\n115:     expect(result.command).toBe(\"tasks\");\n116:     expect(result.subcommand).toBe(\"archive\");\n117:     expect(result.dryRun).toBe(true);\n118:   });\n119: \n120:   test(\"parses tasks graph with options\", () => {\n121:     const result = parseArgs(argv(\"tasks\", \"graph\", \"--ascii\", \"--subtasks\"));\n122:     expect(result.command).toBe(\"tasks\");\n123:     expect(result.subcommand).toBe(\"graph\");\n124:     expect(result.ascii).toBe(true);\n125:     expect(result.graphSubtasks).toBe(true);\n126:   });\n127: \n128:   test(\"features alias resolves to tasks command\", () => {\n129:     const result = parseArgs(argv(\"features\"));\n130:     expect(result.command).toBe(\"tasks\");\n131:     expect(result.subcommand).toBe(\"list\");\n132:   });\n133: \n134:   test(\"features alias with subcommand resolves correctly\", () => {\n135:     const result = parseArgs(argv(\"features\", \"add\", \"my-feat\", \"My Title\"));\n136:     expect(result.command).toBe(\"tasks\");\n137:     expect(result.subcommand).toBe(\"add\");\n138:     expect(result.featureId).toBe(\"my-feat\");\n139:     expect(result.title).toBe(\"My Title\");\n140:   });\n141: });\n142: \n143: // ---------------------------------------------------------------------------\n144: // Selection options (launch)\n145: // ---------------------------------------------------------------------------\n146: \n147: describe(\"parseArgs — selection options\", () => {\n148:   test(\"parses --top-priority N\", () => {\n149:     const result = parseArgs(argv(\"launch\", \"--top-priority\", \"3\"));\n150:     expect(result.topPriority).toBe(3);\n151:   });\n152: \n153:   test(\"parses --quickest-wins N\", () => {\n154:     const result = parseArgs(argv(\"launch\", \"--quickest-wins\", \"5\"));\n155:     expect(result.quickestWins).toBe(5);\n156:   });\n157: \n158:   test(\"parses --priority level\", () => {\n159:     const result = parseArgs(argv(\"launch\", \"--priority\", \"high\"));\n160:     expect(result.priority).toBe(\"high\");\n161:   });\n162: \n163:   test(\"parses --difficulty level\", () => {\n164:     const result = parseArgs(argv(\"launch\", \"--difficulty\", \"easy\"));\n165:     expect(result.difficulty).toBe(\"easy\");\n166:   });\n167: \n168:   test(\"parses --features as comma-separated list (stored in tasks)\", () => {\n169:     const result = parseArgs(argv(\"launch\", \"--features\", \"feat-a,feat-b,feat-c\"));\n170:     expect(result.tasks).toEqual([\"feat-a\", \"feat-b\", \"feat-c\"]);\n171:   });\n172: \n173:   test(\"parses --tasks as comma-separated list\", () => {\n174:     const result = parseArgs(argv(\"launch\", \"--tasks\", \"feat-a,feat-b,feat-c\"));\n175:     expect(result.tasks).toEqual([\"feat-a\", \"feat-b\", \"feat-c\"]);\n176:   });\n177: \n178:   test(\"trims whitespace in --features list\", () => {\n179:     const result = parseArgs(argv(\"launch\", \"--features\", \"feat-a, feat-b , feat-c\"));\n180:     expect(result.tasks).toEqual([\"feat-a\", \"feat-b\", \"feat-c\"]);\n181:   });\n182: \n183:   test(\"parses --all-ready boolean flag\", () => {\n184:     const result = parseArgs(argv(\"launch\", \"--all-ready\"));\n185:     expect(result.allReady).toBe(true);\n186:   });\n187: });\n188: \n189: // ---------------------------------------------------------------------------\n190: // Launch / runtime options\n191: // ---------------------------------------------------------------------------\n192: \n193: describe(\"parseArgs — runtime options\", () => {\n194:   test(\"parses --max-concurrent N\", () => {\n195:     const result = parseArgs(argv(\"launch\", \"--max-concurrent\", \"4\"));\n196:     expect(result.maxConcurrent).toBe(4);\n197:   });\n198: \n199:   test(\"parses --model\", () => {\n200:     const result = parseArgs(argv(\"launch\", \"--model\", \"anthropic/claude-sonnet-4-20250514\"));\n201:     expect(result.model).toBe(\"anthropic/claude-sonnet-4-20250514\");\n202:   });\n203: \n204:   test(\"parses -m as alias for --model\", () => {\n205:     const result = parseArgs(argv(\"launch\", \"-m\", \"gpt-4\"));\n206:     expect(result.model).toBe(\"gpt-4\");\n207:   });\n208: \n209:   test(\"parses --interactive boolean flag\", () => {\n210:     const result = parseArgs(argv(\"launch\", \"--interactive\"));\n211:     expect(result.interactive).toBe(true);\n212:   });\n213: \n214:   test(\"parses --dry-run boolean flag\", () => {\n215:     const result = parseArgs(argv(\"launch\", \"--dry-run\"));\n216:     expect(result.dryRun).toBe(true);\n217:   });\n218: \n219:   test(\"parses --no-tui boolean flag\", () => {\n220:     const result = parseArgs(argv(\"launch\", \"--no-tui\"));\n221:     expect(result.noTui).toBe(true);\n222:   });\n223: \n224:   test(\"parses --auto-push boolean flag\", () => {\n225:     const result = parseArgs(argv(\"launch\", \"--auto-push\"));\n226:     expect(result.autoPush).toBe(true);\n227:   });\n228: \n229:   test(\"parses --base-branch\", () => {\n230:     const result = parseArgs(argv(\"launch\", \"--base-branch\", \"develop\"));\n231:     expect(result.baseBranch).toBe(\"develop\");\n232:   });\n233: \n234:   test(\"parses --max-retries\", () => {\n235:     const result = parseArgs(argv(\"launch\", \"--max-retries\", \"5\"));\n236:     expect(result.maxRetries).toBe(5);\n237:   });\n238: });\n239: \n240: // ---------------------------------------------------------------------------\n241: // General flags\n242: // ---------------------------------------------------------------------------\n243: \n244: describe(\"parseArgs — general flags\", () => {\n245:   test(\"parses --force\", () => {\n246:     const result = parseArgs(argv(\"init\", \"--force\"));\n247:     expect(result.force).toBe(true);\n248:   });\n249: \n250:   test(\"parses --output json\", () => {\n251:     const result = parseArgs(argv(\"features\", \"list\", \"--output\", \"json\"));\n252:     expect(result.outputFmt).toBe(\"json\");\n253:   });\n254: \n255:   test(\"parses -o as alias for --output\", () => {\n256:     const result = parseArgs(argv(\"features\", \"list\", \"-o\", \"json\"));\n257:     expect(result.outputFmt).toBe(\"json\");\n258:   });\n259: \n260:   test(\"parses --check\", () => {\n261:     const result = parseArgs(argv(\"upgrade\", \"--check\"));\n262:     expect(result.checkOnly).toBe(true);\n263:   });\n264: });\n265: \n266: // ---------------------------------------------------------------------------\n267: // Default values\n268: // ---------------------------------------------------------------------------\n269: \n270: describe(\"parseArgs — default values\", () => {\n271:   test(\"interactive defaults to false\", () => {\n272:     const result = parseArgs(argv(\"launch\"));\n273:     expect(result.interactive).toBe(false);\n274:   });\n275: \n276:   test(\"dryRun defaults to false\", () => {\n277:     const result = parseArgs(argv(\"launch\"));\n278:     expect(result.dryRun).toBe(false);\n279:   });\n280: \n281:   test(\"noTui defaults to false\", () => {\n282:     const result = parseArgs(argv(\"launch\"));\n283:     expect(result.noTui).toBe(false);\n284:   });\n285: \n286:   test(\"autoPush defaults to false\", () => {\n287:     const result = parseArgs(argv(\"launch\"));\n288:     expect(result.autoPush).toBe(false);\n289:   });\n290: \n291:   test(\"force defaults to false\", () => {\n292:     const result = parseArgs(argv(\"init\"));\n293:     expect(result.force).toBe(false);\n294:   });\n295: \n296:   test(\"checkOnly defaults to false\", () => {\n297:     const result = parseArgs(argv(\"upgrade\"));\n298:     expect(result.checkOnly).toBe(false);\n299:   });\n300: \n301:   test(\"output format defaults to text\", () => {\n302:     const result = parseArgs(argv(\"features\", \"list\"));\n303:     expect(result.outputFmt).toBe(\"text\");\n304:   });\n305: });\n306: \n307: // ---------------------------------------------------------------------------\n308: // Edge cases: trailing flags, multiple flags, complex combinations\n309: // ---------------------------------------------------------------------------\n310: \n311: describe(\"parseArgs — edge cases\", () => {\n312:   test(\"handles multiple selection options combined\", () => {\n313:     const result = parseArgs(argv(\n314:       \"launch\",\n315:       \"--priority\", \"high\",\n316:       \"--max-concurrent\", \"2\",\n317:       \"--dry-run\",\n318:       \"--no-tui\"\n319:     ));\n320:     expect(result.command).toBe(\"launch\");\n321:     expect(result.priority).toBe(\"high\");\n322:     expect(result.maxConcurrent).toBe(2);\n323:     expect(result.dryRun).toBe(true);\n324:     expect(result.noTui).toBe(true);\n325:   });\n326: \n327:   test(\"handles positional args before flags\", () => {\n328:     const result = parseArgs(argv(\"retry\", \"my-feature\", \"--dry-run\"));\n329:     expect(result.command).toBe(\"retry\");\n330:     expect(result.featureId).toBe(\"my-feature\");\n331:     expect(result.dryRun).toBe(true);\n332:   });\n333: \n334:   test(\"handles tasks add with interleaved flags\", () => {\n335:     const result = parseArgs(argv(\n336:       \"tasks\", \"add\", \"new-feat\", \"New Feature\",\n337:       \"--priority\", \"critical\",\n338:       \"--difficulty\", \"hard\",\n339:       \"--effort\", \"P2D\",\n340:       \"--desc\", \"A detailed description\"\n341:     ));\n342:     expect(result.command).toBe(\"tasks\");\n343:     expect(result.subcommand).toBe(\"add\");\n344:     expect(result.featureId).toBe(\"new-feat\");\n345:     expect(result.title).toBe(\"New Feature\");\n346:     expect(result.priority).toBe(\"critical\");\n347:     expect(result.difficulty).toBe(\"hard\");\n348:     expect(result.effort).toBe(\"P2D\");\n349:     expect(result.description).toBe(\"A detailed description\");\n350:   });\n351: \n352:   test(\"handles --depends-on comma-separated list\", () => {\n353:     const result = parseArgs(argv(\n354:       \"features\", \"add\", \"new-feat\", \"New Feature\",\n355:       \"--depends-on\", \"feat-a,feat-b\"\n356:     ));\n357:     expect(result.dependsOn).toEqual([\"feat-a\", \"feat-b\"]);\n358:   });\n359: \n360:   test(\"handles --fields comma-separated list\", () => {\n361:     const result = parseArgs(argv(\n362:       \"features\", \"list\",\n363:       \"--fields\", \"id,status,priority\"\n364:     ));\n365:     expect(result.fields).toEqual([\"id\", \"status\", \"priority\"]);\n366:   });\n367: \n368:   test(\"unknown flags starting with -- are silently ignored\", () => {\n369:     const result = parseArgs(argv(\"launch\", \"--unknown-flag\", \"--dry-run\"));\n370:     expect(result.dryRun).toBe(true);\n371:     // Unknown flags don't crash, they're just ignored\n372:   });\n373: \n374:   test(\"unknown positional args after featureId and title are ignored\", () => {\n375:     const result = parseArgs(argv(\"features\", \"add\", \"id\", \"title\", \"extra-arg\"));\n376:     expect(result.featureId).toBe(\"id\");\n377:     expect(result.title).toBe(\"title\");\n378:   });\n379: \n380:   test(\"parses --status for features list filtering\", () => {\n381:     const result = parseArgs(argv(\"features\", \"list\", \"--status\", \"in_progress\"));\n382:     expect(result.status).toBe(\"in_progress\");\n383:   });\n384: \n385:   test(\"parses --ready for features list\", () => {\n386:     const result = parseArgs(argv(\"features\", \"list\", \"--ready\"));\n387:     expect(result.ready).toBe(true);\n388:   });\n389: \n390:   test(\"parses --include-archive for features list\", () => {\n391:     const result = parseArgs(argv(\"features\", \"list\", \"--include-archive\"));\n392:     expect(result.includeArchive).toBe(true);\n393:   });\n394: \n395:   test(\"parses --mermaid for features graph\", () => {\n396:     const result = parseArgs(argv(\"features\", \"graph\", \"--mermaid\"));\n397:     expect(result.mermaidRaw).toBe(true);\n398:   });\n399: \n400:   test(\"handles verify with optional feature ID\", () => {\n401:     const withId = parseArgs(argv(\"verify\", \"my-feature\"));\n402:     expect(withId.command).toBe(\"verify\");\n403:     expect(withId.featureId).toBe(\"my-feature\");\n404: \n405:     const withoutId = parseArgs(argv(\"verify\"));\n406:     expect(withoutId.command).toBe(\"verify\");\n407:     expect(withoutId.featureId).toBeUndefined();\n408:   });\n409: \n410:   test(\"handles merge with optional feature ID and flags\", () => {\n411:     const result = parseArgs(argv(\"merge\", \"my-feature\", \"--auto-push\", \"--dry-run\"));\n412:     expect(result.command).toBe(\"merge\");\n413:     expect(result.featureId).toBe(\"my-feature\");\n414:     expect(result.autoPush).toBe(true);\n415:     expect(result.dryRun).toBe(true);\n416:   });\n417: \n418:   test(\"NaN when --top-priority value is not a number\", () => {\n419:     const result = parseArgs(argv(\"launch\", \"--top-priority\", \"abc\"));\n420:     expect(result.topPriority).toBeNaN();\n421:   });\n422: \n423:   test(\"handles describe command with compound names\", () => {\n424:     const result = parseArgs(argv(\"describe\", \"features\", \"add\"));\n425:     expect(result.command).toBe(\"describe\");\n426:     expect(result.featureId).toBe(\"features\");\n427:     expect(result.title).toBe(\"add\");\n428:   });\n429: \n430:   test(\"handles upgrade with --tag flag\", () => {\n431:     const result = parseArgs(argv(\"upgrade\", \"--tag\", \"v0.1.0\"));\n432:     expect(result.command).toBe(\"upgrade\");\n433:     expect(result.tag).toBe(\"v0.1.0\");\n434:   });\n435: });\n436: \n437: // ---------------------------------------------------------------------------\n438: // Command alias resolution\n439: // ---------------------------------------------------------------------------\n440: \n441: describe(\"parseArgs — command aliases\", () => {\n442:   test(\"resolves 'i' to 'init'\", () => {\n443:     const result = parseArgs(argv(\"i\"));\n444:     expect(result.command).toBe(\"init\");\n445:   });\n446: \n447:   test(\"resolves 'l' to 'launch'\", () => {\n448:     const result = parseArgs(argv(\"l\"));\n449:     expect(result.command).toBe(\"launch\");\n450:   });\n451: \n452:   test(\"resolves 'r' to 'resume'\", () => {\n453:     const result = parseArgs(argv(\"r\"));\n454:     expect(result.command).toBe(\"resume\");\n455:   });\n456: \n457:   test(\"resolves 's' to 'status'\", () => {\n458:     const result = parseArgs(argv(\"s\"));\n459:     expect(result.command).toBe(\"status\");\n460:   });\n461: \n462:   test(\"resolves 'v' to 'verify'\", () => {\n463:     const result = parseArgs(argv(\"v\"));\n464:     expect(result.command).toBe(\"verify\");\n465:   });\n466: \n467:   test(\"resolves 'm' to 'merge'\", () => {\n468:     const result = parseArgs(argv(\"m\"));\n469:     expect(result.command).toBe(\"merge\");\n470:   });\n471: \n472:   test(\"resolves 're' to 'retry'\", () => {\n473:     const result = parseArgs(argv(\"re\"));\n474:     expect(result.command).toBe(\"retry\");\n475:   });\n476: \n477:   test(\"resolves 'a' to 'abort'\", () => {\n478:     const result = parseArgs(argv(\"a\"));\n479:     expect(result.command).toBe(\"abort\");\n480:   });\n481: \n482:   test(\"resolves 'c' to 'cleanup'\", () => {\n483:     const result = parseArgs(argv(\"c\"));\n484:     expect(result.command).toBe(\"cleanup\");\n485:   });\n486: \n487:   test(\"resolves 'h' to 'history'\", () => {\n488:     const result = parseArgs(argv(\"h\"));\n489:     expect(result.command).toBe(\"history\");\n490:   });\n491: \n492:   test(\"resolves 'lo' to 'logs'\", () => {\n493:     const result = parseArgs(argv(\"lo\"));\n494:     expect(result.command).toBe(\"logs\");\n495:   });\n496: \n497:   test(\"resolves 't' to 'tasks'\", () => {\n498:     const result = parseArgs(argv(\"t\"));\n499:     expect(result.command).toBe(\"tasks\");\n500:   });\n501: \n502:   test(\"resolves 'features' to 'tasks'\", () => {\n503:     const result = parseArgs(argv(\"features\"));\n504:     expect(result.command).toBe(\"tasks\");\n505:   });\n506: \n507:   test(\"resolves 'u' to 'upgrade'\", () => {\n508:     const result = parseArgs(argv(\"u\"));\n509:     expect(result.command).toBe(\"upgrade\");\n510:   });\n511: \n512:   test(\"resolves 'd' to 'describe'\", () => {\n513:     const result = parseArgs(argv(\"d\"));\n514:     expect(result.command).toBe(\"describe\");\n515:   });\n516: \n517:   test(\"resolves 'comp' to 'completion'\", () => {\n518:     const result = parseArgs(argv(\"comp\"));\n519:     expect(result.command).toBe(\"completion\");\n520:   });\n521: \n522:   test(\"unrecognized command passes through unchanged\", () => {\n523:     const result = parseArgs(argv(\"nonexistent-cmd\"));\n524:     expect(result.command).toBe(\"nonexistent-cmd\");\n525:   });\n526: \n527:   test(\"all COMMAND_ALIASES entries are consistent with parseArgs\", () => {\n528:     for (const [alias, canonical] of Object.entries(COMMAND_ALIASES)) {\n529:       const result = parseArgs(argv(alias));\n530:       expect(result.command).toBe(canonical);\n531:     }\n532:   });\n533: });\n534: \n535: // ---------------------------------------------------------------------------\n536: // Subcommand alias resolution\n537: // ---------------------------------------------------------------------------\n538: \n539: describe(\"parseArgs — subcommand aliases\", () => {\n540:   test(\"resolves 'ls' to 'list'\", () => {\n541:     const result = parseArgs(argv(\"tasks\", \"ls\"));\n542:     expect(result.subcommand).toBe(\"list\");\n543:   });\n544: \n545:   test(\"resolves 'a' to 'add'\", () => {\n546:     const result = parseArgs(argv(\"tasks\", \"a\", \"my-feat\", \"My Title\"));\n547:     expect(result.subcommand).toBe(\"add\");\n548:     expect(result.featureId).toBe(\"my-feat\");\n549:     expect(result.title).toBe(\"My Title\");\n550:   });\n551: \n552:   test(\"resolves 'ss' to 'set-status'\", () => {\n553:     const result = parseArgs(argv(\"tasks\", \"ss\", \"my-feat\", \"done\"));\n554:     expect(result.subcommand).toBe(\"set-status\");\n555:     expect(result.featureId).toBe(\"my-feat\");\n556:     expect(result.title).toBe(\"done\"); // second positional is stored as title\n557:   });\n558: \n559:   test(\"resolves 'sp' to 'set-priority'\", () => {\n560:     const result = parseArgs(argv(\"tasks\", \"sp\", \"my-feat\", \"high\"));\n561:     expect(result.subcommand).toBe(\"set-priority\");\n562:     expect(result.featureId).toBe(\"my-feat\");\n563:     expect(result.title).toBe(\"high\");\n564:   });\n565: \n566:   test(\"resolves 'sd' to 'set-difficulty'\", () => {\n567:     const result = parseArgs(argv(\"tasks\", \"sd\", \"my-feat\", \"hard\"));\n568:     expect(result.subcommand).toBe(\"set-difficulty\");\n569:     expect(result.featureId).toBe(\"my-feat\");\n570:     expect(result.title).toBe(\"hard\");\n571:   });\n572: \n573:   test(\"resolves 'ch' to 'check'\", () => {\n574:     const result = parseArgs(argv(\"tasks\", \"ch\"));\n575:     expect(result.subcommand).toBe(\"check\");\n576:   });\n577: \n578:   test(\"resolves 'validate' to 'check'\", () => {\n579:     const result = parseArgs(argv(\"tasks\", \"validate\"));\n580:     expect(result.subcommand).toBe(\"check\");\n581:   });\n582: \n583:   test(\"resolves 'ar' to 'archive'\", () => {\n584:     const result = parseArgs(argv(\"tasks\", \"ar\"));\n585:     expect(result.subcommand).toBe(\"archive\");\n586:   });\n587: \n588:   test(\"resolves 'sh' to 'show'\", () => {\n589:     const result = parseArgs(argv(\"tasks\", \"sh\", \"my-feat\"));\n590:     expect(result.subcommand).toBe(\"show\");\n591:     expect(result.featureId).toBe(\"my-feat\");\n592:   });\n593: \n594:   test(\"resolves 'g' to 'graph'\", () => {\n595:     const result = parseArgs(argv(\"tasks\", \"g\"));\n596:     expect(result.subcommand).toBe(\"graph\");\n597:   });\n598: \n599:   test(\"combined command alias + subcommand alias: 't ls'\", () => {\n600:     const result = parseArgs(argv(\"t\", \"ls\"));\n601:     expect(result.command).toBe(\"tasks\");\n602:     expect(result.subcommand).toBe(\"list\");\n603:   });\n604: \n605:   test(\"combined alias: 't a my-feat Title'\", () => {\n606:     const result = parseArgs(argv(\"t\", \"a\", \"my-feat\", \"Title\"));\n607:     expect(result.command).toBe(\"tasks\");\n608:     expect(result.subcommand).toBe(\"add\");\n609:     expect(result.featureId).toBe(\"my-feat\");\n610:     expect(result.title).toBe(\"Title\");\n611:   });\n612: \n613:   test(\"combined alias: 't ss my-feat done'\", () => {\n614:     const result = parseArgs(argv(\"t\", \"ss\", \"my-feat\", \"done\"));\n615:     expect(result.command).toBe(\"tasks\");\n616:     expect(result.subcommand).toBe(\"set-status\");\n617:     expect(result.featureId).toBe(\"my-feat\");\n618:   });\n619: \n620:   test(\"all SUBCOMMAND_ALIASES entries are consistent with parseArgs\", () => {\n621:     for (const [alias, canonical] of Object.entries(SUBCOMMAND_ALIASES)) {\n622:       const result = parseArgs(argv(\"tasks\", alias));\n623:       expect(result.subcommand).toBe(canonical);\n624:     }\n625:   });\n626: \n627:   test(\"unrecognized subcommand passes through unchanged\", () => {\n628:     const result = parseArgs(argv(\"tasks\", \"nonexistent\"));\n629:     expect(result.subcommand).toBe(\"nonexistent\");\n630:   });\n631: });\n632: \n633: // ---------------------------------------------------------------------------\n634: // Boolean flags should NOT consume next positional arg\n635: // ---------------------------------------------------------------------------\n636: \n637: describe(\"parseArgs — boolean flags do not consume next positional\", () => {\n638:   test(\"--dry-run before feature ID\", () => {\n639:     const result = parseArgs(argv(\"launch\", \"--dry-run\", \"--all-ready\"));\n640:     expect(result.dryRun).toBe(true);\n641:     expect(result.allReady).toBe(true);\n642:     // No positional args should be consumed\n643:     expect(result.featureId).toBeUndefined();\n644:   });\n645: \n646:   test(\"--all-ready followed by positional arg does not consume it\", () => {\n647:     // In launch context, positional after flags goes to featureId\n648:     const result = parseArgs(argv(\"launch\", \"--all-ready\", \"some-id\"));\n649:     expect(result.allReady).toBe(true);\n650:     expect(result.featureId).toBe(\"some-id\");\n651:   });\n652: \n653:   test(\"--force followed by positional arg does not consume it\", () => {\n654:     const result = parseArgs(argv(\"init\", \"--force\"));\n655:     expect(result.force).toBe(true);\n656:     expect(result.featureId).toBeUndefined();\n657:   });\n658: \n659:   test(\"--interactive followed by feature ID\", () => {\n660:     const result = parseArgs(argv(\"launch\", \"--interactive\", \"feat-1\"));\n661:     expect(result.interactive).toBe(true);\n662:     expect(result.featureId).toBe(\"feat-1\");\n663:   });\n664: \n665:   test(\"--no-tui followed by feature ID\", () => {\n666:     const result = parseArgs(argv(\"launch\", \"--no-tui\", \"feat-1\"));\n667:     expect(result.noTui).toBe(true);\n668:     expect(result.featureId).toBe(\"feat-1\");\n669:   });\n670: \n671:   test(\"--auto-push followed by feature ID\", () => {\n672:     const result = parseArgs(argv(\"merge\", \"--auto-push\", \"feat-1\"));\n673:     expect(result.autoPush).toBe(true);\n674:     expect(result.featureId).toBe(\"feat-1\");\n675:   });\n676: \n677:   test(\"--requeue followed by positional\", () => {\n678:     const result = parseArgs(argv(\"abort\", \"feat-1\", \"--requeue\"));\n679:     expect(result.requeue).toBe(true);\n680:     expect(result.featureId).toBe(\"feat-1\");\n681:   });\n682: \n683:   test(\"--check is boolean and does not consume next arg\", () => {\n684:     const result = parseArgs(argv(\"upgrade\", \"--check\", \"--force\"));\n685:     expect(result.checkOnly).toBe(true);\n686:     expect(result.force).toBe(true);\n687:   });\n688: \n689:   test(\"--ready is boolean and does not consume next arg\", () => {\n690:     const result = parseArgs(argv(\"tasks\", \"list\", \"--ready\", \"--status\", \"backlog\"));\n691:     expect(result.ready).toBe(true);\n692:     expect(result.status).toBe(\"backlog\");\n693:   });\n694: \n695:   test(\"--include-archive is boolean and does not consume next arg\", () => {\n696:     const result = parseArgs(argv(\"tasks\", \"list\", \"--include-archive\", \"--output\", \"json\"));\n697:     expect(result.includeArchive).toBe(true);\n698:     expect(result.outputFmt).toBe(\"json\");\n699:   });\n700: \n701:   test(\"--browser is boolean and does not consume next arg\", () => {\n702:     const result = parseArgs(argv(\"launch\", \"--browser\", \"--dry-run\"));\n703:     expect(result.browser).toBe(true);\n704:     expect(result.dryRun).toBe(true);\n705:   });\n706: \n707:   test(\"--follow is boolean and does not consume next arg\", () => {\n708:     const result = parseArgs(argv(\"logs\", \"feat-1\", \"--follow\"));\n709:     expect(result.follow).toBe(true);\n710:     expect(result.featureId).toBe(\"feat-1\");\n711:   });\n712: \n713:   test(\"-f is boolean and does not consume next arg\", () => {\n714:     const result = parseArgs(argv(\"logs\", \"feat-1\", \"-f\"));\n715:     expect(result.follow).toBe(true);\n716:     expect(result.featureId).toBe(\"feat-1\");\n717:   });\n718: \n719:   test(\"--ascii is boolean and does not consume next arg\", () => {\n720:     const result = parseArgs(argv(\"tasks\", \"graph\", \"--ascii\", \"--mermaid\"));\n721:     expect(result.ascii).toBe(true);\n722:     expect(result.mermaidRaw).toBe(true);\n723:   });\n724: \n725:   test(\"--mermaid is boolean and does not consume next arg\", () => {\n726:     const result = parseArgs(argv(\"tasks\", \"graph\", \"--mermaid\", \"--subtasks\"));\n727:     expect(result.mermaidRaw).toBe(true);\n728:     expect(result.graphSubtasks).toBe(true);\n729:   });\n730: });\n731: \n732: // ---------------------------------------------------------------------------\n733: // requireValue — trailing flags / missing values (graceful exit)\n734: // ---------------------------------------------------------------------------\n735: \n736: describe(\"parseArgs — trailing flags / missing values (requireValue)\", () => {\n737:   // requireValue calls process.exit(1), so we test via subprocess to verify\n738:   // the process exits rather than crashing with an unhandled exception.\n739:   // We use a small inline script that imports parseArgs and tries to parse.\n740: \n741:   /**\n742:    * Helper: run parseArgs in a subprocess with the given CLI args.\n743:    * Returns { exitCode, stderr }.\n744:    */\n745:   async function runParseInSubprocess(...cliArgs: string[]): Promise<{\n746:     exitCode: number;\n747:     stderr: string;\n748:     stdout: string;\n749:   }> {\n750:     const script = `\n751:       import { parseArgs } from \"./src/index.js\";\n752:       const result = parseArgs(${JSON.stringify([\"bun\", \"script.ts\", ...cliArgs])});\n753:       // If we get here, parseArgs didn't exit\n754:       console.log(JSON.stringify(result));\n755:     `;\n756:     const proc = Bun.spawn([\"bun\", \"-e\", script], {\n757:       cwd: import.meta.dir + \"/..\",\n758:       stdout: \"pipe\",\n759:       stderr: \"pipe\",\n760:     });\n761:     const [stdout, stderr] = await Promise.all([\n762:       new Response(proc.stdout).text(),\n763:       new Response(proc.stderr).text(),\n764:     ]);\n765:     const exitCode = await proc.exited;\n766:     return { exitCode, stderr, stdout };\n767:   }\n768: \n769:   test(\"--output as last arg (no value) exits with error\", async () => {\n770:     const { exitCode, stderr } = await runParseInSubprocess(\"launch\", \"--output\");\n771:     expect(exitCode).toBe(1);\n772:     expect(stderr).toContain(\"--output\");\n773:     expect(stderr).toContain(\"requires a value\");\n774:   });\n775: \n776:   test(\"-o as last arg (no value) exits with error\", async () => {\n777:     const { exitCode, stderr } = await runParseInSubprocess(\"launch\", \"-o\");\n778:     expect(exitCode).toBe(1);\n779:     expect(stderr).toContain(\"-o\");\n780:     expect(stderr).toContain(\"requires a value\");\n781:   });\n782: \n783:   test(\"--model as last arg (no value) exits with error\", async () => {\n784:     const { exitCode, stderr } = await runParseInSubprocess(\"launch\", \"--model\");\n785:     expect(exitCode).toBe(1);\n786:     expect(stderr).toContain(\"--model\");\n787:     expect(stderr).toContain(\"requires a value\");\n788:   });\n789: \n790:   test(\"-m as last arg (no value) exits with error\", async () => {\n791:     const { exitCode, stderr } = await runParseInSubprocess(\"launch\", \"-m\");\n792:     expect(exitCode).toBe(1);\n793:     expect(stderr).toContain(\"-m\");\n794:     expect(stderr).toContain(\"requires a value\");\n795:   });\n796: \n797:   test(\"--base-branch as last arg (no value) exits with error\", async () => {\n798:     const { exitCode, stderr } = await runParseInSubprocess(\"launch\", \"--base-branch\");\n799:     expect(exitCode).toBe(1);\n800:     expect(stderr).toContain(\"--base-branch\");\n801:     expect(stderr).toContain(\"requires a value\");\n802:   });\n803: \n804:   test(\"--top-priority as last arg (no value) exits with error\", async () => {\n805:     const { exitCode, stderr } = await runParseInSubprocess(\"launch\", \"--top-priority\");\n806:     expect(exitCode).toBe(1);\n807:     expect(stderr).toContain(\"--top-priority\");\n808:     expect(stderr).toContain(\"requires a value\");\n809:   });\n810: \n811:   test(\"--quickest-wins as last arg (no value) exits with error\", async () => {\n812:     const { exitCode, stderr } = await runParseInSubprocess(\"launch\", \"--quickest-wins\");\n813:     expect(exitCode).toBe(1);\n814:     expect(stderr).toContain(\"--quickest-wins\");\n815:     expect(stderr).toContain(\"requires a value\");\n816:   });\n817: \n818:   test(\"--priority as last arg (no value) exits with error\", async () => {\n819:     const { exitCode, stderr } = await runParseInSubprocess(\"launch\", \"--priority\");\n820:     expect(exitCode).toBe(1);\n821:     expect(stderr).toContain(\"--priority\");\n822:     expect(stderr).toContain(\"requires a value\");\n823:   });\n824: \n825:   test(\"--difficulty as last arg (no value) exits with error\", async () => {\n826:     const { exitCode, stderr } = await runParseInSubprocess(\"launch\", \"--difficulty\");\n827:     expect(exitCode).toBe(1);\n828:     expect(stderr).toContain(\"--difficulty\");\n829:     expect(stderr).toContain(\"requires a value\");\n830:   });\n831: \n832:   test(\"--tasks as last arg (no value) exits with error\", async () => {\n833:     const { exitCode, stderr } = await runParseInSubprocess(\"launch\", \"--tasks\");\n834:     expect(exitCode).toBe(1);\n835:     expect(stderr).toContain(\"--tasks\");\n836:     expect(stderr).toContain(\"requires a value\");\n837:   });\n838: \n839:   test(\"--max-concurrent as last arg (no value) exits with error\", async () => {\n840:     const { exitCode, stderr } = await runParseInSubprocess(\"launch\", \"--max-concurrent\");\n841:     expect(exitCode).toBe(1);\n842:     expect(stderr).toContain(\"--max-concurrent\");\n843:     expect(stderr).toContain(\"requires a value\");\n844:   });\n845: \n846:   test(\"--max-retries as last arg (no value) exits with error\", async () => {\n847:     const { exitCode, stderr } = await runParseInSubprocess(\"launch\", \"--max-retries\");\n848:     expect(exitCode).toBe(1);\n849:     expect(stderr).toContain(\"--max-retries\");\n850:     expect(stderr).toContain(\"requires a value\");\n851:   });\n852: \n853:   test(\"--tag as last arg (no value) exits with error\", async () => {\n854:     const { exitCode, stderr } = await runParseInSubprocess(\"upgrade\", \"--tag\");\n855:     expect(exitCode).toBe(1);\n856:     expect(stderr).toContain(\"--tag\");\n857:     expect(stderr).toContain(\"requires a value\");\n858:   });\n859: \n860:   test(\"--release as last arg (no value) exits with error\", async () => {\n861:     const { exitCode, stderr } = await runParseInSubprocess(\"upgrade\", \"--release\");\n862:     expect(exitCode).toBe(1);\n863:     expect(stderr).toContain(\"--release\");\n864:     expect(stderr).toContain(\"requires a value\");\n865:   });\n866: \n867:   test(\"--status as last arg (no value) exits with error\", async () => {\n868:     const { exitCode, stderr } = await runParseInSubprocess(\"tasks\", \"list\", \"--status\");\n869:     expect(exitCode).toBe(1);\n870:     expect(stderr).toContain(\"--status\");\n871:     expect(stderr).toContain(\"requires a value\");\n872:   });\n873: \n874:   test(\"--title as last arg (no value) exits with error\", async () => {\n875:     const { exitCode, stderr } = await runParseInSubprocess(\"tasks\", \"add\", \"id\", \"--title\");\n876:     expect(exitCode).toBe(1);\n877:     expect(stderr).toContain(\"--title\");\n878:     expect(stderr).toContain(\"requires a value\");\n879:   });\n880: \n881:   test(\"--description as last arg (no value) exits with error\", async () => {\n882:     const { exitCode, stderr } = await runParseInSubprocess(\"tasks\", \"add\", \"id\", \"Title\", \"--description\");\n883:     expect(exitCode).toBe(1);\n884:     expect(stderr).toContain(\"--description\");\n885:     expect(stderr).toContain(\"requires a value\");\n886:   });\n887: \n888:   test(\"--desc as last arg (no value) exits with error\", async () => {\n889:     const { exitCode, stderr } = await runParseInSubprocess(\"tasks\", \"add\", \"id\", \"Title\", \"--desc\");\n890:     expect(exitCode).toBe(1);\n891:     expect(stderr).toContain(\"--desc\");\n892:     expect(stderr).toContain(\"requires a value\");\n893:   });\n894: \n895:   test(\"--effort as last arg (no value) exits with error\", async () => {\n896:     const { exitCode, stderr } = await runParseInSubprocess(\"tasks\", \"add\", \"id\", \"Title\", \"--effort\");\n897:     expect(exitCode).toBe(1);\n898:     expect(stderr).toContain(\"--effort\");\n899:     expect(stderr).toContain(\"requires a value\");\n900:   });\n901: \n902:   test(\"--depends-on as last arg (no value) exits with error\", async () => {\n903:     const { exitCode, stderr } = await runParseInSubprocess(\"tasks\", \"add\", \"id\", \"Title\", \"--depends-on\");\n904:     expect(exitCode).toBe(1);\n905:     expect(stderr).toContain(\"--depends-on\");\n906:     expect(stderr).toContain(\"requires a value\");\n907:   });\n908: \n909:   test(\"--fields as last arg (no value) exits with error\", async () => {\n910:     const { exitCode, stderr } = await runParseInSubprocess(\"tasks\", \"list\", \"--fields\");\n911:     expect(exitCode).toBe(1);\n912:     expect(stderr).toContain(\"--fields\");\n913:     expect(stderr).toContain(\"requires a value\");\n914:   });\n915: \n916:   test(\"--tail as last arg (no value) exits with error\", async () => {\n917:     const { exitCode, stderr } = await runParseInSubprocess(\"logs\", \"feat-1\", \"--tail\");\n918:     expect(exitCode).toBe(1);\n919:     expect(stderr).toContain(\"--tail\");\n920:     expect(stderr).toContain(\"requires a value\");\n921:   });\n922: \n923:   test(\"valid flags parse correctly (no false positive exits)\", async () => {\n924:     const { exitCode, stdout } = await runParseInSubprocess(\n925:       \"launch\", \"--output\", \"json\", \"--model\", \"gpt-4\", \"--top-priority\", \"3\"\n926:     );\n927:     expect(exitCode).toBe(0);\n928:     const result = JSON.parse(stdout.trim().split(\"\\n\").pop()!);\n929:     expect(result.outputFmt).toBe(\"json\");\n930:     expect(result.model).toBe(\"gpt-4\");\n931:     expect(result.topPriority).toBe(3);\n932:   });\n933: });\n934: \n935: // ---------------------------------------------------------------------------\n936: // Unknown flags behavior\n937: // ---------------------------------------------------------------------------\n938: \n939: describe(\"parseArgs — unknown flags\", () => {\n940:   test(\"unknown -- flag is silently ignored and does not crash\", () => {\n941:     const result = parseArgs(argv(\"launch\", \"--unknown-flag\"));\n942:     expect(result.command).toBe(\"launch\");\n943:     // No crash, no undefined property errors\n944:   });\n945: \n946:   test(\"unknown -- flag does not affect other flags\", () => {\n947:     const result = parseArgs(argv(\"launch\", \"--unknown\", \"--dry-run\", \"--force\"));\n948:     expect(result.dryRun).toBe(true);\n949:     expect(result.force).toBe(true);\n950:   });\n951: \n952:   test(\"multiple unknown flags are all silently ignored\", () => {\n953:     const result = parseArgs(argv(\"launch\", \"--foo\", \"--bar\", \"--baz\", \"--dry-run\"));\n954:     expect(result.dryRun).toBe(true);\n955:   });\n956: \n957:   test(\"unknown flags between known flags don't interfere\", () => {\n958:     const result = parseArgs(argv(\n959:       \"launch\",\n960:       \"--priority\", \"high\",\n961:       \"--verbose\",  // unknown\n962:       \"--max-concurrent\", \"3\"\n963:     ));\n964:     expect(result.priority).toBe(\"high\");\n965:     expect(result.maxConcurrent).toBe(3);\n966:   });\n967: \n968:   test(\"unknown flag that looks like it takes a value: value becomes positional\", () => {\n969:     // --unknown-with-value is not recognized, so \"some-value\" becomes a positional\n970:     const result = parseArgs(argv(\"launch\", \"--unknown-with-value\", \"some-value\"));\n971:     expect(result.featureId).toBe(\"some-value\");\n972:   });\n973: \n974:   test(\"unknown single-dash flag is treated as unrecognized\", () => {\n975:     // -z is not a recognized short flag, falls through to default\n976:     const result = parseArgs(argv(\"launch\", \"-z\"));\n977:     // Should not crash; -z starts with \"-\" so it's not captured as positional either\n978:     expect(result.command).toBe(\"launch\");\n979:   });\n980: });\n981: \n982: // ---------------------------------------------------------------------------\n983: // Flag collisions / version flag handling\n984: // ---------------------------------------------------------------------------\n985: \n986: describe(\"parseArgs — flag collisions and version handling\", () => {\n987:   test(\"-v as command resolves to 'verify' (not 'version')\", () => {\n988:     // In COMMAND_ALIASES, v → verify. Version is 'version' or '-V'\n989:     const result = parseArgs(argv(\"v\"));\n990:     expect(result.command).toBe(\"verify\");\n991:   });\n992: \n993:   test(\"-V as command does not resolve (not in aliases)\", () => {\n994:     const result = parseArgs(argv(\"-V\"));\n995:     expect(result.command).toBe(\"-V\");\n996:     // main() handles -V specially, but parseArgs just passes it through\n997:   });\n998: \n999:   test(\"'version' command is passed through (not aliased)\", () => {\n1000:     const result = parseArgs(argv(\"version\"));\n1001:     expect(result.command).toBe(\"version\");\n1002:   });\n1003: \n1004:   test(\"-v and 'version' produce different commands\", () => {\n1005:     const vResult = parseArgs(argv(\"v\"));\n1006:     const versionResult = parseArgs(argv(\"version\"));\n1007:     expect(vResult.command).not.toBe(versionResult.command);\n1008:     expect(vResult.command).toBe(\"verify\");\n1009:     expect(versionResult.command).toBe(\"version\");\n1010:   });\n1011: \n1012:   test(\"--release is alias for --tag\", () => {\n1013:     const tagResult = parseArgs(argv(\"upgrade\", \"--tag\", \"v1.0\"));\n1014:     const releaseResult = parseArgs(argv(\"upgrade\", \"--release\", \"v1.0\"));\n1015:     expect(tagResult.tag).toBe(\"v1.0\");\n1016:     expect(releaseResult.tag).toBe(\"v1.0\");\n1017:   });\n1018: \n1019:   test(\"--desc is alias for --description\", () => {\n1020:     const descResult = parseArgs(argv(\"tasks\", \"add\", \"id\", \"title\", \"--desc\", \"hello\"));\n1021:     const descriptionResult = parseArgs(argv(\"tasks\", \"add\", \"id\", \"title\", \"--description\", \"hello\"));\n1022:     expect(descResult.description).toBe(\"hello\");\n1023:     expect(descriptionResult.description).toBe(\"hello\");\n1024:   });\n1025: \n1026:   test(\"-o is alias for --output\", () => {\n1027:     const oResult = parseArgs(argv(\"tasks\", \"list\", \"-o\", \"json\"));\n1028:     const outputResult = parseArgs(argv(\"tasks\", \"list\", \"--output\", \"json\"));\n1029:     expect(oResult.outputFmt).toBe(\"json\");\n1030:     expect(outputResult.outputFmt).toBe(\"json\");\n1031:   });\n1032: \n1033:   test(\"-m is alias for --model\", () => {\n1034:     const mResult = parseArgs(argv(\"launch\", \"-m\", \"gpt-4\"));\n1035:     const modelResult = parseArgs(argv(\"launch\", \"--model\", \"gpt-4\"));\n1036:     expect(mResult.model).toBe(\"gpt-4\");\n1037:     expect(modelResult.model).toBe(\"gpt-4\");\n1038:   });\n1039: });\n1040: \n1041: // ---------------------------------------------------------------------------\n1042: // Repeated and overriding flags\n1043: // ---------------------------------------------------------------------------\n1044: \n1045: describe(\"parseArgs — repeated flags\", () => {\n1046:   test(\"last value wins when a value flag is repeated\", () => {\n1047:     const result = parseArgs(argv(\n1048:       \"launch\", \"--priority\", \"low\", \"--priority\", \"critical\"\n1049:     ));\n1050:     expect(result.priority).toBe(\"critical\");\n1051:   });\n1052: \n1053:   test(\"last value wins for --model\", () => {\n1054:     const result = parseArgs(argv(\n1055:       \"launch\", \"--model\", \"gpt-3\", \"--model\", \"gpt-4\"\n1056:     ));\n1057:     expect(result.model).toBe(\"gpt-4\");\n1058:   });\n1059: \n1060:   test(\"repeated boolean flags remain true\", () => {\n1061:     const result = parseArgs(argv(\"launch\", \"--dry-run\", \"--dry-run\"));\n1062:     expect(result.dryRun).toBe(true);\n1063:   });\n1064: \n1065:   test(\"--output text overrides default\", () => {\n1066:     const result = parseArgs(argv(\"tasks\", \"list\", \"--output\", \"text\"));\n1067:     expect(result.outputFmt).toBe(\"text\");\n1068:   });\n1069: \n1070:   test(\"--output json then --output text: last wins\", () => {\n1071:     const result = parseArgs(argv(\"tasks\", \"list\", \"--output\", \"json\", \"--output\", \"text\"));\n1072:     expect(result.outputFmt).toBe(\"text\");\n1073:   });\n1074: });\n1075: \n1076: // ---------------------------------------------------------------------------\n1077: // Positional argument assignment\n1078: // ---------------------------------------------------------------------------\n1079: \n1080: describe(\"parseArgs — positional arguments\", () => {\n1081:   test(\"first positional after command goes to featureId\", () => {\n1082:     const result = parseArgs(argv(\"verify\", \"my-feature\"));\n1083:     expect(result.featureId).toBe(\"my-feature\");\n1084:   });\n1085: \n1086:   test(\"second positional after command goes to title\", () => {\n1087:     const result = parseArgs(argv(\"tasks\", \"add\", \"feat-id\", \"Feature Title\"));\n1088:     expect(result.featureId).toBe(\"feat-id\");\n1089:     expect(result.title).toBe(\"Feature Title\");\n1090:   });\n1091: \n1092:   test(\"third and subsequent positionals are ignored\", () => {\n1093:     const result = parseArgs(argv(\"tasks\", \"add\", \"id\", \"title\", \"extra1\", \"extra2\"));\n1094:     expect(result.featureId).toBe(\"id\");\n1095:     expect(result.title).toBe(\"title\");\n1096:     // extra1 and extra2 are silently dropped\n1097:   });\n1098: \n1099:   test(\"positional after boolean flag is not consumed by the flag\", () => {\n1100:     const result = parseArgs(argv(\"retry\", \"--dry-run\", \"feat-1\"));\n1101:     expect(result.dryRun).toBe(true);\n1102:     expect(result.featureId).toBe(\"feat-1\");\n1103:   });\n1104: \n1105:   test(\"no positionals means featureId and title are undefined\", () => {\n1106:     const result = parseArgs(argv(\"launch\"));\n1107:     expect(result.featureId).toBeUndefined();\n1108:     expect(result.title).toBeUndefined();\n1109:   });\n1110: \n1111:   test(\"tasks subcommand: positional after subcommand\", () => {\n1112:     const result = parseArgs(argv(\"tasks\", \"show\", \"feat-id\"));\n1113:     expect(result.featureId).toBe(\"feat-id\");\n1114:   });\n1115: \n1116:   test(\"tasks subcommand: two positionals after subcommand\", () => {\n1117:     const result = parseArgs(argv(\"tasks\", \"set-status\", \"feat-id\", \"done\"));\n1118:     expect(result.featureId).toBe(\"feat-id\");\n1119:     expect(result.title).toBe(\"done\"); // second positional goes to title\n1120:   });\n1121: });\n1122: \n1123: // ---------------------------------------------------------------------------\n1124: // Tasks subcommand with no subcommand specified\n1125: // ---------------------------------------------------------------------------\n1126: \n1127: describe(\"parseArgs — tasks subcommand defaults\", () => {\n1128:   test(\"tasks with no subcommand defaults to list\", () => {\n1129:     const result = parseArgs(argv(\"tasks\"));\n1130:     expect(result.subcommand).toBe(\"list\");\n1131:   });\n1132: \n1133:   test(\"tasks with only flags defaults subcommand to list\", () => {\n1134:     // --status is after the subcommand position, but since the first\n1135:     // arg starts with --, it gets treated as a flag not a subcommand\n1136:     // Actually, --status would be treated as subcommand value then parsed\n1137:     const result = parseArgs(argv(\"tasks\", \"--status\", \"backlog\"));\n1138:     // The second argv element is \"--status\", which becomes the subcommand\n1139:     // (since parseArgs does args[1] || \"list\" for tasks subcommand).\n1140:     // This is a known quirk: \"--status\" becomes the subcommand string.\n1141:     expect(result.subcommand).toBe(\"--status\");\n1142:   });\n1143: });\n1144: \n1145: // ---------------------------------------------------------------------------\n1146: // Logs options\n1147: // ---------------------------------------------------------------------------\n1148: \n1149: describe(\"parseArgs — logs options\", () => {\n1150:   test(\"parses --tail with value\", () => {\n1151:     const result = parseArgs(argv(\"logs\", \"feat-1\", \"--tail\", \"50\"));\n1152:     expect(result.tail).toBe(50);\n1153:     expect(result.featureId).toBe(\"feat-1\");\n1154:   });\n1155: \n1156:   test(\"parses --follow\", () => {\n1157:     const result = parseArgs(argv(\"logs\", \"feat-1\", \"--follow\"));\n1158:     expect(result.follow).toBe(true);\n1159:   });\n1160: \n1161:   test(\"parses -f as alias for --follow\", () => {\n1162:     const result = parseArgs(argv(\"logs\", \"feat-1\", \"-f\"));\n1163:     expect(result.follow).toBe(true);\n1164:   });\n1165: \n1166:   test(\"parses all logs options together\", () => {\n1167:     const result = parseArgs(argv(\"logs\", \"feat-1\", \"--tail\", \"100\", \"--follow\", \"--output\", \"json\"));\n1168:     expect(result.featureId).toBe(\"feat-1\");\n1169:     expect(result.tail).toBe(100);\n1170:     expect(result.follow).toBe(true);\n1171:     expect(result.outputFmt).toBe(\"json\");\n1172:   });\n1173: });\n1174: \n1175: // ---------------------------------------------------------------------------\n1176: // Abort options\n1177: // ---------------------------------------------------------------------------\n1178: \n1179: describe(\"parseArgs — abort options\", () => {\n1180:   test(\"parses abort with feature ID and --requeue\", () => {\n1181:     const result = parseArgs(argv(\"abort\", \"feat-1\", \"--requeue\"));\n1182:     expect(result.command).toBe(\"abort\");\n1183:     expect(result.featureId).toBe(\"feat-1\");\n1184:     expect(result.requeue).toBe(true);\n1185:   });\n1186: \n1187:   test(\"parses abort with --output json\", () => {\n1188:     const result = parseArgs(argv(\"abort\", \"feat-1\", \"--output\", \"json\"));\n1189:     expect(result.command).toBe(\"abort\");\n1190:     expect(result.featureId).toBe(\"feat-1\");\n1191:     expect(result.outputFmt).toBe(\"json\");\n1192:   });\n1193: \n1194:   test(\"abort alias 'a' works\", () => {\n1195:     const result = parseArgs(argv(\"a\", \"feat-1\", \"--requeue\"));\n1196:     expect(result.command).toBe(\"abort\");\n1197:     expect(result.featureId).toBe(\"feat-1\");\n1198:     expect(result.requeue).toBe(true);\n1199:   });\n1200: });\n1201: \n1202: // ---------------------------------------------------------------------------\n1203: // Complete real-world CLI examples from help text\n1204: // ---------------------------------------------------------------------------\n1205: \n1206: describe(\"parseArgs — real-world CLI examples\", () => {\n1207:   test(\"woco launch --quickest-wins 3\", () => {\n1208:     const result = parseArgs(argv(\"launch\", \"--quickest-wins\", \"3\"));\n1209:     expect(result.command).toBe(\"launch\");\n1210:     expect(result.quickestWins).toBe(3);\n1211:   });\n1212: \n1213:   test(\"woco launch --priority high --interactive\", () => {\n1214:     const result = parseArgs(argv(\"launch\", \"--priority\", \"high\", \"--interactive\"));\n1215:     expect(result.command).toBe(\"launch\");\n1216:     expect(result.priority).toBe(\"high\");\n1217:     expect(result.interactive).toBe(true);\n1218:   });\n1219: \n1220:   test(\"woco launch --tasks 'auth-flow,search-api' --max-concurrent 2\", () => {\n1221:     const result = parseArgs(argv(\"launch\", \"--tasks\", \"auth-flow,search-api\", \"--max-concurrent\", \"2\"));\n1222:     expect(result.command).toBe(\"launch\");\n1223:     expect(result.tasks).toEqual([\"auth-flow\", \"search-api\"]);\n1224:     expect(result.maxConcurrent).toBe(2);\n1225:   });\n1226: \n1227:   test(\"woco tasks list --status ready --priority high\", () => {\n1228:     const result = parseArgs(argv(\"tasks\", \"list\", \"--status\", \"ready\", \"--priority\", \"high\"));\n1229:     expect(result.command).toBe(\"tasks\");\n1230:     expect(result.subcommand).toBe(\"list\");\n1231:     expect(result.status).toBe(\"ready\");\n1232:     expect(result.priority).toBe(\"high\");\n1233:   });\n1234: \n1235:   test(\"woco tasks list --fields id,status,priority --output json\", () => {\n1236:     const result = parseArgs(argv(\"tasks\", \"list\", \"--fields\", \"id,status,priority\", \"--output\", \"json\"));\n1237:     expect(result.fields).toEqual([\"id\", \"status\", \"priority\"]);\n1238:     expect(result.outputFmt).toBe(\"json\");\n1239:   });\n1240: \n1241:   test(\"woco tasks add my-task 'My Cool Task' --priority high --difficulty easy\", () => {\n1242:     const result = parseArgs(argv(\"tasks\", \"add\", \"my-task\", \"My Cool Task\", \"--priority\", \"high\", \"--difficulty\", \"easy\"));\n1243:     expect(result.subcommand).toBe(\"add\");\n1244:     expect(result.featureId).toBe(\"my-task\");\n1245:     expect(result.title).toBe(\"My Cool Task\");\n1246:     expect(result.priority).toBe(\"high\");\n1247:     expect(result.difficulty).toBe(\"easy\");\n1248:   });\n1249: \n1250:   test(\"woco logs feat --tail 50 --follow\", () => {\n1251:     const result = parseArgs(argv(\"logs\", \"feat\", \"--tail\", \"50\", \"--follow\"));\n1252:     expect(result.command).toBe(\"logs\");\n1253:     expect(result.featureId).toBe(\"feat\");\n1254:     expect(result.tail).toBe(50);\n1255:     expect(result.follow).toBe(true);\n1256:   });\n1257: \n1258:   test(\"woco history wave-2026-03-12-420\", () => {\n1259:     const result = parseArgs(argv(\"history\", \"wave-2026-03-12-420\"));\n1260:     expect(result.command).toBe(\"history\");\n1261:     expect(result.featureId).toBe(\"wave-2026-03-12-420\");\n1262:   });\n1263: \n1264:   test(\"woco launch with all options combined\", () => {\n1265:     const result = parseArgs(argv(\n1266:       \"launch\",\n1267:       \"--top-priority\", \"5\",\n1268:       \"--max-concurrent\", \"4\",\n1269:       \"--model\", \"anthropic/claude-sonnet-4-20250514\",\n1270:       \"--interactive\",\n1271:       \"--dry-run\",\n1272:       \"--no-tui\",\n1273:       \"--auto-push\",\n1274:       \"--base-branch\", \"develop\",\n1275:       \"--max-retries\", \"3\",\n1276:       \"--browser\",\n1277:       \"--output\", \"json\"\n1278:     ));\n1279:     expect(result.command).toBe(\"launch\");\n1280:     expect(result.topPriority).toBe(5);\n1281:     expect(result.maxConcurrent).toBe(4);\n1282:     expect(result.model).toBe(\"anthropic/claude-sonnet-4-20250514\");\n1283:     expect(result.interactive).toBe(true);\n1284:     expect(result.dryRun).toBe(true);\n1285:     expect(result.noTui).toBe(true);\n1286:     expect(result.autoPush).toBe(true);\n1287:     expect(result.baseBranch).toBe(\"develop\");\n1288:     expect(result.maxRetries).toBe(3);\n1289:     expect(result.browser).toBe(true);\n1290:     expect(result.outputFmt).toBe(\"json\");\n1291:   });\n1292: });\n\n(End of file - total 1292 lines)\n</content>","title":"tests/arg-parsing.test.ts","metadata":{"preview":"/**\n * arg-parsing.test.ts — Unit tests for CLI argument parsing.\n *\n * Coverage:\n *   - Basic command parsing\n *   - Tasks subcommand routing (with \"features\" backward-compat alias)\n *   - Command & subcommand alias resolution\n *   - Flag parsing (boolean flags, value flags)\n *   - Trailing flags / missing values (requireValue behavior)\n *   - Boolean flags not consuming next positional arg\n *   - Flag collisions (-v version vs commands)\n *   - Unknown flags behavior\n *   - Positional argument handling (featureId, title)\n *   - Edge cases: empty args, repeated flags, OOB access\n */\n\nimport { describe, test, expect } from \"bun:test\";\nimport { parseArgs, COMMAND_ALIASES, SUBCOMMAND_ALIASES } from \"../src/index.js\";\n\n// Helper to simulate argv from CLI input. We need to prepend \"bun\" and \"script\"","truncated":false,"loaded":[]},"time":{"start":1773435844655,"end":1773435844661}}}}
{"type":"tool_use","timestamp":1773435845165,"sessionID":"ses_316fcc12bffeSBLLi3jBrbT2M4","part":{"id":"prt_ce9037895001SNsqDXAm0Vp7fL","sessionID":"ses_316fcc12bffeSBLLi3jBrbT2M4","messageID":"msg_ce9036b1f001WQ3dj9eBiOriAQ","type":"tool","callID":"toolu_vrtx_014XDzApiJVE5t96icnHHZGn","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-unit-test-suite/tests/features.test.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-unit-test-suite/tests/features.test.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * features.test.ts — Unit tests for tasks YAML parsing, validation,\n3:  * duration parsing, and dependency resolution.\n4:  *\n5:  * Coverage:\n6:  *   - loadFeatures with null tasks, empty arrays, valid data\n7:  *   - parseDurationMinutes for ISO 8601 durations\n8:  *   - formatDuration for human-readable output\n9:  *   - Dependency resolution (areDependenciesMet, getReadyFeatures)\n10:  *   - normalizeTask defaults\n11:  *   - createBlankFeature\n12:  *   - findFeatureById (recursive search)\n13:  *   - selectFeatures strategies\n14:  *   - YAML schema edge cases\n15:  */\n16: \n17: import { describe, test, expect, beforeEach, afterEach } from \"bun:test\";\n18: import { mkdtempSync, writeFileSync, rmSync, mkdirSync } from \"node:fs\";\n19: import { join } from \"node:path\";\n20: import { tmpdir } from \"node:os\";\n21: import type { WomboConfig } from \"../src/config.js\";\n22: import {\n23:   loadFeatures,\n24:   parseDurationMinutes,\n25:   formatDuration,\n26:   areDependenciesMet,\n27:   getReadyFeatures,\n28:   getDoneFeatureIds,\n29:   selectFeatures,\n30:   createBlankFeature,\n31:   findFeatureById,\n32:   allFeatureIds,\n33:   featureSummary,\n34:   PRIORITY_ORDER,\n35:   DIFFICULTY_ORDER,\n36: } from \"../src/lib/tasks.js\";\n37: import type {\n38:   Feature,\n39:   FeaturesFile,\n40:   Subtask,\n41:   Priority,\n42:   Difficulty,\n43: } from \"../src/lib/tasks.js\";\n44: \n45: // ---------------------------------------------------------------------------\n46: // Helpers\n47: // ---------------------------------------------------------------------------\n48: \n49: function makeConfig(overrides?: Partial<WomboConfig>): WomboConfig {\n50:   return {\n51:     tasksDir: \"tasks\",\n52:     archiveDir: \"archive\",\n53:     baseBranch: \"main\",\n54:     build: { command: \"bun run build\", timeout: 300_000, artifactDir: \"dist\" },\n55:     install: { command: \"bun install\", timeout: 120_000 },\n56:     git: {\n57:       branchPrefix: \"feature/\",\n58:       worktreePrefix: \"wombo-\",\n59:       remote: \"origin\",\n60:       mergeStrategy: \"--no-ff\",\n61:     },\n62:     agent: {\n63:       bin: null,\n64:       name: \"generalist-agent\",\n65:       configFiles: [],\n66:       tmuxPrefix: \"wombo\",\n67:       multiplexer: \"auto\",\n68:     },\n69:     portless: {\n70:       enabled: true,\n71:       bin: null,\n72:       proxyPort: 1355,\n73:       https: false,\n74:     },\n75:     backup: { maxBackups: 5 },\n76:     defaults: { maxConcurrent: 6, maxRetries: 2 },\n77:     browser: {\n78:       enabled: false,\n79:       bin: null,\n80:       headless: true,\n81:       testCommand: null,\n82:       launchTimeout: 30_000,\n83:       testTimeout: 60_000,\n84:       defaultViewport: { width: 1280, height: 720 },\n85:     },\n86:     agentRegistry: {\n87:       mode: \"auto\",\n88:       source: \"msitarzewski/agency-agents\",\n89:       cacheDir: \"agents-cache\",\n90:     },\n91:     ...overrides,\n92:   };\n93: }\n94: \n95: function makeFeature(overrides?: Partial<Feature>): Feature {\n96:   return {\n97:     id: \"test-feature\",\n98:     title: \"Test Feature\",\n99:     description: \"A test feature\",\n100:     status: \"backlog\",\n101:     completion: 0,\n102:     difficulty: \"medium\",\n103:     priority: \"medium\",\n104:     depends_on: [],\n105:     effort: \"PT1H\",\n106:     started_at: null,\n107:     ended_at: null,\n108:     constraints: [],\n109:     forbidden: [],\n110:     references: [],\n111:     notes: [],\n112:     subtasks: [],\n113:     ...overrides,\n114:   };\n115: }\n116: \n117: function makeFeaturesFile(\n118:   tasks: Feature[] = [],\n119:   archive: Feature[] = []\n120: ): FeaturesFile {\n121:   return {\n122:     version: \"1\",\n123:     meta: {\n124:       created_at: \"2025-01-01T00:00:00Z\",\n125:       updated_at: \"2025-01-01T00:00:00Z\",\n126:       project: \"test-project\",\n127:       generator: \"test\",\n128:       maintainer: \"tester\",\n129:     },\n130:     tasks,\n131:     archive,\n132:   };\n133: }\n134: \n135: /**\n136:  * Write a YAML string to the .wombo-combo/tasks.yml inside the given tmpDir.\n137:  * Also creates the .wombo-combo directory.\n138:  */\n139: function writeTasksYaml(dir: string, yaml: string): void {\n140:   mkdirSync(join(dir, \".wombo-combo\"), { recursive: true });\n141:   writeFileSync(join(dir, \".wombo-combo\", \"tasks.yml\"), yaml);\n142: }\n143: \n144: /**\n145:  * Write archive YAML to .wombo-combo/archive.yml.\n146:  */\n147: function writeArchiveYaml(dir: string, yaml: string): void {\n148:   mkdirSync(join(dir, \".wombo-combo\"), { recursive: true });\n149:   writeFileSync(join(dir, \".wombo-combo\", \"archive.yml\"), yaml);\n150: }\n151: \n152: let tmpDir: string;\n153: \n154: beforeEach(() => {\n155:   tmpDir = mkdtempSync(join(tmpdir(), \"wombo-test-features-\"));\n156: });\n157: \n158: afterEach(() => {\n159:   rmSync(tmpDir, { recursive: true, force: true });\n160: });\n161: \n162: // ---------------------------------------------------------------------------\n163: // ISO 8601 Duration Parsing\n164: // ---------------------------------------------------------------------------\n165: \n166: describe(\"parseDurationMinutes\", () => {\n167:   test(\"parses hours only\", () => {\n168:     expect(parseDurationMinutes(\"PT1H\")).toBe(60);\n169:     expect(parseDurationMinutes(\"PT2H\")).toBe(120);\n170:     expect(parseDurationMinutes(\"PT0H\")).toBe(0);\n171:   });\n172: \n173:   test(\"parses minutes only\", () => {\n174:     expect(parseDurationMinutes(\"PT30M\")).toBe(30);\n175:     expect(parseDurationMinutes(\"PT1M\")).toBe(1);\n176:     expect(parseDurationMinutes(\"PT90M\")).toBe(90);\n177:   });\n178: \n179:   test(\"parses days only\", () => {\n180:     expect(parseDurationMinutes(\"P1D\")).toBe(1440);\n181:     expect(parseDurationMinutes(\"P2D\")).toBe(2880);\n182:   });\n183: \n184:   test(\"parses combined durations\", () => {\n185:     expect(parseDurationMinutes(\"PT1H30M\")).toBe(90);\n186:     expect(parseDurationMinutes(\"P1DT4H\")).toBe(1680);\n187:     expect(parseDurationMinutes(\"P2DT4H\")).toBe(3120);\n188:     expect(parseDurationMinutes(\"P1DT2H30M\")).toBe(1590);\n189:   });\n190: \n191:   test(\"parses seconds (rounds up to minutes)\", () => {\n192:     expect(parseDurationMinutes(\"PT30S\")).toBe(1); // ceil(30/60) = 1\n193:     expect(parseDurationMinutes(\"PT60S\")).toBe(1); // ceil(60/60) = 1\n194:     expect(parseDurationMinutes(\"PT61S\")).toBe(2); // ceil(61/60) = 2\n195:     expect(parseDurationMinutes(\"PT1H30S\")).toBe(61); // 60 + ceil(30/60)\n196:   });\n197: \n198:   test(\"returns Infinity for unparseable strings\", () => {\n199:     expect(parseDurationMinutes(\"\")).toBe(Infinity);\n200:     expect(parseDurationMinutes(\"invalid\")).toBe(Infinity);\n201:     expect(parseDurationMinutes(\"1H\")).toBe(Infinity); // missing P\n202:     expect(parseDurationMinutes(\"hello world\")).toBe(Infinity);\n203:   });\n204: \n205:   test(\"handles edge case: PT alone parses as zero duration\", () => {\n206:     // \"PT\" matches the regex: P with T but all time groups are optional\n207:     expect(parseDurationMinutes(\"PT\")).toBe(0);\n208:   });\n209: \n210:   test(\"handles P alone (zero duration)\", () => {\n211:     // P with no components - the regex should handle this\n212:     const result = parseDurationMinutes(\"P\");\n213:     // P alone matches /^P(?:(\\d+)D)?(?:T(?:(\\d+)H)?(?:(\\d+)M)?(?:(\\d+)S)?)?$/\n214:     // All groups are undefined, defaults to 0\n215:     expect(result).toBe(0);\n216:   });\n217: });\n218: \n219: // ---------------------------------------------------------------------------\n220: // Duration Formatting\n221: // ---------------------------------------------------------------------------\n222: \n223: describe(\"formatDuration\", () => {\n224:   test(\"formats minutes only\", () => {\n225:     expect(formatDuration(30)).toBe(\"30m\");\n226:     expect(formatDuration(1)).toBe(\"1m\");\n227:     expect(formatDuration(59)).toBe(\"59m\");\n228:   });\n229: \n230:   test(\"formats hours only\", () => {\n231:     expect(formatDuration(60)).toBe(\"1h\");\n232:     expect(formatDuration(120)).toBe(\"2h\");\n233:   });\n234: \n235:   test(\"formats hours and minutes\", () => {\n236:     expect(formatDuration(90)).toBe(\"1h 30m\");\n237:     expect(formatDuration(150)).toBe(\"2h 30m\");\n238:   });\n239: \n240:   test(\"formats days\", () => {\n241:     expect(formatDuration(1440)).toBe(\"1d\");\n242:     expect(formatDuration(2880)).toBe(\"2d\");\n243:   });\n244: \n245:   test(\"formats days and hours\", () => {\n246:     expect(formatDuration(1500)).toBe(\"1d 1h\");\n247:     expect(formatDuration(1560)).toBe(\"1d 2h\");\n248:   });\n249: \n250:   test(\"formats days, hours, and minutes\", () => {\n251:     expect(formatDuration(1530)).toBe(\"1d 1h 30m\");\n252:   });\n253: \n254:   test(\"formats Infinity as unknown\", () => {\n255:     expect(formatDuration(Infinity)).toBe(\"unknown\");\n256:   });\n257: \n258:   test(\"formats zero\", () => {\n259:     expect(formatDuration(0)).toBe(\"0m\");\n260:   });\n261: });\n262: \n263: // ---------------------------------------------------------------------------\n264: // loadFeatures — YAML parsing edge cases\n265: // ---------------------------------------------------------------------------\n266: \n267: describe(\"loadFeatures\", () => {\n268:   const config = makeConfig();\n269: \n270:   test(\"loads valid tasks file\", () => {\n271:     const yaml = `\n272: version: \"1\"\n273: meta:\n274:   created_at: \"2025-01-01T00:00:00Z\"\n275:   updated_at: \"2025-01-01T00:00:00Z\"\n276:   project: test\n277:   generator: test\n278:   maintainer: tester\n279: tasks:\n280:   - id: feat-a\n281:     title: Feature A\n282:     description: Description of A\n283:     status: backlog\n284:     completion: 0\n285:     difficulty: medium\n286:     priority: high\n287:     depends_on: []\n288:     effort: PT2H\n289:     started_at: null\n290:     ended_at: null\n291:     constraints: []\n292:     forbidden: []\n293:     references: []\n294:     notes: []\n295:     subtasks: []\n296: `;\n297:     writeTasksYaml(tmpDir, yaml);\n298:     const data = loadFeatures(tmpDir, config);\n299:     expect(data.tasks).toHaveLength(1);\n300:     expect(data.tasks[0].id).toBe(\"feat-a\");\n301:     expect(data.tasks[0].priority).toBe(\"high\");\n302:     expect(data.archive).toHaveLength(0);\n303:   });\n304: \n305:   test(\"handles null tasks (empty YAML key)\", () => {\n306:     const yaml = `\n307: version: \"1\"\n308: meta:\n309:   created_at: \"2025-01-01T00:00:00Z\"\n310:   updated_at: \"2025-01-01T00:00:00Z\"\n311:   project: test\n312:   generator: test\n313:   maintainer: tester\n314: tasks:\n315: `;\n316:     writeTasksYaml(tmpDir, yaml);\n317:     const data = loadFeatures(tmpDir, config);\n318:     expect(data.tasks).toBeArray();\n319:     expect(data.tasks).toHaveLength(0);\n320:     expect(data.archive).toBeArray();\n321:     expect(data.archive).toHaveLength(0);\n322:   });\n323: \n324:   test(\"handles tasks with null depends_on and arrays\", () => {\n325:     const yaml = `\n326: version: \"1\"\n327: meta:\n328:   created_at: \"2025-01-01T00:00:00Z\"\n329:   updated_at: \"2025-01-01T00:00:00Z\"\n330:   project: test\n331:   generator: test\n332:   maintainer: tester\n333: tasks:\n334:   - id: feat-a\n335:     title: Feature A\n336:     description: \"\"\n337:     status: backlog\n338:     completion: 0\n339:     difficulty: medium\n340:     priority: medium\n341:     effort: PT1H\n342:     started_at: null\n343:     ended_at: null\n344: `;\n345:     writeTasksYaml(tmpDir, yaml);\n346:     const data = loadFeatures(tmpDir, config);\n347:     expect(data.tasks).toHaveLength(1);\n348:     // normalizeTask should default null arrays to []\n349:     const f = data.tasks[0];\n350:     expect(f.depends_on).toBeArray();\n351:     expect(f.depends_on).toHaveLength(0);\n352:     expect(f.constraints).toBeArray();\n353:     expect(f.forbidden).toBeArray();\n354:     expect(f.references).toBeArray();\n355:     expect(f.notes).toBeArray();\n356:     expect(f.subtasks).toBeArray();\n357:   });\n358: \n359:   test(\"handles nested subtasks normalization\", () => {\n360:     const yaml = `\n361: version: \"1\"\n362: meta:\n363:   created_at: \"2025-01-01T00:00:00Z\"\n364:   updated_at: \"2025-01-01T00:00:00Z\"\n365:   project: test\n366:   generator: test\n367:   maintainer: tester\n368: tasks:\n369:   - id: feat-a\n370:     title: Feature A\n371:     description: \"\"\n372:     status: backlog\n373:     completion: 0\n374:     difficulty: medium\n375:     priority: medium\n376:     effort: PT1H\n377:     started_at: null\n378:     ended_at: null\n379:     subtasks:\n380:       - id: sub-1\n381:         title: Subtask 1\n382:         description: \"\"\n383:         status: backlog\n384:         completion: 0\n385:         difficulty: easy\n386:         priority: medium\n387:         effort: PT30M\n388:         started_at: null\n389:         ended_at: null\n390: `;\n391:     writeTasksYaml(tmpDir, yaml);\n392:     const data = loadFeatures(tmpDir, config);\n393:     const subtask = data.tasks[0].subtasks[0];\n394:     expect(subtask.id).toBe(\"sub-1\");\n395:     expect(subtask.depends_on).toBeArray();\n396:     expect(subtask.constraints).toBeArray();\n397:     expect(subtask.subtasks).toBeArray();\n398:   });\n399: \n400:   test(\"throws on corrupted YAML\", () => {\n401:     writeTasksYaml(tmpDir, \"{{{{not valid yaml::::\");\n402:     expect(() => loadFeatures(tmpDir, config)).toThrow();\n403:   });\n404: \n405:   test(\"throws on missing file\", () => {\n406:     expect(() => loadFeatures(\"/nonexistent/path\", config)).toThrow();\n407:   });\n408: \n409:   test(\"handles custom tasks file path\", () => {\n410:     const customConfig = makeConfig({ tasksFile: \"custom-tasks.yml\" });\n411:     const yaml = `\n412: version: \"1\"\n413: meta:\n414:   created_at: \"2025-01-01T00:00:00Z\"\n415:   updated_at: \"2025-01-01T00:00:00Z\"\n416:   project: test\n417:   generator: test\n418:   maintainer: tester\n419: tasks: []\n420: `;\n421:     mkdirSync(join(tmpDir, \".wombo-combo\"), { recursive: true });\n422:     writeFileSync(join(tmpDir, \".wombo-combo\", \"custom-tasks.yml\"), yaml);\n423:     const data = loadFeatures(tmpDir, customConfig);\n424:     expect(data.tasks).toHaveLength(0);\n425:   });\n426: \n427:   test(\"supports legacy 'features' YAML key\", () => {\n428:     const yaml = `\n429: version: \"1\"\n430: meta:\n431:   created_at: \"2025-01-01T00:00:00Z\"\n432:   updated_at: \"2025-01-01T00:00:00Z\"\n433:   project: test\n434:   generator: test\n435:   maintainer: tester\n436: features:\n437:   - id: legacy-feat\n438:     title: Legacy Feature\n439:     description: Loaded via features key\n440:     status: backlog\n441:     completion: 0\n442:     difficulty: medium\n443:     priority: medium\n444:     depends_on: []\n445:     effort: PT1H\n446:     started_at: null\n447:     ended_at: null\n448:     constraints: []\n449:     forbidden: []\n450:     references: []\n451:     notes: []\n452:     subtasks: []\n453: `;\n454:     writeTasksYaml(tmpDir, yaml);\n455:     const data = loadFeatures(tmpDir, config);\n456:     expect(data.tasks).toHaveLength(1);\n457:     expect(data.tasks[0].id).toBe(\"legacy-feat\");\n458:   });\n459: });\n460: \n461: // ---------------------------------------------------------------------------\n462: // Dependency Resolution\n463: // ---------------------------------------------------------------------------\n464: \n465: describe(\"areDependenciesMet\", () => {\n466:   test(\"returns true when feature has no dependencies\", () => {\n467:     const feature = makeFeature({ depends_on: [] });\n468:     const doneIds = new Set<string>();\n469:     expect(areDependenciesMet(feature, doneIds)).toBe(true);\n470:   });\n471: \n472:   test(\"returns true when all dependencies are done\", () => {\n473:     const feature = makeFeature({ depends_on: [\"dep-a\", \"dep-b\"] });\n474:     const doneIds = new Set([\"dep-a\", \"dep-b\", \"dep-c\"]);\n475:     expect(areDependenciesMet(feature, doneIds)).toBe(true);\n476:   });\n477: \n478:   test(\"returns false when some dependencies are not done\", () => {\n479:     const feature = makeFeature({ depends_on: [\"dep-a\", \"dep-b\"] });\n480:     const doneIds = new Set([\"dep-a\"]);\n481:     expect(areDependenciesMet(feature, doneIds)).toBe(false);\n482:   });\n483: \n484:   test(\"returns false when no dependencies are done\", () => {\n485:     const feature = makeFeature({ depends_on: [\"dep-a\", \"dep-b\"] });\n486:     const doneIds = new Set<string>();\n487:     expect(areDependenciesMet(feature, doneIds)).toBe(false);\n488:   });\n489: });\n490: \n491: describe(\"getDoneFeatureIds\", () => {\n492:   test(\"identifies features with done status\", () => {\n493:     const data = makeFeaturesFile([\n494:       makeFeature({ id: \"feat-done\", status: \"done\", completion: 100 }),\n495:       makeFeature({ id: \"feat-wip\", status: \"in_progress\", completion: 50 }),\n496:     ]);\n497:     const doneIds = getDoneFeatureIds(data);\n498:     expect(doneIds.has(\"feat-done\")).toBe(true);\n499:     expect(doneIds.has(\"feat-wip\")).toBe(false);\n500:   });\n501: \n502:   test(\"identifies features with 100% completion as done\", () => {\n503:     const data = makeFeaturesFile([\n504:       makeFeature({\n505:         id: \"feat-complete\",\n506:         status: \"in_review\",\n507:         completion: 100,\n508:       }),\n509:     ]);\n510:     const doneIds = getDoneFeatureIds(data);\n511:     expect(doneIds.has(\"feat-complete\")).toBe(true);\n512:   });\n513: \n514:   test(\"includes archived features as done\", () => {\n515:     const data = makeFeaturesFile(\n516:       [],\n517:       [makeFeature({ id: \"archived-feat\", status: \"done\", completion: 100 })]\n518:     );\n519:     const doneIds = getDoneFeatureIds(data);\n520:     expect(doneIds.has(\"archived-feat\")).toBe(true);\n521:   });\n522: \n523:   test(\"includes done subtasks\", () => {\n524:     const data = makeFeaturesFile([\n525:       makeFeature({\n526:         id: \"parent\",\n527:         status: \"in_progress\",\n528:         subtasks: [\n529:           {\n530:             id: \"sub-done\",\n531:             title: \"Done sub\",\n532:             description: \"\",\n533:             status: \"done\",\n534:             completion: 100,\n535:             difficulty: \"easy\",\n536:             priority: \"medium\",\n537:             depends_on: [],\n538:             effort: \"PT30M\",\n539:             started_at: null,\n540:             ended_at: null,\n541:             constraints: [],\n542:             forbidden: [],\n543:             references: [],\n544:             notes: [],\n545:             subtasks: [],\n546:           },\n547:         ],\n548:       }),\n549:     ]);\n550:     const doneIds = getDoneFeatureIds(data);\n551:     expect(doneIds.has(\"sub-done\")).toBe(true);\n552:     expect(doneIds.has(\"parent\")).toBe(false);\n553:   });\n554: });\n555: \n556: describe(\"getReadyFeatures\", () => {\n557:   test(\"returns backlog features with deps met\", () => {\n558:     const data = makeFeaturesFile([\n559:       makeFeature({ id: \"ready\", status: \"backlog\", depends_on: [] }),\n560:       makeFeature({\n561:         id: \"blocked\",\n562:         status: \"backlog\",\n563:         depends_on: [\"not-done\"],\n564:       }),\n565:       makeFeature({ id: \"in-progress\", status: \"in_progress\" }),\n566:     ]);\n567:     const ready = getReadyFeatures(data);\n568:     expect(ready).toHaveLength(1);\n569:     expect(ready[0].id).toBe(\"ready\");\n570:   });\n571: \n572:   test(\"considers archived deps as met\", () => {\n573:     const data = makeFeaturesFile(\n574:       [\n575:         makeFeature({\n576:           id: \"waiting\",\n577:           status: \"backlog\",\n578:           depends_on: [\"archived-dep\"],\n579:         }),\n580:       ],\n581:       [\n582:         makeFeature({\n583:           id: \"archived-dep\",\n584:           status: \"done\",\n585:           completion: 100,\n586:         }),\n587:       ]\n588:     );\n589:     const ready = getReadyFeatures(data);\n590:     expect(ready).toHaveLength(1);\n591:     expect(ready[0].id).toBe(\"waiting\");\n592:   });\n593: \n594:   test(\"excludes features with non-zero completion\", () => {\n595:     const data = makeFeaturesFile([\n596:       makeFeature({ id: \"partial\", status: \"backlog\", completion: 50 }),\n597:     ]);\n598:     const ready = getReadyFeatures(data);\n599:     expect(ready).toHaveLength(0);\n600:   });\n601: \n602:   test(\"returns empty array when no features are ready\", () => {\n603:     const data = makeFeaturesFile([\n604:       makeFeature({\n605:         id: \"blocked\",\n606:         status: \"backlog\",\n607:         depends_on: [\"missing\"],\n608:       }),\n609:     ]);\n610:     const ready = getReadyFeatures(data);\n611:     expect(ready).toHaveLength(0);\n612:   });\n613: });\n614: \n615: // ---------------------------------------------------------------------------\n616: // selectFeatures strategies\n617: // ---------------------------------------------------------------------------\n618: \n619: describe(\"selectFeatures\", () => {\n620:   const highPriority = makeFeature({\n621:     id: \"high-pri\",\n622:     priority: \"high\",\n623:     effort: \"PT2H\",\n624:   });\n625:   const criticalSmall = makeFeature({\n626:     id: \"critical-small\",\n627:     priority: \"critical\",\n628:     effort: \"PT30M\",\n629:   });\n630:   const mediumLong = makeFeature({\n631:     id: \"medium-long\",\n632:     priority: \"medium\",\n633:     effort: \"P1D\",\n634:   });\n635:   const lowQuick = makeFeature({\n636:     id: \"low-quick\",\n637:     priority: \"low\",\n638:     effort: \"PT15M\",\n639:     difficulty: \"easy\",\n640:   });\n641: \n642:   const data = makeFeaturesFile([highPriority, criticalSmall, mediumLong, lowQuick]);\n643: \n644:   test(\"allReady returns all ready features sorted by priority\", () => {\n645:     const selected = selectFeatures(data, { allReady: true });\n646:     expect(selected).toHaveLength(4);\n647:     expect(selected[0].id).toBe(\"critical-small\");\n648:     expect(selected[1].id).toBe(\"high-pri\");\n649:   });\n650: \n651:   test(\"topPriority selects top N by priority\", () => {\n652:     const selected = selectFeatures(data, { topPriority: 2 });\n653:     expect(selected).toHaveLength(2);\n654:     expect(selected[0].id).toBe(\"critical-small\");\n655:     expect(selected[1].id).toBe(\"high-pri\");\n656:   });\n657: \n658:   test(\"quickestWins selects N lowest effort\", () => {\n659:     const selected = selectFeatures(data, { quickestWins: 2 });\n660:     expect(selected).toHaveLength(2);\n661:     // Sorted by effort: 15m, 30m, 2h, 1d\n662:     expect(selected[0].id).toBe(\"low-quick\");\n663:     expect(selected[1].id).toBe(\"critical-small\");\n664:   });\n665: \n666:   test(\"priority filter selects matching priority\", () => {\n667:     const selected = selectFeatures(data, { priority: \"high\" });\n668:     expect(selected).toHaveLength(1);\n669:     expect(selected[0].id).toBe(\"high-pri\");\n670:   });\n671: \n672:   test(\"difficulty filter selects matching difficulty\", () => {\n673:     const selected = selectFeatures(data, { difficulty: \"easy\" });\n674:     expect(selected).toHaveLength(1);\n675:     expect(selected[0].id).toBe(\"low-quick\");\n676:   });\n677: \n678:   test(\"featureIds selects specific features (backward compat)\", () => {\n679:     const selected = selectFeatures(data, {\n680:       featureIds: [\"high-pri\", \"low-quick\"],\n681:     });\n682:     expect(selected).toHaveLength(2);\n683:   });\n684: \n685:   test(\"featureIds with nonexistent IDs still returns valid ones\", () => {\n686:     const selected = selectFeatures(data, {\n687:       featureIds: [\"high-pri\", \"nonexistent\"],\n688:     });\n689:     expect(selected).toHaveLength(1);\n690:     expect(selected[0].id).toBe(\"high-pri\");\n691:   });\n692: \n693:   test(\"default returns all ready sorted by priority\", () => {\n694:     const selected = selectFeatures(data, {});\n695:     expect(selected).toHaveLength(4);\n696:     expect(selected[0].id).toBe(\"critical-small\");\n697:   });\n698: });\n699: \n700: // ---------------------------------------------------------------------------\n701: // createBlankFeature\n702: // ---------------------------------------------------------------------------\n703: \n704: describe(\"createBlankFeature\", () => {\n705:   test(\"creates feature with default values\", () => {\n706:     const f = createBlankFeature(\"my-feat\", \"My Feature\");\n707:     expect(f.id).toBe(\"my-feat\");\n708:     expect(f.title).toBe(\"My Feature\");\n709:     expect(f.status).toBe(\"backlog\");\n710:     expect(f.completion).toBe(0);\n711:     expect(f.difficulty).toBe(\"medium\");\n712:     expect(f.priority).toBe(\"medium\");\n713:     expect(f.effort).toBe(\"PT1H\");\n714:     expect(f.depends_on).toEqual([]);\n715:     expect(f.subtasks).toEqual([]);\n716:   });\n717: \n718:   test(\"creates feature with custom options\", () => {\n719:     const f = createBlankFeature(\"my-feat\", \"My Feature\", \"Description\", {\n720:       priority: \"critical\",\n721:       difficulty: \"hard\",\n722:       effort: \"P2D\",\n723:     });\n724:     expect(f.priority).toBe(\"critical\");\n725:     expect(f.difficulty).toBe(\"hard\");\n726:     expect(f.effort).toBe(\"P2D\");\n727:     expect(f.description).toBe(\"Description\");\n728:   });\n729: });\n730: \n731: // ---------------------------------------------------------------------------\n732: // findFeatureById\n733: // ---------------------------------------------------------------------------\n734: \n735: describe(\"findFeatureById\", () => {\n736:   test(\"finds top-level feature\", () => {\n737:     const data = makeFeaturesFile([makeFeature({ id: \"target\" })]);\n738:     const found = findFeatureById(data, \"target\");\n739:     expect(found).toBeDefined();\n740:     expect(found!.id).toBe(\"target\");\n741:   });\n742: \n743:   test(\"finds feature in archive\", () => {\n744:     const data = makeFeaturesFile(\n745:       [],\n746:       [makeFeature({ id: \"archived\" })]\n747:     );\n748:     const found = findFeatureById(data, \"archived\");\n749:     expect(found).toBeDefined();\n750:     expect(found!.id).toBe(\"archived\");\n751:   });\n752: \n753:   test(\"finds nested subtask\", () => {\n754:     const data = makeFeaturesFile([\n755:       makeFeature({\n756:         id: \"parent\",\n757:         subtasks: [\n758:           {\n759:             id: \"nested-sub\",\n760:             title: \"Nested\",\n761:             description: \"\",\n762:             status: \"backlog\",\n763:             completion: 0,\n764:             difficulty: \"easy\",\n765:             priority: \"medium\",\n766:             depends_on: [],\n767:             effort: \"PT30M\",\n768:             started_at: null,\n769:             ended_at: null,\n770:             constraints: [],\n771:             forbidden: [],\n772:             references: [],\n773:             notes: [],\n774:             subtasks: [],\n775:           },\n776:         ],\n777:       }),\n778:     ]);\n779:     const found = findFeatureById(data, \"nested-sub\");\n780:     expect(found).toBeDefined();\n781:     expect(found!.id).toBe(\"nested-sub\");\n782:   });\n783: \n784:   test(\"returns undefined for nonexistent ID\", () => {\n785:     const data = makeFeaturesFile([makeFeature({ id: \"exists\" })]);\n786:     const found = findFeatureById(data, \"nonexistent\");\n787:     expect(found).toBeUndefined();\n788:   });\n789: });\n790: \n791: // ---------------------------------------------------------------------------\n792: // allFeatureIds\n793: // ---------------------------------------------------------------------------\n794: \n795: describe(\"allFeatureIds\", () => {\n796:   test(\"collects all IDs including subtasks and archive\", () => {\n797:     const data = makeFeaturesFile(\n798:       [\n799:         makeFeature({\n800:           id: \"feat-a\",\n801:           subtasks: [\n802:             {\n803:               id: \"sub-1\",\n804:               title: \"Sub\",\n805:               description: \"\",\n806:               status: \"backlog\",\n807:               completion: 0,\n808:               difficulty: \"easy\",\n809:               priority: \"medium\",\n810:               depends_on: [],\n811:               effort: \"PT30M\",\n812:               started_at: null,\n813:               ended_at: null,\n814:               constraints: [],\n815:               forbidden: [],\n816:               references: [],\n817:               notes: [],\n818:               subtasks: [],\n819:             },\n820:           ],\n821:         }),\n822:       ],\n823:       [makeFeature({ id: \"archived\" })]\n824:     );\n825:     const ids = allFeatureIds(data);\n826:     expect(ids).toContain(\"feat-a\");\n827:     expect(ids).toContain(\"sub-1\");\n828:     expect(ids).toContain(\"archived\");\n829:   });\n830: });\n831: \n832: // ---------------------------------------------------------------------------\n833: // featureSummary\n834: // ---------------------------------------------------------------------------\n835: \n836: describe(\"featureSummary\", () => {\n837:   test(\"produces formatted summary string\", () => {\n838:     const f = makeFeature({\n839:       id: \"auth-flow\",\n840:       title: \"Auth Flow\",\n841:       priority: \"high\",\n842:       difficulty: \"medium\",\n843:       effort: \"PT2H\",\n844:     });\n845:     const summary = featureSummary(f);\n846:     expect(summary).toContain(\"[high/medium]\");\n847:     expect(summary).toContain(\"auth-flow\");\n848:     expect(summary).toContain(\"Auth Flow\");\n849:     expect(summary).toContain(\"2h\");\n850:   });\n851: });\n852: \n853: // ---------------------------------------------------------------------------\n854: // Priority and Difficulty orderings\n855: // ---------------------------------------------------------------------------\n856: \n857: describe(\"PRIORITY_ORDER\", () => {\n858:   test(\"critical < high < medium < low < wishlist\", () => {\n859:     expect(PRIORITY_ORDER.critical).toBeLessThan(PRIORITY_ORDER.high);\n860:     expect(PRIORITY_ORDER.high).toBeLessThan(PRIORITY_ORDER.medium);\n861:     expect(PRIORITY_ORDER.medium).toBeLessThan(PRIORITY_ORDER.low);\n862:     expect(PRIORITY_ORDER.low).toBeLessThan(PRIORITY_ORDER.wishlist);\n863:   });\n864: });\n865: \n866: describe(\"DIFFICULTY_ORDER\", () => {\n867:   test(\"trivial < easy < medium < hard < very_hard\", () => {\n868:     expect(DIFFICULTY_ORDER.trivial).toBeLessThan(DIFFICULTY_ORDER.easy);\n869:     expect(DIFFICULTY_ORDER.easy).toBeLessThan(DIFFICULTY_ORDER.medium);\n870:     expect(DIFFICULTY_ORDER.medium).toBeLessThan(DIFFICULTY_ORDER.hard);\n871:     expect(DIFFICULTY_ORDER.hard).toBeLessThan(DIFFICULTY_ORDER.very_hard);\n872:   });\n873: });\n\n(End of file - total 873 lines)\n</content>","title":"tests/features.test.ts","metadata":{"preview":"/**\n * features.test.ts — Unit tests for tasks YAML parsing, validation,\n * duration parsing, and dependency resolution.\n *\n * Coverage:\n *   - loadFeatures with null tasks, empty arrays, valid data\n *   - parseDurationMinutes for ISO 8601 durations\n *   - formatDuration for human-readable output\n *   - Dependency resolution (areDependenciesMet, getReadyFeatures)\n *   - normalizeTask defaults\n *   - createBlankFeature\n *   - findFeatureById (recursive search)\n *   - selectFeatures strategies\n *   - YAML schema edge cases\n */\n\nimport { describe, test, expect, beforeEach, afterEach } from \"bun:test\";\nimport { mkdtempSync, writeFileSync, rmSync, mkdirSync } from \"node:fs\";\nimport { join } from \"node:path\";\nimport { tmpdir } from \"node:os\";","truncated":false,"loaded":[]},"time":{"start":1773435845096,"end":1773435845158}}}}
{"type":"tool_use","timestamp":1773435845768,"sessionID":"ses_316fcc12bffeSBLLi3jBrbT2M4","part":{"id":"prt_ce9037a47001yinU0cLd7ZIcMB","sessionID":"ses_316fcc12bffeSBLLi3jBrbT2M4","messageID":"msg_ce9036b1f001WQ3dj9eBiOriAQ","type":"tool","callID":"toolu_vrtx_01Kh9ytkkN7dz8qx6TwiaAkZ","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-unit-test-suite/tests/state.test.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-unit-test-suite/tests/state.test.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * state.test.ts — Unit tests for wave state persistence and mutations.\n3:  *\n4:  * Coverage:\n5:  *   - saveState / loadState round-trip\n6:  *   - Atomic write (write to .tmp then rename)\n7:  *   - State file corruption recovery (returns null)\n8:  *   - createWaveState / createAgentState\n9:  *   - updateAgent with valid/invalid feature IDs\n10:  *   - agentCounts\n11:  *   - activeAgents / queuedAgents\n12:  *   - isWaveComplete\n13:  *   - generateWaveId format\n14:  *   - Concurrent mutation patterns\n15:  */\n16: \n17: import { describe, test, expect, beforeEach, afterEach } from \"bun:test\";\n18: import { mkdtempSync, mkdirSync, writeFileSync, readFileSync, rmSync, existsSync } from \"node:fs\";\n19: import { join } from \"node:path\";\n20: import { tmpdir } from \"node:os\";\n21: import {\n22:   loadState,\n23:   saveState,\n24:   createWaveState,\n25:   createAgentState,\n26:   getAgent,\n27:   updateAgent,\n28:   agentCounts,\n29:   activeAgents,\n30:   queuedAgents,\n31:   isWaveComplete,\n32:   generateWaveId,\n33: } from \"../src/lib/state.js\";\n34: import type { WaveState, AgentState, AgentStatus } from \"../src/lib/state.js\";\n35: \n36: // ---------------------------------------------------------------------------\n37: // Helpers\n38: // ---------------------------------------------------------------------------\n39: \n40: let tmpDir: string;\n41: \n42: beforeEach(() => {\n43:   tmpDir = mkdtempSync(join(tmpdir(), \"wombo-test-state-\"));\n44: });\n45: \n46: afterEach(() => {\n47:   rmSync(tmpDir, { recursive: true, force: true });\n48: });\n49: \n50: function makeWaveState(overrides?: Partial<WaveState>): WaveState {\n51:   return {\n52:     wave_id: \"wave-2025-01-01-000\",\n53:     base_branch: \"main\",\n54:     started_at: \"2025-01-01T00:00:00Z\",\n55:     updated_at: \"2025-01-01T00:00:00Z\",\n56:     max_concurrent: 4,\n57:     model: null,\n58:     interactive: false,\n59:     agents: [],\n60:     ...overrides,\n61:   };\n62: }\n63: \n64: function makeAgentState(overrides?: Partial<AgentState>): AgentState {\n65:   return {\n66:     feature_id: \"test-feature\",\n67:     branch: \"feature/test-feature\",\n68:     worktree: \"/tmp/wombo-test-feature\",\n69:     session_id: null,\n70:     pid: null,\n71:     status: \"queued\",\n72:     activity: null,\n73:     activity_updated_at: null,\n74:     retries: 0,\n75:     max_retries: 2,\n76:     started_at: null,\n77:     completed_at: null,\n78:     build_passed: null,\n79:     build_output: null,\n80:     error: null,\n81:     effort_estimate_ms: null,\n82:     ...overrides,\n83:   };\n84: }\n85: \n86: // ---------------------------------------------------------------------------\n87: // generateWaveId\n88: // ---------------------------------------------------------------------------\n89: \n90: describe(\"generateWaveId\", () => {\n91:   test(\"produces wave ID in expected format\", () => {\n92:     const id = generateWaveId();\n93:     // The sequence part is hours*60+minutes, padStart(3, \"0\"), so can be 3-4 digits\n94:     expect(id).toMatch(/^wave-\\d{4}-\\d{2}-\\d{2}-\\d{3,4}$/);\n95:   });\n96: \n97:   test(\"includes current date\", () => {\n98:     const id = generateWaveId();\n99:     const today = new Date().toISOString().slice(0, 10);\n100:     expect(id).toContain(today);\n101:   });\n102: \n103:   test(\"produces consistent format on repeated calls\", () => {\n104:     const id1 = generateWaveId();\n105:     const id2 = generateWaveId();\n106:     // Both should match the format (though values may differ slightly)\n107:     expect(id1).toMatch(/^wave-\\d{4}-\\d{2}-\\d{2}-\\d{3,4}$/);\n108:     expect(id2).toMatch(/^wave-\\d{4}-\\d{2}-\\d{2}-\\d{3,4}$/);\n109:   });\n110: });\n111: \n112: // ---------------------------------------------------------------------------\n113: // createWaveState\n114: // ---------------------------------------------------------------------------\n115: \n116: describe(\"createWaveState\", () => {\n117:   test(\"creates state with provided options\", () => {\n118:     const state = createWaveState({\n119:       baseBranch: \"develop\",\n120:       maxConcurrent: 3,\n121:       model: \"gpt-4\",\n122:       interactive: true,\n123:     });\n124:     expect(state.base_branch).toBe(\"develop\");\n125:     expect(state.max_concurrent).toBe(3);\n126:     expect(state.model).toBe(\"gpt-4\");\n127:     expect(state.interactive).toBe(true);\n128:     expect(state.agents).toEqual([]);\n129:     expect(state.wave_id).toMatch(/^wave-/);\n130:   });\n131: \n132:   test(\"creates state with null model\", () => {\n133:     const state = createWaveState({\n134:       baseBranch: \"main\",\n135:       maxConcurrent: 6,\n136:       model: null,\n137:       interactive: false,\n138:     });\n139:     expect(state.model).toBeNull();\n140:   });\n141: \n142:   test(\"sets started_at and updated_at timestamps\", () => {\n143:     const before = new Date().toISOString();\n144:     const state = createWaveState({\n145:       baseBranch: \"main\",\n146:       maxConcurrent: 1,\n147:       model: null,\n148:       interactive: false,\n149:     });\n150:     const after = new Date().toISOString();\n151:     expect(state.started_at >= before).toBe(true);\n152:     expect(state.started_at <= after).toBe(true);\n153:   });\n154: });\n155: \n156: // ---------------------------------------------------------------------------\n157: // createAgentState\n158: // ---------------------------------------------------------------------------\n159: \n160: describe(\"createAgentState\", () => {\n161:   test(\"creates agent with default max retries\", () => {\n162:     const agent = createAgentState(\"my-feat\", \"feature/my-feat\", \"/tmp/wt\");\n163:     expect(agent.feature_id).toBe(\"my-feat\");\n164:     expect(agent.branch).toBe(\"feature/my-feat\");\n165:     expect(agent.worktree).toBe(\"/tmp/wt\");\n166:     expect(agent.status).toBe(\"queued\");\n167:     expect(agent.max_retries).toBe(2);\n168:     expect(agent.retries).toBe(0);\n169:     expect(agent.pid).toBeNull();\n170:     expect(agent.session_id).toBeNull();\n171:     expect(agent.build_passed).toBeNull();\n172:   });\n173: \n174:   test(\"creates agent with custom max retries\", () => {\n175:     const agent = createAgentState(\"my-feat\", \"feature/my-feat\", \"/tmp/wt\", 5);\n176:     expect(agent.max_retries).toBe(5);\n177:   });\n178: });\n179: \n180: // ---------------------------------------------------------------------------\n181: // saveState / loadState round-trip\n182: // ---------------------------------------------------------------------------\n183: \n184: describe(\"saveState / loadState\", () => {\n185:   test(\"round-trips state through file system\", () => {\n186:     const state = makeWaveState({\n187:       agents: [makeAgentState({ feature_id: \"feat-a\" })],\n188:     });\n189:     saveState(tmpDir, state);\n190:     const loaded = loadState(tmpDir);\n191:     expect(loaded).not.toBeNull();\n192:     expect(loaded!.wave_id).toBe(state.wave_id);\n193:     expect(loaded!.agents).toHaveLength(1);\n194:     expect(loaded!.agents[0].feature_id).toBe(\"feat-a\");\n195:   });\n196: \n197:   test(\"updates updated_at timestamp on save\", () => {\n198:     const state = makeWaveState();\n199:     const oldTimestamp = state.updated_at;\n200:     // Wait a tiny bit to ensure timestamp differs\n201:     saveState(tmpDir, state);\n202:     const loaded = loadState(tmpDir);\n203:     expect(loaded).not.toBeNull();\n204:     // The saved state should have a newer (or equal) timestamp\n205:     expect(loaded!.updated_at >= oldTimestamp).toBe(true);\n206:   });\n207: \n208:   test(\"writes valid JSON\", () => {\n209:     const state = makeWaveState({\n210:       agents: [\n211:         makeAgentState({ feature_id: \"feat-a\", status: \"running\" }),\n212:         makeAgentState({ feature_id: \"feat-b\", status: \"completed\" }),\n213:       ],\n214:     });\n215:     saveState(tmpDir, state);\n216:     const raw = readFileSync(join(tmpDir, \".wombo-combo\", \"state.json\"), \"utf-8\");\n217:     const parsed = JSON.parse(raw);\n218:     expect(parsed.wave_id).toBe(state.wave_id);\n219:     expect(parsed.agents).toHaveLength(2);\n220:   });\n221: \n222:   test(\"atomic write: tmp file is cleaned up after rename\", () => {\n223:     const state = makeWaveState();\n224:     saveState(tmpDir, state);\n225:     // The .tmp file should not exist after a successful save\n226:     expect(existsSync(join(tmpDir, \".wombo-combo\", \"state.json.tmp\"))).toBe(false);\n227:     // The actual file should exist\n228:     expect(existsSync(join(tmpDir, \".wombo-combo\", \"state.json\"))).toBe(true);\n229:   });\n230: \n231:   test(\"returns null when no state file exists\", () => {\n232:     const loaded = loadState(tmpDir);\n233:     expect(loaded).toBeNull();\n234:   });\n235: \n236:   test(\"returns null on corrupted JSON\", () => {\n237:     mkdirSync(join(tmpDir, \".wombo-combo\"), { recursive: true });\n238:     writeFileSync(\n239:       join(tmpDir, \".wombo-combo\", \"state.json\"),\n240:       \"{{not valid json!!!\",\n241:       \"utf-8\"\n242:     );\n243:     const loaded = loadState(tmpDir);\n244:     expect(loaded).toBeNull();\n245:   });\n246: \n247:   test(\"returns null on empty file\", () => {\n248:     mkdirSync(join(tmpDir, \".wombo-combo\"), { recursive: true });\n249:     writeFileSync(join(tmpDir, \".wombo-combo\", \"state.json\"), \"\", \"utf-8\");\n250:     const loaded = loadState(tmpDir);\n251:     expect(loaded).toBeNull();\n252:   });\n253: \n254:   test(\"handles state with many agents\", () => {\n255:     const agents: AgentState[] = [];\n256:     for (let i = 0; i < 50; i++) {\n257:       agents.push(\n258:         makeAgentState({\n259:           feature_id: `feat-${i}`,\n260:           branch: `feature/feat-${i}`,\n261:         })\n262:       );\n263:     }\n264:     const state = makeWaveState({ agents });\n265:     saveState(tmpDir, state);\n266:     const loaded = loadState(tmpDir);\n267:     expect(loaded!.agents).toHaveLength(50);\n268:   });\n269: \n270:   test(\"preserves all agent fields through round-trip\", () => {\n271:     const agent = makeAgentState({\n272:       feature_id: \"full-agent\",\n273:       branch: \"feature/full\",\n274:       worktree: \"/tmp/wt-full\",\n275:       session_id: \"tmux-session-123\",\n276:       pid: 12345,\n277:       status: \"running\",\n278:       activity: \"Building project\",\n279:       activity_updated_at: \"2025-01-01T12:00:00Z\",\n280:       retries: 1,\n281:       max_retries: 3,\n282:       started_at: \"2025-01-01T10:00:00Z\",\n283:       completed_at: null,\n284:       build_passed: null,\n285:       build_output: null,\n286:       error: null,\n287:       effort_estimate_ms: 3600000,\n288:     });\n289:     const state = makeWaveState({ agents: [agent] });\n290:     saveState(tmpDir, state);\n291:     const loaded = loadState(tmpDir);\n292:     const loadedAgent = loaded!.agents[0];\n293:     expect(loadedAgent.feature_id).toBe(\"full-agent\");\n294:     expect(loadedAgent.session_id).toBe(\"tmux-session-123\");\n295:     expect(loadedAgent.pid).toBe(12345);\n296:     expect(loadedAgent.status).toBe(\"running\");\n297:     expect(loadedAgent.activity).toBe(\"Building project\");\n298:     expect(loadedAgent.retries).toBe(1);\n299:     expect(loadedAgent.max_retries).toBe(3);\n300:     expect(loadedAgent.effort_estimate_ms).toBe(3600000);\n301:   });\n302: });\n303: \n304: // ---------------------------------------------------------------------------\n305: // getAgent\n306: // ---------------------------------------------------------------------------\n307: \n308: describe(\"getAgent\", () => {\n309:   test(\"finds agent by feature ID\", () => {\n310:     const state = makeWaveState({\n311:       agents: [\n312:         makeAgentState({ feature_id: \"feat-a\" }),\n313:         makeAgentState({ feature_id: \"feat-b\" }),\n314:       ],\n315:     });\n316:     const agent = getAgent(state, \"feat-b\");\n317:     expect(agent).toBeDefined();\n318:     expect(agent!.feature_id).toBe(\"feat-b\");\n319:   });\n320: \n321:   test(\"returns undefined for nonexistent feature ID\", () => {\n322:     const state = makeWaveState({\n323:       agents: [makeAgentState({ feature_id: \"feat-a\" })],\n324:     });\n325:     const agent = getAgent(state, \"nonexistent\");\n326:     expect(agent).toBeUndefined();\n327:   });\n328: \n329:   test(\"returns undefined when agents list is empty\", () => {\n330:     const state = makeWaveState({ agents: [] });\n331:     const agent = getAgent(state, \"any\");\n332:     expect(agent).toBeUndefined();\n333:   });\n334: });\n335: \n336: // ---------------------------------------------------------------------------\n337: // updateAgent\n338: // ---------------------------------------------------------------------------\n339: \n340: describe(\"updateAgent\", () => {\n341:   test(\"updates agent status\", () => {\n342:     const state = makeWaveState({\n343:       agents: [makeAgentState({ feature_id: \"feat-a\", status: \"queued\" })],\n344:     });\n345:     updateAgent(state, \"feat-a\", { status: \"running\" });\n346:     expect(state.agents[0].status).toBe(\"running\");\n347:   });\n348: \n349:   test(\"updates multiple fields at once\", () => {\n350:     const state = makeWaveState({\n351:       agents: [makeAgentState({ feature_id: \"feat-a\" })],\n352:     });\n353:     updateAgent(state, \"feat-a\", {\n354:       status: \"running\",\n355:       pid: 12345,\n356:       started_at: \"2025-01-01T00:00:00Z\",\n357:       activity: \"Installing dependencies\",\n358:     });\n359:     expect(state.agents[0].status).toBe(\"running\");\n360:     expect(state.agents[0].pid).toBe(12345);\n361:     expect(state.agents[0].started_at).toBe(\"2025-01-01T00:00:00Z\");\n362:     expect(state.agents[0].activity).toBe(\"Installing dependencies\");\n363:   });\n364: \n365:   test(\"throws for nonexistent feature ID\", () => {\n366:     const state = makeWaveState({\n367:       agents: [makeAgentState({ feature_id: \"feat-a\" })],\n368:     });\n369:     expect(() => updateAgent(state, \"nonexistent\", { status: \"running\" })).toThrow(\n370:       \"Agent not found for feature: nonexistent\"\n371:     );\n372:   });\n373: \n374:   test(\"throws when agents list is empty\", () => {\n375:     const state = makeWaveState({ agents: [] });\n376:     expect(() => updateAgent(state, \"any\", { status: \"running\" })).toThrow(\n377:       \"Agent not found for feature: any\"\n378:     );\n379:   });\n380: \n381:   test(\"only updates the targeted agent\", () => {\n382:     const state = makeWaveState({\n383:       agents: [\n384:         makeAgentState({ feature_id: \"feat-a\", status: \"queued\" }),\n385:         makeAgentState({ feature_id: \"feat-b\", status: \"queued\" }),\n386:       ],\n387:     });\n388:     updateAgent(state, \"feat-a\", { status: \"running\" });\n389:     expect(state.agents[0].status).toBe(\"running\");\n390:     expect(state.agents[1].status).toBe(\"queued\");\n391:   });\n392: \n393:   test(\"sequential updates accumulate correctly\", () => {\n394:     const state = makeWaveState({\n395:       agents: [makeAgentState({ feature_id: \"feat-a\" })],\n396:     });\n397:     updateAgent(state, \"feat-a\", { status: \"installing\" });\n398:     updateAgent(state, \"feat-a\", { status: \"running\", pid: 1234 });\n399:     updateAgent(state, \"feat-a\", {\n400:       status: \"completed\",\n401:       completed_at: \"2025-01-01T01:00:00Z\",\n402:       build_passed: true,\n403:     });\n404:     const agent = state.agents[0];\n405:     expect(agent.status).toBe(\"completed\");\n406:     expect(agent.pid).toBe(1234);\n407:     expect(agent.build_passed).toBe(true);\n408:     expect(agent.completed_at).toBe(\"2025-01-01T01:00:00Z\");\n409:   });\n410: });\n411: \n412: // ---------------------------------------------------------------------------\n413: // agentCounts\n414: // ---------------------------------------------------------------------------\n415: \n416: describe(\"agentCounts\", () => {\n417:   test(\"counts agents by status\", () => {\n418:     const state = makeWaveState({\n419:       agents: [\n420:         makeAgentState({ feature_id: \"a\", status: \"queued\" }),\n421:         makeAgentState({ feature_id: \"b\", status: \"queued\" }),\n422:         makeAgentState({ feature_id: \"c\", status: \"running\" }),\n423:         makeAgentState({ feature_id: \"d\", status: \"completed\" }),\n424:         makeAgentState({ feature_id: \"e\", status: \"failed\" }),\n425:       ],\n426:     });\n427:     const counts = agentCounts(state);\n428:     expect(counts.queued).toBe(2);\n429:     expect(counts.running).toBe(1);\n430:     expect(counts.completed).toBe(1);\n431:     expect(counts.failed).toBe(1);\n432:     expect(counts.installing).toBe(0);\n433:     expect(counts.verified).toBe(0);\n434:     expect(counts.merged).toBe(0);\n435:     expect(counts.retry).toBe(0);\n436:     expect(counts.resolving_conflict).toBe(0);\n437:   });\n438: \n439:   test(\"returns all zeros for empty agents list\", () => {\n440:     const state = makeWaveState({ agents: [] });\n441:     const counts = agentCounts(state);\n442:     expect(counts.queued).toBe(0);\n443:     expect(counts.running).toBe(0);\n444:     expect(counts.completed).toBe(0);\n445:   });\n446: });\n447: \n448: // ---------------------------------------------------------------------------\n449: // activeAgents\n450: // ---------------------------------------------------------------------------\n451: \n452: describe(\"activeAgents\", () => {\n453:   test(\"returns running, installing, and resolving_conflict agents\", () => {\n454:     const state = makeWaveState({\n455:       agents: [\n456:         makeAgentState({ feature_id: \"a\", status: \"running\" }),\n457:         makeAgentState({ feature_id: \"b\", status: \"installing\" }),\n458:         makeAgentState({ feature_id: \"c\", status: \"resolving_conflict\" }),\n459:         makeAgentState({ feature_id: \"d\", status: \"queued\" }),\n460:         makeAgentState({ feature_id: \"e\", status: \"completed\" }),\n461:       ],\n462:     });\n463:     const active = activeAgents(state);\n464:     expect(active).toHaveLength(3);\n465:     const ids = active.map((a) => a.feature_id);\n466:     expect(ids).toContain(\"a\");\n467:     expect(ids).toContain(\"b\");\n468:     expect(ids).toContain(\"c\");\n469:   });\n470: \n471:   test(\"returns empty array when no agents are active\", () => {\n472:     const state = makeWaveState({\n473:       agents: [\n474:         makeAgentState({ feature_id: \"a\", status: \"queued\" }),\n475:         makeAgentState({ feature_id: \"b\", status: \"completed\" }),\n476:       ],\n477:     });\n478:     expect(activeAgents(state)).toHaveLength(0);\n479:   });\n480: });\n481: \n482: // ---------------------------------------------------------------------------\n483: // queuedAgents\n484: // ---------------------------------------------------------------------------\n485: \n486: describe(\"queuedAgents\", () => {\n487:   test(\"returns only queued agents\", () => {\n488:     const state = makeWaveState({\n489:       agents: [\n490:         makeAgentState({ feature_id: \"a\", status: \"queued\" }),\n491:         makeAgentState({ feature_id: \"b\", status: \"running\" }),\n492:         makeAgentState({ feature_id: \"c\", status: \"queued\" }),\n493:       ],\n494:     });\n495:     const queued = queuedAgents(state);\n496:     expect(queued).toHaveLength(2);\n497:     expect(queued[0].feature_id).toBe(\"a\");\n498:     expect(queued[1].feature_id).toBe(\"c\");\n499:   });\n500: });\n501: \n502: // ---------------------------------------------------------------------------\n503: // isWaveComplete\n504: // ---------------------------------------------------------------------------\n505: \n506: describe(\"isWaveComplete\", () => {\n507:   test(\"returns true when all agents are in terminal states\", () => {\n508:     const state = makeWaveState({\n509:       agents: [\n510:         makeAgentState({ feature_id: \"a\", status: \"completed\" }),\n511:         makeAgentState({ feature_id: \"b\", status: \"verified\" }),\n512:         makeAgentState({ feature_id: \"c\", status: \"failed\" }),\n513:         makeAgentState({ feature_id: \"d\", status: \"merged\" }),\n514:       ],\n515:     });\n516:     expect(isWaveComplete(state)).toBe(true);\n517:   });\n518: \n519:   test(\"returns false when some agents are still queued\", () => {\n520:     const state = makeWaveState({\n521:       agents: [\n522:         makeAgentState({ feature_id: \"a\", status: \"completed\" }),\n523:         makeAgentState({ feature_id: \"b\", status: \"queued\" }),\n524:       ],\n525:     });\n526:     expect(isWaveComplete(state)).toBe(false);\n527:   });\n528: \n529:   test(\"returns false when some agents are still running\", () => {\n530:     const state = makeWaveState({\n531:       agents: [\n532:         makeAgentState({ feature_id: \"a\", status: \"completed\" }),\n533:         makeAgentState({ feature_id: \"b\", status: \"running\" }),\n534:       ],\n535:     });\n536:     expect(isWaveComplete(state)).toBe(false);\n537:   });\n538: \n539:   test(\"returns false when some agents are installing\", () => {\n540:     const state = makeWaveState({\n541:       agents: [\n542:         makeAgentState({ feature_id: \"a\", status: \"installing\" }),\n543:       ],\n544:     });\n545:     expect(isWaveComplete(state)).toBe(false);\n546:   });\n547: \n548:   test(\"returns false when some agents are in retry\", () => {\n549:     const state = makeWaveState({\n550:       agents: [\n551:         makeAgentState({ feature_id: \"a\", status: \"retry\" }),\n552:       ],\n553:     });\n554:     expect(isWaveComplete(state)).toBe(false);\n555:   });\n556: \n557:   test(\"returns true for empty agents list\", () => {\n558:     const state = makeWaveState({ agents: [] });\n559:     expect(isWaveComplete(state)).toBe(true);\n560:   });\n561: });\n562: \n563: // ---------------------------------------------------------------------------\n564: // Concurrent mutation patterns (save-load-modify-save cycles)\n565: // ---------------------------------------------------------------------------\n566: \n567: describe(\"concurrent mutation patterns\", () => {\n568:   test(\"multiple save-load cycles preserve data integrity\", () => {\n569:     const state = makeWaveState({\n570:       agents: [\n571:         makeAgentState({ feature_id: \"feat-a\", status: \"queued\" }),\n572:         makeAgentState({ feature_id: \"feat-b\", status: \"queued\" }),\n573:       ],\n574:     });\n575: \n576:     // Save initial state\n577:     saveState(tmpDir, state);\n578: \n579:     // Simulate agent A starting: load, modify, save\n580:     const s1 = loadState(tmpDir)!;\n581:     updateAgent(s1, \"feat-a\", { status: \"running\", pid: 1001 });\n582:     saveState(tmpDir, s1);\n583: \n584:     // Simulate agent B starting: load, modify, save\n585:     const s2 = loadState(tmpDir)!;\n586:     expect(s2.agents[0].status).toBe(\"running\"); // A's change persisted\n587:     updateAgent(s2, \"feat-b\", { status: \"running\", pid: 1002 });\n588:     saveState(tmpDir, s2);\n589: \n590:     // Final verification\n591:     const final = loadState(tmpDir)!;\n592:     expect(final.agents[0].status).toBe(\"running\");\n593:     expect(final.agents[0].pid).toBe(1001);\n594:     expect(final.agents[1].status).toBe(\"running\");\n595:     expect(final.agents[1].pid).toBe(1002);\n596:   });\n597: \n598:   test(\"rapid sequential updates don't corrupt state\", () => {\n599:     const state = makeWaveState({\n600:       agents: [makeAgentState({ feature_id: \"feat-a\", status: \"queued\" })],\n601:     });\n602: \n603:     // Rapid fire updates\n604:     const statuses: AgentStatus[] = [\n605:       \"queued\",\n606:       \"installing\",\n607:       \"running\",\n608:       \"completed\",\n609:     ];\n610:     for (const status of statuses) {\n611:       updateAgent(state, \"feat-a\", { status });\n612:       saveState(tmpDir, state);\n613:     }\n614: \n615:     const loaded = loadState(tmpDir)!;\n616:     expect(loaded.agents[0].status).toBe(\"completed\");\n617:   });\n618: \n619:   test(\"save and load with all possible agent statuses\", () => {\n620:     const allStatuses: AgentStatus[] = [\n621:       \"queued\",\n622:       \"installing\",\n623:       \"running\",\n624:       \"completed\",\n625:       \"verified\",\n626:       \"failed\",\n627:       \"merged\",\n628:       \"retry\",\n629:       \"resolving_conflict\",\n630:     ];\n631: \n632:     const agents = allStatuses.map((status, i) =>\n633:       makeAgentState({ feature_id: `feat-${i}`, status })\n634:     );\n635:     const state = makeWaveState({ agents });\n636:     saveState(tmpDir, state);\n637: \n638:     const loaded = loadState(tmpDir)!;\n639:     for (let i = 0; i < allStatuses.length; i++) {\n640:       expect(loaded.agents[i].status).toBe(allStatuses[i]);\n641:     }\n642:   });\n643: });\n\n(End of file - total 643 lines)\n</content>","title":"tests/state.test.ts","metadata":{"preview":"/**\n * state.test.ts — Unit tests for wave state persistence and mutations.\n *\n * Coverage:\n *   - saveState / loadState round-trip\n *   - Atomic write (write to .tmp then rename)\n *   - State file corruption recovery (returns null)\n *   - createWaveState / createAgentState\n *   - updateAgent with valid/invalid feature IDs\n *   - agentCounts\n *   - activeAgents / queuedAgents\n *   - isWaveComplete\n *   - generateWaveId format\n *   - Concurrent mutation patterns\n */\n\nimport { describe, test, expect, beforeEach, afterEach } from \"bun:test\";\nimport { mkdtempSync, mkdirSync, writeFileSync, readFileSync, rmSync, existsSync } from \"node:fs\";\nimport { join } from \"node:path\";\nimport { tmpdir } from \"node:os\";","truncated":false,"loaded":[]},"time":{"start":1773435845638,"end":1773435845745}}}}
{"type":"tool_use","timestamp":1773435846294,"sessionID":"ses_316fcc12bffeSBLLi3jBrbT2M4","part":{"id":"prt_ce9037c0d001mzON1bDcy5pXgx","sessionID":"ses_316fcc12bffeSBLLi3jBrbT2M4","messageID":"msg_ce9036b1f001WQ3dj9eBiOriAQ","type":"tool","callID":"toolu_vrtx_01B5x352Mrqrh9RGELxAgnfo","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-unit-test-suite/tests/worktree-filtering.test.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-unit-test-suite/tests/worktree-filtering.test.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * worktree-filtering.test.ts — Integration tests for worktree listing, filtering,\n3:  * and safety guards using real temporary git repositories.\n4:  *\n5:  * Critical coverage:\n6:  *   - listWomboWorktrees(): filters by config.git.worktreePrefix, excludes project root\n7:  *     even when project dir name starts with the prefix (e.g. \"wombo-combo\" with prefix\n8:  *     \"wombo-\", and the dangerous case \"woco-something\" with prefix \"woco-\")\n9:  *   - removeWorktree(): safety guard must never remove project root or non-worktree dirs\n10:  *   - cleanupAllWorktrees(): removes all woco worktrees, skips non-woco ones\n11:  *   - verifyConfigFiles(): ensures config files are copied into worktrees\n12:  */\n13: \n14: import { describe, test, expect, beforeEach, afterEach } from \"bun:test\";\n15: import {\n16:   mkdtempSync,\n17:   mkdirSync,\n18:   writeFileSync,\n19:   existsSync,\n20:   rmSync,\n21:   readFileSync,\n22: } from \"node:fs\";\n23: import { join, resolve, basename } from \"node:path\";\n24: import { tmpdir } from \"node:os\";\n25: import { execSync } from \"node:child_process\";\n26: import type { WomboConfig } from \"../src/config.js\";\n27: import type { WorktreeInfo } from \"../src/lib/worktree.js\";\n28: import {\n29:   listWorktrees,\n30:   listWomboWorktrees,\n31:   removeWorktree,\n32:   cleanupAllWorktrees,\n33:   verifyConfigFiles,\n34:   createWorktree,\n35: } from \"../src/lib/worktree.js\";\n36: \n37: // ---------------------------------------------------------------------------\n38: // Helpers\n39: // ---------------------------------------------------------------------------\n40: \n41: /** Run a git command synchronously in a given directory. */\n42: function git(cmd: string, cwd: string): string {\n43:   return execSync(`git ${cmd}`, {\n44:     cwd,\n45:     encoding: \"utf-8\",\n46:     stdio: [\"pipe\", \"pipe\", \"pipe\"],\n47:   }).trim();\n48: }\n49: \n50: /**\n51:  * Create a minimal WomboConfig for testing.\n52:  * worktreePrefix defaults to \"woco-\" to test the dangerous prefix collision cases.\n53:  */\n54: function makeConfig(\n55:   overrides?: Partial<WomboConfig[\"git\"]>,\n56:   agentOverrides?: Partial<WomboConfig[\"agent\"]>\n57: ): WomboConfig {\n58:   return {\n59:     tasksDir: \"tasks\",\n60:     archiveDir: \"archive\",\n61:     baseBranch: \"main\",\n62:     build: { command: \"echo build\", timeout: 300_000, artifactDir: \"dist\" },\n63:     install: { command: \"echo install\", timeout: 120_000 },\n64:     git: {\n65:       branchPrefix: \"feature/\",\n66:       worktreePrefix: \"woco-\",\n67:       remote: \"origin\",\n68:       mergeStrategy: \"--no-ff\",\n69:       ...overrides,\n70:     },\n71:     agent: {\n72:       bin: null,\n73:       name: \"generalist-agent\",\n74:       configFiles: [\".opencode/\", \"opencode.json\", \"AGENTS.md\"],\n75:       tmuxPrefix: \"wombo\",\n76:       multiplexer: \"auto\",\n77:       ...agentOverrides,\n78:     },\n79:     portless: {\n80:       enabled: true,\n81:       bin: null,\n82:       proxyPort: 1355,\n83:       https: false,\n84:     },\n85:     backup: { maxBackups: 5 },\n86:     defaults: { maxConcurrent: 6, maxRetries: 2 },\n87:     browser: {\n88:       enabled: false,\n89:       bin: null,\n90:       headless: true,\n91:       testCommand: null,\n92:       launchTimeout: 30_000,\n93:       testTimeout: 60_000,\n94:       defaultViewport: { width: 1280, height: 720 },\n95:     },\n96:     agentRegistry: {\n97:       mode: \"auto\",\n98:       source: \"msitarzewski/agency-agents\",\n99:       cacheDir: \"agents-cache\",\n100:     },\n101:   };\n102: }\n103: \n104: /**\n105:  * Create a temporary git repository with an initial commit.\n106:  * Returns the absolute path to the repo root.\n107:  * The directory name can be customized to test prefix collisions.\n108:  */\n109: function createTempGitRepo(dirName?: string): string {\n110:   const parentDir = mkdtempSync(join(tmpdir(), \"wombo-wt-test-\"));\n111:   const repoDir = dirName ? join(parentDir, dirName) : parentDir;\n112: \n113:   if (dirName) {\n114:     mkdirSync(repoDir, { recursive: true });\n115:   }\n116: \n117:   git(\"init -b main\", repoDir);\n118:   git(\"config user.email test@test.com\", repoDir);\n119:   git(\"config user.name Test\", repoDir);\n120:   writeFileSync(join(repoDir, \"README.md\"), \"# Test\\n\");\n121:   git(\"add .\", repoDir);\n122:   git('commit -m \"initial\"', repoDir);\n123: \n124:   return repoDir;\n125: }\n126: \n127: /**\n128:  * Clean up a temp directory tree.\n129:  * Handles the case where git worktrees need pruning first.\n130:  */\n131: function cleanupTempDir(dir: string): void {\n132:   try {\n133:     // Prune worktrees first to avoid lock issues\n134:     git(\"worktree prune\", dir);\n135:   } catch {\n136:     // Repo might be gone already\n137:   }\n138:   try {\n139:     rmSync(dir, { recursive: true, force: true });\n140:   } catch {\n141:     // Best effort cleanup\n142:   }\n143: }\n144: \n145: // ---------------------------------------------------------------------------\n146: // listWomboWorktrees — real git repo integration tests\n147: // ---------------------------------------------------------------------------\n148: \n149: describe(\"listWomboWorktrees — real git integration\", () => {\n150:   let repoDir: string;\n151:   let parentDir: string;\n152: \n153:   afterEach(() => {\n154:     if (repoDir) {\n155:       // Clean up worktrees before removing the parent dir\n156:       try {\n157:         const worktrees = listWorktrees(repoDir);\n158:         for (const wt of worktrees) {\n159:           if (resolve(wt.path) !== resolve(repoDir)) {\n160:             try {\n161:               git(`worktree remove --force \"${wt.path}\"`, repoDir);\n162:             } catch {\n163:               // best effort\n164:             }\n165:           }\n166:         }\n167:       } catch {\n168:         // repo may be gone\n169:       }\n170:       cleanupTempDir(resolve(repoDir, \"..\"));\n171:     }\n172:   });\n173: \n174:   test(\"returns empty list for repo with no worktrees\", () => {\n175:     repoDir = createTempGitRepo(\"my-project\");\n176:     const config = makeConfig();\n177:     const result = listWomboWorktrees(repoDir, config);\n178:     expect(result).toHaveLength(0);\n179:   });\n180: \n181:   test(\"lists worktrees matching the prefix\", () => {\n182:     repoDir = createTempGitRepo(\"my-project\");\n183:     parentDir = resolve(repoDir, \"..\");\n184:     const config = makeConfig();\n185: \n186:     // Create a feature branch and worktree with matching prefix\n187:     git(\"branch feature/auth main\", repoDir);\n188:     const wtPath = join(parentDir, \"woco-auth\");\n189:     git(`worktree add \"${wtPath}\" feature/auth`, repoDir);\n190: \n191:     const result = listWomboWorktrees(repoDir, config);\n192:     expect(result).toHaveLength(1);\n193:     expect(result[0].path).toBe(wtPath);\n194:     expect(result[0].branch).toBe(\"feature/auth\");\n195:   });\n196: \n197:   test(\"excludes worktrees that don't match the prefix\", () => {\n198:     repoDir = createTempGitRepo(\"my-project\");\n199:     parentDir = resolve(repoDir, \"..\");\n200:     const config = makeConfig();\n201: \n202:     // Create worktrees with and without matching prefix\n203:     git(\"branch feature/auth main\", repoDir);\n204:     git(\"branch feature/other main\", repoDir);\n205:     const wocoPath = join(parentDir, \"woco-auth\");\n206:     const otherPath = join(parentDir, \"other-worktree\");\n207:     git(`worktree add \"${wocoPath}\" feature/auth`, repoDir);\n208:     git(`worktree add \"${otherPath}\" feature/other`, repoDir);\n209: \n210:     const result = listWomboWorktrees(repoDir, config);\n211:     expect(result).toHaveLength(1);\n212:     expect(result[0].path).toBe(wocoPath);\n213:   });\n214: \n215:   test(\"excludes project root even when its name starts with the prefix\", () => {\n216:     // DANGEROUS CASE: project directory is named \"woco-something\"\n217:     // and prefix is \"woco-\". The project root basename starts with the prefix!\n218:     repoDir = createTempGitRepo(\"woco-something\");\n219:     parentDir = resolve(repoDir, \"..\");\n220:     const config = makeConfig();\n221: \n222:     // Project root basename is \"woco-something\" which starts with \"woco-\"\n223:     expect(basename(repoDir).startsWith(config.git.worktreePrefix)).toBe(true);\n224: \n225:     // Create a legitimate woco worktree\n226:     git(\"branch feature/auth main\", repoDir);\n227:     const wtPath = join(parentDir, \"woco-auth\");\n228:     git(`worktree add \"${wtPath}\" feature/auth`, repoDir);\n229: \n230:     const result = listWomboWorktrees(repoDir, config);\n231: \n232:     // The project root \"woco-something\" must NOT be in the result\n233:     const resultPaths = result.map((w) => resolve(w.path));\n234:     expect(resultPaths).not.toContain(resolve(repoDir));\n235: \n236:     // Only the legitimate worktree should be included\n237:     expect(result).toHaveLength(1);\n238:     expect(result[0].path).toBe(wtPath);\n239:   });\n240: \n241:   test(\"excludes project root named 'wombo-combo' with prefix 'wombo-'\", () => {\n242:     // Classic case: \"wombo-combo\" project dir name contains \"wombo-\" prefix\n243:     repoDir = createTempGitRepo(\"wombo-combo\");\n244:     parentDir = resolve(repoDir, \"..\");\n245:     const config = makeConfig({ worktreePrefix: \"wombo-\" });\n246: \n247:     expect(basename(repoDir).startsWith(config.git.worktreePrefix)).toBe(true);\n248: \n249:     // Create two legitimate worktrees\n250:     git(\"branch feature/auth main\", repoDir);\n251:     git(\"branch feature/search main\", repoDir);\n252:     const wt1 = join(parentDir, \"wombo-auth\");\n253:     const wt2 = join(parentDir, \"wombo-search\");\n254:     git(`worktree add \"${wt1}\" feature/auth`, repoDir);\n255:     git(`worktree add \"${wt2}\" feature/search`, repoDir);\n256: \n257:     const result = listWomboWorktrees(repoDir, config);\n258: \n259:     // Project root must NOT appear\n260:     const resultPaths = result.map((w) => resolve(w.path));\n261:     expect(resultPaths).not.toContain(resolve(repoDir));\n262: \n263:     // Both legitimate worktrees should be present\n264:     expect(result).toHaveLength(2);\n265:     expect(resultPaths).toContain(resolve(wt1));\n266:     expect(resultPaths).toContain(resolve(wt2));\n267:   });\n268: \n269:   test(\"handles multiple worktrees with mixed prefixes\", () => {\n270:     repoDir = createTempGitRepo(\"my-project\");\n271:     parentDir = resolve(repoDir, \"..\");\n272:     const config = makeConfig();\n273: \n274:     // Create branches\n275:     git(\"branch feature/a main\", repoDir);\n276:     git(\"branch feature/b main\", repoDir);\n277:     git(\"branch feature/c main\", repoDir);\n278: \n279:     // Create worktrees: 2 match \"woco-\", 1 does not\n280:     const wt1 = join(parentDir, \"woco-a\");\n281:     const wt2 = join(parentDir, \"woco-b\");\n282:     const wt3 = join(parentDir, \"other-c\");\n283:     git(`worktree add \"${wt1}\" feature/a`, repoDir);\n284:     git(`worktree add \"${wt2}\" feature/b`, repoDir);\n285:     git(`worktree add \"${wt3}\" feature/c`, repoDir);\n286: \n287:     const result = listWomboWorktrees(repoDir, config);\n288:     expect(result).toHaveLength(2);\n289:     const paths = result.map((w) => w.path);\n290:     expect(paths).toContain(wt1);\n291:     expect(paths).toContain(wt2);\n292:     expect(paths).not.toContain(wt3);\n293:   });\n294: \n295:   test(\"works with custom worktree prefix\", () => {\n296:     repoDir = createTempGitRepo(\"my-project\");\n297:     parentDir = resolve(repoDir, \"..\");\n298:     const config = makeConfig({ worktreePrefix: \"wt-\" });\n299: \n300:     git(\"branch feature/auth main\", repoDir);\n301:     git(\"branch feature/other main\", repoDir);\n302:     const wtMatch = join(parentDir, \"wt-auth\");\n303:     const wtNoMatch = join(parentDir, \"woco-other\");\n304:     git(`worktree add \"${wtMatch}\" feature/auth`, repoDir);\n305:     git(`worktree add \"${wtNoMatch}\" feature/other`, repoDir);\n306: \n307:     const result = listWomboWorktrees(repoDir, config);\n308:     expect(result).toHaveLength(1);\n309:     expect(result[0].path).toBe(wtMatch);\n310:   });\n311: });\n312: \n313: // ---------------------------------------------------------------------------\n314: // removeWorktree — safety guard tests\n315: // ---------------------------------------------------------------------------\n316: \n317: describe(\"removeWorktree — safety guard (integration)\", () => {\n318:   let repoDir: string;\n319: \n320:   afterEach(() => {\n321:     if (repoDir) {\n322:       cleanupTempDir(resolve(repoDir, \"..\"));\n323:     }\n324:   });\n325: \n326:   test(\"throws when asked to remove project root (exact match)\", () => {\n327:     repoDir = createTempGitRepo(\"my-project\");\n328:     expect(() => removeWorktree(repoDir, repoDir)).toThrow(\n329:       \"SAFETY: refusing to remove project root\"\n330:     );\n331:   });\n332: \n333:   test(\"throws when asked to remove project root with resolved relative path\", () => {\n334:     repoDir = createTempGitRepo(\"my-project\");\n335:     const messyPath = join(repoDir, \".\", \"subdir\", \"..\");\n336:     expect(() => removeWorktree(repoDir, messyPath)).toThrow(\n337:       \"SAFETY: refusing to remove project root\"\n338:     );\n339:   });\n340: \n341:   test(\"throws when asked to remove project root with trailing slash\", () => {\n342:     repoDir = createTempGitRepo(\"my-project\");\n343:     expect(() => removeWorktree(repoDir, repoDir + \"/\")).toThrow(\n344:       \"SAFETY: refusing to remove project root\"\n345:     );\n346:   });\n347: \n348:   test(\"throws when project root name starts with prefix (woco-something)\", () => {\n349:     // The dangerous case: project dir IS named \"woco-something\"\n350:     repoDir = createTempGitRepo(\"woco-my-project\");\n351:     expect(() => removeWorktree(repoDir, repoDir)).toThrow(\n352:       \"SAFETY: refusing to remove project root\"\n353:     );\n354:   });\n355: \n356:   test(\"successfully removes a legitimate worktree\", () => {\n357:     repoDir = createTempGitRepo(\"my-project\");\n358:     const parentDir = resolve(repoDir, \"..\");\n359: \n360:     // Create a worktree\n361:     git(\"branch feature/temp main\", repoDir);\n362:     const wtPath = join(parentDir, \"woco-temp\");\n363:     git(`worktree add \"${wtPath}\" feature/temp`, repoDir);\n364: \n365:     // Verify worktree exists\n366:     expect(existsSync(wtPath)).toBe(true);\n367: \n368:     // Remove it\n369:     removeWorktree(repoDir, wtPath, true);\n370: \n371:     // Verify it's gone\n372:     expect(existsSync(wtPath)).toBe(false);\n373:   });\n374: \n375:   test(\"removes worktree and deletes branch when deleteBranchToo=true\", () => {\n376:     repoDir = createTempGitRepo(\"my-project\");\n377:     const parentDir = resolve(repoDir, \"..\");\n378: \n379:     git(\"branch feature/delete-me main\", repoDir);\n380:     const wtPath = join(parentDir, \"woco-delete-me\");\n381:     git(`worktree add \"${wtPath}\" feature/delete-me`, repoDir);\n382: \n383:     removeWorktree(repoDir, wtPath, true);\n384: \n385:     // Branch should be deleted\n386:     const branches = git(\"branch --list feature/delete-me\", repoDir);\n387:     expect(branches).toBe(\"\");\n388:   });\n389: \n390:   test(\"removes worktree but keeps branch when deleteBranchToo=false\", () => {\n391:     repoDir = createTempGitRepo(\"my-project\");\n392:     const parentDir = resolve(repoDir, \"..\");\n393: \n394:     git(\"branch feature/keep-branch main\", repoDir);\n395:     const wtPath = join(parentDir, \"woco-keep-branch\");\n396:     git(`worktree add \"${wtPath}\" feature/keep-branch`, repoDir);\n397: \n398:     removeWorktree(repoDir, wtPath, false);\n399: \n400:     // Branch should still exist\n401:     const branches = git(\"branch --list feature/keep-branch\", repoDir);\n402:     expect(branches.trim()).toContain(\"feature/keep-branch\");\n403:   });\n404: });\n405: \n406: // ---------------------------------------------------------------------------\n407: // cleanupAllWorktrees — removes woco worktrees, skips non-woco ones\n408: // ---------------------------------------------------------------------------\n409: \n410: describe(\"cleanupAllWorktrees — selective cleanup\", () => {\n411:   let repoDir: string;\n412: \n413:   afterEach(() => {\n414:     if (repoDir) {\n415:       // Clean up any remaining worktrees\n416:       try {\n417:         const worktrees = listWorktrees(repoDir);\n418:         for (const wt of worktrees) {\n419:           if (resolve(wt.path) !== resolve(repoDir)) {\n420:             try {\n421:               git(`worktree remove --force \"${wt.path}\"`, repoDir);\n422:             } catch {\n423:               // best effort\n424:             }\n425:           }\n426:         }\n427:       } catch {\n428:         // repo may be gone\n429:       }\n430:       cleanupTempDir(resolve(repoDir, \"..\"));\n431:     }\n432:   });\n433: \n434:   test(\"removes all worktrees matching the prefix\", () => {\n435:     repoDir = createTempGitRepo(\"my-project\");\n436:     const parentDir = resolve(repoDir, \"..\");\n437:     const config = makeConfig();\n438: \n439:     // Create two woco worktrees\n440:     git(\"branch feature/a main\", repoDir);\n441:     git(\"branch feature/b main\", repoDir);\n442:     const wt1 = join(parentDir, \"woco-a\");\n443:     const wt2 = join(parentDir, \"woco-b\");\n444:     git(`worktree add \"${wt1}\" feature/a`, repoDir);\n445:     git(`worktree add \"${wt2}\" feature/b`, repoDir);\n446: \n447:     const removed = cleanupAllWorktrees(repoDir, config);\n448: \n449:     expect(removed).toBe(2);\n450:     expect(existsSync(wt1)).toBe(false);\n451:     expect(existsSync(wt2)).toBe(false);\n452:   });\n453: \n454:   test(\"skips worktrees that don't match the prefix\", () => {\n455:     repoDir = createTempGitRepo(\"my-project\");\n456:     const parentDir = resolve(repoDir, \"..\");\n457:     const config = makeConfig();\n458: \n459:     // Create one woco and one non-woco worktree\n460:     git(\"branch feature/woco main\", repoDir);\n461:     git(\"branch feature/other main\", repoDir);\n462:     const wocoWt = join(parentDir, \"woco-feature\");\n463:     const otherWt = join(parentDir, \"other-feature\");\n464:     git(`worktree add \"${wocoWt}\" feature/woco`, repoDir);\n465:     git(`worktree add \"${otherWt}\" feature/other`, repoDir);\n466: \n467:     const removed = cleanupAllWorktrees(repoDir, config);\n468: \n469:     expect(removed).toBe(1);\n470:     expect(existsSync(wocoWt)).toBe(false);\n471:     // Non-woco worktree should still exist\n472:     expect(existsSync(otherWt)).toBe(true);\n473:   });\n474: \n475:   test(\"never removes project root even when name starts with prefix\", () => {\n476:     // CRITICAL: project named \"woco-dangerous\" with prefix \"woco-\"\n477:     repoDir = createTempGitRepo(\"woco-dangerous\");\n478:     const parentDir = resolve(repoDir, \"..\");\n479:     const config = makeConfig();\n480: \n481:     // Create a legitimate worktree\n482:     git(\"branch feature/safe main\", repoDir);\n483:     const wtPath = join(parentDir, \"woco-safe\");\n484:     git(`worktree 