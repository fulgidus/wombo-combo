{"type":"tool_use","timestamp":1773435952892,"sessionID":"ses_316fcc12bffeSBLLi3jBrbT2M4","part":{"id":"prt_ce9051be2001J011Vj2WSMAXiO","sessionID":"ses_316fcc12bffeSBLLi3jBrbT2M4","messageID":"msg_ce9051057001VoYtJbo61pWv0e","type":"tool","callID":"toolu_vrtx_01WskhYmeomtXEfkPNzypAdP","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-unit-test-suite/src/lib/task-schema.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-unit-test-suite/src/lib/task-schema.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * task-schema.ts — Single source of truth for task field enums, ordering,\n3:  * required fields, and validation.\n4:  *\n5:  * Every command that needs to validate or enumerate task field values should\n6:  * import from here. No more duplicated VALID_* arrays.\n7:  */\n8: \n9: import type { TaskStatus, Priority, Difficulty, Task } from \"./tasks.js\";\n10: import { parseDurationMinutes } from \"./tasks.js\";\n11: import { validateId, type ValidationResult } from \"./validate.js\";\n12: \n13: // ---------------------------------------------------------------------------\n14: // Canonical enum arrays (order matters: used for display and sorting)\n15: // ---------------------------------------------------------------------------\n16: \n17: export const VALID_STATUSES: readonly TaskStatus[] = [\n18:   \"backlog\",\n19:   \"planned\",\n20:   \"in_progress\",\n21:   \"blocked\",\n22:   \"in_review\",\n23:   \"done\",\n24:   \"cancelled\",\n25: ] as const;\n26: \n27: export const VALID_PRIORITIES: readonly Priority[] = [\n28:   \"critical\",\n29:   \"high\",\n30:   \"medium\",\n31:   \"low\",\n32:   \"wishlist\",\n33: ] as const;\n34: \n35: export const VALID_DIFFICULTIES: readonly Difficulty[] = [\n36:   \"trivial\",\n37:   \"easy\",\n38:   \"medium\",\n39:   \"hard\",\n40:   \"very_hard\",\n41: ] as const;\n42: \n43: // ---------------------------------------------------------------------------\n44: // Ordering maps (lower = more important / easier)\n45: // ---------------------------------------------------------------------------\n46: \n47: export const PRIORITY_ORDER: Readonly<Record<Priority, number>> = {\n48:   critical: 0,\n49:   high: 1,\n50:   medium: 2,\n51:   low: 3,\n52:   wishlist: 4,\n53: };\n54: \n55: export const DIFFICULTY_ORDER: Readonly<Record<Difficulty, number>> = {\n56:   trivial: 0,\n57:   easy: 1,\n58:   medium: 2,\n59:   hard: 3,\n60:   very_hard: 4,\n61: };\n62: \n63: // ---------------------------------------------------------------------------\n64: // _meta.yml schema\n65: // ---------------------------------------------------------------------------\n66: \n67: export interface MetaSchema {\n68:   version: string;\n69:   meta: {\n70:     created_at: string;\n71:     updated_at: string;\n72:     project: string;\n73:     generator: string;\n74:     maintainer: string;\n75:   };\n76: }\n77: \n78: export const META_REQUIRED_FIELDS = [\"version\", \"meta\"] as const;\n79: export const META_INNER_REQUIRED_FIELDS = [\n80:   \"created_at\",\n81:   \"updated_at\",\n82:   \"project\",\n83:   \"generator\",\n84:   \"maintainer\",\n85: ] as const;\n86: \n87: // ---------------------------------------------------------------------------\n88: // Task schema — required fields and array-defaulted fields\n89: // ---------------------------------------------------------------------------\n90: \n91: export const TASK_REQUIRED_FIELDS = [\"id\", \"title\", \"status\"] as const;\n92: \n93: /** Fields that must be arrays; YAML may parse absent values as null */\n94: export const TASK_ARRAY_FIELDS = [\n95:   \"depends_on\",\n96:   \"constraints\",\n97:   \"forbidden\",\n98:   \"references\",\n99:   \"notes\",\n100:   \"subtasks\",\n101: ] as const;\n102: \n103: // ---------------------------------------------------------------------------\n104: // Validation result\n105: // ---------------------------------------------------------------------------\n106: \n107: export interface SchemaIssue {\n108:   level: \"error\" | \"warning\";\n109:   taskId: string;\n110:   message: string;\n111: }\n112: \n113: // ---------------------------------------------------------------------------\n114: // Validate a single task object\n115: // ---------------------------------------------------------------------------\n116: \n117: /**\n118:  * Validate a task against the schema. Returns a list of issues (errors and\n119:  * warnings). Does NOT throw — callers decide how to handle issues.\n120:  *\n121:  * Checks:\n122:  *   - Required fields: id, title, status\n123:  *   - id format (kebab-case via validateId)\n124:  *   - status is a valid enum\n125:  *   - priority is a valid enum (if present)\n126:  *   - difficulty is a valid enum (if present)\n127:  *   - effort is a parseable ISO 8601 duration (warning if not)\n128:  *   - completion is 0-100 (warning if out of range)\n129:  *   - depends_on entries are strings (structural check only; cross-ref is\n130:  *     done by check.ts which has access to the full task set)\n131:  */\n132: export function validateTask(task: unknown): SchemaIssue[] {\n133:   const issues: SchemaIssue[] = [];\n134:   const t = task as Record<string, unknown>;\n135:   const id = typeof t?.id === \"string\" ? t.id : \"<unknown>\";\n136: \n137:   // Required fields\n138:   for (const field of TASK_REQUIRED_FIELDS) {\n139:     if (!t?.[field]) {\n140:       issues.push({ level: \"error\", taskId: id, message: `Missing required field: ${field}` });\n141:     }\n142:   }\n143: \n144:   // id format\n145:   if (typeof t?.id === \"string\") {\n146:     const idResult: ValidationResult = validateId(t.id, \"Task ID\");\n147:     if (!idResult.valid) {\n148:       issues.push({ level: \"error\", taskId: id, message: idResult.error! });\n149:     }\n150:   }\n151: \n152:   // status enum\n153:   if (t?.status && !(VALID_STATUSES as readonly string[]).includes(t.status as string)) {\n154:     issues.push({ level: \"error\", taskId: id, message: `Invalid status: \"${t.status}\"` });\n155:   }\n156: \n157:   // priority enum\n158:   if (t?.priority && !(VALID_PRIORITIES as readonly string[]).includes(t.priority as string)) {\n159:     issues.push({ level: \"error\", taskId: id, message: `Invalid priority: \"${t.priority}\"` });\n160:   }\n161: \n162:   // difficulty enum\n163:   if (t?.difficulty && !(VALID_DIFFICULTIES as readonly string[]).includes(t.difficulty as string)) {\n164:     issues.push({ level: \"error\", taskId: id, message: `Invalid difficulty: \"${t.difficulty}\"` });\n165:   }\n166: \n167:   // effort duration\n168:   if (typeof t?.effort === \"string\" && t.effort.length > 0) {\n169:     const minutes = parseDurationMinutes(t.effort);\n170:     if (minutes === Infinity) {\n171:       issues.push({ level: \"warning\", taskId: id, message: `Unparseable effort duration: \"${t.effort}\"` });\n172:     }\n173:   } else if (!t?.effort || t.effort === \"PT0S\") {\n174:     issues.push({ level: \"warning\", taskId: id, message: \"No effort estimate\" });\n175:   }\n176: \n177:   // completion range\n178:   if (typeof t?.completion === \"number\" && (t.completion < 0 || t.completion > 100)) {\n179:     issues.push({ level: \"warning\", taskId: id, message: `Completion ${t.completion} is out of range 0-100` });\n180:   }\n181: \n182:   // depends_on structural check\n183:   if (t?.depends_on != null && !Array.isArray(t.depends_on)) {\n184:     issues.push({ level: \"error\", taskId: id, message: \"depends_on must be an array\" });\n185:   }\n186: \n187:   return issues;\n188: }\n189: \n190: // ---------------------------------------------------------------------------\n191: // Validate _meta.yml\n192: // ---------------------------------------------------------------------------\n193: \n194: /**\n195:  * Validate a parsed _meta.yml object. Returns issues.\n196:  */\n197: export function validateMeta(meta: unknown): SchemaIssue[] {\n198:   const issues: SchemaIssue[] = [];\n199:   const m = meta as Record<string, unknown>;\n200:   const id = \"_meta.yml\";\n201: \n202:   if (!m?.version) {\n203:     issues.push({ level: \"error\", taskId: id, message: \"Missing required field: version\" });\n204:   }\n205: \n206:   if (!m?.meta || typeof m.meta !== \"object\") {\n207:     issues.push({ level: \"error\", taskId: id, message: \"Missing required field: meta\" });\n208:     return issues; // Can't check inner fields\n209:   }\n210: \n211:   const inner = m.meta as Record<string, unknown>;\n212:   for (const field of META_INNER_REQUIRED_FIELDS) {\n213:     if (!inner[field]) {\n214:       issues.push({ level: \"warning\", taskId: id, message: `Missing meta field: ${field}` });\n215:     }\n216:   }\n217: \n218:   return issues;\n219: }\n\n(End of file - total 219 lines)\n</content>","title":"src/lib/task-schema.ts","metadata":{"preview":"/**\n * task-schema.ts — Single source of truth for task field enums, ordering,\n * required fields, and validation.\n *\n * Every command that needs to validate or enumerate task field values should\n * import from here. No more duplicated VALID_* arrays.\n */\n\nimport type { TaskStatus, Priority, Difficulty, Task } from \"./tasks.js\";\nimport { parseDurationMinutes } from \"./tasks.js\";\nimport { validateId, type ValidationResult } from \"./validate.js\";\n\n// ---------------------------------------------------------------------------\n// Canonical enum arrays (order matters: used for display and sorting)\n// ---------------------------------------------------------------------------\n\nexport const VALID_STATUSES: readonly TaskStatus[] = [\n  \"backlog\",\n  \"planned\",\n  \"in_progress\",","truncated":false,"loaded":[]},"time":{"start":1773435952889,"end":1773435952891}}}}
{"type":"tool_use","timestamp":1773435953442,"sessionID":"ses_316fcc12bffeSBLLi3jBrbT2M4","part":{"id":"prt_ce9051f6c001fHAhsE39NljGNQ","sessionID":"ses_316fcc12bffeSBLLi3jBrbT2M4","messageID":"msg_ce9051057001VoYtJbo61pWv0e","type":"tool","callID":"toolu_vrtx_01UWfdtANfLudWK8YnJiZyiU","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-unit-test-suite/src/lib/validate.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-unit-test-suite/src/lib/validate.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * validate.ts — Input validation / hardening for agent-ready CLI.\n3:  *\n4:  * All user/agent-supplied inputs pass through these validators at the CLI\n5:  * boundary. This prevents hallucinated inputs from corrupting state.\n6:  *\n7:  * Rules:\n8:  *   - Feature IDs: kebab-case only, no path traversals, no query params\n9:  *   - Branch names: no control chars, no \"..\", no spaces\n10:  *   - Free-text (titles, descriptions): no control chars except \\n \\t\n11:  *   - Effort strings: ISO 8601 duration pattern only\n12:  */\n13: \n14: // ---------------------------------------------------------------------------\n15: // Patterns\n16: // ---------------------------------------------------------------------------\n17: \n18: /** Valid feature/subtask ID: lowercase alphanumeric + hyphens, 1-128 chars */\n19: const ID_PATTERN = /^[a-z0-9][a-z0-9-]{0,127}$/;\n20: \n21: /** Control characters below space, excluding \\t (0x09) and \\n (0x0a) */\n22: const CONTROL_CHARS = /[\\x00-\\x08\\x0b\\x0c\\x0e-\\x1f\\x7f]/;\n23: \n24: /** Path traversal sequences */\n25: const PATH_TRAVERSAL = /\\.\\.\\//;\n26: \n27: /** Embedded query params or fragments */\n28: const QUERY_FRAGMENT = /[?#]/;\n29: \n30: /** Percent-encoded sequences (indicates double-encoding risk) */\n31: const PERCENT_ENCODED = /%[0-9a-fA-F]{2}/;\n32: \n33: /** ISO 8601 duration: P[nY][nM][nD][T[nH][nM][nS]] */\n34: const DURATION_PATTERN = /^P(?:\\d+Y)?(?:\\d+M)?(?:\\d+D)?(?:T(?:\\d+H)?(?:\\d+M)?(?:\\d+S)?)?$/;\n35: \n36: // ---------------------------------------------------------------------------\n37: // Result type\n38: // ---------------------------------------------------------------------------\n39: \n40: export interface ValidationResult {\n41:   valid: boolean;\n42:   error?: string;\n43: }\n44: \n45: function ok(): ValidationResult {\n46:   return { valid: true };\n47: }\n48: \n49: function fail(error: string): ValidationResult {\n50:   return { valid: false, error };\n51: }\n52: \n53: // ---------------------------------------------------------------------------\n54: // Validators\n55: // ---------------------------------------------------------------------------\n56: \n57: /**\n58:  * Validate a feature or subtask ID.\n59:  * Must be kebab-case, no traversals, no query params, no encoded chars.\n60:  */\n61: export function validateId(value: string, label: string = \"ID\"): ValidationResult {\n62:   if (!value || value.length === 0) {\n63:     return fail(`${label} must not be empty.`);\n64:   }\n65: \n66:   if (CONTROL_CHARS.test(value)) {\n67:     return fail(`${label} contains control characters.`);\n68:   }\n69: \n70:   if (PATH_TRAVERSAL.test(value)) {\n71:     return fail(`${label} contains path traversal sequence \"../\".`);\n72:   }\n73: \n74:   if (QUERY_FRAGMENT.test(value)) {\n75:     return fail(`${label} contains query/fragment characters (? or #).`);\n76:   }\n77: \n78:   if (PERCENT_ENCODED.test(value)) {\n79:     return fail(`${label} contains percent-encoded characters — possible double-encoding.`);\n80:   }\n81: \n82:   if (!ID_PATTERN.test(value)) {\n83:     return fail(\n84:       `${label} \"${value}\" is invalid. IDs must be kebab-case ` +\n85:       `(lowercase letters, digits, hyphens), 1–128 characters, starting with a letter or digit.`\n86:     );\n87:   }\n88: \n89:   return ok();\n90: }\n91: \n92: /**\n93:  * Validate free-text input (titles, descriptions, notes).\n94:  * Rejects control chars except \\t and \\n.\n95:  */\n96: export function validateText(value: string, label: string = \"text\"): ValidationResult {\n97:   if (CONTROL_CHARS.test(value)) {\n98:     return fail(`${label} contains control characters (non-printable bytes).`);\n99:   }\n100:   return ok();\n101: }\n102: \n103: /**\n104:  * Validate a branch name.\n105:  * No control chars, no \"..\", no spaces, no ~, ^, :, \\, ?, *, [\n106:  */\n107: export function validateBranchName(value: string, label: string = \"branch name\"): ValidationResult {\n108:   if (!value || value.length === 0) {\n109:     return fail(`${label} must not be empty.`);\n110:   }\n111: \n112:   if (CONTROL_CHARS.test(value)) {\n113:     return fail(`${label} contains control characters.`);\n114:   }\n115: \n116:   if (/\\.\\./.test(value)) {\n117:     return fail(`${label} contains \"..\" which is not allowed in git branch names.`);\n118:   }\n119: \n120:   if (/[ ~^:\\\\?*\\[]/.test(value)) {\n121:     return fail(`${label} contains characters not allowed in git branch names.`);\n122:   }\n123: \n124:   return ok();\n125: }\n126: \n127: /**\n128:  * Validate an ISO 8601 duration string.\n129:  */\n130: export function validateDuration(value: string, label: string = \"effort\"): ValidationResult {\n131:   if (!value || value.length === 0) {\n132:     return fail(`${label} must not be empty.`);\n133:   }\n134: \n135:   if (!DURATION_PATTERN.test(value)) {\n136:     return fail(\n137:       `${label} \"${value}\" is not a valid ISO 8601 duration. ` +\n138:       `Expected format: P[nY][nM][nD][T[nH][nM][nS]] (e.g., \"PT2H\", \"P1D\", \"P1DT4H30M\").`\n139:     );\n140:   }\n141: \n142:   return ok();\n143: }\n144: \n145: /**\n146:  * Validate a status value against the allowed set.\n147:  */\n148: export function validateEnum(\n149:   value: string,\n150:   allowed: readonly string[],\n151:   label: string = \"value\"\n152: ): ValidationResult {\n153:   if (!allowed.includes(value)) {\n154:     return fail(`${label} \"${value}\" is not valid. Allowed values: ${allowed.join(\", \")}`);\n155:   }\n156:   return ok();\n157: }\n158: \n159: // ---------------------------------------------------------------------------\n160: // Convenience: validate and exit on failure\n161: // ---------------------------------------------------------------------------\n162: \n163: /**\n164:  * Run a validation and exit with error message if invalid.\n165:  * For use at the CLI boundary.\n166:  */\n167: export function assertValid(result: ValidationResult): void {\n168:   if (!result.valid) {\n169:     console.error(`Validation error: ${result.error}`);\n170:     process.exit(1);\n171:   }\n172: }\n\n(End of file - total 172 lines)\n</content>","title":"src/lib/validate.ts","metadata":{"preview":"/**\n * validate.ts — Input validation / hardening for agent-ready CLI.\n *\n * All user/agent-supplied inputs pass through these validators at the CLI\n * boundary. This prevents hallucinated inputs from corrupting state.\n *\n * Rules:\n *   - Feature IDs: kebab-case only, no path traversals, no query params\n *   - Branch names: no control chars, no \"..\", no spaces\n *   - Free-text (titles, descriptions): no control chars except \\n \\t\n *   - Effort strings: ISO 8601 duration pattern only\n */\n\n// ---------------------------------------------------------------------------\n// Patterns\n// ---------------------------------------------------------------------------\n\n/** Valid feature/subtask ID: lowercase alphanumeric + hyphens, 1-128 chars */\nconst ID_PATTERN = /^[a-z0-9][a-z0-9-]{0,127}$/;\n","truncated":false,"loaded":[]},"time":{"start":1773435953434,"end":1773435953441}}}}
{"type":"text","timestamp":1773435953816,"sessionID":"ses_316fcc12bffeSBLLi3jBrbT2M4","part":{"id":"prt_ce9051970001Fv6HAYaARsh8AM","sessionID":"ses_316fcc12bffeSBLLi3jBrbT2M4","messageID":"msg_ce9051057001VoYtJbo61pWv0e","type":"text","text":"Now let me look at the source modules I need to test. Let me read the key files I plan to write tests for:","time":{"start":1773435953816,"end":1773435953816}}}
{"type":"tool_use","timestamp":1773435953819,"sessionID":"ses_316fcc12bffeSBLLi3jBrbT2M4","part":{"id":"prt_ce905211b0019TviNT6kbobkGe","sessionID":"ses_316fcc12bffeSBLLi3jBrbT2M4","messageID":"msg_ce9051057001VoYtJbo61pWv0e","type":"tool","callID":"toolu_vrtx_01WVvEJujwjMDDgZDCoeTsqG","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-unit-test-suite/src/lib/output.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-unit-test-suite/src/lib/output.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * output.ts — Shared output helpers for agent-ready CLI.\n3:  *\n4:  * Provides a centralized way for commands to emit structured data that\n5:  * renders as human-readable text on TTY or as JSON when --output json\n6:  * is specified (or when stdout is not a TTY).\n7:  *\n8:  * Usage in commands:\n9:  *   import { output, OutputFormat } from \"../lib/output.js\";\n10:  *\n11:  *   // At the end of a command:\n12:  *   output(format, data);           // emits JSON or human text\n13:  *   outputError(format, message);   // emits error in the right format\n14:  */\n15: \n16: // ---------------------------------------------------------------------------\n17: // Types\n18: // ---------------------------------------------------------------------------\n19: \n20: export type OutputFormat = \"text\" | \"json\" | \"toon\";\n21: \n22: // ---------------------------------------------------------------------------\n23: // Helpers\n24: // ---------------------------------------------------------------------------\n25: \n26: /**\n27:  * Determine the output format. Priority:\n28:  *   1. Explicit --output flag value\n29:  *   2. WOMBO_OUTPUT env var (for agent pipelines)\n30:  *   3. Default to \"text\"\n31:  *\n32:  * Note: We intentionally do NOT auto-detect based on TTY. Many legitimate\n33:  * use cases (bun dev, piped to less/grep, CI) have non-TTY stdout but still\n34:  * want human output. Agents should explicitly pass --output json or set\n35:  * WOMBO_OUTPUT=json.\n36:  */\n37: export function resolveOutputFormat(explicit?: string): OutputFormat {\n38:   if (explicit === \"json\") return \"json\";\n39:   if (explicit === \"toon\") return \"toon\";\n40:   if (explicit === \"text\") return \"text\";\n41:   // Check env var for agent pipelines\n42:   const env = process.env.WOMBO_OUTPUT;\n43:   if (env === \"json\") return \"json\";\n44:   if (env === \"toon\") return \"toon\";\n45:   return \"text\";\n46: }\n47: \n48: /**\n49:  * Emit structured data. In JSON mode, outputs a single JSON line to stdout.\n50:  * In text mode, calls the provided textRenderer callback.\n51:  */\n52: export function output(\n53:   format: OutputFormat,\n54:   data: unknown,\n55:   textRenderer: () => void\n56: ): void {\n57:   if (format === \"json\") {\n58:     console.log(JSON.stringify(data));\n59:   } else {\n60:     textRenderer();\n61:   }\n62: }\n63: \n64: /**\n65:  * Emit an error. In JSON mode, outputs {\"error\": message} to stderr.\n66:  * In text mode, outputs the message to stderr normally.\n67:  */\n68: export function outputError(format: OutputFormat, message: string, exitCode: number = 1): never {\n69:   if (format === \"json\") {\n70:     console.error(JSON.stringify({ error: message }));\n71:   } else {\n72:     console.error(message);\n73:   }\n74:   process.exit(exitCode);\n75: }\n76: \n77: /**\n78:  * Emit a success/info message. In JSON mode, outputs {\"message\": msg, ...extra}.\n79:  * In text mode, outputs the message to stdout normally.\n80:  */\n81: export function outputMessage(\n82:   format: OutputFormat,\n83:   message: string,\n84:   extra?: Record<string, unknown>\n85: ): void {\n86:   if (format === \"json\") {\n87:     console.log(JSON.stringify({ message, ...extra }));\n88:   } else {\n89:     console.log(message);\n90:   }\n91: }\n92: \n93: // ---------------------------------------------------------------------------\n94: // Field filtering for compact output (--fields)\n95: // ---------------------------------------------------------------------------\n96: \n97: /**\n98:  * Filter an object to only include the specified fields.\n99:  * If fields is undefined/empty, returns the object unchanged.\n100:  */\n101: export function filterFields<T extends Record<string, unknown>>(\n102:   obj: T,\n103:   fields?: string[]\n104: ): Partial<T> {\n105:   if (!fields || fields.length === 0) return obj;\n106:   const result: Partial<T> = {};\n107:   for (const field of fields) {\n108:     if (field in obj) {\n109:       (result as any)[field] = (obj as any)[field];\n110:     }\n111:   }\n112:   return result;\n113: }\n114: \n115: /**\n116:  * Filter an array of objects to only include specified fields per object.\n117:  * If fields is undefined/empty, returns the array unchanged.\n118:  */\n119: export function filterFieldsArray<T extends Record<string, unknown>>(\n120:   arr: T[],\n121:   fields?: string[]\n122: ): Partial<T>[] {\n123:   if (!fields || fields.length === 0) return arr;\n124:   return arr.map((obj) => filterFields(obj, fields));\n125: }\n126: \n127: /**\n128:  * Render a compact text table from an array of objects with selected fields.\n129:  * Used for text-mode --fields output.\n130:  */\n131: export function renderCompactTable(\n132:   items: Record<string, unknown>[],\n133:   fields: string[]\n134: ): void {\n135:   if (items.length === 0) return;\n136: \n137:   // Calculate column widths\n138:   const widths: Record<string, number> = {};\n139:   for (const field of fields) {\n140:     widths[field] = field.length;\n141:     for (const item of items) {\n142:       const val = String(item[field] ?? \"\");\n143:       widths[field] = Math.max(widths[field], val.length);\n144:     }\n145:   }\n146: \n147:   // Header\n148:   const header = fields.map((f) => f.padEnd(widths[f])).join(\"  \");\n149:   console.log(header);\n150:   console.log(fields.map((f) => \"─\".repeat(widths[f])).join(\"  \"));\n151: \n152:   // Rows\n153:   for (const item of items) {\n154:     const row = fields.map((f) => String(item[f] ?? \"\").padEnd(widths[f])).join(\"  \");\n155:     console.log(row);\n156:   }\n157: }\n\n(End of file - total 157 lines)\n</content>","title":"src/lib/output.ts","metadata":{"preview":"/**\n * output.ts — Shared output helpers for agent-ready CLI.\n *\n * Provides a centralized way for commands to emit structured data that\n * renders as human-readable text on TTY or as JSON when --output json\n * is specified (or when stdout is not a TTY).\n *\n * Usage in commands:\n *   import { output, OutputFormat } from \"../lib/output.js\";\n *\n *   // At the end of a command:\n *   output(format, data);           // emits JSON or human text\n *   outputError(format, message);   // emits error in the right format\n */\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type OutputFormat = \"text\" | \"json\" | \"toon\";","truncated":false,"loaded":[]},"time":{"start":1773435953814,"end":1773435953818}}}}
