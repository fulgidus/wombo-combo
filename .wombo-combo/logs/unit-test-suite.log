{"type":"tool_use","timestamp":1773435960144,"sessionID":"ses_316fcc12bffeSBLLi3jBrbT2M4","part":{"id":"prt_ce9053974001Gb5tEmZph7f875","sessionID":"ses_316fcc12bffeSBLLi3jBrbT2M4","messageID":"msg_ce905326b001tS1kO83s5mFPE1","type":"tool","callID":"toolu_vrtx_01G8YqhsGGz4AHivv4qGMijR","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-unit-test-suite/src/lib/state.ts","limit":100,"offset":300},"output":"<path>/home/fulgidus/Documents/wt-wombo-unit-test-suite/src/lib/state.ts</path>\n<type>file</type>\n<content>300: /**\n301:  * Check if an agent's dependencies within the wave are all satisfied.\n302:  * Dependencies are satisfied when their agents reach \"verified\" or \"merged\" status.\n303:  *\n304:  * If the agent has no depends_on entries, it's always ready.\n305:  */\n306: export function areAgentDepsReady(\n307:   state: WaveState,\n308:   agent: AgentState\n309: ): boolean {\n310:   if (agent.depends_on.length === 0) return true;\n311: \n312:   for (const depId of agent.depends_on) {\n313:     const depAgent = state.agents.find((a) => a.feature_id === depId);\n314:     if (depAgent && !DEP_SATISFIED_STATUSES.has(depAgent.status)) {\n315:       return false;\n316:     }\n317:     // If depAgent doesn't exist in this wave, the dep is external — assumed satisfied\n318:   }\n319:   return true;\n320: }\n321: \n322: /**\n323:  * Get queued agents whose dependencies are all satisfied.\n324:  * This is the dependency-aware replacement for plain queuedAgents().\n325:  */\n326: export function readyToLaunchAgents(state: WaveState): AgentState[] {\n327:   return state.agents.filter(\n328:     (a) => a.status === \"queued\" && areAgentDepsReady(state, a)\n329:   );\n330: }\n331: \n332: /**\n333:  * Get all agents that are downstream (depend on) a given feature, directly or transitively.\n334:  * Used for failure cascading — when a feature fails, cancel all downstream.\n335:  */\n336: export function getDownstreamAgents(\n337:   state: WaveState,\n338:   featureId: string\n339: ): AgentState[] {\n340:   const visited = new Set<string>();\n341:   const result: AgentState[] = [];\n342: \n343:   function collect(id: string): void {\n344:     const agent = state.agents.find((a) => a.feature_id === id);\n345:     if (!agent) return;\n346: \n347:     for (const downstreamId of agent.depended_on_by) {\n348:       if (visited.has(downstreamId)) continue;\n349:       visited.add(downstreamId);\n350: \n351:       const downstream = state.agents.find((a) => a.feature_id === downstreamId);\n352:       if (downstream) {\n353:         result.push(downstream);\n354:         collect(downstreamId);\n355:       }\n356:     }\n357:   }\n358: \n359:   collect(featureId);\n360:   return result;\n361: }\n362: \n363: /**\n364:  * Cancel all downstream agents when an upstream dependency fails.\n365:  * Sets status to \"failed\" with an error explaining the dependency failure.\n366:  * Returns the list of cancelled agent IDs.\n367:  */\n368: export function cancelDownstream(\n369:   state: WaveState,\n370:   failedFeatureId: string\n371: ): string[] {\n372:   const downstream = getDownstreamAgents(state, failedFeatureId);\n373:   const cancelled: string[] = [];\n374: \n375:   for (const agent of downstream) {\n376:     // Only cancel agents that haven't already reached a terminal state\n377:     if (\n378:       agent.status === \"queued\" ||\n379:       agent.status === \"installing\" ||\n380:       agent.status === \"running\" ||\n381:       agent.status === \"retry\"\n382:     ) {\n383:       updateAgent(state, agent.feature_id, {\n384:         status: \"failed\",\n385:         error: `Dependency \"${failedFeatureId}\" failed — downstream cancelled`,\n386:         activity: null,\n387:         completed_at: new Date().toISOString(),\n388:       });\n389:       cancelled.push(agent.feature_id);\n390:     }\n391:   }\n392: \n393:   return cancelled;\n394: }\n\n(End of file - total 394 lines)\n</content>","title":"src/lib/state.ts","metadata":{"preview":"/**\n * Check if an agent's dependencies within the wave are all satisfied.\n * Dependencies are satisfied when their agents reach \"verified\" or \"merged\" status.\n *\n * If the agent has no depends_on entries, it's always ready.\n */\nexport function areAgentDepsReady(\n  state: WaveState,\n  agent: AgentState\n): boolean {\n  if (agent.depends_on.length === 0) return true;\n\n  for (const depId of agent.depends_on) {\n    const depAgent = state.agents.find((a) => a.feature_id === depId);\n    if (depAgent && !DEP_SATISFIED_STATUSES.has(depAgent.status)) {\n      return false;\n    }\n    // If depAgent doesn't exist in this wave, the dep is external — assumed satisfied\n  }\n  return true;","truncated":false,"loaded":[]},"time":{"start":1773435960140,"end":1773435960143}}}}
