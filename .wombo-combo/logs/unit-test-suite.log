ure\",\n98:     title: \"Test Feature\",\n99:     description: \"A test feature\",\n100:     status: \"backlog\",\n101:     completion: 0,\n102:     difficulty: \"medium\",\n103:     priority: \"medium\",\n104:     depends_on: [],\n105:     effort: \"PT1H\",\n106:     started_at: null,\n107:     ended_at: null,\n108:     constraints: [],\n109:     forbidden: [],\n110:     references: [],\n111:     notes: [],\n112:     subtasks: [],\n113:     ...overrides,\n114:   };\n115: }\n116: \n117: function makeFeaturesFile(\n118:   tasks: Feature[] = [],\n119:   archive: Feature[] = []\n120: ): FeaturesFile {\n121:   return {\n122:     version: \"1\",\n123:     meta: {\n124:       created_at: \"2025-01-01T00:00:00Z\",\n125:       updated_at: \"2025-01-01T00:00:00Z\",\n126:       project: \"test-project\",\n127:       generator: \"test\",\n128:       maintainer: \"tester\",\n129:     },\n130:     tasks,\n131:     archive,\n132:   };\n133: }\n134: \n135: /**\n136:  * Write a YAML string to the .wombo-combo/tasks.yml inside the given tmpDir.\n137:  * Also creates the .wombo-combo directory.\n138:  */\n139: function writeTasksYaml(dir: string, yaml: string): void {\n140:   mkdirSync(join(dir, \".wombo-combo\"), { recursive: true });\n141:   writeFileSync(join(dir, \".wombo-combo\", \"tasks.yml\"), yaml);\n142: }\n143: \n144: /**\n145:  * Write archive YAML to .wombo-combo/archive.yml.\n146:  */\n147: function writeArchiveYaml(dir: string, yaml: string): void {\n148:   mkdirSync(join(dir, \".wombo-combo\"), { recursive: true });\n149:   writeFileSync(join(dir, \".wombo-combo\", \"archive.yml\"), yaml);\n150: }\n151: \n152: let tmpDir: string;\n153: \n154: beforeEach(() => {\n155:   tmpDir = mkdtempSync(join(tmpdir(), \"wombo-test-features-\"));\n156: });\n157: \n158: afterEach(() => {\n159:   rmSync(tmpDir, { recursive: true, force: true });\n160: });\n161: \n162: // ---------------------------------------------------------------------------\n163: // ISO 8601 Duration Parsing\n164: // ---------------------------------------------------------------------------\n165: \n166: describe(\"parseDurationMinutes\", () => {\n167:   test(\"parses hours only\", () => {\n168:     expect(parseDurationMinutes(\"PT1H\")).toBe(60);\n169:     expect(parseDurationMinutes(\"PT2H\")).toBe(120);\n\n(Showing lines 50-169 of 873. Use offset=170 to continue.)\n</content>","title":"tests/features.test.ts","metadata":{"preview":"  return {\n    tasksDir: \"tasks\",\n    archiveDir: \"archive\",\n    baseBranch: \"main\",\n    build: { command: \"bun run build\", timeout: 300_000, artifactDir: \"dist\" },\n    install: { command: \"bun install\", timeout: 120_000 },\n    git: {\n      branchPrefix: \"feature/\",\n      worktreePrefix: \"wombo-\",\n      remote: \"origin\",\n      mergeStrategy: \"--no-ff\",\n    },\n    agent: {\n      bin: null,\n      name: \"generalist-agent\",\n      configFiles: [],\n      tmuxPrefix: \"wombo\",\n      multiplexer: \"auto\",\n    },\n    portless: {","truncated":true,"loaded":[]},"time":{"start":1773435942213,"end":1773435942216}}}}
