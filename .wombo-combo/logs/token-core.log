{"type":"tool_use","timestamp":1773482650789,"sessionID":"ses_314328225ffewlGaXNfSOaaL0F","part":{"id":"prt_cebcdac9e001W5czKQnVgLkduR","sessionID":"ses_314328225ffewlGaXNfSOaaL0F","messageID":"msg_cebcda100001s27bsx1an1tAYf","type":"tool","callID":"toolu_vrtx_015BVNnqgEVcJmnAMLukeqMu","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/token-core/src/lib/token-collector.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/token-core/src/lib/token-collector.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * token-collector.ts — Parse and collect token usage data from agent events.\n3:  *\n4:  * Responsibilities:\n5:  *   - Define the UsageRecord type for structured token usage data\n6:  *   - Parse step_finish events to extract per-step token counts\n7:  *   - Accumulate usage records per agent (task_id)\n8:  *   - Emit parsed records via callback (storage is handled elsewhere)\n9:  *\n10:  * OpenCode emits step_finish events with this token structure:\n11:  *   {\n12:  *     type: \"step_finish\",\n13:  *     part: {\n14:  *       reason: \"tool-calls\" | \"stop\",\n15:  *       cost: number,\n16:  *       tokens: {\n17:  *         total: number,\n18:  *         input: number,\n19:  *         output: number,\n20:  *         reasoning: number,\n21:  *         cache: { read: number, write: number }\n22:  *       }\n23:  *     }\n24:  *   }\n25:  */\n26: \n27: import type { OpenCodeEvent } from \"./monitor.js\";\n28: \n29: // ---------------------------------------------------------------------------\n30: // Types\n31: // ---------------------------------------------------------------------------\n32: \n33: /**\n34:  * A single token usage record extracted from an agent's step_finish event.\n35:  *\n36:  * Each record represents one step's token consumption. Multiple records\n37:  * are emitted per agent session (one per step_finish event).\n38:  */\n39: export interface UsageRecord {\n40:   /** The task/feature ID this usage belongs to */\n41:   task_id: string;\n42:   /** Optional quest ID if the agent is working within a quest */\n43:   quest_id: string | null;\n44:   /** Model identifier (e.g. \"claude-sonnet-4-20250514\") — from launch context */\n45:   model: string | null;\n46:   /** Provider name (e.g. \"anthropic\", \"openai\") — from launch context */\n47:   provider: string | null;\n48:   /** Agent harness name (e.g. \"opencode\") — from launch context */\n49:   harness: string | null;\n50:   /** Input tokens consumed in this step */\n51:   input_tokens: number;\n52:   /** Output tokens generated in this step */\n53:   output_tokens: number;\n54:   /** Tokens read from cache in this step */\n55:   cache_read: number;\n56:   /** Tokens written to cache in this step */\n57:   cache_write: number;\n58:   /** Reasoning tokens used in this step (e.g. for o1-style models) */\n59:   reasoning_tokens: number;\n60:   /** Total tokens for this step (input + output + reasoning) */\n61:   total_tokens: number;\n62:   /** Cost reported by the agent harness (may be 0 if not available) */\n63:   cost: number;\n64:   /** Whether this was the final step (reason === \"stop\") */\n65:   is_final_step: boolean;\n66:   /** ISO 8601 timestamp when this usage was recorded */\n67:   timestamp: string;\n68: }\n69: \n70: /**\n71:  * Aggregated usage summary for a single agent session.\n72:  */\n73: export interface UsageSummary {\n74:   /** The task/feature ID */\n75:   task_id: string;\n76:   /** Total input tokens across all steps */\n77:   total_input: number;\n78:   /** Total output tokens across all steps */\n79:   total_output: number;\n80:   /** Total cache read tokens across all steps */\n81:   total_cache_read: number;\n82:   /** Total cache write tokens across all steps */\n83:   total_cache_write: number;\n84:   /** Total reasoning tokens across all steps */\n85:   total_reasoning: number;\n86:   /** Grand total tokens across all steps */\n87:   total_tokens: number;\n88:   /** Total cost across all steps */\n89:   total_cost: number;\n90:   /** Number of steps recorded */\n91:   step_count: number;\n92: }\n93: \n94: // ---------------------------------------------------------------------------\n95: // Parsing\n96: // ---------------------------------------------------------------------------\n97: \n98: /**\n99:  * Check if an OpenCode event is a step_finish with token data.\n100:  */\n101: export function isTokenEvent(event: OpenCodeEvent): boolean {\n102:   return (\n103:     event.type === \"step_finish\" &&\n104:     event.part?.tokens != null &&\n105:     typeof event.part.tokens.input === \"number\"\n106:   );\n107: }\n108: \n109: /**\n110:  * Extract a UsageRecord from a step_finish event.\n111:  *\n112:  * Returns null if the event doesn't contain valid token data.\n113:  *\n114:  * @param event     The OpenCode JSON event (must be type \"step_finish\")\n115:  * @param taskId    The task/feature ID this agent is working on\n116:  * @param context   Optional context from the launch environment\n117:  */\n118: export function parseUsageFromEvent(\n119:   event: OpenCodeEvent,\n120:   taskId: string,\n121:   context?: {\n122:     quest_id?: string | null;\n123:     model?: string | null;\n124:     provider?: string | null;\n125:     harness?: string | null;\n126:   }\n127: ): UsageRecord | null {\n128:   if (!isTokenEvent(event)) return null;\n129: \n130:   const tokens = event.part!.tokens!;\n131:   const cache = tokens.cache ?? { read: 0, write: 0 };\n132: \n133:   return {\n134:     task_id: taskId,\n135:     quest_id: context?.quest_id ?? null,\n136:     model: context?.model ?? null,\n137:     provider: context?.provider ?? null,\n138:     harness: context?.harness ?? \"opencode\",\n139:     input_tokens: tokens.input,\n140:     output_tokens: tokens.output,\n141:     cache_read: cache.read,\n142:     cache_write: cache.write,\n143:     reasoning_tokens: tokens.reasoning ?? 0,\n144:     total_tokens: tokens.total,\n145:     cost: event.part?.cost ?? 0,\n146:     is_final_step: event.part?.reason === \"stop\",\n147:     timestamp: new Date(event.timestamp ?? Date.now()).toISOString(),\n148:   };\n149: }\n150: \n151: // ---------------------------------------------------------------------------\n152: // Collector\n153: // ---------------------------------------------------------------------------\n154: \n155: /** Callback invoked when a new usage record is parsed */\n156: export type UsageCallback = (record: UsageRecord) => void;\n157: \n158: /**\n159:  * TokenCollector accumulates usage records for multiple agents.\n160:  *\n161:  * Usage:\n162:  *   const collector = new TokenCollector((record) => {\n163:  *     console.log(\"Usage:\", record);\n164:  *   });\n165:  *\n166:  *   // Register context for an agent before it starts\n167:  *   collector.registerAgent(\"my-feature\", {\n168:  *     quest_id: \"quest-1\",\n169:  *     model: \"claude-sonnet-4-20250514\",\n170:  *   });\n171:  *\n172:  *   // Feed events as they arrive\n173:  *   collector.ingestEvent(\"my-feature\", event);\n174:  *\n175:  *   // Get aggregated summary\n176:  *   const summary = collector.getSummary(\"my-feature\");\n177:  */\n178: export class TokenCollector {\n179:   /** Per-agent usage records */\n180:   private records: Map<string, UsageRecord[]> = new Map();\n181: \n182:   /** Per-agent context (model, provider, quest, etc.) */\n183:   private contexts: Map<\n184:     string,\n185:     {\n186:       quest_id?: string | null;\n187:       model?: string | null;\n188:       provider?: string | null;\n189:       harness?: string | null;\n190:     }\n191:   > = new Map();\n192: \n193:   /** Callback invoked for each new usage record */\n194:   private onUsage: UsageCallback | null;\n195: \n196:   constructor(onUsage?: UsageCallback) {\n197:     this.onUsage = onUsage ?? null;\n198:   }\n199: \n200:   /**\n201:    * Register context for an agent before events start flowing.\n202:    * This context (model, provider, quest_id) is attached to every\n203:    * UsageRecord emitted for this agent.\n204:    */\n205:   registerAgent(\n206:     taskId: string,\n207:     context?: {\n208:       quest_id?: string | null;\n209:       model?: string | null;\n210:       provider?: string | null;\n211:       harness?: string | null;\n212:     }\n213:   ): void {\n214:     this.contexts.set(taskId, context ?? {});\n215:     if (!this.records.has(taskId)) {\n216:       this.records.set(taskId, []);\n217:     }\n218:   }\n219: \n220:   /**\n221:    * Feed an OpenCode event for a specific agent.\n222:    * If the event is a step_finish with token data, a UsageRecord\n223:    * is created and the onUsage callback is invoked.\n224:    *\n225:    * @returns The parsed UsageRecord, or null if the event had no token data\n226:    */\n227:   ingestEvent(taskId: string, event: OpenCodeEvent): UsageRecord | null {\n228:     if (!isTokenEvent(event)) return null;\n229: \n230:     const context = this.contexts.get(taskId);\n231:     const record = parseUsageFromEvent(event, taskId, context);\n232:     if (!record) return null;\n233: \n234:     if (!this.records.has(taskId)) {\n235:       this.records.set(taskId, []);\n236:     }\n237:     this.records.get(taskId)!.push(record);\n238: \n239:     this.onUsage?.(record);\n240: \n241:     return record;\n242:   }\n243: \n244:   /**\n245:    * Get all usage records for an agent.\n246:    */\n247:   getRecords(taskId: string): UsageRecord[] {\n248:     return this.records.get(taskId) ?? [];\n249:   }\n250: \n251:   /**\n252:    * Get all usage records across all agents.\n253:    */\n254:   getAllRecords(): UsageRecord[] {\n255:     const all: UsageRecord[] = [];\n256:     for (const records of this.records.values()) {\n257:       all.push(...records);\n258:     }\n259:     return all;\n260:   }\n261: \n262:   /**\n263:    * Get an aggregated usage summary for an agent.\n264:    * Returns null if no records exist for the agent.\n265:    */\n266:   getSummary(taskId: string): UsageSummary | null {\n267:     const records = this.records.get(taskId);\n268:     if (!records || records.length === 0) return null;\n269: \n270:     return {\n271:       task_id: taskId,\n272:       total_input: records.reduce((sum, r) => sum + r.input_tokens, 0),\n273:       total_output: records.reduce((sum, r) => sum + r.output_tokens, 0),\n274:       total_cache_read: records.reduce((sum, r) => sum + r.cache_read, 0),\n275:       total_cache_write: records.reduce((sum, r) => sum + r.cache_write, 0),\n276:       total_reasoning: records.reduce((sum, r) => sum + r.reasoning_tokens, 0),\n277:       total_tokens: records.reduce((sum, r) => sum + r.total_tokens, 0),\n278:       total_cost: records.reduce((sum, r) => sum + r.cost, 0),\n279:       step_count: records.length,\n280:     };\n281:   }\n282: \n283:   /**\n284:    * Get aggregated summaries for all tracked agents.\n285:    */\n286:   getAllSummaries(): UsageSummary[] {\n287:     const summaries: UsageSummary[] = [];\n288:     for (const taskId of this.records.keys()) {\n289:       const summary = this.getSummary(taskId);\n290:       if (summary) summaries.push(summary);\n291:     }\n292:     return summaries;\n293:   }\n294: \n295:   /**\n296:    * Remove all records for an agent (e.g. after archiving).\n297:    */\n298:   clear(taskId: string): void {\n299:     this.records.delete(taskId);\n300:     this.contexts.delete(taskId);\n301:   }\n302: \n303:   /**\n304:    * Remove all records for all agents.\n305:    */\n306:   clearAll(): void {\n307:     this.records.clear();\n308:     this.contexts.clear();\n309:   }\n310: }\n\n(End of file - total 310 lines)\n</content>","title":"src/lib/token-collector.ts","metadata":{"preview":"/**\n * token-collector.ts — Parse and collect token usage data from agent events.\n *\n * Responsibilities:\n *   - Define the UsageRecord type for structured token usage data\n *   - Parse step_finish events to extract per-step token counts\n *   - Accumulate usage records per agent (task_id)\n *   - Emit parsed records via callback (storage is handled elsewhere)\n *\n * OpenCode emits step_finish events with this token structure:\n *   {\n *     type: \"step_finish\",\n *     part: {\n *       reason: \"tool-calls\" | \"stop\",\n *       cost: number,\n *       tokens: {\n *         total: number,\n *         input: number,\n *         output: number,\n *         reasoning: number,","truncated":false,"loaded":[]},"time":{"start":1773482650785,"end":1773482650788}}}}
{"type":"tool_use","timestamp":1773482651300,"sessionID":"ses_314328225ffewlGaXNfSOaaL0F","part":{"id":"prt_cebcdad09001q315D1pViGtOgY","sessionID":"ses_314328225ffewlGaXNfSOaaL0F","messageID":"msg_cebcda100001s27bsx1an1tAYf","type":"tool","callID":"toolu_vrtx_01SA5XSCw9pKBDbbCvwJwDii","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/token-core/src/lib/monitor.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/token-core/src/lib/monitor.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * monitor.ts — Parse JSON events from agent and detect completion/failure.\n3:  *\n4:  * Responsibilities:\n5:  *   - Parse newline-delimited JSON events from agent stdout\n6:  *   - Detect session completion (agent finished)\n7:  *   - Detect session ID from events\n8:  *   - Detect errors and failures\n9:  *   - Write per-agent raw log files for diagnostics\n10:  *   - Maintain per-agent parsed activity log for TUI preview\n11:  *\n12:  * ## Process Lifecycle (audit: wave-detach-audit)\n13:  *\n14:  * ProcessMonitor manages the lifecycle of headless agent child processes:\n15:  *\n16:  * **Normal flow**: Agent stdout → JSON event parsing → callbacks → completion\n17:  *   1. `addProcess()` registers a ChildProcess and attaches stdout/stderr listeners\n18:  *   2. Stdout data is parsed line-by-line as JSON events\n19:  *   3. Callbacks fire: `onSessionId`, `onActivity`, `onComplete`, `onError`\n20:  *   4. On process exit (code 0 or sawFinalStop), `onComplete` is called\n21:  *   5. On process exit (non-zero, no final stop), `onError` is called\n22:  *\n23:  * **Teardown flow**: Parent quit → `killAll()` → SIGTERM to each child\n24:  *   1. TUI `onQuit` or SIGINT handler calls `monitor.killAll()`\n25:  *   2. `killAll()` iterates all processes and calls `remove(featureId)`\n26:  *   3. `remove()` sends SIGTERM to the child process (if still running)\n27:  *   4. The process map entry is deleted — no further events are tracked\n28:  *\n29:  * **Key behavior**: `remove()` and `killAll()` intentionally kill child\n30:  * processes. This is correct because headless agents are spawned with\n31:  * `detached: false` — they are tied to the parent and would die anyway\n32:  * when the parent exits. Explicitly killing them ensures a clean shutdown\n33:  * with proper state saving before the parent terminates.\n34:  *\n35:  * **Edge case**: If the parent is killed with SIGKILL (not catchable),\n36:  * child processes die with no cleanup. `woco resume` handles this by\n37:  * detecting orphaned worktrees with commits and re-verifying/re-launching.\n38:  */\n39: \n40: import type { ChildProcess } from \"node:child_process\";\n41: import { isProcessRunning } from \"./launcher.js\";\n42: import { mkdirSync, appendFileSync, existsSync } from \"node:fs\";\n43: import { resolve } from \"node:path\";\n44: import { TokenCollector, type UsageRecord } from \"./token-collector.js\";\n45: \n46: // ---------------------------------------------------------------------------\n47: // Log directory name (configurable would be overkill here)\n48: // ---------------------------------------------------------------------------\n49: \n50: const LOG_DIR_NAME = \".wombo-combo/logs\";\n51: \n52: // ---------------------------------------------------------------------------\n53: // Types — OpenCode JSON Events\n54: // ---------------------------------------------------------------------------\n55: \n56: export interface OpenCodeEvent {\n57:   type: string;\n58:   sessionID?: string;\n59:   timestamp?: number;\n60:   part?: {\n61:     type?: string;\n62:     tool?: string;\n63:     callID?: string;\n64:     text?: string;\n65:     reason?: string;\n66:     cost?: number;\n67:     tokens?: {\n68:       total: number;\n69:       input: number;\n70:       output: number;\n71:       reasoning: number;\n72:       cache?: {\n73:         read: number;\n74:         write: number;\n75:       };\n76:     };\n77:     state?: {\n78:       status?: string;\n79:       input?: Record<string, any>;\n80:       output?: string;\n81:       error?: string;\n82:     };\n83:   };\n84:   [key: string]: any;\n85: }\n86: \n87: // ---------------------------------------------------------------------------\n88: // Event Parser\n89: // ---------------------------------------------------------------------------\n90: \n91: export interface ParsedOutput {\n92:   sessionId: string | null;\n93:   completed: boolean;\n94:   errored: boolean;\n95:   lastError: string | null;\n96:   events: OpenCodeEvent[];\n97: }\n98: \n99: export function parseEvents(rawOutput: string): ParsedOutput {\n100:   const result: ParsedOutput = {\n101:     sessionId: null,\n102:     completed: false,\n103:     errored: false,\n104:     lastError: null,\n105:     events: [],\n106:   };\n107: \n108:   const lines = rawOutput.split(\"\\n\").filter((l) => l.trim());\n109: \n110:   for (const line of lines) {\n111:     try {\n112:       const event = JSON.parse(line) as OpenCodeEvent;\n113:       result.events.push(event);\n114: \n115:       if (event.sessionID && !result.sessionId) {\n116:         result.sessionId = event.sessionID;\n117:       }\n118: \n119:       if (\n120:         event.type === \"step_finish\" &&\n121:         event.part?.reason === \"stop\"\n122:       ) {\n123:         result.completed = true;\n124:       }\n125: \n126:       if (\n127:         event.type === \"tool_use\" &&\n128:         event.part?.state?.status === \"error\"\n129:       ) {\n130:         result.errored = true;\n131:         result.lastError = event.part.state.error ?? \"unknown tool error\";\n132:       }\n133:     } catch {\n134:       // Not valid JSON — skip\n135:     }\n136:   }\n137: \n138:   return result;\n139: }\n140: \n141: // ---------------------------------------------------------------------------\n142: // Activity Extraction\n143: // ---------------------------------------------------------------------------\n144: \n145: function shortPath(fullPath: string | undefined, maxLen: number = 30): string {\n146:   if (!fullPath) return \"\";\n147:   const parts = fullPath.replace(/^\\/+/, \"\").split(\"/\");\n148:   const short =\n149:     parts.length > 1\n150:       ? parts.slice(-2).join(\"/\")\n151:       : parts[parts.length - 1];\n152:   if (short.length <= maxLen) return short;\n153:   const fname = parts[parts.length - 1];\n154:   return fname.length <= maxLen ? fname : fname.slice(0, maxLen - 1) + \"\\u2026\";\n155: }\n156: \n157: function shortCmd(cmd: string | undefined, maxLen: number = 30): string {\n158:   if (!cmd) return \"\";\n159:   const first = cmd.split(\"\\n\")[0].trim();\n160:   if (first.length <= maxLen) return first;\n161:   return first.slice(0, maxLen - 1) + \"\\u2026\";\n162: }\n163: \n164: /**\n165:  * Map an event to a human-readable activity string.\n166:  */\n167: export function extractActivity(event: OpenCodeEvent): string | null {\n168:   switch (event.type) {\n169:     case \"step_start\":\n170:       return \"thinking\\u2026\";\n171: \n172:     case \"tool_use\": {\n173:       const toolName = (event.part?.tool ?? \"\").toLowerCase();\n174:       const input = event.part?.state?.input ?? {};\n175:       const status = event.part?.state?.status ?? \"\";\n176: \n177:       if (status === \"error\") {\n178:         return `${toolName}: error`;\n179:       }\n180: \n181:       switch (toolName) {\n182:         case \"read\":\n183:           return `reading ${shortPath(input.filePath ?? input.path)}`;\n184:         case \"write\":\n185:           return `writing ${shortPath(input.filePath ?? input.path)}`;\n186:         case \"edit\":\n187:           return `editing ${shortPath(input.filePath ?? input.path)}`;\n188:         case \"bash\":\n189:         case \"command\":\n190:         case \"terminal\": {\n191:           const cmd = input.command ?? input.cmd ?? \"\";\n192:           // Detect HITL ask script invocation\n193:           if (cmd.includes(\"hitl-ask\")) {\n194:             return \"waiting for human…\";\n195:           }\n196:           return `$ ${shortCmd(cmd)}`;\n197:         }\n198:         case \"glob\":\n199:           return `finding: ${shortPath(input.pattern)}`;\n200:         case \"grep\":\n201:         case \"search\":\n202:           return `searching: ${(input.pattern ?? \"\").slice(0, 25)}`;\n203:         case \"task\":\n204:           return \"delegating task\\u2026\";\n205:         case \"webfetch\":\n206:         case \"web_fetch\":\n207:           return \"fetching URL\\u2026\";\n208:         case \"todowrite\":\n209:         case \"todo_write\":\n210:           return \"planning\\u2026\";\n211:         case \"question\":\n212:           return \"asking question\\u2026\";\n213:         case \"jcodemunch_index_folder\":\n214:         case \"jcodemunch_index_repo\":\n215:           return \"indexing code\\u2026\";\n216:         case \"jcodemunch_search_symbols\":\n217:         case \"jcodemunch_search_text\":\n218:           return \"searching symbols\\u2026\";\n219:         case \"jcodemunch_get_file_outline\":\n220:           return `outlining ${shortPath(input.file_path)}`;\n221:         case \"jcodemunch_get_symbol\":\n222:         case \"jcodemunch_get_symbols\":\n223:           return \"reading symbol\\u2026\";\n224:         default:\n225:           return `tool: ${toolName}`;\n226:       }\n227:     }\n228: \n229:     case \"text\":\n230:       return \"responding\\u2026\";\n231: \n232:     case \"step_finish\":\n233:       if (event.part?.reason === \"stop\") return \"done\";\n234:       if (event.part?.reason === \"tool-calls\") return null;\n235:       return null;\n236: \n237:     default:\n238:       return null;\n239:   }\n240: }\n241: \n242: /**\n243:  * Format an event into a human-readable log line for the activity stream.\n244:  */\n245: export function formatEventForLog(event: OpenCodeEvent): string | null {\n246:   switch (event.type) {\n247:     case \"step_start\":\n248:       return \"-- step started\";\n249: \n250:     case \"tool_use\": {\n251:       const toolName = event.part?.tool ?? \"unknown\";\n252:       const input = event.part?.state?.input ?? {};\n253:       const status = event.part?.state?.status ?? \"\";\n254:       const output = event.part?.state?.output ?? \"\";\n255:       const error = event.part?.state?.error ?? \"\";\n256: \n257:       let line = `>> ${toolName}`;\n258:       switch (toolName.toLowerCase()) {\n259:         case \"read\":\n260:           line = `>> read ${shortPath(input.filePath ?? input.path, 50)}`;\n261:           break;\n262:         case \"write\":\n263:           line = `>> write ${shortPath(input.filePath ?? input.path, 50)}`;\n264:           break;\n265:         case \"edit\":\n266:           line = `>> edit ${shortPath(input.filePath ?? input.path, 50)}`;\n267:           break;\n268:         case \"bash\":\n269:         case \"command\":\n270:           line = `>> $ ${shortCmd(input.command ?? input.cmd, 60)}`;\n271:           break;\n272:         case \"glob\":\n273:           line = `>> glob ${input.pattern ?? \"\"}`;\n274:           break;\n275:         case \"grep\":\n276:           line = `>> grep \"${(input.pattern ?? \"\").slice(0, 30)}\"`;\n277:           break;\n278:         case \"task\":\n279:           line = `>> task: ${(input.description ?? input.prompt ?? \"\").slice(0, 50)}`;\n280:           break;\n281:       }\n282: \n283:       if (status === \"completed\" && output) {\n284:         const preview = output.split(\"\\n\")[0].slice(0, 80);\n285:         return `${line}\\n   ${preview}${output.length > 80 ? \"\\u2026\" : \"\"}`;\n286:       }\n287:       if (status === \"error\" && error) {\n288:         return `${line}\\n!! ${error.slice(0, 100)}`;\n289:       }\n290:       return line;\n291:     }\n292: \n293:     case \"text\": {\n294:       const text = event.part?.text ?? \"\";\n295:       if (!text.trim()) return null;\n296:       const firstLine = text.split(\"\\n\").find((l: string) => l.trim())?.trim() ?? \"\";\n297:       if (firstLine.length === 0) return null;\n298:       return `   ${firstLine.slice(0, 120)}${firstLine.length > 120 ? \"\\u2026\" : \"\"}`;\n299:     }\n300: \n301:     case \"step_finish\": {\n302:       const reason = event.part?.reason ?? \"\";\n303:       const tokens = event.part?.tokens;\n304:       if (reason === \"stop\") {\n305:         let tokStr = \"\";\n306:         if (tokens) {\n307:           const parts = [`${tokens.input}in`, `${tokens.output}out`];\n308:           if (tokens.cache?.read) parts.push(`${tokens.cache.read}cache`);\n309:           tokStr = ` (${parts.join(\"/\")})`;\n310:         }\n311:         return `-- done${tokStr}`;\n312:       }\n313:       return null;\n314:     }\n315: \n316:     default:\n317:       return null;\n318:   }\n319: }\n320: \n321: // ---------------------------------------------------------------------------\n322: // Per-agent Activity Log (in-memory ring buffer for TUI)\n323: // ---------------------------------------------------------------------------\n324: \n325: export interface ActivityEntry {\n326:   timestamp: string;\n327:   text: string;\n328: }\n329: \n330: const MAX_ACTIVITY_LINES = 500;\n331: \n332: // ---------------------------------------------------------------------------\n333: // Process Monitor\n334: // ---------------------------------------------------------------------------\n335: \n336: export interface MonitorCallbacks {\n337:   onSessionId?: (featureId: string, sessionId: string) => void;\n338:   onComplete?: (featureId: string) => void;\n339:   onError?: (featureId: string, error: string) => void;\n340:   onOutput?: (featureId: string, data: string) => void;\n341:   onActivity?: (featureId: string, activity: string) => void;\n342:   /** Called when an agent asks a human question via HITL */\n343:   onQuestion?: (featureId: string, questionText: string) => void;\n344:   /** Called when token usage data is parsed from a step_finish event */\n345:   onUsage?: (featureId: string, record: UsageRecord) => void;\n346: }\n347: \n348: interface MonitoredProcess {\n349:   featureId: string;\n350:   process: ChildProcess;\n351:   stdout: string;\n352:   stderr: string;\n353:   sessionId: string | null;\n354:   done: boolean;\n355:   lineBuffer: string;\n356:   sawFinalStop: boolean;\n357: }\n358: \n359: /**\n360:  * Monitor a set of headless agent processes.\n361:  * Collects stdout, parses events, and calls callbacks on state changes.\n362:  */\n363: export class ProcessMonitor {\n364:   private processes: Map<string, MonitoredProcess> = new Map();\n365:   private callbacks: MonitorCallbacks;\n366:   private logDir: string;\n367:   /** Per-agent activity log for TUI preview pane */\n368:   public activityLogs: Map<string, ActivityEntry[]> = new Map();\n369:   /** Token usage collector — parses and accumulates usage from step_finish events */\n370:   public tokenCollector: TokenCollector;\n371: \n372:   constructor(projectRoot: string, callbacks: MonitorCallbacks = {}) {\n373:     this.callbacks = callbacks;\n374:     this.logDir = resolve(projectRoot, LOG_DIR_NAME);\n375:     if (!existsSync(this.logDir)) {\n376:       mkdirSync(this.logDir, { recursive: true });\n377:     }\n378:     this.tokenCollector = new TokenCollector((record) => {\n379:       this.callbacks.onUsage?.(record.task_id, record);\n380:     });\n381:   }\n382: \n383:   private pushActivity(featureId: string, text: string): void {\n384:     if (!this.activityLogs.has(featureId)) {\n385:       this.activityLogs.set(featureId, []);\n386:     }\n387:     const log = this.activityLogs.get(featureId)!;\n388:     for (const line of text.split(\"\\n\")) {\n389:       log.push({ timestamp: new Date().toISOString().slice(11, 19), text: line });\n390:     }\n391:     if (log.length > MAX_ACTIVITY_LINES) {\n392:       log.splice(0, log.length - MAX_ACTIVITY_LINES);\n393:     }\n394:   }\n395: \n396:   private writeLog(featureId: string, data: string): void {\n397:     try {\n398:       const logFile = resolve(this.logDir, `${featureId}.log`);\n399:       appendFileSync(logFile, data);\n400:     } catch {\n401:       // Non-critical\n402:     }\n403:   }\n404: \n405:   getActivityLog(featureId: string): ActivityEntry[] {\n406:     return this.activityLogs.get(featureId) ?? [];\n407:   }\n408: \n409:   addProcess(featureId: string, child: ChildProcess): void {\n410:     const monitored: MonitoredProcess = {\n411:       featureId,\n412:       process: child,\n413:       stdout: \"\",\n414:       stderr: \"\",\n415:       sessionId: null,\n416:       done: false,\n417:       lineBuffer: \"\",\n418:       sawFinalStop: false,\n419:     };\n420: \n421:     this.pushActivity(featureId, \"-- agent process started\");\n422:     this.writeLog(featureId, `[wombo] Process started at ${new Date().toISOString()}\\n`);\n423: \n424:     child.stdout?.on(\"data\", (data: Buffer) => {\n425:       const chunk = data.toString();\n426:       monitored.stdout += chunk;\n427:       this.callbacks.onOutput?.(featureId, chunk);\n428:       this.writeLog(featureId, chunk);\n429: \n430:       monitored.lineBuffer += chunk;\n431:       const lines = monitored.lineBuffer.split(\"\\n\");\n432:       monitored.lineBuffer = lines.pop() ?? \"\";\n433: \n434:       for (const line of lines) {\n435:         const trimmed = line.trim();\n436:         if (!trimmed) continue;\n437:         try {\n438:           const event = JSON.parse(trimmed) as OpenCodeEvent;\n439: \n440:           if (!monitored.sessionId && event.sessionID) {\n441:             monitored.sessionId = event.sessionID;\n442:             this.callbacks.onSessionId?.(featureId, event.sessionID);\n443:             this.pushActivity(featureId, `-- session: ${event.sessionID}`);\n444:           }\n445: \n446:           const activity = extractActivity(event);\n447:           if (activity) {\n448:             this.callbacks.onActivity?.(featureId, activity);\n449:           }\n450: \n451:           const logLine = formatEventForLog(event);\n452:           if (logLine) {\n453:             this.pushActivity(featureId, logLine);\n454:           }\n455: \n456:           // Extract token usage from step_finish events\n457:           this.tokenCollector.ingestEvent(featureId, event);\n458: \n459:           if (\n460:             event.type === \"step_finish\" &&\n461:             event.part?.reason === \"stop\"\n462:           ) {\n463:             monitored.sawFinalStop = true;\n464:           }\n465:         } catch {\n466:           if (trimmed.length > 0 && trimmed.length < 500) {\n467:             this.pushActivity(featureId, `[raw] ${trimmed.slice(0, 120)}`);\n468:           }\n469:         }\n470:       }\n471:     });\n472: \n473:     child.stderr?.on(\"data\", (data: Buffer) => {\n474:       const chunk = data.toString();\n475:       monitored.stderr += chunk;\n476:       this.writeLog(featureId, `[stderr] ${chunk}`);\n477:       const lines = chunk.split(\"\\n\").filter((l) => l.trim());\n478:       for (const line of lines) {\n479:         this.pushActivity(featureId, `[stderr] ${line.trim().slice(0, 120)}`);\n480:       }\n481:     });\n482: \n483:     child.on(\"exit\", (code) => {\n484:       monitored.done = true;\n485:       this.pushActivity(featureId, `-- process exited (code ${code})`);\n486:       this.writeLog(featureId, `\\n[wombo] Process exited with code ${code} at ${new Date().toISOString()}\\n`);\n487: \n488:       if (code === 0 || monitored.sawFinalStop) {\n489:         this.callbacks.onComplete?.(featureId);\n490:       } else {\n491:         const error =\n492:           monitored.stderr.slice(-2000) ||\n493:           `Process exited with code ${code}`;\n494:         this.callbacks.onError?.(featureId, error);\n495:       }\n496:     });\n497: \n498:     child.on(\"error\", (err) => {\n499:       monitored.done = true;\n500:       this.pushActivity(featureId, `!! process error: ${err.message}`);\n501:       this.writeLog(featureId, `\\n[wombo] Process error: ${err.message}\\n`);\n502:       this.callbacks.onError?.(featureId, err.message);\n503:     });\n504: \n505:     this.processes.set(featureId, monitored);\n506:   }\n507: \n508:   getSessionId(featureId: string): string | null {\n509:     return this.processes.get(featureId)?.sessionId ?? null;\n510:   }\n511: \n512:   getOutput(featureId: string): string {\n513:     return this.processes.get(featureId)?.stdout ?? \"\";\n514:   }\n515: \n516:   isRunning(featureId: string): boolean {\n517:     const m = this.processes.get(featureId);\n518:     if (!m) return false;\n519:     if (m.done) return false;\n520:     return isProcessRunning(m.process.pid!);\n521:   }\n522: \n523:   allDone(): boolean {\n524:     for (const m of this.processes.values()) {\n525:       if (!m.done) return false;\n526:     }\n527:     return true;\n528:   }\n529: \n530:   activeCount(): number {\n531:     let count = 0;\n532:     for (const m of this.processes.values()) {\n533:       if (!m.done) count++;\n534:     }\n535:     return count;\n536:   }\n537: \n538:   /**\n539:    * Remove a process from monitoring and kill it if still running.\n540:    *\n541:    * Sends SIGTERM (not SIGKILL) to allow the agent to handle shutdown\n542:    * gracefully (e.g., save partial work, close files). The process map\n543:    * entry is deleted immediately — any subsequent events from the dying\n544:    * process are ignored.\n545:    */\n546:   remove(featureId: string): void {\n547:     const m = this.processes.get(featureId);\n548:     if (m && !m.done) {\n549:       try {\n550:         m.process.kill(\"SIGTERM\");\n551:       } catch {}\n552:     }\n553:     this.processes.delete(featureId);\n554:   }\n555: \n556:   /**\n557:    * Kill all monitored processes. Called during graceful shutdown\n558:    * (SIGINT, TUI quit) to ensure no orphaned agent processes remain.\n559:    *\n560:    * This is the primary teardown path. After killAll(), the parent\n561:    * process saves wave state and exits. Agents can be re-launched\n562:    * later via `woco resume`.\n563:    */\n564:   killAll(): void {\n565:     for (const id of this.processes.keys()) {\n566:       this.remove(id);\n567:     }\n568:   }\n569: \n570:   waitAll(pollIntervalMs: number = 1000): Promise<void> {\n571:     return new Promise((resolve) => {\n572:       const check = () => {\n573:         if (this.allDone()) {\n574:           resolve();\n575:         } else {\n576:           setTimeout(check, pollIntervalMs);\n577:         }\n578:       };\n579:       check();\n580:     });\n581:   }\n582: }\n583: \n584: // ---------------------------------------------------------------------------\n585: // Re-exports from token-collector for convenience\n586: // ---------------------------------------------------------------------------\n587: \n588: export { TokenCollector, type UsageRecord } from \"./token-collector.js\";\n589: export type { UsageSummary, UsageCallback } from \"./token-collector.js\";\n\n(End of file - total 589 lines)\n</content>","title":"src/lib/monitor.ts","metadata":{"preview":"/**\n * monitor.ts — Parse JSON events from agent and detect completion/failure.\n *\n * Responsibilities:\n *   - Parse newline-delimited JSON events from agent stdout\n *   - Detect session completion (agent finished)\n *   - Detect session ID from events\n *   - Detect errors and failures\n *   - Write per-agent raw log files for diagnostics\n *   - Maintain per-agent parsed activity log for TUI preview\n *\n * ## Process Lifecycle (audit: wave-detach-audit)\n *\n * ProcessMonitor manages the lifecycle of headless agent child processes:\n *\n * **Normal flow**: Agent stdout → JSON event parsing → callbacks → completion\n *   1. `addProcess()` registers a ChildProcess and attaches stdout/stderr listeners\n *   2. Stdout data is parsed line-by-line as JSON events\n *   3. Callbacks fire: `onSessionId`, `onActivity`, `onComplete`, `onError`\n *   4. On process exit (code 0 or sawFinalStop), `onComplete` is called","truncated":false,"loaded":[]},"time":{"start":1773482651295,"end":1773482651299}}}}
{"type":"tool_use","timestamp":1773482651694,"sessionID":"ses_314328225ffewlGaXNfSOaaL0F","part":{"id":"prt_cebcdaf08001NdCeD2NRrQYlLB","sessionID":"ses_314328225ffewlGaXNfSOaaL0F","messageID":"msg_cebcda100001s27bsx1an1tAYf","type":"tool","callID":"toolu_vrtx_01TMtT3kgugdswoSyNPCVwdV","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/token-core/src/config.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/token-core/src/config.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * config.ts — Load .wombo-combo/config.json, merge with defaults, validate, expose typed config.\n3:  *\n4:  * The config file lives at .wombo-combo/config.json inside the target project root.\n5:  * All values have sensible defaults so minimal config works out of the box.\n6:  */\n7: \n8: import { readFileSync, existsSync } from \"node:fs\";\n9: import { resolve } from \"node:path\";\n10: import type { MultiplexerPreference } from \"./lib/multiplexer.js\";\n11: \n12: // ---------------------------------------------------------------------------\n13: // .wombo-combo directory constant\n14: // ---------------------------------------------------------------------------\n15: \n16: /** Name of the directory that holds all wombo-combo files */\n17: export const WOMBO_DIR = \".wombo-combo\";\n18: \n19: // ---------------------------------------------------------------------------\n20: // Types\n21: // ---------------------------------------------------------------------------\n22: \n23: /** Agent registry download mode */\n24: export type AgentRegistryMode = \"auto\" | \"monitored\" | \"disabled\";\n25: \n26: export interface WomboConfig {\n27:   /** Directory name for task files relative to .wombo-combo/ (folder-based storage) */\n28:   tasksDir: string;\n29:   /** Directory name for archived task files relative to .wombo-combo/ */\n30:   archiveDir: string;\n31:   /** @deprecated Use tasksDir. Legacy single-file path relative to .wombo-combo/ */\n32:   tasksFile?: string;\n33:   /** @deprecated Use archiveDir. Legacy single-file path relative to .wombo-combo/ */\n34:   archiveFile?: string;\n35:   /** Base branch to create feature branches from */\n36:   baseBranch: string;\n37:   /** Build configuration */\n38:   build: {\n39:     /** Build command to run in worktrees */\n40:     command: string;\n41:     /** Build timeout in milliseconds */\n42:     timeout: number;\n43:     /** Build artifact directory (for quick \"did it build?\" checks) */\n44:     artifactDir: string;\n45:   };\n46:   /** Install configuration */\n47:   install: {\n48:     /** Install command to run in worktrees */\n49:     command: string;\n50:     /** Install timeout in milliseconds */\n51:     timeout: number;\n52:   };\n53:   /** Git configuration */\n54:   git: {\n55:     /** Branch name prefix for feature branches */\n56:     branchPrefix: string;\n57:     /** Git remote name */\n58:     remote: string;\n59:     /** Merge strategy flag */\n60:     mergeStrategy: string;\n61:   };\n62:   /** Agent configuration */\n63:   agent: {\n64:     /** Path to agent binary (null = auto-detect) */\n65:     bin: string | null;\n66:     /** Agent name to pass via --agent flag */\n67:     name: string;\n68:     /** Config files/dirs to copy into worktrees */\n69:     configFiles: string[];\n70:     /** Session name prefix for terminal multiplexer */\n71:     tmuxPrefix: string;\n72:     /** Terminal multiplexer preference: \"auto\" (prefer dmux), \"dmux\", or \"tmux\" */\n73:     multiplexer: MultiplexerPreference;\n74:   };\n75:   /** Portless integration for localhost server testing */\n76:   portless: {\n77:     /** Whether portless is enabled for agent worktrees */\n78:     enabled: boolean;\n79:     /** Path to portless binary (null = auto-detect via PATH) */\n80:     bin: string | null;\n81:     /** Proxy port (portless default is 1355) */\n82:     proxyPort: number;\n83:     /** Whether to use HTTPS mode */\n84:     https: boolean;\n85:   };\n86:   /** Backup configuration for tasks file */\n87:   backup: {\n88:     /** Maximum number of timestamped backups to keep */\n89:     maxBackups: number;\n90:   };\n91:   /** Default runtime values */\n92:   defaults: {\n93:     /** Max concurrent agents */\n94:     maxConcurrent: number;\n95:     /** Max retries per agent */\n96:     maxRetries: number;\n97:   };\n98:   /** Browser testing configuration */\n99:   browser: BrowserConfig;\n100:   /** Agent registry configuration for specialized agent downloads */\n101:   agentRegistry: AgentRegistryConfig;\n102:   /** Test-Driven Development configuration */\n103:   tdd: TddConfig;\n104: }\n105: \n106: /** Configuration for browser-based verification and testing */\n107: export interface BrowserConfig {\n108:   /** Enable browser testing in the verify pipeline */\n109:   enabled: boolean;\n110:   /** Path to browser binary (null = auto-detect) */\n111:   bin: string | null;\n112:   /** Run browser in headless mode (required for CI) */\n113:   headless: boolean;\n114:   /** Custom test command to run browser tests (overrides script discovery) */\n115:   testCommand: string | null;\n116:   /** Timeout for launching a browser instance (ms) */\n117:   launchTimeout: number;\n118:   /** Timeout for each browser test script (ms) */\n119:   testTimeout: number;\n120:   /** Default viewport size */\n121:   defaultViewport: {\n122:     width: number;\n123:     height: number;\n124:   };\n125: }\n126: \n127: /** Configuration for the external agent registry (e.g. agency-agents) */\n128: export interface AgentRegistryConfig {\n129:   /**\n130:    * Download mode:\n131:    * - \"auto\"      — download agents without asking (default)\n132:    * - \"monitored\" — user reviews/edits/rejects each agent before launch\n133:    * - \"disabled\"  — always use the generalist agent\n134:    */\n135:   mode: AgentRegistryMode;\n136:   /** GitHub repo in \"owner/repo\" format to pull agent definitions from */\n137:   source: string;\n138:   /** Cache directory name (relative to .wombo-combo/) */\n139:   cacheDir: string;\n140:   /** Cache TTL in milliseconds. Cached agents older than this are re-fetched. Default 24h. */\n141:   cacheTTL: number;\n142: }\n143: \n144: /** Configuration for Test-Driven Development workflow */\n145: export interface TddConfig {\n146:   /** Enable TDD red-green-refactor instructions in agent prompts */\n147:   enabled: boolean;\n148:   /** Test command to run (default: \"bun test\") */\n149:   testCommand: string;\n150:   /** Strict TDD mode: fail verification if new files are missing tests */\n151:   strictTdd: boolean;\n152:   /** Test command timeout in milliseconds (default: 120_000) */\n153:   testTimeout: number;\n154: }\n155: \n156: // ---------------------------------------------------------------------------\n157: // Defaults\n158: // ---------------------------------------------------------------------------\n159: \n160: export const DEFAULT_CONFIG: WomboConfig = {\n161:   tasksDir: \"tasks\",\n162:   archiveDir: \"archive\",\n163:   baseBranch: \"develop\",\n164:   build: {\n165:     command: \"bun run build\",\n166:     timeout: 300_000,\n167:     artifactDir: \"dist\",\n168:   },\n169:   install: {\n170:     command: \"bun install\",\n171:     timeout: 120_000,\n172:   },\n173:   git: {\n174:     branchPrefix: \"feature/\",\n175:     remote: \"origin\",\n176:     mergeStrategy: \"--no-ff\",\n177:   },\n178:   agent: {\n179:     bin: null,\n180:     name: \"generalist-agent\",\n181:     configFiles: [\".opencode/\", \"opencode.json\", \"AGENTS.md\"],\n182:     tmuxPrefix: \"wombo\",\n183:     multiplexer: \"auto\",\n184:   },\n185:   portless: {\n186:     enabled: true,\n187:     bin: null,\n188:     proxyPort: 1355,\n189:     https: false,\n190:   },\n191:   backup: {\n192:     maxBackups: 5,\n193:   },\n194:   defaults: {\n195:     maxConcurrent: 6,\n196:     maxRetries: 2,\n197:   },\n198:   browser: {\n199:     enabled: false,\n200:     bin: null,\n201:     headless: true,\n202:     testCommand: null,\n203:     launchTimeout: 30_000,\n204:     testTimeout: 60_000,\n205:     defaultViewport: {\n206:       width: 1280,\n207:       height: 720,\n208:     },\n209:   },\n210:   agentRegistry: {\n211:     mode: \"auto\",\n212:     source: \"msitarzewski/agency-agents\",\n213:     cacheDir: \"agents-cache\",\n214:     cacheTTL: 24 * 60 * 60 * 1000, // 24 hours\n215:   },\n216:   tdd: {\n217:     enabled: false,\n218:     testCommand: \"bun test\",\n219:     strictTdd: false,\n220:     testTimeout: 120_000,\n221:   },\n222: };\n223: \n224: // ---------------------------------------------------------------------------\n225: // Config File Name\n226: // ---------------------------------------------------------------------------\n227: \n228: export const CONFIG_FILE = `${WOMBO_DIR}/config.json`;\n229: \n230: // ---------------------------------------------------------------------------\n231: // Loader\n232: // ---------------------------------------------------------------------------\n233: \n234: /**\n235:  * Deep-merge source into target. Only merges plain objects, not arrays.\n236:  */\n237: function deepMerge<T extends Record<string, any>>(target: T, source: Partial<T>): T {\n238:   const result = { ...target };\n239:   for (const key of Object.keys(source) as (keyof T)[]) {\n240:     const srcVal = source[key];\n241:     const tgtVal = target[key];\n242:     if (\n243:       srcVal !== undefined &&\n244:       srcVal !== null &&\n245:       typeof srcVal === \"object\" &&\n246:       !Array.isArray(srcVal) &&\n247:       typeof tgtVal === \"object\" &&\n248:       !Array.isArray(tgtVal) &&\n249:       tgtVal !== null\n250:     ) {\n251:       result[key] = deepMerge(tgtVal as any, srcVal as any);\n252:     } else if (srcVal !== undefined) {\n253:       result[key] = srcVal as T[keyof T];\n254:     }\n255:   }\n256:   return result;\n257: }\n258: \n259: /**\n260:  * Load .wombo-combo/config.json from the given project root and merge with defaults.\n261:  * Returns the full config. If no config file exists, returns defaults.\n262:  */\n263: export function loadConfig(projectRoot: string): WomboConfig {\n264:   const configPath = resolve(projectRoot, CONFIG_FILE);\n265: \n266:   if (!existsSync(configPath)) {\n267:     return { ...DEFAULT_CONFIG };\n268:   }\n269: \n270:   try {\n271:     const raw = readFileSync(configPath, \"utf-8\");\n272:     const partial = JSON.parse(raw) as Partial<WomboConfig>;\n273: \n274:     // Migrate legacy single-file config keys to folder-based\n275:     if ((partial as any).tasksFile && !partial.tasksDir) {\n276:       // Legacy \"tasks.yml\" → strip extension for dir name, or use as-is\n277:       const legacy = (partial as any).tasksFile as string;\n278:       partial.tasksDir = legacy.replace(/\\.ya?ml$/i, \"\") || \"tasks\";\n279:       delete (partial as any).tasksFile;\n280:     }\n281:     if ((partial as any).archiveFile && !partial.archiveDir) {\n282:       const legacy = (partial as any).archiveFile as string;\n283:       partial.archiveDir = legacy.replace(/\\.ya?ml$/i, \"\") || \"archive\";\n284:       delete (partial as any).archiveFile;\n285:     }\n286: \n287:     return deepMerge(DEFAULT_CONFIG, partial);\n288:   } catch (err: any) {\n289:     throw new Error(`Failed to load ${CONFIG_FILE}: ${err.message}`);\n290:   }\n291: }\n292: \n293: /**\n294:  * Resolve the agent binary path. Priority:\n295:  *   1. config.agent.bin (explicit)\n296:  *   2. OPENCODE_BIN env var\n297:  *   3. ~/.opencode/bin/opencode (default install location)\n298:  */\n299: export function resolveAgentBin(config: WomboConfig): string {\n300:   if (config.agent.bin) return config.agent.bin;\n301:   if (process.env.OPENCODE_BIN) return process.env.OPENCODE_BIN;\n302:   return resolve(process.env.HOME || \"~\", \".opencode/bin/opencode\");\n303: }\n304: \n305: /**\n306:  * Validate the config for obvious issues. Throws on error.\n307:  */\n308: export function validateConfig(config: WomboConfig): void {\n309:   if (!config.tasksDir) {\n310:     throw new Error(\"config.tasksDir must be a non-empty string\");\n311:   }\n312:   if (!config.archiveDir) {\n313:     throw new Error(\"config.archiveDir must be a non-empty string\");\n314:   }\n315:   if (!config.baseBranch) {\n316:     throw new Error(\"config.baseBranch must be a non-empty string\");\n317:   }\n318:   if (!config.build.command) {\n319:     throw new Error(\"config.build.command must be a non-empty string\");\n320:   }\n321:   if (!config.install.command) {\n322:     throw new Error(\"config.install.command must be a non-empty string\");\n323:   }\n324:   if (!config.git.branchPrefix) {\n325:     throw new Error(\"config.git.branchPrefix must be a non-empty string\");\n326:   }\n327:   if (config.defaults.maxConcurrent < 1) {\n328:     throw new Error(\"config.defaults.maxConcurrent must be >= 1\");\n329:   }\n330:   if (config.defaults.maxRetries < 0) {\n331:     throw new Error(\"config.defaults.maxRetries must be >= 0\");\n332:   }\n333:   if (config.backup.maxBackups < 0) {\n334:     throw new Error(\"config.backup.maxBackups must be >= 0\");\n335:   }\n336:   const validModes: AgentRegistryMode[] = [\"auto\", \"monitored\", \"disabled\"];\n337:   if (!validModes.includes(config.agentRegistry.mode)) {\n338:     throw new Error(`config.agentRegistry.mode must be one of: ${validModes.join(\", \")}`);\n339:   }\n340:   if (!config.agentRegistry.source) {\n341:     throw new Error(\"config.agentRegistry.source must be a non-empty string\");\n342:   }\n343:   if (!config.agentRegistry.cacheDir) {\n344:     throw new Error(\"config.agentRegistry.cacheDir must be a non-empty string\");\n345:   }\n346:   if (config.tdd.enabled && !config.tdd.testCommand) {\n347:     throw new Error(\"config.tdd.testCommand must be a non-empty string when TDD is enabled\");\n348:   }\n349: }\n350: \n351: /**\n352:  * Generate the default .wombo-combo/config.json content string (for `woco init`).\n353:  */\n354: export function generateDefaultConfig(): string {\n355:   return JSON.stringify(DEFAULT_CONFIG, null, 2) + \"\\n\";\n356: }\n\n(End of file - total 356 lines)\n</content>","title":"src/config.ts","metadata":{"preview":"/**\n * config.ts — Load .wombo-combo/config.json, merge with defaults, validate, expose typed config.\n *\n * The config file lives at .wombo-combo/config.json inside the target project root.\n * All values have sensible defaults so minimal config works out of the box.\n */\n\nimport { readFileSync, existsSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\nimport type { MultiplexerPreference } from \"./lib/multiplexer.js\";\n\n// ---------------------------------------------------------------------------\n// .wombo-combo directory constant\n// ---------------------------------------------------------------------------\n\n/** Name of the directory that holds all wombo-combo files */\nexport const WOMBO_DIR = \".wombo-combo\";\n\n// ---------------------------------------------------------------------------\n// Types","truncated":false,"loaded":[]},"time":{"start":1773482651691,"end":1773482651693}}}}
