{"type":"tool_use","timestamp":1773482664848,"sessionID":"ses_314328225ffewlGaXNfSOaaL0F","part":{"id":"prt_cebcddfd4001LeEoG3nCeR0HNh","sessionID":"ses_314328225ffewlGaXNfSOaaL0F","messageID":"msg_cebcdcf59001Z4WKchmx47QPs1","type":"tool","callID":"toolu_vrtx_01EkDwLP1dFrQnmYx9CmCvCW","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/token-core/src/lib/state.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/token-core/src/lib/state.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * state.ts — Persistent wave state management.\n3:  *\n4:  * Responsibilities:\n5:  *   - Define the shape of .wombo-combo/state.json\n6:  *   - Read/write state atomically\n7:  *   - Generate wave IDs\n8:  *   - Update individual agent state within a wave\n9:  */\n10: \n11: import { readFileSync, writeFileSync, existsSync, renameSync, mkdirSync } from \"node:fs\";\n12: import { resolve } from \"node:path\";\n13: import { WOMBO_DIR } from \"../config.js\";\n14: \n15: // ---------------------------------------------------------------------------\n16: // Types\n17: // ---------------------------------------------------------------------------\n18: \n19: export type AgentStatus =\n20:   | \"queued\"\n21:   | \"installing\"\n22:   | \"running\"\n23:   | \"completed\"\n24:   | \"verified\"\n25:   | \"failed\"\n26:   | \"merged\"\n27:   | \"retry\"\n28:   | \"resolving_conflict\";\n29: \n30: export interface AgentState {\n31:   feature_id: string;\n32:   branch: string;\n33:   worktree: string;\n34:   session_id: string | null;\n35:   pid: number | null;\n36:   status: AgentStatus;\n37:   activity: string | null;\n38:   activity_updated_at: string | null;\n39:   retries: number;\n40:   max_retries: number;\n41:   started_at: string | null;\n42:   completed_at: string | null;\n43:   build_passed: boolean | null;\n44:   build_output: string | null;\n45:   error: string | null;\n46:   /** Estimated effort in milliseconds (from feature's ISO 8601 duration) */\n47:   effort_estimate_ms: number | null;\n48:   /** Stream index this agent belongs to (for dependency-aware scheduling) */\n49:   stream_index: number | null;\n50:   /** IDs of features this agent depends on (within the current wave) */\n51:   depends_on: string[];\n52:   /** IDs of features that depend on this agent (within the current wave) */\n53:   depended_on_by: string[];\n54:   /**\n55:    * Override agent name for this specific agent (from registry).\n56:    * When set, uses this agent definition instead of the default generalist.\n57:    * e.g. \"engineering-frontend-developer\"\n58:    */\n59:   agent_name: string | null;\n60:   /**\n61:    * The agent_type from the task (e.g. \"engineering/engineering-frontend-developer\").\n62:    * Stored for informational purposes and to support resume with re-fetch.\n63:    */\n64:   agent_type: string | null;\n65: }\n66: \n67: export interface WaveState {\n68:   wave_id: string;\n69:   base_branch: string;\n70:   started_at: string;\n71:   updated_at: string;\n72:   max_concurrent: number;\n73:   model: string | null;\n74:   interactive: boolean;\n75:   agents: AgentState[];\n76:   /** Dependency-aware scheduling plan (null if no dependencies exist) */\n77:   schedule_plan: SerializedSchedulePlan | null;\n78:   /** Quest ID this wave belongs to (null if not quest-scoped) */\n79:   quest_id: string | null;\n80: }\n81: \n82: /**\n83:  * Serialized schedule plan stored in wave state JSON.\n84:  * Uses plain arrays instead of the rich SchedulePlan type for JSON compatibility.\n85:  */\n86: export interface SerializedSchedulePlan {\n87:   /** Streams: each is a list of feature IDs to execute sequentially */\n88:   streams: string[][];\n89:   /** Merge gates: features that must wait for multiple deps from different streams */\n90:   merge_gates: Array<{ feature_id: string; wait_for: string[] }>;\n91:   /** Topological order of all features */\n92:   topological_order: string[];\n93: }\n94: \n95: // ---------------------------------------------------------------------------\n96: // Constants\n97: // ---------------------------------------------------------------------------\n98: \n99: const STATE_FILE = \".wombo-combo/state.json\";\n100: \n101: // ---------------------------------------------------------------------------\n102: // Wave ID Generation\n103: // ---------------------------------------------------------------------------\n104: \n105: /**\n106:  * Generate a unique wave ID based on current timestamp.\n107:  * Format: wave-YYYY-MM-DD-NNN\n108:  */\n109: export function generateWaveId(): string {\n110:   const now = new Date();\n111:   const date = now.toISOString().slice(0, 10);\n112:   const seq = String(now.getHours() * 60 + now.getMinutes()).padStart(3, \"0\");\n113:   return `wave-${date}-${seq}`;\n114: }\n115: \n116: // ---------------------------------------------------------------------------\n117: // State Path\n118: // ---------------------------------------------------------------------------\n119: \n120: function statePath(projectRoot: string): string {\n121:   return resolve(projectRoot, STATE_FILE);\n122: }\n123: \n124: // ---------------------------------------------------------------------------\n125: // Read State\n126: // ---------------------------------------------------------------------------\n127: \n128: /**\n129:  * Load the current wave state from disk. Returns null if no state file exists.\n130:  */\n131: export function loadState(projectRoot: string): WaveState | null {\n132:   const p = statePath(projectRoot);\n133:   if (!existsSync(p)) return null;\n134:   try {\n135:     const raw = readFileSync(p, \"utf-8\");\n136:     return JSON.parse(raw) as WaveState;\n137:   } catch {\n138:     return null;\n139:   }\n140: }\n141: \n142: // ---------------------------------------------------------------------------\n143: // Write State\n144: // ---------------------------------------------------------------------------\n145: \n146: /**\n147:  * Save wave state to disk atomically (write to tmp then rename).\n148:  */\n149: export function saveState(projectRoot: string, state: WaveState): void {\n150:   const dir = resolve(projectRoot, WOMBO_DIR);\n151:   if (!existsSync(dir)) mkdirSync(dir, { recursive: true });\n152:   state.updated_at = new Date().toISOString();\n153:   const p = statePath(projectRoot);\n154:   const tmp = p + \".tmp\";\n155:   writeFileSync(tmp, JSON.stringify(state, null, 2) + \"\\n\", \"utf-8\");\n156:   renameSync(tmp, p);\n157: }\n158: \n159: // ---------------------------------------------------------------------------\n160: // State Mutations\n161: // ---------------------------------------------------------------------------\n162: \n163: /**\n164:  * Create a fresh wave state.\n165:  */\n166: export function createWaveState(opts: {\n167:   baseBranch: string;\n168:   maxConcurrent: number;\n169:   model: string | null;\n170:   interactive: boolean;\n171:   questId?: string | null;\n172: }): WaveState {\n173:   return {\n174:     wave_id: generateWaveId(),\n175:     base_branch: opts.baseBranch,\n176:     started_at: new Date().toISOString(),\n177:     updated_at: new Date().toISOString(),\n178:     max_concurrent: opts.maxConcurrent,\n179:     model: opts.model,\n180:     interactive: opts.interactive,\n181:     agents: [],\n182:     schedule_plan: null,\n183:     quest_id: opts.questId ?? null,\n184:   };\n185: }\n186: \n187: /**\n188:  * Create an initial agent state for a feature.\n189:  */\n190: export function createAgentState(\n191:   featureId: string,\n192:   branch: string,\n193:   worktreePath: string,\n194:   maxRetries: number = 2\n195: ): AgentState {\n196:   return {\n197:     feature_id: featureId,\n198:     branch,\n199:     worktree: worktreePath,\n200:     session_id: null,\n201:     pid: null,\n202:     status: \"queued\",\n203:     activity: null,\n204:     activity_updated_at: null,\n205:     retries: 0,\n206:     max_retries: maxRetries,\n207:     started_at: null,\n208:     completed_at: null,\n209:     build_passed: null,\n210:     build_output: null,\n211:     error: null,\n212:     effort_estimate_ms: null,\n213:     stream_index: null,\n214:     depends_on: [],\n215:     depended_on_by: [],\n216:     agent_name: null,\n217:     agent_type: null,\n218:   };\n219: }\n220: \n221: /**\n222:  * Find an agent state by feature ID.\n223:  */\n224: export function getAgent(\n225:   state: WaveState,\n226:   featureId: string\n227: ): AgentState | undefined {\n228:   return state.agents.find((a) => a.feature_id === featureId);\n229: }\n230: \n231: /**\n232:  * Update an agent's state fields.\n233:  */\n234: export function updateAgent(\n235:   state: WaveState,\n236:   featureId: string,\n237:   updates: Partial<AgentState>\n238: ): void {\n239:   const agent = state.agents.find((a) => a.feature_id === featureId);\n240:   if (!agent) throw new Error(`Agent not found for feature: ${featureId}`);\n241:   Object.assign(agent, updates);\n242: }\n243: \n244: /**\n245:  * Get counts of agents by status.\n246:  */\n247: export function agentCounts(state: WaveState): Record<AgentStatus, number> {\n248:   const counts: Record<AgentStatus, number> = {\n249:     queued: 0,\n250:     installing: 0,\n251:     running: 0,\n252:     completed: 0,\n253:     verified: 0,\n254:     failed: 0,\n255:     merged: 0,\n256:     retry: 0,\n257:     resolving_conflict: 0,\n258:   };\n259:   for (const a of state.agents) {\n260:     counts[a.status]++;\n261:   }\n262:   return counts;\n263: }\n264: \n265: /**\n266:  * Get agents that are currently running or installing.\n267:  */\n268: export function activeAgents(state: WaveState): AgentState[] {\n269:   return state.agents.filter(\n270:     (a) => a.status === \"running\" || a.status === \"installing\" || a.status === \"resolving_conflict\"\n271:   );\n272: }\n273: \n274: /**\n275:  * Get agents that are queued and ready to be launched.\n276:  */\n277: export function queuedAgents(state: WaveState): AgentState[] {\n278:   return state.agents.filter((a) => a.status === \"queued\");\n279: }\n280: \n281: /**\n282:  * Check if the wave is fully complete (no queued, installing, running, or retry agents).\n283:  */\n284: export function isWaveComplete(state: WaveState): boolean {\n285:   return state.agents.every(\n286:     (a) =>\n287:       a.status === \"completed\" ||\n288:       a.status === \"verified\" ||\n289:       a.status === \"failed\" ||\n290:       a.status === \"merged\"\n291:   );\n292: }\n293: \n294: // ---------------------------------------------------------------------------\n295: // Dependency-Aware Helpers\n296: // ---------------------------------------------------------------------------\n297: \n298: /**\n299:  * Terminal statuses that count as \"dependency satisfied\" for downstream features.\n300:  * A dependency is satisfied when it has been verified or merged.\n301:  */\n302: const DEP_SATISFIED_STATUSES: Set<AgentStatus> = new Set([\"verified\", \"merged\"]);\n303: \n304: /**\n305:  * Check if an agent's dependencies within the wave are all satisfied.\n306:  * Dependencies are satisfied when their agents reach \"verified\" or \"merged\" status.\n307:  *\n308:  * If the agent has no depends_on entries, it's always ready.\n309:  */\n310: export function areAgentDepsReady(\n311:   state: WaveState,\n312:   agent: AgentState\n313: ): boolean {\n314:   if (agent.depends_on.length === 0) return true;\n315: \n316:   for (const depId of agent.depends_on) {\n317:     const depAgent = state.agents.find((a) => a.feature_id === depId);\n318:     if (depAgent && !DEP_SATISFIED_STATUSES.has(depAgent.status)) {\n319:       return false;\n320:     }\n321:     // If depAgent doesn't exist in this wave, the dep is external — assumed satisfied\n322:   }\n323:   return true;\n324: }\n325: \n326: /**\n327:  * Get queued agents whose dependencies are all satisfied.\n328:  * This is the dependency-aware replacement for plain queuedAgents().\n329:  */\n330: export function readyToLaunchAgents(state: WaveState): AgentState[] {\n331:   return state.agents.filter(\n332:     (a) => a.status === \"queued\" && areAgentDepsReady(state, a)\n333:   );\n334: }\n335: \n336: /**\n337:  * Get all agents that are downstream (depend on) a given feature, directly or transitively.\n338:  * Used for failure cascading — when a feature fails, cancel all downstream.\n339:  */\n340: export function getDownstreamAgents(\n341:   state: WaveState,\n342:   featureId: string\n343: ): AgentState[] {\n344:   const visited = new Set<string>();\n345:   const result: AgentState[] = [];\n346: \n347:   function collect(id: string): void {\n348:     const agent = state.agents.find((a) => a.feature_id === id);\n349:     if (!agent) return;\n350: \n351:     for (const downstreamId of agent.depended_on_by) {\n352:       if (visited.has(downstreamId)) continue;\n353:       visited.add(downstreamId);\n354: \n355:       const downstream = state.agents.find((a) => a.feature_id === downstreamId);\n356:       if (downstream) {\n357:         result.push(downstream);\n358:         collect(downstreamId);\n359:       }\n360:     }\n361:   }\n362: \n363:   collect(featureId);\n364:   return result;\n365: }\n366: \n367: /**\n368:  * Cancel all downstream agents when an upstream dependency fails.\n369:  * Sets status to \"failed\" with an error explaining the dependency failure.\n370:  * Returns the list of cancelled agent IDs.\n371:  */\n372: export function cancelDownstream(\n373:   state: WaveState,\n374:   failedFeatureId: string\n375: ): string[] {\n376:   const downstream = getDownstreamAgents(state, failedFeatureId);\n377:   const cancelled: string[] = [];\n378: \n379:   for (const agent of downstream) {\n380:     // Only cancel agents that haven't already reached a terminal state\n381:     if (\n382:       agent.status === \"queued\" ||\n383:       agent.status === \"installing\" ||\n384:       agent.status === \"running\" ||\n385:       agent.status === \"retry\"\n386:     ) {\n387:       updateAgent(state, agent.feature_id, {\n388:         status: \"failed\",\n389:         error: `Dependency \"${failedFeatureId}\" failed — downstream cancelled`,\n390:         activity: null,\n391:         completed_at: new Date().toISOString(),\n392:       });\n393:       cancelled.push(agent.feature_id);\n394:     }\n395:   }\n396: \n397:   return cancelled;\n398: }\n\n(End of file - total 398 lines)\n</content>","title":"src/lib/state.ts","metadata":{"preview":"/**\n * state.ts — Persistent wave state management.\n *\n * Responsibilities:\n *   - Define the shape of .wombo-combo/state.json\n *   - Read/write state atomically\n *   - Generate wave IDs\n *   - Update individual agent state within a wave\n */\n\nimport { readFileSync, writeFileSync, existsSync, renameSync, mkdirSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\nimport { WOMBO_DIR } from \"../config.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type AgentStatus =\n  | \"queued\"","truncated":false,"loaded":[]},"time":{"start":1773482664844,"end":1773482664847}}}}
