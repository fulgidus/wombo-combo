{"type":"tool_use","timestamp":1773482665202,"sessionID":"ses_314328225ffewlGaXNfSOaaL0F","part":{"id":"prt_cebcde38e001vfQvKVxiIl9AvQ","sessionID":"ses_314328225ffewlGaXNfSOaaL0F","messageID":"msg_cebcdcf59001Z4WKchmx47QPs1","type":"tool","callID":"toolu_vrtx_01J7uwATgJmp3LW4HJsAvrUP","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/token-core/src/lib/history.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/token-core/src/lib/history.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * history.ts — Wave history persistence.\n3:  *\n4:  * Responsibilities:\n5:  *   - Define the shape of wave history records\n6:  *   - Save wave history to .wombo-combo/history/<wave-id>.json\n7:  *   - Load individual history records\n8:  *   - List all saved history records\n9:  *   - Export wave state to history on completion\n10:  *\n11:  * History records survive `woco cleanup` because they are stored\n12:  * separately from .wombo-combo/state.json. The .wombo-combo/history/\n13:  * directory is gitignored.\n14:  */\n15: \n16: import {\n17:   existsSync,\n18:   mkdirSync,\n19:   readFileSync,\n20:   writeFileSync,\n21:   readdirSync,\n22:   renameSync,\n23: } from \"node:fs\";\n24: import { resolve, basename } from \"node:path\";\n25: import type { WaveState, AgentState, AgentStatus } from \"./state.js\";\n26: \n27: // ---------------------------------------------------------------------------\n28: // Types\n29: // ---------------------------------------------------------------------------\n30: \n31: export interface AgentHistoryRecord {\n32:   feature_id: string;\n33:   branch: string;\n34:   status: AgentStatus;\n35:   /** Number of retries attempted */\n36:   retries: number;\n37:   max_retries: number;\n38:   /** Whether the build passed (null if never verified) */\n39:   build_passed: boolean | null;\n40:   /** ISO 8601 timestamp when the agent started */\n41:   started_at: string | null;\n42:   /** ISO 8601 timestamp when the agent finished */\n43:   completed_at: string | null;\n44:   /** Duration in milliseconds (computed from started_at → completed_at) */\n45:   duration_ms: number | null;\n46:   /** Error message if failed */\n47:   error: string | null;\n48:   /** Whether the agent encountered merge conflicts */\n49:   had_merge_conflict: boolean;\n50:   /** Build output summary (only for failed builds) */\n51:   build_output: string | null;\n52: }\n53: \n54: export interface WaveHistoryRecord {\n55:   /** Unique wave identifier */\n56:   wave_id: string;\n57:   /** Base branch used for this wave */\n58:   base_branch: string;\n59:   /** ISO 8601 timestamp when the wave started */\n60:   started_at: string;\n61:   /** ISO 8601 timestamp when the history was exported */\n62:   exported_at: string;\n63:   /** Model used (if any) */\n64:   model: string | null;\n65:   /** Max concurrency setting */\n66:   max_concurrent: number;\n67:   /** Whether the wave ran in interactive mode */\n68:   interactive: boolean;\n69:   /** Summary statistics */\n70:   summary: {\n71:     total: number;\n72:     succeeded: number;\n73:     failed: number;\n74:     merged: number;\n75:     verified: number;\n76:     total_retries: number;\n77:     total_duration_ms: number;\n78:   };\n79:   /** Per-agent results */\n80:   agents: AgentHistoryRecord[];\n81: }\n82: \n83: // ---------------------------------------------------------------------------\n84: // Constants\n85: // ---------------------------------------------------------------------------\n86: \n87: const HISTORY_DIR = \".wombo-combo/history\";\n88: \n89: // ---------------------------------------------------------------------------\n90: // History Directory\n91: // ---------------------------------------------------------------------------\n92: \n93: function historyDir(projectRoot: string): string {\n94:   return resolve(projectRoot, HISTORY_DIR);\n95: }\n96: \n97: function ensureHistoryDir(projectRoot: string): string {\n98:   const dir = historyDir(projectRoot);\n99:   if (!existsSync(dir)) {\n100:     mkdirSync(dir, { recursive: true });\n101:   }\n102:   return dir;\n103: }\n104: \n105: // ---------------------------------------------------------------------------\n106: // Export Wave State → History Record\n107: // ---------------------------------------------------------------------------\n108: \n109: /**\n110:  * Convert a WaveState to a WaveHistoryRecord for persistence.\n111:  */\n112: export function waveStateToHistory(state: WaveState): WaveHistoryRecord {\n113:   const agents: AgentHistoryRecord[] = state.agents.map((agent) => {\n114:     const durationMs = computeDuration(agent.started_at, agent.completed_at);\n115:     const hadConflict =\n116:       agent.status === \"resolving_conflict\" ||\n117:       (agent.error != null && agent.error.toLowerCase().includes(\"conflict\"));\n118: \n119:     return {\n120:       feature_id: agent.feature_id,\n121:       branch: agent.branch,\n122:       status: agent.status,\n123:       retries: agent.retries,\n124:       max_retries: agent.max_retries,\n125:       build_passed: agent.build_passed,\n126:       started_at: agent.started_at,\n127:       completed_at: agent.completed_at,\n128:       duration_ms: durationMs,\n129:       error: agent.error,\n130:       had_merge_conflict: hadConflict,\n131:       build_output: agent.build_passed === false ? agent.build_output : null,\n132:     };\n133:   });\n134: \n135:   const succeeded = agents.filter(\n136:     (a) => a.status === \"merged\" || a.status === \"verified\"\n137:   ).length;\n138:   const failed = agents.filter((a) => a.status === \"failed\").length;\n139:   const merged = agents.filter((a) => a.status === \"merged\").length;\n140:   const verified = agents.filter((a) => a.status === \"verified\").length;\n141:   const totalRetries = agents.reduce((sum, a) => sum + a.retries, 0);\n142:   const totalDuration = agents.reduce(\n143:     (sum, a) => sum + (a.duration_ms ?? 0),\n144:     0\n145:   );\n146: \n147:   return {\n148:     wave_id: state.wave_id,\n149:     base_branch: state.base_branch,\n150:     started_at: state.started_at,\n151:     exported_at: new Date().toISOString(),\n152:     model: state.model,\n153:     max_concurrent: state.max_concurrent,\n154:     interactive: state.interactive,\n155:     summary: {\n156:       total: agents.length,\n157:       succeeded,\n158:       failed,\n159:       merged,\n160:       verified,\n161:       total_retries: totalRetries,\n162:       total_duration_ms: totalDuration,\n163:     },\n164:     agents,\n165:   };\n166: }\n167: \n168: // ---------------------------------------------------------------------------\n169: // Save History\n170: // ---------------------------------------------------------------------------\n171: \n172: /**\n173:  * Save a wave history record to .wombo-combo/history/<wave-id>.json.\n174:  * Writes atomically (tmp + rename).\n175:  */\n176: export function saveHistory(\n177:   projectRoot: string,\n178:   record: WaveHistoryRecord\n179: ): string {\n180:   const dir = ensureHistoryDir(projectRoot);\n181:   const filename = `${record.wave_id}.json`;\n182:   const filePath = resolve(dir, filename);\n183:   const tmpPath = filePath + \".tmp\";\n184: \n185:   writeFileSync(tmpPath, JSON.stringify(record, null, 2) + \"\\n\", \"utf-8\");\n186:   renameSync(tmpPath, filePath);\n187: \n188:   return filePath;\n189: }\n190: \n191: /**\n192:  * Export the current wave state to history. This is the main entry point\n193:  * called when a wave completes.\n194:  *\n195:  * Returns the path to the saved history file.\n196:  */\n197: export function exportWaveHistory(\n198:   projectRoot: string,\n199:   state: WaveState\n200: ): string {\n201:   const record = waveStateToHistory(state);\n202:   const filePath = saveHistory(projectRoot, record);\n203:   return filePath;\n204: }\n205: \n206: // ---------------------------------------------------------------------------\n207: // Load History\n208: // ---------------------------------------------------------------------------\n209: \n210: /**\n211:  * Load a single wave history record by wave ID.\n212:  * Returns null if not found.\n213:  */\n214: export function loadHistory(\n215:   projectRoot: string,\n216:   waveId: string\n217: ): WaveHistoryRecord | null {\n218:   const filePath = resolve(historyDir(projectRoot), `${waveId}.json`);\n219:   if (!existsSync(filePath)) return null;\n220: \n221:   try {\n222:     const raw = readFileSync(filePath, \"utf-8\");\n223:     return JSON.parse(raw) as WaveHistoryRecord;\n224:   } catch {\n225:     return null;\n226:   }\n227: }\n228: \n229: /**\n230:  * List all wave history records, sorted by start time (newest first).\n231:  * Returns lightweight summaries without full agent details.\n232:  */\n233: export function listHistory(projectRoot: string): WaveHistoryRecord[] {\n234:   const dir = historyDir(projectRoot);\n235:   if (!existsSync(dir)) return [];\n236: \n237:   const files = readdirSync(dir)\n238:     .filter((f) => f.endsWith(\".json\") && !f.endsWith(\".tmp\"))\n239:     .sort()\n240:     .reverse(); // newest first (wave IDs contain dates)\n241: \n242:   const records: WaveHistoryRecord[] = [];\n243:   for (const file of files) {\n244:     try {\n245:       const raw = readFileSync(resolve(dir, file), \"utf-8\");\n246:       const record = JSON.parse(raw) as WaveHistoryRecord;\n247:       records.push(record);\n248:     } catch {\n249:       // Skip corrupt files\n250:     }\n251:   }\n252: \n253:   return records;\n254: }\n255: \n256: // ---------------------------------------------------------------------------\n257: // Helpers\n258: // ---------------------------------------------------------------------------\n259: \n260: /**\n261:  * Compute duration in milliseconds between two ISO timestamps.\n262:  * Returns null if either timestamp is missing.\n263:  */\n264: function computeDuration(\n265:   startedAt: string | null,\n266:   completedAt: string | null\n267: ): number | null {\n268:   if (!startedAt || !completedAt) return null;\n269:   const start = new Date(startedAt).getTime();\n270:   const end = new Date(completedAt).getTime();\n271:   if (isNaN(start) || isNaN(end)) return null;\n272:   return Math.max(0, end - start);\n273: }\n\n(End of file - total 273 lines)\n</content>","title":"src/lib/history.ts","metadata":{"preview":"/**\n * history.ts — Wave history persistence.\n *\n * Responsibilities:\n *   - Define the shape of wave history records\n *   - Save wave history to .wombo-combo/history/<wave-id>.json\n *   - Load individual history records\n *   - List all saved history records\n *   - Export wave state to history on completion\n *\n * History records survive `woco cleanup` because they are stored\n * separately from .wombo-combo/state.json. The .wombo-combo/history/\n * directory is gitignored.\n */\n\nimport {\n  existsSync,\n  mkdirSync,\n  readFileSync,\n  writeFileSync,","truncated":false,"loaded":[]},"time":{"start":1773482665198,"end":1773482665201}}}}
