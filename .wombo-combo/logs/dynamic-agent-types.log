{"type":"tool_use","timestamp":1773440116649,"sessionID":"ses_316bba7bfffeeA1IqckNkl9JmJ","part":{"id":"prt_ce944a4de001h3T51eomYfas6u","sessionID":"ses_316bba7bfffeeA1IqckNkl9JmJ","messageID":"msg_ce9449636001QAUsgE7moHXwpe","type":"tool","callID":"toolu_vrtx_01H4J5pQMgNkNMfUKqFPvEZe","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/dynamic-agent-types/src/config.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/dynamic-agent-types/src/config.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * config.ts — Load .wombo-combo/config.json, merge with defaults, validate, expose typed config.\n3:  *\n4:  * The config file lives at .wombo-combo/config.json inside the target project root.\n5:  * All values have sensible defaults so minimal config works out of the box.\n6:  */\n7: \n8: import { readFileSync, existsSync } from \"node:fs\";\n9: import { resolve } from \"node:path\";\n10: import type { MultiplexerPreference } from \"./lib/multiplexer.js\";\n11: \n12: // ---------------------------------------------------------------------------\n13: // .wombo-combo directory constant\n14: // ---------------------------------------------------------------------------\n15: \n16: /** Name of the directory that holds all wombo-combo files */\n17: export const WOMBO_DIR = \".wombo-combo\";\n18: \n19: // ---------------------------------------------------------------------------\n20: // Types\n21: // ---------------------------------------------------------------------------\n22: \n23: /** Agent registry download mode */\n24: export type AgentRegistryMode = \"auto\" | \"monitored\" | \"disabled\";\n25: \n26: export interface WomboConfig {\n27:   /** Directory name for task files relative to .wombo-combo/ (folder-based storage) */\n28:   tasksDir: string;\n29:   /** Directory name for archived task files relative to .wombo-combo/ */\n30:   archiveDir: string;\n31:   /** @deprecated Use tasksDir. Legacy single-file path relative to .wombo-combo/ */\n32:   tasksFile?: string;\n33:   /** @deprecated Use archiveDir. Legacy single-file path relative to .wombo-combo/ */\n34:   archiveFile?: string;\n35:   /** Base branch to create feature branches from */\n36:   baseBranch: string;\n37:   /** Build configuration */\n38:   build: {\n39:     /** Build command to run in worktrees */\n40:     command: string;\n41:     /** Build timeout in milliseconds */\n42:     timeout: number;\n43:     /** Build artifact directory (for quick \"did it build?\" checks) */\n44:     artifactDir: string;\n45:   };\n46:   /** Install configuration */\n47:   install: {\n48:     /** Install command to run in worktrees */\n49:     command: string;\n50:     /** Install timeout in milliseconds */\n51:     timeout: number;\n52:   };\n53:   /** Git configuration */\n54:   git: {\n55:     /** Branch name prefix for feature branches */\n56:     branchPrefix: string;\n57:     /** Worktree directory name prefix */\n58:     worktreePrefix: string;\n59:     /** Git remote name */\n60:     remote: string;\n61:     /** Merge strategy flag */\n62:     mergeStrategy: string;\n63:   };\n64:   /** Agent configuration */\n65:   agent: {\n66:     /** Path to agent binary (null = auto-detect) */\n67:     bin: string | null;\n68:     /** Agent name to pass via --agent flag */\n69:     name: string;\n70:     /** Config files/dirs to copy into worktrees */\n71:     configFiles: string[];\n72:     /** Session name prefix for terminal multiplexer */\n73:     tmuxPrefix: string;\n74:     /** Terminal multiplexer preference: \"auto\" (prefer dmux), \"dmux\", or \"tmux\" */\n75:     multiplexer: MultiplexerPreference;\n76:   };\n77:   /** Portless integration for localhost server testing */\n78:   portless: {\n79:     /** Whether portless is enabled for agent worktrees */\n80:     enabled: boolean;\n81:     /** Path to portless binary (null = auto-detect via PATH) */\n82:     bin: string | null;\n83:     /** Proxy port (portless default is 1355) */\n84:     proxyPort: number;\n85:     /** Whether to use HTTPS mode */\n86:     https: boolean;\n87:   };\n88:   /** Backup configuration for tasks file */\n89:   backup: {\n90:     /** Maximum number of timestamped backups to keep */\n91:     maxBackups: number;\n92:   };\n93:   /** Default runtime values */\n94:   defaults: {\n95:     /** Max concurrent agents */\n96:     maxConcurrent: number;\n97:     /** Max retries per agent */\n98:     maxRetries: number;\n99:   };\n100:   /** Browser testing configuration */\n101:   browser: BrowserConfig;\n102:   /** Agent registry configuration for specialized agent downloads */\n103:   agentRegistry: AgentRegistryConfig;\n104:   /** Test-Driven Development configuration */\n105:   tdd: TddConfig;\n106: }\n107: \n108: /** Configuration for browser-based verification and testing */\n109: export interface BrowserConfig {\n110:   /** Enable browser testing in the verify pipeline */\n111:   enabled: boolean;\n112:   /** Path to browser binary (null = auto-detect) */\n113:   bin: string | null;\n114:   /** Run browser in headless mode (required for CI) */\n115:   headless: boolean;\n116:   /** Custom test command to run browser tests (overrides script discovery) */\n117:   testCommand: string | null;\n118:   /** Timeout for launching a browser instance (ms) */\n119:   launchTimeout: number;\n120:   /** Timeout for each browser test script (ms) */\n121:   testTimeout: number;\n122:   /** Default viewport size */\n123:   defaultViewport: {\n124:     width: number;\n125:     height: number;\n126:   };\n127: }\n128: \n129: /** Configuration for the external agent registry (e.g. agency-agents) */\n130: export interface AgentRegistryConfig {\n131:   /**\n132:    * Download mode:\n133:    * - \"auto\"      — download agents without asking (default)\n134:    * - \"monitored\" — user reviews/edits/rejects each agent before launch\n135:    * - \"disabled\"  — always use the generalist agent\n136:    */\n137:   mode: AgentRegistryMode;\n138:   /** GitHub repo in \"owner/repo\" format to pull agent definitions from */\n139:   source: string;\n140:   /** Cache directory name (relative to .wombo-combo/) */\n141:   cacheDir: string;\n142:   /** Cache TTL in milliseconds. Cached agents older than this are re-fetched. Default 24h. */\n143:   cacheTTL: number;\n144: }\n145: \n146: /** Configuration for Test-Driven Development workflow */\n147: export interface TddConfig {\n148:   /** Enable TDD red-green-refactor instructions in agent prompts */\n149:   enabled: boolean;\n150:   /** Test command to run (default: \"bun test\") */\n151:   testCommand: string;\n152:   /** Strict TDD mode: fail verification if new files are missing tests */\n153:   strictTdd: boolean;\n154:   /** Test command timeout in milliseconds (default: 120_000) */\n155:   testTimeout: number;\n156: }\n157: \n158: // ---------------------------------------------------------------------------\n159: // Defaults\n160: // ---------------------------------------------------------------------------\n161: \n162: export const DEFAULT_CONFIG: WomboConfig = {\n163:   tasksDir: \"tasks\",\n164:   archiveDir: \"archive\",\n165:   baseBranch: \"develop\",\n166:   build: {\n167:     command: \"bun run build\",\n168:     timeout: 300_000,\n169:     artifactDir: \"dist\",\n170:   },\n171:   install: {\n172:     command: \"bun install\",\n173:     timeout: 120_000,\n174:   },\n175:   git: {\n176:     branchPrefix: \"feature/\",\n177:     worktreePrefix: \"wombo-\",\n178:     remote: \"origin\",\n179:     mergeStrategy: \"--no-ff\",\n180:   },\n181:   agent: {\n182:     bin: null,\n183:     name: \"generalist-agent\",\n184:     configFiles: [\".opencode/\", \"opencode.json\", \"AGENTS.md\"],\n185:     tmuxPrefix: \"wombo\",\n186:     multiplexer: \"auto\",\n187:   },\n188:   portless: {\n189:     enabled: true,\n190:     bin: null,\n191:     proxyPort: 1355,\n192:     https: false,\n193:   },\n194:   backup: {\n195:     maxBackups: 5,\n196:   },\n197:   defaults: {\n198:     maxConcurrent: 6,\n199:     maxRetries: 2,\n200:   },\n201:   browser: {\n202:     enabled: false,\n203:     bin: null,\n204:     headless: true,\n205:     testCommand: null,\n206:     launchTimeout: 30_000,\n207:     testTimeout: 60_000,\n208:     defaultViewport: {\n209:       width: 1280,\n210:       height: 720,\n211:     },\n212:   },\n213:   agentRegistry: {\n214:     mode: \"auto\",\n215:     source: \"msitarzewski/agency-agents\",\n216:     cacheDir: \"agents-cache\",\n217:     cacheTTL: 24 * 60 * 60 * 1000, // 24 hours\n218:   },\n219:   tdd: {\n220:     enabled: false,\n221:     testCommand: \"bun test\",\n222:     strictTdd: false,\n223:     testTimeout: 120_000,\n224:   },\n225: };\n226: \n227: // ---------------------------------------------------------------------------\n228: // Config File Name\n229: // ---------------------------------------------------------------------------\n230: \n231: export const CONFIG_FILE = `${WOMBO_DIR}/config.json`;\n232: \n233: // ---------------------------------------------------------------------------\n234: // Loader\n235: // ---------------------------------------------------------------------------\n236: \n237: /**\n238:  * Deep-merge source into target. Only merges plain objects, not arrays.\n239:  */\n240: function deepMerge<T extends Record<string, any>>(target: T, source: Partial<T>): T {\n241:   const result = { ...target };\n242:   for (const key of Object.keys(source) as (keyof T)[]) {\n243:     const srcVal = source[key];\n244:     const tgtVal = target[key];\n245:     if (\n246:       srcVal !== undefined &&\n247:       srcVal !== null &&\n248:       typeof srcVal === \"object\" &&\n249:       !Array.isArray(srcVal) &&\n250:       typeof tgtVal === \"object\" &&\n251:       !Array.isArray(tgtVal) &&\n252:       tgtVal !== null\n253:     ) {\n254:       result[key] = deepMerge(tgtVal as any, srcVal as any);\n255:     } else if (srcVal !== undefined) {\n256:       result[key] = srcVal as T[keyof T];\n257:     }\n258:   }\n259:   return result;\n260: }\n261: \n262: /**\n263:  * Load .wombo-combo/config.json from the given project root and merge with defaults.\n264:  * Returns the full config. If no config file exists, returns defaults.\n265:  */\n266: export function loadConfig(projectRoot: string): WomboConfig {\n267:   const configPath = resolve(projectRoot, CONFIG_FILE);\n268: \n269:   if (!existsSync(configPath)) {\n270:     return { ...DEFAULT_CONFIG };\n271:   }\n272: \n273:   try {\n274:     const raw = readFileSync(configPath, \"utf-8\");\n275:     const partial = JSON.parse(raw) as Partial<WomboConfig>;\n276: \n277:     // Migrate legacy single-file config keys to folder-based\n278:     if ((partial as any).tasksFile && !partial.tasksDir) {\n279:       // Legacy \"tasks.yml\" → strip extension for dir name, or use as-is\n280:       const legacy = (partial as any).tasksFile as string;\n281:       partial.tasksDir = legacy.replace(/\\.ya?ml$/i, \"\") || \"tasks\";\n282:       delete (partial as any).tasksFile;\n283:     }\n284:     if ((partial as any).archiveFile && !partial.archiveDir) {\n285:       const legacy = (partial as any).archiveFile as string;\n286:       partial.archiveDir = legacy.replace(/\\.ya?ml$/i, \"\") || \"archive\";\n287:       delete (partial as any).archiveFile;\n288:     }\n289: \n290:     return deepMerge(DEFAULT_CONFIG, partial);\n291:   } catch (err: any) {\n292:     throw new Error(`Failed to load ${CONFIG_FILE}: ${err.message}`);\n293:   }\n294: }\n295: \n296: /**\n297:  * Resolve the agent binary path. Priority:\n298:  *   1. config.agent.bin (explicit)\n299:  *   2. OPENCODE_BIN env var\n300:  *   3. ~/.opencode/bin/opencode (default install location)\n301:  */\n302: export function resolveAgentBin(config: WomboConfig): string {\n303:   if (config.agent.bin) return config.agent.bin;\n304:   if (process.env.OPENCODE_BIN) return process.env.OPENCODE_BIN;\n305:   return resolve(process.env.HOME || \"~\", \".opencode/bin/opencode\");\n306: }\n307: \n308: /**\n309:  * Validate the config for obvious issues. Throws on error.\n310:  */\n311: export function validateConfig(config: WomboConfig): void {\n312:   if (!config.tasksDir) {\n313:     throw new Error(\"config.tasksDir must be a non-empty string\");\n314:   }\n315:   if (!config.archiveDir) {\n316:     throw new Error(\"config.archiveDir must be a non-empty string\");\n317:   }\n318:   if (!config.baseBranch) {\n319:     throw new Error(\"config.baseBranch must be a non-empty string\");\n320:   }\n321:   if (!config.build.command) {\n322:     throw new Error(\"config.build.command must be a non-empty string\");\n323:   }\n324:   if (!config.install.command) {\n325:     throw new Error(\"config.install.command must be a non-empty string\");\n326:   }\n327:   if (!config.git.branchPrefix) {\n328:     throw new Error(\"config.git.branchPrefix must be a non-empty string\");\n329:   }\n330:   if (!config.git.worktreePrefix) {\n331:     throw new Error(\"config.git.worktreePrefix must be a non-empty string\");\n332:   }\n333:   if (config.defaults.maxConcurrent < 1) {\n334:     throw new Error(\"config.defaults.maxConcurrent must be >= 1\");\n335:   }\n336:   if (config.defaults.maxRetries < 0) {\n337:     throw new Error(\"config.defaults.maxRetries must be >= 0\");\n338:   }\n339:   if (config.backup.maxBackups < 0) {\n340:     throw new Error(\"config.backup.maxBackups must be >= 0\");\n341:   }\n342:   const validModes: AgentRegistryMode[] = [\"auto\", \"monitored\", \"disabled\"];\n343:   if (!validModes.includes(config.agentRegistry.mode)) {\n344:     throw new Error(`config.agentRegistry.mode must be one of: ${validModes.join(\", \")}`);\n345:   }\n346:   if (!config.agentRegistry.source) {\n347:     throw new Error(\"config.agentRegistry.source must be a non-empty string\");\n348:   }\n349:   if (!config.agentRegistry.cacheDir) {\n350:     throw new Error(\"config.agentRegistry.cacheDir must be a non-empty string\");\n351:   }\n352:   if (config.tdd.enabled && !config.tdd.testCommand) {\n353:     throw new Error(\"config.tdd.testCommand must be a non-empty string when TDD is enabled\");\n354:   }\n355: }\n356: \n357: /**\n358:  * Generate the default .wombo-combo/config.json content string (for `woco init`).\n359:  */\n360: export function generateDefaultConfig(): string {\n361:   return JSON.stringify(DEFAULT_CONFIG, null, 2) + \"\\n\";\n362: }\n\n(End of file - total 362 lines)\n</content>","title":"src/config.ts","metadata":{"preview":"/**\n * config.ts — Load .wombo-combo/config.json, merge with defaults, validate, expose typed config.\n *\n * The config file lives at .wombo-combo/config.json inside the target project root.\n * All values have sensible defaults so minimal config works out of the box.\n */\n\nimport { readFileSync, existsSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\nimport type { MultiplexerPreference } from \"./lib/multiplexer.js\";\n\n// ---------------------------------------------------------------------------\n// .wombo-combo directory constant\n// ---------------------------------------------------------------------------\n\n/** Name of the directory that holds all wombo-combo files */\nexport const WOMBO_DIR = \".wombo-combo\";\n\n// ---------------------------------------------------------------------------\n// Types","truncated":false,"loaded":[]},"time":{"start":1773440116646,"end":1773440116648}}}}
{"type":"tool_use","timestamp":1773440117193,"sessionID":"ses_316bba7bfffeeA1IqckNkl9JmJ","part":{"id":"prt_ce944a8730015L6oYavkLCeVee","sessionID":"ses_316bba7bfffeeA1IqckNkl9JmJ","messageID":"msg_ce9449636001QAUsgE7moHXwpe","type":"tool","callID":"toolu_vrtx_013jCqwuzeGAyzKsAYRegzf8","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/dynamic-agent-types/src/lib/templates.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/dynamic-agent-types/src/lib/templates.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * templates.ts — Resolve paths to bundled template files, render agent\n3:  * definitions, and compose patched agent definitions from imported agents.\n4:  *\n5:  * Template architecture:\n6:  *\n7:  *   generalist-agent.md          — standalone agent definition (no imported base)\n8:  *   wc-patch.description.end.md  — appended to imported agent's frontmatter description\n9:  *   wc-patch.body.start.md       — prepended to imported agent's body\n10:  *   wc-patch.body.end.md         — appended to imported agent's body\n11:  *\n12:  * Conditional blocks (portless, browser testing) are injected programmatically\n13:  * by the render/patch functions based on config — never left as \"if enabled\"\n14:  * prose for the LLM to interpret.\n15:  */\n16: \n17: import { join, dirname, resolve } from \"node:path\";\n18: import { existsSync, readFileSync, writeFileSync, mkdirSync } from \"node:fs\";\n19: import YAML from \"yaml\";\n20: import type { WomboConfig } from \"../config.js\";\n21: import { isPortlessAvailable } from \"./portless.js\";\n22: import { normalizeAgentFormat } from \"./format-converter.js\";\n23: \n24: // ---------------------------------------------------------------------------\n25: // Template Directory & Paths\n26: // ---------------------------------------------------------------------------\n27: \n28: const TEMPLATES_DIR = join(dirname(import.meta.dir), \"templates\");\n29: \n30: /** Standalone generalist agent template. */\n31: export const GENERALIST_TEMPLATE_PATH = join(TEMPLATES_DIR, \"generalist-agent.md\");\n32: \n33: /** Patch: text appended to an imported agent's frontmatter `description` field. */\n34: export const PATCH_DESCRIPTION_END_PATH = join(TEMPLATES_DIR, \"wc-patch.description.end.md\");\n35: \n36: /** Patch: markdown prepended to an imported agent's body. */\n37: export const PATCH_BODY_START_PATH = join(TEMPLATES_DIR, \"wc-patch.body.start.md\");\n38: \n39: /** Patch: markdown appended to an imported agent's body. */\n40: export const PATCH_BODY_END_PATH = join(TEMPLATES_DIR, \"wc-patch.body.end.md\");\n41: \n42: /**\n43:  * Backward-compatible alias. Code that referenced `AGENT_TEMPLATE_PATH`\n44:  * continues to work — it now points to the generalist template.\n45:  */\n46: export const AGENT_TEMPLATE_PATH = GENERALIST_TEMPLATE_PATH;\n47: \n48: // ---------------------------------------------------------------------------\n49: // Deterministic Conditional Blocks\n50: // ---------------------------------------------------------------------------\n51: \n52: /**\n53:  * Portless server-testing block. Injected by render/patch functions ONLY when\n54:  * `config.portless.enabled` is true. The agent never sees \"if portless is\n55:  * enabled\" — it either gets these instructions or it doesn't.\n56:  */\n57: const PORTLESS_BLOCK = `\n58: ## Server Testing (portless)\n59: \n60: Your environment is preconfigured with **portless** for collision-free localhost servers:\n61: \n62: - **\\`PORTLESS_ENABLED=1\\`** is set in your environment.\n63: - **Do NOT hardcode port numbers.** Use \\`process.env.PORT\\` or let your framework pick a port automatically.\n64: - **Use \\`portless run <cmd>\\`** to start dev servers (e.g., \\`portless run bun start\\`). This auto-assigns a port and gives you a stable \\`.localhost\\` URL via \\`PORTLESS_URL\\`.\n65: - **Check \\`PORTLESS_URL\\`** in your environment for the stable URL assigned to your worktree's server.\n66: - Multiple agents can run dev servers simultaneously without port conflicts — portless handles routing through its proxy.\n67: - **Never hardcode port numbers.** Always use the portless-assigned port.\n68: `;\n69: \n70: /**\n71:  * TDD red-green-refactor block. Injected by render/patch functions ONLY when\n72:  * `config.tdd.enabled` is true. The agent never sees \"if TDD is enabled\" —\n73:  * it either gets these instructions or it doesn't.\n74:  *\n75:  * The `{{testCommand}}` placeholder is replaced at render time.\n76:  */\n77: const TDD_BLOCK = `\n78: ## Test-Driven Development (TDD)\n79: \n80: You MUST follow the **red-green-refactor** TDD cycle for all implementation work:\n81: \n82: ### The TDD Cycle\n83: \n84: 1. **🔴 Red — Write a failing test first**\n85:    - Before writing any implementation code, write a test that describes the desired behavior.\n86:    - Use Bun's built-in test runner. Create test files alongside source files using the \\`.test.ts\\` naming convention.\n87:    - The test MUST fail initially — this proves the test is actually testing something.\n88: \n89: 2. **🔴 Verify the test fails**\n90:    - Run \\`{{testCommand}}\\` and confirm the new test fails with the expected error.\n91:    - If the test passes without implementation, the test is not testing the right thing — rewrite it.\n92: \n93: 3. **🟢 Green — Write minimal code to pass**\n94:    - Implement just enough production code to make the failing test pass.\n95:    - Do NOT write more code than necessary to satisfy the test.\n96:    - Do NOT add features or handle edge cases not covered by a test yet.\n97: \n98: 4. **🟢 Verify the test passes**\n99:    - Run \\`{{testCommand}}\\` and confirm ALL tests pass (both new and existing).\n100:    - If any test fails, fix the implementation — do NOT modify the test to make it pass (unless the test itself is wrong).\n101: \n102: 5. **🔵 Refactor**\n103:    - Clean up the implementation while keeping all tests green.\n104:    - Extract helpers, rename variables, simplify logic — but run \\`{{testCommand}}\\` after each change.\n105:    - If a refactor breaks a test, undo the refactor and try a different approach.\n106: \n107: ### TDD Rules\n108: \n109: - **Never skip the red step.** Every new behavior starts with a failing test.\n110: - **One behavior per cycle.** Each red-green-refactor iteration should cover exactly one small behavior or edge case.\n111: - **Tests are first-class code.** Keep them readable, well-named, and focused.\n112: - **Run tests frequently.** Run \\`{{testCommand}}\\` after every meaningful change — not just at the end.\n113: - **Commit at green.** Each commit should have all tests passing. Use the cycle boundaries as natural commit points.\n114: \n115: ### Test File Conventions\n116: \n117: - Place test files next to the source: \\`src/foo.ts\\` → \\`src/foo.test.ts\\` (or \\`tests/foo.test.ts\\`)\n118: - Use descriptive test names: \\`test(\"returns empty array when input is null\", ...)\\`\n119: - Import from \\`bun:test\\`: \\`import { describe, test, expect } from \"bun:test\";\\`\n120: `;\n121: \n122: /**\n123:  * Build the TDD block with the configured test command substituted in.\n124:  */\n125: function buildTddBlock(config: WomboConfig): string {\n126:   return TDD_BLOCK.replace(/\\{\\{testCommand\\}\\}/g, config.tdd.testCommand);\n127: }\n128: \n129: // ---------------------------------------------------------------------------\n130: // Placeholder Substitution\n131: // ---------------------------------------------------------------------------\n132: \n133: /**\n134:  * Default runtime description used when no project-specific value is available.\n135:  */\n136: const DEFAULT_RUNTIME = \"Bun (not Node). TypeScript, strict mode, ESM only.\";\n137: \n138: /**\n139:  * Replace {{placeholders}} in template content with config-derived values.\n140:  *\n141:  * Supported placeholders:\n142:  *   - {{tasksDir}}       — tasks directory name (e.g. \"tasks\")\n143:  *   - {{branchPrefix}}   — git branch prefix (e.g. \"feature/\")\n144:  *   - {{buildCommand}}   — build command (e.g. \"bun run build\")\n145:  *   - {{runtime}}        — project runtime description\n146:  *   - {{project}}        — project directory name\n147:  */\n148: function applyPlaceholders(\n149:   content: string,\n150:   config: WomboConfig,\n151:   projectRoot: string\n152: ): string {\n153:   const projectName = projectRoot.split(\"/\").pop() ?? \"project\";\n154:   return content\n155:     .replace(/\\{\\{tasksDir\\}\\}/g, config.tasksDir)\n156:     .replace(/\\{\\{branchPrefix\\}\\}/g, config.git.branchPrefix)\n157:     .replace(/\\{\\{buildCommand\\}\\}/g, config.build.command)\n158:     .replace(/\\{\\{runtime\\}\\}/g, DEFAULT_RUNTIME)\n159:     .replace(/\\{\\{project\\}\\}/g, projectName);\n160: }\n161: \n162: // ---------------------------------------------------------------------------\n163: // Frontmatter Parsing\n164: // ---------------------------------------------------------------------------\n165: \n166: /**\n167:  * Split a markdown file with YAML frontmatter into its two parts.\n168:  * Returns the raw YAML string (without delimiters) and the body.\n169:  */\n170: function splitFrontmatter(md: string): { yaml: string; body: string } {\n171:   const match = md.match(/^---\\r?\\n([\\s\\S]*?)\\r?\\n---\\r?\\n?([\\s\\S]*)$/);\n172:   if (!match) {\n173:     return { yaml: \"\", body: md };\n174:   }\n175:   return { yaml: match[1], body: match[2] };\n176: }\n177: \n178: /**\n179:  * Reassemble frontmatter YAML and body into a markdown string.\n180:  */\n181: function joinFrontmatter(yaml: string, body: string): string {\n182:   if (!yaml.trim()) return body;\n183:   return `---\\n${yaml.trimEnd()}\\n---\\n${body}`;\n184: }\n185: \n186: // ---------------------------------------------------------------------------\n187: // Generalist Agent Rendering\n188: // ---------------------------------------------------------------------------\n189: \n190: /**\n191:  * Render the standalone generalist agent template.\n192:  *\n193:  * This is the default agent definition for projects that don't import a\n194:  * specialized agent from an external registry. Portless instructions are\n195:  * injected deterministically based on config.\n196:  */\n197: export function renderGeneralistAgent(\n198:   config: WomboConfig,\n199:   projectRoot: string\n200: ): string {\n201:   let raw = readFileSync(GENERALIST_TEMPLATE_PATH, \"utf-8\");\n202: \n203:   // Deterministic portless injection\n204:   if (config.portless.enabled && isPortlessAvailable(config)) {\n205:     // Insert portless block before \"## What You Must Never Do\" (or at end)\n206:     const neverDoMarker = \"## What You Must Never Do\";\n207:     const idx = raw.indexOf(neverDoMarker);\n208:     if (idx !== -1) {\n209:       raw = raw.slice(0, idx) + PORTLESS_BLOCK + \"\\n\" + raw.slice(idx);\n210:     } else {\n211:       raw += \"\\n\" + PORTLESS_BLOCK;\n212:     }\n213:   }\n214: \n215:   // Deterministic TDD injection\n216:   if (config.tdd.enabled) {\n217:     const tddContent = buildTddBlock(config);\n218:     const neverDoMarker = \"## What You Must Never Do\";\n219:     const idx = raw.indexOf(neverDoMarker);\n220:     if (idx !== -1) {\n221:       raw = raw.slice(0, idx) + tddContent + \"\\n\" + raw.slice(idx);\n222:     } else {\n223:       raw += \"\\n\" + tddContent;\n224:     }\n225:   }\n226: \n227:   return applyPlaceholders(raw, config, projectRoot);\n228: }\n229: \n230: // ---------------------------------------------------------------------------\n231: // Imported Agent Patching\n232: // ---------------------------------------------------------------------------\n233: \n234: /**\n235:  * Patch an imported agent definition (e.g. from agency-agents) with\n236:  * wombo-combo operational context.\n237:  *\n238:  * Composition order:\n239:  *   1. Parse the imported agent's frontmatter and body\n240:  *   2. Append wc-patch.description.end to the `description` frontmatter field\n241:  *   3. Prepend wc-patch.body.start to the body\n242:  *   4. Append wc-patch.body.end to the body\n243:  *   5. Conditionally inject portless block (deterministic, based on config)\n244:  *   6. Apply {{placeholder}} substitution to the entire result\n245:  *\n246:  * @param rawAgentMd  — raw markdown content of the imported agent file\n247:  * @param config      — wombo-combo project config\n248:  * @param projectRoot — absolute path to the project root\n249:  */\n250: export function patchImportedAgent(\n251:   rawAgentMd: string,\n252:   config: WomboConfig,\n253:   projectRoot: string\n254: ): string {\n255:   // Normalize agency-agents format to woco-compatible format before patching.\n256:   // If the content is already in woco format, this is a no-op.\n257:   const normalizedMd = normalizeAgentFormat(rawAgentMd);\n258: \n259:   const { yaml: rawYaml, body: rawBody } = splitFrontmatter(normalizedMd);\n260: \n261:   // --- Patch frontmatter description ---\n262:   let patchedYaml = rawYaml;\n263:   if (rawYaml) {\n264:     try {\n265:       const descPatchRaw = readFileSync(PATCH_DESCRIPTION_END_PATH, \"utf-8\").trim();\n266:       if (descPatchRaw) {\n267:         const doc = YAML.parseDocument(rawYaml);\n268:         const currentDesc = doc.get(\"description\");\n269:         if (typeof currentDesc === \"string\") {\n270:           doc.set(\"description\", currentDesc.trimEnd() + \"\\n\\n\" + descPatchRaw);\n271:         } else {\n272:           // No description field — add one\n273:           doc.set(\"description\", descPatchRaw);\n274:         }\n275:         // Ensure mode is set for wombo-combo compatibility\n276:         if (!doc.has(\"mode\")) {\n277:           doc.set(\"mode\", \"primary\");\n278:         }\n279:         patchedYaml = YAML.stringify(doc, { lineWidth: 0 }).trimEnd();\n280:       }\n281:     } catch {\n282:       // Patch file missing or YAML parse error — proceed without patching\n283:     }\n284:   }\n285: \n286:   // --- Patch body ---\n287:   let patchedBody = rawBody;\n288: \n289:   // Prepend body.start\n290:   try {\n291:     const bodyStart = readFileSync(PATCH_BODY_START_PATH, \"utf-8\");\n292:     if (bodyStart.trim()) {\n293:       patchedBody = bodyStart + patchedBody;\n294:     }\n295:   } catch {\n296:     // Patch file missing — skip\n297:   }\n298: \n299:   // Append body.end\n300:   try {\n301:     const bodyEnd = readFileSync(PATCH_BODY_END_PATH, \"utf-8\");\n302:     if (bodyEnd.trim()) {\n303:       patchedBody = patchedBody.trimEnd() + \"\\n\" + bodyEnd;\n304:     }\n305:   } catch {\n306:     // Patch file missing — skip\n307:   }\n308: \n309:   // Deterministic portless injection (appended after body.end)\n310:   if (config.portless.enabled && isPortlessAvailable(config)) {\n311:     patchedBody = patchedBody.trimEnd() + \"\\n\" + PORTLESS_BLOCK;\n312:   }\n313: \n314:   // Deterministic TDD injection (appended after portless or body.end)\n315:   if (config.tdd.enabled) {\n316:     patchedBody = patchedBody.trimEnd() + \"\\n\" + buildTddBlock(config);\n317:   }\n318: \n319:   // --- Reassemble & substitute placeholders ---\n320:   const composed = joinFrontmatter(patchedYaml, patchedBody);\n321:   return applyPlaceholders(composed, config, projectRoot);\n322: }\n323: \n324: // ---------------------------------------------------------------------------\n325: // Backward Compatibility\n326: // ---------------------------------------------------------------------------\n327: \n328: /**\n329:  * Render the agent template. When `agentName` is provided and differs from\n330:  * the config default, check for a local agent definition file at\n331:  * `.opencode/agents/<agentName>.md`. If it exists, return its contents\n332:  * with placeholder substitution applied. Otherwise, fall back to the\n333:  * bundled generalist agent.\n334:  */\n335: export function renderAgentTemplate(\n336:   config: WomboConfig,\n337:   projectRoot: string,\n338:   agentName?: string\n339: ): string {\n340:   // If a specific agent is requested and it's not the default generalist,\n341:   // try to read it from the local agents directory.\n342:   if (agentName && agentName !== config.agent.name) {\n343:     const localPath = resolve(projectRoot, \".opencode\", \"agents\", `${agentName}.md`);\n344:     if (existsSync(localPath)) {\n345:       const content = readFileSync(localPath, \"utf-8\");\n346:       return applyPlaceholders(content, config, projectRoot);\n347:     }\n348:     // If the local file doesn't exist, fall back to generalist with a warning\n349:     console.warn(\n350:       `\\x1b[33m[WARNING]\\x1b[0m Local agent definition not found: .opencode/agents/${agentName}.md — falling back to ${config.agent.name}`\n351:     );\n352:   }\n353:   return renderGeneralistAgent(config, projectRoot);\n354: }\n355: \n356: // ---------------------------------------------------------------------------\n357: // Agent Definition Guard\n358: // ---------------------------------------------------------------------------\n359: \n360: /**\n361:  * Ensure the agent definition file exists at the expected path.\n362:  * If missing, reinstall from the bundled generalist template and warn.\n363:  *\n364:  * Called at the start of `woco launch` to prevent the failure mode where\n365:  * agents spawn without their agent definition file.\n366:  *\n367:  * When `agentName` is provided (from a task's `agent` field), also ensure\n368:  * that the specified agent definition exists. For non-default agents,\n369:  * only warns if missing (does not generate a template — the user must\n370:  * provide custom agent definitions).\n371:  *\n372:  * @returns true if the default file was reinstalled, false if it already existed.\n373:  */\n374: export function ensureAgentDefinition(\n375:   projectRoot: string,\n376:   config: WomboConfig,\n377:   agentName?: string\n378: ): boolean {\n379:   const agentDir = resolve(projectRoot, \".opencode\", \"agents\");\n380:   const agentDefPath = resolve(agentDir, `${config.agent.name}.md`);\n381: \n382:   if (existsSync(agentDefPath)) {\n383:     // Default agent exists; also check per-task agent if specified\n384:     if (agentName && agentName !== config.agent.name) {\n385:       const customPath = resolve(agentDir, `${agentName}.md`);\n386:       if (!existsSync(customPath)) {\n387:         console.warn(\n388:           `\\x1b[33m[WARNING]\\x1b[0m Custom agent definition not found: .opencode/agents/${agentName}.md`\n389:         );\n390:         console.warn(\n391:           `  Tasks specifying agent: \"${agentName}\" will fall back to the default agent (${config.agent.name}).\\n`\n392:         );\n393:       }\n394:     }\n395:     return false;\n396:   }\n397: \n398:   // Agent definition missing — reinstall from bundled template\n399:   console.warn(\n400:     `\\x1b[33m[WARNING]\\x1b[0m Agent definition not found: .opencode/agents/${config.agent.name}.md`\n401:   );\n402:   console.warn(`  Reinstalling from bundled generalist template...`);\n403: \n404:   try {\n405:     mkdirSync(agentDir, { recursive: true });\n406:     const content = renderGeneralistAgent(config, projectRoot);\n407:     writeFileSync(agentDefPath, content, \"utf-8\");\n408:     console.warn(`  Restored .opencode/agents/${config.agent.name}.md\\n`);\n409: \n410:     // Also check per-task agent after restoring default\n411:     if (agentName && agentName !== config.agent.name) {\n412:       const customPath = resolve(agentDir, `${agentName}.md`);\n413:       if (!existsSync(customPath)) {\n414:         console.warn(\n415:           `\\x1b[33m[WARNING]\\x1b[0m Custom agent definition not found: .opencode/agents/${agentName}.md`\n416:         );\n417:         console.warn(\n418:           `  Tasks specifying agent: \"${agentName}\" will fall back to the default agent (${config.agent.name}).\\n`\n419:         );\n420:       }\n421:     }\n422: \n423:     return true;\n424:   } catch (err: any) {\n425:     console.error(\n426:       `  Failed to restore agent definition: ${err.message}`\n427:     );\n428:     console.error(\n429:       `  Agents may launch without their definition file.\\n`\n430:     );\n431:     return false;\n432:   }\n433: }\n\n(End of file - total 433 lines)\n</content>","title":"src/lib/templates.ts","metadata":{"preview":"/**\n * templates.ts — Resolve paths to bundled template files, render agent\n * definitions, and compose patched agent definitions from imported agents.\n *\n * Template architecture:\n *\n *   generalist-agent.md          — standalone agent definition (no imported base)\n *   wc-patch.description.end.md  — appended to imported agent's frontmatter description\n *   wc-patch.body.start.md       — prepended to imported agent's body\n *   wc-patch.body.end.md         — appended to imported agent's body\n *\n * Conditional blocks (portless, browser testing) are injected programmatically\n * by the render/patch functions based on config — never left as \"if enabled\"\n * prose for the LLM to interpret.\n */\n\nimport { join, dirname, resolve } from \"node:path\";\nimport { existsSync, readFileSync, writeFileSync, mkdirSync } from \"node:fs\";\nimport YAML from \"yaml\";\nimport type { WomboConfig } from \"../config.js\";","truncated":false,"loaded":[]},"time":{"start":1773440117188,"end":1773440117191}}}}
