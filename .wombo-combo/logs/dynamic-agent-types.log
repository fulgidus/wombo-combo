{"type":"tool_use","timestamp":1773440513475,"sessionID":"ses_316bba7bfffeeA1IqckNkl9JmJ","part":{"id":"prt_ce94ab5ab0010uLgd3KiuaRMKv","sessionID":"ses_316bba7bfffeeA1IqckNkl9JmJ","messageID":"msg_ce94aaa7f0013KOqQwQlQwPC5u","type":"tool","callID":"toolu_vrtx_013xHgcb9HgNVLBY73Hh6bfw","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/dynamic-agent-types/src/commands/retry.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/dynamic-agent-types/src/commands/retry.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * retry.ts — Retry a specific failed agent.\n3:  *\n4:  * Usage: woco retry <feature-id> [--interactive] [--model <model>] [--output json]\n5:  *\n6:  * Resets the agent's retry count and re-launches it. Can launch in either\n7:  * headless mode (default) or interactive (dmux/tmux) mode.\n8:  */\n9: \n10: import type { WomboConfig } from \"../config.js\";\n11: import { loadFeatures, type Feature } from \"../lib/tasks.js\";\n12: import {\n13:   loadState,\n14:   saveState,\n15:   updateAgent,\n16: } from \"../lib/state.js\";\n17: import { worktreeReady } from \"../lib/worktree.js\";\n18: import { generatePrompt } from \"../lib/prompt.js\";\n19: import { launchInteractive, getMultiplexerName } from \"../lib/launcher.js\";\n20: import { ProcessMonitor } from \"../lib/monitor.js\";\n21: import { launchSingleHeadless } from \"./launch.js\";\n22: import { output, outputError, outputMessage, type OutputFormat } from \"../lib/output.js\";\n23: import { renderRetry } from \"../lib/toon.js\";\n24: \n25: // ---------------------------------------------------------------------------\n26: // Types\n27: // ---------------------------------------------------------------------------\n28: \n29: export interface RetryCommandOptions {\n30:   projectRoot: string;\n31:   config: WomboConfig;\n32:   featureId: string;\n33:   model?: string;\n34:   interactive: boolean;\n35:   dryRun?: boolean;\n36:   outputFmt?: OutputFormat;\n37: }\n38: \n39: // ---------------------------------------------------------------------------\n40: // Command\n41: // ---------------------------------------------------------------------------\n42: \n43: export async function cmdRetry(opts: RetryCommandOptions): Promise<void> {\n44:   const { projectRoot, config } = opts;\n45:   const fmt = opts.outputFmt ?? \"text\";\n46: \n47:   if (!opts.featureId) {\n48:     outputError(fmt, \"Usage: woco retry <feature-id>\");\n49:     return; // unreachable — outputError calls process.exit\n50:   }\n51: \n52:   const state = loadState(projectRoot);\n53:   if (!state) {\n54:     outputMessage(fmt, \"No active wave.\", { wave_id: null });\n55:     return;\n56:   }\n57: \n58:   const agent = state.agents.find((a) => a.feature_id === opts.featureId);\n59:   if (!agent) {\n60:     outputError(fmt, `Agent not found for feature: ${opts.featureId}`);\n61:     return; // unreachable\n62:   }\n63: \n64:   if (agent.status !== \"failed\") {\n65:     outputError(\n66:       fmt,\n67:       `Agent ${opts.featureId} is not in failed state (current: ${agent.status})`\n68:     );\n69:     return; // unreachable\n70:   }\n71: \n72:   // Dry-run: show what would be retried without doing it\n73:   if (opts.dryRun) {\n74:     const dryRunResult = {\n75:       dry_run: true,\n76:       feature_id: opts.featureId,\n77:       current_status: agent.status,\n78:       retries_so_far: agent.retries,\n79:       worktree: agent.worktree,\n80:       mode: opts.interactive ? \"interactive\" : \"headless\",\n81:       model: opts.model ?? null,\n82:     };\n83: \n84:     output(fmt, dryRunResult, () => {\n85:       console.log(`\\n[dry-run] Would retry agent: ${opts.featureId}`);\n86:       console.log(`  Current status: ${agent.status}`);\n87:       console.log(`  Retries so far: ${agent.retries}`);\n88:       console.log(`  Worktree: ${agent.worktree}`);\n89:       console.log(`  Mode: ${opts.interactive ? \"interactive (multiplexer)\" : \"headless\"}`);\n90:       if (opts.model) console.log(`  Model: ${opts.model}`);\n91:     }, () => {\n92:       console.log(renderRetry(dryRunResult));\n93:     });\n94:     return;\n95:   }\n96: \n97:   // Reset retry count and re-run\n98:   updateAgent(state, agent.feature_id, {\n99:     status: \"queued\",\n100:     retries: 0,\n101:     error: null,\n102:     build_passed: null,\n103:     build_output: null,\n104:     completed_at: null,\n105:   });\n106:   saveState(projectRoot, state);\n107: \n108:   const data = loadFeatures(projectRoot, config);\n109:   const feature = data.tasks.find((f: Feature) => f.id === opts.featureId);\n110:   if (!feature) {\n111:     outputError(fmt, `Feature ${opts.featureId} not found in ${config.tasksDir}`);\n112:     return; // unreachable\n113:   }\n114: \n115:   if (opts.interactive) {\n116:     const prompt = generatePrompt(feature, state.base_branch, config);\n117:     launchInteractive({\n118:       worktreePath: agent.worktree,\n119:       featureId: feature.id,\n120:       prompt,\n121:       model: opts.model,\n122:       interactive: true,\n123:       config,\n124:     });\n125: \n126:     updateAgent(state, agent.feature_id, {\n127:       status: \"running\",\n128:       started_at: new Date().toISOString(),\n129:     });\n130:     saveState(projectRoot, state);\n131:     const muxName = getMultiplexerName(config);\n132: \n133:     output(fmt, {\n134:       feature_id: opts.featureId,\n135:       mode: \"interactive\",\n136:       status: \"running\",\n137:       mux_session: `${config.agent.tmuxPrefix}-${opts.featureId}`,\n138:     }, () => {\n139:       console.log(`Retrying ${opts.featureId} in ${muxName} session ${config.agent.tmuxPrefix}-${opts.featureId}`);\n140:     }, () => {\n141:       console.log(renderRetry({\n142:         feature_id: opts.featureId,\n143:         mode: \"interactive\",\n144:         status: \"running\",\n145:         mux_session: `${config.agent.tmuxPrefix}-${opts.featureId}`,\n146:       }));\n147:     });\n148:   } else {\n149:     const monitor = new ProcessMonitor(projectRoot);\n150:     await launchSingleHeadless(projectRoot, state, agent, feature, monitor, config, opts.model);\n151: \n152:     // Re-read agent after launch to get PID\n153:     const updatedAgent = state.agents.find((a) => a.feature_id === opts.featureId);\n154: \n155:     output(fmt, {\n156:       feature_id: opts.featureId,\n157:       mode: \"headless\",\n158:       status: updatedAgent?.status ?? \"running\",\n159:       pid: updatedAgent?.pid ?? null,\n160:     }, () => {\n161:       console.log(`Retrying ${opts.featureId} in headless mode`);\n162:     }, () => {\n163:       console.log(renderRetry({\n164:         feature_id: opts.featureId,\n165:         mode: \"headless\",\n166:         status: updatedAgent?.status ?? \"running\",\n167:         pid: updatedAgent?.pid ?? null,\n168:       }));\n169:     });\n170:   }\n171: }\n\n(End of file - total 171 lines)\n</content>","title":"src/commands/retry.ts","metadata":{"preview":"/**\n * retry.ts — Retry a specific failed agent.\n *\n * Usage: woco retry <feature-id> [--interactive] [--model <model>] [--output json]\n *\n * Resets the agent's retry count and re-launches it. Can launch in either\n * headless mode (default) or interactive (dmux/tmux) mode.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport { loadFeatures, type Feature } from \"../lib/tasks.js\";\nimport {\n  loadState,\n  saveState,\n  updateAgent,\n} from \"../lib/state.js\";\nimport { worktreeReady } from \"../lib/worktree.js\";\nimport { generatePrompt } from \"../lib/prompt.js\";\nimport { launchInteractive, getMultiplexerName } from \"../lib/launcher.js\";\nimport { ProcessMonitor } from \"../lib/monitor.js\";","truncated":false,"loaded":[]},"time":{"start":1773440513472,"end":1773440513474}}}}
