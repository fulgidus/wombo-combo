{"type":"tool_use","timestamp":1773440123457,"sessionID":"ses_316bba7bfffeeA1IqckNkl9JmJ","part":{"id":"prt_ce944bfd2001Of9BWikr2SMOyA","sessionID":"ses_316bba7bfffeeA1IqckNkl9JmJ","messageID":"msg_ce944abf2001edoOT1rzoQBo11","type":"tool","callID":"toolu_vrtx_016V4C5SLLxD67p6LeK8FUZ7","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/dynamic-agent-types/src/lib/state.ts","limit":100},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/dynamic-agent-types/src/lib/state.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * state.ts — Persistent wave state management.\n3:  *\n4:  * Responsibilities:\n5:  *   - Define the shape of .wombo-combo/state.json\n6:  *   - Read/write state atomically\n7:  *   - Generate wave IDs\n8:  *   - Update individual agent state within a wave\n9:  */\n10: \n11: import { readFileSync, writeFileSync, existsSync, renameSync, mkdirSync } from \"node:fs\";\n12: import { resolve } from \"node:path\";\n13: import { WOMBO_DIR } from \"../config.js\";\n14: \n15: // ---------------------------------------------------------------------------\n16: // Types\n17: // ---------------------------------------------------------------------------\n18: \n19: export type AgentStatus =\n20:   | \"queued\"\n21:   | \"installing\"\n22:   | \"running\"\n23:   | \"completed\"\n24:   | \"verified\"\n25:   | \"failed\"\n26:   | \"merged\"\n27:   | \"retry\"\n28:   | \"resolving_conflict\";\n29: \n30: export interface AgentState {\n31:   feature_id: string;\n32:   branch: string;\n33:   worktree: string;\n34:   session_id: string | null;\n35:   pid: number | null;\n36:   status: AgentStatus;\n37:   activity: string | null;\n38:   activity_updated_at: string | null;\n39:   retries: number;\n40:   max_retries: number;\n41:   started_at: string | null;\n42:   completed_at: string | null;\n43:   build_passed: boolean | null;\n44:   build_output: string | null;\n45:   error: string | null;\n46:   /** Estimated effort in milliseconds (from feature's ISO 8601 duration) */\n47:   effort_estimate_ms: number | null;\n48:   /** Stream index this agent belongs to (for dependency-aware scheduling) */\n49:   stream_index: number | null;\n50:   /** IDs of features this agent depends on (within the current wave) */\n51:   depends_on: string[];\n52:   /** IDs of features that depend on this agent (within the current wave) */\n53:   depended_on_by: string[];\n54:   /**\n55:    * Override agent name for this specific agent (from registry).\n56:    * When set, uses this agent definition instead of the default generalist.\n57:    * e.g. \"engineering-frontend-developer\"\n58:    */\n59:   agent_name: string | null;\n60:   /**\n61:    * The agent_type from the task (e.g. \"engineering/engineering-frontend-developer\").\n62:    * Stored for informational purposes and to support resume with re-fetch.\n63:    */\n64:   agent_type: string | null;\n65: }\n66: \n67: export interface WaveState {\n68:   wave_id: string;\n69:   base_branch: string;\n70:   started_at: string;\n71:   updated_at: string;\n72:   max_concurrent: number;\n73:   model: string | null;\n74:   interactive: boolean;\n75:   agents: AgentState[];\n76:   /** Dependency-aware scheduling plan (null if no dependencies exist) */\n77:   schedule_plan: SerializedSchedulePlan | null;\n78: }\n79: \n80: /**\n81:  * Serialized schedule plan stored in wave state JSON.\n82:  * Uses plain arrays instead of the rich SchedulePlan type for JSON compatibility.\n83:  */\n84: export interface SerializedSchedulePlan {\n85:   /** Streams: each is a list of feature IDs to execute sequentially */\n86:   streams: string[][];\n87:   /** Merge gates: features that must wait for multiple deps from different streams */\n88:   merge_gates: Array<{ feature_id: string; wait_for: string[] }>;\n89:   /** Topological order of all features */\n90:   topological_order: string[];\n91: }\n92: \n93: // ---------------------------------------------------------------------------\n94: // Constants\n95: // ---------------------------------------------------------------------------\n96: \n97: const STATE_FILE = \".wombo-combo/state.json\";\n98: \n99: // ---------------------------------------------------------------------------\n100: // Wave ID Generation\n\n(Showing lines 1-100 of 394. Use offset=101 to continue.)\n</content>","title":"src/lib/state.ts","metadata":{"preview":"/**\n * state.ts — Persistent wave state management.\n *\n * Responsibilities:\n *   - Define the shape of .wombo-combo/state.json\n *   - Read/write state atomically\n *   - Generate wave IDs\n *   - Update individual agent state within a wave\n */\n\nimport { readFileSync, writeFileSync, existsSync, renameSync, mkdirSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\nimport { WOMBO_DIR } from \"../config.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type AgentStatus =\n  | \"queued\"","truncated":true,"loaded":[]},"time":{"start":1773440123450,"end":1773440123456}}}}
