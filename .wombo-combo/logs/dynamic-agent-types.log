{"type":"tool_use","timestamp":1773439937958,"sessionID":"ses_316be8c08ffeZXbNAgwvZBSoRI","part":{"id":"prt_ce941ea08001Jt8HAgpieWG8V4","sessionID":"ses_316be8c08ffeZXbNAgwvZBSoRI","messageID":"msg_ce941d3be001iWa2jWDQklACFJ","type":"tool","callID":"toolu_vrtx_01WScoxVZmH6rGrSFaBDZ2CT","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/dynamic-agent-types/src/index.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/dynamic-agent-types/src/index.ts</path>\n<type>file</type>\n<content>1: #!/usr/bin/env bun\n2: /**\n3:  * index.ts — CLI entry point for the wombo-combo agent orchestration system.\n4:  *\n5:  * Every command has a short alias (e.g., woco i = woco init, woco t ls = woco tasks list).\n6:  *\n7:  * Usage:\n8:  *   woco init                                         (alias: i)\n9:  *   woco launch --top-priority 3                      (alias: l)\n10:  *   woco launch --quickest-wins 5\n11:  *   woco launch --priority high\n12:  *   woco launch --difficulty easy\n13:  *   woco launch --tasks \"feat-a,feat-b\"\n14:  *   woco launch --all-ready\n15:  *   woco launch ... --max-concurrent 3 --model \"anthropic/claude-sonnet-4-20250514\"\n16:  *   woco launch ... --interactive\n17:  *   woco resume                                       (alias: r)\n18:  *   woco status                                       (alias: s)\n19:  *   woco verify [feature-id]                          (alias: v)\n20:  *   woco merge [feature-id]                           (alias: m)\n21:  *   woco retry <feature-id>                           (alias: re)\n22:  *   woco abort <feature-id> [--requeue] [--output json]  (alias: a)\n23:  *   woco logs <feature-id> [--tail N] [--follow]      (alias: lo)\n24:  *   woco cleanup                                      (alias: c)\n25:  *   woco history [wave-id] [--output json]            (alias: h)\n26:  *   woco tasks list [--status <s>] [--priority <p>]   (alias: t ls)\n27:  *   woco tasks add <id> <title> [options]             (alias: t a)\n28:  *   woco tasks set-status <task-id> <status>          (alias: t ss)\n29:  *   woco tasks set-priority <task-id> <priority>      (alias: t sp)\n30:  *   woco tasks set-difficulty <task-id> <difficulty>   (alias: t sd)\n31:  *   woco tasks check                                  (alias: t ch)\n32:  *   woco tasks archive [task-id] [--dry-run]          (alias: t ar)\n33:  *   woco tasks show <task-id>                         (alias: t sh)\n34:  *   woco tasks graph [--ascii] [--mermaid]            (alias: t g)\n35:  *   woco completion <bash|zsh|fish>                   (alias: comp)\n36:  *   woco help\n37:  *   woco version\n38:  *   woco -v\n39:  */\n40: \n41: import { resolve } from \"node:path\";\n42: import { existsSync, readFileSync } from \"node:fs\";\n43: import { loadConfig, validateConfig } from \"./config.js\";\n44: import { loadState, saveState } from \"./lib/state.js\";\n45: \n46: // ---------------------------------------------------------------------------\n47: // Dev-mode guard: warn if running the global binary inside the wombo-combo repo\n48: // ---------------------------------------------------------------------------\n49: \n50: function checkDevModeGuard(): void {\n51:   const cwd = process.cwd();\n52:   const pkgPath = resolve(cwd, \"package.json\");\n53: \n54:   // Are we inside the wombo-combo repo?\n55:   if (!existsSync(pkgPath)) return;\n56: \n57:   let pkgName: string | undefined;\n58:   try {\n59:     const raw = readFileSync(pkgPath, \"utf-8\");\n60:     pkgName = JSON.parse(raw).name;\n61:   } catch {\n62:     return;\n63:   }\n64:   if (pkgName !== \"wombo-combo\") return;\n65: \n66:   // We're in the wombo-combo repo. Is the source being run from a different location?\n67:   // import.meta.dir = directory of THIS file (index.ts). If it's under cwd,\n68:   // we're running local source (bun dev). If it's elsewhere (e.g. ~/.bun/install),\n69:   // we're running the globally installed binary.\n70:   const sourceDir = resolve(import.meta.dir);\n71:   const projectSrc = resolve(cwd, \"src\");\n72: \n73:   if (!sourceDir.startsWith(projectSrc)) {\n74:     console.warn(\n75:       \"\\x1b[33m[WARNING]\\x1b[0m You are running the globally installed woco binary \" +\n76:       \"inside the wombo-combo repo.\\n\" +\n77:       \"  Use \\x1b[1mbun dev <command>\\x1b[0m instead to run from local source.\\n\" +\n78:       \"  See AGENTS.md for details.\\n\"\n79:     );\n80:   }\n81: }\n82: \n83: import { cmdInit } from \"./commands/init.js\";\n84: import { cmdLaunch } from \"./commands/launch.js\";\n85: import { cmdResume } from \"./commands/resume.js\";\n86: import { cmdStatus } from \"./commands/status.js\";\n87: import { cmdVerify } from \"./commands/verify.js\";\n88: import { cmdMerge } from \"./commands/merge.js\";\n89: import { cmdRetry } from \"./commands/retry.js\";\n90: import { cmdCleanup } from \"./commands/cleanup.js\";\n91: import { cmdAbort } from \"./commands/abort.js\";\n92: import { cmdLogs } from \"./commands/logs.js\";\n93: import { cmdUpgrade } from \"./commands/upgrade.js\";\n94: import { cmdHistory } from \"./commands/history.js\";\n95: import { cmdCompletion } from \"./commands/completion.js\";\n96: import { cmdTasksList } from \"./commands/tasks/list.js\";\n97: import { cmdTasksAdd } from \"./commands/tasks/add.js\";\n98: import { cmdTasksSetStatus } from \"./commands/tasks/set-status.js\";\n99: import { cmdTasksSetPriority } from \"./commands/tasks/set-priority.js\";\n100: import { cmdTasksSetDifficulty } from \"./commands/tasks/set-difficulty.js\";\n101: import { cmdTasksCheck } from \"./commands/tasks/check.js\";\n102: import { cmdTasksArchive } from \"./commands/tasks/archive.js\";\n103: import { cmdTasksShow } from \"./commands/tasks/show.js\";\n104: import { cmdTasksGraph } from \"./commands/tasks/graph.js\";\n105: \n106: import { ensureTasksFile } from \"./lib/tasks.js\";\n107: import type { Priority, Difficulty, FeatureStatus } from \"./lib/tasks.js\";\n108: import { resolveOutputFormat, type OutputFormat } from \"./lib/output.js\";\n109: import { validateId, validateText, validateBranchName, validateDuration, assertValid } from \"./lib/validate.js\";\n110: import { findCommandDef, commandToSchema, allCommandSchemas } from \"./lib/schema.js\";\n111: import { buildToonSpec, renderToonLegend } from \"./lib/toon-spec.js\";\n112: \n113: // ---------------------------------------------------------------------------\n114: // Types\n115: // ---------------------------------------------------------------------------\n116: \n117: export interface CLIArgs {\n118:   command: string;\n119:   subcommand?: string;\n120:   // Selection options (launch)\n121:   topPriority?: number;\n122:   quickestWins?: number;\n123:   priority?: Priority;\n124:   difficulty?: Difficulty;\n125:   tasks?: string[];\n126:   allReady?: boolean;\n127:   // Launch / runtime options\n128:   maxConcurrent?: number;\n129:   model?: string;\n130:   interactive: boolean;\n131:   dryRun: boolean;\n132:   baseBranch?: string;\n133:   maxRetries?: number;\n134:   noTui: boolean;\n135:   autoPush: boolean;\n136:   // Abort options\n137:   requeue: boolean;\n138:   // General\n139:   featureId?: string;\n140:   force: boolean;\n141:   // Output format\n142:   outputFmt: OutputFormat;\n143:   // Upgrade options\n144:   checkOnly: boolean;\n145:   tag?: string;\n146:   // Features subcommand extras\n147:   status?: string;\n148:   ready?: boolean;\n149:   includeArchive?: boolean;\n150:   title?: string;\n151:   description?: string;\n152:   effort?: string;\n153:   dependsOn?: string[];\n154:   // Logs options\n155:   tail?: number;\n156:   follow?: boolean;\n157:   // Compact output\n158:   fields?: string[];\n159:   // Graph options\n160:   ascii?: boolean;\n161:   mermaidRaw?: boolean;\n162:   graphSubtasks?: boolean;\n163:   // Browser verification\n164:   browser?: boolean;\n165:   // TDD verification\n166:   skipTests?: boolean;\n167:   strictTdd?: boolean;\n168:   // Agent selection (per-task override)\n169:   agent?: string;\n170: }\n171: \n172: // ---------------------------------------------------------------------------\n173: // Command & Subcommand Aliases\n174: // ---------------------------------------------------------------------------\n175: \n176: /** Map of short aliases → canonical top-level command names. */\n177: export const COMMAND_ALIASES: Record<string, string> = {\n178:   i: \"init\",\n179:   l: \"launch\",\n180:   r: \"resume\",\n181:   s: \"status\",\n182:   v: \"verify\",\n183:   m: \"merge\",\n184:   re: \"retry\",\n185:   a: \"abort\",\n186:   c: \"cleanup\",\n187:   h: \"history\",\n188:   lo: \"logs\",\n189:   t: \"tasks\",\n190:   features: \"tasks\", // backward-compat full-word alias\n191:   u: \"upgrade\",\n192:   d: \"describe\",\n193:   comp: \"completion\",\n194: };\n195: \n196: /** Map of short aliases → canonical tasks subcommand names. */\n197: export const SUBCOMMAND_ALIASES: Record<string, string> = {\n198:   ls: \"list\",\n199:   a: \"add\",\n200:   ss: \"set-status\",\n201:   sp: \"set-priority\",\n202:   sd: \"set-difficulty\",\n203:   ch: \"check\",\n204:   validate: \"check\", // backward-compat full-word alias\n205:   ar: \"archive\",\n206:   sh: \"show\",\n207:   g: \"graph\",\n208: };\n209: \n210: // ---------------------------------------------------------------------------\n211: // Arg Parsing\n212: // ---------------------------------------------------------------------------\n213: \n214: export function parseArgs(argv: string[]): CLIArgs {\n215:   const args = argv.slice(2); // skip 'bun' and script path\n216:   const result: CLIArgs = {\n217:     command: args[0] || \"help\",\n218:     interactive: false,\n219:     dryRun: false,\n220:     noTui: false,\n221:     autoPush: false,\n222:     requeue: false,\n223:     force: false,\n224:     checkOnly: false,\n225:     outputFmt: resolveOutputFormat(undefined), // auto-detect until --output overrides\n226:   };\n227: \n228:   // Resolve top-level command alias (e.g., \"i\" → \"init\", \"t\" → \"tasks\")\n229:   result.command = COMMAND_ALIASES[result.command] ?? result.command;\n230: \n231:   // If the command is \"tasks\", treat the second positional as the subcommand\n232:   let startIdx = 1;\n233:   if (result.command === \"tasks\") {\n234:     result.subcommand = args[1] || \"list\";\n235:     // Resolve subcommand alias (e.g., \"ls\" → \"list\", \"ss\" → \"set-status\")\n236:     result.subcommand = SUBCOMMAND_ALIASES[result.subcommand] ?? result.subcommand;\n237:     startIdx = 2;\n238:   }\n239: \n240:   for (let i = startIdx; i < args.length; i++) {\n241:     const arg = args[i];\n242: \n243:     // Helper: consume the next argument, or exit with a clear error\n244:     function requireValue(flag: string): string {\n245:       if (i + 1 >= args.length) {\n246:         console.error(`Flag ${flag} requires a value.`);\n247:         process.exit(1);\n248:       }\n249:       return args[++i];\n250:     }\n251: \n252:     switch (arg) {\n253:       // --- Selection options ---\n254:       case \"--top-priority\":\n255:         result.topPriority = parseInt(requireValue(arg), 10);\n256:         break;\n257:       case \"--quickest-wins\":\n258:         result.quickestWins = parseInt(requireValue(arg), 10);\n259:         break;\n260:       case \"--priority\":\n261:         result.priority = requireValue(arg) as Priority;\n262:         break;\n263:       case \"--difficulty\":\n264:         result.difficulty = requireValue(arg) as Difficulty;\n265:         break;\n266:       case \"--tasks\":\n267:       case \"--features\": // backward-compat alias\n268:         result.tasks = requireValue(arg).split(\",\").map((s) => s.trim());\n269:         break;\n270:       case \"--all-ready\":\n271:         result.allReady = true;\n272:         break;\n273: \n274:       // --- Launch / runtime options ---\n275:       case \"--max-concurrent\":\n276:         result.maxConcurrent = parseInt(requireValue(arg), 10);\n277:         break;\n278:       case \"--model\":\n279:       case \"-m\":\n280:         result.model = requireValue(arg);\n281:         break;\n282:       case \"--interactive\":\n283:         result.interactive = true;\n284:         break;\n285:       case \"--dry-run\":\n286:         result.dryRun = true;\n287:         break;\n288:       case \"--no-tui\":\n289:         result.noTui = true;\n290:         break;\n291:       case \"--auto-push\":\n292:         result.autoPush = true;\n293:         break;\n294:       case \"--requeue\":\n295:         result.requeue = true;\n296:         break;\n297:       case \"--base-branch\":\n298:         result.baseBranch = requireValue(arg);\n299:         break;\n300:       case \"--max-retries\":\n301:         result.maxRetries = parseInt(requireValue(arg), 10);\n302:         break;\n303: \n304:       // --- General flags ---\n305:       case \"--force\":\n306:         result.force = true;\n307:         break;\n308:       case \"--check\":\n309:         result.checkOnly = true;\n310:         break;\n311:       case \"--tag\":\n312:       case \"--release\":\n313:         result.tag = requireValue(arg);\n314:         break;\n315:       case \"--output\":\n316:       case \"-o\":\n317:         result.outputFmt = resolveOutputFormat(requireValue(arg));\n318:         break;\n319: \n320:       // --- Tasks subcommand options ---\n321:       case \"--status\":\n322:         result.status = requireValue(arg);\n323:         break;\n324:       case \"--ready\":\n325:         result.ready = true;\n326:         break;\n327:       case \"--include-archive\":\n328:         result.includeArchive = true;\n329:         break;\n330:       case \"--title\":\n331:         result.title = requireValue(arg);\n332:         break;\n333:       case \"--description\":\n334:       case \"--desc\":\n335:         result.description = requireValue(arg);\n336:         break;\n337:       case \"--effort\":\n338:         result.effort = requireValue(arg);\n339:         break;\n340:       case \"--depends-on\":\n341:         result.dependsOn = requireValue(arg).split(\",\").map((s) => s.trim());\n342:         break;\n343:       case \"--fields\":\n344:         result.fields = requireValue(arg).split(\",\").map((s) => s.trim());\n345:         break;\n346: \n347:       // --- Graph options ---\n348:       case \"--ascii\":\n349:         result.ascii = true;\n350:         break;\n351:       case \"--mermaid\":\n352:         result.mermaidRaw = true;\n353:         break;\n354:       case \"--subtasks\":\n355:         result.graphSubtasks = true;\n356:         break;\n357: \n358:       // --- Logs options ---\n359:       case \"--tail\":\n360:         result.tail = parseInt(requireValue(arg), 10);\n361:         break;\n362:       case \"--follow\":\n363:       case \"-f\":\n364:         result.follow = true;\n365:         break;\n366: \n367:       // --- Browser verification ---\n368:       case \"--browser\":\n369:         result.browser = true;\n370:         break;\n371: \n372:       // --- TDD verification ---\n373:       case \"--skip-tests\":\n374:         result.skipTests = true;\n375:         break;\n376:       case \"--strict-tdd\":\n377:         result.strictTdd = true;\n378:         break;\n379: \n380:       // --- Agent selection ---\n381:       case \"--agent\":\n382:         result.agent = requireValue(arg);\n383:         break;\n384: \n385:       // --- Positional (feature-id, title for add, etc.) ---\n386:       default:\n387:         if (!arg.startsWith(\"-\")) {\n388:           if (!result.featureId) {\n389:             result.featureId = arg;\n390:           } else if (!result.title) {\n391:             result.title = arg;\n392:           }\n393:         }\n394:         break;\n395:     }\n396:   }\n397: \n398:   return result;\n399: }\n400: \n401: // ---------------------------------------------------------------------------\n402: // Help\n403: // ---------------------------------------------------------------------------\n404: \n405: function cmdHelp(): void {\n406:   console.log(`\n407: wombo-combo — AI Agent Orchestration System\n408: \n409:   WOMBO COMBO! Parallel feature development with AI agents.\n410: \n411: Commands:                        (alias)\n412:   init                           (i)     Generate .wombo-combo/config.json in the current project\n413:   launch                         (l)     Launch a wave of agents to implement features\n414:   resume                         (r)     Resume a previously stopped wave\n415:   status                         (s)     Show the status of the current wave\n416:   verify                         (v)     Run build verification on completed agents\n417:   merge                          (m)     Merge verified branches into the base branch\n418:   retry                          (re)    Retry a failed agent\n419:   abort                          (a)     Kill a single running agent (--requeue to return to queue)\n420:   logs                           (lo)    Pretty-print agent logs for a feature\n421:   cleanup                        (c)     Remove all wave worktrees and multiplexer sessions\n422:   history                        (h)     List/view past wave results (stored in .wombo-combo/history/)\n423:   tasks                          (t)     Manage tasks file (see below; 'features' also accepted)\n424:   upgrade                        (u)     Check for updates and upgrade wombo-combo\n425:   describe                       (d)     Emit JSON schema of a command (for AI agents)\n426:   completion                     (comp)  Generate shell completions (bash, zsh, fish)\n427:   version                                Print version and exit\n428:   help                                   Show this help\n429: \n430: Tasks Subcommands:               (alias)\n431:   tasks list                     (ls)    List tasks (--status, --priority, --difficulty, --ready, --include-archive)\n432:   tasks add <id> <title>         (a)     Add a new task (--desc, --priority, --difficulty, --effort, --depends-on)\n433:   tasks set-status <id> <s>      (ss)    Change a task's status\n434:   tasks set-priority <id> <p>    (sp)    Change a task's priority (critical/high/medium/low/wishlist)\n435:   tasks set-difficulty <id> <d>  (sd)    Change a task's difficulty (trivial/easy/medium/hard/very_hard)\n436:   tasks check                    (ch)    Validate tasks file (schema, deps, duplicates, cycles)\n437:   tasks archive [id]             (ar)    Move done/cancelled to archive (--dry-run)\n438:   tasks show <id>                (sh)    Show task details\n439:   tasks graph                    (g)     Visualize dependency graph (--ascii, --mermaid, --subtasks)\n440: \n441: Selection Options (for launch):\n442:   --top-priority N         Select top N tasks by priority\n443:   --quickest-wins N        Select N tasks with lowest effort\n444:   --priority <level>       Filter by priority (critical/high/medium/low/wishlist)\n445:   --difficulty <level>     Filter by difficulty (trivial/easy/medium/hard/very_hard)\n446:   --tasks \"id1,id2\"        Select specific tasks by ID (--features also accepted)\n447:   --all-ready              Select all tasks whose dependencies are met\n448: \n449: Launch Options:\n450:   --max-concurrent N       Max agents running in parallel (default: from config)\n451:   --model <model>          Model to use (e.g., \"anthropic/claude-sonnet-4-20250514\")\n452:   --interactive            Use multiplexer (dmux/tmux) TUI mode instead of headless\n453:   --no-tui                 Headless mode without neo-blessed TUI (periodic console dashboard)\n454:   --auto-push              Push base branch to remote after all merges complete\n455:   --dry-run                Show what would be launched without launching\n456:   --base-branch <branch>   Base branch (default: from config)\n457:   --max-retries N          Max retries per agent (default: from config)\n458:   --browser                Enable browser-based verification (run after build passes)\n459:   --skip-tests             Skip running tests during TDD verification\n460:   --strict-tdd             Strict TDD: fail verification if new files are missing tests\n461:   --agent <name>           Override agent definition for all launched tasks (name without .md extension)\n462: \n463: General:\n464:   --force                  Force overwrite (e.g., for init) / skip prompts (e.g., for upgrade)\n465:   --output <fmt>           Output format: text (default on TTY) or json (default when piped)\n466:   -o <fmt>                 Alias for --output\n467:   --dry-run                Show what would happen without performing the action\n468:   --fields <list>          Comma-separated fields to include (e.g., id,status,priority)\n469: \n470: Upgrade Options:\n471:   --check                  Only check for updates, don't install\n472:   --tag <tag>              Install a specific version (e.g., v0.1.0)\n473: \n474: Logs Options:\n475:   --tail N                 Show only the last N lines\n476:   --follow, -f             Stream new output as it arrives (like tail -f)\n477: \n478: Aliases (every command has a short form):\n479:   woco i                         woco init\n480:   woco l --all-ready             woco launch --all-ready\n481:   woco t ls                      woco tasks list\n482:   woco t a my-task \"Title\"       woco tasks add my-task \"Title\"\n483:   woco t ss my-task done         woco tasks set-status my-task done\n484: \n485: Shell Completion:\n486:   eval \"$(woco completion bash)\"    # Bash: add to ~/.bashrc\n487:   eval \"$(woco completion zsh)\"     # Zsh:  add to ~/.zshrc\n488:   woco completion fish | source     # Fish (or save to ~/.config/fish/completions/woco.fish)\n489: \n490: Examples:\n491:   woco init\n492:   woco launch --quickest-wins 3\n493:   woco launch --priority high --interactive\n494:   woco launch --tasks \"auth-flow,search-api\" --max-concurrent 2\n495:   woco resume\n496:   woco status\n497:   woco verify\n498:   woco merge\n499:   woco retry auth-flow\n500:   woco abort auth-flow\n501:   woco abort auth-flow --requeue\n502:   woco abort auth-flow --output json\n503:   woco logs auth-flow\n504:   woco logs auth-flow --tail 50\n505:   woco logs auth-flow --follow\n506:   woco logs auth-flow --output json\n507:   woco cleanup\n508:   woco tasks list --status ready --priority high\n509:   woco tasks list --fields id,status,priority --output json\n510:   woco tasks add my-task \"My Cool Task\" --priority high --difficulty easy\n511:   woco tasks set-status my-task in-progress\n512:   woco tasks check\n513:   woco tasks archive --dry-run\n514:   woco tasks show my-task\n515:   woco history\n516:   woco history wave-2026-03-12-420\n517:   woco history --output json\n518:   woco describe                           # list all commands as JSON\n519:   woco describe launch                    # describe a specific command\n520:   woco describe tasks add                 # describe a subcommand\n521: `);\n522: }\n523: \n524: // ---------------------------------------------------------------------------\n525: // Main\n526: // ---------------------------------------------------------------------------\n527: \n528: async function main(): Promise<void> {\n529:   checkDevModeGuard();\n530: \n531:   const PROJECT_ROOT = resolve(process.cwd());\n532:   const args = parseArgs(process.argv);\n533: \n534:   // -----------------------------------------------------------------------\n535:   // Input validation at the CLI boundary\n536:   // -----------------------------------------------------------------------\n537:   if (args.featureId) {\n538:     assertValid(validateId(args.featureId, \"feature ID\"));\n539:   }\n540:   if (args.title) {\n541:     assertValid(validateText(args.title, \"title\"));\n542:   }\n543:   if (args.description) {\n544:     assertValid(validateText(args.description, \"description\"));\n545:   }\n546:   if (args.baseBranch) {\n547:     assertValid(validateBranchName(args.baseBranch, \"base branch\"));\n548:   }\n549:   if (args.effort) {\n550:     assertValid(validateDuration(args.effort, \"effort\"));\n551:   }\n552:   if (args.tasks) {\n553:     for (const fid of args.tasks) {\n554:       assertValid(validateId(fid, \"task ID in --tasks\"));\n555:     }\n556:   }\n557:   if (args.dependsOn) {\n558:     for (const dep of args.dependsOn) {\n559:       assertValid(validateId(dep, \"dependency ID in --depends-on\"));\n560:     }\n561:   }\n562: \n563:   // Validate numeric args are not NaN\n564:   const numericArgs: [string, number | undefined][] = [\n565:     [\"--top-priority\", args.topPriority],\n566:     [\"--quickest-wins\", args.quickestWins],\n567:     [\"--max-concurrent\", args.maxConcurrent],\n568:     [\"--max-retries\", args.maxRetries],\n569:     [\"--tail\", args.tail],\n570:   ];\n571:   for (const [flag, value] of numericArgs) {\n572:     if (value !== undefined && isNaN(value)) {\n573:       console.error(`${flag} requires a numeric value.`);\n574:       process.exit(1);\n575:     }\n576:   }\n577: \n578:   // Commands that don't need config loading\n579:   if (args.command === \"version\" || args.command === \"-v\" || args.command === \"-V\") {\n580:     const pkgPath = resolve(import.meta.dir, \"..\", \"package.json\");\n581:     const pkgFile = Bun.file(pkgPath);\n582:     try {\n583:       const pkg = await pkgFile.json();\n584:       console.log(`wombo-combo ${pkg.version ?? \"(unknown version)\"}`);\n585:     } catch {\n586:       console.log(\"wombo-combo (unknown version)\");\n587:     }\n588:     return;\n589:   }\n590: \n591:   if (args.command === \"help\" || args.command === \"--help\" || args.command === \"-h\") {\n592:     cmdHelp();\n593:     return;\n594:   }\n595: \n596:   if (args.command === \"describe\") {\n597:     // Schema introspection: `woco describe [command]`\n598:     if (args.outputFmt === \"toon\") {\n599:       // Emit TOON format legend — self-describing, cacheable by agents\n600:       const pkgPath = resolve(import.meta.dir, \"..\", \"package.json\");\n601:       let version = \"unknown\";\n602:       try {\n603:         const pkg = await Bun.file(pkgPath).json();\n604:         version = pkg.version ?? \"unknown\";\n605:       } catch {}\n606: \n607:       if (!args.featureId) {\n608:         // Full TOON spec (legend + all commands)\n609:         console.log(renderToonLegend(version));\n610:       } else {\n611:         // JSON structure for the full spec (--output toon with a specific command\n612:         // still emits JSON since TOON is a line-oriented data format, not a schema format)\n613:         const spec = buildToonSpec(version);\n614:         const cmdName = args.title\n615:           ? `${args.featureId} ${args.title}`\n616:           : args.featureId;\n617:         const cmdSpec = spec.commands.find((c) => c.command === cmdName);\n618:         if (!cmdSpec) {\n619:           console.error(`Unknown command: \"${cmdName}\"`);\n620:           console.error(\"Run 'woco describe --output toon' to see the full TOON spec.\");\n621:           process.exit(1);\n622:           return;\n623:         }\n624:         console.log(JSON.stringify(cmdSpec, null, 2));\n625:       }\n626:       return;\n627:     }\n628: \n629:     if (!args.featureId) {\n630:       // No command specified — list all commands\n631:       console.log(JSON.stringify(allCommandSchemas(), null, 2));\n632:     } else {\n633:       // Describe a specific command. Handle compound names: \"features list\"\n634:       const cmdName = args.title\n635:         ? `${args.featureId} ${args.title}`\n636:         : args.featureId;\n637:       const def = findCommandDef(cmdName);\n638:       if (!def) {\n639:         console.error(`Unknown command: \"${cmdName}\"`);\n640:         console.error(\"Run 'woco describe' to list all commands.\");\n641:         process.exit(1);\n642:         return;\n643:       }\n644:       console.log(JSON.stringify(commandToSchema(def), null, 2));\n645:     }\n646:     return;\n647:   }\n648: \n649:   if (args.command === \"init\") {\n650:     await cmdInit({ projectRoot: PROJECT_ROOT, force: args.force });\n651:     return;\n652:   }\n653: \n654:   if (args.command === \"upgrade\") {\n655:     await cmdUpgrade({\n656:       force: args.force,\n657:       tag: args.tag,\n658:       checkOnly: args.checkOnly,\n659:     });\n660:     return;\n661:   }\n662: \n663:   if (args.command === \"completion\") {\n664:     cmdCompletion({ shell: args.featureId }); // first positional = shell name\n665:     return;\n666:   }\n667: \n668:   if (args.command === \"logs\") {\n669:     if (!args.featureId) {\n670:       console.error(\"Usage: woco logs <feature-id> [--tail N] [--follow] [--output json]\");\n671:       process.exit(1);\n672:       return;\n673:     }\n674:     await cmdLogs({\n675:       projectRoot: PROJECT_ROOT,\n676:       featureId: args.featureId,\n677:       tail: args.tail,\n678:       follow: args.follow,\n679:       outputFmt: args.outputFmt,\n680:     });\n681:     return;\n682:   }\n683: \n684:   // Everything else requires config\n685:   const config = loadConfig(PROJECT_ROOT);\n686:   validateConfig(config);\n687: \n688:   // Commands that operate on the tasks file — ensure it exists first\n689:   const needsTasksFile = new Set([\"launch\", \"resume\", \"verify\", \"retry\", \"tasks\"]);\n690:   if (needsTasksFile.has(args.command)) {\n691:     await ensureTasksFile(PROJECT_ROOT, config);\n692:   }\n693: \n694:   switch (args.command) {\n695:     case \"launch\":\n696:       // Apply browser verification override if --browser flag was passed\n697:       if (args.browser !== undefined) {\n698:         config.browser.enabled = args.browser;\n699:       }\n700:       await cmdLaunch({\n701:         projectRoot: PROJECT_ROOT,\n702:         config,\n703:         topPriority: args.topPriority,\n704:         quickestWins: args.quickestWins,\n705:         priority: args.priority,\n706:         difficulty: args.difficulty,\n707:         features: args.tasks,\n708:         allReady: args.allReady,\n709:         maxConcurrent: args.maxConcurrent ?? config.defaults.maxConcurrent,\n710:         model: args.model,\n711:         interactive: args.interactive,\n712:         dryRun: args.dryRun,\n713:         baseBranch: args.baseBranch ?? config.baseBranch,\n714:         maxRetries: args.maxRetries ?? config.defaults.maxRetries,\n715:         noTui: args.noTui,\n716:         autoPush: args.autoPush,\n717:         outputFmt: args.outputFmt,\n718:         agent: args.agent,\n719:       });\n720:       break;\n721: \n722:     case \"resume\":\n723:       await cmdResume({\n724:         projectRoot: PROJECT_ROOT,\n725:         config,\n726:         maxConcurrent: args.maxConcurrent,\n727:         model: args.model,\n728:         interactive: args.interactive,\n729:         noTui: args.noTui,\n730:         autoPush: args.autoPush,\n731:         baseBranch: args.baseBranch,\n732:         maxRetries: args.maxRetries,\n733:         outputFmt: args.outputFmt,\n734:       });\n735:       break;\n736: \n737:     case \"status\":\n738:       await cmdStatus({ projectRoot: PROJECT_ROOT, config, outputFmt: args.outputFmt });\n739:       break;\n740: \n741:     case \"verify\":\n742:       await cmdVerify({\n743:         projectRoot: PROJECT_ROOT,\n744:         config,\n745:         featureId: args.featureId,\n746:         model: args.model,\n747:         maxRetries: args.maxRetries,\n748:         browserVerify: args.browser,\n749:         skipTests: args.skipTests,\n750:         strictTdd: args.strictTdd,\n751:         outputFmt: args.outputFmt,\n752:       });\n753:       break;\n754: \n755:     case \"merge\":\n756:       await cmdMerge({\n757:         projectRoot: PROJECT_ROOT,\n758:         config,\n759:         featureId: args.featureId,\n760:         autoPush: args.autoPush,\n761:         dryRun: args.dryRun,\n762:         model: args.model,\n763:         outputFmt: args.outputFmt,\n764:       });\n765:       break;\n766: \n767:     case \"retry\": {\n768:       if (!args.featureId) {\n769:         console.error(\"Usage: woco retry <feature-id>\");\n770:         process.exit(1);\n771:         return;\n772:       }\n773:       await cmdRetry({\n774:         projectRoot: PROJECT_ROOT,\n775:         config,\n776:         featureId: args.featureId,\n777:         model: args.model,\n778:         interactive: args.interactive,\n779:         dryRun: args.dryRun,\n780:         outputFmt: args.outputFmt,\n781:       });\n782:       break;\n783:     }\n784: \n785:     case \"cleanup\":\n786:       await cmdCleanup({ projectRoot: PROJECT_ROOT, config, dryRun: args.dryRun, outputFmt: args.outputFmt });\n787:       break;\n788: \n789:     case \"history\":\n790:       await cmdHistory({\n791:         projectRoot: PROJECT_ROOT,\n792:         config,\n793:         waveId: args.featureId,\n794:         outputFmt: args.outputFmt,\n795:       });\n796:       break;\n797: \n798:     case \"abort\": {\n799:       if (!args.featureId) {\n800:         console.error(\"Usage: woco abort <feature-id> [--requeue] [--output json]\");\n801:         process.exit(1);\n802:         return;\n803:       }\n804:       await cmdAbort({\n805:         projectRoot: PROJECT_ROOT,\n806:         config,\n807:         featureId: args.featureId,\n808:         requeue: args.requeue,\n809:         outputFmt: args.outputFmt,\n810:       });\n811:       break;\n812:     }\n813: \n814:     case \"tasks\":\n815:       await handleTasksSubcommand(args, PROJECT_ROOT, config);\n816:       break;\n817: \n818:     default:\n819:       console.error(`Unknown command: ${args.command}`);\n820:       cmdHelp();\n821:       process.exit(1);\n822:       return;\n823:   }\n824: }\n825: \n826: // ---------------------------------------------------------------------------\n827: // Tasks Subcommand Router\n828: // ---------------------------------------------------------------------------\n829: \n830: async function handleTasksSubcommand(\n831:   args: CLIArgs,\n832:   projectRoot: string,\n833:   config: import(\"./config.js\").WomboConfig\n834: ): Promise<void> {\n835:   switch (args.subcommand) {\n836:     case \"list\":\n837:       await cmdTasksList({\n838:         projectRoot,\n839:         config,\n840:         status: args.status as FeatureStatus | undefined,\n841:         priority: args.priority,\n842:         difficulty: args.difficulty,\n843:         ready: args.ready,\n844:         includeArchive: args.includeArchive,\n845:         outputFmt: args.outputFmt,\n846:         fields: args.fields,\n847:       });\n848:       break;\n849: \n850:     case \"add\": {\n851:       if (!args.featureId || !args.title) {\n852:         console.error(\"Usage: woco tasks add <id> <title> [--desc <desc>] [--priority <p>] [--difficulty <d>] [--effort <e>] [--depends-on <ids>]\");\n853:         process.exit(1);\n854:         return;\n855:       }\n856:       await cmdTasksAdd({\n857:         projectRoot,\n858:         config,\n859:         id: args.featureId,\n860:         title: args.title,\n861:         description: args.description,\n862:         priority: args.priority,\n863:         difficulty: args.difficulty,\n864:         effort: args.effort,\n865:         dependsOn: args.dependsOn,\n866:         outputFmt: args.outputFmt,\n867:         dryRun: args.dryRun,\n868:       });\n869:       break;\n870:     }\n871: \n872:     case \"set-status\": {\n873:       // The new status can come from the second positional (stored in args.title)\n874:       // or from the --status flag\n875:       const newStatus = args.title || args.status;\n876:       if (!args.featureId || !newStatus) {\n877:         console.error(\"Usage: woco tasks set-status <task-id> <status>\");\n878:         process.exit(1);\n879:         return;\n880:       }\n881:       await cmdTasksSetStatus({\n882:         projectRoot,\n883:         config,\n884:         featureId: args.featureId,\n885:         newStatus,\n886:         outputFmt: args.outputFmt,\n887:         dryRun: args.dryRun,\n888:       });\n889:       break;\n890:     }\n891: \n892:     case \"set-priority\": {\n893:       // The new priority can come from the second positional (stored in args.title)\n894:       // or from the --priority flag\n895:       const newPriority = args.title || (args.priority as string | undefined);\n896:       if (!args.featureId || !newPriority) {\n897:         console.error(\"Usage: woco tasks set-priority <task-id> <priority>\");\n898:         process.exit(1);\n899:         return;\n900:       }\n901:       await cmdTasksSetPriority({\n902:         projectRoot,\n903:         config,\n904:         featureId: args.featureId,\n905:         newPriority,\n906:         outputFmt: args.outputFmt,\n907:         dryRun: args.dryRun,\n908:       });\n909:       break;\n910:     }\n911: \n912:     case \"set-difficulty\": {\n913:       // The new difficulty can come from the second positional (stored in args.title)\n914:       // or from the --difficulty flag\n915:       const newDifficulty = args.title || (args.difficulty as string | undefined);\n916:       if (!args.featureId || !newDifficulty) {\n917:         console.error(\"Usage: woco tasks set-difficulty <task-id> <difficulty>\");\n918:         process.exit(1);\n919:         return;\n920:       }\n921:       await cmdTasksSetDifficulty({\n922:         projectRoot,\n923:         config,\n924:         featureId: args.featureId,\n925:         newDifficulty,\n926:         outputFmt: args.outputFmt,\n927:         dryRun: args.dryRun,\n928:       });\n929:       break;\n930:     }\n931: \n932:     case \"check\":\n933:       await cmdTasksCheck({ projectRoot, config, outputFmt: args.outputFmt });\n934:       break;\n935: \n936:     case \"archive\":\n937:       await cmdTasksArchive({\n938:         projectRoot,\n939:         config,\n940:         featureId: args.featureId,\n941:         dryRun: args.dryRun,\n942:         outputFmt: args.outputFmt,\n943:       });\n944:       break;\n945: \n946:     case \"show\": {\n947:       if (!args.featureId) {\n948:         console.error(\"Usage: woco tasks show <task-id>\");\n949:         process.exit(1);\n950:         return;\n951:       }\n952:       await cmdTasksShow({\n953:         projectRoot,\n954:         config,\n955:         featureId: args.featureId,\n956:         outputFmt: args.outputFmt,\n957:         fields: args.fields,\n958:       });\n959:       break;\n960:     }\n961: \n962:     case \"graph\":\n963:       await cmdTasksGraph({\n964:         projectRoot,\n965:         config,\n966:         status: args.status as FeatureStatus | undefined,\n967:         ascii: args.ascii,\n968:         mermaid: args.mermaidRaw,\n969:         subtasks: args.graphSubtasks,\n970:         outputFmt: args.outputFmt,\n971:       });\n972:       break;\n973: \n974:     case \"help\":\n975:     case \"--help\":\n976:     case \"-h\":\n977:       cmdHelp();\n978:       break;\n979: \n980:     default:\n981:       console.error(`Unknown tasks subcommand: ${args.subcommand}`);\n982:       console.error(\"Run 'woco tasks help' or 'woco help' for usage.\");\n983:       process.exit(1);\n984:       return;\n985:   }\n986: }\n987: \n988: // ---------------------------------------------------------------------------\n989: // Error Handlers & Entry\n990: // ---------------------------------------------------------------------------\n991: \n992: // Global error handlers — prevent silent crashes\n993: process.on(\"uncaughtException\", (err) => {\n994:   console.error(`\\n[FATAL] Uncaught exception: ${err.message}`);\n995:   console.error(err.stack);\n996:   try {\n997:     const state = loadState(process.cwd());\n998:     if (state) saveState(process.cwd(), state);\n999:   } catch {}\n1000:   process.exit(1);\n1001: });\n1002: \n1003: process.on(\"unhandledRejection\", (reason: any) => {\n1004:   console.error(`\\n[FATAL] Unhandled rejection: ${reason?.message || reason}`);\n1005:   if (reason?.stack) console.error(reason.stack);\n1006:   try {\n1007:     const state = loadState(process.cwd());\n1008:     if (state) saveState(process.cwd(), state);\n1009:   } catch {}\n1010:   process.exit(1);\n1011: });\n1012: \n1013: main().catch((err) => {\n1014:   console.error(\"Fatal error:\", err.message);\n1015:   process.exit(1);\n1016: });\n\n(End of file - total 1016 lines)\n</content>","title":"src/index.ts","metadata":{"preview":"#!/usr/bin/env bun\n/**\n * index.ts — CLI entry point for the wombo-combo agent orchestration system.\n *\n * Every command has a short alias (e.g., woco i = woco init, woco t ls = woco tasks list).\n *\n * Usage:\n *   woco init                                         (alias: i)\n *   woco launch --top-priority 3                      (alias: l)\n *   woco launch --quickest-wins 5\n *   woco launch --priority high\n *   woco launch --difficulty easy\n *   woco launch --tasks \"feat-a,feat-b\"\n *   woco launch --all-ready\n *   woco launch ... --max-concurrent 3 --model \"anthropic/claude-sonnet-4-20250514\"\n *   woco launch ... --interactive\n *   woco resume                                       (alias: r)\n *   woco status                                       (alias: s)\n *   woco verify [feature-id]                          (alias: v)\n *   woco merge [feature-id]                           (alias: m)","truncated":false,"loaded":[]},"time":{"start":1773439937954,"end":1773439937957}}}}
{"type":"tool_use","timestamp":1773439938674,"sessionID":"ses_316be8c08ffeZXbNAgwvZBSoRI","part":{"id":"prt_ce941eda3001beS5niBSfjIHcp","sessionID":"ses_316be8c08ffeZXbNAgwvZBSoRI","messageID":"msg_ce941d3be001iWa2jWDQklACFJ","type":"tool","callID":"toolu_vrtx_01TpqopzEkb3urqkQZiJF2QJ","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/dynamic-agent-types/src/lib/format-converter.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/dynamic-agent-types/src/lib/format-converter.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * format-converter.ts — Convert agency-agents definition format to woco agent\n3:  * template format.\n4:  *\n5:  * The agency-agents registry (github.com/msitarzewski/agency-agents) uses a\n6:  * different markdown structure than woco's generalist-agent.md template:\n7:  *\n8:  *   Agency-agents frontmatter:\n9:  *     name, description, color, emoji, vibe\n10:  *\n11:  *   Woco frontmatter:\n12:  *     description (long-form with examples), mode (primary)\n13:  *\n14:  * This module detects the agency-agents format and converts it to a form\n15:  * compatible with the patchImportedAgent() pipeline in templates.ts. The\n16:  * converted output preserves the specialized agent's personality and domain\n17:  * expertise while conforming to woco's expected structure.\n18:  *\n19:  * Usage:\n20:  *   Called automatically by patchImportedAgent() when the raw agent content\n21:  *   is detected as agency-agents format. No manual invocation needed.\n22:  */\n23: \n24: import YAML from \"yaml\";\n25: \n26: // ---------------------------------------------------------------------------\n27: // Types\n28: // ---------------------------------------------------------------------------\n29: \n30: /**\n31:  * Parsed representation of an agency-agents frontmatter.\n32:  * Fields match the schema used in msitarzewski/agency-agents.\n33:  */\n34: export interface AgencyAgentFrontmatter {\n35:   /** Human-readable agent name, e.g. \"Frontend Developer\" */\n36:   name: string;\n37:   /** Short description of the agent's expertise */\n38:   description: string;\n39:   /** Terminal color identifier, e.g. \"cyan\" */\n40:   color?: string;\n41:   /** Emoji representing the agent, e.g. \"🖥️\" */\n42:   emoji?: string;\n43:   /** Short personality tagline, e.g. \"Builds responsive, accessible web apps...\" */\n44:   vibe?: string;\n45: }\n46: \n47: /**\n48:  * Parsed sections from an agency-agents markdown body.\n49:  * All fields are optional — not every agent has every section.\n50:  */\n51: export interface AgencyAgentSections {\n52:   /** The agent personality intro paragraph(s) */\n53:   identity?: string;\n54:   /** Core mission / primary responsibilities */\n55:   coreMission?: string;\n56:   /** Critical rules the agent must follow */\n57:   criticalRules?: string;\n58:   /** Technical deliverables (code examples, templates) */\n59:   deliverables?: string;\n60:   /** Workflow process steps */\n61:   workflow?: string;\n62:   /** Communication style guidelines */\n63:   communicationStyle?: string;\n64:   /** Success metrics */\n65:   successMetrics?: string;\n66:   /** Advanced capabilities */\n67:   advancedCapabilities?: string;\n68:   /** Any remaining body content not matched to known sections */\n69:   remaining?: string;\n70: }\n71: \n72: /**\n73:  * Full parsed agency-agents definition.\n74:  */\n75: export interface ParsedAgencyAgent {\n76:   frontmatter: AgencyAgentFrontmatter;\n77:   sections: AgencyAgentSections;\n78:   /** Raw body content (everything after frontmatter) */\n79:   rawBody: string;\n80: }\n81: \n82: // ---------------------------------------------------------------------------\n83: // Format Detection\n84: // ---------------------------------------------------------------------------\n85: \n86: /**\n87:  * Detect whether raw markdown content is in agency-agents format.\n88:  *\n89:  * Heuristics:\n90:  *   1. Has YAML frontmatter with `name` field (woco uses `mode`, not `name`)\n91:  *   2. Frontmatter contains `color` or `emoji` or `vibe` (agency-agents specific)\n92:  *   3. Does NOT have `mode` in frontmatter (woco-specific)\n93:  *\n94:  * @param rawMd — raw markdown content to check\n95:  * @returns true if the content appears to be in agency-agents format\n96:  */\n97: export function isAgencyAgentFormat(rawMd: string): boolean {\n98:   const trimmed = rawMd.trimStart();\n99:   if (!trimmed.startsWith(\"---\")) return false;\n100: \n101:   const endIdx = trimmed.indexOf(\"---\", 3);\n102:   if (endIdx === -1) return false;\n103: \n104:   const fmBlock = trimmed.slice(3, endIdx);\n105: \n106:   try {\n107:     const parsed = YAML.parse(fmBlock);\n108:     if (!parsed || typeof parsed !== \"object\") return false;\n109: \n110:     // Agency-agents format has `name` in frontmatter; woco has `mode`\n111:     const hasName = typeof parsed.name === \"string\" && parsed.name.length > 0;\n112:     const hasMode = \"mode\" in parsed;\n113: \n114:     // If it already has `mode`, it's likely already in woco format (or patched)\n115:     if (hasMode) return false;\n116: \n117:     // Agency-agents specific fields\n118:     const hasAgencyFields =\n119:       \"color\" in parsed || \"emoji\" in parsed || \"vibe\" in parsed;\n120: \n121:     return hasName || hasAgencyFields;\n122:   } catch {\n123:     return false;\n124:   }\n125: }\n126: \n127: // ---------------------------------------------------------------------------\n128: // Parsing\n129: // ---------------------------------------------------------------------------\n130: \n131: /**\n132:  * Parse raw agency-agents markdown into structured form.\n133:  *\n134:  * @param rawMd — raw markdown content in agency-agents format\n135:  * @returns parsed representation, or null if parsing fails\n136:  */\n137: export function parseAgencyAgent(rawMd: string): ParsedAgencyAgent | null {\n138:   const trimmed = rawMd.trimStart();\n139:   if (!trimmed.startsWith(\"---\")) return null;\n140: \n141:   const endIdx = trimmed.indexOf(\"---\", 3);\n142:   if (endIdx === -1) return null;\n143: \n144:   const fmBlock = trimmed.slice(3, endIdx);\n145:   // Body starts after the closing --- and any trailing newline\n146:   const afterFm = trimmed.slice(endIdx + 3);\n147:   const rawBody = afterFm.startsWith(\"\\n\") ? afterFm.slice(1) : afterFm;\n148: \n149:   let parsed: Record<string, unknown>;\n150:   try {\n151:     parsed = YAML.parse(fmBlock);\n152:     if (!parsed || typeof parsed !== \"object\") return null;\n153:   } catch {\n154:     return null;\n155:   }\n156: \n157:   const frontmatter: AgencyAgentFrontmatter = {\n158:     name: String(parsed.name ?? \"Specialized Agent\"),\n159:     description: String(parsed.description ?? \"\"),\n160:     color: parsed.color != null ? String(parsed.color) : undefined,\n161:     emoji: parsed.emoji != null ? String(parsed.emoji) : undefined,\n162:     vibe: parsed.vibe != null ? String(parsed.vibe) : undefined,\n163:   };\n164: \n165:   const sections = extractSections(rawBody);\n166: \n167:   return { frontmatter, sections, rawBody };\n168: }\n169: \n170: /**\n171:  * Extract known sections from the agency-agents body.\n172:  *\n173:  * Agency-agents use h2 (##) headers with emoji prefixes to delimit sections.\n174:  * We extract the ones we care about for mapping, and collect the rest.\n175:  */\n176: function extractSections(body: string): AgencyAgentSections {\n177:   const sections: AgencyAgentSections = {};\n178: \n179:   // Split body into sections by h2 headers (## ...)\n180:   // Keep h1 headers attached to identity section\n181:   const h2Pattern = /^## .+$/gm;\n182:   const h2Matches: Array<{ heading: string; startIdx: number }> = [];\n183: \n184:   let match: RegExpExecArray | null;\n185:   while ((match = h2Pattern.exec(body)) !== null) {\n186:     h2Matches.push({ heading: match[0], startIdx: match.index });\n187:   }\n188: \n189:   // Everything before first h2 is identity/intro\n190:   if (h2Matches.length > 0) {\n191:     const identityContent = body.slice(0, h2Matches[0].startIdx).trim();\n192:     if (identityContent) {\n193:       sections.identity = identityContent;\n194:     }\n195:   } else {\n196:     // No h2 headers — everything is identity\n197:     sections.identity = body.trim();\n198:     return sections;\n199:   }\n200: \n201:   // Process each h2 section\n202:   const remainingParts: string[] = [];\n203: \n204:   for (let i = 0; i < h2Matches.length; i++) {\n205:     const { heading, startIdx } = h2Matches[i];\n206:     const endIdx = i + 1 < h2Matches.length ? h2Matches[i + 1].startIdx : body.length;\n207:     const sectionContent = body.slice(startIdx, endIdx).trim();\n208:     const headingLower = heading.toLowerCase();\n209: \n210:     if (matchesSection(headingLower, [\"identity\", \"memory\"])) {\n211:       sections.identity = joinContent(sections.identity, sectionContent);\n212:     } else if (matchesSection(headingLower, [\"core mission\", \"mission\", \"responsibilities\"])) {\n213:       sections.coreMission = joinContent(sections.coreMission, sectionContent);\n214:     } else if (matchesSection(headingLower, [\"critical rules\", \"rules you must follow\", \"constraints\"])) {\n215:       sections.criticalRules = joinContent(sections.criticalRules, sectionContent);\n216:     } else if (matchesSection(headingLower, [\"deliverable\", \"technical deliverable\"])) {\n217:       sections.deliverables = joinContent(sections.deliverables, sectionContent);\n218:     } else if (matchesSection(headingLower, [\"workflow\", \"process\"])) {\n219:       sections.workflow = joinContent(sections.workflow, sectionContent);\n220:     } else if (matchesSection(headingLower, [\"communication style\", \"communication\"])) {\n221:       sections.communicationStyle = joinContent(sections.communicationStyle, sectionContent);\n222:     } else if (matchesSection(headingLower, [\"success metrics\", \"metrics\"])) {\n223:       sections.successMetrics = joinContent(sections.successMetrics, sectionContent);\n224:     } else if (matchesSection(headingLower, [\"advanced capabilities\", \"capabilities\"])) {\n225:       sections.advancedCapabilities = joinContent(sections.advancedCapabilities, sectionContent);\n226:     } else {\n227:       remainingParts.push(sectionContent);\n228:     }\n229:   }\n230: \n231:   if (remainingParts.length > 0) {\n232:     sections.remaining = remainingParts.join(\"\\n\\n\");\n233:   }\n234: \n235:   return sections;\n236: }\n237: \n238: /**\n239:  * Check if a heading matches any of the given keyword patterns.\n240:  */\n241: function matchesSection(headingLower: string, keywords: string[]): boolean {\n242:   return keywords.some((kw) => headingLower.includes(kw));\n243: }\n244: \n245: /**\n246:  * Join existing content with new content, separated by double newline.\n247:  */\n248: function joinContent(existing: string | undefined, newContent: string): string {\n249:   if (!existing) return newContent;\n250:   return existing + \"\\n\\n\" + newContent;\n251: }\n252: \n253: // ---------------------------------------------------------------------------\n254: // Conversion\n255: // ---------------------------------------------------------------------------\n256: \n257: /**\n258:  * Convert an agency-agents definition to woco-compatible agent markdown.\n259:  *\n260:  * The output follows the structure expected by patchImportedAgent() in\n261:  * templates.ts:\n262:  *   - YAML frontmatter with `description` and `mode: primary`\n263:  *   - Markdown body with the agent's specialized content\n264:  *\n265:  * The conversion:\n266:  *   1. Transforms frontmatter: name/description/vibe → description, adds mode\n267:  *   2. Restructures body: preserves specialized content, strips emoji headers,\n268:  *      reflows into a clean structure\n269:  *   3. Preserves all domain expertise and personality\n270:  *\n271:  * The patching pipeline (wc-patch.body.start/end, portless/TDD injection,\n272:  * placeholder substitution) runs AFTER this conversion, adding wombo-combo\n273:  * operational context around the converted content.\n274:  *\n275:  * @param agent — parsed agency-agents definition\n276:  * @returns markdown string in woco-compatible format\n277:  */\n278: export function convertAgencyToWoco(agent: ParsedAgencyAgent): string {\n279:   // --- Build woco-style description ---\n280:   const descParts: string[] = [];\n281:   descParts.push(agent.frontmatter.description);\n282:   if (agent.frontmatter.vibe) {\n283:     descParts.push(agent.frontmatter.vibe);\n284:   }\n285:   const wocoDescription = descParts.join(\" \").trim();\n286: \n287:   // --- Build frontmatter ---\n288:   const fmObj: Record<string, string> = {\n289:     description: wocoDescription,\n290:     mode: \"primary\",\n291:   };\n292:   const fmYaml = YAML.stringify(fmObj, { lineWidth: 0 }).trimEnd();\n293: \n294:   // --- Build body ---\n295:   const bodyParts: string[] = [];\n296: \n297:   // Agent role preamble — preserve the identity/personality\n298:   const agentName = agent.frontmatter.name;\n299:   bodyParts.push(\n300:     `You are **${agentName}**, a specialized agent with domain expertise.`\n301:   );\n302: \n303:   // Identity section\n304:   if (agent.sections.identity) {\n305:     bodyParts.push(\"\");\n306:     bodyParts.push(cleanEmojiHeaders(agent.sections.identity));\n307:   }\n308: \n309:   // Core mission\n310:   if (agent.sections.coreMission) {\n311:     bodyParts.push(\"\");\n312:     bodyParts.push(cleanEmojiHeaders(agent.sections.coreMission));\n313:   }\n314: \n315:   // Critical rules\n316:   if (agent.sections.criticalRules) {\n317:     bodyParts.push(\"\");\n318:     bodyParts.push(cleanEmojiHeaders(agent.sections.criticalRules));\n319:   }\n320: \n321:   // Workflow\n322:   if (agent.sections.workflow) {\n323:     bodyParts.push(\"\");\n324:     bodyParts.push(cleanEmojiHeaders(agent.sections.workflow));\n325:   }\n326: \n327:   // Deliverables\n328:   if (agent.sections.deliverables) {\n329:     bodyParts.push(\"\");\n330:     bodyParts.push(cleanEmojiHeaders(agent.sections.deliverables));\n331:   }\n332: \n333:   // Communication style\n334:   if (agent.sections.communicationStyle) {\n335:     bodyParts.push(\"\");\n336:     bodyParts.push(cleanEmojiHeaders(agent.sections.communicationStyle));\n337:   }\n338: \n339:   // Advanced capabilities\n340:   if (agent.sections.advancedCapabilities) {\n341:     bodyParts.push(\"\");\n342:     bodyParts.push(cleanEmojiHeaders(agent.sections.advancedCapabilities));\n343:   }\n344: \n345:   // Success metrics\n346:   if (agent.sections.successMetrics) {\n347:     bodyParts.push(\"\");\n348:     bodyParts.push(cleanEmojiHeaders(agent.sections.successMetrics));\n349:   }\n350: \n351:   // Remaining sections\n352:   if (agent.sections.remaining) {\n353:     bodyParts.push(\"\");\n354:     bodyParts.push(cleanEmojiHeaders(agent.sections.remaining));\n355:   }\n356: \n357:   const body = bodyParts.join(\"\\n\") + \"\\n\";\n358: \n359:   return `---\\n${fmYaml}\\n---\\n${body}`;\n360: }\n361: \n362: /**\n363:  * Clean emoji prefixes from markdown headers.\n364:  *\n365:  * Agency-agents use emoji-prefixed headers like:\n366:  *   ## 🧠 Your Identity & Memory\n367:  *   ## 🎯 Your Core Mission\n368:  *\n369:  * These are cleaned to plain headers:\n370:  *   ## Your Identity & Memory\n371:  *   ## Your Core Mission\n372:  *\n373:  * This avoids confusing the LLM with decorative emoji in operational headers.\n374:  */\n375: function cleanEmojiHeaders(content: string): string {\n376:   // Match h1-h4 headers with emoji prefixes\n377:   // Emoji pattern: unicode emoji chars followed by optional space\n378:   return content.replace(\n379:     /^(#{1,4})\\s+[\\u{1F300}-\\u{1FAFF}\\u{2600}-\\u{27BF}\\u{FE00}-\\u{FE0F}\\u{200D}\\u{20E3}\\u{E0020}-\\u{E007F}]+\\s*/gmu,\n380:     \"$1 \"\n381:   );\n382: }\n383: \n384: // ---------------------------------------------------------------------------\n385: // Convenience: Detect + Convert\n386: // ---------------------------------------------------------------------------\n387: \n388: /**\n389:  * If the raw markdown is in agency-agents format, convert it to woco format.\n390:  * Otherwise return it unchanged.\n391:  *\n392:  * This is the primary entry point used by patchImportedAgent() to ensure\n393:  * all imported agent definitions are in a compatible format before patching.\n394:  *\n395:  * @param rawMd — raw markdown content (may be agency-agents or woco format)\n396:  * @returns markdown in woco-compatible format\n397:  */\n398: export function normalizeAgentFormat(rawMd: string): string {\n399:   if (!isAgencyAgentFormat(rawMd)) {\n400:     return rawMd;\n401:   }\n402: \n403:   const parsed = parseAgencyAgent(rawMd);\n404:   if (!parsed) {\n405:     // Parsing failed — return as-is and let patchImportedAgent handle it\n406:     return rawMd;\n407:   }\n408: \n409:   return convertAgencyToWoco(parsed);\n410: }\n\n(End of file - total 410 lines)\n</content>","title":"src/lib/format-converter.ts","metadata":{"preview":"/**\n * format-converter.ts — Convert agency-agents definition format to woco agent\n * template format.\n *\n * The agency-agents registry (github.com/msitarzewski/agency-agents) uses a\n * different markdown structure than woco's generalist-agent.md template:\n *\n *   Agency-agents frontmatter:\n *     name, description, color, emoji, vibe\n *\n *   Woco frontmatter:\n *     description (long-form with examples), mode (primary)\n *\n * This module detects the agency-agents format and converts it to a form\n * compatible with the patchImportedAgent() pipeline in templates.ts. The\n * converted output preserves the specialized agent's personality and domain\n * expertise while conforming to woco's expected structure.\n *\n * Usage:\n *   Called automatically by patchImportedAgent() when the raw agent content","truncated":false,"loaded":[]},"time":{"start":1773439938670,"end":1773439938673}}}}
{"type":"tool_use","timestamp":1773439939048,"sessionID":"ses_316be8c08ffeZXbNAgwvZBSoRI","part":{"id":"prt_ce941f06f001t64bmCuIFqSgJf","sessionID":"ses_316be8c08ffeZXbNAgwvZBSoRI","messageID":"msg_ce941d3be001iWa2jWDQklACFJ","type":"tool","callID":"toolu_vrtx_014FBwgxpa5KJLagSLWZmuHp","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/dynamic-agent-types/src/lib/state.ts","limit":100},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/dynamic-agent-types/src/lib/state.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * state.ts — Persistent wave state management.\n3:  *\n4:  * Responsibilities:\n5:  *   - Define the shape of .wombo-combo/state.json\n6:  *   - Read/write state atomically\n7:  *   - Generate wave IDs\n8:  *   - Update individual agent state within a wave\n9:  */\n10: \n11: import { readFileSync, writeFileSync, existsSync, renameSync, mkdirSync } from \"node:fs\";\n12: import { resolve } from \"node:path\";\n13: import { WOMBO_DIR } from \"../config.js\";\n14: \n15: // ---------------------------------------------------------------------------\n16: // Types\n17: // ---------------------------------------------------------------------------\n18: \n19: export type AgentStatus =\n20:   | \"queued\"\n21:   | \"installing\"\n22:   | \"running\"\n23:   | \"completed\"\n24:   | \"verified\"\n25:   | \"failed\"\n26:   | \"merged\"\n27:   | \"retry\"\n28:   | \"resolving_conflict\";\n29: \n30: export interface AgentState {\n31:   feature_id: string;\n32:   branch: string;\n33:   worktree: string;\n34:   session_id: string | null;\n35:   pid: number | null;\n36:   status: AgentStatus;\n37:   activity: string | null;\n38:   activity_updated_at: string | null;\n39:   retries: number;\n40:   max_retries: number;\n41:   started_at: string | null;\n42:   completed_at: string | null;\n43:   build_passed: boolean | null;\n44:   build_output: string | null;\n45:   error: string | null;\n46:   /** Estimated effort in milliseconds (from feature's ISO 8601 duration) */\n47:   effort_estimate_ms: number | null;\n48:   /** Stream index this agent belongs to (for dependency-aware scheduling) */\n49:   stream_index: number | null;\n50:   /** IDs of features this agent depends on (within the current wave) */\n51:   depends_on: string[];\n52:   /** IDs of features that depend on this agent (within the current wave) */\n53:   depended_on_by: string[];\n54:   /**\n55:    * Override agent name for this specific agent (from registry).\n56:    * When set, uses this agent definition instead of the default generalist.\n57:    * e.g. \"engineering-frontend-developer\"\n58:    */\n59:   agent_name: string | null;\n60:   /**\n61:    * The agent_type from the task (e.g. \"engineering/engineering-frontend-developer\").\n62:    * Stored for informational purposes and to support resume with re-fetch.\n63:    */\n64:   agent_type: string | null;\n65: }\n66: \n67: export interface WaveState {\n68:   wave_id: string;\n69:   base_branch: string;\n70:   started_at: string;\n71:   updated_at: string;\n72:   max_concurrent: number;\n73:   model: string | null;\n74:   interactive: boolean;\n75:   agents: AgentState[];\n76:   /** Dependency-aware scheduling plan (null if no dependencies exist) */\n77:   schedule_plan: SerializedSchedulePlan | null;\n78: }\n79: \n80: /**\n81:  * Serialized schedule plan stored in wave state JSON.\n82:  * Uses plain arrays instead of the rich SchedulePlan type for JSON compatibility.\n83:  */\n84: export interface SerializedSchedulePlan {\n85:   /** Streams: each is a list of feature IDs to execute sequentially */\n86:   streams: string[][];\n87:   /** Merge gates: features that must wait for multiple deps from different streams */\n88:   merge_gates: Array<{ feature_id: string; wait_for: string[] }>;\n89:   /** Topological order of all features */\n90:   topological_order: string[];\n91: }\n92: \n93: // ---------------------------------------------------------------------------\n94: // Constants\n95: // ---------------------------------------------------------------------------\n96: \n97: const STATE_FILE = \".wombo-combo/state.json\";\n98: \n99: // ---------------------------------------------------------------------------\n100: // Wave ID Generation\n\n(Showing lines 1-100 of 394. Use offset=101 to continue.)\n</content>","title":"src/lib/state.ts","metadata":{"preview":"/**\n * state.ts — Persistent wave state management.\n *\n * Responsibilities:\n *   - Define the shape of .wombo-combo/state.json\n *   - Read/write state atomically\n *   - Generate wave IDs\n *   - Update individual agent state within a wave\n */\n\nimport { readFileSync, writeFileSync, existsSync, renameSync, mkdirSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\nimport { WOMBO_DIR } from \"../config.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type AgentStatus =\n  | \"queued\"","truncated":true,"loaded":[]},"time":{"start":1773439939045,"end":1773439939047}}}}
