\n361:           activity: \"resuming...\",\n362:         });\n363:         saveState(projectRoot, state);\n364: \n365:         try {\n366:           if (!worktreeReady(agent.worktree)) {\n367:             await createWorktree(projectRoot, agent.feature_id, state.base_branch, config);\n368:             await installDeps(agent.worktree, agent.feature_id, config);\n369:           }\n370: \n371:           const prompt = generatePrompt(feature, state.base_branch, config);\n372:           const result = launchInteractive({\n373:             worktreePath: agent.worktree,\n374:             featureId: feature.id,\n375:             prompt,\n376:             model,\n377:             interactive: true,\n378:             config,\n379:           });\n380: \n381:           const muxName = getMultiplexerName(config);\n382:           updateAgent(state, agent.feature_id, {\n383:             status: \"running\",\n384:             pid: result.pid,\n385:             activity: `${muxName} session active`,\n386:           });\n387:           saveState(projectRoot, state);\n388:         } catch (err: any) {\n389:           updateAgent(state, agent.feature_id, {\n390:             status: \"failed\",\n391:             error: err.message,\n392:             activity: null,\n393:             completed_at: new Date().toISOString(),\n394:           });\n395:           saveState(projectRoot, state);\n396:         }\n397:       })\n398:     );\n399: \n400:     if (fmt === \"text\") {\n401:       printDashboard(state);\n402:       const mux = detectMultiplexer(config.agent.multiplexer);\n403:       console.log(`\\nResume complete. Use '${muxAttachCommand(mux, `${config.agent.tmuxPrefix}-<id>`)}' to check sessions.`);\n404:     }\n405:   } else {\n406:     // Headless resume — re-enter monitoring loop\n407:     const monitor = new ProcessMonitor(projectRoot, {\n408:       onSessionId: (featureId, sessionId) => {\n409:         updateAgent(state, featureId, { session_id: sessionId });\n410:         saveState(projectRoot, state);\n411:       },\n412:       onComplete: (featureId) => {\n413:         updateAgent(state, featureId, {\n414:           status: \"completed\",\n415:           completed_at: new Date().toISOString(),\n416:           activity: \"done\",\n417:         });\n418:         saveState(projectRoot, state);\n419:         wtLog(featureId, \"agent completed — verifying build...\");\n420: \n421:         const agent = state.agents.find((a) => a.feature_id === featureId)!;\n422:         const feature = featureMap.get(featureId)!;\n423:         handleBuildVerification(projectRoot, state, agent, feature, config, model, monitor)\n424:           .then(() => launchAllReady(projectRoot, state, featureMap, monitor, config, model))\n425:           .catch((err) => {\n426:             wtLog(featureId, `BUILD VERIFICATION UNHANDLED ERROR: ${err.message}`);\n427:             launchAllReady(projectRoot, state, featureMap, monitor, config, model);\n428:           });\n429:       },\n430:       onError: (featureId, error) => {\n431:         const agent = state.agents.find((a) => a.feature_id === featureId)!;\n432:         if (agent.retries < agent.max_retries) {\n433:           updateAgent(state, featureId, {\n434:             status: \"retry\",\n435:             retries: agent.retries + 1,\n436:             error,\n437:             activity: \"retrying...\",\n438:           });\n439:           saveState(projectRoot, state);\n440:           handleRetry(projectRoot, state, agent, monitor, config, model);\n441:         } else {\n442:           updateAgent(state, featureId, {\n443:             status: \"failed\",\n444:             error,\n445:             activity: null,\n446:             completed_at: new Date().toISOString(),\n447:           });\n448:           saveState(projectRoot, state);\n449: \n450:           // Cascade failure to downstream agents\n451:           const cancelled = cancelDownstream(state, featureId);\n452:           if (cancelled.length > 0) {\n453:             wtLog(featureId, `downstream cancelled: ${cancelled.join(\", \")}`);\n454:             saveState(projectRoot, state);\n455:           }\n456:         }\n457:         launchAllReady(projectRoot, state, featureMap, monitor, config, model);\n458:       },\n459:       onActivity: (featureId, activity) => {\n460:         updateAgent(state, featureId, {\n461:           activity,\n462:           activity_updated_at: new Date().toISOString(),\n463:         });\n464:       },\n465:     });\n466: \n467:     // Handle graceful shutdown\n468:     const tuiRef = { current: null as WomboTUI | null };\n469:     process.on(\"SIGINT\", () => {\n470:       if (tuiRef.current) tuiRef.current.stop();\n471:       for (const agent of state.agents) {\n472:         if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n473:           updateAgent(state, agent.feature_id, {\n474:             activity: \"interrupted\",\n475:           });\n476:         }\n477:       }\n478:       monitor.killAll();\n479:       saveState(projectRoot, state);\n480:       if (fmt === \"text\") console.log(\"\\nState saved. Use 'woco resume' to continue.\");\n481:       process.exit(0);\n482:     });\n483: \n484:     await Promise.all(\n485:       toLaunchNow.map((agent) => {\n486:         const feature = featureMap.get(agent.feature_id);\n487:         if (!feature) return Promise.resolve();\n488:         return launchSingleHeadless(projectRoot, state, agent, feature, monitor, config, model);\n489:       })\n490:     );\n491: \n492:     // Start TUI dashboard (or skip if --no-tui)\n493:     if (!opts.noTui) {\n494:       tuiRef.current = new WomboTUI({\n495:         state,\n496:         monitor,\n497:         projectRoot,\n498:         interactive: false,\n499:         config,\n\n(Showing lines 320-499 of 646. Use offset=500 to continue.)\n</content>","title":"src/commands/resume.ts","metadata":{"preview":"      }\n    }\n  }\n\n  // Re-launch agents\n  const maxConcurrent = 