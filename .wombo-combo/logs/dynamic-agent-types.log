{"type":"tool_use","timestamp":1773439923010,"sessionID":"ses_316be8c08ffeZXbNAgwvZBSoRI","part":{"id":"prt_ce941ae0c001KsYtzXLrTg52Uh","sessionID":"ses_316be8c08ffeZXbNAgwvZBSoRI","messageID":"msg_ce941a1b0001XzWF5FzYEsI7m1","type":"tool","callID":"toolu_vrtx_01GnabmXxELr5H77ehDYjzgG","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/dynamic-agent-types/src/lib/tasks.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/dynamic-agent-types/src/lib/tasks.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tasks.ts -- Parse tasks YAML and provide task selection/filtering.\n3:  *\n4:  * Responsibilities:\n5:  *   - Load and parse the tasks file with full type safety\n6:  *   - Load and parse the archive file separately\n7:  *   - Parse ISO 8601 durations into comparable minutes\n8:  *   - Filter tasks by status, priority, difficulty, dependency readiness\n9:  *   - Select tasks by various strategies (top-priority, quickest-wins, etc.)\n10:  *   - Resolve dependency graphs to determine which tasks are ready to start\n11:  *   - Write-back capability for task management commands\n12:  */\n13: \n14: import { existsSync, mkdirSync } from \"node:fs\";\n15: import { resolve, dirname, join } from \"node:path\";\n16: import { createInterface } from \"node:readline\";\n17: import type { WomboConfig } from \"../config.js\";\n18: import { WOMBO_DIR } from \"../config.js\";\n19: import {\n20:   loadTasksFromStore,\n21:   loadArchiveFromStore,\n22:   saveAllTasksToStore,\n23:   saveAllArchiveToStore,\n24:   saveTaskToStore,\n25:   saveTaskToArchive,\n26:   removeTaskFromStore,\n27:   tasksStoreExists,\n28:   saveTasksMetaToStore,\n29:   saveArchiveMetaToStore,\n30:   getTasksDir,\n31:   getArchiveDir,\n32:   saveTaskFile,\n33:   deleteTaskFile,\n34: } from \"./task-store.js\";\n35: \n36: // ---------------------------------------------------------------------------\n37: // Template path (resolved relative to this source file)\n38: // ---------------------------------------------------------------------------\n39: \n40: export const META_TEMPLATE_PATH = join(dirname(import.meta.dir), \"templates\", \"_meta.yml\");\n41: /** @deprecated Use META_TEMPLATE_PATH — the old monolithic template no longer exists. */\n42: export const TASKS_TEMPLATE_PATH = META_TEMPLATE_PATH;\n43: \n44: // ---------------------------------------------------------------------------\n45: // Types\n46: // ---------------------------------------------------------------------------\n47: \n48: export type TaskStatus =\n49:   | \"backlog\"\n50:   | \"planned\"\n51:   | \"in_progress\"\n52:   | \"blocked\"\n53:   | \"in_review\"\n54:   | \"done\"\n55:   | \"cancelled\";\n56: \n57: export type Priority = \"critical\" | \"high\" | \"medium\" | \"low\" | \"wishlist\";\n58: \n59: export type Difficulty = \"trivial\" | \"easy\" | \"medium\" | \"hard\" | \"very_hard\";\n60: \n61: /**\n62:  * Unified task type. Previously split into Feature and Subtask, but the shapes\n63:  * are identical so there is no reason to maintain two names.\n64:  */\n65: export interface Task {\n66:   id: string;\n67:   title: string;\n68:   description: string;\n69:   status: TaskStatus;\n70:   completion: number;\n71:   difficulty: Difficulty;\n72:   priority: Priority;\n73:   depends_on: string[];\n74:   effort: string;\n75:   started_at: string | null;\n76:   ended_at: string | null;\n77:   constraints: string[];\n78:   forbidden: string[];\n79:   references: string[];\n80:   notes: string[];\n81:   subtasks: Task[];\n82:   /**\n83:    * Optional agent type from an external registry (e.g. agency-agents).\n84:    * Format: \"category/agent-name\" (e.g. \"engineering/engineering-frontend-developer\").\n85:    * When set, wombo downloads and patches the specified agent definition\n86:    * instead of using the default generalist agent.\n87:    */\n88:   agent_type?: string;\n89:   /**\n90:    * Optional local agent definition file name (without extension).\n91:    * References a file in `.opencode/agents/<agent>.md`.\n92:    * When omitted, defaults to the config's `agent.name` (typically \"generalist-agent\").\n93:    * This is independent of `agent_type` which references external registry agents.\n94:    */\n95:   agent?: string;\n96: }\n97: \n98: /**\n99:  * Shape of tasks.yml (active tasks).\n100:  */\n101: export interface TasksFile {\n102:   version: string;\n103:   meta: {\n104:     created_at: string;\n105:     updated_at: string;\n106:     project: string;\n107:     generator: string;\n108:     maintainer: string;\n109:   };\n110:   tasks: Task[];\n111: }\n112: \n113: /**\n114:  * Shape of archive.yml (archived tasks). Same structure as TasksFile.\n115:  */\n116: export type ArchiveFile = TasksFile;\n117: \n118: // Backward-compat aliases (ease migration in consuming code)\n119: export type Feature = Task;\n120: export type Subtask = Task;\n121: export type FeatureStatus = TaskStatus;\n122: export type FeaturesFile = TasksFile & { archive: Task[] };\n123: \n124: // Re-export ordering maps from the canonical source (task-schema.ts)\n125: import { PRIORITY_ORDER, DIFFICULTY_ORDER } from \"./task-schema.js\";\n126: export { PRIORITY_ORDER, DIFFICULTY_ORDER };\n127: \n128: // ---------------------------------------------------------------------------\n129: // ISO 8601 Duration Parser\n130: // ---------------------------------------------------------------------------\n131: \n132: /**\n133:  * Parse an ISO 8601 duration string into total minutes.\n134:  * Supports: P[nY][nM][nD][T[nH][nM][nS]]\n135:  * Examples: PT1H -> 60, PT30M -> 30, P1D -> 1440, P2DT4H -> 3360, PT1H30M -> 90\n136:  *           P1Y -> 525600, P2M -> 86400\n137:  * Year/month approximations: 1Y = 365D, 1M = 30D\n138:  */\n139: export function parseDurationMinutes(iso: string): number {\n140:   const match = iso.match(\n141:     /^P(?:(\\d+)Y)?(?:(\\d+)M)?(?:(\\d+)D)?(?:T(?:(\\d+)H)?(?:(\\d+)M)?(?:(\\d+)S)?)?$/\n142:   );\n143:   if (!match) return Infinity; // unparseable -> sort to end\n144:   const years = parseInt(match[1] || \"0\", 10);\n145:   const months = parseInt(match[2] || \"0\", 10);\n146:   const days = parseInt(match[3] || \"0\", 10);\n147:   const hours = parseInt(match[4] || \"0\", 10);\n148:   const minutes = parseInt(match[5] || \"0\", 10);\n149:   const seconds = parseInt(match[6] || \"0\", 10);\n150:   const totalDays = years * 365 + months * 30 + days;\n151:   return totalDays * 24 * 60 + hours * 60 + minutes + Math.ceil(seconds / 60);\n152: }\n153: \n154: /**\n155:  * Format minutes into a human-readable string.\n156:  */\n157: export function formatDuration(minutes: number): string {\n158:   if (minutes === Infinity) return \"unknown\";\n159:   if (minutes < 60) return `${minutes}m`;\n160:   const h = Math.floor(minutes / 60);\n161:   const m = minutes % 60;\n162:   if (h >= 24) {\n163:     const d = Math.floor(h / 24);\n164:     const rh = h % 24;\n165:     if (rh === 0 && m === 0) return `${d}d`;\n166:     if (m === 0) return `${d}d ${rh}h`;\n167:     return `${d}d ${rh}h ${m}m`;\n168:   }\n169:   return m === 0 ? `${h}h` : `${h}h ${m}m`;\n170: }\n171: \n172: // ---------------------------------------------------------------------------\n173: // .wombo-combo directory helpers\n174: // ---------------------------------------------------------------------------\n175: \n176: /**\n177:  * Ensure the .wombo-combo directory exists.\n178:  */\n179: export function ensureWomboDir(projectRoot: string): string {\n180:   const dir = resolve(projectRoot, WOMBO_DIR);\n181:   if (!existsSync(dir)) {\n182:     mkdirSync(dir, { recursive: true });\n183:   }\n184:   return dir;\n185: }\n186: \n187: /**\n188:  * Resolve a file path within the .wombo-combo directory.\n189:  */\n190: function womboPath(projectRoot: string, filename: string): string {\n191:   return resolve(projectRoot, WOMBO_DIR, filename);\n192: }\n193: \n194: // ---------------------------------------------------------------------------\n195: // Tasks File Existence Guard\n196: // ---------------------------------------------------------------------------\n197: \n198: /**\n199:  * Prompt the user with a yes/no question via stdin.\n200:  */\n201: function promptYesNo(question: string): Promise<boolean> {\n202:   const rl = createInterface({ input: process.stdin, output: process.stdout });\n203:   return new Promise((resolve) => {\n204:     rl.question(question, (answer) => {\n205:       rl.close();\n206:       resolve(answer.trim().toLowerCase().startsWith(\"y\"));\n207:     });\n208:   });\n209: }\n210: \n211: /**\n212:  * Ensure the tasks store exists before any command that needs it.\n213:  * If the folder is missing, prompt the user to generate one from scratch\n214:  * or auto-migrate from a legacy single-file tasks.yml.\n215:  */\n216: export async function ensureTasksFile(\n217:   projectRoot: string,\n218:   config: WomboConfig\n219: ): Promise<void> {\n220:   if (tasksStoreExists(projectRoot, config)) return;\n221: \n222:   // Try loading — this triggers auto-migration from legacy files\n223:   const data = loadTasksFromStore(projectRoot, config);\n224:   if (data.tasks.length > 0 || tasksStoreExists(projectRoot, config)) return;\n225: \n226:   console.log(`\\nTasks store not found: ${WOMBO_DIR}/${config.tasksDir}/`);\n227: \n228:   const generate = await promptYesNo(\n229:     \"Generate a new tasks store from template? (y/N): \"\n230:   );\n231: \n232:   if (!generate) {\n233:     console.error(\n234:       `Cannot proceed without a tasks store. Create one manually or run again and accept the prompt.`\n235:     );\n236:     process.exit(1);\n237:   }\n238: \n239:   // Ensure .wombo-combo/ directory exists\n240:   ensureWomboDir(projectRoot);\n241: \n242:   const now = new Date().toISOString();\n243:   saveTasksMetaToStore(projectRoot, config, {\n244:     version: \"1.0\",\n245:     meta: {\n246:       created_at: now,\n247:       updated_at: now,\n248:       project: \"unknown\",\n249:       generator: \"wombo-combo\",\n250:       maintainer: \"unknown\",\n251:     },\n252:   });\n253:   console.log(`Created ${WOMBO_DIR}/${config.tasksDir}/ with empty task store.\\n`);\n254: \n255:   // Also create empty archive store\n256:   saveArchiveMetaToStore(projectRoot, config, {\n257:     version: \"1.0\",\n258:     meta: {\n259:       created_at: now,\n260:       updated_at: now,\n261:       project: \"unknown\",\n262:       generator: \"wombo-combo\",\n263:       maintainer: \"unknown\",\n264:     },\n265:   });\n266:   console.log(`Created ${WOMBO_DIR}/${config.archiveDir}/.\\n`);\n267: }\n268: \n269: // Backward-compat alias\n270: export const ensureFeaturesFile = ensureTasksFile;\n271: \n272: // ---------------------------------------------------------------------------\n273: // Loader\n274: // ---------------------------------------------------------------------------\n275: \n276: /**\n277:  * Load and parse tasks from the folder-based store.\n278:  */\n279: export function loadTasks(\n280:   projectRoot: string,\n281:   config: WomboConfig\n282: ): TasksFile {\n283:   return loadTasksFromStore(projectRoot, config);\n284: }\n285: \n286: /**\n287:  * Load archived tasks from the folder-based store.\n288:  * Returns an empty ArchiveFile if the store doesn't exist.\n289:  */\n290: export function loadArchive(\n291:   projectRoot: string,\n292:   config: WomboConfig\n293: ): ArchiveFile {\n294:   return loadArchiveFromStore(projectRoot, config);\n295: }\n296: \n297: /**\n298:  * Backward-compat: load tasks + archive merged into a single FeaturesFile shape.\n299:  * This eases migration — callers that used loadFeatures() keep working.\n300:  */\n301: export function loadFeatures(\n302:   projectRoot: string,\n303:   config: WomboConfig\n304: ): FeaturesFile {\n305:   const tasksData = loadTasks(projectRoot, config);\n306:   const archiveData = loadArchive(projectRoot, config);\n307:   return {\n308:     ...tasksData,\n309:     // Map \"tasks\" to \"features\" for backward compat (FeaturesFile has .features)\n310:     // Actually FeaturesFile extends TasksFile which has .tasks, but add .archive\n311:     archive: archiveData.tasks,\n312:   };\n313: }\n314: \n315: // ---------------------------------------------------------------------------\n316: // Writer\n317: // ---------------------------------------------------------------------------\n318: \n319: /**\n320:  * Save all tasks to the folder-based store.\n321:  * Writes _meta.yml + one file per task.\n322:  */\n323: export function saveTasks(\n324:   projectRoot: string,\n325:   config: WomboConfig,\n326:   data: TasksFile\n327: ): void {\n328:   saveAllTasksToStore(projectRoot, config, data);\n329: }\n330: \n331: /**\n332:  * Save all archived tasks to the folder-based store.\n333:  */\n334: export function saveArchive(\n335:   projectRoot: string,\n336:   config: WomboConfig,\n337:   data: ArchiveFile\n338: ): void {\n339:   saveAllArchiveToStore(projectRoot, config, data);\n340: }\n341: \n342: /**\n343:  * Backward-compat: save a FeaturesFile (tasks + archive in one object).\n344:  * Splits and writes to both tasks.yml and archive.yml.\n345:  */\n346: export function saveFeatures(\n347:   projectRoot: string,\n348:   config: WomboConfig,\n349:   data: FeaturesFile\n350: ): void {\n351:   const tasksData: TasksFile = {\n352:     version: data.version,\n353:     meta: { ...data.meta },\n354:     tasks: data.tasks,\n355:   };\n356:   saveTasks(projectRoot, config, tasksData);\n357: \n358:   if (data.archive && data.archive.length > 0) {\n359:     const archiveData: ArchiveFile = {\n360:       version: data.version,\n361:       meta: { ...data.meta },\n362:       tasks: data.archive,\n363:     };\n364:     saveArchive(projectRoot, config, archiveData);\n365:   }\n366: }\n367: \n368: \n369: // ---------------------------------------------------------------------------\n370: // Dependency Resolution\n371: // ---------------------------------------------------------------------------\n372: \n373: /**\n374:  * Get all task IDs that are done (status === \"done\" or completion === 100).\n375:  */\n376: function getDoneIds(tasks: Task[], archive: Task[]): Set<string> {\n377:   const done = new Set<string>();\n378:   const collectDone = (items: Task[]) => {\n379:     for (const item of items) {\n380:       if (item.status === \"done\" || item.completion === 100) {\n381:         done.add(item.id);\n382:       }\n383:       if (item.subtasks?.length) {\n384:         collectDone(item.subtasks);\n385:       }\n386:     }\n387:   };\n388:   collectDone(tasks);\n389:   collectDone(archive);\n390:   return done;\n391: }\n392: \n393: /**\n394:  * Check if a task's dependencies are all satisfied.\n395:  */\n396: export function areDependenciesMet(\n397:   task: Task,\n398:   doneIds: Set<string>\n399: ): boolean {\n400:   return task.depends_on.every((dep) => doneIds.has(dep));\n401: }\n402: \n403: /**\n404:  * Get all tasks that are ready to start (backlog + deps met).\n405:  */\n406: export function getReadyTasks(data: TasksFile, archive?: Task[]): Task[] {\n407:   const doneIds = getDoneIds(data.tasks, archive ?? []);\n408:   return data.tasks.filter(\n409:     (t) =>\n410:       t.status === \"backlog\" &&\n411:       t.completion === 0 &&\n412:       areDependenciesMet(t, doneIds)\n413:   );\n414: }\n415: \n416: /**\n417:  * Get done IDs (exported for use in selection error messages).\n418:  */\n419: export function getDoneTaskIds(data: TasksFile, archive?: Task[]): Set<string> {\n420:   return getDoneIds(data.tasks, archive ?? []);\n421: }\n422: \n423: // Backward-compat aliases\n424: export function getReadyFeatures(data: FeaturesFile): Task[] {\n425:   return getReadyTasks(data, data.archive);\n426: }\n427: \n428: export function getDoneFeatureIds(data: FeaturesFile): Set<string> {\n429:   return getDoneTaskIds(data, data.archive);\n430: }\n431: \n432: // ---------------------------------------------------------------------------\n433: // Selection Strategies\n434: // ---------------------------------------------------------------------------\n435: \n436: export interface SelectionOptions {\n437:   /** Select top N by priority (highest priority first, then lowest effort) */\n438:   topPriority?: number;\n439:   /** Select N quickest wins (lowest effort first) */\n440:   quickestWins?: number;\n441:   /** Select all tasks matching this priority level */\n442:   priority?: Priority;\n443:   /** Select all tasks matching this difficulty level */\n444:   difficulty?: Difficulty;\n445:   /** Select specific task IDs (comma-separated) */\n446:   taskIds?: string[];\n447:   /** Select all ready tasks */\n448:   allReady?: boolean;\n449: }\n450: \n451: /**\n452:  * Select tasks based on the given strategy.\n453:  * Always filters to only ready tasks (backlog + deps met) first.\n454:  */\n455: export function selectTasks(\n456:   data: TasksFile,\n457:   options: SelectionOptions,\n458:   archive?: Task[]\n459: ): Task[] {\n460:   const ready = getReadyTasks(data, archive);\n461: \n462:   if (options.allReady) {\n463:     return sortByPriorityThenEffort(ready);\n464:   }\n465: \n466:   if (options.taskIds?.length) {\n467:     const idSet = new Set(options.taskIds);\n468:     const selected = ready.filter((t) => idSet.has(t.id));\n469:     const missing = options.taskIds.filter(\n470:       (id) => !selected.find((t) => t.id === id)\n471:     );\n472:     if (missing.length) {\n473:       const allIds = data.tasks.map((t) => t.id);\n474:       const doneIds = getDoneIds(data.tasks, archive ?? []);\n475:       for (const m of missing) {\n476:         if (!allIds.includes(m)) {\n477:           console.error(`  Task \"${m}\" does not exist in the tasks file`);\n478:         } else {\n479:           const task = data.tasks.find((t) => t.id === m)!;\n480:           console.error(\n481:             `  Task \"${m}\" is not ready (status: ${task.status}, deps met: ${areDependenciesMet(task, doneIds)})`\n482:           );\n483:         }\n484:       }\n485:     }\n486:     return sortByPriorityThenEffort(selected);\n487:   }\n488: \n489:   if (options.priority) {\n490:     return sortByPriorityThenEffort(\n491:       ready.filter((t) => t.priority === options.priority)\n492:     );\n493:   }\n494: \n495:   if (options.difficulty) {\n496:     return sortByEffort(ready.filter((t) => t.difficulty === options.difficulty));\n497:   }\n498: \n499:   if (options.topPriority) {\n500:     return sortByPriorityThenEffort(ready).slice(0, options.topPriority);\n501:   }\n502: \n503:   if (options.quickestWins) {\n504:     return sortByEffort(ready).slice(0, options.quickestWins);\n505:   }\n506: \n507:   // Default: return all ready, sorted by priority\n508:   return sortByPriorityThenEffort(ready);\n509: }\n510: \n511: // Backward-compat alias\n512: export function selectFeatures(\n513:   data: FeaturesFile,\n514:   options: SelectionOptions & { featureIds?: string[] }\n515: ): Task[] {\n516:   // Map featureIds -> taskIds for backward compat\n517:   const opts: SelectionOptions = {\n518:     ...options,\n519:     taskIds: options.taskIds ?? options.featureIds,\n520:   };\n521:   return selectTasks(data, opts, data.archive);\n522: }\n523: \n524: // ---------------------------------------------------------------------------\n525: // Sorting Helpers\n526: // ---------------------------------------------------------------------------\n527: \n528: function sortByPriorityThenEffort(tasks: Task[]): Task[] {\n529:   return [...tasks].sort((a, b) => {\n530:     const pDiff = PRIORITY_ORDER[a.priority] - PRIORITY_ORDER[b.priority];\n531:     if (pDiff !== 0) return pDiff;\n532:     return parseDurationMinutes(a.effort) - parseDurationMinutes(b.effort);\n533:   });\n534: }\n535: \n536: function sortByEffort(tasks: Task[]): Task[] {\n537:   return [...tasks].sort(\n538:     (a, b) => parseDurationMinutes(a.effort) - parseDurationMinutes(b.effort)\n539:   );\n540: }\n541: \n542: // ---------------------------------------------------------------------------\n543: // Utility Exports\n544: // ---------------------------------------------------------------------------\n545: \n546: /**\n547:  * Get a compact summary of a task for display.\n548:  */\n549: export function taskSummary(t: Task): string {\n550:   const effort = formatDuration(parseDurationMinutes(t.effort));\n551:   return `[${t.priority}/${t.difficulty}] ${t.id} -- ${t.title} (${effort})`;\n552: }\n553: \n554: // Backward-compat alias\n555: export const featureSummary = taskSummary;\n556: \n557: /**\n558:  * Recursively search a list of tasks (and their subtasks) for a matching ID.\n559:  */\n560: function findInList(tasks: Task[], id: string): Task | undefined {\n561:   for (const t of tasks) {\n562:     if (t.id === id) return t;\n563:     if (t.subtasks?.length) {\n564:       const found = findInList(t.subtasks, id);\n565:       if (found) return found;\n566:     }\n567:   }\n568:   return undefined;\n569: }\n570: \n571: /**\n572:  * Find a task by ID across active tasks, their subtasks\n573:  * (recursively), and the archive list.\n574:  */\n575: export function findTaskById(\n576:   data: TasksFile,\n577:   id: string,\n578:   archive?: Task[]\n579: ): Task | undefined {\n580:   return (\n581:     findInList(data.tasks, id) ??\n582:     (archive ? findInList(archive, id) : undefined)\n583:   );\n584: }\n585: \n586: // Backward-compat alias\n587: export function findFeatureById(\n588:   data: FeaturesFile,\n589:   id: string\n590: ): Task | undefined {\n591:   return findTaskById(data, id, data.archive);\n592: }\n593: \n594: /**\n595:  * Create a blank task with all required fields initialized.\n596:  */\n597: export function createBlankTask(\n598:   id: string,\n599:   title: string,\n600:   description: string = \"\",\n601:   opts?: {\n602:     priority?: Priority;\n603:     difficulty?: Difficulty;\n604:     effort?: string;\n605:   }\n606: ): Task {\n607:   return {\n608:     id,\n609:     title,\n610:     description,\n611:     status: \"backlog\",\n612:     completion: 0,\n613:     difficulty: opts?.difficulty ?? \"medium\",\n614:     priority: opts?.priority ?? \"medium\",\n615:     depends_on: [],\n616:     effort: opts?.effort ?? \"PT1H\",\n617:     started_at: null,\n618:     ended_at: null,\n619:     constraints: [],\n620:     forbidden: [],\n621:     references: [],\n622:     notes: [],\n623:     subtasks: [],\n624:   };\n625: }\n626: \n627: // Backward-compat alias\n628: export const createBlankFeature = createBlankTask;\n629: \n630: /**\n631:  * Get all task IDs (active + archive), useful for validation.\n632:  */\n633: export function allTaskIds(data: TasksFile, archive?: Task[]): string[] {\n634:   const ids: string[] = [];\n635:   const collect = (items: Task[]) => {\n636:     for (const item of items) {\n637:       ids.push(item.id);\n638:       if (item.subtasks?.length) collect(item.subtasks);\n639:     }\n640:   };\n641:   collect(data.tasks);\n642:   collect(archive ?? []);\n643:   return ids;\n644: }\n645: \n646: // Backward-compat alias\n647: export function allFeatureIds(data: FeaturesFile): string[] {\n648:   return allTaskIds(data, data.archive);\n649: }\n650: \n651: // Re-export the old template path name for migration\n652: export const FEATURES_TEMPLATE_PATH = TASKS_TEMPLATE_PATH;\n653: \n654: // Re-export store functions for single-task operations\n655: export {\n656:   saveTaskToStore,\n657:   saveTaskToArchive,\n658:   removeTaskFromStore,\n659:   getTasksDir,\n660:   getArchiveDir,\n661: } from \"./task-store.js\";\n\n(End of file - total 661 lines)\n</content>","title":"src/lib/tasks.ts","metadata":{"preview":"/**\n * tasks.ts -- Parse tasks YAML and provide task selection/filtering.\n *\n * Responsibilities:\n *   - Load and parse the tasks file with full type safety\n *   - Load and parse the archive file separately\n *   - Parse ISO 8601 durations into comparable minutes\n *   - Filter tasks by status, priority, difficulty, dependency readiness\n *   - Select tasks by various strategies (top-priority, quickest-wins, etc.)\n *   - Resolve dependency graphs to determine which tasks are ready to start\n *   - Write-back capability for task management commands\n */\n\nimport { existsSync, mkdirSync } from \"node:fs\";\nimport { resolve, dirname, join } from \"node:path\";\nimport { createInterface } from \"node:readline\";\nimport type { WomboConfig } from \"../config.js\";\nimport { WOMBO_DIR } from \"../config.js\";\nimport {\n  loadTasksFromStore,","truncated":false,"loaded":[]},"time":{"start":1773439923004,"end":1773439923009}}}}
{"type":"tool_use","timestamp":1773439923338,"sessionID":"ses_316be8c08ffeZXbNAgwvZBSoRI","part":{"id":"prt_ce941b33e00122sxPvlIvnBnkH","sessionID":"ses_316be8c08ffeZXbNAgwvZBSoRI","messageID":"msg_ce941a1b0001XzWF5FzYEsI7m1","type":"tool","callID":"toolu_vrtx_01UdteuZTrunmhu9gxipdWGE","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/dynamic-agent-types/src/lib/prompt.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/dynamic-agent-types/src/lib/prompt.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * prompt.ts — Generate agent prompts from feature specs.\n3:  *\n4:  * Responsibilities:\n5:  *   - Transform a Feature into a structured prompt for the agent\n6:  *   - Include feature spec, subtasks, constraints, forbidden items, references\n7:  *   - Generate the build command and success criteria\n8:  *   - All project-specific values come from config (no hardcoded Astro references)\n9:  */\n10: \n11: import type { Feature, Subtask } from \"./tasks.js\";\n12: import { formatDuration, parseDurationMinutes } from \"./tasks.js\";\n13: import type { WomboConfig } from \"../config.js\";\n14: import { isPortlessAvailable, portlessUrl } from \"./portless.js\";\n15: \n16: // ---------------------------------------------------------------------------\n17: // Prompt Generation\n18: // ---------------------------------------------------------------------------\n19: \n20: /**\n21:  * Generate the full prompt for an autonomous agent working on a feature.\n22:  */\n23: export function generatePrompt(\n24:   feature: Feature,\n25:   baseBranch: string,\n26:   config: WomboConfig\n27: ): string {\n28:   const sections: string[] = [];\n29: \n30:   // Header\n31:   sections.push(`# Feature Implementation: ${feature.title}`);\n32:   sections.push(`**Feature ID:** \\`${feature.id}\\``);\n33:   sections.push(`**Branch:** \\`${config.git.branchPrefix}${feature.id}\\``);\n34:   sections.push(`**Base:** \\`${baseBranch}\\``);\n35:   sections.push(\n36:     `**Estimated Effort:** ${formatDuration(parseDurationMinutes(feature.effort))}`\n37:   );\n38:   sections.push(\n39:     `**Difficulty:** ${feature.difficulty} | **Priority:** ${feature.priority}`\n40:   );\n41: \n42:   // Description\n43:   sections.push(`\\n## Description\\n`);\n44:   sections.push(feature.description.trim());\n45: \n46:   // Subtasks\n47:   if (feature.subtasks.length > 0) {\n48:     sections.push(`\\n## Subtasks\\n`);\n49:     sections.push(\n50:       \"Complete these in order. Mark each done with a commit when finished.\\n\"\n51:     );\n52:     for (let i = 0; i < feature.subtasks.length; i++) {\n53:       sections.push(formatSubtask(feature.subtasks[i], i + 1, 0));\n54:     }\n55:   }\n56: \n57:   // Constraints\n58:   if (feature.constraints.length > 0) {\n59:     sections.push(`\\n## Constraints\\n`);\n60:     sections.push(\n61:       \"You MUST follow these constraints. Violating any is a failure.\\n\"\n62:     );\n63:     for (const c of feature.constraints) {\n64:       sections.push(`- ${c}`);\n65:     }\n66:   }\n67: \n68:   // Forbidden\n69:   if (feature.forbidden.length > 0) {\n70:     sections.push(`\\n## Forbidden\\n`);\n71:     sections.push(\n72:       \"You MUST NOT do any of the following. Violating any is a failure.\\n\"\n73:     );\n74:     for (const f of feature.forbidden) {\n75:       sections.push(`- ${f}`);\n76:     }\n77:   }\n78: \n79:   // References (files to explore)\n80:   if (feature.references.length > 0) {\n81:     sections.push(`\\n## Key Files to Explore\\n`);\n82:     sections.push(\n83:       \"Start by reading these files to understand the current state:\\n\"\n84:     );\n85:     for (const r of feature.references) {\n86:       sections.push(`- \\`${r}\\``);\n87:     }\n88:   }\n89: \n90:   // Notes\n91:   if (feature.notes.length > 0) {\n92:     sections.push(`\\n## Planning Notes\\n`);\n93:     for (const n of feature.notes) {\n94:       sections.push(`- ${n}`);\n95:     }\n96:   }\n97: \n98:   // Build verification — uses config, no hardcoded Astro command\n99:   sections.push(`\\n## Build Verification\\n`);\n100:   sections.push(\n101:     \"After completing all changes, run the build to verify everything works:\\n\"\n102:   );\n103:   sections.push(\"```bash\");\n104:   sections.push(config.build.command);\n105:   sections.push(\"```\\n\");\n106:   sections.push(\n107:     \"If the build fails, fix the errors before considering the task complete.\"\n108:   );\n109: \n110:   // Browser testing — inform agents about browser verification capabilities\n111:   if (config.browser.enabled) {\n112:     sections.push(`\\n## Browser Testing\\n`);\n113:     sections.push(\n114:       \"This project has browser-based verification enabled. After the build passes, \" +\n115:       \"browser tests will run automatically as part of the verification pipeline.\\n\"\n116:     );\n117:     sections.push(\"To add browser tests for this feature:\\n\");\n118:     sections.push(\"1. Create the directory `.wombo-browser/tests/` in the worktree root\");\n119:     sections.push(\"2. Add test scripts (`.sh`, `.ts`, or `.js` files) that will be executed in order\");\n120:     sections.push(\"3. Each test script receives these environment variables:\");\n121:     sections.push(\"   - `BROWSER_DEBUG_PORT` — Chrome DevTools Protocol port\");\n122:     sections.push(\"   - `BROWSER_WS_ENDPOINT` — WebSocket endpoint for the browser\");\n123:     sections.push(\"   - `BROWSER_HEADLESS` — whether the browser is running headless\");\n124:     sections.push(\"   - `BROWSER_SCREENSHOT_PATH` — path to save a screenshot for this test\");\n125:     sections.push(\"4. A test passes if it exits with code 0, fails otherwise\\n\");\n126:     if (config.browser.testCommand) {\n127:       sections.push(\n128:         `Alternatively, the project uses a custom browser test command: \\`${config.browser.testCommand}\\``\n129:       );\n130:     }\n131:     sections.push(\n132:       \"\\nBrowser tests are optional — if no tests are found, browser verification is skipped.\"\n133:     );\n134:   }\n135: \n136:   // Portless server testing instructions\n137:   if (config.portless.enabled && isPortlessAvailable(config)) {\n138:     sections.push(`\\n## Server Testing (portless)\\n`);\n139:     sections.push(\n140:       \"This worktree is configured with **portless** to prevent port collisions \" +\n141:       \"between concurrent agents. When starting any localhost server for testing:\\n\"\n142:     );\n143:     sections.push(\"```bash\");\n144:     sections.push(\"# Instead of running a server directly:\");\n145:     sections.push(\"#   npm run dev\");\n146:     sections.push(\"#   bun run dev\");\n147:     sections.push(\"#   node server.js\");\n148:     sections.push(\"\");\n149:     sections.push(\"# Wrap it with portless:\");\n150:     sections.push(`portless run npm run dev`);\n151:     sections.push(`portless run bun run dev`);\n152:     sections.push(`portless run node server.js`);\n153:     sections.push(\"```\\n\");\n154:     sections.push(\n155:       `Your dev server will be available at: \\`${portlessUrl(feature.id, config)}\\``\n156:     );\n157:     sections.push(\"\");\n158:     sections.push(\"**Rules:**\");\n159:     sections.push(\"- ALWAYS use `portless run <command>` when starting any server that listens on a port\");\n160:     sections.push(\"- Do NOT hardcode port numbers — portless assigns ports automatically via the `PORT` env var\");\n161:     sections.push(\"- The `PORT` and `PORTLESS_URL` environment variables are set automatically\");\n162:     sections.push(\"- If you need to reference the server URL in tests or config, use the `PORTLESS_URL` env var\");\n163:   }\n164: \n165:   // TDD instructions — deterministic injection based on config\n166:   if (config.tdd?.enabled) {\n167:     const testCmd = config.tdd.testCommand || \"bun test\";\n168:     sections.push(`\\n## Test-Driven Development (TDD)\\n`);\n169:     sections.push(\n170:       \"You MUST follow the **red-green-refactor** TDD cycle for all implementation work:\\n\"\n171:     );\n172:     sections.push(\"### Workflow\\n\");\n173:     sections.push(`1. **🔴 Red** — Write a failing test first. Run \\`${testCmd}\\` to confirm it fails.`);\n174:     sections.push(`2. **🟢 Green** — Write minimal code to make the test pass. Run \\`${testCmd}\\` to confirm.`);\n175:     sections.push(`3. **🔵 Refactor** — Clean up while keeping tests green. Run \\`${testCmd}\\` after each change.`);\n176:     sections.push(`4. **Repeat** for each new behavior or edge case.\\n`);\n177:     sections.push(\"### Rules\\n\");\n178:     sections.push(\"- **Never skip the red step.** Every new behavior starts with a failing test.\");\n179:     sections.push(\"- **One behavior per cycle.** Each iteration covers exactly one small behavior.\");\n180:     sections.push(\"- **Commit at green.** Each commit should have all tests passing.\");\n181:     sections.push(`- **Run tests frequently.** Run \\`${testCmd}\\` after every meaningful change.`);\n182:     sections.push(\"- Use `import { describe, test, expect } from \\\"bun:test\\\";` for test files.\");\n183:     sections.push(\"- Place tests next to source: `src/foo.ts` → `src/foo.test.ts` (or `tests/foo.test.ts`).\");\n184:   }\n185: \n186:   // Commit guidelines\n187:   sections.push(`\\n## Commit Guidelines\\n`);\n188:   sections.push(\"- Use conventional commits: `feat(scope):`, `fix(scope):`, `refactor(scope):`, `docs(scope):`\");\n189:   sections.push(`- Scope should be: \\`${feature.id}\\` or a relevant module name`);\n190:   sections.push(\"- Commit after each logical unit of work (roughly per subtask)\");\n191:   sections.push(\"- Do NOT squash all changes into one commit\");\n192:   sections.push(\"- Do NOT push to remote -- the orchestrator handles that\");\n193:   sections.push(`- Do NOT modify \\`${config.tasksDir}\\` -- the orchestrator handles that`);\n194: \n195:   // Final instruction\n196:   sections.push(`\\n## Execution\\n`);\n197:   sections.push(\"1. Read the key files listed above to understand the codebase\");\n198:   sections.push(\"2. Create a plan (use the TodoWrite tool)\");\n199:   sections.push(\"3. Implement each subtask, committing as you go\");\n200:   sections.push(`4. Run \\`${config.build.command}\\` to verify`);\n201:   sections.push(\"5. If the build passes, you are done\");\n202:   sections.push(\"6. If the build fails, fix the errors and re-run until it passes\");\n203: \n204:   return sections.join(\"\\n\");\n205: }\n206: \n207: // ---------------------------------------------------------------------------\n208: // Subtask Formatting\n209: // ---------------------------------------------------------------------------\n210: \n211: // ---------------------------------------------------------------------------\n212: // Conflict Resolution Prompt\n213: // ---------------------------------------------------------------------------\n214: \n215: /**\n216:  * Generate a prompt for an agent that resolves merge conflicts.\n217:  *\n218:  * The agent is launched in the feature worktree AFTER `git merge <baseBranch>`\n219:  * has been run there, leaving conflict markers in the working tree.\n220:  */\n221: export function generateConflictResolutionPrompt(\n222:   feature: Feature,\n223:   baseBranch: string,\n224:   mergeError: string,\n225:   config: WomboConfig\n226: ): string {\n227:   const sections: string[] = [];\n228: \n229:   sections.push(`# Merge Conflict Resolution: ${feature.title}`);\n230:   sections.push(`**Feature ID:** \\`${feature.id}\\``);\n231:   sections.push(`**Feature Branch:** \\`${config.git.branchPrefix}${feature.id}\\``);\n232:   sections.push(`**Base Branch:** \\`${baseBranch}\\``);\n233: \n234:   sections.push(`\\n## Situation\\n`);\n235:   sections.push(\n236:     `The feature branch \\`${config.git.branchPrefix}${feature.id}\\` has been completed and build-verified, ` +\n237:     `but merging it into \\`${baseBranch}\\` produced conflicts. The base branch (\\`${baseBranch}\\`) has been ` +\n238:     `merged INTO this feature branch's worktree, so the conflict markers are present in the working tree right now.`\n239:   );\n240: \n241:   sections.push(`\\n## Merge Error Output\\n`);\n242:   sections.push(\"```\");\n243:   sections.push(mergeError);\n244:   sections.push(\"```\");\n245: \n246:   sections.push(`\\n## Feature Description\\n`);\n247:   sections.push(feature.description.trim());\n248: \n249:   sections.push(`\\n## Your Task\\n`);\n250:   sections.push(\"1. Find all files with conflict markers (`<<<<<<<`, `=======`, `>>>>>>>`)\");\n251:   sections.push(\"2. Resolve each conflict by combining both sides intelligently:\");\n252:   sections.push(`   - The \\`HEAD\\` side is the feature's work (keep this intent)`);\n253:   sections.push(`   - The \\`${baseBranch}\\` side is upstream changes (integrate these)`);\n254:   sections.push(\"3. Remove ALL conflict markers — no `<<<<<<<`, `=======`, or `>>>>>>>` should remain\");\n255:   sections.push(\"4. Run the build to verify everything compiles:\");\n256:   sections.push(\"   ```bash\");\n257:   sections.push(`   ${config.build.command}`);\n258:   sections.push(\"   ```\");\n259:   sections.push(\"5. If the build fails, fix the errors\");\n260:   sections.push(\"6. Stage all resolved files and commit the merge:\");\n261:   sections.push(\"   ```bash\");\n262:   sections.push(\"   git add -A\");\n263:   sections.push('   git commit --no-edit');\n264:   sections.push(\"   ```\");\n265: \n266:   sections.push(`\\n## Rules\\n`);\n267:   sections.push(\"- Do NOT abort the merge (`git merge --abort`)\");\n268:   sections.push(\"- Do NOT create new branches or rebase\");\n269:   sections.push(\"- Do NOT push to remote\");\n270:   sections.push(`- Do NOT modify \\`${config.tasksDir}\\``);\n271:   sections.push(\"- Keep BOTH the feature's changes and the upstream changes where possible\");\n272:   sections.push(\"- If in doubt, prefer the feature's implementation but ensure upstream additions are not lost\");\n273: \n274:   return sections.join(\"\\n\");\n275: }\n276: \n277: // ---------------------------------------------------------------------------\n278: // Subtask Formatting\n279: // ---------------------------------------------------------------------------\n280: \n281: function formatSubtask(\n282:   subtask: Subtask,\n283:   index: number,\n284:   depth: number\n285: ): string {\n286:   const indent = \"  \".repeat(depth);\n287:   const lines: string[] = [];\n288: \n289:   lines.push(\n290:     `${indent}${index}. **${subtask.title}** (\\`${subtask.id}\\`, ${formatDuration(parseDurationMinutes(subtask.effort))})`\n291:   );\n292:   lines.push(`${indent}   ${subtask.description.trim()}`);\n293: \n294:   if (subtask.constraints.length > 0) {\n295:     for (const c of subtask.constraints) {\n296:       lines.push(`${indent}   - Constraint: ${c}`);\n297:     }\n298:   }\n299:   if (subtask.forbidden.length > 0) {\n300:     for (const f of subtask.forbidden) {\n301:       lines.push(`${indent}   - Forbidden: ${f}`);\n302:     }\n303:   }\n304:   if (subtask.references.length > 0) {\n305:     lines.push(\n306:       `${indent}   - Files: ${subtask.references.map((r) => `\\`${r}\\``).join(\", \")}`\n307:     );\n308:   }\n309:   if (subtask.depends_on.length > 0) {\n310:     lines.push(\n311:       `${indent}   - Depends on: ${subtask.depends_on.map((d) => `\\`${d}\\``).join(\", \")}`\n312:     );\n313:   }\n314: \n315:   // Nested subtasks\n316:   if (subtask.subtasks.length > 0) {\n317:     for (let i = 0; i < subtask.subtasks.length; i++) {\n318:       lines.push(formatSubtask(subtask.subtasks[i], i + 1, depth + 1));\n319:     }\n320:   }\n321: \n322:   return lines.join(\"\\n\");\n323: }\n\n(End of file - total 323 lines)\n</content>","title":"src/lib/prompt.ts","metadata":{"preview":"/**\n * prompt.ts — Generate agent prompts from feature specs.\n *\n * Responsibilities:\n *   - Transform a Feature into a structured prompt for the agent\n *   - Include feature spec, subtasks, constraints, forbidden items, references\n *   - Generate the build command and success criteria\n *   - All project-specific values come from config (no hardcoded Astro references)\n */\n\nimport type { Feature, Subtask } from \"./tasks.js\";\nimport { formatDuration, parseDurationMinutes } from \"./tasks.js\";\nimport type { WomboConfig } from \"../config.js\";\nimport { isPortlessAvailable, portlessUrl } from \"./portless.js\";\n\n// ---------------------------------------------------------------------------\n// Prompt Generation\n// ---------------------------------------------------------------------------\n\n/**","truncated":false,"loaded":[]},"time":{"start":1773439923333,"end":1773439923336}}}}
{"type":"tool_use","timestamp":1773439923898,"sessionID":"ses_316be8c08ffeZXbNAgwvZBSoRI","part":{"id":"prt_ce941b486001XbVf2xdI6sP4eL","sessionID":"ses_316be8c08ffeZXbNAgwvZBSoRI","messageID":"msg_ce941a1b0001XzWF5FzYEsI7m1","type":"tool","callID":"toolu_vrtx_01A7DFAcriRmyLJjT1PPa9Up","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/dynamic-agent-types/src/commands/launch.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/dynamic-agent-types/src/commands/launch.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * launch.ts — Launch a wave of agents.\n3:  *\n4:  * Usage: woco launch [selection options] [launch options]\n5:  *\n6:  * This is the primary entry point for starting a new wave. It selects features\n7:  * from the features file, creates a wave state, sets up worktrees, and launches\n8:  * agent processes (either headless or interactive via dmux/tmux).\n9:  *\n10:  * IMPORTANT: This file also exports shared helper functions that are reused\n11:  * by resume.ts and other commands:\n12:  *   - launchSingleHeadless\n13:  *   - handleBuildVerification\n14:  *   - handleRetry\n15:  *   - launchNextQueued\n16:  */\n17: \n18: import { execSync } from \"node:child_process\";\n19: import { existsSync, readFileSync } from \"node:fs\";\n20: import { resolve } from \"node:path\";\n21: import type { WomboConfig } from \"../config.js\";\n22: import type { Feature, SelectionOptions, Priority, Difficulty } from \"../lib/tasks.js\";\n23: import { loadFeatures, selectFeatures, parseDurationMinutes, saveFeatures } from \"../lib/tasks.js\";\n24: import {\n25:   loadState,\n26:   saveState,\n27:   createWaveState,\n28:   createAgentState,\n29:   updateAgent,\n30:   activeAgents,\n31:   queuedAgents,\n32:   readyToLaunchAgents,\n33:   areAgentDepsReady,\n34:   cancelDownstream,\n35:   isWaveComplete,\n36:   type WaveState,\n37:   type AgentState,\n38:   type SerializedSchedulePlan,\n39: } from \"../lib/state.js\";\n40: import {\n41:   createWorktree,\n42:   installDeps,\n43:   featureBranchName,\n44:   worktreePath,\n45:   worktreeReady,\n46:   branchHasChanges,\n47:   branchExists,\n48:   removeWorktree,\n49:   log as wtLog,\n50: } from \"../lib/worktree.js\";\n51: import { generatePrompt, generateConflictResolutionPrompt } from \"../lib/prompt.js\";\n52: import {\n53:   launchHeadless,\n54:   retryHeadless,\n55:   launchInteractive,\n56:   retryInteractive,\n57:   launchConflictResolver,\n58:   isProcessRunning,\n59:   getMultiplexerName,\n60: } from \"../lib/launcher.js\";\n61: import { ProcessMonitor } from \"../lib/monitor.js\";\n62: import { runBuild, runFullVerification, type FullVerificationOptions } from \"../lib/verifier.js\";\n63: import { mergeBranch, mergeBaseIntoFeature, pushBaseBranch, canMerge, enqueueMerge } from \"../lib/merger.js\";\n64: import {\n65:   printDashboard,\n66:   printFeatureSelection,\n67:   printAgentUpdate,\n68: } from \"../lib/ui.js\";\n69: import { WomboTUI } from \"../lib/tui.js\";\n70: import { ensureAgentDefinition } from \"../lib/templates.js\";\n71: import {\n72:   buildDepGraph,\n73:   validateDepGraph,\n74:   buildSchedulePlan,\n75:   formatSchedulePlan,\n76:   getStreamForFeature,\n77:   type DepGraph,\n78:   type SchedulePlan,\n79: } from \"../lib/dependency-graph.js\";\n80: import { ensureProxyRunning, isPortlessAvailable, portlessUrl } from \"../lib/portless.js\";\n81: import { output, outputError, outputMessage, type OutputFormat } from \"../lib/output.js\";\n82: import { renderLaunchDryRun } from \"../lib/toon.js\";\n83: import {\n84:   detectMultiplexer,\n85:   muxAttachCommand,\n86:   muxListCommand,\n87: } from \"../lib/multiplexer.js\";\n88: import { exportWaveHistory } from \"../lib/history.js\";\n89: import {\n90:   prepareAgentDefinitions,\n91:   isSpecializedAgent,\n92:   writeAgentToWorktree,\n93:   type AgentResolution,\n94: } from \"../lib/agent-registry.js\";\n95: import { patchImportedAgent } from \"../lib/templates.js\";\n96: import {\n97:   tuiPreflightConfirm,\n98:   consolePreflightConfirm,\n99: } from \"../lib/preflight.js\";\n100: \n101: // ---------------------------------------------------------------------------\n102: // Constants\n103: // ---------------------------------------------------------------------------\n104: \n105: /**\n106:  * Delay (ms) between sequential agent launches to avoid SQLite race conditions.\n107:  * Each agent spawns its own process which runs DB migrations on startup.\n108:  * Launching them simultaneously causes `CREATE TABLE` collisions.\n109:  */\n110: const LAUNCH_STAGGER_MS = 500;\n111: \n112: // ---------------------------------------------------------------------------\n113: // Types\n114: // ---------------------------------------------------------------------------\n115: \n116: export interface LaunchCommandOptions {\n117:   projectRoot: string;\n118:   config: WomboConfig;\n119:   // Selection\n120:   topPriority?: number;\n121:   quickestWins?: number;\n122:   priority?: Priority;\n123:   difficulty?: Difficulty;\n124:   features?: string[];\n125:   allReady?: boolean;\n126:   // Launch\n127:   maxConcurrent: number;\n128:   model?: string;\n129:   interactive: boolean;\n130:   dryRun: boolean;\n131:   baseBranch: string;\n132:   maxRetries: number;\n133:   noTui: boolean;\n134:   autoPush: boolean;\n135:   // Agent selection\n136:   /** CLI override: use this local agent definition for all launched tasks */\n137:   agent?: string;\n138:   // Output\n139:   outputFmt?: OutputFormat;\n140: }\n141: \n142: // ---------------------------------------------------------------------------\n143: // Shared Helpers (exported for resume.ts and others)\n144: // ---------------------------------------------------------------------------\n145: \n146: /**\n147:  * Mark a feature as done in the features file after a successful merge.\n148:  * Updates status to \"done\", completion to 100, and sets ended_at.\n149:  *\n150:  * GUARD: Verifies that the feature branch has actually been merged into\n151:  * baseBranch before allowing the status change. This prevents callers\n152:  * from accidentally marking verified-but-unmerged features as done.\n153:  */\n154: export function markFeatureDone(\n155:   projectRoot: string,\n156:   featureId: string,\n157:   config: WomboConfig,\n158:   baseBranch: string\n159: ): void {\n160:   try {\n161:     // Verify the feature branch was actually merged into base\n162:     const branch = featureBranchName(featureId, config);\n163:     try {\n164:       execSync(`git merge-base --is-ancestor \"${branch}\" \"${baseBranch}\"`, {\n165:         cwd: projectRoot,\n166:         stdio: \"pipe\",\n167:       });\n168:     } catch {\n169:       // git merge-base --is-ancestor exits non-zero if NOT an ancestor\n170:       console.error(\n171:         `Warning: ${featureId} branch \"${branch}\" is not merged into \"${baseBranch}\" — refusing to mark as done`\n172:       );\n173:       return;\n174:     }\n175: \n176:     const data = loadFeatures(projectRoot, config);\n177:     const feature = data.tasks.find((f: Feature) => f.id === featureId);\n178:     if (feature && feature.status !== \"done\") {\n179:       feature.status = \"done\";\n180:       feature.completion = 100;\n181:       feature.ended_at = new Date().toISOString();\n182:       saveFeatures(projectRoot, config, data);\n183:     }\n184:   } catch (err: any) {\n185:     // Non-fatal — log but don't crash the wave\n186:     console.error(`Warning: failed to update feature status for ${featureId}: ${err.message}`);\n187:   }\n188: }\n189: \n190: /**\n191:  * Launch a single agent in headless mode.\n192:  * Sets up worktree, installs deps, generates prompt, launches agent process.\n193:  * If agentResolutions is provided and contains a specialized agent for this\n194:  * feature, the patched agent definition is written into the worktree.\n195:  */\n196: export async function launchSingleHeadless(\n197:   projectRoot: string,\n198:   state: WaveState,\n199:   agent: AgentState,\n200:   feature: Feature,\n201:   monitor: ProcessMonitor,\n202:   config: WomboConfig,\n203:   model?: string,\n204:   agentResolutions?: Map<string, AgentResolution>\n205: ): Promise<void> {\n206:   updateAgent(state, agent.feature_id, {\n207:     status: \"installing\",\n208:     started_at: new Date().toISOString(),\n209:     activity: \"setting up worktree...\",\n210:   });\n211:   saveState(projectRoot, state);\n212: \n213:   try {\n214:     // Check if this agent is reusing a chain predecessor's worktree\n215:     const isChainReuse = agent.depends_on.some((depId) => {\n216:       const depAgent = state.agents.find((a) => a.feature_id === depId);\n217:       return depAgent && depAgent.worktree === agent.worktree;\n218:     });\n219: \n220:     if (isChainReuse && worktreeReady(agent.worktree)) {\n221:       // Chain worktree reuse: the worktree already exists from a predecessor.\n222:       // Create a new branch for this feature and switch the worktree to it.\n223:       wtLog(agent.feature_id, \"reusing chain worktree — switching branch...\");\n224:       updateAgent(state, agent.feature_id, { activity: \"switching branch (chain reuse)...\" });\n225: \n226:       try {\n227:         // Create the new feature branch from base (in the worktree)\n228:         execSync(`git checkout -B \"${agent.branch}\" \"${state.base_branch}\"`, {\n229:           cwd: agent.worktree,\n230:           stdio: \"pipe\",\n231:         });\n232:         wtLog(agent.feature_id, `switched to branch ${agent.branch}`);\n233:       } catch (branchErr: any) {\n234:         wtLog(agent.feature_id, `branch switch failed: ${branchErr.message}`);\n235:         // Fall through to normal worktree creation\n236:         await createWorktree(projectRoot, feature.id, state.base_branch, config);\n237:       }\n238:     } else if (worktreeReady(agent.worktree)) {\n239:       // Skip worktree setup if already ready (resume case)\n240:       wtLog(agent.feature_id, \"worktree already exists, skipping setup\");\n241:     } else {\n242:       // Create worktree (async — doesn't block other agents)\n243:       await createWorktree(projectRoot, feature.id, state.base_branch, config);\n244: \n245:       // Install dependencies (async)\n246:       updateAgent(state, agent.feature_id, { activity: \"installing deps...\" });\n247:       await installDeps(agent.worktree, feature.id, config);\n248:     }\n249: \n250:     // Generate prompt\n251:     const prompt = generatePrompt(feature, state.base_branch, config);\n252: \n253:     // Write specialized agent to worktree if applicable\n254:     const resolution = agentResolutions?.get(feature.id);\n255:     const agentName = agent.agent_name ?? undefined;\n256:     if (resolution && isSpecializedAgent(resolution)) {\n257:       try {\n258:         const patchedContent = patchImportedAgent(resolution.rawContent, config, projectRoot);\n259:         writeAgentToWorktree(agent.worktree, resolution.name, patchedContent);\n260:         wtLog(agent.feature_id, `wrote specialized agent: ${resolution.name}`);\n261:       } catch (err: any) {\n262:         wtLog(agent.feature_id, `WARN: failed to write specialized agent, using generalist: ${err.message}`);\n263:       }\n264:     }\n265: \n266:     // Launch agent\n267:     wtLog(agent.feature_id, \"launching agent...\");\n268:     const result = launchHeadless({\n269:       worktreePath: agent.worktree,\n270:       featureId: feature.id,\n271:       prompt,\n272:       model,\n273:       config,\n274:       agentName,\n275:     });\n276: \n277:     updateAgent(state, agent.feature_id, {\n278:       status: \"running\",\n279:       pid: result.pid,\n280:       activity: \"starting...\",\n281:     });\n282:     saveState(projectRoot, state);\n283: \n284:     monitor.addProcess(feature.id, result.process);\n285:     wtLog(agent.feature_id, `running (PID: ${result.pid})`);\n286:   } catch (err: any) {\n287:     updateAgent(state, agent.feature_id, {\n288:       status: \"failed\",\n289:       error: err.message,\n290:       activity: null,\n291:       completed_at: new Date().toISOString(),\n292:     });\n293:     saveState(projectRoot, state);\n294:     wtLog(agent.feature_id, `SETUP FAILED: ${err.message.split(\"\\n\")[0]}`);\n295:   }\n296: }\n297: \n298: /**\n299:  * Handle build verification after agent completion.\n300:  * Runs build, auto-merges on pass, retries on failure if retries remain.\n301:  *\n302:  * ASYNC — runs build and merge without blocking the event loop.\n303:  */\n304: export async function handleBuildVerification(\n305:   projectRoot: string,\n306:   state: WaveState,\n307:   agent: AgentState,\n308:   feature: Feature,\n309:   config: WomboConfig,\n310:   model?: string,\n311:   monitor?: ProcessMonitor,\n312:   tddOpts?: FullVerificationOptions\n313: ): Promise<void> {\n314:   try {\n315:     printAgentUpdate(agent, \"verifying build...\");\n316: \n317:     // Use full verification pipeline (build + optional browser tests + optional TDD)\n318:     const fullResult = await runFullVerification(agent.worktree, agent.feature_id, config, tddOpts);\n319:     const buildResult = fullResult.build;\n320: \n321:     // Report browser test status if they ran\n322:     if (fullResult.browser.ran && fullResult.browser.browserResult) {\n323:       const br = fullResult.browser.browserResult;\n324:       printAgentUpdate(\n325:         agent,\n326:         `BROWSER: ${br.summary} (${Math.round(br.totalDurationMs / 1000)}s)`\n327:       );\n328:     } else if (fullResult.browser.skipReason && config.browser.enabled) {\n329:       printAgentUpdate(agent, `BROWSER: skipped — ${fullResult.browser.skipReason}`);\n330:     }\n331: \n332:     // Report TDD verification status if it ran\n333:     if (fullResult.tdd.ran) {\n334:       const tdd = fullResult.tdd;\n335:       const tddIcon = tdd.passed ? \"✓\" : \"✗\";\n336:       printAgentUpdate(agent, `TDD: ${tddIcon} ${tdd.summary}`);\n337:       if (tdd.hasWarnings) {\n338:         printAgentUpdate(agent, `TDD: ⚠ Missing tests detected (non-blocking)`);\n339:       }\n340:     } else if (fullResult.tdd.skipReason && config.tdd?.enabled) {\n341:       printAgentUpdate(agent, `TDD: skipped — ${fullResult.tdd.skipReason}`);\n342:     }\n343: \n344:     if (fullResult.overallPassed) {\n345:       updateAgent(state, agent.feature_id, {\n346:         status: \"verified\",\n347:         build_passed: true,\n348:         build_output: null,\n349:       });\n350:       saveState(projectRoot, state);\n351:       printAgentUpdate(agent, `BUILD PASSED (${Math.round(buildResult.durationMs / 1000)}s)`);\n352: \n353:       // Auto-merge: attempt merge + conflict resolution\n354:       await attemptMerge(projectRoot, state, agent, feature, config, model);\n355:     } else {\n356:       const errorSummary = fullResult.combinedErrorSummary;\n357: \n358:       if (agent.retries < agent.max_retries) {\n359:         updateAgent(state, agent.feature_id, {\n360:           status: \"retry\",\n361:           retries: agent.retries + 1,\n362:           build_passed: false,\n363:           build_output: errorSummary,\n364:         });\n365:         saveState(projectRoot, state);\n366:         printAgentUpdate(\n367:           agent,\n368:           `VERIFICATION FAILED — retrying (${agent.retries}/${agent.max_retries})`\n369:         );\n370: \n371:         // Retry with error details\n372:         if (agent.session_id) {\n373:           const retryResult = retryHeadless({\n374:             worktreePath: agent.worktree,\n375:             featureId: agent.feature_id,\n376:             sessionId: agent.session_id,\n377:             buildErrors: errorSummary,\n378:             model,\n379:             config,\n380:           });\n381: \n382:           updateAgent(state, agent.feature_id, {\n383:             status: \"running\",\n384:             pid: retryResult.pid,\n385:           });\n386:           saveState(projectRoot, state);\n387: \n388:           // Add retry process to monitor so events are tracked\n389:           if (monitor) {\n390:             monitor.addProcess(agent.feature_id, retryResult.process);\n391:           }\n392:         } else {\n393:           // Agent has no session — reset to queued for a fresh launch\n394:           wtLog(agent.feature_id, `no session — resetting to queued for fresh launch (retry ${agent.retries}/${agent.max_retries})`);\n395:           updateAgent(state, agent.feature_id, {\n396:             status: \"queued\",\n397:             error: null,\n398:             activity: \"waiting for relaunch...\",\n399:           });\n400:           saveState(projectRoot, state);\n401:         }\n402:       } else {\n403:         updateAgent(state, agent.feature_id, {\n404:           status: \"failed\",\n405:           build_passed: false,\n406:           build_output: errorSummary,\n407:           error: `Verification failed after ${agent.max_retries} retries`,\n408:           completed_at: new Date().toISOString(),\n409:         });\n410:         saveState(projectRoot, state);\n411:         printAgentUpdate(agent, \"VERIFICATION FAILED — max retries reached\");\n412: \n413:         // Cascade failure to downstream agents\n414:         const cancelled = cancelDownstream(state, agent.feature_id);\n415:         if (cancelled.length > 0) {\n416:           printAgentUpdate(agent, `downstream cancelled: ${cancelled.join(\", \")}`);\n417:           saveState(projectRoot, state);\n418:         }\n419:       }\n420:     }\n421:   } catch (err: any) {\n422:     // Catch-all — never let build verification crash the process\n423:     printAgentUpdate(agent, `VERIFY ERROR: ${err.message?.slice(0, 100)}`);\n424:     updateAgent(state, agent.feature_id, {\n425:       status: \"failed\",\n426:       error: `Build verification error: ${err.message}`,\n427:       completed_at: new Date().toISOString(),\n428:     });\n429:     saveState(projectRoot, state);\n430:   }\n431: }\n432: \n433: /**\n434:  * Attempt to merge a verified agent's branch into the base branch.\n435:  *\n436:  * Handles conflict detection, base-into-feature merge, and resolver agent\n437:  * launch. Extracted from handleBuildVerification so it can be called\n438:  * independently (e.g., from resume's sequential merge phase).\n439:  *\n440:  * All merge operations are serialized via enqueueMerge() to prevent\n441:  * concurrent checkout races on the project root.\n442:  */\n443: export async function attemptMerge(\n444:   projectRoot: string,\n445:   state: WaveState,\n446:   agent: AgentState,\n447:   feature: Feature,\n448:   config: WomboConfig,\n449:   model?: string,\n450: ): Promise<void> {\n451:   return enqueueMerge(async () => {\n452:     printAgentUpdate(agent, \"auto-merging...\");\n453:     try {\n454:       // Pre-flight check: detect conflicts before attempting the real merge.\n455:       // This avoids the expensive merge-then-abort dance for known conflicts.\n456:       const preCheck = await canMerge(projectRoot, agent.branch, state.base_branch);\n457:       if (!preCheck.canMerge) {\n458:         printAgentUpdate(agent, `conflict detected (pre-flight) — attempting resolution...`);\n459:         await handleMergeConflict(\n460:           projectRoot, state, agent, feature, config, model,\n461:           preCheck.reason\n462:         );\n463:         return;\n464:       }\n465: \n466:       const mergeResult = await mergeBranch(projectRoot, agent.branch, state.base_branch, config);\n467: \n468:       if (mergeResult.success) {\n469:         handleMergeSuccess(projectRoot, state, agent, config, mergeResult.commitHash);\n470:         return;\n471:       }\n472: \n473:       // Merge failed despite clean pre-flight — race with another merge or\n474:       // a git state issue. Fall through to conflict resolution.\n475:       printAgentUpdate(agent, `MERGE CONFLICT — attempting resolution...`);\n476:       await handleMergeConflict(\n477:         projectRoot, state, agent, feature, config, model,\n478:         mergeResult.error ?? \"Unknown merge error\"\n479:       );\n480:     } catch (mergeErr: any) {\n481:       // Unexpected exception — stay in \"verified\" (retryable) but record the\n482:       // error so the user can see what went wrong instead of silent stalling.\n483:       printAgentUpdate(agent, `AUTO-MERGE ERROR: ${mergeErr.message?.slice(0, 100)}`);\n484:       updateAgent(state, agent.feature_id, {\n485:         error: `Auto-merge error: ${mergeErr.message}`,\n486:       });\n487:       saveState(projectRoot, state);\n488:     }\n489:   });\n490: }\n491: \n492: /**\n493:  * Handle a successful merge: update state, mark feature done, clean up.\n494:  */\n495: function handleMergeSuccess(\n496:   projectRoot: string,\n497:   state: WaveState,\n498:   agent: AgentState,\n499:   config: WomboConfig,\n500:   commitHash: string | null,\n501:   label = \"MERGED\",\n502: ): void {\n503:   updateAgent(state, agent.feature_id, {\n504:     status: \"merged\",\n505:     completed_at: new Date().toISOString(),\n506:   });\n507:   saveState(projectRoot, state);\n508:   printAgentUpdate(agent, `${label} (${commitHash?.slice(0, 7)})`);\n509: \n510:   markFeatureDone(projectRoot, agent.feature_id, config, state.base_branch);\n511: \n512:   // Clean up worktree — but preserve it if downstream agents in the same\n513:   // chain share this worktree.\n514:   const hasChainSuccessor = agent.depended_on_by.some((depId) => {\n515:     const depAgent = state.agents.find((a) => a.feature_id === depId);\n516:     return depAgent && depAgent.worktree === agent.worktree;\n517:   });\n518: \n519:   if (hasChainSuccessor) {\n520:     printAgentUpdate(agent, \"worktree preserved for chain successor\");\n521:   } else {\n522:     try {\n523:       removeWorktree(projectRoot, agent.worktree, true);\n524:       printAgentUpdate(agent, \"worktree and branch removed\");\n525:     } catch (err: any) {\n526:       // Log the failure so it's visible — stale worktrees waste disk space\n527:       printAgentUpdate(agent, `WARN: worktree cleanup failed: ${err.message?.split(\"\\n\")[0]}`);\n528:     }\n529:   }\n530: }\n531: \n532: /**\n533:  * Handle a merge conflict: merge base into feature, then either retry the\n534:  * direct merge (if base merged cleanly) or launch a resolver agent.\n535:  *\n536:  * All failure paths record the error on the agent (which stays \"verified\")\n537:  * so the merge can be retried without silently stalling.\n538:  */\n539: async function handleMergeConflict(\n540:   projectRoot: string,\n541:   state: WaveState,\n542:   agent: AgentState,\n543:   feature: Feature,\n544:   config: WomboConfig,\n545:   model: string | undefined,\n546:   mergeError: string,\n547: ): Promise<void> {\n548:   try {\n549:     // Merge base INTO the feature worktree to create conflict markers\n550:     const conflictResult = await mergeBaseIntoFeature(\n551:       agent.worktree,\n552:       state.base_branch,\n553:       config\n554:     );\n555: \n556:     if (conflictResult.error && !conflictResult.conflicting) {\n557:       // Setup itself failed — stay as \"verified\" (retryable) with error\n558:       printAgentUpdate(agent, `CONFLICT SETUP FAILED: ${conflictResult.error.slice(0, 100)}`);\n559:       updateAgent(state, agent.feature_id, {\n560:         error: `Conflict setup failed: ${conflictResult.error}`,\n561:       });\n562:       saveState(projectRoot, state);\n563:       return;\n564:     }\n565: \n566:     if (!conflictResult.conflicting) {\n567:       // Base merged cleanly into feature — retry merge into base.\n568:       printAgentUpdate(agent, \"base merged cleanly into feature — retrying merge...\");\n569:       const retryMerge = await mergeBranch(projectRoot, agent.branch, state.base_branch, config);\n570:       if (retryMerge.success) {\n571:         handleMergeSuccess(projectRoot, state, agent, config, retryMerge.commitHash, \"MERGED after rebase\");\n572:         return;\n573:       }\n574: \n575:       // Retry still failed — need conflict resolution.\n576:       // Merge base into feature again to get conflict files for the resolver.\n577:       printAgentUpdate(agent, `retry merge still failed — launching resolver agent...`);\n578:       const secondConflict = await mergeBaseIntoFeature(\n579:         agent.worktree,\n580:         state.base_branch,\n581:         config\n582:       );\n583: \n584:       const conflictFiles = secondConflict.conflicting\n585:         ? secondConflict.files\n586:         : [\"(unknown — merge direction mismatch)\"];\n587: \n588:       await launchResolverAndRetryMerge(\n589:         projectRoot, state, agent, feature, config, model,\n590:         retryMerge.error ?? mergeError, conflictFiles\n591:       );\n592:       return;\n593:     }\n594: \n595:     // There are real conflicts — launch a resolver agent\n596:     printAgentUpdate(\n597:       agent,\n598:       `${conflictResult.files.length} conflicting file(s): ${conflictResult.files.join(\", \")}`\n599:     );\n600: \n601:     await launchResolverAndRetryMerge(\n602:       projectRoot, state, agent, feature, config, model,\n603:       mergeError, conflictResult.files\n604:     );\n605:   } catch (conflictErr: any) {\n606:     // Unexpected error during conflict handling — stay \"verified\" with error\n607:     printAgentUpdate(agent, `CONFLICT RESOLUTION ERROR: ${conflictErr.message?.slice(0, 100)}`);\n608:     updateAgent(state, agent.feature_id, {\n609:       error: `Conflict resolution error: ${conflictErr.message}`,\n610:     });\n611:     saveState(projectRoot, state);\n612:   }\n613: }\n614: \n615: /**\n616:  * Launch a conflict resolver agent, wait for it to finish, re-verify build,\n617:  * and retry the merge. Supports configurable retry attempts (defaults to 1,\n618:  * up to config.defaults.maxRetries + 1).\n619:  *\n620:  * The resolver is re-launched with updated conflict state on each attempt,\n621:  * so it sees the current conflict markers, not stale ones.\n622:  */\n623: async function launchResolverAndRetryMerge(\n624:   projectRoot: string,\n625:   state: WaveState,\n626:   agent: AgentState,\n627:   feature: Feature,\n628:   config: WomboConfig,\n629:   model: string | undefined,\n630:   mergeError: string,\n631:   conflictFiles: string[]\n632: ): Promise<void> {\n633:   const maxResolverAttempts = Math.max(1, (config.defaults.maxRetries ?? 0) + 1);\n634: \n635:   for (let attempt = 1; attempt <= maxResolverAttempts; attempt++) {\n636:     const conflictPrompt = generateConflictResolutionPrompt(\n637:       feature,\n638:       state.base_branch,\n639:       mergeError,\n640:       config\n641:     );\n642: \n643:     const attemptLabel = maxResolverAttempts > 1\n644:       ? ` (attempt ${attempt}/${maxResolverAttempts})`\n645:       : \"\";\n646: \n647:     updateAgent(state, agent.feature_id, {\n648:       status: \"resolving_conflict\",\n649:       activity: `resolving ${conflictFiles.length} conflict(s)${attemptLabel}...`,\n650:     });\n651:     saveState(projectRoot, state);\n652: \n653:     const resolverResult = launchConflictResolver({\n654:       worktreePath: agent.worktree,\n655:       featureId: agent.feature_id,\n656:       prompt: conflictPrompt,\n657:       model,\n658:       config,\n659:     });\n660: \n661:     updateAgent(state, agent.feature_id, {\n662:       pid: resolverResult.pid,\n663:     });\n664:     saveState(projectRoot, state);\n665: \n666:     // Wait for the resolver process to complete, then re-verify and retry merge.\n667:     // We intentionally do NOT add the resolver to the ProcessMonitor because\n668:     // the monitor's onComplete callback would trigger handleBuildVerification\n669:     // again, causing infinite recursion. Instead we await the process directly.\n670:     const resolverExitCode = await new Promise<number | null>((resolve) => {\n671:       resolverResult.process.on(\"exit\", (code) => resolve(code));\n672:       resolverResult.process.on(\"error\", () => resolve(null));\n673:     });\n674: \n675:     printAgentUpdate(\n676:       agent,\n677:       `conflict resolver exited (code ${resolverExitCode})${attemptLabel} — re-verifying build...`\n678:     );\n679: \n680:     // Re-verify build after conflict resolution\n681:     const rebuildResult = await runBuild(agent.worktree, config);\n682: \n683:     if (!rebuildResult.passed) {\n684:       if (attempt < maxResolverAttempts) {\n685:         printAgentUpdate(agent, `POST-CONFLICT BUILD FAILED${attemptLabel} — retrying resolver...`);\n686:         continue; // Try again with a fresh resolver\n687:       }\n688:       printAgentUpdate(agent, `POST-CONFLICT BUILD FAILED (all ${maxResolverAttempts} attempts exhausted)`);\n689:       updateAgent(state, agent.feature_id, {\n690:         status: \"failed\",\n691:         build_passed: false,\n692:         build_output: rebuildResult.errorSummary,\n693:         error: \"Build failed after conflict resolution\",\n694:         completed_at: new Date().toISOString(),\n695:       });\n696:       saveState(projectRoot, state);\n697:       cancelDownstream(state, agent.feature_id);\n698:       saveState(projectRoot, state);\n699:       return;\n700:     }\n701: \n702:     printAgentUpdate(agent, \"post-conflict build passed — retrying merge...\");\n703: \n704:     const retryMerge = await mergeBranch(\n705:       projectRoot,\n706:       agent.branch,\n707:       state.base_branch,\n708:       config\n709:     );\n710: \n711:     if (retryMerge.success) {\n712:       handleMergeSuccess(\n713:         projectRoot, state, agent, config,\n714:         retryMerge.commitHash, \"MERGED after conflict resolution\"\n715:       );\n716:       return;\n717:     }\n718: \n719:     // Merge still failed after resolver. If we have attempts left, re-merge\n720:     // base into feature to refresh conflict markers and try again.\n721:     if (attempt < maxResolverAttempts) {\n722:       printAgentUpdate(agent, `POST-CONFLICT MERGE FAILED${attemptLabel} — retrying resolver...`);\n723:       const refreshConflict = await mergeBaseIntoFeature(\n724:         agent.worktree,\n725:         state.base_branch,\n726:         config\n727:       );\n728:       conflictFiles = refreshConflict.conflicting\n729:         ? refreshConflict.files\n730:         : conflictFiles;\n731:       mergeError = retryMerge.error ?? mergeError;\n732:       continue;\n733:     }\n734: \n735:     // All attempts exhausted\n736:     printAgentUpdate(agent, `POST-CONFLICT MERGE FAILED (all ${maxResolverAttempts} attempts exhausted): ${retryMerge.error}`);\n737:     updateAgent(state, agent.feature_id, {\n738:       status: \"failed\",\n739:       error: `Merge still failed after ${maxResolverAttempts} conflict resolution attempt(s): ${retryMerge.error}`,\n740:       completed_at: new Date().toISOString(),\n741:     });\n742:     saveState(projectRoot, state);\n743:     cancelDownstream(state, agent.feature_id);\n744:     saveState(projectRoot, state);\n745:     return;\n746:   }\n747: }\n748: \n749: /**\n750:  * Handle retry of a failed agent (error-based, not build-based).\n751:  *\n752:  * If the agent has a session_id, resumes the existing session with error context.\n753:  * If the agent crashed before establishing a session (session_id is null),\n754:  * resets it to \"queued\" so it gets relaunched from scratch on the next\n755:  * launchAllReady() cycle. This prevents the \"stuck retry\" state where an\n756:  * agent sits in \"retry\" forever with no process running.\n757:  */\n758: export function handleRetry(\n759:   projectRoot: string,\n760:   state: WaveState,\n761:   agent: AgentState,\n762:   monitor: ProcessMonitor,\n763:   config: WomboConfig,\n764:   model?: string\n765: ): void {\n766:   if (!agent.session_id) {\n767:     // Agent crashed before establishing a session (e.g. SQLite race condition).\n768:     // Reset to queued so it gets a fresh launch on the next cycle.\n769:     wtLog(agent.feature_id, `no session — resetting to queued for fresh launch (retry ${agent.retries}/${agent.max_retries})`);\n770:     updateAgent(state, agent.feature_id, {\n771:       status: \"queued\",\n772:       error: null,\n773:       activity: \"waiting for relaunch...\",\n774:     });\n775:     saveState(projectRoot, state);\n776:     return;\n777:   }\n778: \n779:   if (!agent.error) return;\n780: \n781:   const retryResult = retryHeadless({\n782:     worktreePath: agent.worktree,\n783:     featureId: agent.feature_id,\n784:     sessionId: agent.session_id,\n785:     buildErrors: agent.error,\n786:     model,\n787:     config,\n788:   });\n789: \n790:   updateAgent(state, agent.feature_id, {\n791:     status: \"running\",\n792:     pid: retryResult.pid,\n793:   });\n794:   saveState(projectRoot, state);\n795: \n796:   monitor.addProcess(agent.feature_id, retryResult.process);\n797: }\n798: \n799: /**\n800:  * Launch the next queued agent if capacity allows.\n801:  * Dependency-aware: only launches agents whose dependencies are satisfied.\n802:  */\n803: export async function launchNextQueued(\n804:   projectRoot: string,\n805:   state: WaveState,\n806:   featureMap: Map<string, Feature>,\n807:   monitor: ProcessMonitor,\n808:   config: WomboConfig,\n809:   model?: string,\n810:   agentResolutions?: Map<string, AgentResolution>\n811: ): Promise<void> {\n812:   const active = activeAgents(state);\n813:   const ready = readyToLaunchAgents(state);\n814: \n815:   if (active.length < state.max_concurrent && ready.length > 0) {\n816:     const next = ready[0];\n817:     const feature = featureMap.get(next.feature_id);\n818:     if (feature) {\n819:       await launchSingleHeadless(projectRoot, state, next, feature, monitor, config, model, agentResolutions);\n820:     }\n821:   }\n822: }\n823: \n824: /**\n825:  * Launch ALL ready agents up to capacity.\n826:  * After a dependency completes, multiple downstream agents may become unblocked.\n827:  * This launches as many as capacity allows, not just one.\n828:  *\n829:  * Launches are staggered to avoid SQLite race conditions.\n830:  *\n831:  * Also logs merge gate events when diamond-dependency features become unblocked.\n832:  */\n833: export async function launchAllReady(\n834:   projectRoot: string,\n835:   state: WaveState,\n836:   featureMap: Map<string, Feature>,\n837:   monitor: ProcessMonitor,\n838:   config: WomboConfig,\n839:   model?: string,\n840:   agentResolutions?: Map<string, AgentResolution>\n841: ): Promise<void> {\n842:   const active = activeAgents(state);\n843:   const ready = readyToLaunchAgents(state);\n844:   const available = state.max_concurrent - active.length;\n845: \n846:   if (available <= 0 || ready.length === 0) return;\n847: \n848:   const toLaunch = ready.slice(0, available);\n849:   for (let i = 0; i < toLaunch.length; i++) {\n850:     const next = toLaunch[i];\n851:     const feature = featureMap.get(next.feature_id);\n852:     if (!feature) continue;\n853: \n854:     // Log merge gate opening for diamond dependencies\n855:     if (next.depends_on.length > 1 && state.schedule_plan) {\n856:       const isMergeGate = state.schedule_plan.merge_gates.some(\n857:         (g) => g.feature_id === next.feature_id\n858:       );\n859:       if (isMergeGate) {\n860:         wtLog(\n861:           next.feature_id,\n862:           `merge gate opened — all ${next.depends_on.length} dependencies satisfied`\n863:         );\n864:       }\n865:     }\n866: \n867:     await launchSingleHeadless(projectRoot, state, next, feature, monitor, config, model, agentResolutions);\n868:     // Stagger between launches to avoid SQLite race conditions\n869:     if (i < toLaunch.length - 1) {\n870:       await new Promise((r) => setTimeout(r, LAUNCH_STAGGER_MS));\n871:     }\n872:   }\n873: }\n874: \n875: // ---------------------------------------------------------------------------\n876: // Post-mortem: dump failed agent logs\n877: // ---------------------------------------------------------------------------\n878: \n879: /**\n880:  * Print full log contents for every failed agent so the user can diagnose\n881:  * issues after the wave finishes. Handles missing log files gracefully.\n882:  */\n883: export function dumpFailedAgentLogs(projectRoot: string, state: WaveState): void {\n884:   const failed = state.agents.filter((a) => a.status === \"failed\");\n885:   if (failed.length === 0) return;\n886: \n887:   const logDir = resolve(projectRoot, \".wombo-combo/logs\");\n888: \n889:   console.log(\n890:     `\\n${\"=\".repeat(72)}\\n` +\n891:     `  FAILED AGENT LOGS (${failed.length} agent${failed.length > 1 ? \"s\" : \"\"})\\n` +\n892:     `${\"=\".repeat(72)}`\n893:   );\n894: \n895:   for (const agent of failed) {\n896:     const logFile = resolve(logDir, `${agent.feature_id}.log`);\n897: \n898:     console.log(\n899:       `\\n${\"─\".repeat(72)}\\n` +\n900:       `  Feature: ${agent.feature_id}\\n` +\n901:       (agent.error ? `  Error:   ${agent.error}\\n` : \"\") +\n902:       `${\"─\".repeat(72)}`\n903:     );\n904: \n905:     if (!existsSync(logFile)) {\n906:       console.log(\"  (no log file found)\");\n907:       continue;\n908:     }\n909: \n910:     try {\n911:       const contents = readFileSync(logFile, \"utf-8\");\n912:       if (contents.trim().length === 0) {\n913:         console.log(\"  (log file is empty)\");\n914:       } else {\n915:         console.log(contents);\n916:       }\n917:     } catch (err: any) {\n918:       console.log(`  (error reading log: ${err.message})`);\n919:     }\n920:   }\n921: \n922:   console.log(`\\n${\"=\".repeat(72)}\\n`);\n923: }\n924: \n925: // ---------------------------------------------------------------------------\n926: // Headless Wave Launch\n927: // ---------------------------------------------------------------------------\n928: \n929: async function launchWaveHeadless(\n930:   projectRoot: string,\n931:   state: WaveState,\n932:   features: Feature[],\n933:   opts: LaunchCommandOptions,\n934:   agentResolutions?: Map<string, AgentResolution>\n935: ): Promise<void> {\n936:   const { config, model } = opts;\n937:   const featureMap = new Map(features.map((f) => [f.id, f]));\n938: \n939:   const monitor = new ProcessMonitor(projectRoot, {\n940:     onSessionId: (featureId, sessionId) => {\n941:       updateAgent(state, featureId, { session_id: sessionId });\n942:       saveState(projectRoot, state);\n943:     },\n944:     onComplete: (featureId) => {\n945:       updateAgent(state, featureId, {\n946:         status: \"completed\",\n947:         completed_at: new Date().toISOString(),\n948:       });\n949:       saveState(projectRoot, state);\n950: \n951:       // Run build verification — fire-and-forget\n952:       const agent = state.agents.find((a) => a.feature_id === featureId)!;\n953:       handleBuildVerification(projectRoot, state, agent, featureMap.get(featureId)!, config, model, monitor)\n954:         .then(() => {\n955:           // After verification/merge, try to launch dependency-ready agents\n956:           // Multiple queued agents may now be unblocked\n957:           launchAllReady(projectRoot, state, featureMap, monitor, config, model, agentResolutions)\n958:             .catch((err) => wtLog(featureId, `LAUNCH ERROR: ${err.message}`));\n959:         })\n960:         .catch((err) => {\n961:           wtLog(featureId, `BUILD VERIFICATION UNHANDLED ERROR: ${err.message}`);\n962:           launchAllReady(projectRoot, state, featureMap, monitor, config, model, agentResolutions)\n963:             .catch((err2) => wtLog(featureId, `LAUNCH ERROR: ${err2.message}`));\n964:         });\n965:     },\n966:     onError: (featureId, error) => {\n967:       const agent = state.agents.find((a) => a.feature_id === featureId)!;\n968:       if (agent.retries < agent.max_retries) {\n969:         updateAgent(state, featureId, {\n970:           status: \"retry\",\n971:           retries: agent.retries + 1,\n972:           error,\n973:         });\n974:         saveState(projectRoot, state);\n975: \n976:         // Retry\n977:         handleRetry(projectRoot, state, agent, monitor, config, model);\n978:       } else {\n979:         updateAgent(state, featureId, {\n980:           status: \"failed\",\n981:           error,\n982:           completed_at: new Date().toISOString(),\n983:         });\n984:         saveState(projectRoot, state);\n985: \n986:         // Cascade failure to downstream agents\n987:         const cancelled = cancelDownstream(state, featureId);\n988:         if (cancelled.length > 0) {\n989:           wtLog(featureId, `downstream cancelled: ${cancelled.join(\", \")}`);\n990:           saveState(projectRoot, state);\n991:         }\n992:       }\n993: \n994:       // Try to launch dependency-ready agents\n995:       launchAllReady(projectRoot, state, featureMap, monitor, config, model, agentResolutions)\n996:         .catch((err) => wtLog(featureId, `LAUNCH ERROR: ${err.message}`));\n997:     },\n998:     onOutput: (_featureId, _data) => {\n999:       // Raw output — logged to file by ProcessMonitor\n1000:     },\n1001:     onActivity: (featureId, activity) => {\n1002:       updateAgent(state, featureId, {\n1003:         activity,\n1004:         activity_updated_at: new Date().toISOString(),\n1005:       });\n1006:       // Don't save to disk on every activity — too frequent.\n1007:     },\n1008:   });\n1009: \n1010:   // Create the TUI — it will auto-refresh and show activity from the monitor\n1011:   const tuiRef = { current: null as WomboTUI | null };\n1012:   const startTUI = () => {\n1013:     tuiRef.current = new WomboTUI({\n1014:       state,\n1015:       monitor,\n1016:       projectRoot,\n1017:       interactive: false,\n1018:       config,\n1019:       onQuit: () => {\n1020:         // Same as SIGINT — save state and exit\n1021:         for (const agent of state.agents) {\n1022:           if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n1023:             updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n1024:           }\n1025:         }\n1026:         monitor.killAll();\n1027:         saveState(projectRoot, state);\n1028:         console.log(\"State saved. Use 'woco resume' to continue.\");\n1029:         process.exit(0);\n1030:       },\n1031:       onRetry: (featureId: string) => {\n1032:         const agent = state.agents.find((a) => a.feature_id === featureId);\n1033:         if (!agent) return;\n1034:         if (agent.status !== \"failed\" && agent.status !== \"retry\") return;\n1035: \n1036:         // Reset retries if exhausted, give it one more shot\n1037:         if (agent.retries >= agent.max_retries) {\n1038:           updateAgent(state, featureId, { max_retries: agent.retries + 1 });\n1039:         }\n1040: \n1041:         wtLog(featureId, `manual retry requested from TUI — resetting to queued`);\n1042:         updateAgent(state, featureId, {\n1043:           status: \"queued\",\n1044:           error: null,\n1045:           activity: \"waiting for relaunch (manual retry)...\",\n1046:         });\n1047:         saveState(projectRoot, state);\n1048:         // The polling loop will call launchAllReady() and pick this up\n1049:       },\n1050:     });\n1051:     tuiRef.current.start();\n1052:   };\n1053: \n1054:   // Handle graceful shutdown\n1055:   process.on(\"SIGINT\", () => {\n1056:     if (tuiRef.current) tuiRef.current.stop();\n1057:     for (const agent of state.agents) {\n1058:       if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n1059:         updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n1060:       }\n1061:     }\n1062:     monitor.killAll();\n1063:     saveState(projectRoot, state);\n1064:     console.log(\"\\nState saved. Use 'woco resume' to continue.\");\n1065:     process.exit(0);\n1066:   });\n1067: \n1068:   // Launch initial batch — only agents whose dependencies are already satisfied\n1069:   // Stagger launches to avoid SQLite race conditions in agent processes:\n1070:   // each agent spawns its own DB, and simultaneous CREATE TABLE calls collide.\n1071:   const ready = readyToLaunchAgents(state);\n1072:   const tolaunch = ready.slice(0, opts.maxConcurrent);\n1073:   console.log(`Setting up ${tolaunch.length} agent(s) (staggered)...\\n`);\n1074: \n1075:   for (let i = 0; i < tolaunch.length; i++) {\n1076:     await launchSingleHeadless(\n1077:       projectRoot,\n1078:       state,\n1079:       tolaunch[i],\n1080:       featureMap.get(tolaunch[i].feature_id)!,\n1081:       monitor,\n1082:       config,\n1083:       model,\n1084:       agentResolutions\n1085:     );\n1086:     // Brief delay between spawns so each agent's DB migration settles\n1087:     if (i < tolaunch.length - 1) {\n1088:       await new Promise((r) => setTimeout(r, LAUNCH_STAGGER_MS));\n1089:     }\n1090:   }\n1091: \n1092:   const launched = state.agents.filter((a) => a.status === \"running\").length;\n1093: \n1094:   // Start the TUI dashboard (or skip if --no-tui)\n1095:   if (opts.noTui) {\n1096:     console.log(`${launched} agent(s) running. (--no-tui mode, dashboard prints every 15s)\\n`);\n1097:     printDashboard(state);\n1098:   } else {\n1099:     console.log(`${launched} agent(s) running. Launching TUI...\\n`);\n1100:     startTUI();\n1101:   }\n1102: \n1103:   // Background monitoring loop — checks for dead processes and launches queued\n1104:   const POLL_INTERVAL = 5000;\n1105:   let dashboardCounter = 0;\n1106:   while (!isWaveComplete(state)) {\n1107:     await new Promise((r) => setTimeout(r, POLL_INTERVAL));\n1108: \n1109:     // Check for completed processes that weren't caught by event handlers\n1110:     for (const agent of state.agents) {\n1111:       if (\n1112:         (agent.status === \"running\" || agent.status === \"resolving_conflict\") &&\n1113:         agent.pid &&\n1114:         !isProcessRunning(agent.pid) &&\n1115:         !monitor.isRunning(agent.feature_id)\n1116:       ) {\n1117:         if (agent.status === \"resolving_conflict\") {\n1118:           // Conflict resolver died — the await in handleBuildVerification\n1119:           // will resolve via the 'exit' event, so nothing to do here\n1120:           continue;\n1121:         }\n1122:         // Process exited but we didn't get a callback\n1123:         // Check if the agent actually made any commits\n1124:         if (!branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n1125:           // Agent died without producing any code — mark as failed, not completed\n1126:           updateAgent(state, agent.feature_id, {\n1127:             status: \"failed\",\n1128:             error: \"Agent process exited without making any commits\",\n1129:             activity: null,\n1130:             completed_at: new Date().toISOString(),\n1131:           });\n1132:           saveState(projectRoot, state);\n1133:           wtLog(agent.feature_id, \"process died with no code changes — marked failed\");\n1134: \n1135:           // Cascade failure to downstream agents\n1136:           const cancelled = cancelDownstream(state, agent.feature_id);\n1137:           if (cancelled.length > 0) {\n1138:             wtLog(agent.feature_id, `downstream cancelled: ${cancelled.join(\", \")}`);\n1139:             saveState(projectRoot, state);\n1140:           }\n1141:         } else {\n1142:           updateAgent(state, agent.feature_id, {\n1143:             status: \"completed\",\n1144:             completed_at: new Date().toISOString(),\n1145:             activity: \"done\",\n1146:           });\n1147:           saveState(projectRoot, state);\n1148:           try {\n1149:             await handleBuildVerification(projectRoot, state, agent, featureMap.get(agent.feature_id)!, config, model, monitor);\n1150:           } catch (err: any) {\n1151:             wtLog(agent.feature_id, `POLL VERIFY ERROR: ${err.message}`);\n1152:           }\n1153:         }\n1154:         await launchAllReady(projectRoot, state, featureMap, monitor, config, model, agentResolutions);\n1155:       }\n1156:     }\n1157: \n1158:     // Safety net: detect agents stuck in \"retry\" with no running process.\n1159:     // This catches edge cases where handleRetry() wasn't called or failed\n1160:     // to reset the agent (e.g. race between onError callback and poll loop).\n1161:     for (const agent of state.agents) {\n1162:       if (\n1163:         agent.status === \"retry\" &&\n1164:         (!agent.pid || !isProcessRunning(agent.pid)) &&\n1165:         !monitor.isRunning(agent.feature_id)\n1166:       ) {\n1167:         if (agent.retries >= agent.max_retries) {\n1168:           // Out of retries — mark as failed and cascade\n1169:           wtLog(agent.feature_id, `stuck in retry with no process and retries exhausted (${agent.retries}/${agent.max_retries}) — marking failed`);\n1170:           updateAgent(state, agent.feature_id, {\n1171:             status: \"failed\",\n1172:             error: agent.error ?? \"Agent stuck in retry state with no running process\",\n1173:             activity: null,\n1174:             completed_at: new Date().toISOString(),\n1175:           });\n1176:           saveState(projectRoot, state);\n1177:           const cancelled = cancelDownstream(state, agent.feature_id);\n1178:           if (cancelled.length > 0) {\n1179:             wtLog(agent.feature_id, `downstream cancelled: ${cancelled.join(\", \")}`);\n1180:             saveState(projectRoot, state);\n1181:           }\n1182:         } else {\n1183:           // Has retries left — reset to queued for a fresh launch\n1184:           wtLog(agent.feature_id, `stuck in retry with no process — resetting to queued (retry ${agent.retries}/${agent.max_retries})`);\n1185:           updateAgent(state, agent.feature_id, {\n1186:             status: \"queued\",\n1187:             error: null,\n1188:             activity: \"waiting for relaunch...\",\n1189:           });\n1190:           saveState(projectRoot, state);\n1191:         }\n1192:       }\n1193:     }\n1194: \n1195:     // After recovering stuck agents, try launching any that are now ready\n1196:     await launchAllReady(projectRoot, state, featureMap, monitor, config, model, agentResolutions);\n1197: \n1198:     // Persist state periodically\n1199:     saveState(projectRoot, state);\n1200: \n1201:     // Update TUI state reference (or print dashboard in --no-tui mode)\n1202:     if (tuiRef.current) {\n1203:       tuiRef.current.updateState(state);\n1204:     } else if (opts.noTui) {\n1205:       dashboardCounter++;\n1206:       if (dashboardCounter % 3 === 0) {\n1207:         printDashboard(state);\n1208: \n1209:         // Auto-push base branch if requested\n1210:         if (opts.autoPush) {\n1211:           const anyMerged = state.agents.some((a) => a.status === \"merged\");\n1212:           if (anyMerged) {\n1213:             await pushBaseBranch(projectRoot, state.base_branch, config);\n1214:           } else {\n1215:             console.log(\"No branches were merged — skipping push.\");\n1216:           }\n1217:         }\n1218:       }\n1219:     }\n1220:   }\n1221: \n1222:   // Wave complete — keep TUI open for post-mortem browsing\n1223:   if (tuiRef.current) {\n1224:     tuiRef.current.updateState(state);\n1225:     tuiRef.current.markWaveComplete();\n1226:     // Wait for the user to press q to exit the TUI\n1227:     await tuiRef.current.waitForQuit();\n1228:   }\n1229: \n1230:   // Print final dashboard after TUI is closed\n1231:   printDashboard(state);\n1232: \n1233:   // Dump full logs for failed agents (post-mortem)\n1234:   dumpFailedAgentLogs(projectRoot, state);\n1235: \n1236:   // Auto-export wave history\n1237:   try {\n1238:     const historyPath = exportWaveHistory(projectRoot, state);\n1239:     console.log(`Wave history exported to ${historyPath}`);\n1240:   } catch (err: any) {\n1241:     console.error(`Warning: failed to export wave history: ${err.message}`);\n1242:   }\n1243: \n1244:   // Auto-push base branch if requested\n1245:   if (opts.autoPush) {\n1246:     await pushBaseBranch(projectRoot, state.base_branch, config);\n1247:   }\n1248: \n1249:   console.log(\"Wave complete.\");\n1250: }\n1251: \n1252: // ---------------------------------------------------------------------------\n1253: // Interactive Wave Launch\n1254: // ---------------------------------------------------------------------------\n1255: \n1256: async function launchWaveInteractive(\n1257:   projectRoot: string,\n1258:   state: WaveState,\n1259:   features: Feature[],\n1260:   opts: LaunchCommandOptions,\n1261:   agentResolutions?: Map<string, AgentResolution>\n1262: ): Promise<void> {\n1263:   const { config, model } = opts;\n1264:   const featureMap = new Map(features.map((f) => [f.id, f]));\n1265: \n1266:   // Show dashboard immediately\n1267:   printDashboard(state);\n1268: \n1269:   // Launch initial batch — parallelize setup\n1270:   const tolaunch = queuedAgents(state).slice(0, opts.maxConcurrent);\n1271:   console.log(`Setting up ${tolaunch.length} agent(s) in parallel...\\n`);\n1272: \n1273:   await Promise.all(\n1274:     tolaunch.map(async (agent) => {\n1275:       updateAgent(state, agent.feature_id, {\n1276:         status: \"installing\",\n1277:         started_at: new Date().toISOString(),\n1278:         activity: \"setting up worktree...\",\n1279:       });\n1280:       saveState(projectRoot, state);\n1281: \n1282:       try {\n1283:         if (worktreeReady(agent.worktree)) {\n1284:           wtLog(agent.feature_id, \"worktree already exists, skipping setup\");\n1285:         } else {\n1286:           await createWorktree(projectRoot, agent.feature_id, state.base_branch, config);\n1287:           updateAgent(state, agent.feature_id, { activity: \"installing deps...\" });\n1288:           await installDeps(agent.worktree, agent.feature_id, config);\n1289:         }\n1290: \n1291:         const prompt = generatePrompt(\n1292:           featureMap.get(agent.feature_id)!,\n1293:           state.base_branch,\n1294:           config\n1295:         );\n1296: \n1297:         // Write specialized agent to worktree if applicable\n1298:         const resolution = agentResolutions?.get(agent.feature_id);\n1299:         const agentName = agent.agent_name ?? undefined;\n1300:         if (resolution && isSpecializedAgent(resolution)) {\n1301:           try {\n1302:             const patchedContent = patchImportedAgent(resolution.rawContent, config, projectRoot);\n1303:             writeAgentToWorktree(agent.worktree, resolution.name, patchedContent);\n1304:             wtLog(agent.feature_id, `wrote specialized agent: ${resolution.name}`);\n1305:           } catch (err: any) {\n1306:             wtLog(agent.feature_id, `WARN: failed to write specialized agent, using generalist: ${err.message}`);\n1307:           }\n1308:         }\n1309: \n1310:         wtLog(agent.feature_id, \"launching interactive session...\");\n1311:         const result = launchInteractive({\n1312:           worktreePath: agent.worktree,\n1313:           featureId: agent.feature_id,\n1314:           prompt,\n1315:           model,\n1316:           interactive: true,\n1317:           config,\n1318:           agentName,\n1319:         });\n1320: \n1321:         const muxName = getMultiplexerName(config);\n1322:         updateAgent(state, agent.feature_id, {\n1323:           status: \"running\",\n1324:           pid: result.pid,\n1325:           activity: `${muxName} session active`,\n1326:         });\n1327:         saveState(projectRoot, state);\n1328:         wtLog(agent.feature_id, `${muxName} session: ${config.agent.tmuxPrefix}-${agent.feature_id}`);\n1329:       } catch (err: any) {\n1330:         updateAgent(state, agent.feature_id, {\n1331:           status: \"failed\",\n1332:           error: err.message,\n1333:           activity: null,\n1334:           completed_at: new Date().toISOString(),\n1335:         });\n1336:         saveState(projectRoot, state);\n1337:         wtLog(agent.feature_id, `SETUP FAILED: ${err.message.split(\"\\n\")[0]}`);\n1338:       }\n1339:     })\n1340:   );\n1341: \n1342:   const mux = detectMultiplexer(config.agent.multiplexer);\n1343:   const muxName = getMultiplexerName(config);\n1344:   console.log(\"\\nInteractive sessions launched. Use these commands:\");\n1345:   console.log(`  ${muxAttachCommand(mux, `${config.agent.tmuxPrefix}-<feature-id>`)}   # attach to a session`);\n1346:   console.log(`  ${muxListCommand(mux)}${\" \".repeat(Math.max(1, 54 - muxListCommand(mux).length))}# list sessions`);\n1347:   console.log(\"  woco status                                             # check status\");\n1348:   console.log(\"  woco verify                                             # verify builds\");\n1349:   console.log(\"  woco merge                                              # merge verified\");\n1350:   console.log(\"  woco cleanup                                            # remove worktrees\");\n1351: \n1352:   printDashboard(state);\n1353: }\n1354: \n1355: // ---------------------------------------------------------------------------\n1356: // Main Command\n1357: // ---------------------------------------------------------------------------\n1358: \n1359: export async function cmdLaunch(opts: LaunchCommandOptions): Promise<void> {\n1360:   const { projectRoot, config } = opts;\n1361:   const fmt = opts.outputFmt ?? \"text\";\n1362: \n1363:   if (fmt === \"text\") console.log(\"\\n--- wombo-combo: Launch ---\\n\");\n1364: \n1365:   // Ensure agent definition exists — reinstall from template if missing\n1366:   ensureAgentDefinition(projectRoot, config, opts.agent);\n1367: \n1368:   // Ensure portless proxy is running (if enabled) to prevent port collisions\n1369:   if (config.portless.enabled) {\n1370:     if (isPortlessAvailable(config)) {\n1371:       const proxyOk = ensureProxyRunning(config);\n1372:       if (!proxyOk && fmt === \"text\") {\n1373:         console.warn(\n1374:           \"\\x1b[33m[portless]\\x1b[0m proxy could not be started — agents may encounter port collisions\"\n1375:         );\n1376:       }\n1377:     } else if (fmt === \"text\") {\n1378:       console.warn(\n1379:         \"\\x1b[33m[portless]\\x1b[0m enabled but not installed. Install with: npm install -g portless\"\n1380:       );\n1381:       console.warn(\n1382:         \"  Agents will run without portless — concurrent dev servers may have port collisions.\\n\"\n1383:       );\n1384:     }\n1385:   }\n1386: \n1387:   // -------------------------------------------------------------------------\n1388:   // Validate that the configured baseBranch exists as a local branch\n1389:   // -------------------------------------------------------------------------\n1390:   if (!branchExists(projectRoot, opts.baseBranch)) {\n1391:     const msg = `Base branch \"${opts.baseBranch}\" does not exist as a local branch. ` +\n1392:       `Create it first (e.g. \"git checkout -b ${opts.baseBranch}\") or specify ` +\n1393:       `a different branch with --base-branch.`;\n1394:     outputError(fmt, msg);\n1395:   }\n1396: \n1397:   // -------------------------------------------------------------------------\n1398:   // Check for existing wave state — don't overwrite work in progress\n1399:   // -------------------------------------------------------------------------\n1400:   const existingState = loadState(projectRoot);\n1401:   if (existingState) {\n1402:     const merged = existingState.agents.filter((a) => a.status === \"merged\");\n1403:     const verified = existingState.agents.filter((a) => a.status === \"verified\");\n1404:     const completed = existingState.agents.filter((a) => a.status === \"completed\");\n1405:     const running = existingState.agents.filter((a) => a.status === \"running\");\n1406:     const queued = existingState.agents.filter((a) => a.status === \"queued\");\n1407:     const failed = existingState.agents.filter((a) => a.status === \"failed\");\n1408: \n1409:     const hasWork = merged.length > 0 || verified.length > 0 || completed.length > 0 || running.length > 0;\n1410: \n1411:     if (hasWork) {\n1412:       if (fmt === \"text\") {\n1413:         console.log(`Existing wave found: ${existingState.wave_id}`);\n1414:         console.log(`  ${merged.length} merged, ${verified.length} verified, ${completed.length} completed, ${running.length} running, ${queued.length} queued, ${failed.length} failed`);\n1415:       }\n1416: \n1417:       // Finalize any merged agents by marking their features as done\n1418:       if (merged.length > 0) {\n1419:         if (fmt === \"text\") console.log(\"\\nFinalizing merged tasks in tasks file...\");\n1420:         for (const agent of merged) {\n\n(Output capped at 50 KB. Showing lines 1-1420. Use offset=1421 to continue.)\n</content>","title":"src/commands/launch.ts","metadata":{"preview":"/**\n * launch.ts — Launch a wave of agents.\n *\n * Usage: woco launch [selection options] [launch options]\n *\n * This is the primary entry point for starting a new wave. It selects features\n * from the features file, creates a wave state, sets up worktrees, and launches\n * agent processes (either headless or interactive via dmux/tmux).\n *\n * IMPORTANT: This file also exports shared helper functions that are reused\n * by resume.ts and other commands:\n *   - launchSingleHeadless\n *   - handleBuildVerification\n *   - handleRetry\n *   - launchNextQueued\n */\n\nimport { execSync } from \"node:child_process\";\nimport { existsSync, readFileSync } from \"node:fs\";\nimport { resolve } from \"node:path\";","truncated":true,"loaded":[]},"time":{"start":1773439923892,"end":1773439923896}}}}
{"type":"tool_use","timestamp":1773439924501,"sessionID":"ses_316be8c08ffeZXbNAgwvZBSoRI","part":{"id":"prt_ce941b71a001TF1tDHrQ52eQCg","sessionID":"ses_316be8c08ffeZXbNAgwvZBSoRI","messageID":"msg_ce941a1b0001XzWF5FzYEsI7m1","type":"tool","callID":"toolu_vrtx_01CgVwgX2gheVQLYSvx7yHuE","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/dynamic-agent-types/src/config.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/dynamic-agent-types/src/config.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * config.ts — Load .wombo-combo/config.json, merge with defaults, validate, expose typed config.\n3:  *\n4:  * The config file lives at .wombo-combo/config.json inside the target project root.\n5:  * All values have sensible defaults so minimal config works out of the box.\n6:  */\n7: \n8: import { readFileSync, existsSync } from \"node:fs\";\n9: import { resolve } from \"node:path\";\n10: import type { MultiplexerPreference } from \"./lib/multiplexer.js\";\n11: \n12: // ---------------------------------------------------------------------------\n13: // .wombo-combo directory constant\n14: // ---------------------------------------------------------------------------\n15: \n16: /** Name of the directory that holds all wombo-combo files */\n17: export const WOMBO_DIR = \".wombo-combo\";\n18: \n19: // ---------------------------------------------------------------------------\n20: // Types\n21: // ---------------------------------------------------------------------------\n22: \n23: /** Agent registry download mode */\n24: export type AgentRegistryMode = \"auto\" | \"monitored\" | \"disabled\";\n25: \n26: export interface WomboConfig {\n27:   /** Directory name for task files relative to .wombo-combo/ (folder-based storage) */\n28:   tasksDir: string;\n29:   /** Directory name for archived task files relative to .wombo-combo/ */\n30:   archiveDir: string;\n31:   /** @deprecated Use tasksDir. Legacy single-file path relative to .wombo-combo/ */\n32:   tasksFile?: string;\n33:   /** @deprecated Use archiveDir. Legacy single-file path relative to .wombo-combo/ */\n34:   archiveFile?: string;\n35:   /** Base branch to create feature branches from */\n36:   baseBranch: string;\n37:   /** Build configuration */\n38:   build: {\n39:     /** Build command to run in worktrees */\n40:     command: string;\n41:     /** Build timeout in milliseconds */\n42:     timeout: number;\n43:     /** Build artifact directory (for quick \"did it build?\" checks) */\n44:     artifactDir: string;\n45:   };\n46:   /** Install configuration */\n47:   install: {\n48:     /** Install command to run in worktrees */\n49:     command: string;\n50:     /** Install timeout in milliseconds */\n51:     timeout: number;\n52:   };\n53:   /** Git configuration */\n54:   git: {\n55:     /** Branch name prefix for feature branches */\n56:     branchPrefix: string;\n57:     /** Worktree directory name prefix */\n58:     worktreePrefix: string;\n59:     /** Git remote name */\n60:     remote: string;\n61:     /** Merge strategy flag */\n62:     mergeStrategy: string;\n63:   };\n64:   /** Agent configuration */\n65:   agent: {\n66:     /** Path to agent binary (null = auto-detect) */\n67:     bin: string | null;\n68:     /** Agent name to pass via --agent flag */\n69:     name: string;\n70:     /** Config files/dirs to copy into worktrees */\n71:     configFiles: string[];\n72:     /** Session name prefix for terminal multiplexer */\n73:     tmuxPrefix: string;\n74:     /** Terminal multiplexer preference: \"auto\" (prefer dmux), \"dmux\", or \"tmux\" */\n75:     multiplexer: MultiplexerPreference;\n76:   };\n77:   /** Portless integration for localhost server testing */\n78:   portless: {\n79:     /** Whether portless is enabled for agent worktrees */\n80:     enabled: boolean;\n81:     /** Path to portless binary (null = auto-detect via PATH) */\n82:     bin: string | null;\n83:     /** Proxy port (portless default is 1355) */\n84:     proxyPort: number;\n85:     /** Whether to use HTTPS mode */\n86:     https: boolean;\n87:   };\n88:   /** Backup configuration for tasks file */\n89:   backup: {\n90:     /** Maximum number of timestamped backups to keep */\n91:     maxBackups: number;\n92:   };\n93:   /** Default runtime values */\n94:   defaults: {\n95:     /** Max concurrent agents */\n96:     maxConcurrent: number;\n97:     /** Max retries per agent */\n98:     maxRetries: number;\n99:   };\n100:   /** Browser testing configuration */\n101:   browser: BrowserConfig;\n102:   /** Agent registry configuration for specialized agent downloads */\n103:   agentRegistry: AgentRegistryConfig;\n104:   /** Test-Driven Development configuration */\n105:   tdd: TddConfig;\n106: }\n107: \n108: /** Configuration for browser-based verification and testing */\n109: export interface BrowserConfig {\n110:   /** Enable browser testing in the verify pipeline */\n111:   enabled: boolean;\n112:   /** Path to browser binary (null = auto-detect) */\n113:   bin: string | null;\n114:   /** Run browser in headless mode (required for CI) */\n115:   headless: boolean;\n116:   /** Custom test command to run browser tests (overrides script discovery) */\n117:   testCommand: string | null;\n118:   /** Timeout for launching a browser instance (ms) */\n119:   launchTimeout: number;\n120:   /** Timeout for each browser test script (ms) */\n121:   testTimeout: number;\n122:   /** Default viewport size */\n123:   defaultViewport: {\n124:     width: number;\n125:     height: number;\n126:   };\n127: }\n128: \n129: /** Configuration for the external agent registry (e.g. agency-agents) */\n130: export interface AgentRegistryConfig {\n131:   /**\n132:    * Download mode:\n133:    * - \"auto\"      — download agents without asking (default)\n134:    * - \"monitored\" — user reviews/edits/rejects each agent before launch\n135:    * - \"disabled\"  — always use the generalist agent\n136:    */\n137:   mode: AgentRegistryMode;\n138:   /** GitHub repo in \"owner/repo\" format to pull agent definitions from */\n139:   source: string;\n140:   /** Cache directory name (relative to .wombo-combo/) */\n141:   cacheDir: string;\n142:   /** Cache TTL in milliseconds. Cached agents older than this are re-fetched. Default 24h. */\n143:   cacheTTL: number;\n144: }\n145: \n146: /** Configuration for Test-Driven Development workflow */\n147: export interface TddConfig {\n148:   /** Enable TDD red-green-refactor instructions in agent prompts */\n149:   enabled: boolean;\n150:   /** Test command to run (default: \"bun test\") */\n151:   testCommand: string;\n152:   /** Strict TDD mode: fail verification if new files are missing tests */\n153:   strictTdd: boolean;\n154:   /** Test command timeout in milliseconds (default: 120_000) */\n155:   testTimeout: number;\n156: }\n157: \n158: // ---------------------------------------------------------------------------\n159: // Defaults\n160: // ---------------------------------------------------------------------------\n161: \n162: export const DEFAULT_CONFIG: WomboConfig = {\n163:   tasksDir: \"tasks\",\n164:   archiveDir: \"archive\",\n165:   baseBranch: \"develop\",\n166:   build: {\n167:     command: \"bun run build\",\n168:     timeout: 300_000,\n169:     artifactDir: \"dist\",\n170:   },\n171:   install: {\n172:     command: \"bun install\",\n173:     timeout: 120_000,\n174:   },\n175:   git: {\n176:     branchPrefix: \"feature/\",\n177:     worktreePrefix: \"wombo-\",\n178:     remote: \"origin\",\n179:     mergeStrategy: \"--no-ff\",\n180:   },\n181:   agent: {\n182:     bin: null,\n183:     name: \"generalist-agent\",\n184:     configFiles: [\".opencode/\", \"opencode.json\", \"AGENTS.md\"],\n185:     tmuxPrefix: \"wombo\",\n186:     multiplexer: \"auto\",\n187:   },\n188:   portless: {\n189:     enabled: true,\n190:     bin: null,\n191:     proxyPort: 1355,\n192:     https: false,\n193:   },\n194:   backup: {\n195:     maxBackups: 5,\n196:   },\n197:   defaults: {\n198:     maxConcurrent: 6,\n199:     maxRetries: 2,\n200:   },\n201:   browser: {\n202:     enabled: false,\n203:     bin: null,\n204:     headless: true,\n205:     testCommand: null,\n206:     launchTimeout: 30_000,\n207:     testTimeout: 60_000,\n208:     defaultViewport: {\n209:       width: 1280,\n210:       height: 720,\n211:     },\n212:   },\n213:   agentRegistry: {\n214:     mode: \"auto\",\n215:     source: \"msitarzewski/agency-agents\",\n216:     cacheDir: \"agents-cache\",\n217:     cacheTTL: 24 * 60 * 60 * 1000, // 24 hours\n218:   },\n219:   tdd: {\n220:     enabled: false,\n221:     testCommand: \"bun test\",\n222:     strictTdd: false,\n223:     testTimeout: 120_000,\n224:   },\n225: };\n226: \n227: // ---------------------------------------------------------------------------\n228: // Config File Name\n229: // ---------------------------------------------------------------------------\n230: \n231: export const CONFIG_FILE = `${WOMBO_DIR}/config.json`;\n232: \n233: // ---------------------------------------------------------------------------\n234: // Loader\n235: // ---------------------------------------------------------------------------\n236: \n237: /**\n238:  * Deep-merge source into target. Only merges plain objects, not arrays.\n239:  */\n240: function deepMerge<T extends Record<string, any>>(target: T, source: Partial<T>): T {\n241:   const result = { ...target };\n242:   for (const key of Object.keys(source) as (keyof T)[]) {\n243:     const srcVal = source[key];\n244:     const tgtVal = target[key];\n245:     if (\n246:       srcVal !== undefined &&\n247:       srcVal !== null &&\n248:       typeof srcVal === \"object\" &&\n249:       !Array.isArray(srcVal) &&\n250:       typeof tgtVal === \"object\" &&\n251:       !Array.isArray(tgtVal) &&\n252:       tgtVal !== null\n253:     ) {\n254:       result[key] = deepMerge(tgtVal as any, srcVal as any);\n255:     } else if (srcVal !== undefined) {\n256:       result[key] = srcVal as T[keyof T];\n257:     }\n258:   }\n259:   return result;\n260: }\n261: \n262: /**\n263:  * Load .wombo-combo/config.json from the given project root and merge with defaults.\n264:  * Returns the full config. If no config file exists, returns defaults.\n265:  */\n266: export function loadConfig(projectRoot: string): WomboConfig {\n267:   const configPath = resolve(projectRoot, CONFIG_FILE);\n268: \n269:   if (!existsSync(configPath)) {\n270:     return { ...DEFAULT_CONFIG };\n271:   }\n272: \n273:   try {\n274:     const raw = readFileSync(configPath, \"utf-8\");\n275:     const partial = JSON.parse(raw) as Partial<WomboConfig>;\n276: \n277:     // Migrate legacy single-file config keys to folder-based\n278:     if ((partial as any).tasksFile && !partial.tasksDir) {\n279:       // Legacy \"tasks.yml\" → strip extension for dir name, or use as-is\n280:       const legacy = (partial as any).tasksFile as string;\n281:       partial.tasksDir = legacy.replace(/\\.ya?ml$/i, \"\") || \"tasks\";\n282:       delete (partial as any).tasksFile;\n283:     }\n284:     if ((partial as any).archiveFile && !partial.archiveDir) {\n285:       const legacy = (partial as any).archiveFile as string;\n286:       partial.archiveDir = legacy.replace(/\\.ya?ml$/i, \"\") || \"archive\";\n287:       delete (partial as any).archiveFile;\n288:     }\n289: \n290:     return deepMerge(DEFAULT_CONFIG, partial);\n291:   } catch (err: any) {\n292:     throw new Error(`Failed to load ${CONFIG_FILE}: ${err.message}`);\n293:   }\n294: }\n295: \n296: /**\n297:  * Resolve the agent binary path. Priority:\n298:  *   1. config.agent.bin (explicit)\n299:  *   2. OPENCODE_BIN env var\n300:  *   3. ~/.opencode/bin/opencode (default install location)\n301:  */\n302: export function resolveAgentBin(config: WomboConfig): string {\n303:   if (config.agent.bin) return config.agent.bin;\n304:   if (process.env.OPENCODE_BIN) return process.env.OPENCODE_BIN;\n305:   return resolve(process.env.HOME || \"~\", \".opencode/bin/opencode\");\n306: }\n307: \n308: /**\n309:  * Validate the config for obvious issues. Throws on error.\n310:  */\n311: export function validateConfig(config: WomboConfig): void {\n312:   if (!config.tasksDir) {\n313:     throw new Error(\"config.tasksDir must be a non-empty string\");\n314:   }\n315:   if (!config.archiveDir) {\n316:     throw new Error(\"config.archiveDir must be a non-empty string\");\n317:   }\n318:   if (!config.baseBranch) {\n319:     throw new Error(\"config.baseBranch must be a non-empty string\");\n320:   }\n321:   if (!config.build.command) {\n322:     throw new Error(\"config.build.command must be a non-empty string\");\n323:   }\n324:   if (!config.install.command) {\n325:     throw new Error(\"config.install.command must be a non-empty string\");\n326:   }\n327:   if (!config.git.branchPrefix) {\n328:     throw new Error(\"config.git.branchPrefix must be a non-empty string\");\n329:   }\n330:   if (!config.git.worktreePrefix) {\n331:     throw new Error(\"config.git.worktreePrefix must be a non-empty string\");\n332:   }\n333:   if (config.defaults.maxConcurrent < 1) {\n334:     throw new Error(\"config.defaults.maxConcurrent must be >= 1\");\n335:   }\n336:   if (config.defaults.maxRetries < 0) {\n337:     throw new Error(\"config.defaults.maxRetries must be >= 0\");\n338:   }\n339:   if (config.backup.maxBackups < 0) {\n340:     throw new Error(\"config.backup.maxBackups must be >= 0\");\n341:   }\n342:   const validModes: AgentRegistryMode[] = [\"auto\", \"monitored\", \"disabled\"];\n343:   if (!validModes.includes(config.agentRegistry.mode)) {\n344:     throw new Error(`config.agentRegistry.mode must be one of: ${validModes.join(\", \")}`);\n345:   }\n346:   if (!config.agentRegistry.source) {\n347:     throw new Error(\"config.agentRegistry.source must be a non-empty string\");\n348:   }\n349:   if (!config.agentRegistry.cacheDir) {\n350:     throw new Error(\"config.agentRegistry.cacheDir must be a non-empty string\");\n351:   }\n352:   if (config.tdd.enabled && !config.tdd.testCommand) {\n353:     throw new Error(\"config.tdd.testCommand must be a non-empty string when TDD is enabled\");\n354:   }\n355: }\n356: \n357: /**\n358:  * Generate the default .wombo-combo/config.json content string (for `woco init`).\n359:  */\n360: export function generateDefaultConfig(): string {\n361:   return JSON.stringify(DEFAULT_CONFIG, null, 2) + \"\\n\";\n362: }\n\n(End of file - total 362 lines)\n</content>","title":"src/config.ts","metadata":{"preview":"/**\n * config.ts — Load .wombo-combo/config.json, merge with defaults, validate, expose typed config.\n *\n * The config file lives at .wombo-combo/config.json inside the target project root.\n * All values have sensible defaults so minimal config works out of the box.\n */\n\nimport { readFileSync, existsSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\nimport type { MultiplexerPreference } from \"./lib/multiplexer.js\";\n\n// ---------------------------------------------------------------------------\n// .wombo-combo directory constant\n// ---------------------------------------------------------------------------\n\n/** Name of the directory that holds all wombo-combo files */\nexport const WOMBO_DIR = \".wombo-combo\";\n\n// ---------------------------------------------------------------------------\n// Types","truncated":false,"loaded":[]},"time":{"start":1773439924495,"end":1773439924500}}}}
{"type":"text","timestamp":1773439925179,"sessionID":"ses_316be8c08ffeZXbNAgwvZBSoRI","part":{"id":"prt_ce941ac75001zCMIKm2Y0uFo4d","sessionID":"ses_316be8c08ffeZXbNAgwvZBSoRI","messageID":"msg_ce941a1b0001XzWF5FzYEsI7m1","type":"text","text":"Now let me explore key source files and the agency-agents format:","time":{"start":1773439925179,"end":1773439925179}}}
{"type":"tool_use","timestamp":1773439925359,"sessionID":"ses_316be8c08ffeZXbNAgwvZBSoRI","part":{"id":"prt_ce941b911001lUw9rEUJX1oicp","sessionID":"ses_316be8c08ffeZXbNAgwvZBSoRI","messageID":"msg_ce941a1b0001XzWF5FzYEsI7m1","type":"tool","callID":"toolu_vrtx_0165FtHjgMF6xi9KjL673pvh","tool":"webfetch","state":{"status":"completed","input":{"format":"text","url":"https://raw.githubusercontent.com/msitarzewski/agency-agents/main/engineering/engineering-frontend-developer.md"},"output":"---\nname: Frontend Developer\ndescription: Expert frontend developer specializing in modern web technologies, React/Vue/Angular frameworks, UI implementation, and performance optimization\ncolor: cyan\nemoji: 🖥️\nvibe: Builds responsive, accessible web apps with pixel-perfect precision.\n---\n\n# Frontend Developer Agent Personality\n\nYou are **Frontend Developer**, an expert frontend developer who specializes in modern web technologies, UI frameworks, and performance optimization. You create responsive, accessible, and performant web applications with pixel-perfect design implementation and exceptional user experiences.\n\n## 🧠 Your Identity & Memory\n- **Role**: Modern web application and UI implementation specialist\n- **Personality**: Detail-oriented, performance-focused, user-centric, technically precise\n- **Memory**: You remember successful UI patterns, performance optimization techniques, and accessibility best practices\n- **Experience**: You've seen applications succeed through great UX and fail through poor implementation\n\n## 🎯 Your Core Mission\n\n### Editor Integration Engineering\n- Build editor extensions with navigation commands (openAt, reveal, peek)\n- Implement WebSocket/RPC bridges for cross-application communication\n- Handle editor protocol URIs for seamless navigation\n- Create status indicators for connection state and context awareness\n- Manage bidirectional event flows between applications\n- Ensure sub-150ms round-trip latency for navigation actions\n\n### Create Modern Web Applications\n- Build responsive, performant web applications using React, Vue, Angular, or Svelte\n- Implement pixel-perfect designs with modern CSS techniques and frameworks\n- Create component libraries and design systems for scalable development\n- Integrate with backend APIs and manage application state effectively\n- **Default requirement**: Ensure accessibility compliance and mobile-first responsive design\n\n### Optimize Performance and User Experience\n- Implement Core Web Vitals optimization for excellent page performance\n- Create smooth animations and micro-interactions using modern techniques\n- Build Progressive Web Apps (PWAs) with offline capabilities\n- Optimize bundle sizes with code splitting and lazy loading strategies\n- Ensure cross-browser compatibility and graceful degradation\n\n### Maintain Code Quality and Scalability\n- Write comprehensive unit and integration tests with high coverage\n- Follow modern development practices with TypeScript and proper tooling\n- Implement proper error handling and user feedback systems\n- Create maintainable component architectures with clear separation of concerns\n- Build automated testing and CI/CD integration for frontend deployments\n\n## 🚨 Critical Rules You Must Follow\n\n### Performance-First Development\n- Implement Core Web Vitals optimization from the start\n- Use modern performance techniques (code splitting, lazy loading, caching)\n- Optimize images and assets for web delivery\n- Monitor and maintain excellent Lighthouse scores\n\n### Accessibility and Inclusive Design\n- Follow WCAG 2.1 AA guidelines for accessibility compliance\n- Implement proper ARIA labels and semantic HTML structure\n- Ensure keyboard navigation and screen reader compatibility\n- Test with real assistive technologies and diverse user scenarios\n\n## 📋 Your Technical Deliverables\n\n### Modern React Component Example\n```tsx\n// Modern React component with performance optimization\nimport React, { memo, useCallback, useMemo } from 'react';\nimport { useVirtualizer } from '@tanstack/react-virtual';\n\ninterface DataTableProps {\n  data: Array<Record<string, any>>;\n  columns: Column[];\n  onRowClick?: (row: any) => void;\n}\n\nexport const DataTable = memo<DataTableProps>(({ data, columns, onRowClick }) => {\n  const parentRef = React.useRef<HTMLDivElement>(null);\n  \n  const rowVirtualizer = useVirtualizer({\n    count: data.length,\n    getScrollElement: () => parentRef.current,\n    estimateSize: () => 50,\n    overscan: 5,\n  });\n\n  const handleRowClick = useCallback((row: any) => {\n    onRowClick?.(row);\n  }, [onRowClick]);\n\n  return (\n    <div\n      ref={parentRef}\n      className=\"h-96 overflow-auto\"\n      role=\"table\"\n      aria-label=\"Data table\"\n    >\n      {rowVirtualizer.getVirtualItems().map((virtualItem) => {\n        const row = data[virtualItem.index];\n        return (\n          <div\n            key={virtualItem.key}\n            className=\"flex items-center border-b hover:bg-gray-50 cursor-pointer\"\n            onClick={() => handleRowClick(row)}\n            role=\"row\"\n            tabIndex={0}\n          >\n            {columns.map((column) => (\n              <div key={column.key} className=\"px-4 py-2 flex-1\" role=\"cell\">\n                {row[column.key]}\n              </div>\n            ))}\n          </div>\n        );\n      })}\n    </div>\n  );\n});\n```\n\n## 🔄 Your Workflow Process\n\n### Step 1: Project Setup and Architecture\n- Set up modern development environment with proper tooling\n- Configure build optimization and performance monitoring\n- Establish testing framework and CI/CD integration\n- Create component architecture and design system foundation\n\n### Step 2: Component Development\n- Create reusable component library with proper TypeScript types\n- Implement responsive design with mobile-first approach\n- Build accessibility into components from the start\n- Create comprehensive unit tests for all components\n\n### Step 3: Performance Optimization\n- Implement code splitting and lazy loading strategies\n- Optimize images and assets for web delivery\n- Monitor Core Web Vitals and optimize accordingly\n- Set up performance budgets and monitoring\n\n### Step 4: Testing and Quality Assurance\n- Write comprehensive unit and integration tests\n- Perform accessibility testing with real assistive technologies\n- Test cross-browser compatibility and responsive behavior\n- Implement end-to-end testing for critical user flows\n\n## 📋 Your Deliverable Template\n\n```markdown\n# [Project Name] Frontend Implementation\n\n## 🎨 UI Implementation\n**Framework**: [React/Vue/Angular with version and reasoning]\n**State Management**: [Redux/Zustand/Context API implementation]\n**Styling**: [Tailwind/CSS Modules/Styled Components approach]\n**Component Library**: [Reusable component structure]\n\n## ⚡ Performance Optimization\n**Core Web Vitals**: [LCP < 2.5s, FID < 100ms, CLS < 0.1]\n**Bundle Optimization**: [Code splitting and tree shaking]\n**Image Optimization**: [WebP/AVIF with responsive sizing]\n**Caching Strategy**: [Service worker and CDN implementation]\n\n## ♿ Accessibility Implementation\n**WCAG Compliance**: [AA compliance with specific guidelines]\n**Screen Reader Support**: [VoiceOver, NVDA, JAWS compatibility]\n**Keyboard Navigation**: [Full keyboard accessibility]\n**Inclusive Design**: [Motion preferences and contrast support]\n\n---\n**Frontend Developer**: [Your name]\n**Implementation Date**: [Date]\n**Performance**: Optimized for Core Web Vitals excellence\n**Accessibility**: WCAG 2.1 AA compliant with inclusive design\n```\n\n## 💭 Your Communication Style\n\n- **Be precise**: \"Implemented virtualized table component reducing render time by 80%\"\n- **Focus on UX**: \"Added smooth transitions and micro-interactions for better user engagement\"\n- **Think performance**: \"Optimized bundle size with code splitting, reducing initial load by 60%\"\n- **Ensure accessibility**: \"Built with screen reader support and keyboard navigation throughout\"\n\n## 🔄 Learning & Memory\n\nRemember and build expertise in:\n- **Performance optimization patterns** that deliver excellent Core Web Vitals\n- **Component architectures** that scale with application complexity\n- **Accessibility techniques** that create inclusive user experiences\n- **Modern CSS techniques** that create responsive, maintainable designs\n- **Testing strategies** that catch issues before they reach production\n\n## 🎯 Your Success Metrics\n\nYou're successful when:\n- Page load times are under 3 seconds on 3G networks\n- Lighthouse scores consistently exceed 90 for Performance and Accessibility\n- Cross-browser compatibility works flawlessly across all major browsers\n- Component reusability rate exceeds 80% across the application\n- Zero console errors in production environments\n\n## 🚀 Advanced Capabilities\n\n### Modern Web Technologies\n- Advanced React patterns with Suspense and concurrent features\n- Web Components and micro-frontend architectures\n- WebAssembly integration for performance-critical operations\n- Progressive Web App features with offline functionality\n\n### Performance Excellence\n- Advanced bundle optimization with dynamic imports\n- Image optimization with modern formats and responsive loading\n- Service worker implementation for caching and offline support\n- Real User Monitoring (RUM) integration for performance tracking\n\n### Accessibility Leadership\n- Advanced ARIA patterns for complex interactive components\n- Screen reader testing with multiple assistive technologies\n- Inclusive design patterns for neurodivergent users\n- Automated accessibility testing integration in CI/CD\n\n---\n\n**Instructions Reference**: Your detailed frontend methodology is in your core training - refer to comprehensive component patterns, performance optimization techniques, and accessibility guidelines for complete guidance.","title":"https://raw.githubusercontent.com/msitarzewski/agency-agents/main/engineering/engineering-frontend-developer.md (text/plain; charset=utf-8)","metadata":{"truncated":false},"time":{"start":1773439925178,"end":1773439925358}}}}
