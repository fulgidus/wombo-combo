{"type":"tool_use","timestamp":1773440122286,"sessionID":"ses_316bba7bfffeeA1IqckNkl9JmJ","part":{"id":"prt_ce944b97f001uTykHz0zqMjpTY","sessionID":"ses_316bba7bfffeeA1IqckNkl9JmJ","messageID":"msg_ce944abf2001edoOT1rzoQBo11","type":"tool","callID":"toolu_vrtx_019JivWT7S3vFURD4AwFo91h","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/dynamic-agent-types/src/lib/format-converter.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/dynamic-agent-types/src/lib/format-converter.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * format-converter.ts — Convert agency-agents definition format to woco agent\n3:  * template format.\n4:  *\n5:  * The agency-agents registry (github.com/msitarzewski/agency-agents) uses a\n6:  * different markdown structure than woco's generalist-agent.md template:\n7:  *\n8:  *   Agency-agents frontmatter:\n9:  *     name, description, color, emoji, vibe\n10:  *\n11:  *   Woco frontmatter:\n12:  *     description (long-form with examples), mode (primary)\n13:  *\n14:  * This module detects the agency-agents format and converts it to a form\n15:  * compatible with the patchImportedAgent() pipeline in templates.ts. The\n16:  * converted output preserves the specialized agent's personality and domain\n17:  * expertise while conforming to woco's expected structure.\n18:  *\n19:  * Usage:\n20:  *   Called automatically by patchImportedAgent() when the raw agent content\n21:  *   is detected as agency-agents format. No manual invocation needed.\n22:  */\n23: \n24: import YAML from \"yaml\";\n25: \n26: // ---------------------------------------------------------------------------\n27: // Types\n28: // ---------------------------------------------------------------------------\n29: \n30: /**\n31:  * Parsed representation of an agency-agents frontmatter.\n32:  * Fields match the schema used in msitarzewski/agency-agents.\n33:  */\n34: export interface AgencyAgentFrontmatter {\n35:   /** Human-readable agent name, e.g. \"Frontend Developer\" */\n36:   name: string;\n37:   /** Short description of the agent's expertise */\n38:   description: string;\n39:   /** Terminal color identifier, e.g. \"cyan\" */\n40:   color?: string;\n41:   /** Emoji representing the agent, e.g. \"🖥️\" */\n42:   emoji?: string;\n43:   /** Short personality tagline, e.g. \"Builds responsive, accessible web apps...\" */\n44:   vibe?: string;\n45: }\n46: \n47: /**\n48:  * Parsed sections from an agency-agents markdown body.\n49:  * All fields are optional — not every agent has every section.\n50:  */\n51: export interface AgencyAgentSections {\n52:   /** The agent personality intro paragraph(s) */\n53:   identity?: string;\n54:   /** Core mission / primary responsibilities */\n55:   coreMission?: string;\n56:   /** Critical rules the agent must follow */\n57:   criticalRules?: string;\n58:   /** Technical deliverables (code examples, templates) */\n59:   deliverables?: string;\n60:   /** Workflow process steps */\n61:   workflow?: string;\n62:   /** Communication style guidelines */\n63:   communicationStyle?: string;\n64:   /** Success metrics */\n65:   successMetrics?: string;\n66:   /** Advanced capabilities */\n67:   advancedCapabilities?: string;\n68:   /** Any remaining body content not matched to known sections */\n69:   remaining?: string;\n70: }\n71: \n72: /**\n73:  * Full parsed agency-agents definition.\n74:  */\n75: export interface ParsedAgencyAgent {\n76:   frontmatter: AgencyAgentFrontmatter;\n77:   sections: AgencyAgentSections;\n78:   /** Raw body content (everything after frontmatter) */\n79:   rawBody: string;\n80: }\n81: \n82: // ---------------------------------------------------------------------------\n83: // Format Detection\n84: // ---------------------------------------------------------------------------\n85: \n86: /**\n87:  * Detect whether raw markdown content is in agency-agents format.\n88:  *\n89:  * Heuristics:\n90:  *   1. Has YAML frontmatter with `name` field (woco uses `mode`, not `name`)\n91:  *   2. Frontmatter contains `color` or `emoji` or `vibe` (agency-agents specific)\n92:  *   3. Does NOT have `mode` in frontmatter (woco-specific)\n93:  *\n94:  * @param rawMd — raw markdown content to check\n95:  * @returns true if the content appears to be in agency-agents format\n96:  */\n97: export function isAgencyAgentFormat(rawMd: string): boolean {\n98:   const trimmed = rawMd.trimStart();\n99:   if (!trimmed.startsWith(\"---\")) return false;\n100: \n101:   const endIdx = trimmed.indexOf(\"---\", 3);\n102:   if (endIdx === -1) return false;\n103: \n104:   const fmBlock = trimmed.slice(3, endIdx);\n105: \n106:   try {\n107:     const parsed = YAML.parse(fmBlock);\n108:     if (!parsed || typeof parsed !== \"object\") return false;\n109: \n110:     // Agency-agents format has `name` in frontmatter; woco has `mode`\n111:     const hasName = typeof parsed.name === \"string\" && parsed.name.length > 0;\n112:     const hasMode = \"mode\" in parsed;\n113: \n114:     // If it already has `mode`, it's likely already in woco format (or patched)\n115:     if (hasMode) return false;\n116: \n117:     // Agency-agents specific fields\n118:     const hasAgencyFields =\n119:       \"color\" in parsed || \"emoji\" in parsed || \"vibe\" in parsed;\n120: \n121:     return hasName || hasAgencyFields;\n122:   } catch {\n123:     return false;\n124:   }\n125: }\n126: \n127: // ---------------------------------------------------------------------------\n128: // Parsing\n129: // ---------------------------------------------------------------------------\n130: \n131: /**\n132:  * Parse raw agency-agents markdown into structured form.\n133:  *\n134:  * @param rawMd — raw markdown content in agency-agents format\n135:  * @returns parsed representation, or null if parsing fails\n136:  */\n137: export function parseAgencyAgent(rawMd: string): ParsedAgencyAgent | null {\n138:   const trimmed = rawMd.trimStart();\n139:   if (!trimmed.startsWith(\"---\")) return null;\n140: \n141:   const endIdx = trimmed.indexOf(\"---\", 3);\n142:   if (endIdx === -1) return null;\n143: \n144:   const fmBlock = trimmed.slice(3, endIdx);\n145:   // Body starts after the closing --- and any trailing newline\n146:   const afterFm = trimmed.slice(endIdx + 3);\n147:   const rawBody = afterFm.startsWith(\"\\n\") ? afterFm.slice(1) : afterFm;\n148: \n149:   let parsed: Record<string, unknown>;\n150:   try {\n151:     parsed = YAML.parse(fmBlock);\n152:     if (!parsed || typeof parsed !== \"object\") return null;\n153:   } catch {\n154:     return null;\n155:   }\n156: \n157:   const frontmatter: AgencyAgentFrontmatter = {\n158:     name: String(parsed.name ?? \"Specialized Agent\"),\n159:     description: String(parsed.description ?? \"\"),\n160:     color: parsed.color != null ? String(parsed.color) : undefined,\n161:     emoji: parsed.emoji != null ? String(parsed.emoji) : undefined,\n162:     vibe: parsed.vibe != null ? String(parsed.vibe) : undefined,\n163:   };\n164: \n165:   const sections = extractSections(rawBody);\n166: \n167:   return { frontmatter, sections, rawBody };\n168: }\n169: \n170: /**\n171:  * Extract known sections from the agency-agents body.\n172:  *\n173:  * Agency-agents use h2 (##) headers with emoji prefixes to delimit sections.\n174:  * We extract the ones we care about for mapping, and collect the rest.\n175:  */\n176: function extractSections(body: string): AgencyAgentSections {\n177:   const sections: AgencyAgentSections = {};\n178: \n179:   // Split body into sections by h2 headers (## ...)\n180:   // Keep h1 headers attached to identity section\n181:   const h2Pattern = /^## .+$/gm;\n182:   const h2Matches: Array<{ heading: string; startIdx: number }> = [];\n183: \n184:   let match: RegExpExecArray | null;\n185:   while ((match = h2Pattern.exec(body)) !== null) {\n186:     h2Matches.push({ heading: match[0], startIdx: match.index });\n187:   }\n188: \n189:   // Everything before first h2 is identity/intro\n190:   if (h2Matches.length > 0) {\n191:     const identityContent = body.slice(0, h2Matches[0].startIdx).trim();\n192:     if (identityContent) {\n193:       sections.identity = identityContent;\n194:     }\n195:   } else {\n196:     // No h2 headers — everything is identity\n197:     sections.identity = body.trim();\n198:     return sections;\n199:   }\n200: \n201:   // Process each h2 section\n202:   const remainingParts: string[] = [];\n203: \n204:   for (let i = 0; i < h2Matches.length; i++) {\n205:     const { heading, startIdx } = h2Matches[i];\n206:     const endIdx = i + 1 < h2Matches.length ? h2Matches[i + 1].startIdx : body.length;\n207:     const sectionContent = body.slice(startIdx, endIdx).trim();\n208:     const headingLower = heading.toLowerCase();\n209: \n210:     if (matchesSection(headingLower, [\"identity\", \"memory\"])) {\n211:       sections.identity = joinContent(sections.identity, sectionContent);\n212:     } else if (matchesSection(headingLower, [\"core mission\", \"mission\", \"responsibilities\"])) {\n213:       sections.coreMission = joinContent(sections.coreMission, sectionContent);\n214:     } else if (matchesSection(headingLower, [\"critical rules\", \"rules you must follow\", \"constraints\"])) {\n215:       sections.criticalRules = joinContent(sections.criticalRules, sectionContent);\n216:     } else if (matchesSection(headingLower, [\"deliverable\", \"technical deliverable\"])) {\n217:       sections.deliverables = joinContent(sections.deliverables, sectionContent);\n218:     } else if (matchesSection(headingLower, [\"workflow\", \"process\"])) {\n219:       sections.workflow = joinContent(sections.workflow, sectionContent);\n220:     } else if (matchesSection(headingLower, [\"communication style\", \"communication\"])) {\n221:       sections.communicationStyle = joinContent(sections.communicationStyle, sectionContent);\n222:     } else if (matchesSection(headingLower, [\"success metrics\", \"metrics\"])) {\n223:       sections.successMetrics = joinContent(sections.successMetrics, sectionContent);\n224:     } else if (matchesSection(headingLower, [\"advanced capabilities\", \"capabilities\"])) {\n225:       sections.advancedCapabilities = joinContent(sections.advancedCapabilities, sectionContent);\n226:     } else {\n227:       remainingParts.push(sectionContent);\n228:     }\n229:   }\n230: \n231:   if (remainingParts.length > 0) {\n232:     sections.remaining = remainingParts.join(\"\\n\\n\");\n233:   }\n234: \n235:   return sections;\n236: }\n237: \n238: /**\n239:  * Check if a heading matches any of the given keyword patterns.\n240:  */\n241: function matchesSection(headingLower: string, keywords: string[]): boolean {\n242:   return keywords.some((kw) => headingLower.includes(kw));\n243: }\n244: \n245: /**\n246:  * Join existing content with new content, separated by double newline.\n247:  */\n248: function joinContent(existing: string | undefined, newContent: string): string {\n249:   if (!existing) return newContent;\n250:   return existing + \"\\n\\n\" + newContent;\n251: }\n252: \n253: // ---------------------------------------------------------------------------\n254: // Conversion\n255: // ---------------------------------------------------------------------------\n256: \n257: /**\n258:  * Convert an agency-agents definition to woco-compatible agent markdown.\n259:  *\n260:  * The output follows the structure expected by patchImportedAgent() in\n261:  * templates.ts:\n262:  *   - YAML frontmatter with `description` and `mode: primary`\n263:  *   - Markdown body with the agent's specialized content\n264:  *\n265:  * The conversion:\n266:  *   1. Transforms frontmatter: name/description/vibe → description, adds mode\n267:  *   2. Restructures body: preserves specialized content, strips emoji headers,\n268:  *      reflows into a clean structure\n269:  *   3. Preserves all domain expertise and personality\n270:  *\n271:  * The patching pipeline (wc-patch.body.start/end, portless/TDD injection,\n272:  * placeholder substitution) runs AFTER this conversion, adding wombo-combo\n273:  * operational context around the converted content.\n274:  *\n275:  * @param agent — parsed agency-agents definition\n276:  * @returns markdown string in woco-compatible format\n277:  */\n278: export function convertAgencyToWoco(agent: ParsedAgencyAgent): string {\n279:   // --- Build woco-style description ---\n280:   const descParts: string[] = [];\n281:   descParts.push(agent.frontmatter.description);\n282:   if (agent.frontmatter.vibe) {\n283:     descParts.push(agent.frontmatter.vibe);\n284:   }\n285:   const wocoDescription = descParts.join(\" \").trim();\n286: \n287:   // --- Build frontmatter ---\n288:   const fmObj: Record<string, string> = {\n289:     description: wocoDescription,\n290:     mode: \"primary\",\n291:   };\n292:   const fmYaml = YAML.stringify(fmObj, { lineWidth: 0 }).trimEnd();\n293: \n294:   // --- Build body ---\n295:   const bodyParts: string[] = [];\n296: \n297:   // Agent role preamble — preserve the identity/personality\n298:   const agentName = agent.frontmatter.name;\n299:   bodyParts.push(\n300:     `You are **${agentName}**, a specialized agent with domain expertise.`\n301:   );\n302: \n303:   // Identity section\n304:   if (agent.sections.identity) {\n305:     bodyParts.push(\"\");\n306:     bodyParts.push(cleanEmojiHeaders(agent.sections.identity));\n307:   }\n308: \n309:   // Core mission\n310:   if (agent.sections.coreMission) {\n311:     bodyParts.push(\"\");\n312:     bodyParts.push(cleanEmojiHeaders(agent.sections.coreMission));\n313:   }\n314: \n315:   // Critical rules\n316:   if (agent.sections.criticalRules) {\n317:     bodyParts.push(\"\");\n318:     bodyParts.push(cleanEmojiHeaders(agent.sections.criticalRules));\n319:   }\n320: \n321:   // Workflow\n322:   if (agent.sections.workflow) {\n323:     bodyParts.push(\"\");\n324:     bodyParts.push(cleanEmojiHeaders(agent.sections.workflow));\n325:   }\n326: \n327:   // Deliverables\n328:   if (agent.sections.deliverables) {\n329:     bodyParts.push(\"\");\n330:     bodyParts.push(cleanEmojiHeaders(agent.sections.deliverables));\n331:   }\n332: \n333:   // Communication style\n334:   if (agent.sections.communicationStyle) {\n335:     bodyParts.push(\"\");\n336:     bodyParts.push(cleanEmojiHeaders(agent.sections.communicationStyle));\n337:   }\n338: \n339:   // Advanced capabilities\n340:   if (agent.sections.advancedCapabilities) {\n341:     bodyParts.push(\"\");\n342:     bodyParts.push(cleanEmojiHeaders(agent.sections.advancedCapabilities));\n343:   }\n344: \n345:   // Success metrics\n346:   if (agent.sections.successMetrics) {\n347:     bodyParts.push(\"\");\n348:     bodyParts.push(cleanEmojiHeaders(agent.sections.successMetrics));\n349:   }\n350: \n351:   // Remaining sections\n352:   if (agent.sections.remaining) {\n353:     bodyParts.push(\"\");\n354:     bodyParts.push(cleanEmojiHeaders(agent.sections.remaining));\n355:   }\n356: \n357:   const body = bodyParts.join(\"\\n\") + \"\\n\";\n358: \n359:   return `---\\n${fmYaml}\\n---\\n${body}`;\n360: }\n361: \n362: /**\n363:  * Clean emoji prefixes from markdown headers.\n364:  *\n365:  * Agency-agents use emoji-prefixed headers like:\n366:  *   ## 🧠 Your Identity & Memory\n367:  *   ## 🎯 Your Core Mission\n368:  *\n369:  * These are cleaned to plain headers:\n370:  *   ## Your Identity & Memory\n371:  *   ## Your Core Mission\n372:  *\n373:  * This avoids confusing the LLM with decorative emoji in operational headers.\n374:  */\n375: function cleanEmojiHeaders(content: string): string {\n376:   // Match h1-h4 headers with emoji prefixes\n377:   // Emoji pattern: unicode emoji chars followed by optional space\n378:   return content.replace(\n379:     /^(#{1,4})\\s+[\\u{1F300}-\\u{1FAFF}\\u{2600}-\\u{27BF}\\u{FE00}-\\u{FE0F}\\u{200D}\\u{20E3}\\u{E0020}-\\u{E007F}]+\\s*/gmu,\n380:     \"$1 \"\n381:   );\n382: }\n383: \n384: // ---------------------------------------------------------------------------\n385: // Convenience: Detect + Convert\n386: // ---------------------------------------------------------------------------\n387: \n388: /**\n389:  * If the raw markdown is in agency-agents format, convert it to woco format.\n390:  * Otherwise return it unchanged.\n391:  *\n392:  * This is the primary entry point used by patchImportedAgent() to ensure\n393:  * all imported agent definitions are in a compatible format before patching.\n394:  *\n395:  * @param rawMd — raw markdown content (may be agency-agents or woco format)\n396:  * @returns markdown in woco-compatible format\n397:  */\n398: export function normalizeAgentFormat(rawMd: string): string {\n399:   if (!isAgencyAgentFormat(rawMd)) {\n400:     return rawMd;\n401:   }\n402: \n403:   const parsed = parseAgencyAgent(rawMd);\n404:   if (!parsed) {\n405:     // Parsing failed — return as-is and let patchImportedAgent handle it\n406:     return rawMd;\n407:   }\n408: \n409:   return convertAgencyToWoco(parsed);\n410: }\n\n(End of file - total 410 lines)\n</content>","title":"src/lib/format-converter.ts","metadata":{"preview":"/**\n * format-converter.ts — Convert agency-agents definition format to woco agent\n * template format.\n *\n * The agency-agents registry (github.com/msitarzewski/agency-agents) uses a\n * different markdown structure than woco's generalist-agent.md template:\n *\n *   Agency-agents frontmatter:\n *     name, description, color, emoji, vibe\n *\n *   Woco frontmatter:\n *     description (long-form with examples), mode (primary)\n *\n * This module detects the agency-agents format and converts it to a form\n * compatible with the patchImportedAgent() pipeline in templates.ts. The\n * converted output preserves the specialized agent's personality and domain\n * expertise while conforming to woco's expected structure.\n *\n * Usage:\n *   Called automatically by patchImportedAgent() when the raw agent content","truncated":false,"loaded":[]},"time":{"start":1773440122280,"end":1773440122285}}}}
