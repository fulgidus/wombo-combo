rce":"typescript"},{"range":{"start":{"line":30,"character":2},"end":{"line":30,"character":15}},"message":"'getArchiveDir' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"},{"range":{"start":{"line":31,"character":2},"end":{"line":31,"character":14}},"message":"'saveTaskFile' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"},{"range":{"start":{"line":32,"character":2},"end":{"line":32,"character":16}},"message":"'deleteTaskFile' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"},{"range":{"start":{"line":189,"character":9},"end":{"line":189,"character":18}},"message":"'womboPath' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"},{"range":{"start":{"line":651,"character":38},"end":{"line":651,"character":57}},"message":"'TASKS_TEMPLATE_PATH' is deprecated.","severity":4,"code":6385,"source":"typescript","relatedInformation":[{"location":{"uri":"file:///home/fulgidus/Documents/wombo-combo-worktrees/dynamic-agent-types/src/lib/tasks.ts","range":{"start":{"line":40,"character":4},"end":{"line":40,"character":87}}},"message":"The declaration was marked as deprecated here."}]}],"/home/fulgidus/Documents/wombo-combo-worktrees/dynamic-agent-types/src/lib/prompt.ts":[],"/home/fulgidus/Documents/wombo-combo-worktrees/dynamic-agent-types/src/config.ts":[],"/home/fulgidus/Documents/wombo-combo-worktrees/dynamic-agent-types/src/lib/templates.ts":[],"/home/fulgidus/Documents/wombo-combo-worktrees/dynamic-agent-types/src/index.ts":[{"range":{"start":{"line":621,"character":10},"end":{"line":621,"character":16}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":641,"character":8},"end":{"line":641,"character":14}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":671,"character":6},"end":{"line":671,"