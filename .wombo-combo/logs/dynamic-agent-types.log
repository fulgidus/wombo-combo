{"type":"tool_use","timestamp":1773440194580,"sessionID":"ses_316bba7bfffeeA1IqckNkl9JmJ","part":{"id":"prt_ce945d77b002zw0y3d4p4AW3dt","sessionID":"ses_316bba7bfffeeA1IqckNkl9JmJ","messageID":"msg_ce945cd8b001hLFAV1Sqpcn5TD","type":"tool","callID":"toolu_vrtx_012frbjxWyTn72Q6as2vQqss","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/dynamic-agent-types/src/lib/state.ts","offset":100},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/dynamic-agent-types/src/lib/state.ts</path>\n<type>file</type>\n<content>100: // Wave ID Generation\n101: // ---------------------------------------------------------------------------\n102: \n103: /**\n104:  * Generate a unique wave ID based on current timestamp.\n105:  * Format: wave-YYYY-MM-DD-NNN\n106:  */\n107: export function generateWaveId(): string {\n108:   const now = new Date();\n109:   const date = now.toISOString().slice(0, 10);\n110:   const seq = String(now.getHours() * 60 + now.getMinutes()).padStart(3, \"0\");\n111:   return `wave-${date}-${seq}`;\n112: }\n113: \n114: // ---------------------------------------------------------------------------\n115: // State Path\n116: // ---------------------------------------------------------------------------\n117: \n118: function statePath(projectRoot: string): string {\n119:   return resolve(projectRoot, STATE_FILE);\n120: }\n121: \n122: // ---------------------------------------------------------------------------\n123: // Read State\n124: // ---------------------------------------------------------------------------\n125: \n126: /**\n127:  * Load the current wave state from disk. Returns null if no state file exists.\n128:  */\n129: export function loadState(projectRoot: string): WaveState | null {\n130:   const p = statePath(projectRoot);\n131:   if (!existsSync(p)) return null;\n132:   try {\n133:     const raw = readFileSync(p, \"utf-8\");\n134:     return JSON.parse(raw) as WaveState;\n135:   } catch {\n136:     return null;\n137:   }\n138: }\n139: \n140: // ---------------------------------------------------------------------------\n141: // Write State\n142: // ---------------------------------------------------------------------------\n143: \n144: /**\n145:  * Save wave state to disk atomically (write to tmp then rename).\n146:  */\n147: export function saveState(projectRoot: string, state: WaveState): void {\n148:   const dir = resolve(projectRoot, WOMBO_DIR);\n149:   if (!existsSync(dir)) mkdirSync(dir, { recursive: true });\n150:   state.updated_at = new Date().toISOString();\n151:   const p = statePath(projectRoot);\n152:   const tmp = p + \".tmp\";\n153:   writeFileSync(tmp, JSON.stringify(state, null, 2) + \"\\n\", \"utf-8\");\n154:   renameSync(tmp, p);\n155: }\n156: \n157: // ---------------------------------------------------------------------------\n158: // State Mutations\n159: // ---------------------------------------------------------------------------\n160: \n161: /**\n162:  * Create a fresh wave state.\n163:  */\n164: export function createWaveState(opts: {\n165:   baseBranch: string;\n166:   maxConcurrent: number;\n167:   model: string | null;\n168:   interactive: boolean;\n169: }): WaveState {\n170:   return {\n171:     wave_id: generateWaveId(),\n172:     base_branch: opts.baseBranch,\n173:     started_at: new Date().toISOString(),\n174:     updated_at: new Date().toISOString(),\n175:     max_concurrent: opts.maxConcurrent,\n176:     model: opts.model,\n177:     interactive: opts.interactive,\n178:     agents: [],\n179:     schedule_plan: null,\n180:   };\n181: }\n182: \n183: /**\n184:  * Create an initial agent state for a feature.\n185:  */\n186: export function createAgentState(\n187:   featureId: string,\n188:   branch: string,\n189:   worktreePath: string,\n190:   maxRetries: number = 2\n191: ): AgentState {\n192:   return {\n193:     feature_id: featureId,\n194:     branch,\n195:     worktree: worktreePath,\n196:     session_id: null,\n197:     pid: null,\n198:     status: \"queued\",\n199:     activity: null,\n200:     activity_updated_at: null,\n201:     retries: 0,\n202:     max_retries: maxRetries,\n203:     started_at: null,\n204:     completed_at: null,\n205:     build_passed: null,\n206:     build_output: null,\n207:     error: null,\n208:     effort_estimate_ms: null,\n209:     stream_index: null,\n210:     depends_on: [],\n211:     depended_on_by: [],\n212:     agent_name: null,\n213:     agent_type: null,\n214:   };\n215: }\n216: \n217: /**\n218:  * Find an agent state by feature ID.\n219:  */\n220: export function getAgent(\n221:   state: WaveState,\n222:   featureId: string\n223: ): AgentState | undefined {\n224:   return state.agents.find((a) => a.feature_id === featureId);\n225: }\n226: \n227: /**\n228:  * Update an agent's state fields.\n229:  */\n230: export function updateAgent(\n231:   state: WaveState,\n232:   featureId: string,\n233:   updates: Partial<AgentState>\n234: ): void {\n235:   const agent = state.agents.find((a) => a.feature_id === featureId);\n236:   if (!agent) throw new Error(`Agent not found for feature: ${featureId}`);\n237:   Object.assign(agent, updates);\n238: }\n239: \n240: /**\n241:  * Get counts of agents by status.\n242:  */\n243: export function agentCounts(state: WaveState): Record<AgentStatus, number> {\n244:   const counts: Record<AgentStatus, number> = {\n245:     queued: 0,\n246:     installing: 0,\n247:     running: 0,\n248:     completed: 0,\n249:     verified: 0,\n250:     failed: 0,\n251:     merged: 0,\n252:     retry: 0,\n253:     resolving_conflict: 0,\n254:   };\n255:   for (const a of state.agents) {\n256:     counts[a.status]++;\n257:   }\n258:   return counts;\n259: }\n260: \n261: /**\n262:  * Get agents that are currently running or installing.\n263:  */\n264: export function activeAgents(state: WaveState): AgentState[] {\n265:   return state.agents.filter(\n266:     (a) => a.status === \"running\" || a.status === \"installing\" || a.status === \"resolving_conflict\"\n267:   );\n268: }\n269: \n270: /**\n271:  * Get agents that are queued and ready to be launched.\n272:  */\n273: export function queuedAgents(state: WaveState): AgentState[] {\n274:   return state.agents.filter((a) => a.status === \"queued\");\n275: }\n276: \n277: /**\n278:  * Check if the wave is fully complete (no queued, installing, running, or retry agents).\n279:  */\n280: export function isWaveComplete(state: WaveState): boolean {\n281:   return state.agents.every(\n282:     (a) =>\n283:       a.status === \"completed\" ||\n284:       a.status === \"verified\" ||\n285:       a.status === \"failed\" ||\n286:       a.status === \"merged\"\n287:   );\n288: }\n289: \n290: // ---------------------------------------------------------------------------\n291: // Dependency-Aware Helpers\n292: // ---------------------------------------------------------------------------\n293: \n294: /**\n295:  * Terminal statuses that count as \"dependency satisfied\" for downstream features.\n296:  * A dependency is satisfied when it has been verified or merged.\n297:  */\n298: const DEP_SATISFIED_STATUSES: Set<AgentStatus> = new Set([\"verified\", \"merged\"]);\n299: \n300: /**\n301:  * Check if an agent's dependencies within the wave are all satisfied.\n302:  * Dependencies are satisfied when their agents reach \"verified\" or \"merged\" status.\n303:  *\n304:  * If the agent has no depends_on entries, it's always ready.\n305:  */\n306: export function areAgentDepsReady(\n307:   state: WaveState,\n308:   agent: AgentState\n309: ): boolean {\n310:   if (agent.depends_on.length === 0) return true;\n311: \n312:   for (const depId of agent.depends_on) {\n313:     const depAgent = state.agents.find((a) => a.feature_id === depId);\n314:     if (depAgent && !DEP_SATISFIED_STATUSES.has(depAgent.status)) {\n315:       return false;\n316:     }\n317:     // If depAgent doesn't exist in this wave, the dep is external — assumed satisfied\n318:   }\n319:   return true;\n320: }\n321: \n322: /**\n323:  * Get queued agents whose dependencies are all satisfied.\n324:  * This is the dependency-aware replacement for plain queuedAgents().\n325:  */\n326: export function readyToLaunchAgents(state: WaveState): AgentState[] {\n327:   return state.agents.filter(\n328:     (a) => a.status === \"queued\" && areAgentDepsReady(state, a)\n329:   );\n330: }\n331: \n332: /**\n333:  * Get all agents that are downstream (depend on) a given feature, directly or transitively.\n334:  * Used for failure cascading — when a feature fails, cancel all downstream.\n335:  */\n336: export function getDownstreamAgents(\n337:   state: WaveState,\n338:   featureId: string\n339: ): AgentState[] {\n340:   const visited = new Set<string>();\n341:   const result: AgentState[] = [];\n342: \n343:   function collect(id: string): void {\n344:     const agent = state.agents.find((a) => a.feature_id === id);\n345:     if (!agent) return;\n346: \n347:     for (const downstreamId of agent.depended_on_by) {\n348:       if (visited.has(downstreamId)) continue;\n349:       visited.add(downstreamId);\n350: \n351:       const downstream = state.agents.find((a) => a.feature_id === downstreamId);\n352:       if (downstream) {\n353:         result.push(downstream);\n354:         collect(downstreamId);\n355:       }\n356:     }\n357:   }\n358: \n359:   collect(featureId);\n360:   return result;\n361: }\n362: \n363: /**\n364:  * Cancel all downstream agents when an upstream dependency fails.\n365:  * Sets status to \"failed\" with an error explaining the dependency failure.\n366:  * Returns the list of cancelled agent IDs.\n367:  */\n368: export function cancelDownstream(\n369:   state: WaveState,\n370:   failedFeatureId: string\n371: ): string[] {\n372:   const downstream = getDownstreamAgents(state, failedFeatureId);\n373:   const cancelled: string[] = [];\n374: \n375:   for (const agent of downstream) {\n376:     // Only cancel agents that haven't already reached a terminal state\n377:     if (\n378:       agent.status === \"queued\" ||\n379:       agent.status === \"installing\" ||\n380:       agent.status === \"running\" ||\n381:       agent.status === \"retry\"\n382:     ) {\n383:       updateAgent(state, agent.feature_id, {\n384:         status: \"failed\",\n385:         error: `Dependency \"${failedFeatureId}\" failed — downstream cancelled`,\n386:         activity: null,\n387:         completed_at: new Date().toISOString(),\n388:       });\n389:       cancelled.push(agent.feature_id);\n390:     }\n391:   }\n392: \n393:   return cancelled;\n394: }\n\n(End of file - total 394 lines)\n</content>","title":"src/lib/state.ts","metadata":{"preview":"// Wave ID Generation\n// ---------------------------------------------------------------------------\n\n/**\n * Generate a unique wave ID based on current timestamp.\n * Format: wave-YYYY-MM-DD-NNN\n */\nexport function generateWaveId(): string {\n  const now = new Date();\n  const date = now.toISOString().slice(0, 10);\n  const seq = String(now.getHours() * 60 + now.getMinutes()).padStart(3, \"0\");\n  return `wave-${date}-${seq}`;\n}\n\n// ---------------------------------------------------------------------------\n// State Path\n// ---------------------------------------------------------------------------\n\nfunction statePath(projectRoot: string): string {\n  return resolve(projectRoot, STATE_FILE);","truncated":false,"loaded":[]},"time":{"start":1773440194577,"end":1773440194580}}}}
{"type":"tool_use","timestamp":1773440198302,"sessionID":"ses_316bba7bfffeeA1IqckNkl9JmJ","part":{"id":"prt_ce945e5be00180Qs5F62H9j5zB","sessionID":"ses_316bba7bfffeeA1IqckNkl9JmJ","messageID":"msg_ce945cd8b001hLFAV1Sqpcn5TD","type":"tool","callID":"toolu_vrtx_01AX1GkgRvpRYAW95n35GTCz","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/dynamic-agent-types/src/commands/launch.ts","offset":1420},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/dynamic-agent-types/src/commands/launch.ts</path>\n<type>file</type>\n<content>1420:         for (const agent of merged) {\n1421:           markFeatureDone(projectRoot, agent.feature_id, config, existingState.base_branch);\n1422:           // Clean up worktree and branch (already merged, safe to delete)\n1423:           try {\n1424:             removeWorktree(projectRoot, agent.worktree, true);\n1425:             if (fmt === \"text\") console.log(`  ${agent.feature_id}: marked done, worktree removed`);\n1426:           } catch {\n1427:             if (fmt === \"text\") console.log(`  ${agent.feature_id}: marked done (worktree already cleaned)`);\n1428:           }\n1429:         }\n1430:       }\n1431: \n1432:       // Verified agents: build passed but NOT merged — do NOT mark done.\n1433:       // Leave them for 'woco resume' to attempt the merge.\n1434:       if (verified.length > 0) {\n1435:         for (const agent of verified) {\n1436:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: verified (not yet merged) — use 'woco resume' to merge`);\n1437:         }\n1438:       }\n1439: \n1440:       const activeCount = running.length + completed.length + queued.length;\n1441:       if (activeCount > 0) {\n1442:         outputError(fmt, `Wave ${existingState.wave_id} has ${activeCount} unfinished agent(s). Use 'woco resume' to continue the existing wave, or 'woco cleanup' to clear it before starting a new one.`);\n1443:       }\n1444: \n1445:       // All agents are in terminal states (merged/verified/failed) — safe to start fresh\n1446:       if (fmt === \"text\") console.log(\"\\nAll agents in previous wave are finished. Starting fresh wave.\\n\");\n1447:     }\n1448:   }\n1449: \n1450:   // Load features\n1451:   const data = loadFeatures(projectRoot, config);\n1452: \n1453:   // Build selection options\n1454:   const selOpts: SelectionOptions = {};\n1455:   if (opts.topPriority) selOpts.topPriority = opts.topPriority;\n1456:   if (opts.quickestWins) selOpts.quickestWins = opts.quickestWins;\n1457:   if (opts.priority) selOpts.priority = opts.priority;\n1458:   if (opts.difficulty) selOpts.difficulty = opts.difficulty;\n1459:   if (opts.features) selOpts.taskIds = opts.features;\n1460:   if (opts.allReady) selOpts.allReady = true;\n1461: \n1462:   // Select features\n1463:   const selected = selectFeatures(data, selOpts);\n1464: \n1465:   if (selected.length === 0) {\n1466:     // Build a context-aware message based on which flags were passed\n1467:     const activeFilters: string[] = [];\n1468:     if (opts.allReady) activeFilters.push(\"--all-ready\");\n1469:     if (opts.topPriority) activeFilters.push(`--top-priority ${opts.topPriority}`);\n1470:     if (opts.quickestWins) activeFilters.push(`--quickest-wins ${opts.quickestWins}`);\n1471:     if (opts.priority) activeFilters.push(`--priority ${opts.priority}`);\n1472:     if (opts.difficulty) activeFilters.push(`--difficulty ${opts.difficulty}`);\n1473:     if (opts.features?.length) activeFilters.push(`--tasks ${opts.features.join(\",\")}`);\n1474: \n1475:     let msg: string;\n1476:     if (opts.allReady && activeFilters.length === 1) {\n1477:       msg = \"No launchable tasks found (all tasks are done, cancelled, or have unmet dependencies).\";\n1478:     } else if (activeFilters.length > 0) {\n1479:       msg = `No tasks matched the current filters: ${activeFilters.join(\", \")}.`;\n1480:     } else {\n1481:       msg = \"No launchable tasks found.\";\n1482:     }\n1483: \n1484:     outputError(fmt, msg);\n1485:   }\n1486: \n1487:   // Show selection\n1488:   if (fmt === \"text\") {\n1489:     printFeatureSelection(\n1490:       selected.map((f) => ({\n1491:         id: f.id,\n1492:         title: f.title,\n1493:         priority: f.priority,\n1494:         difficulty: f.difficulty,\n1495:         effort: f.effort,\n1496:       }))\n1497:     );\n1498:   }\n1499: \n1500:   // Check per-task agent definitions exist\n1501:   if (!opts.agent) {\n1502:     const taskAgents = new Set(\n1503:       selected.map((f) => f.agent).filter((a): a is string => !!a)\n1504:     );\n1505:     for (const agentName of taskAgents) {\n1506:       ensureAgentDefinition(projectRoot, config, agentName);\n1507:     }\n1508:   }\n1509: \n1510:   // ---------------------------------------------------------------------------\n1511:   // Dependency graph analysis\n1512:   // ---------------------------------------------------------------------------\n1513:   const depGraph = buildDepGraph(selected, data.tasks);\n1514:   let schedulePlan: SchedulePlan | null = null;\n1515: \n1516:   // Check if any features actually have dependencies within the selected set\n1517:   const hasDeps = selected.some(\n1518:     (f) => f.depends_on.some((d) => selected.find((s) => s.id === d))\n1519:   );\n1520: \n1521:   if (hasDeps) {\n1522:     // Validate graph — throws on cycles or dangling deps\n1523:     try {\n1524:       validateDepGraph(depGraph);\n1525:     } catch (err: any) {\n1526:       outputError(fmt, `${err.message}\\nFix dependency issues before launching.`);\n1527:     }\n1528: \n1529:     // Build scheduling plan\n1530:     schedulePlan = buildSchedulePlan(depGraph);\n1531:     if (fmt === \"text\") console.log(`\\n${formatSchedulePlan(schedulePlan)}\\n`);\n1532:   }\n1533: \n1534:   if (opts.dryRun) {\n1535:     const dryRunResult = {\n1536:       dry_run: true,\n1537:       base_branch: opts.baseBranch,\n1538:       max_concurrent: opts.maxConcurrent,\n1539:       model: opts.model ?? null,\n1540:       interactive: opts.interactive,\n1541:       selected: selected.map((f) => ({\n1542:         id: f.id,\n1543:         title: f.title,\n1544:         priority: f.priority,\n1545:         difficulty: f.difficulty,\n1546:         effort: f.effort,\n1547:       })),\n1548:       schedule_plan: schedulePlan ? {\n1549:         streams: schedulePlan.streams.map((s) => s.featureIds),\n1550:         merge_gates: schedulePlan.mergeGates.map((g) => ({\n1551:           feature_id: g.featureId,\n1552:           wait_for: g.waitFor,\n1553:         })),\n1554:         topological_order: schedulePlan.topologicalOrder,\n1555:       } : null,\n1556:     };\n1557: \n1558:     output(fmt, dryRunResult, () => {\n1559:       console.log(\"Dry run — not launching agents.\");\n1560:     }, () => {\n1561:       console.log(renderLaunchDryRun(dryRunResult));\n1562:     });\n1563:     return;\n1564:   }\n1565: \n1566:   // ---------------------------------------------------------------------------\n1567:   // Agent registry: resolve specialized agents for tasks with agent_type\n1568:   // ---------------------------------------------------------------------------\n1569:   let agentResolutions: Map<string, AgentResolution> | undefined;\n1570: \n1571:   if (config.agentRegistry.mode !== \"disabled\") {\n1572:     const tasksWithAgentType = selected.filter((t) => t.agent_type);\n1573:     if (tasksWithAgentType.length > 0) {\n1574:       if (fmt === \"text\") console.log(`\\nResolving ${tasksWithAgentType.length} specialized agent(s) from registry...`);\n1575:       agentResolutions = await prepareAgentDefinitions(selected, config, projectRoot);\n1576: \n1577:       const specialized = [...agentResolutions.values()].filter(isSpecializedAgent);\n1578:       const cached = specialized.filter((r) => r.fromCache);\n1579:       if (fmt === \"text\") {\n1580:         console.log(\n1581:           `  ${specialized.length} specialized (${cached.length} cached, ${specialized.length - cached.length} fetched), ` +\n1582:           `${selected.length - specialized.length} generalist`\n1583:         );\n1584:       }\n1585:     }\n1586:   }\n1587: \n1588:   // ---------------------------------------------------------------------------\n1589:   // Preflight confirmation\n1590:   // ---------------------------------------------------------------------------\n1591:   if (agentResolutions && agentResolutions.size > 0) {\n1592:     const isTTY = process.stdout.isTTY && process.stdin.isTTY;\n1593:     const preflight = isTTY && !opts.noTui\n1594:       ? await tuiPreflightConfirm(selected, agentResolutions, config)\n1595:       : await consolePreflightConfirm(selected, agentResolutions, config);\n1596: \n1597:     if (!preflight.proceed) {\n1598:       outputMessage(fmt, \"Launch cancelled.\");\n1599:       return;\n1600:     }\n1601: \n1602:     // Apply user's changes (rejected agents, mode changes)\n1603:     agentResolutions = preflight.agents;\n1604:   }\n1605: \n1606:   // Create wave state\n1607:   const state = createWaveState({\n1608:     baseBranch: opts.baseBranch,\n1609:     maxConcurrent: opts.maxConcurrent,\n1610:     model: opts.model ?? null,\n1611:     interactive: opts.interactive,\n1612:   });\n1613: \n1614:   // Store serialized schedule plan in wave state\n1615:   if (schedulePlan) {\n1616:     state.schedule_plan = {\n1617:       streams: schedulePlan.streams.map((s) => s.featureIds),\n1618:       merge_gates: schedulePlan.mergeGates.map((g) => ({\n1619:         feature_id: g.featureId,\n1620:         wait_for: g.waitFor,\n1621:       })),\n1622:       topological_order: schedulePlan.topologicalOrder,\n1623:     };\n1624:   }\n1625: \n1626:   // Create agent entries for all selected features\n1627:   const selectedIds = new Set(selected.map((f) => f.id));\n1628: \n1629:   // Build a map from feature ID → shared worktree path for chain reuse.\n1630:   // All features in the same chain share the worktree of the chain's first feature.\n1631:   const chainWorktreeMap = new Map<string, string>();\n1632:   if (schedulePlan) {\n1633:     for (const stream of schedulePlan.streams) {\n1634:       if (stream.featureIds.length > 1) {\n1635:         // All features in this chain share the first feature's worktree\n1636:         const sharedWtPath = worktreePath(projectRoot, stream.featureIds[0], config);\n1637:         for (const featureId of stream.featureIds) {\n1638:           chainWorktreeMap.set(featureId, sharedWtPath);\n1639:         }\n1640:       }\n1641:     }\n1642:   }\n1643: \n1644:   for (const feature of selected) {\n1645:     const branch = featureBranchName(feature.id, config);\n1646:     // Use shared worktree path for chain members, or individual path otherwise\n1647:     const wtPath = chainWorktreeMap.get(feature.id) ?? worktreePath(projectRoot, feature.id, config);\n1648:     const agent = createAgentState(feature.id, branch, wtPath, opts.maxRetries);\n1649: \n1650:     // Set effort estimate from feature spec\n1651:     const effortMinutes = parseDurationMinutes(feature.effort);\n1652:     agent.effort_estimate_ms = effortMinutes === Infinity ? null : effortMinutes * 60 * 1000;\n1653: \n1654:     // Populate dependency fields from the graph\n1655:     const graphNode = depGraph.nodes.get(feature.id);\n1656:     if (graphNode) {\n1657:       // Only track internal deps (within the selected set)\n1658:       agent.depends_on = graphNode.dependsOn.filter((d) => selectedIds.has(d));\n1659:       agent.depended_on_by = graphNode.dependedOnBy.filter((d) => selectedIds.has(d));\n1660:     }\n1661: \n1662:     // Set stream index\n1663:     if (schedulePlan) {\n1664:       agent.stream_index = getStreamForFeature(schedulePlan, feature.id);\n1665:     }\n1666: \n1667:     // Set specialized agent info from resolution\n1668:     const resolution = agentResolutions?.get(feature.id);\n1669:     if (resolution && isSpecializedAgent(resolution)) {\n1670:       agent.agent_name = resolution.name;\n1671:       agent.agent_type = resolution.agentType;\n1672:     }\n1673: \n1674:     // Per-task local agent override: CLI --agent flag takes precedence,\n1675:     // then task-level `agent` field, then registry resolution (above).\n1676:     // This is for local agent definitions in .opencode/agents/<name>.md.\n1677:     const localAgent = opts.agent ?? feature.agent;\n1678:     if (localAgent && !agent.agent_name) {\n1679:       // Only set if not already resolved from the external registry\n1680:       agent.agent_name = localAgent;\n1681:     } else if (opts.agent) {\n1682:       // CLI --agent flag overrides even registry agents\n1683:       agent.agent_name = opts.agent;\n1684:     }\n1685: \n1686:     state.agents.push(agent);\n1687:   }\n1688: \n1689:   saveState(projectRoot, state);\n1690:   if (fmt === \"text\") console.log(`Wave ${state.wave_id} created with ${selected.length} agents.`);\n1691: \n1692:   // Launch agents up to max_concurrent\n1693:   if (opts.interactive) {\n1694:     await launchWaveInteractive(projectRoot, state, selected, opts, agentResolutions);\n1695:   } else {\n1696:     await launchWaveHeadless(projectRoot, state, selected, opts, agentResolutions);\n1697:   }\n1698: }\n\n(End of file - total 1698 lines)\n</content>","title":"src/commands/launch.ts","metadata":{"preview":"        for (const agent of merged) {\n          markFeatureDone(projectRoot, agent.feature_id, config, existingState.base_branch);\n          // Clean up worktree and branch (already merged, safe to delete)\n          try {\n            removeWorktree(projectRoot, agent.worktree, true);\n            if (fmt === \"text\") console.log(`  ${agent.feature_id}: marked done, worktree removed`);\n          } catch {\n            if (fmt === \"text\") console.log(`  ${agent.feature_id}: marked done (worktree already cleaned)`);\n          }\n        }\n      }\n\n      // Verified agents: build passed but NOT merged — do NOT mark done.\n      // Leave them for 'woco resume' to attempt the merge.\n      if (verified.length > 0) {\n        for (const agent of verified) {\n          if (fmt === \"text\") console.log(`  ${agent.feature_id}: verified (not yet merged) — use 'woco resume' to merge`);\n        }\n      }\n","truncated":false,"loaded":[]},"time":{"start":1773440198296,"end":1773440198301}}}}
{"type":"tool_use","timestamp":1773440198471,"sessionID":"ses_316bba7bfffeeA1IqckNkl9JmJ","part":{"id":"prt_ce945e6990015aA1uFH7A1zPEO","sessionID":"ses_316bba7bfffeeA1IqckNkl9JmJ","messageID":"msg_ce945cd8b001hLFAV1Sqpcn5TD","type":"tool","callID":"toolu_vrtx_01MdwbM51AnTTXgZAqyhEpWq","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/dynamic-agent-types/src/commands/resume.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/dynamic-agent-types/src/commands/resume.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * resume.ts — Resume a previously stopped wave.\n3:  *\n4:  * Usage: woco resume [options] [--output json]\n5:  *\n6:  * Restores from .wombo-combo/state.json:\n7:  *   - Agents in \"running\"/\"installing\" whose PID is dead → re-check or re-launch\n8:  *   - Agents in \"queued\" → launch them\n9:  *   - Agents in terminal states (verified/failed/merged) → leave alone\n10:  */\n11: \n12: import type { WomboConfig } from \"../config.js\";\n13: import type { Feature } from \"../lib/tasks.js\";\n14: import { loadFeatures } from \"../lib/tasks.js\";\n15: import {\n16:   loadState,\n17:   saveState,\n18:   updateAgent,\n19:   queuedAgents,\n20:   readyToLaunchAgents,\n21:   cancelDownstream,\n22:   isWaveComplete,\n23:   type WaveState,\n24:   type AgentState,\n25: } from \"../lib/state.js\";\n26: import {\n27:   createWorktree,\n28:   installDeps,\n29:   worktreeReady,\n30:   worktreeExists,\n31:   branchHasChanges,\n32:   removeWorktree,\n33:   log as wtLog,\n34: } from \"../lib/worktree.js\";\n35: import { generatePrompt } from \"../lib/prompt.js\";\n36: import {\n37:   launchInteractive,\n38:   isProcessRunning,\n39:   getMultiplexerName,\n40: } from \"../lib/launcher.js\";\n41: import { ProcessMonitor } from \"../lib/monitor.js\";\n42: import { pushBaseBranch } from \"../lib/merger.js\";\n43: import { runBuild } from \"../lib/verifier.js\";\n44: import { printDashboard, printAgentUpdate } from \"../lib/ui.js\";\n45: import { WomboTUI } from \"../lib/tui.js\";\n46: import {\n47:   launchSingleHeadless,\n48:   handleBuildVerification,\n49:   handleRetry,\n50:   launchNextQueued,\n51:   launchAllReady,\n52:   markFeatureDone,\n53:   attemptMerge,\n54:   dumpFailedAgentLogs,\n55: } from \"./launch.js\";\n56: import {\n57:   detectMultiplexer,\n58:   muxAttachCommand,\n59: } from \"../lib/multiplexer.js\";\n60: import { exportWaveHistory } from \"../lib/history.js\";\n61: import { outputError, outputMessage, type OutputFormat } from \"../lib/output.js\";\n62: \n63: // ---------------------------------------------------------------------------\n64: // Types\n65: // ---------------------------------------------------------------------------\n66: \n67: export interface ResumeCommandOptions {\n68:   projectRoot: string;\n69:   config: WomboConfig;\n70:   maxConcurrent?: number;\n71:   model?: string;\n72:   interactive: boolean;\n73:   noTui: boolean;\n74:   autoPush: boolean;\n75:   baseBranch?: string;\n76:   maxRetries?: number;\n77:   outputFmt?: OutputFormat;\n78: }\n79: \n80: // ---------------------------------------------------------------------------\n81: // Command\n82: // ---------------------------------------------------------------------------\n83: \n84: export async function cmdResume(opts: ResumeCommandOptions): Promise<void> {\n85:   const { projectRoot, config } = opts;\n86:   const fmt = opts.outputFmt ?? \"text\";\n87: \n88:   const state = loadState(projectRoot);\n89:   if (!state) {\n90:     outputError(fmt, \"No wave state found. Use 'woco launch' to start a new wave.\");\n91:     return; // unreachable — outputError calls process.exit\n92:   }\n93: \n94:   if (fmt === \"text\") {\n95:     console.log(`\\n--- wombo-combo: Resume ${state.wave_id} ---\\n`);\n96:   }\n97: \n98:   // Load feature data for prompt generation\n99:   const data = loadFeatures(projectRoot, config);\n100:   const featureMap = new Map(data.tasks.map((f: Feature) => [f.id, f]));\n101: \n102:   // Triage agents by current state\n103:   let toRelaunch: AgentState[] = [];\n104:   let toVerify: AgentState[] = [];\n105: \n106:   for (const agent of state.agents) {\n107:     switch (agent.status) {\n108:       case \"running\":\n109:       case \"installing\":\n110:       case \"retry\":\n111:       case \"resolving_conflict\":\n112:         // Was in-flight when we stopped — check if PID is still alive\n113:         if (agent.pid && isProcessRunning(agent.pid)) {\n114:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: still running (PID ${agent.pid}), leaving alone`);\n115:         } else {\n116:           // Process is dead — check if worktree exists with meaningful changes.\n117:           // Use worktreeExists (not worktreeReady) because node_modules may be\n118:           // missing — the worktree still has code that should be verified.\n119:           if (worktreeExists(agent.worktree) && branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n120:             // Worktree exists AND branch has commits — try build verification\n121:             if (fmt === \"text\") console.log(`  ${agent.feature_id}: process dead, worktree has changes — will verify build`);\n122:             toVerify.push(agent);\n123:           } else {\n124:             // No worktree, or worktree exists but branch has no commits (agent did nothing)\n125:             const reason = worktreeExists(agent.worktree)\n126:               ? \"worktree exists but no code changes\"\n127:               : \"no worktree\";\n128:             if (fmt === \"text\") console.log(`  ${agent.feature_id}: process dead, ${reason} — will re-launch`);\n129:             updateAgent(state, agent.feature_id, {\n130:               status: \"queued\",\n131:               pid: null,\n132:               activity: null,\n133:               session_id: null,\n134:             });\n135:             toRelaunch.push(agent);\n136:           }\n137:         }\n138:         break;\n139: \n140:       case \"queued\":\n141:         if (fmt === \"text\") console.log(`  ${agent.feature_id}: queued — will launch`);\n142:         toRelaunch.push(agent);\n143:         break;\n144: \n145:       case \"completed\":\n146:         // Completed but not verified — verify\n147:         if (fmt === \"text\") console.log(`  ${agent.feature_id}: completed — will verify build`);\n148:         toVerify.push(agent);\n149:         break;\n150: \n151:       case \"verified\":\n152:         // Build passed but NOT yet merged — need to attempt merge (+ conflict resolution)\n153:         if (fmt === \"text\") console.log(`  ${agent.feature_id}: verified — will attempt merge`);\n154:         toVerify.push(agent);\n155:         break;\n156: \n157:       case \"merged\":\n158:         if (fmt === \"text\") console.log(`  ${agent.feature_id}: merged — marking feature as done`);\n159:         markFeatureDone(projectRoot, agent.feature_id, config, state.base_branch);\n160:         try {\n161:           removeWorktree(projectRoot, agent.worktree, true);\n162:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: worktree and branch removed`);\n163:         } catch {\n164:           // Already cleaned — not critical\n165:         }\n166:         break;\n167: \n168:       case \"failed\":\n169:         // If the worktree exists with code changes and retries remain,\n170:         // attempt build verification rather than discarding the work.\n171:         if (agent.retries < agent.max_retries &&\n172:             worktreeExists(agent.worktree) &&\n173:             branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n174:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: failed but has work (retry ${agent.retries}/${agent.max_retries}) — will verify build`);\n175:           // Clear stale error and mark as completed so handleBuildVerification\n176:           // processes it correctly (it expects a non-failed agent)\n177:           updateAgent(state, agent.feature_id, {\n178:             status: \"completed\",\n179:             error: null,\n180:             build_passed: null,\n181:             build_output: null,\n182:             completed_at: new Date().toISOString(),\n183:           });\n184:           toVerify.push(agent);\n185:         } else if (agent.retries < agent.max_retries) {\n186:           // No worktree or no changes — re-launch from scratch\n187:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: failed, no salvageable work (retry ${agent.retries}/${agent.max_retries}) — will re-launch`);\n188:           updateAgent(state, agent.feature_id, {\n189:             status: \"queued\",\n190:             pid: null,\n191:             error: null,\n192:             build_passed: null,\n193:             build_output: null,\n194:             activity: null,\n195:             session_id: null,\n196:             completed_at: null,\n197:           });\n198:           toRelaunch.push(agent);\n199:         } else {\n200:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: failed — max retries reached (use 'woco retry' to reset)`);\n201:         }\n202:         break;\n203:     }\n204:   }\n205: \n206:   saveState(projectRoot, state);\n207: \n208:   // ---------------------------------------------------------------------------\n209:   // Phase 1: Parallel build verification\n210:   // Each agent's worktree is independent, so dep install + build can run\n211:   // concurrently. Merges must remain sequential (they mutate the project root).\n212:   // ---------------------------------------------------------------------------\n213:   if (toVerify.length > 0) {\n214:     if (fmt === \"text\") console.log(`\\nVerifying ${toVerify.length} agent(s) in parallel...\\n`);\n215: \n216:     const verifyResults = await Promise.all(\n217:       toVerify.map(async (agent): Promise<{ agent: AgentState; needsMerge: boolean }> => {\n218:         const feature = featureMap.get(agent.feature_id);\n219:         if (!feature) return { agent, needsMerge: false };\n220: \n221:         // Already verified — skip build, go straight to merge\n222:         if (agent.status === \"verified\") {\n223:           printAgentUpdate(agent, \"already verified — queued for merge\");\n224:           return { agent, needsMerge: true };\n225:         }\n226: \n227:         printAgentUpdate(agent, \"verifying build...\");\n228: \n229:         // Ensure deps are installed — worktree may exist without node_modules\n230:         // (e.g., failed agents whose setup was interrupted)\n231:         if (!worktreeReady(agent.worktree) && worktreeExists(agent.worktree)) {\n232:           try {\n233:             printAgentUpdate(agent, \"installing deps...\");\n234:             await installDeps(agent.worktree, agent.feature_id, config);\n235:           } catch (depErr: any) {\n236:             printAgentUpdate(agent, `dep install failed: ${depErr.message}`);\n237:             updateAgent(state, agent.feature_id, {\n238:               status: \"failed\",\n239:               error: `Dependency install failed: ${depErr.message}`,\n240:               retries: agent.retries + 1,\n241:               completed_at: new Date().toISOString(),\n242:             });\n243:             saveState(projectRoot, state);\n244:             return { agent, needsMerge: false };\n245:           }\n246:         }\n247: \n248:         try {\n249:           const buildResult = await runBuild(agent.worktree, config);\n250:           if (buildResult.passed) {\n251:             updateAgent(state, agent.feature_id, {\n252:               status: \"verified\",\n253:               build_passed: true,\n254:               build_output: null,\n255:             });\n256:             saveState(projectRoot, state);\n257:             printAgentUpdate(agent, `BUILD PASSED (${Math.round(buildResult.durationMs / 1000)}s)`);\n258:             return { agent, needsMerge: true };\n259:           } else {\n260:             // Build failed\n261:             if (agent.retries < agent.max_retries) {\n262:               updateAgent(state, agent.feature_id, {\n263:                 status: \"retry\",\n264:                 retries: agent.retries + 1,\n265:                 build_passed: false,\n266:                 build_output: buildResult.errorSummary,\n267:               });\n268:               saveState(projectRoot, state);\n269:               printAgentUpdate(agent, `BUILD FAILED — will retry (${agent.retries + 1}/${agent.max_retries})`);\n270:             } else {\n271:               updateAgent(state, agent.feature_id, {\n272:                 status: \"failed\",\n273:                 build_passed: false,\n274:                 build_output: buildResult.errorSummary,\n275:                 error: `Build failed after ${agent.max_retries} retries`,\n276:                 completed_at: new Date().toISOString(),\n277:               });\n278:               saveState(projectRoot, state);\n279:               printAgentUpdate(agent, \"BUILD FAILED — max retries reached\");\n280:             }\n281:             return { agent, needsMerge: false };\n282:           }\n283:         } catch (err: any) {\n284:           printAgentUpdate(agent, `verify error: ${err.message}`);\n285:           updateAgent(state, agent.feature_id, {\n286:             status: \"failed\",\n287:             error: `Build verification error: ${err.message}`,\n288:             completed_at: new Date().toISOString(),\n289:           });\n290:           saveState(projectRoot, state);\n291:           return { agent, needsMerge: false };\n292:         }\n293:       })\n294:     );\n295: \n296:     saveState(projectRoot, state);\n297: \n298:     // -------------------------------------------------------------------------\n299:     // Phase 2: Sequential merge for verified agents\n300:     // Merges must be sequential because they operate on the project root.\n301:     // -------------------------------------------------------------------------\n302:     const toMerge = verifyResults.filter((r) => r.needsMerge);\n303:     if (toMerge.length > 0) {\n304:       if (fmt === \"text\") console.log(`\\nMerging ${toMerge.length} verified agent(s)...\\n`);\n305:       for (const { agent } of toMerge) {\n306:         const feature = featureMap.get(agent.feature_id);\n307:         if (!feature) continue;\n308:         try {\n309:           await attemptMerge(projectRoot, state, agent, feature, config, opts.model);\n310:         } catch (err: any) {\n311:           printAgentUpdate(agent, `merge error: ${err.message}`);\n312:         }\n313:       }\n314:     }\n315: \n316:     // Collect agents that need re-launching from verify results\n317:     for (const { agent } of verifyResults) {\n318:       if (agent.status === \"retry\" || agent.status === \"running\") {\n319:         toRelaunch.push(agent);\n320:       }\n321:     }\n322:   }\n323: \n324:   // Re-launch agents\n325:   const maxConcurrent = opts.maxConcurrent ?? state.max_concurrent;\n326:   const toLaunchNow = toRelaunch.slice(0, maxConcurrent);\n327:   if (toLaunchNow.length === 0) {\n328:     outputMessage(fmt, \"No agents need (re)launching.\", {\n329:       wave_id: state.wave_id,\n330:       triage: {\n331:         to_verify: toVerify.length,\n332:         to_relaunch: 0,\n333:       },\n334:       agents: state.agents.map((a) => ({\n335:         feature_id: a.feature_id,\n336:         status: a.status,\n337:         build_passed: a.build_passed,\n338:         error: a.error,\n339:       })),\n340:     });\n341:     if (fmt === \"text\") printDashboard(state);\n342:     return;\n343:   }\n344: \n345:   if (fmt === \"text\") {\n346:     console.log(`\\nRe-launching ${toLaunchNow.length} agent(s)...\\n`);\n347:     printDashboard(state);\n348:   }\n349:   const model = opts.model ?? state.model ?? undefined;\n350: \n351:   if (opts.interactive) {\n352:     // Interactive resume\n353:     await Promise.all(\n354:       toLaunchNow.map(async (agent) => {\n355:         const feature = featureMap.get(agent.feature_id);\n356:         if (!feature) return;\n357: \n358:         updateAgent(state, agent.feature_id, {\n359:           status: \"installing\",\n360:           started_at: new Date().toISOString(),\n361:           activity: \"resuming...\",\n362:         });\n363:         saveState(projectRoot, state);\n364: \n365:         try {\n366:           if (!worktreeReady(agent.worktree)) {\n367:             await createWorktree(projectRoot, agent.feature_id, state.base_branch, config);\n368:             await installDeps(agent.worktree, agent.feature_id, config);\n369:           }\n370: \n371:           const prompt = generatePrompt(feature, state.base_branch, config);\n372:           const result = launchInteractive({\n373:             worktreePath: agent.worktree,\n374:             featureId: feature.id,\n375:             prompt,\n376:             model,\n377:             interactive: true,\n378:             config,\n379:           });\n380: \n381:           const muxName = getMultiplexerName(config);\n382:           updateAgent(state, agent.feature_id, {\n383:             status: \"running\",\n384:             pid: result.pid,\n385:             activity: `${muxName} session active`,\n386:           });\n387:           saveState(projectRoot, state);\n388:         } catch (err: any) {\n389:           updateAgent(state, agent.feature_id, {\n390:             status: \"failed\",\n391:             error: err.message,\n392:             activity: null,\n393:             completed_at: new Date().toISOString(),\n394:           });\n395:           saveState(projectRoot, state);\n396:         }\n397:       })\n398:     );\n399: \n400:     if (fmt === \"text\") {\n401:       printDashboard(state);\n402:       const mux = detectMultiplexer(config.agent.multiplexer);\n403:       console.log(`\\nResume complete. Use '${muxAttachCommand(mux, `${config.agent.tmuxPrefix}-<id>`)}' to check sessions.`);\n404:     }\n405:   } else {\n406:     // Headless resume — re-enter monitoring loop\n407:     const monitor = new ProcessMonitor(projectRoot, {\n408:       onSessionId: (featureId, sessionId) => {\n409:         updateAgent(state, featureId, { session_id: sessionId });\n410:         saveState(projectRoot, state);\n411:       },\n412:       onComplete: (featureId) => {\n413:         updateAgent(state, featureId, {\n414:           status: \"completed\",\n415:           completed_at: new Date().toISOString(),\n416:           activity: \"done\",\n417:         });\n418:         saveState(projectRoot, state);\n419:         wtLog(featureId, \"agent completed — verifying build...\");\n420: \n421:         const agent = state.agents.find((a) => a.feature_id === featureId)!;\n422:         const feature = featureMap.get(featureId)!;\n423:         handleBuildVerification(projectRoot, state, agent, feature, config, model, monitor)\n424:           .then(() => launchAllReady(projectRoot, state, featureMap, monitor, config, model))\n425:           .catch((err) => {\n426:             wtLog(featureId, `BUILD VERIFICATION UNHANDLED ERROR: ${err.message}`);\n427:             launchAllReady(projectRoot, state, featureMap, monitor, config, model);\n428:           });\n429:       },\n430:       onError: (featureId, error) => {\n431:         const agent = state.agents.find((a) => a.feature_id === featureId)!;\n432:         if (agent.retries < agent.max_retries) {\n433:           updateAgent(state, featureId, {\n434:             status: \"retry\",\n435:             retries: agent.retries + 1,\n436:             error,\n437:             activity: \"retrying...\",\n438:           });\n439:           saveState(projectRoot, state);\n440:           handleRetry(projectRoot, state, agent, monitor, config, model);\n441:         } else {\n442:           updateAgent(state, featureId, {\n443:             status: \"failed\",\n444:             error,\n445:             activity: null,\n446:             completed_at: new Date().toISOString(),\n447:           });\n448:           saveState(projectRoot, state);\n449: \n450:           // Cascade failure to downstream agents\n451:           const cancelled = cancelDownstream(state, featureId);\n452:           if (cancelled.length > 0) {\n453:             wtLog(featureId, `downstream cancelled: ${cancelled.join(\", \")}`);\n454:             saveState(projectRoot, state);\n455:           }\n456:         }\n457:         launchAllReady(projectRoot, state, featureMap, monitor, config, model);\n458:       },\n459:       onActivity: (featureId, activity) => {\n460:         updateAgent(state, featureId, {\n461:           activity,\n462:           activity_updated_at: new Date().toISOString(),\n463:         });\n464:       },\n465:     });\n466: \n467:     // Handle graceful shutdown\n468:     const tuiRef = { current: null as WomboTUI | null };\n469:     process.on(\"SIGINT\", () => {\n470:       if (tuiRef.current) tuiRef.current.stop();\n471:       for (const agent of state.agents) {\n472:         if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n473:           updateAgent(state, agent.feature_id, {\n474:             activity: \"interrupted\",\n475:           });\n476:         }\n477:       }\n478:       monitor.killAll();\n479:       saveState(projectRoot, state);\n480:       if (fmt === \"text\") console.log(\"\\nState saved. Use 'woco resume' to continue.\");\n481:       process.exit(0);\n482:     });\n483: \n484:     await Promise.all(\n485:       toLaunchNow.map((agent) => {\n486:         const feature = featureMap.get(agent.feature_id);\n487:         if (!feature) return Promise.resolve();\n488:         return launchSingleHeadless(projectRoot, state, agent, feature, monitor, config, model);\n489:       })\n490:     );\n491: \n492:     // Start TUI dashboard (or skip if --no-tui)\n493:     if (!opts.noTui) {\n494:       tuiRef.current = new WomboTUI({\n495:         state,\n496:         monitor,\n497:         projectRoot,\n498:         interactive: false,\n499:         config,\n500:         onQuit: () => {\n501:           for (const agent of state.agents) {\n502:             if (agent.status === \"running\") {\n503:               updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n504:             }\n505:           }\n506:           monitor.killAll();\n507:           saveState(projectRoot, state);\n508:           if (fmt === \"text\") console.log(\"State saved. Use 'woco resume' to continue.\");\n509:           process.exit(0);\n510:         },\n511:         onRetry: (featureId: string) => {\n512:           const agent = state.agents.find((a) => a.feature_id === featureId);\n513:           if (!agent) return;\n514:           if (agent.status !== \"failed\" && agent.status !== \"retry\") return;\n515: \n516:           // Reset retries if exhausted, give it one more shot\n517:           if (agent.retries >= agent.max_retries) {\n518:             updateAgent(state, featureId, { max_retries: agent.retries + 1 });\n519:           }\n520: \n521:           wtLog(featureId, `manual retry requested from TUI — resetting to queued`);\n522:           updateAgent(state, featureId, {\n523:             status: \"queued\",\n524:             error: null,\n525:             activity: \"waiting for relaunch (manual retry)...\",\n526:           });\n527:           saveState(projectRoot, state);\n528:         },\n529:       });\n530:       tuiRef.current.start();\n531:     } else {\n532:       if (fmt === \"text\") console.log(\"(--no-tui mode, dashboard prints every 15s)\\n\");\n533:       printDashboard(state);\n534:     }\n535: \n536:     // Monitoring loop\n537:     const POLL_INTERVAL = 5000;\n538:     let dashboardCounter = 0;\n539:     while (!isWaveComplete(state)) {\n540:       await new Promise((r) => setTimeout(r, POLL_INTERVAL));\n541: \n542:       for (const agent of state.agents) {\n543:         if (\n544:           (agent.status === \"running\" || agent.status === \"resolving_conflict\") &&\n545:           agent.pid &&\n546:           !isProcessRunning(agent.pid) &&\n547:           !monitor.isRunning(agent.feature_id)\n548:         ) {\n549:           if (agent.status === \"resolving_conflict\") {\n550:             // Conflict resolver died unexpectedly — mark as failed\n551:             updateAgent(state, agent.feature_id, {\n552:               status: \"failed\",\n553:               error: \"Conflict resolver process died unexpectedly\",\n554:               activity: null,\n555:               completed_at: new Date().toISOString(),\n556:             });\n557:             saveState(projectRoot, state);\n558:             wtLog(agent.feature_id, \"conflict resolver died — marked failed\");\n559: \n560:             // Cascade failure to downstream agents\n561:             const cancelled = cancelDownstream(state, agent.feature_id);\n562:             if (cancelled.length > 0) {\n563:               wtLog(agent.feature_id, `downstream cancelled: ${cancelled.join(\", \")}`);\n564:               saveState(projectRoot, state);\n565:             }\n566: \n567:             launchAllReady(projectRoot, state, featureMap, monitor, config, model);\n568:             continue;\n569:           }\n570:           // Check if the agent actually made any commits\n571:           if (!branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n572:             // Agent died without producing any code — mark as failed\n573:             updateAgent(state, agent.feature_id, {\n574:               status: \"failed\",\n575:               error: \"Agent process exited without making any commits\",\n576:               activity: null,\n577:               completed_at: new Date().toISOString(),\n578:             });\n579:             saveState(projectRoot, state);\n580:             wtLog(agent.feature_id, \"process died with no code changes — marked failed\");\n581: \n582:             // Cascade failure to downstream agents\n583:             const cancelled = cancelDownstream(state, agent.feature_id);\n584:             if (cancelled.length > 0) {\n585:               wtLog(agent.feature_id, `downstream cancelled: ${cancelled.join(\", \")}`);\n586:               saveState(projectRoot, state);\n587:             }\n588:           } else {\n589:             updateAgent(state, agent.feature_id, {\n590:               status: \"completed\",\n591:               completed_at: new Date().toISOString(),\n592:               activity: \"done\",\n593:             });\n594:             saveState(projectRoot, state);\n595:             const feature = featureMap.get(agent.feature_id)!;\n596:             try {\n597:               await handleBuildVerification(projectRoot, state, agent, feature, config, model, monitor);\n598:             } catch (err: any) {\n599:               wtLog(agent.feature_id, `POLL VERIFY ERROR: ${err.message}`);\n600:             }\n601:           }\n602:           launchAllReady(projectRoot, state, featureMap, monitor, config, model);\n603:         }\n604:       }\n605: \n606:       saveState(projectRoot, state);\n607:       if (tuiRef.current) {\n608:         tuiRef.current.updateState(state);\n609:       } else if (opts.noTui) {\n610:         dashboardCounter++;\n611:         if (dashboardCounter % 3 === 0) {\n612:           printDashboard(state);\n613:         }\n614:       }\n615:     }\n616: \n617:     // Wave complete — keep TUI open for post-mortem browsing\n618:     if (tuiRef.current) {\n619:       tuiRef.current.updateState(state);\n620:       tuiRef.current.markWaveComplete();\n621:       await tuiRef.current.waitForQuit();\n622:     }\n623: \n624:     if (fmt === \"text\") {\n625:       printDashboard(state);\n626: \n627:       // Dump full logs for failed agents (post-mortem)\n628:       dumpFailedAgentLogs(projectRoot, state);\n629:     }\n630: \n631:     // Auto-export wave history\n632:     try {\n633:       const historyPath = exportWaveHistory(projectRoot, state);\n634:       if (fmt === \"text\") console.log(`Wave history exported to ${historyPath}`);\n635:     } catch (err: any) {\n636:       if (fmt === \"text\") console.error(`Warning: failed to export wave history: ${err.message}`);\n637:     }\n638: \n639:     // Auto-push base branch if requested\n640:     if (opts.autoPush) {\n641:       await pushBaseBranch(projectRoot, state.base_branch, config);\n642:     }\n643: \n644:     if (fmt === \"text\") console.log(\"Wave complete.\");\n645:   }\n646: }\n\n(End of file - total 646 lines)\n</content>","title":"src/commands/resume.ts","metadata":{"preview":"/**\n * resume.ts — Resume a previously stopped wave.\n *\n * Usage: woco resume [options] [--output json]\n *\n * Restores from .wombo-combo/state.json:\n *   - Agents in \"running\"/\"installing\" whose PID is dead → re-check or re-launch\n *   - Agents in \"queued\" → launch them\n *   - Agents in terminal states (verified/failed/merged) → leave alone\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport type { Feature } from \"../lib/tasks.js\";\nimport { loadFeatures } from \"../lib/tasks.js\";\nimport {\n  loadState,\n  saveState,\n  updateAgent,\n  queuedAgents,\n  readyToLaunchAgents,","truncated":false,"loaded":[]},"time":{"start":1773440198465,"end":1773440198470}}}}
