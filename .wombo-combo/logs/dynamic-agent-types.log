{"type":"tool_use","timestamp":1773439930181,"sessionID":"ses_316be8c08ffeZXbNAgwvZBSoRI","part":{"id":"prt_ce941cbc5001pPdJ8mx7h2WUzK","sessionID":"ses_316be8c08ffeZXbNAgwvZBSoRI","messageID":"msg_ce941bce70010SbLrb1NHkgeJu","type":"tool","callID":"toolu_vrtx_015o869FgMPhtjWuRw8MNnQB","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/dynamic-agent-types/src/lib/agent-registry.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/dynamic-agent-types/src/lib/agent-registry.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * agent-registry.ts — Fetch, cache, and resolve specialized agent definitions\n3:  * from an external registry (e.g. github.com/msitarzewski/agency-agents).\n4:  *\n5:  * Flow:\n6:  *   1. Task has `agent_type: \"engineering/engineering-frontend-developer\"`\n7:  *   2. resolveAgentForTask() checks cache, fetches if missing, returns raw md\n8:  *   3. At launch time, raw md is patched via patchImportedAgent() and written\n9:  *      into the worktree's .opencode/agents/ directory\n10:  *\n11:  * Cache layout:\n12:  *   .wombo-combo/agents-cache/engineering/engineering-frontend-developer.md\n13:  *\n14:  * Raw downloads are cached. Patching is done at launch time (not cached)\n15:  * because patches depend on runtime config (portless, placeholders, etc.).\n16:  */\n17: \n18: import { resolve, dirname, relative } from \"node:path\";\n19: import {\n20:   existsSync,\n21:   readFileSync,\n22:   writeFileSync,\n23:   mkdirSync,\n24:   readdirSync,\n25:   statSync,\n26: } from \"node:fs\";\n27: import { WOMBO_DIR, type WomboConfig, type AgentRegistryMode } from \"../config.js\";\n28: import type { Task } from \"./tasks.js\";\n29: \n30: // ---------------------------------------------------------------------------\n31: // Types\n32: // ---------------------------------------------------------------------------\n33: \n34: /** Result of resolving an agent for a task */\n35: export interface ResolvedAgent {\n36:   /** Task ID this agent is resolved for */\n37:   taskId: string;\n38:   /**\n39:    * Agent name (last path segment of agent_type).\n40:    * e.g. \"engineering-frontend-developer\" from \"engineering/engineering-frontend-developer\"\n41:    */\n42:   name: string;\n43:   /** Raw markdown content from the registry (before patching) */\n44:   rawContent: string;\n45:   /** Whether this was loaded from cache (true) or freshly fetched (false) */\n46:   fromCache: boolean;\n47:   /** The agent_type string from the task */\n48:   agentType: string;\n49: }\n50: \n51: /** Generalist fallback — no specialized agent, use default */\n52: export interface GeneralistFallback {\n53:   taskId: string;\n54:   name: null;\n55:   rawContent: null;\n56:   fromCache: false;\n57:   agentType: null;\n58: }\n59: \n60: export type AgentResolution = ResolvedAgent | GeneralistFallback;\n61: \n62: /** Summary info for a registry agent (used by listRegistryAgents / getCachedAgents) */\n63: export interface RegistryAgentInfo {\n64:   /** Agent type path, e.g. \"engineering/engineering-frontend-developer\" */\n65:   agentType: string;\n66:   /** Short name derived from the path, e.g. \"engineering-frontend-developer\" */\n67:   name: string;\n68:   /** Category (first path segment), e.g. \"engineering\" */\n69:   category: string;\n70:   /** Human-readable description extracted from frontmatter, or null if unavailable */\n71:   description: string | null;\n72: }\n73: \n74: /** Entry returned by the GitHub Contents API */\n75: interface GitHubContentEntry {\n76:   name: string;\n77:   path: string;\n78:   type: \"file\" | \"dir\" | \"symlink\" | \"submodule\";\n79:   size?: number;\n80:   download_url?: string | null;\n81: }\n82: \n83: // ---------------------------------------------------------------------------\n84: // Agent Name Derivation\n85: // ---------------------------------------------------------------------------\n86: \n87: /**\n88:  * Derive the agent name from an agent_type string.\n89:  * \"engineering/engineering-frontend-developer\" → \"engineering-frontend-developer\"\n90:  */\n91: export function agentNameFromType(agentType: string): string {\n92:   const segments = agentType.split(\"/\");\n93:   return segments[segments.length - 1];\n94: }\n95: \n96: // ---------------------------------------------------------------------------\n97: // Frontmatter Parsing\n98: // ---------------------------------------------------------------------------\n99: \n100: /**\n101:  * Extract description from YAML frontmatter in a markdown string.\n102:  * Expects `---` delimiters at the top of the file.\n103:  * Returns null if no frontmatter or no description field found.\n104:  */\n105: function extractDescription(markdownContent: string): string | null {\n106:   const trimmed = markdownContent.trimStart();\n107:   if (!trimmed.startsWith(\"---\")) return null;\n108: \n109:   const endIndex = trimmed.indexOf(\"---\", 3);\n110:   if (endIndex === -1) return null;\n111: \n112:   const frontmatter = trimmed.slice(3, endIndex);\n113:   // Simple regex extraction — avoids pulling in a YAML parser for a single field\n114:   const match = frontmatter.match(/^description:\\s*(.+)$/m);\n115:   if (!match) return null;\n116: \n117:   // Strip surrounding quotes if present\n118:   let desc = match[1].trim();\n119:   if ((desc.startsWith('\"') && desc.endsWith('\"')) || (desc.startsWith(\"'\") && desc.endsWith(\"'\"))) {\n120:     desc = desc.slice(1, -1);\n121:   }\n122:   return desc || null;\n123: }\n124: \n125: // ---------------------------------------------------------------------------\n126: // Cache Operations\n127: // ---------------------------------------------------------------------------\n128: \n129: /**\n130:  * Resolve the cache directory root for agents.\n131:  */\n132: function cacheDir(projectRoot: string, config: WomboConfig): string {\n133:   return resolve(projectRoot, WOMBO_DIR, config.agentRegistry.cacheDir);\n134: }\n135: \n136: /**\n137:  * Resolve the cache file path for an agent type.\n138:  * e.g. \"engineering/engineering-frontend-developer\"\n139:  *   → \".wombo-combo/agents-cache/engineering/engineering-frontend-developer.md\"\n140:  */\n141: function cachePath(projectRoot: string, config: WomboConfig, agentType: string): string {\n142:   return resolve(cacheDir(projectRoot, config), `${agentType}.md`);\n143: }\n144: \n145: /**\n146:  * Check whether a cached agent file is still valid (within TTL).\n147:  * Returns true if the file exists and its mtime is within cacheTTL ms of now.\n148:  */\n149: function isCacheValid(\n150:   projectRoot: string,\n151:   config: WomboConfig,\n152:   agentType: string\n153: ): boolean {\n154:   const path = cachePath(projectRoot, config, agentType);\n155:   if (!existsSync(path)) return false;\n156:   try {\n157:     const stat = statSync(path);\n158:     const age = Date.now() - stat.mtimeMs;\n159:     return age < config.agentRegistry.cacheTTL;\n160:   } catch {\n161:     return false;\n162:   }\n163: }\n164: \n165: /**\n166:  * Read a cached agent definition. Returns null if not cached.\n167:  * Does NOT check TTL — callers should use isCacheValid() for freshness checks.\n168:  */\n169: export function getCachedAgent(\n170:   projectRoot: string,\n171:   config: WomboConfig,\n172:   agentType: string\n173: ): string | null {\n174:   const path = cachePath(projectRoot, config, agentType);\n175:   if (!existsSync(path)) return null;\n176:   try {\n177:     return readFileSync(path, \"utf-8\");\n178:   } catch {\n179:     return null;\n180:   }\n181: }\n182: \n183: /**\n184:  * Write an agent definition to the cache.\n185:  */\n186: export function cacheAgent(\n187:   projectRoot: string,\n188:   config: WomboConfig,\n189:   agentType: string,\n190:   content: string\n191: ): void {\n192:   const path = cachePath(projectRoot, config, agentType);\n193:   mkdirSync(dirname(path), { recursive: true });\n194:   writeFileSync(path, content, \"utf-8\");\n195: }\n196: \n197: /**\n198:  * List all locally cached agents from .wombo-combo/agents-cache/.\n199:  * Recursively scans the cache directory for .md files and extracts\n200:  * metadata from their frontmatter.\n201:  */\n202: export function getCachedAgents(\n203:   projectRoot: string,\n204:   config: WomboConfig\n205: ): RegistryAgentInfo[] {\n206:   const root = cacheDir(projectRoot, config);\n207:   if (!existsSync(root)) return [];\n208: \n209:   const results: RegistryAgentInfo[] = [];\n210: \n211:   function walk(dir: string): void {\n212:     let entries: string[];\n213:     try {\n214:       entries = readdirSync(dir);\n215:     } catch {\n216:       return;\n217:     }\n218:     for (const entry of entries) {\n219:       const fullPath = resolve(dir, entry);\n220:       let stat;\n221:       try {\n222:         stat = statSync(fullPath);\n223:       } catch {\n224:         continue;\n225:       }\n226:       if (stat.isDirectory()) {\n227:         walk(fullPath);\n228:       } else if (stat.isFile() && entry.endsWith(\".md\")) {\n229:         // Derive agentType from relative path minus .md extension\n230:         const rel = relative(root, fullPath);\n231:         const agentType = rel.replace(/\\.md$/, \"\").replace(/\\\\/g, \"/\");\n232:         const name = agentNameFromType(agentType);\n233:         const segments = agentType.split(\"/\");\n234:         const category = segments.length > 1 ? segments[0] : \"\";\n235: \n236:         let description: string | null = null;\n237:         try {\n238:           const content = readFileSync(fullPath, \"utf-8\");\n239:           description = extractDescription(content);\n240:         } catch {\n241:           // ignore read errors — description stays null\n242:         }\n243: \n244:         results.push({ agentType, name, category, description });\n245:       }\n246:     }\n247:   }\n248: \n249:   walk(root);\n250:   return results;\n251: }\n252: \n253: // ---------------------------------------------------------------------------\n254: // Fetch from Registry\n255: // ---------------------------------------------------------------------------\n256: \n257: /**\n258:  * Build the raw GitHub URL for an agent definition.\n259:  * Source: \"msitarzewski/agency-agents\"\n260:  * Agent type: \"engineering/engineering-frontend-developer\"\n261:  * → \"https://raw.githubusercontent.com/msitarzewski/agency-agents/main/engineering/engineering-frontend-developer.md\"\n262:  */\n263: function rawUrl(source: string, agentType: string): string {\n264:   return `https://raw.githubusercontent.com/${source}/main/${agentType}.md`;\n265: }\n266: \n267: /**\n268:  * Build the GitHub API URL for listing directory contents.\n269:  * Source: \"msitarzewski/agency-agents\"\n270:  * Path: \"engineering\" (or \"\" for root)\n271:  * → \"https://api.github.com/repos/msitarzewski/agency-agents/contents/engineering\"\n272:  */\n273: function contentsApiUrl(source: string, path?: string): string {\n274:   const base = `https://api.github.com/repos/${source}/contents`;\n275:   return path ? `${base}/${path}` : base;\n276: }\n277: \n278: /**\n279:  * Fetch an agent definition from the registry by agent type.\n280:  * Returns the raw markdown content or throws on failure.\n281:  *\n282:  * @param agentType — e.g. \"engineering/engineering-frontend-developer\"\n283:  * @param source    — GitHub repo in \"owner/repo\" format\n284:  */\n285: export async function fetchAgent(\n286:   agentType: string,\n287:   source: string\n288: ): Promise<string> {\n289:   const url = rawUrl(source, agentType);\n290:   const response = await fetch(url);\n291: \n292:   if (!response.ok) {\n293:     if (response.status === 404) {\n294:       throw new Error(\n295:         `Agent \"${agentType}\" not found in registry \"${source}\". ` +\n296:         `Looked at: ${url}`\n297:       );\n298:     }\n299:     throw new Error(\n300:       `Failed to fetch agent \"${agentType}\" from registry: ` +\n301:       `HTTP ${response.status} ${response.statusText}`\n302:     );\n303:   }\n304: \n305:   return await response.text();\n306: }\n307: \n308: /**\n309:  * Fetch the list of available agents from the registry.\n310:  *\n311:  * Uses the GitHub Contents API to recursively walk the repo and find all .md\n312:  * agent definitions. For each found agent, fetches the raw content to extract\n313:  * the description from the YAML frontmatter.\n314:  *\n315:  * Categories excluded from listing: files in the repo root, and directories\n316:  * that are not agent categories (e.g. \"scripts\", \"examples\", \".github\").\n317:  *\n318:  * @param source — GitHub repo in \"owner/repo\" format (e.g. \"msitarzewski/agency-agents\")\n319:  * @returns Array of agent info objects with name, category, and description\n320:  */\n321: export async function listRegistryAgents(\n322:   source: string\n323: ): Promise<RegistryAgentInfo[]> {\n324:   // Directories that are NOT agent categories — skip them\n325:   const EXCLUDED_DIRS = new Set([\n326:     \".github\",\n327:     \"scripts\",\n328:     \"examples\",\n329:   ]);\n330: \n331:   // Step 1: Fetch root listing to discover categories\n332:   const rootUrl = contentsApiUrl(source);\n333:   const rootResponse = await fetch(rootUrl, {\n334:     headers: { Accept: \"application/vnd.github.v3+json\" },\n335:   });\n336: \n337:   if (!rootResponse.ok) {\n338:     throw new Error(\n339:       `Failed to list registry \"${source}\": HTTP ${rootResponse.status} ${rootResponse.statusText}`\n340:     );\n341:   }\n342: \n343:   const rootEntries = (await rootResponse.json()) as GitHubContentEntry[];\n344:   const categoryDirs = rootEntries.filter(\n345:     (e) => e.type === \"dir\" && !e.name.startsWith(\".\") && !EXCLUDED_DIRS.has(e.name)\n346:   );\n347: \n348:   // Step 2: Fetch each category directory in parallel\n349:   const categoryResults = await Promise.allSettled(\n350:     categoryDirs.map(async (catEntry) => {\n351:       const catUrl = contentsApiUrl(source, catEntry.path);\n352:       const catResponse = await fetch(catUrl, {\n353:         headers: { Accept: \"application/vnd.github.v3+json\" },\n354:       });\n355: \n356:       if (!catResponse.ok) {\n357:         throw new Error(\n358:           `Failed to list category \"${catEntry.path}\": HTTP ${catResponse.status}`\n359:         );\n360:       }\n361: \n362:       const files = (await catResponse.json()) as GitHubContentEntry[];\n363:       return { category: catEntry.name, files };\n364:     })\n365:   );\n366: \n367:   // Step 3: For each .md file, extract agent info.\n368:   // We fetch the raw content in parallel (batched per category) to get descriptions.\n369:   const agents: RegistryAgentInfo[] = [];\n370: \n371:   for (const result of categoryResults) {\n372:     if (result.status !== \"fulfilled\") continue;\n373:     const { category, files } = result.value;\n374: \n375:     const mdFiles = files.filter(\n376:       (f) => f.type === \"file\" && f.name.endsWith(\".md\")\n377:     );\n378: \n379:     // Fetch raw contents in parallel to extract descriptions\n380:     const fileResults = await Promise.allSettled(\n381:       mdFiles.map(async (mdFile) => {\n382:         const agentType = mdFile.path.replace(/\\.md$/, \"\");\n383:         const name = agentNameFromType(agentType);\n384: \n385:         let description: string | null = null;\n386:         if (mdFile.download_url) {\n387:           try {\n388:             const raw = await fetch(mdFile.download_url);\n389:             if (raw.ok) {\n390:               const content = await raw.text();\n391:               description = extractDescription(content);\n392:             }\n393:           } catch {\n394:             // Couldn't fetch content — description stays null\n395:           }\n396:         }\n397: \n398:         return { agentType, name, category, description } as RegistryAgentInfo;\n399:       })\n400:     );\n401: \n402:     for (const fileResult of fileResults) {\n403:       if (fileResult.status === \"fulfilled\") {\n404:         agents.push(fileResult.value);\n405:       }\n406:     }\n407:   }\n408: \n409:   return agents;\n410: }\n411: \n412: // ---------------------------------------------------------------------------\n413: // Resolution (with TTL + offline fallback)\n414: // ---------------------------------------------------------------------------\n415: \n416: /**\n417:  * Resolve the agent definition for a single task.\n418:  *\n419:  * If the task has no agent_type or registry mode is disabled, returns a\n420:  * generalist fallback. Otherwise checks cache (with TTL) then fetches\n421:  * from the registry. If the fetch fails, falls back to stale cache\n422:  * silently with a warning (offline support).\n423:  */\n424: export async function resolveAgentForTask(\n425:   task: Task,\n426:   config: WomboConfig,\n427:   projectRoot: string\n428: ): Promise<AgentResolution> {\n429:   // No agent_type specified or registry disabled → generalist\n430:   if (!task.agent_type || config.agentRegistry.mode === \"disabled\") {\n431:     return {\n432:       taskId: task.id,\n433:       name: null,\n434:       rawContent: null,\n435:       fromCache: false,\n436:       agentType: null,\n437:     };\n438:   }\n439: \n440:   const agentType = task.agent_type;\n441:   const name = agentNameFromType(agentType);\n442: \n443:   // Check cache first — only use if within TTL\n444:   if (isCacheValid(projectRoot, config, agentType)) {\n445:     const cached = getCachedAgent(projectRoot, config, agentType);\n446:     if (cached !== null) {\n447:       return {\n448:         taskId: task.id,\n449:         name,\n450:         rawContent: cached,\n451:         fromCache: true,\n452:         agentType,\n453:       };\n454:     }\n455:   }\n456: \n457:   // Attempt to fetch from registry\n458:   try {\n459:     const rawContent = await fetchAgent(agentType, config.agentRegistry.source);\n460: \n461:     // Cache the raw download\n462:     cacheAgent(projectRoot, config, agentType, rawContent);\n463: \n464:     return {\n465:       taskId: task.id,\n466:       name,\n467:       rawContent,\n468:       fromCache: false,\n469:       agentType,\n470:     };\n471:   } catch (fetchError: any) {\n472:     // Offline fallback: try stale cache (ignore TTL)\n473:     const staleCache = getCachedAgent(projectRoot, config, agentType);\n474:     if (staleCache !== null) {\n475:       console.warn(\n476:         `\\x1b[33m[WARNING]\\x1b[0m Failed to fetch agent \"${agentType}\" from registry: ${fetchError?.message ?? fetchError}`\n477:       );\n478:       console.warn(\n479:         `  Using stale cached version (offline fallback).\\n`\n480:       );\n481:       return {\n482:         taskId: task.id,\n483:         name,\n484:         rawContent: staleCache,\n485:         fromCache: true,\n486:         agentType,\n487:       };\n488:     }\n489: \n490:     // No cache available — re-throw the original error\n491:     throw fetchError;\n492:   }\n493: }\n494: \n495: /**\n496:  * Resolve agent definitions for all tasks in a launch wave.\n497:  *\n498:  * Returns a Map from task ID to agent resolution. Fetches are parallelized.\n499:  * Individual fetch failures are caught and logged — the task falls back to\n500:  * the generalist agent rather than blocking the entire wave.\n501:  */\n502: export async function prepareAgentDefinitions(\n503:   tasks: Task[],\n504:   config: WomboConfig,\n505:   projectRoot: string\n506: ): Promise<Map<string, AgentResolution>> {\n507:   const results = new Map<string, AgentResolution>();\n508: \n509:   // Resolve all tasks in parallel\n510:   const resolutions = await Promise.allSettled(\n511:     tasks.map(async (task) => {\n512:       const resolution = await resolveAgentForTask(task, config, projectRoot);\n513:       return { taskId: task.id, resolution };\n514:     })\n515:   );\n516: \n517:   for (const result of resolutions) {\n518:     if (result.status === \"fulfilled\") {\n519:       results.set(result.value.taskId, result.value.resolution);\n520:     } else {\n521:       // Extract task ID from the error context — find the task that failed\n522:       // by checking which tasks don't have results yet\n523:       const resolvedIds = new Set(results.keys());\n524:       const failedTask = tasks.find((t) => !resolvedIds.has(t.id));\n525:       if (failedTask) {\n526:         console.warn(\n527:           `\\x1b[33m[WARNING]\\x1b[0m Failed to resolve agent for task \"${failedTask.id}\": ${result.reason?.message ?? result.reason}`\n528:         );\n529:         console.warn(`  Falling back to generalist agent.\\n`);\n530:         results.set(failedTask.id, {\n531:           taskId: failedTask.id,\n532:           name: null,\n533:           rawContent: null,\n534:           fromCache: false,\n535:           agentType: null,\n536:         });\n537:       }\n538:     }\n539:   }\n540: \n541:   return results;\n542: }\n543: \n544: /**\n545:  * Write a patched agent definition into a worktree's agent/ directory.\n546:  *\n547:  * @param worktreePath — absolute path to the worktree root\n548:  * @param agentName    — derived name (e.g. \"engineering-frontend-developer\")\n549:  * @param patchedContent — fully patched markdown content\n550:  */\n551: export function writeAgentToWorktree(\n552:   worktreePath: string,\n553:   agentName: string,\n554:   patchedContent: string\n555: ): void {\n556:   const agentDir = resolve(worktreePath, \".opencode\", \"agents\");\n557:   mkdirSync(agentDir, { recursive: true });\n558:   const agentPath = resolve(agentDir, `${agentName}.md`);\n559:   writeFileSync(agentPath, patchedContent, \"utf-8\");\n560: }\n561: \n562: /**\n563:  * Check if a resolution is a specialized agent (not generalist fallback).\n564:  */\n565: export function isSpecializedAgent(resolution: AgentResolution): resolution is ResolvedAgent {\n566:   return resolution.name !== null && resolution.rawContent !== null;\n567: }\n\n(End of file - total 567 lines)\n</content>","title":"src/lib/agent-registry.ts","metadata":{"preview":"/**\n * agent-registry.ts — Fetch, cache, and resolve specialized agent definitions\n * from an external registry (e.g. github.com/msitarzewski/agency-agents).\n *\n * Flow:\n *   1. Task has `agent_type: \"engineering/engineering-frontend-developer\"`\n *   2. resolveAgentForTask() checks cache, fetches if missing, returns raw md\n *   3. At launch time, raw md is patched via patchImportedAgent() and written\n *      into the worktree's .opencode/agents/ directory\n *\n * Cache layout:\n *   .wombo-combo/agents-cache/engineering/engineering-frontend-developer.md\n *\n * Raw downloads are cached. Patching is done at launch time (not cached)\n * because patches depend on runtime config (portless, placeholders, etc.).\n */\n\nimport { resolve, dirname, relative } from \"node:path\";\nimport {\n  existsSync,","truncated":false,"loaded":[]},"time":{"start":1773439930175,"end":1773439930180}}}}
{"type":"tool_use","timestamp":1773439930673,"sessionID":"ses_316be8c08ffeZXbNAgwvZBSoRI","part":{"id":"prt_ce941cf41001BzomoiSG9c9HRd","sessionID":"ses_316be8c08ffeZXbNAgwvZBSoRI","messageID":"msg_ce941bce70010SbLrb1NHkgeJu","type":"tool","callID":"toolu_vrtx_01VrfMTjwNfBuZAp3cksT7Y5","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/dynamic-agent-types/src/lib/templates.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/dynamic-agent-types/src/lib/templates.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * templates.ts — Resolve paths to bundled template files, render agent\n3:  * definitions, and compose patched agent definitions from imported agents.\n4:  *\n5:  * Template architecture:\n6:  *\n7:  *   generalist-agent.md          — standalone agent definition (no imported base)\n8:  *   wc-patch.description.end.md  — appended to imported agent's frontmatter description\n9:  *   wc-patch.body.start.md       — prepended to imported agent's body\n10:  *   wc-patch.body.end.md         — appended to imported agent's body\n11:  *\n12:  * Conditional blocks (portless, browser testing) are injected programmatically\n13:  * by the render/patch functions based on config — never left as \"if enabled\"\n14:  * prose for the LLM to interpret.\n15:  */\n16: \n17: import { join, dirname, resolve } from \"node:path\";\n18: import { existsSync, readFileSync, writeFileSync, mkdirSync } from \"node:fs\";\n19: import YAML from \"yaml\";\n20: import type { WomboConfig } from \"../config.js\";\n21: import { isPortlessAvailable } from \"./portless.js\";\n22: import { normalizeAgentFormat } from \"./format-converter.js\";\n23: \n24: // ---------------------------------------------------------------------------\n25: // Template Directory & Paths\n26: // ---------------------------------------------------------------------------\n27: \n28: const TEMPLATES_DIR = join(dirname(import.meta.dir), \"templates\");\n29: \n30: /** Standalone generalist agent template. */\n31: export const GENERALIST_TEMPLATE_PATH = join(TEMPLATES_DIR, \"generalist-agent.md\");\n32: \n33: /** Patch: text appended to an imported agent's frontmatter `description` field. */\n34: export const PATCH_DESCRIPTION_END_PATH = join(TEMPLATES_DIR, \"wc-patch.description.end.md\");\n35: \n36: /** Patch: markdown prepended to an imported agent's body. */\n37: export const PATCH_BODY_START_PATH = join(TEMPLATES_DIR, \"wc-patch.body.start.md\");\n38: \n39: /** Patch: markdown appended to an imported agent's body. */\n40: export const PATCH_BODY_END_PATH = join(TEMPLATES_DIR, \"wc-patch.body.end.md\");\n41: \n42: /**\n43:  * Backward-compatible alias. Code that referenced `AGENT_TEMPLATE_PATH`\n44:  * continues to work — it now points to the generalist template.\n45:  */\n46: export const AGENT_TEMPLATE_PATH = GENERALIST_TEMPLATE_PATH;\n47: \n48: // ---------------------------------------------------------------------------\n49: // Deterministic Conditional Blocks\n50: // ---------------------------------------------------------------------------\n51: \n52: /**\n53:  * Portless server-testing block. Injected by render/patch functions ONLY when\n54:  * `config.portless.enabled` is true. The agent never sees \"if portless is\n55:  * enabled\" — it either gets these instructions or it doesn't.\n56:  */\n57: const PORTLESS_BLOCK = `\n58: ## Server Testing (portless)\n59: \n60: Your environment is preconfigured with **portless** for collision-free localhost servers:\n61: \n62: - **\\`PORTLESS_ENABLED=1\\`** is set in your environment.\n63: - **Do NOT hardcode port numbers.** Use \\`process.env.PORT\\` or let your framework pick a port automatically.\n64: - **Use \\`portless run <cmd>\\`** to start dev servers (e.g., \\`portless run bun start\\`). This auto-assigns a port and gives you a stable \\`.localhost\\` URL via \\`PORTLESS_URL\\`.\n65: - **Check \\`PORTLESS_URL\\`** in your environment for the stable URL assigned to your worktree's server.\n66: - Multiple agents can run dev servers simultaneously without port conflicts — portless handles routing through its proxy.\n67: - **Never hardcode port numbers.** Always use the portless-assigned port.\n68: `;\n69: \n70: /**\n71:  * TDD red-green-refactor block. Injected by render/patch functions ONLY when\n72:  * `config.tdd.enabled` is true. The agent never sees \"if TDD is enabled\" —\n73:  * it either gets these instructions or it doesn't.\n74:  *\n75:  * The `{{testCommand}}` placeholder is replaced at render time.\n76:  */\n77: const TDD_BLOCK = `\n78: ## Test-Driven Development (TDD)\n79: \n80: You MUST follow the **red-green-refactor** TDD cycle for all implementation work:\n81: \n82: ### The TDD Cycle\n83: \n84: 1. **🔴 Red — Write a failing test first**\n85:    - Before writing any implementation code, write a test that describes the desired behavior.\n86:    - Use Bun's built-in test runner. Create test files alongside source files using the \\`.test.ts\\` naming convention.\n87:    - The test MUST fail initially — this proves the test is actually testing something.\n88: \n89: 2. **🔴 Verify the test fails**\n90:    - Run \\`{{testCommand}}\\` and confirm the new test fails with the expected error.\n91:    - If the test passes without implementation, the test is not testing the right thing — rewrite it.\n92: \n93: 3. **🟢 Green — Write minimal code to pass**\n94:    - Implement just enough production code to make the failing test pass.\n95:    - Do NOT write more code than necessary to satisfy the test.\n96:    - Do NOT add features or handle edge cases not covered by a test yet.\n97: \n98: 4. **🟢 Verify the test passes**\n99:    - Run \\`{{testCommand}}\\` and confirm ALL tests pass (both new and existing).\n100:    - If any test fails, fix the implementation — do NOT modify the test to make it pass (unless the test itself is wrong).\n101: \n102: 5. **🔵 Refactor**\n103:    - Clean up the implementation while keeping all tests green.\n104:    - Extract helpers, rename variables, simplify logic — but run \\`{{testCommand}}\\` after each change.\n105:    - If a refactor breaks a test, undo the refactor and try a different approach.\n106: \n107: ### TDD Rules\n108: \n109: - **Never skip the red step.** Every new behavior starts with a failing test.\n110: - **One behavior per cycle.** Each red-green-refactor iteration should cover exactly one small behavior or edge case.\n111: - **Tests are first-class code.** Keep them readable, well-named, and focused.\n112: - **Run tests frequently.** Run \\`{{testCommand}}\\` after every meaningful change — not just at the end.\n113: - **Commit at green.** Each commit should have all tests passing. Use the cycle boundaries as natural commit points.\n114: \n115: ### Test File Conventions\n116: \n117: - Place test files next to the source: \\`src/foo.ts\\` → \\`src/foo.test.ts\\` (or \\`tests/foo.test.ts\\`)\n118: - Use descriptive test names: \\`test(\"returns empty array when input is null\", ...)\\`\n119: - Import from \\`bun:test\\`: \\`import { describe, test, expect } from \"bun:test\";\\`\n120: `;\n121: \n122: /**\n123:  * Build the TDD block with the configured test command substituted in.\n124:  */\n125: function buildTddBlock(config: WomboConfig): string {\n126:   return TDD_BLOCK.replace(/\\{\\{testCommand\\}\\}/g, config.tdd.testCommand);\n127: }\n128: \n129: // ---------------------------------------------------------------------------\n130: // Placeholder Substitution\n131: // ---------------------------------------------------------------------------\n132: \n133: /**\n134:  * Default runtime description used when no project-specific value is available.\n135:  */\n136: const DEFAULT_RUNTIME = \"Bun (not Node). TypeScript, strict mode, ESM only.\";\n137: \n138: /**\n139:  * Replace {{placeholders}} in template content with config-derived values.\n140:  *\n141:  * Supported placeholders:\n142:  *   - {{tasksDir}}       — tasks directory name (e.g. \"tasks\")\n143:  *   - {{branchPrefix}}   — git branch prefix (e.g. \"feature/\")\n144:  *   - {{buildCommand}}   — build command (e.g. \"bun run build\")\n145:  *   - {{runtime}}        — project runtime description\n146:  *   - {{project}}        — project directory name\n147:  */\n148: function applyPlaceholders(\n149:   content: string,\n150:   config: WomboConfig,\n151:   projectRoot: string\n152: ): string {\n153:   const projectName = projectRoot.split(\"/\").pop() ?? \"project\";\n154:   return content\n155:     .replace(/\\{\\{tasksDir\\}\\}/g, config.tasksDir)\n156:     .replace(/\\{\\{branchPrefix\\}\\}/g, config.git.branchPrefix)\n157:     .replace(/\\{\\{buildCommand\\}\\}/g, config.build.command)\n158:     .replace(/\\{\\{runtime\\}\\}/g, DEFAULT_RUNTIME)\n159:     .replace(/\\{\\{project\\}\\}/g, projectName);\n160: }\n161: \n162: // ---------------------------------------------------------------------------\n163: // Frontmatter Parsing\n164: // ---------------------------------------------------------------------------\n165: \n166: /**\n167:  * Split a markdown file with YAML frontmatter into its two parts.\n168:  * Returns the raw YAML string (without delimiters) and the body.\n169:  */\n170: function splitFrontmatter(md: string): { yaml: string; body: string } {\n171:   const match = md.match(/^---\\r?\\n([\\s\\S]*?)\\r?\\n---\\r?\\n?([\\s\\S]*)$/);\n172:   if (!match) {\n173:     return { yaml: \"\", body: md };\n174:   }\n175:   return { yaml: match[1], body: match[2] };\n176: }\n177: \n178: /**\n179:  * Reassemble frontmatter YAML and body into a markdown string.\n180:  */\n181: function joinFrontmatter(yaml: string, body: string): string {\n182:   if (!yaml.trim()) return body;\n183:   return `---\\n${yaml.trimEnd()}\\n---\\n${body}`;\n184: }\n185: \n186: // ---------------------------------------------------------------------------\n187: // Generalist Agent Rendering\n188: // ---------------------------------------------------------------------------\n189: \n190: /**\n191:  * Render the standalone generalist agent template.\n192:  *\n193:  * This is the default agent definition for projects that don't import a\n194:  * specialized agent from an external registry. Portless instructions are\n195:  * injected deterministically based on config.\n196:  */\n197: export function renderGeneralistAgent(\n198:   config: WomboConfig,\n199:   projectRoot: string\n200: ): string {\n201:   let raw = readFileSync(GENERALIST_TEMPLATE_PATH, \"utf-8\");\n202: \n203:   // Deterministic portless injection\n204:   if (config.portless.enabled && isPortlessAvailable(config)) {\n205:     // Insert portless block before \"## What You Must Never Do\" (or at end)\n206:     const neverDoMarker = \"## What You Must Never Do\";\n207:     const idx = raw.indexOf(neverDoMarker);\n208:     if (idx !== -1) {\n209:       raw = raw.slice(0, idx) + PORTLESS_BLOCK + \"\\n\" + raw.slice(idx);\n210:     } else {\n211:       raw += \"\\n\" + PORTLESS_BLOCK;\n212:     }\n213:   }\n214: \n215:   // Deterministic TDD injection\n216:   if (config.tdd.enabled) {\n217:     const tddContent = buildTddBlock(config);\n218:     const neverDoMarker = \"## What You Must Never Do\";\n219:     const idx = raw.indexOf(neverDoMarker);\n220:     if (idx !== -1) {\n221:       raw = raw.slice(0, idx) + tddContent + \"\\n\" + raw.slice(idx);\n222:     } else {\n223:       raw += \"\\n\" + tddContent;\n224:     }\n225:   }\n226: \n227:   return applyPlaceholders(raw, config, projectRoot);\n228: }\n229: \n230: // ---------------------------------------------------------------------------\n231: // Imported Agent Patching\n232: // ---------------------------------------------------------------------------\n233: \n234: /**\n235:  * Patch an imported agent definition (e.g. from agency-agents) with\n236:  * wombo-combo operational context.\n237:  *\n238:  * Composition order:\n239:  *   1. Parse the imported agent's frontmatter and body\n240:  *   2. Append wc-patch.description.end to the `description` frontmatter field\n241:  *   3. Prepend wc-patch.body.start to the body\n242:  *   4. Append wc-patch.body.end to the body\n243:  *   5. Conditionally inject portless block (deterministic, based on config)\n244:  *   6. Apply {{placeholder}} substitution to the entire result\n245:  *\n246:  * @param rawAgentMd  — raw markdown content of the imported agent file\n247:  * @param config      — wombo-combo project config\n248:  * @param projectRoot — absolute path to the project root\n249:  */\n250: export function patchImportedAgent(\n251:   rawAgentMd: string,\n252:   config: WomboConfig,\n253:   projectRoot: string\n254: ): string {\n255:   // Normalize agency-agents format to woco-compatible format before patching.\n256:   // If the content is already in woco format, this is a no-op.\n257:   const normalizedMd = normalizeAgentFormat(rawAgentMd);\n258: \n259:   const { yaml: rawYaml, body: rawBody } = splitFrontmatter(normalizedMd);\n260: \n261:   // --- Patch frontmatter description ---\n262:   let patchedYaml = rawYaml;\n263:   if (rawYaml) {\n264:     try {\n265:       const descPatchRaw = readFileSync(PATCH_DESCRIPTION_END_PATH, \"utf-8\").trim();\n266:       if (descPatchRaw) {\n267:         const doc = YAML.parseDocument(rawYaml);\n268:         const currentDesc = doc.get(\"description\");\n269:         if (typeof currentDesc === \"string\") {\n270:           doc.set(\"description\", currentDesc.trimEnd() + \"\\n\\n\" + descPatchRaw);\n271:         } else {\n272:           // No description field — add one\n273:           doc.set(\"description\", descPatchRaw);\n274:         }\n275:         // Ensure mode is set for wombo-combo compatibility\n276:         if (!doc.has(\"mode\")) {\n277:           doc.set(\"mode\", \"primary\");\n278:         }\n279:         patchedYaml = YAML.stringify(doc, { lineWidth: 0 }).trimEnd();\n280:       }\n281:     } catch {\n282:       // Patch file missing or YAML parse error — proceed without patching\n283:     }\n284:   }\n285: \n286:   // --- Patch body ---\n287:   let patchedBody = rawBody;\n288: \n289:   // Prepend body.start\n290:   try {\n291:     const bodyStart = readFileSync(PATCH_BODY_START_PATH, \"utf-8\");\n292:     if (bodyStart.trim()) {\n293:       patchedBody = bodyStart + patchedBody;\n294:     }\n295:   } catch {\n296:     // Patch file missing — skip\n297:   }\n298: \n299:   // Append body.end\n300:   try {\n301:     const bodyEnd = readFileSync(PATCH_BODY_END_PATH, \"utf-8\");\n302:     if (bodyEnd.trim()) {\n303:       patchedBody = patchedBody.trimEnd() + \"\\n\" + bodyEnd;\n304:     }\n305:   } catch {\n306:     // Patch file missing — skip\n307:   }\n308: \n309:   // Deterministic portless injection (appended after body.end)\n310:   if (config.portless.enabled && isPortlessAvailable(config)) {\n311:     patchedBody = patchedBody.trimEnd() + \"\\n\" + PORTLESS_BLOCK;\n312:   }\n313: \n314:   // Deterministic TDD injection (appended after portless or body.end)\n315:   if (config.tdd.enabled) {\n316:     patchedBody = patchedBody.trimEnd() + \"\\n\" + buildTddBlock(config);\n317:   }\n318: \n319:   // --- Reassemble & substitute placeholders ---\n320:   const composed = joinFrontmatter(patchedYaml, patchedBody);\n321:   return applyPlaceholders(composed, config, projectRoot);\n322: }\n323: \n324: // ---------------------------------------------------------------------------\n325: // Backward Compatibility\n326: // ---------------------------------------------------------------------------\n327: \n328: /**\n329:  * Render the agent template. When `agentName` is provided and differs from\n330:  * the config default, check for a local agent definition file at\n331:  * `.opencode/agents/<agentName>.md`. If it exists, return its contents\n332:  * with placeholder substitution applied. Otherwise, fall back to the\n333:  * bundled generalist agent.\n334:  */\n335: export function renderAgentTemplate(\n336:   config: WomboConfig,\n337:   projectRoot: string,\n338:   agentName?: string\n339: ): string {\n340:   // If a specific agent is requested and it's not the default generalist,\n341:   // try to read it from the local agents directory.\n342:   if (agentName && agentName !== config.agent.name) {\n343:     const localPath = resolve(projectRoot, \".opencode\", \"agents\", `${agentName}.md`);\n344:     if (existsSync(localPath)) {\n345:       const content = readFileSync(localPath, \"utf-8\");\n346:       return applyPlaceholders(content, config, projectRoot);\n347:     }\n348:     // If the local file doesn't exist, fall back to generalist with a warning\n349:     console.warn(\n350:       `\\x1b[33m[WARNING]\\x1b[0m Local agent definition not found: .opencode/agents/${agentName}.md — falling back to ${config.agent.name}`\n351:     );\n352:   }\n353:   return renderGeneralistAgent(config, projectRoot);\n354: }\n355: \n356: // ---------------------------------------------------------------------------\n357: // Agent Definition Guard\n358: // ---------------------------------------------------------------------------\n359: \n360: /**\n361:  * Ensure the agent definition file exists at the expected path.\n362:  * If missing, reinstall from the bundled generalist template and warn.\n363:  *\n364:  * Called at the start of `woco launch` to prevent the failure mode where\n365:  * agents spawn without their agent definition file.\n366:  *\n367:  * When `agentName` is provided (from a task's `agent` field), also ensure\n368:  * that the specified agent definition exists. For non-default agents,\n369:  * only warns if missing (does not generate a template — the user must\n370:  * provide custom agent definitions).\n371:  *\n372:  * @returns true if the default file was reinstalled, false if it already existed.\n373:  */\n374: export function ensureAgentDefinition(\n375:   projectRoot: string,\n376:   config: WomboConfig,\n377:   agentName?: string\n378: ): boolean {\n379:   const agentDir = resolve(projectRoot, \".opencode\", \"agents\");\n380:   const agentDefPath = resolve(agentDir, `${config.agent.name}.md`);\n381: \n382:   if (existsSync(agentDefPath)) {\n383:     // Default agent exists; also check per-task agent if specified\n384:     if (agentName && agentName !== config.agent.name) {\n385:       const customPath = resolve(agentDir, `${agentName}.md`);\n386:       if (!existsSync(customPath)) {\n387:         console.warn(\n388:           `\\x1b[33m[WARNING]\\x1b[0m Custom agent definition not found: .opencode/agents/${agentName}.md`\n389:         );\n390:         console.warn(\n391:           `  Tasks specifying agent: \"${agentName}\" will fall back to the default agent (${config.agent.name}).\\n`\n392:         );\n393:       }\n394:     }\n395:     return false;\n396:   }\n397: \n398:   // Agent definition missing — reinstall from bundled template\n399:   console.warn(\n400:     `\\x1b[33m[WARNING]\\x1b[0m Agent definition not found: .opencode/agents/${config.agent.name}.md`\n401:   );\n402:   console.warn(`  Reinstalling from bundled generalist template...`);\n403: \n404:   try {\n405:     mkdirSync(agentDir, { recursive: true });\n406:     const content = renderGeneralistAgent(config, projectRoot);\n407:     writeFileSync(agentDefPath, content, \"utf-8\");\n408:     console.warn(`  Restored .opencode/agents/${config.agent.name}.md\\n`);\n409: \n410:     // Also check per-task agent after restoring default\n411:     if (agentName && agentName !== config.agent.name) {\n412:       const customPath = resolve(agentDir, `${agentName}.md`);\n413:       if (!existsSync(customPath)) {\n414:         console.warn(\n415:           `\\x1b[33m[WARNING]\\x1b[0m Custom agent definition not found: .opencode/agents/${agentName}.md`\n416:         );\n417:         console.warn(\n418:           `  Tasks specifying agent: \"${agentName}\" will fall back to the default agent (${config.agent.name}).\\n`\n419:         );\n420:       }\n421:     }\n422: \n423:     return true;\n424:   } catch (err: any) {\n425:     console.error(\n426:       `  Failed to restore agent definition: ${err.message}`\n427:     );\n428:     console.error(\n429:       `  Agents may launch without their definition file.\\n`\n430:     );\n431:     return false;\n432:   }\n433: }\n\n(End of file - total 433 lines)\n</content>","title":"src/lib/templates.ts","metadata":{"preview":"/**\n * templates.ts — Resolve paths to bundled template files, render agent\n * definitions, and compose patched agent definitions from imported agents.\n *\n * Template architecture:\n *\n *   generalist-agent.md          — standalone agent definition (no imported base)\n *   wc-patch.description.end.md  — appended to imported agent's frontmatter description\n *   wc-patch.body.start.md       — prepended to imported agent's body\n *   wc-patch.body.end.md         — appended to imported agent's body\n *\n * Conditional blocks (portless, browser testing) are injected programmatically\n * by the render/patch functions based on config — never left as \"if enabled\"\n * prose for the LLM to interpret.\n */\n\nimport { join, dirname, resolve } from \"node:path\";\nimport { existsSync, readFileSync, writeFileSync, mkdirSync } from \"node:fs\";\nimport YAML from \"yaml\";\nimport type { WomboConfig } from \"../config.js\";","truncated":false,"loaded":[]},"time":{"start":1773439930669,"end":1773439930671}}}}
