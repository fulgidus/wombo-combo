{"type":"tool_use","timestamp":1773483370847,"sessionID":"ses_3142777b4ffe3IuXz7qBZaextx","part":{"id":"prt_cebd8a7b1001CTVt11WSE58L1t","sessionID":"ses_3142777b4ffe3IuXz7qBZaextx","messageID":"msg_cebd89b5b001ItZnpRlVJU47hV","type":"tool","callID":"toolu_vrtx_01VRr8reCUBak9DuHDskPBYq","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/token-tui/src/lib/state.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/token-tui/src/lib/state.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * state.ts — Persistent wave state management.\n3:  *\n4:  * Responsibilities:\n5:  *   - Define the shape of .wombo-combo/state.json\n6:  *   - Read/write state atomically\n7:  *   - Generate wave IDs\n8:  *   - Update individual agent state within a wave\n9:  */\n10: \n11: import { readFileSync, writeFileSync, existsSync, renameSync, mkdirSync } from \"node:fs\";\n12: import { resolve } from \"node:path\";\n13: import { WOMBO_DIR } from \"../config.js\";\n14: \n15: // ---------------------------------------------------------------------------\n16: // Types\n17: // ---------------------------------------------------------------------------\n18: \n19: export type AgentStatus =\n20:   | \"queued\"\n21:   | \"installing\"\n22:   | \"running\"\n23:   | \"completed\"\n24:   | \"verified\"\n25:   | \"failed\"\n26:   | \"merged\"\n27:   | \"retry\"\n28:   | \"resolving_conflict\";\n29: \n30: export interface AgentState {\n31:   feature_id: string;\n32:   branch: string;\n33:   worktree: string;\n34:   session_id: string | null;\n35:   pid: number | null;\n36:   status: AgentStatus;\n37:   activity: string | null;\n38:   activity_updated_at: string | null;\n39:   retries: number;\n40:   max_retries: number;\n41:   started_at: string | null;\n42:   completed_at: string | null;\n43:   build_passed: boolean | null;\n44:   build_output: string | null;\n45:   error: string | null;\n46:   /** Estimated effort in milliseconds (from feature's ISO 8601 duration) */\n47:   effort_estimate_ms: number | null;\n48:   /** Stream index this agent belongs to (for dependency-aware scheduling) */\n49:   stream_index: number | null;\n50:   /** IDs of features this agent depends on (within the current wave) */\n51:   depends_on: string[];\n52:   /** IDs of features that depend on this agent (within the current wave) */\n53:   depended_on_by: string[];\n54:   /**\n55:    * Override agent name for this specific agent (from registry).\n56:    * When set, uses this agent definition instead of the default generalist.\n57:    * e.g. \"engineering-frontend-developer\"\n58:    */\n59:   agent_name: string | null;\n60:   /**\n61:    * The agent_type from the task (e.g. \"engineering/engineering-frontend-developer\").\n62:    * Stored for informational purposes and to support resume with re-fetch.\n63:    */\n64:   agent_type: string | null;\n65: }\n66: \n67: export interface WaveState {\n68:   wave_id: string;\n69:   base_branch: string;\n70:   started_at: string;\n71:   updated_at: string;\n72:   max_concurrent: number;\n73:   model: string | null;\n74:   interactive: boolean;\n75:   agents: AgentState[];\n76:   /** Dependency-aware scheduling plan (null if no dependencies exist) */\n77:   schedule_plan: SerializedSchedulePlan | null;\n78:   /** Quest ID this wave belongs to (null if not quest-scoped) */\n79:   quest_id: string | null;\n80: }\n81: \n82: /**\n83:  * Serialized schedule plan stored in wave state JSON.\n84:  * Uses plain arrays instead of the rich SchedulePlan type for JSON compatibility.\n85:  */\n86: export interface SerializedSchedulePlan {\n87:   /** Streams: each is a list of feature IDs to execute sequentially */\n88:   streams: string[][];\n89:   /** Merge gates: features that must wait for multiple deps from different streams */\n90:   merge_gates: Array<{ feature_id: string; wait_for: string[] }>;\n91:   /** Topological order of all features */\n92:   topological_order: string[];\n93: }\n94: \n95: // ---------------------------------------------------------------------------\n96: // Constants\n97: // ---------------------------------------------------------------------------\n98: \n99: const STATE_FILE = \".wombo-combo/state.json\";\n100: \n101: // ---------------------------------------------------------------------------\n102: // Wave ID Generation\n103: // ---------------------------------------------------------------------------\n104: \n105: /**\n106:  * Generate a unique wave ID based on current timestamp.\n107:  * Format: wave-YYYY-MM-DD-NNN\n108:  */\n109: export function generateWaveId(): string {\n110:   const now = new Date();\n111:   const date = now.toISOString().slice(0, 10);\n112:   const seq = String(now.getHours() * 60 + now.getMinutes()).padStart(3, \"0\");\n113:   return `wave-${date}-${seq}`;\n114: }\n115: \n116: // ---------------------------------------------------------------------------\n117: // State Path\n118: // ---------------------------------------------------------------------------\n119: \n120: function statePath(projectRoot: string): string {\n121:   return resolve(projectRoot, STATE_FILE);\n122: }\n123: \n124: // ---------------------------------------------------------------------------\n125: // Read State\n126: // ---------------------------------------------------------------------------\n127: \n128: /**\n129:  * Load the current wave state from disk. Returns null if no state file exists.\n130:  */\n131: export function loadState(projectRoot: string): WaveState | null {\n132:   const p = statePath(projectRoot);\n133:   if (!existsSync(p)) return null;\n134:   try {\n135:     const raw = readFileSync(p, \"utf-8\");\n136:     return JSON.parse(raw) as WaveState;\n137:   } catch {\n138:     return null;\n139:   }\n140: }\n141: \n142: // ---------------------------------------------------------------------------\n143: // Write State\n144: // ---------------------------------------------------------------------------\n145: \n146: /**\n147:  * Save wave state to disk atomically (write to tmp then rename).\n148:  */\n149: export function saveState(projectRoot: string, state: WaveState): void {\n150:   const dir = resolve(projectRoot, WOMBO_DIR);\n151:   if (!existsSync(dir)) mkdirSync(dir, { recursive: true });\n152:   state.updated_at = new Date().toISOString();\n153:   const p = statePath(projectRoot);\n154:   const tmp = p + \".tmp\";\n155:   writeFileSync(tmp, JSON.stringify(state, null, 2) + \"\\n\", \"utf-8\");\n156:   renameSync(tmp, p);\n157: }\n158: \n159: /**\n160:  * Flush wave state to disk with integrity verification.\n161:  *\n162:  * Like saveState(), but reads back the written file and verifies it parses\n163:  * as valid JSON. This is the \"safe shutdown\" variant — use it before\n164:  * process.exit() or screen.destroy() to guarantee the state file is not\n165:  * left in a partial/corrupt state.\n166:  *\n167:  * If the integrity check fails, a second write attempt is made. If that\n168:  * also fails, the error is logged but not thrown (we're shutting down).\n169:  *\n170:  * @returns true if the state was written and verified successfully.\n171:  */\n172: export function flushState(projectRoot: string, state: WaveState): boolean {\n173:   for (let attempt = 1; attempt <= 2; attempt++) {\n174:     try {\n175:       saveState(projectRoot, state);\n176: \n177:       // Read back and verify JSON integrity\n178:       const p = statePath(projectRoot);\n179:       const raw = readFileSync(p, \"utf-8\");\n180:       const parsed = JSON.parse(raw) as WaveState;\n181: \n182:       // Sanity check: wave_id and agents array must survive the round-trip\n183:       if (parsed.wave_id !== state.wave_id) {\n184:         throw new Error(\n185:           `wave_id mismatch after write: expected \"${state.wave_id}\", got \"${parsed.wave_id}\"`\n186:         );\n187:       }\n188:       if (!Array.isArray(parsed.agents) || parsed.agents.length !== state.agents.length) {\n189:         throw new Error(\n190:           `agents array mismatch after write: expected ${state.agents.length} agents, got ${Array.isArray(parsed.agents) ? parsed.agents.length : \"non-array\"}`\n191:         );\n192:       }\n193: \n194:       return true;\n195:     } catch (err: any) {\n196:       if (attempt === 1) {\n197:         // First failure — retry once\n198:         try {\n199:           // Log to stderr so it doesn't corrupt TUI output\n200:           process.stderr.write(\n201:             `[wombo] state flush attempt ${attempt} failed: ${err.message} — retrying...\\n`\n202:           );\n203:         } catch {\n204:           // stderr may be closed during shutdown\n205:         }\n206:       } else {\n207:         // Second failure — give up but don't throw (we're shutting down)\n208:         try {\n209:           process.stderr.write(\n210:             `[wombo] state flush failed after 2 attempts: ${err.message}\\n`\n211:           );\n212:         } catch {\n213:           // stderr may be closed during shutdown\n214:         }\n215:       }\n216:     }\n217:   }\n218:   return false;\n219: }\n220: \n221: // ---------------------------------------------------------------------------\n222: // State Mutations\n223: // ---------------------------------------------------------------------------\n224: \n225: /**\n226:  * Create a fresh wave state.\n227:  */\n228: export function createWaveState(opts: {\n229:   baseBranch: string;\n230:   maxConcurrent: number;\n231:   model: string | null;\n232:   interactive: boolean;\n233:   questId?: string | null;\n234: }): WaveState {\n235:   return {\n236:     wave_id: generateWaveId(),\n237:     base_branch: opts.baseBranch,\n238:     started_at: new Date().toISOString(),\n239:     updated_at: new Date().toISOString(),\n240:     max_concurrent: opts.maxConcurrent,\n241:     model: opts.model,\n242:     interactive: opts.interactive,\n243:     agents: [],\n244:     schedule_plan: null,\n245:     quest_id: opts.questId ?? null,\n246:   };\n247: }\n248: \n249: /**\n250:  * Create an initial agent state for a feature.\n251:  */\n252: export function createAgentState(\n253:   featureId: string,\n254:   branch: string,\n255:   worktreePath: string,\n256:   maxRetries: number = 2\n257: ): AgentState {\n258:   return {\n259:     feature_id: featureId,\n260:     branch,\n261:     worktree: worktreePath,\n262:     session_id: null,\n263:     pid: null,\n264:     status: \"queued\",\n265:     activity: null,\n266:     activity_updated_at: null,\n267:     retries: 0,\n268:     max_retries: maxRetries,\n269:     started_at: null,\n270:     completed_at: null,\n271:     build_passed: null,\n272:     build_output: null,\n273:     error: null,\n274:     effort_estimate_ms: null,\n275:     stream_index: null,\n276:     depends_on: [],\n277:     depended_on_by: [],\n278:     agent_name: null,\n279:     agent_type: null,\n280:   };\n281: }\n282: \n283: /**\n284:  * Find an agent state by feature ID.\n285:  */\n286: export function getAgent(\n287:   state: WaveState,\n288:   featureId: string\n289: ): AgentState | undefined {\n290:   return state.agents.find((a) => a.feature_id === featureId);\n291: }\n292: \n293: /**\n294:  * Update an agent's state fields.\n295:  */\n296: export function updateAgent(\n297:   state: WaveState,\n298:   featureId: string,\n299:   updates: Partial<AgentState>\n300: ): void {\n301:   const agent = state.agents.find((a) => a.feature_id === featureId);\n302:   if (!agent) throw new Error(`Agent not found for feature: ${featureId}`);\n303:   Object.assign(agent, updates);\n304: }\n305: \n306: /**\n307:  * Get counts of agents by status.\n308:  */\n309: export function agentCounts(state: WaveState): Record<AgentStatus, number> {\n310:   const counts: Record<AgentStatus, number> = {\n311:     queued: 0,\n312:     installing: 0,\n313:     running: 0,\n314:     completed: 0,\n315:     verified: 0,\n316:     failed: 0,\n317:     merged: 0,\n318:     retry: 0,\n319:     resolving_conflict: 0,\n320:   };\n321:   for (const a of state.agents) {\n322:     counts[a.status]++;\n323:   }\n324:   return counts;\n325: }\n326: \n327: /**\n328:  * Get agents that are currently running or installing.\n329:  */\n330: export function activeAgents(state: WaveState): AgentState[] {\n331:   return state.agents.filter(\n332:     (a) => a.status === \"running\" || a.status === \"installing\" || a.status === \"resolving_conflict\"\n333:   );\n334: }\n335: \n336: /**\n337:  * Get agents that are queued and ready to be launched.\n338:  */\n339: export function queuedAgents(state: WaveState): AgentState[] {\n340:   return state.agents.filter((a) => a.status === \"queued\");\n341: }\n342: \n343: /**\n344:  * Check if the wave is fully complete (no queued, installing, running, or retry agents).\n345:  */\n346: export function isWaveComplete(state: WaveState): boolean {\n347:   return state.agents.every(\n348:     (a) =>\n349:       a.status === \"completed\" ||\n350:       a.status === \"verified\" ||\n351:       a.status === \"failed\" ||\n352:       a.status === \"merged\"\n353:   );\n354: }\n355: \n356: // ---------------------------------------------------------------------------\n357: // Dependency-Aware Helpers\n358: // ---------------------------------------------------------------------------\n359: \n360: /**\n361:  * Terminal statuses that count as \"dependency satisfied\" for downstream features.\n362:  * A dependency is satisfied when it has been verified or merged.\n363:  */\n364: const DEP_SATISFIED_STATUSES: Set<AgentStatus> = new Set([\"verified\", \"merged\"]);\n365: \n366: /**\n367:  * Check if an agent's dependencies within the wave are all satisfied.\n368:  * Dependencies are satisfied when their agents reach \"verified\" or \"merged\" status.\n369:  *\n370:  * If the agent has no depends_on entries, it's always ready.\n371:  */\n372: export function areAgentDepsReady(\n373:   state: WaveState,\n374:   agent: AgentState\n375: ): boolean {\n376:   if (agent.depends_on.length === 0) return true;\n377: \n378:   for (const depId of agent.depends_on) {\n379:     const depAgent = state.agents.find((a) => a.feature_id === depId);\n380:     if (depAgent && !DEP_SATISFIED_STATUSES.has(depAgent.status)) {\n381:       return false;\n382:     }\n383:     // If depAgent doesn't exist in this wave, the dep is external — assumed satisfied\n384:   }\n385:   return true;\n386: }\n387: \n388: /**\n389:  * Get queued agents whose dependencies are all satisfied.\n390:  * This is the dependency-aware replacement for plain queuedAgents().\n391:  */\n392: export function readyToLaunchAgents(state: WaveState): AgentState[] {\n393:   return state.agents.filter(\n394:     (a) => a.status === \"queued\" && areAgentDepsReady(state, a)\n395:   );\n396: }\n397: \n398: /**\n399:  * Get all agents that are downstream (depend on) a given feature, directly or transitively.\n400:  * Used for failure cascading — when a feature fails, cancel all downstream.\n401:  */\n402: export function getDownstreamAgents(\n403:   state: WaveState,\n404:   featureId: string\n405: ): AgentState[] {\n406:   const visited = new Set<string>();\n407:   const result: AgentState[] = [];\n408: \n409:   function collect(id: string): void {\n410:     const agent = state.agents.find((a) => a.feature_id === id);\n411:     if (!agent) return;\n412: \n413:     for (const downstreamId of agent.depended_on_by) {\n414:       if (visited.has(downstreamId)) continue;\n415:       visited.add(downstreamId);\n416: \n417:       const downstream = state.agents.find((a) => a.feature_id === downstreamId);\n418:       if (downstream) {\n419:         result.push(downstream);\n420:         collect(downstreamId);\n421:       }\n422:     }\n423:   }\n424: \n425:   collect(featureId);\n426:   return result;\n427: }\n428: \n429: /**\n430:  * Cancel all downstream agents when an upstream dependency fails.\n431:  * Sets status to \"failed\" with an error explaining the dependency failure.\n432:  * Returns the list of cancelled agent IDs.\n433:  */\n434: export function cancelDownstream(\n435:   state: WaveState,\n436:   failedFeatureId: string\n437: ): string[] {\n438:   const downstream = getDownstreamAgents(state, failedFeatureId);\n439:   const cancelled: string[] = [];\n440: \n441:   for (const agent of downstream) {\n442:     // Only cancel agents that haven't already reached a terminal state\n443:     if (\n444:       agent.status === \"queued\" ||\n445:       agent.status === \"installing\" ||\n446:       agent.status === \"running\" ||\n447:       agent.status === \"retry\"\n448:     ) {\n449:       updateAgent(state, agent.feature_id, {\n450:         status: \"failed\",\n451:         error: `Dependency \"${failedFeatureId}\" failed — downstream cancelled`,\n452:         activity: null,\n453:         completed_at: new Date().toISOString(),\n454:       });\n455:       cancelled.push(agent.feature_id);\n456:     }\n457:   }\n458: \n459:   return cancelled;\n460: }\n\n(End of file - total 460 lines)\n</content>","title":"src/lib/state.ts","metadata":{"preview":"/**\n * state.ts — Persistent wave state management.\n *\n * Responsibilities:\n *   - Define the shape of .wombo-combo/state.json\n *   - Read/write state atomically\n *   - Generate wave IDs\n *   - Update individual agent state within a wave\n */\n\nimport { readFileSync, writeFileSync, existsSync, renameSync, mkdirSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\nimport { WOMBO_DIR } from \"../config.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type AgentStatus =\n  | \"queued\"","truncated":false,"loaded":[]},"time":{"start":1773483370840,"end":1773483370846}}}}
{"type":"step_finish","timestamp":1773483371015,"sessionID":"ses_3142777b4ffe3IuXz7qBZaextx","part":{"id":"prt_cebd8a960001yNmdDExgKWEuc5","sessionID":"ses_3142777b4ffe3IuXz7qBZaextx","messageID":"msg_cebd89b5b001ItZnpRlVJU47hV","type":"step-finish","reason":"tool-calls","snapshot":"d21063b64da18dc45ca54de5ec6298af92b5e3e7","cost":0,"tokens":{"total":19438,"input":19216,"output":222,"reasoning":0,"cache":{"read":0,"write":0}}}}
