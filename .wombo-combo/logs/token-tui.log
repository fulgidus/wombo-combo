{"type":"tool_use","timestamp":1773483380699,"sessionID":"ses_3142777b4ffe3IuXz7qBZaextx","part":{"id":"prt_cebd8cdf0001LKZzPyWeHSLz6T","sessionID":"ses_3142777b4ffe3IuXz7qBZaextx","messageID":"msg_cebd8bf4a0011VZIdCvM5CEOg3","type":"tool","callID":"toolu_vrtx_01Kd5rEsFsfTTDfZ8YdCeXFV","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/token-tui/src/lib/monitor.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/token-tui/src/lib/monitor.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * monitor.ts — Parse JSON events from agent and detect completion/failure.\n3:  *\n4:  * Responsibilities:\n5:  *   - Parse newline-delimited JSON events from agent stdout\n6:  *   - Detect session completion (agent finished)\n7:  *   - Detect session ID from events\n8:  *   - Detect errors and failures\n9:  *   - Write per-agent raw log files for diagnostics\n10:  *   - Maintain per-agent parsed activity log for TUI preview\n11:  *\n12:  * ## Process Lifecycle (audit: wave-detach-audit)\n13:  *\n14:  * ProcessMonitor manages the lifecycle of headless agent child processes:\n15:  *\n16:  * **Normal flow**: Agent stdout → JSON event parsing → callbacks → completion\n17:  *   1. `addProcess()` registers a ChildProcess and attaches stdout/stderr listeners\n18:  *   2. Stdout data is parsed line-by-line as JSON events\n19:  *   3. Callbacks fire: `onSessionId`, `onActivity`, `onComplete`, `onError`\n20:  *   4. On process exit (code 0 or sawFinalStop), `onComplete` is called\n21:  *   5. On process exit (non-zero, no final stop), `onError` is called\n22:  *\n23:  * **Teardown flow**: Parent quit → `killAll()` → SIGTERM to each child\n24:  *   1. TUI `onQuit` or SIGINT handler calls `monitor.killAll()`\n25:  *   2. `killAll()` iterates all processes and calls `remove(featureId)`\n26:  *   3. `remove()` sends SIGTERM to the child process (if still running)\n27:  *   4. The process map entry is deleted — no further events are tracked\n28:  *\n29:  * **Key behavior**: `remove()` and `killAll()` intentionally kill child\n30:  * processes. This is correct because headless agents are spawned with\n31:  * `detached: false` — they are tied to the parent and would die anyway\n32:  * when the parent exits. Explicitly killing them ensures a clean shutdown\n33:  * with proper state saving before the parent terminates.\n34:  *\n35:  * **Edge case**: If the parent is killed with SIGKILL (not catchable),\n36:  * child processes die with no cleanup. `woco resume` handles this by\n37:  * detecting orphaned worktrees with commits and re-verifying/re-launching.\n38:  */\n39: \n40: import type { ChildProcess } from \"node:child_process\";\n41: import { isProcessRunning } from \"./launcher.js\";\n42: import { mkdirSync, appendFileSync, existsSync, readFileSync } from \"node:fs\";\n43: import { resolve } from \"node:path\";\n44: import { TokenCollector, type UsageRecord } from \"./token-collector.js\";\n45: import { UsageStore } from \"./token-usage.js\";\n46: \n47: // ---------------------------------------------------------------------------\n48: // Log directory name (configurable would be overkill here)\n49: // ---------------------------------------------------------------------------\n50: \n51: const LOG_DIR_NAME = \".wombo-combo/logs\";\n52: \n53: // ---------------------------------------------------------------------------\n54: // Types — OpenCode JSON Events\n55: // ---------------------------------------------------------------------------\n56: \n57: export interface OpenCodeEvent {\n58:   type: string;\n59:   sessionID?: string;\n60:   timestamp?: number;\n61:   part?: {\n62:     type?: string;\n63:     tool?: string;\n64:     callID?: string;\n65:     text?: string;\n66:     reason?: string;\n67:     cost?: number;\n68:     tokens?: {\n69:       total: number;\n70:       input: number;\n71:       output: number;\n72:       reasoning: number;\n73:       cache?: {\n74:         read: number;\n75:         write: number;\n76:       };\n77:     };\n78:     state?: {\n79:       status?: string;\n80:       input?: Record<string, any>;\n81:       output?: string;\n82:       error?: string;\n83:     };\n84:   };\n85:   [key: string]: any;\n86: }\n87: \n88: // ---------------------------------------------------------------------------\n89: // Event Parser\n90: // ---------------------------------------------------------------------------\n91: \n92: export interface ParsedOutput {\n93:   sessionId: string | null;\n94:   completed: boolean;\n95:   errored: boolean;\n96:   lastError: string | null;\n97:   events: OpenCodeEvent[];\n98: }\n99: \n100: export function parseEvents(rawOutput: string): ParsedOutput {\n101:   const result: ParsedOutput = {\n102:     sessionId: null,\n103:     completed: false,\n104:     errored: false,\n105:     lastError: null,\n106:     events: [],\n107:   };\n108: \n109:   const lines = rawOutput.split(\"\\n\").filter((l) => l.trim());\n110: \n111:   for (const line of lines) {\n112:     try {\n113:       const event = JSON.parse(line) as OpenCodeEvent;\n114:       result.events.push(event);\n115: \n116:       if (event.sessionID && !result.sessionId) {\n117:         result.sessionId = event.sessionID;\n118:       }\n119: \n120:       if (\n121:         event.type === \"step_finish\" &&\n122:         event.part?.reason === \"stop\"\n123:       ) {\n124:         result.completed = true;\n125:       }\n126: \n127:       if (\n128:         event.type === \"tool_use\" &&\n129:         event.part?.state?.status === \"error\"\n130:       ) {\n131:         result.errored = true;\n132:         result.lastError = event.part.state.error ?? \"unknown tool error\";\n133:       }\n134:     } catch {\n135:       // Not valid JSON — skip\n136:     }\n137:   }\n138: \n139:   return result;\n140: }\n141: \n142: // ---------------------------------------------------------------------------\n143: // Activity Extraction\n144: // ---------------------------------------------------------------------------\n145: \n146: function shortPath(fullPath: string | undefined, maxLen: number = 30): string {\n147:   if (!fullPath) return \"\";\n148:   const parts = fullPath.replace(/^\\/+/, \"\").split(\"/\");\n149:   const short =\n150:     parts.length > 1\n151:       ? parts.slice(-2).join(\"/\")\n152:       : parts[parts.length - 1];\n153:   if (short.length <= maxLen) return short;\n154:   const fname = parts[parts.length - 1];\n155:   return fname.length <= maxLen ? fname : fname.slice(0, maxLen - 1) + \"\\u2026\";\n156: }\n157: \n158: function shortCmd(cmd: string | undefined, maxLen: number = 30): string {\n159:   if (!cmd) return \"\";\n160:   const first = cmd.split(\"\\n\")[0].trim();\n161:   if (first.length <= maxLen) return first;\n162:   return first.slice(0, maxLen - 1) + \"\\u2026\";\n163: }\n164: \n165: /**\n166:  * Map an event to a human-readable activity string.\n167:  */\n168: export function extractActivity(event: OpenCodeEvent): string | null {\n169:   switch (event.type) {\n170:     case \"step_start\":\n171:       return \"thinking\\u2026\";\n172: \n173:     case \"tool_use\": {\n174:       const toolName = (event.part?.tool ?? \"\").toLowerCase();\n175:       const input = event.part?.state?.input ?? {};\n176:       const status = event.part?.state?.status ?? \"\";\n177: \n178:       if (status === \"error\") {\n179:         return `${toolName}: error`;\n180:       }\n181: \n182:       switch (toolName) {\n183:         case \"read\":\n184:           return `reading ${shortPath(input.filePath ?? input.path)}`;\n185:         case \"write\":\n186:           return `writing ${shortPath(input.filePath ?? input.path)}`;\n187:         case \"edit\":\n188:           return `editing ${shortPath(input.filePath ?? input.path)}`;\n189:         case \"bash\":\n190:         case \"command\":\n191:         case \"terminal\": {\n192:           const cmd = input.command ?? input.cmd ?? \"\";\n193:           // Detect HITL ask script invocation\n194:           if (cmd.includes(\"hitl-ask\")) {\n195:             return \"waiting for human…\";\n196:           }\n197:           return `$ ${shortCmd(cmd)}`;\n198:         }\n199:         case \"glob\":\n200:           return `finding: ${shortPath(input.pattern)}`;\n201:         case \"grep\":\n202:         case \"search\":\n203:           return `searching: ${(input.pattern ?? \"\").slice(0, 25)}`;\n204:         case \"task\":\n205:           return \"delegating task\\u2026\";\n206:         case \"webfetch\":\n207:         case \"web_fetch\":\n208:           return \"fetching URL\\u2026\";\n209:         case \"todowrite\":\n210:         case \"todo_write\":\n211:           return \"planning\\u2026\";\n212:         case \"question\":\n213:           return \"asking question\\u2026\";\n214:         case \"jcodemunch_index_folder\":\n215:         case \"jcodemunch_index_repo\":\n216:           return \"indexing code\\u2026\";\n217:         case \"jcodemunch_search_symbols\":\n218:         case \"jcodemunch_search_text\":\n219:           return \"searching symbols\\u2026\";\n220:         case \"jcodemunch_get_file_outline\":\n221:           return `outlining ${shortPath(input.file_path)}`;\n222:         case \"jcodemunch_get_symbol\":\n223:         case \"jcodemunch_get_symbols\":\n224:           return \"reading symbol\\u2026\";\n225:         default:\n226:           return `tool: ${toolName}`;\n227:       }\n228:     }\n229: \n230:     case \"text\":\n231:       return \"responding\\u2026\";\n232: \n233:     case \"step_finish\":\n234:       if (event.part?.reason === \"stop\") return \"done\";\n235:       if (event.part?.reason === \"tool-calls\") return null;\n236:       return null;\n237: \n238:     default:\n239:       return null;\n240:   }\n241: }\n242: \n243: /**\n244:  * Format an event into a human-readable log line for the activity stream.\n245:  */\n246: export function formatEventForLog(event: OpenCodeEvent): string | null {\n247:   switch (event.type) {\n248:     case \"step_start\":\n249:       return \"-- step started\";\n250: \n251:     case \"tool_use\": {\n252:       const toolName = event.part?.tool ?? \"unknown\";\n253:       const input = event.part?.state?.input ?? {};\n254:       const status = event.part?.state?.status ?? \"\";\n255:       const output = event.part?.state?.output ?? \"\";\n256:       const error = event.part?.state?.error ?? \"\";\n257: \n258:       let line = `>> ${toolName}`;\n259:       switch (toolName.toLowerCase()) {\n260:         case \"read\":\n261:           line = `>> read ${shortPath(input.filePath ?? input.path, 50)}`;\n262:           break;\n263:         case \"write\":\n264:           line = `>> write ${shortPath(input.filePath ?? input.path, 50)}`;\n265:           break;\n266:         case \"edit\":\n267:           line = `>> edit ${shortPath(input.filePath ?? input.path, 50)}`;\n268:           break;\n269:         case \"bash\":\n270:         case \"command\":\n271:           line = `>> $ ${shortCmd(input.command ?? input.cmd, 60)}`;\n272:           break;\n273:         case \"glob\":\n274:           line = `>> glob ${input.pattern ?? \"\"}`;\n275:           break;\n276:         case \"grep\":\n277:           line = `>> grep \"${(input.pattern ?? \"\").slice(0, 30)}\"`;\n278:           break;\n279:         case \"task\":\n280:           line = `>> task: ${(input.description ?? input.prompt ?? \"\").slice(0, 50)}`;\n281:           break;\n282:       }\n283: \n284:       if (status === \"completed\" && output) {\n285:         const preview = output.split(\"\\n\")[0].slice(0, 80);\n286:         return `${line}\\n   ${preview}${output.length > 80 ? \"\\u2026\" : \"\"}`;\n287:       }\n288:       if (status === \"error\" && error) {\n289:         return `${line}\\n!! ${error.slice(0, 100)}`;\n290:       }\n291:       return line;\n292:     }\n293: \n294:     case \"text\": {\n295:       const text = event.part?.text ?? \"\";\n296:       if (!text.trim()) return null;\n297:       const firstLine = text.split(\"\\n\").find((l: string) => l.trim())?.trim() ?? \"\";\n298:       if (firstLine.length === 0) return null;\n299:       return `   ${firstLine.slice(0, 120)}${firstLine.length > 120 ? \"\\u2026\" : \"\"}`;\n300:     }\n301: \n302:     case \"step_finish\": {\n303:       const reason = event.part?.reason ?? \"\";\n304:       const tokens = event.part?.tokens;\n305:       if (reason === \"stop\") {\n306:         let tokStr = \"\";\n307:         if (tokens) {\n308:           const parts = [`${tokens.input}in`, `${tokens.output}out`];\n309:           if (tokens.cache?.read) parts.push(`${tokens.cache.read}cache`);\n310:           tokStr = ` (${parts.join(\"/\")})`;\n311:         }\n312:         return `-- done${tokStr}`;\n313:       }\n314:       return null;\n315:     }\n316: \n317:     default:\n318:       return null;\n319:   }\n320: }\n321: \n322: // ---------------------------------------------------------------------------\n323: // Per-agent Activity Log (in-memory ring buffer for TUI)\n324: // ---------------------------------------------------------------------------\n325: \n326: export interface ActivityEntry {\n327:   timestamp: string;\n328:   text: string;\n329: }\n330: \n331: const MAX_ACTIVITY_LINES = 500;\n332: \n333: // ---------------------------------------------------------------------------\n334: // Process Monitor\n335: // ---------------------------------------------------------------------------\n336: \n337: export interface MonitorCallbacks {\n338:   onSessionId?: (featureId: string, sessionId: string) => void;\n339:   onComplete?: (featureId: string) => void;\n340:   onError?: (featureId: string, error: string) => void;\n341:   onOutput?: (featureId: string, data: string) => void;\n342:   onActivity?: (featureId: string, activity: string) => void;\n343:   /** Called when an agent asks a human question via HITL */\n344:   onQuestion?: (featureId: string, questionText: string) => void;\n345:   /** Called when token usage data is parsed from a step_finish event */\n346:   onUsage?: (featureId: string, record: UsageRecord) => void;\n347: }\n348: \n349: interface MonitoredProcess {\n350:   featureId: string;\n351:   process: ChildProcess | null;\n352:   /** Explicit PID — used for reconnected processes where no ChildProcess handle exists */\n353:   pid: number;\n354:   stdout: string;\n355:   stderr: string;\n356:   sessionId: string | null;\n357:   done: boolean;\n358:   lineBuffer: string;\n359:   sawFinalStop: boolean;\n360:   /** True when this entry was created by reconnectProcess() (PID-only, no ChildProcess) */\n361:   reconnected: boolean;\n362: }\n363: \n364: /**\n365:  * Monitor a set of headless agent processes.\n366:  * Collects stdout, parses events, and calls callbacks on state changes.\n367:  */\n368: export class ProcessMonitor {\n369:   private processes: Map<string, MonitoredProcess> = new Map();\n370:   private callbacks: MonitorCallbacks;\n371:   private logDir: string;\n372:   /** Per-agent activity log for TUI preview pane */\n373:   public activityLogs: Map<string, ActivityEntry[]> = new Map();\n374:   /** Token usage collector — parses and accumulates usage from step_finish events */\n375:   public tokenCollector: TokenCollector;\n376:   /** Token usage store — persists records to .wombo-combo/usage.jsonl */\n377:   public usageStore: UsageStore;\n378: \n379:   constructor(projectRoot: string, callbacks: MonitorCallbacks = {}) {\n380:     this.callbacks = callbacks;\n381:     this.logDir = resolve(projectRoot, LOG_DIR_NAME);\n382:     if (!existsSync(this.logDir)) {\n383:       mkdirSync(this.logDir, { recursive: true });\n384:     }\n385:     this.usageStore = new UsageStore(projectRoot);\n386:     this.tokenCollector = new TokenCollector((record) => {\n387:       // Persist to JSONL file for historical tracking\n388:       try {\n389:         this.usageStore.append(record);\n390:       } catch {\n391:         // Non-critical — don't break agent monitoring if write fails\n392:       }\n393:       this.callbacks.onUsage?.(record.task_id, record);\n394:     });\n395:   }\n396: \n397:   private pushActivity(featureId: string, text: string): void {\n398:     if (!this.activityLogs.has(featureId)) {\n399:       this.activityLogs.set(featureId, []);\n400:     }\n401:     const log = this.activityLogs.get(featureId)!;\n402:     for (const line of text.split(\"\\n\")) {\n403:       log.push({ timestamp: new Date().toISOString().slice(11, 19), text: line });\n404:     }\n405:     if (log.length > MAX_ACTIVITY_LINES) {\n406:       log.splice(0, log.length - MAX_ACTIVITY_LINES);\n407:     }\n408:   }\n409: \n410:   private writeLog(featureId: string, data: string): void {\n411:     try {\n412:       const logFile = resolve(this.logDir, `${featureId}.log`);\n413:       appendFileSync(logFile, data);\n414:     } catch {\n415:       // Non-critical\n416:     }\n417:   }\n418: \n419:   getActivityLog(featureId: string): ActivityEntry[] {\n420:     return this.activityLogs.get(featureId) ?? [];\n421:   }\n422: \n423:   addProcess(featureId: string, child: ChildProcess): void {\n424:     const monitored: MonitoredProcess = {\n425:       featureId,\n426:       process: child,\n427:       pid: child.pid!,\n428:       stdout: \"\",\n429:       stderr: \"\",\n430:       sessionId: null,\n431:       done: false,\n432:       lineBuffer: \"\",\n433:       sawFinalStop: false,\n434:       reconnected: false,\n435:     };\n436: \n437:     this.pushActivity(featureId, \"-- agent process started\");\n438:     this.writeLog(featureId, `[wombo] Process started at ${new Date().toISOString()}\\n`);\n439: \n440:     child.stdout?.on(\"data\", (data: Buffer) => {\n441:       const chunk = data.toString();\n442:       monitored.stdout += chunk;\n443:       this.callbacks.onOutput?.(featureId, chunk);\n444:       this.writeLog(featureId, chunk);\n445: \n446:       monitored.lineBuffer += chunk;\n447:       const lines = monitored.lineBuffer.split(\"\\n\");\n448:       monitored.lineBuffer = lines.pop() ?? \"\";\n449: \n450:       for (const line of lines) {\n451:         const trimmed = line.trim();\n452:         if (!trimmed) continue;\n453:         try {\n454:           const event = JSON.parse(trimmed) as OpenCodeEvent;\n455: \n456:           if (!monitored.sessionId && event.sessionID) {\n457:             monitored.sessionId = event.sessionID;\n458:             this.callbacks.onSessionId?.(featureId, event.sessionID);\n459:             this.pushActivity(featureId, `-- session: ${event.sessionID}`);\n460:           }\n461: \n462:           const activity = extractActivity(event);\n463:           if (activity) {\n464:             this.callbacks.onActivity?.(featureId, activity);\n465:           }\n466: \n467:           const logLine = formatEventForLog(event);\n468:           if (logLine) {\n469:             this.pushActivity(featureId, logLine);\n470:           }\n471: \n472:           // Extract token usage from step_finish events\n473:           this.tokenCollector.ingestEvent(featureId, event);\n474: \n475:           if (\n476:             event.type === \"step_finish\" &&\n477:             event.part?.reason === \"stop\"\n478:           ) {\n479:             monitored.sawFinalStop = true;\n480:           }\n481:         } catch {\n482:           if (trimmed.length > 0 && trimmed.length < 500) {\n483:             this.pushActivity(featureId, `[raw] ${trimmed.slice(0, 120)}`);\n484:           }\n485:         }\n486:       }\n487:     });\n488: \n489:     child.stderr?.on(\"data\", (data: Buffer) => {\n490:       const chunk = data.toString();\n491:       monitored.stderr += chunk;\n492:       this.writeLog(featureId, `[stderr] ${chunk}`);\n493:       const lines = chunk.split(\"\\n\").filter((l) => l.trim());\n494:       for (const line of lines) {\n495:         this.pushActivity(featureId, `[stderr] ${line.trim().slice(0, 120)}`);\n496:       }\n497:     });\n498: \n499:     child.on(\"exit\", (code) => {\n500:       monitored.done = true;\n501:       this.pushActivity(featureId, `-- process exited (code ${code})`);\n502:       this.writeLog(featureId, `\\n[wombo] Process exited with code ${code} at ${new Date().toISOString()}\\n`);\n503: \n504:       if (code === 0 || monitored.sawFinalStop) {\n505:         this.callbacks.onComplete?.(featureId);\n506:       } else {\n507:         const error =\n508:           monitored.stderr.slice(-2000) ||\n509:           `Process exited with code ${code}`;\n510:         this.callbacks.onError?.(featureId, error);\n511:       }\n512:     });\n513: \n514:     child.on(\"error\", (err) => {\n515:       monitored.done = true;\n516:       this.pushActivity(featureId, `!! process error: ${err.message}`);\n517:       this.writeLog(featureId, `\\n[wombo] Process error: ${err.message}\\n`);\n518:       this.callbacks.onError?.(featureId, err.message);\n519:     });\n520: \n521:     this.processes.set(featureId, monitored);\n522:   }\n523: \n524:   /**\n525:    * Reconnect to a running agent process by PID.\n526:    *\n527:    * Creates a \"virtual\" MonitoredProcess entry with no ChildProcess handle.\n528:    * This is used when resuming a wave where agents (typically interactive\n529:    * mux-based agents) are still alive but the parent monitor was stopped.\n530:    *\n531:    * Since there are no stdio pipes to read from, this method:\n532:    *   - Loads historical activity from the existing log file (last N lines)\n533:    *   - Starts a PID polling interval to detect process death\n534:    *   - When the PID dies, fires onComplete or onError callbacks based on\n535:    *     whether the agent's worktree has commits (determined by the caller)\n536:    *\n537:    * The polling loop detects PID death and marks the entry as done, which\n538:    * allows the resume.ts polling loop to handle verification/re-launch.\n539:    */\n540:   reconnectProcess(featureId: string, pid: number, sessionId?: string | null): void {\n541:     const monitored: MonitoredProcess = {\n542:       featureId,\n543:       process: null,\n544:       pid,\n545:       stdout: \"\",\n546:       stderr: \"\",\n547:       sessionId: sessionId ?? null,\n548:       done: false,\n549:       lineBuffer: \"\",\n550:       sawFinalStop: false,\n551:       reconnected: true,\n552:     };\n553: \n554:     this.pushActivity(featureId, `-- reconnected to running process (PID ${pid})`);\n555:     this.writeLog(featureId, `\\n[wombo] Reconnected to PID ${pid} at ${new Date().toISOString()}\\n`);\n556: \n557:     // Load historical activity from the log file so the TUI has context\n558:     this._loadHistoricalActivity(featureId);\n559: \n560:     // Start a polling interval to detect PID death.\n561:     // When the PID dies, mark as done and fire the appropriate callback.\n562:     // The resume.ts polling loop will handle verification/re-launch.\n563:     const pollInterval = setInterval(() => {\n564:       if (!isProcessRunning(pid)) {\n565:         clearInterval(pollInterval);\n566:         monitored.done = true;\n567:         this.pushActivity(featureId, `-- reconnected process exited (PID ${pid})`);\n568:         this.writeLog(featureId, `\\n[wombo] Reconnected process PID ${pid} exited at ${new Date().toISOString()}\\n`);\n569:         // Fire onComplete — the resume.ts polling loop checks branchHasChanges\n570:         // and will downgrade to onError/failed if no commits were made.\n571:         this.callbacks.onComplete?.(featureId);\n572:       }\n573:     }, 2000);\n574: \n575:     // Ensure the interval doesn't hold the process alive if everything else is done\n576:     if (pollInterval.unref) {\n577:       pollInterval.unref();\n578:     }\n579: \n580:     this.processes.set(featureId, monitored);\n581:   }\n582: \n583:   /**\n584:    * Load recent lines from the log file into the activity buffer.\n585:    * Gives the TUI context about what the agent was doing before the monitor\n586:    * was stopped.\n587:    */\n588:   private _loadHistoricalActivity(featureId: string): void {\n589:     const logFile = resolve(this.logDir, `${featureId}.log`);\n590:     if (!existsSync(logFile)) return;\n591: \n592:     try {\n593:       const content = readFileSync(logFile, \"utf-8\");\n594:       const lines = content.split(\"\\n\").filter((l) => l.trim());\n595:       // Take last N lines to avoid flooding the activity buffer\n596:       const recentLines = lines.slice(-50);\n597: \n598:       for (const line of recentLines) {\n599:         const trimmed = line.trim();\n600:         if (!trimmed) continue;\n601: \n602:         // Try parsing as JSON event to extract structured activity\n603:         try {\n604:           const event = JSON.parse(trimmed) as OpenCodeEvent;\n605:           const logLine = formatEventForLog(event);\n606:           if (logLine) {\n607:             this.pushActivity(featureId, logLine);\n608:           }\n609:         } catch {\n610:           // Not JSON — add as raw log line (skip [wombo] meta lines)\n611:           if (!trimmed.startsWith(\"[wombo]\")) {\n612:             this.pushActivity(featureId, `[log] ${trimmed.slice(0, 120)}`);\n613:           }\n614:         }\n615:       }\n616:     } catch {\n617:       // Non-critical — log file may be unreadable\n618:     }\n619:   }\n620: \n621:   getSessionId(featureId: string): string | null {\n622:     return this.processes.get(featureId)?.sessionId ?? null;\n623:   }\n624: \n625:   getOutput(featureId: string): string {\n626:     return this.processes.get(featureId)?.stdout ?? \"\";\n627:   }\n628: \n629:   isRunning(featureId: string): boolean {\n630:     const m = this.processes.get(featureId);\n631:     if (!m) return false;\n632:     if (m.done) return false;\n633:     return isProcessRunning(m.pid);\n634:   }\n635: \n636:   allDone(): boolean {\n637:     for (const m of this.processes.values()) {\n638:       if (!m.done) return false;\n639:     }\n640:     return true;\n641:   }\n642: \n643:   activeCount(): number {\n644:     let count = 0;\n645:     for (const m of this.processes.values()) {\n646:       if (!m.done) count++;\n647:     }\n648:     return count;\n649:   }\n650: \n651:   /**\n652:    * Remove a process from monitoring and kill it if still running.\n653:    *\n654:    * Sends SIGTERM (not SIGKILL) to allow the agent to handle shutdown\n655:    * gracefully (e.g., save partial work, close files). The process map\n656:    * entry is deleted immediately — any subsequent events from the dying\n657:    * process are ignored.\n658:    *\n659:    * For reconnected processes (no ChildProcess handle), uses\n660:    * `process.kill(pid, 'SIGTERM')` directly.\n661:    */\n662:   remove(featureId: string): void {\n663:     const m = this.processes.get(featureId);\n664:     if (m && !m.done) {\n665:       try {\n666:         if (m.process) {\n667:           m.process.kill(\"SIGTERM\");\n668:         } else {\n669:           // Reconnected process — no ChildProcess handle, use PID directly\n670:           process.kill(m.pid, \"SIGTERM\");\n671:         }\n672:       } catch {}\n673:     }\n674:     this.processes.delete(featureId);\n675:   }\n676: \n677:   /**\n678:    * Kill all monitored processes. Called during graceful shutdown\n679:    * (SIGINT, TUI quit) to ensure no orphaned agent processes remain.\n680:    *\n681:    * This is the primary teardown path. After killAll(), the parent\n682:    * process saves wave state and exits. Agents can be re-launched\n683:    * later via `woco resume`.\n684:    *\n685:    * Reconnected processes are NOT killed — they are independent agents\n686:    * (typically in mux sessions) that should survive the parent's exit.\n687:    * They are simply removed from the monitor map so polling stops.\n688:    */\n689:   killAll(): void {\n690:     for (const [id, m] of this.processes.entries()) {\n691:       if (m.reconnected) {\n692:         // Don't kill reconnected processes — just stop monitoring\n693:         this.processes.delete(id);\n694:       } else {\n695:         this.remove(id);\n696:       }\n697:     }\n698:   }\n699: \n700:   waitAll(pollIntervalMs: number = 1000): Promise<void> {\n701:     return new Promise((resolve) => {\n702:       const check = () => {\n703:         if (this.allDone()) {\n704:           resolve();\n705:         } else {\n706:           setTimeout(check, pollIntervalMs);\n707:         }\n708:       };\n709:       check();\n710:     });\n711:   }\n712: }\n713: \n714: // ---------------------------------------------------------------------------\n715: // Re-exports from token-collector for convenience\n716: // ---------------------------------------------------------------------------\n717: \n718: export { TokenCollector, type UsageRecord } from \"./token-collector.js\";\n719: export type { UsageSummary, UsageCallback } from \"./token-collector.js\";\n720: \n721: // ---------------------------------------------------------------------------\n722: // Re-exports from token-usage for convenience\n723: // ---------------------------------------------------------------------------\n724: \n725: export { UsageStore, appendUsageRecord, loadUsageRecords, totalUsage, filterByDateRange, groupBy } from \"./token-usage.js\";\n726: export type { UsageTotals, GroupableField } from \"./token-usage.js\";\n\n(End of file - total 726 lines)\n</content>","title":"src/lib/monitor.ts","metadata":{"preview":"/**\n * monitor.ts — Parse JSON events from agent and detect completion/failure.\n *\n * Responsibilities:\n *   - Parse newline-delimited JSON events from agent stdout\n *   - Detect session completion (agent finished)\n *   - Detect session ID from events\n *   - Detect errors and failures\n *   - Write per-agent raw log files for diagnostics\n *   - Maintain per-agent parsed activity log for TUI preview\n *\n * ## Process Lifecycle (audit: wave-detach-audit)\n *\n * ProcessMonitor manages the lifecycle of headless agent child processes:\n *\n * **Normal flow**: Agent stdout → JSON event parsing → callbacks → completion\n *   1. `addProcess()` registers a ChildProcess and attaches stdout/stderr listeners\n *   2. Stdout data is parsed line-by-line as JSON events\n *   3. Callbacks fire: `onSessionId`, `onActivity`, `onComplete`, `onError`\n *   4. On process exit (code 0 or sawFinalStop), `onComplete` is called","truncated":false,"loaded":[]},"time":{"start":1773483380687,"end":1773483380697}}}}
