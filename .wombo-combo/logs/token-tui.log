.ended_at.slice(0, 10)}`);\n"},"output":"Edit applied successfully.","title":"src/lib/tui-quest-picker.ts","metadata":{"diagnostics":{"/home/fulgidus/Documents/wombo-combo-worktrees/token-tui/src/lib/state.ts":[],"/home/fulgidus/Documents/wombo-combo-worktrees/token-tui/src/lib/tui.ts":[{"range":{"start":{"line":29,"character":0},"end":{"line":29,"character":46}},"message":"'execSync' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"}],"/home/fulgidus/Documents/wombo-combo-worktrees/token-tui/src/lib/token-usage.ts":[],"/home/fulgidus/Documents/wombo-combo-worktrees/token-tui/src/lib/token-collector.ts":[],"/home/fulgidus/Documents/wombo-combo-worktrees/token-tui/src/lib/tui-browser.ts":[{"range":{"start":{"line":37,"character":20},"end":{"line":37,"character":29}},"message":"'TasksFile' is declared but never used.","severity":4,"code":6196,"source":"typescript"},{"range":{"start":{"line":40,"character":25},"end":{"line":40,"character":41}},"message":"'DIFFICULTY_ORDER' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"},{"range":{"start":{"line":47,"character":0},"end":{"line":47,"character":56}},"message":"'UsageRecord' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"},{"range":{"start":{"line":316,"character":10},"end":{"line":316,"character":22}},"message":"'overallUsage' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"}],"/home/fulgidus/Documents/wombo-combo-worktrees/token-tui/src/lib/tui-quest-picker.ts":[{"range":{"start":{"line":156,"character":10},"end":{"line":156,"character":22}},"message":"'overallUsage' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"},{"range":{"start":{"line":274,"character":10},"end":{"line":274,"character":17}},"message":"'taskMap' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"},{"range":{"start":