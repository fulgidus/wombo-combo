{"type":"tool_use","timestamp":1773483539275,"sessionID":"ses_3142777b4ffe3IuXz7qBZaextx","part":{"id":"prt_cebdb37b3002TIgU9CfEOz20ny","sessionID":"ses_3142777b4ffe3IuXz7qBZaextx","messageID":"msg_cebdb2e2f001yk4l1PYw15V1oc","type":"tool","callID":"toolu_vrtx_01At2srcZrFd4NfS73PMS7zp","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/token-tui/src/lib/tui-quest-picker.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/token-tui/src/lib/tui-quest-picker.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tui-quest-picker.ts -- Quest picker view for the wombo-combo TUI.\n3:  *\n4:  * Shows all quests as a selectable list with an \"All Tasks\" option at the top.\n5:  * Selecting a quest navigates to the Task Browser filtered to that quest's tasks.\n6:  *\n7:  * Layout:\n8:  *   +-----------------------------------------------------------+\n9:  *   | WOMBO-COMBO Quest Picker  | 4 quests                      |\n10:  *   +---------------------------+-------------------------------+\n11:  *   | > All Tasks (42)          | Quest: auth-overhaul           |\n12:  *   |   auth-overhaul   ACTV    | Status: active                 |\n13:  *   |   search-api      DRFT    | Priority: high                 |\n14:  *   |   perf-optim      PAUS    | Tasks: 8 (3 done, 62%)         |\n15:  *   |   ui-redesign     PLAN    | Goal: Replace basic auth...    |\n16:  *   |                           |                                |\n17:  *   +---------------------------+-------------------------------+\n18:  *   | Enter:select  C:create  Q:quit                            |\n19:  *   +-----------------------------------------------------------+\n20:  *\n21:  * Keybinds:\n22:  *   Enter/Space  -- select quest (or \"All Tasks\") and proceed to browser\n23:  *   C            -- create new quest (Phase 2 p2-quest-create-tui)\n24:  *   A            -- activate/pause selected quest\n25:  *   Q / C-c      -- quit the TUI\n26:  */\n27: \n28: import blessed from \"neo-blessed\";\n29: import type { Widgets } from \"neo-blessed\";\n30: import type { Quest, QuestHitlMode } from \"./quest.js\";\n31: import { QUEST_STATUS_ORDER, createBlankQuest, VALID_HITL_MODES } from \"./quest.js\";\n32: import { loadAllQuests, saveQuest, loadQuest } from \"./quest-store.js\";\n33: import { VALID_PRIORITIES, VALID_DIFFICULTIES } from \"./task-schema.js\";\n34: import type { Priority, Difficulty } from \"./tasks.js\";\n35: import { loadTasks, getDoneTaskIds, loadArchive } from \"./tasks.js\";\n36: import type { WomboConfig } from \"../config.js\";\n37: import { loadUsageRecords, totalUsage, groupBy as groupUsageBy } from \"./token-usage.js\";\n38: import type { UsageTotals } from \"./token-usage.js\";\n39: // ---------------------------------------------------------------------------\n40: // Types\n41: // ---------------------------------------------------------------------------\n42: \n43: export type QuestPickerAction =\n44:   | { type: \"select\"; questId: string | null }\n45:   | { type: \"plan\"; questId: string }\n46:   | { type: \"genesis\" }\n47:   | { type: \"errand\" }\n48:   | { type: \"wishlist\" }\n49:   | { type: \"quit\" };\n50: \n51: export interface QuestPickerOptions {\n52:   projectRoot: string;\n53:   config: WomboConfig;\n54:   onSelect: (questId: string | null) => void;\n55:   onPlan?: (questId: string) => void;\n56:   onGenesis?: () => void;\n57:   onErrand?: () => void;\n58:   onWishlist?: () => void;\n59:   onQuit: () => void;\n60: }\n61: \n62: // ---------------------------------------------------------------------------\n63: // Display helpers\n64: // ---------------------------------------------------------------------------\n65: \n66: const STATUS_ABBREV: Record<string, string> = {\n67:   draft: \"DRFT\",\n68:   planning: \"PLAN\",\n69:   active: \"ACTV\",\n70:   paused: \"PAUS\",\n71:   completed: \"DONE\",\n72:   abandoned: \"ABAN\",\n73: };\n74: \n75: const STATUS_COLORS: Record<string, string> = {\n76:   draft: \"gray\",\n77:   planning: \"blue\",\n78:   active: \"green\",\n79:   paused: \"yellow\",\n80:   completed: \"cyan\",\n81:   abandoned: \"red\",\n82: };\n83: \n84: const PRIORITY_COLORS: Record<string, string> = {\n85:   critical: \"red\",\n86:   high: \"yellow\",\n87:   medium: \"white\",\n88:   low: \"gray\",\n89:   wishlist: \"gray\",\n90: };\n91: \n92: function escapeBlessedTags(text: string): string {\n93:   return text.replace(/\\{/g, \"\\uFF5B\").replace(/\\}/g, \"\\uFF5D\");\n94: }\n95: \n96: // ---------------------------------------------------------------------------\n97: // Quest summary for display\n98: // ---------------------------------------------------------------------------\n99: \n100: interface QuestSummary {\n101:   quest: Quest;\n102:   totalTasks: number;\n103:   doneTasks: number;\n104:   completionPct: number;\n105: }\n106: \n107: // ---------------------------------------------------------------------------\n108: // QuestPicker Class\n109: // ---------------------------------------------------------------------------\n110: \n111: export class QuestPicker {\n112:   private screen: Widgets.Screen;\n113:   private headerBox: Widgets.BoxElement;\n114:   private questList: Widgets.ListElement;\n115:   private detailBox: Widgets.BoxElement;\n116:   private statusBar: Widgets.BoxElement;\n117: \n118:   private projectRoot: string;\n119:   private config: WomboConfig;\n120:   private onSelect: (questId: string | null) => void;\n121:   private onPlan?: (questId: string) => void;\n122:   private onGenesis?: () => void;\n123:   private onErrand?: () => void;\n124:   private onWishlist?: () => void;\n125:   private onQuit: () => void;\n126: \n127:   /** \"All Tasks\" + quest summaries */\n128:   private items: Array<{ type: \"all\" } | { type: \"quest\"; summary: QuestSummary }> = [];\n129:   private selectedIndex: number = 0;\n130:   private totalTaskCount: number = 0;\n131: \n132:   constructor(opts: QuestPickerOptions) {\n133:     this.projectRoot = opts.projectRoot;\n134:     this.config = opts.config;\n135:     this.onSelect = opts.onSelect;\n136:     this.onPlan = opts.onPlan;\n137:     this.onGenesis = opts.onGenesis;\n138:     this.onErrand = opts.onErrand;\n139:     this.onWishlist = opts.onWishlist;\n140:     this.onQuit = opts.onQuit;\n141: \n142:     this.loadQuests();\n143: \n144:     // Create screen\n145:     this.screen = blessed.screen({\n146:       smartCSR: true,\n147:       title: \"wombo-combo -- Quest Picker\",\n148:       fullUnicode: true,\n149:     });\n150: \n151:     // Header\n152:     this.headerBox = blessed.box({\n153:       top: 0,\n154:       left: 0,\n155:       width: \"100%\",\n156:       height: 3,\n157:       tags: true,\n158:       style: { fg: \"white\", bg: \"black\" },\n159:     });\n160: \n161:     // Quest list (left pane)\n162:     this.questList = blessed.list({\n163:       top: 3,\n164:       left: 0,\n165:       width: \"50%\",\n166:       height: \"100%-6\",\n167:       tags: true,\n168:       scrollable: true,\n169:       mouse: true,\n170:       keys: true,\n171:       vi: true,\n172:       border: { type: \"line\" },\n173:       style: {\n174:         border: { fg: \"gray\" },\n175:         selected: { bg: \"blue\", fg: \"white\", bold: true },\n176:         item: { fg: \"white\" },\n177:       },\n178:       label: \" Quests \",\n179:     });\n180: \n181:     // Detail pane (right pane)\n182:     this.detailBox = blessed.box({\n183:       top: 3,\n184:       left: \"50%\",\n185:       width: \"50%\",\n186:       height: \"100%-6\",\n187:       tags: true,\n188:       scrollable: true,\n189:       mouse: true,\n190:       border: { type: \"line\" },\n191:       style: {\n192:         border: { fg: \"gray\" },\n193:         fg: \"white\",\n194:       },\n195:       label: \" Details \",\n196:     });\n197: \n198:     // Status bar\n199:     this.statusBar = blessed.box({\n200:       bottom: 0,\n201:       left: 0,\n202:       width: \"100%\",\n203:       height: 3,\n204:       tags: true,\n205:       style: { fg: \"white\", bg: \"black\" },\n206:     });\n207: \n208:     // Assemble\n209:     this.screen.append(this.headerBox);\n210:     this.screen.append(this.questList);\n211:     this.screen.append(this.detailBox);\n212:     this.screen.append(this.statusBar);\n213:     this.questList.focus();\n214: \n215:     this.bindKeys();\n216:   }\n217: \n218:   // -----------------------------------------------------------------------\n219:   // Public API\n220:   // -----------------------------------------------------------------------\n221: \n222:   start(): void {\n223:     this.refreshAll();\n224:     this.screen.render();\n225:   }\n226: \n227:   stop(): void {\n228:     this.screen.destroy();\n229:   }\n230: \n231:   destroy(): void {\n232:     this.screen.destroy();\n233:     process.stdout.write(\"\\x1B[2J\\x1B[H\");\n234:   }\n235: \n236:   // -----------------------------------------------------------------------\n237:   // Data Loading\n238:   // -----------------------------------------------------------------------\n239: \n240:   private loadQuests(): void {\n241:     const quests = loadAllQuests(this.projectRoot);\n242:     const tasksData = loadTasks(this.projectRoot, this.config);\n243:     const archiveData = loadArchive(this.projectRoot, this.config);\n244:     const doneIds = getDoneTaskIds(tasksData, archiveData.tasks);\n245:     this.totalTaskCount = tasksData.tasks.length;\n246: \n247:     // Build task lookup for quest summaries\n248:     const taskMap = new Map(tasksData.tasks.map((t) => [t.id, t]));\n249: \n250:     // Sort quests: active first, then by status order, then by priority\n251:     const sorted = [...quests].sort((a, b) => {\n252:       const statusDiff = (QUEST_STATUS_ORDER[a.status] ?? 99) - (QUEST_STATUS_ORDER[b.status] ?? 99);\n253:       if (statusDiff !== 0) return statusDiff;\n254:       return 0;\n255:     });\n256: \n257:     // Build items list\n258:     this.items = [{ type: \"all\" as const }];\n259:     for (const quest of sorted) {\n260:       const totalTasks = quest.taskIds.length;\n261:       const doneTasks = quest.taskIds.filter((id) => doneIds.has(id)).length;\n262:       const completionPct = totalTasks > 0 ? Math.round((doneTasks / totalTasks) * 100) : 0;\n263: \n264:       this.items.push({\n265:         type: \"quest\" as const,\n266:         summary: { quest, totalTasks, doneTasks, completionPct },\n267:       });\n268:     }\n269:   }\n270: \n271:   // -----------------------------------------------------------------------\n272:   // Key Bindings\n273:   // -----------------------------------------------------------------------\n274: \n275:   private bindKeys(): void {\n276:     // Quit\n277:     this.screen.key([\"q\", \"C-c\"], () => {\n278:       this.stop();\n279:       this.onQuit();\n280:     });\n281: \n282:     // Navigate\n283:     this.questList.on(\"select item\", (_item: any, index: number) => {\n284:       this.selectedIndex = index;\n285:       this.refreshDetail();\n286:       this.screen.render();\n287:     });\n288: \n289:     // Enter/Space -- select\n290:     this.screen.key([\"enter\", \"space\"], () => {\n291:       this.selectCurrent();\n292:     });\n293: \n294:     // A -- activate/pause quest\n295:     this.screen.key([\"a\"], () => {\n296:       this.toggleQuestActive();\n297:     });\n298: \n299:     // C -- create new quest\n300:     this.screen.key([\"c\"], () => {\n301:       this.showCreateQuestModal();\n302:     });\n303: \n304:     // P -- plan quest (run planner agent)\n305:     this.screen.key([\"p\"], () => {\n306:       this.planQuest();\n307:     });\n308: \n309:     // G -- genesis (project-level decomposition)\n310:     this.screen.key([\"g\"], () => {\n311:       this.triggerGenesis();\n312:     });\n313: \n314:     // E -- errand (quick task generation without a quest)\n315:     this.screen.key([\"e\"], () => {\n316:       this.triggerErrand();\n317:     });\n318: \n319:     // W -- wishlist browser\n320:     this.screen.key([\"w\"], () => {\n321:       this.triggerWishlist();\n322:     });\n323:   }\n324: \n325:   // -----------------------------------------------------------------------\n326:   // Actions\n327:   // -----------------------------------------------------------------------\n328: \n329:   private selectCurrent(): void {\n330:     const item = this.items[this.selectedIndex];\n331:     if (!item) return;\n332: \n333:     if (item.type === \"all\") {\n334:       this.destroy();\n335:       this.onSelect(null);\n336:     } else {\n337:       this.destroy();\n338:       this.onSelect(item.summary.quest.id);\n339:     }\n340:   }\n341: \n342:   private toggleQuestActive(): void {\n343:     const item = this.items[this.selectedIndex];\n344:     if (!item || item.type === \"all\") return;\n345: \n346:     const quest = item.summary.quest;\n347:     if (quest.status === \"active\") {\n348:       quest.status = \"paused\";\n349:     } else if (quest.status === \"draft\" || quest.status === \"paused\" || quest.status === \"planning\") {\n350:       quest.status = \"active\";\n351:       if (!quest.started_at) {\n352:         quest.started_at = new Date().toISOString();\n353:       }\n354:     } else {\n355:       // completed/abandoned -- can't toggle\n356:       return;\n357:     }\n358: \n359:     saveQuest(this.projectRoot, quest);\n360:     this.loadQuests();\n361:     this.refreshAll();\n362:     this.screen.render();\n363:   }\n364: \n365:   private planQuest(): void {\n366:     if (this.creatingQuest) return;\n367:     const item = this.items[this.selectedIndex];\n368:     if (!item || item.type === \"all\") return;\n369: \n370:     const quest = item.summary.quest;\n371:     // Only allow planning for draft or planning quests\n372:     if (quest.status !== \"draft\" && quest.status !== \"planning\") {\n373:       return;\n374:     }\n375: \n376:     if (!this.onPlan) return;\n377: \n378:     this.destroy();\n379:     this.onPlan(quest.id);\n380:   }\n381: \n382:   private triggerGenesis(): void {\n383:     if (this.creatingQuest) return;\n384:     if (!this.onGenesis) return;\n385: \n386:     this.destroy();\n387:     this.onGenesis();\n388:   }\n389: \n390:   private triggerErrand(): void {\n391:     if (this.creatingQuest) return;\n392:     if (!this.onErrand) return;\n393: \n394:     this.destroy();\n395:     this.onErrand();\n396:   }\n397: \n398:   private triggerWishlist(): void {\n399:     if (this.creatingQuest) return;\n400:     if (!this.onWishlist) return;\n401: \n402:     this.destroy();\n403:     this.onWishlist();\n404:   }\n405: \n406:   // -----------------------------------------------------------------------\n407:   // Create Quest Modal\n408:   // -----------------------------------------------------------------------\n409: \n410:   /** Whether the create modal is currently showing (blocks other key handlers) */\n411:   private creatingQuest = false;\n412: \n413:   /**\n414:    * Show a multi-step modal form to create a new quest.\n415:    * Steps: ID -> Title -> Goal -> Priority -> Difficulty -> HITL -> Confirm\n416:    */\n417:   private showCreateQuestModal(): void {\n418:     if (this.creatingQuest) return;\n419:     this.creatingQuest = true;\n420: \n421:     // Overlay box that covers the detail pane\n422:     const modal = blessed.box({\n423:       parent: this.screen,\n424:       top: \"center\",\n425:       left: \"center\",\n426:       width: \"70%\",\n427:       height: \"80%\",\n428:       tags: true,\n429:       border: { type: \"line\" },\n430:       style: {\n431:         border: { fg: \"magenta\" },\n432:         fg: \"white\",\n433:         bg: \"black\",\n434:       },\n435:       label: \" {magenta-fg}New Quest{/magenta-fg} \",\n436:       shadow: true,\n437:     });\n438: \n439:     // Content area (instructions)\n440:     const content = blessed.box({\n441:       parent: modal,\n442:       top: 0,\n443:       left: 1,\n444:       right: 1,\n445:       height: 3,\n446:       tags: true,\n447:       style: { fg: \"white\", bg: \"black\" },\n448:     });\n449: \n450:     // Textbox for text input steps\n451:     const textbox = blessed.textbox({\n452:       parent: modal,\n453:       top: 3,\n454:       left: 1,\n455:       right: 1,\n456:       height: 3,\n457:       border: { type: \"line\" },\n458:       style: {\n459:         border: { fg: \"cyan\" },\n460:         fg: \"white\",\n461:         bg: \"black\",\n462:         focus: { border: { fg: \"magenta\" } },\n463:       },\n464:       inputOnFocus: true,\n465:     });\n466: \n467:     // Textarea for goal (multi-line)\n468:     const textarea = blessed.textarea({\n469:       parent: modal,\n470:       top: 3,\n471:       left: 1,\n472:       right: 1,\n473:       height: 10,\n474:       border: { type: \"line\" },\n475:       style: {\n476:         border: { fg: \"cyan\" },\n477:         fg: \"white\",\n478:         bg: \"black\",\n479:         focus: { border: { fg: \"magenta\" } },\n480:       },\n481:       inputOnFocus: true,\n482:       hidden: true,\n483:     });\n484: \n485:     // Selection list for enum steps (priority, difficulty, hitl)\n486:     const selectList = blessed.list({\n487:       parent: modal,\n488:       top: 3,\n489:       left: 1,\n490:       right: 1,\n491:       height: \"100%-8\",\n492:       tags: true,\n493:       keys: true,\n494:       vi: true,\n495:       border: { type: \"line\" },\n496:       style: {\n497:         border: { fg: \"cyan\" },\n498:         selected: { bg: \"blue\", fg: \"white\", bold: true },\n499:         item: { fg: \"white\" },\n500:         bg: \"black\",\n501:       },\n502:       hidden: true,\n503:     });\n504: \n505:     // Status line at bottom of modal\n506:     const statusLine = blessed.box({\n507:       parent: modal,\n508:       bottom: 0,\n509:       left: 1,\n510:       right: 1,\n511:       height: 1,\n512:       tags: true,\n513:       style: { fg: \"gray\", bg: \"black\" },\n514:     });\n515: \n516:     // Collected values\n517:     let questId = \"\";\n518:     let questTitle = \"\";\n519:     let questGoal = \"\";\n520:     let questPriority: Priority = \"medium\";\n521:     let questDifficulty: Difficulty = \"medium\";\n522:     let questHitl: QuestHitlMode = \"yolo\";\n523: \n524:     type Step = \"id\" | \"title\" | \"goal\" | \"priority\" | \"difficulty\" | \"hitl\";\n525:     const steps: Step[] = [\"id\", \"title\", \"goal\", \"priority\", \"difficulty\", \"hitl\"];\n526:     let currentStepIdx = 0;\n527: \n528:     const cleanup = () => {\n529:       modal.destroy();\n530:       this.creatingQuest = false;\n531:       this.questList.focus();\n532:       this.screen.render();\n533:     };\n534: \n535:     const showStep = (step: Step) => {\n536:       textbox.hide();\n537:       textarea.hide();\n538:       selectList.hide();\n539: \n540:       const stepLabel = `Step ${currentStepIdx + 1}/${steps.length}`;\n541: \n542:       switch (step) {\n543:         case \"id\":\n544:           content.setContent(\n545:             `{bold}${stepLabel} — Quest ID{/bold}\\n` +\n546:             `{gray-fg}Kebab-case identifier (e.g. auth-overhaul, search-api){/gray-fg}\\n` +\n547:             `{gray-fg}Esc to cancel{/gray-fg}`\n548:           );\n549:           statusLine.setContent(\"{gray-fg}Enter a unique ID for the quest{/gray-fg}\");\n550:           textbox.setValue(\"\");\n551:           textbox.show();\n552:           textbox.focus();\n553:           break;\n554: \n555:         case \"title\":\n556:           content.setContent(\n557:             `{bold}${stepLabel} — Title{/bold}\\n` +\n558:             `{gray-fg}Human-readable name for the quest{/gray-fg}\\n` +\n559:             `{gray-fg}Esc to go back{/gray-fg}`\n560:           );\n561:           statusLine.setContent(`{gray-fg}ID: ${questId}{/gray-fg}`);\n562:           textbox.setValue(\"\");\n563:           textbox.show();\n564:           textbox.focus();\n565:           break;\n566: \n567:         case \"goal\":\n568:           content.setContent(\n569:             `{bold}${stepLabel} — Goal{/bold}\\n` +\n570:             `{gray-fg}What should this quest achieve? (Enter to submit, Esc to go back){/gray-fg}\\n` +\n571:             `{gray-fg}Shift+Enter or \\\\n for newlines{/gray-fg}`\n572:           );\n573:           statusLine.setContent(`{gray-fg}ID: ${questId} | Title: ${questTitle}{/gray-fg}`);\n574:           textarea.setValue(\"\");\n575:           textarea.show();\n576:           textarea.focus();\n577:           break;\n578: \n579:         case \"priority\":\n580:           content.setContent(\n581:             `{bold}${stepLabel} — Priority{/bold}\\n` +\n582:             `{gray-fg}Select with Enter, Esc to go back{/gray-fg}`\n583:           );\n584:           statusLine.setContent(`{gray-fg}ID: ${questId} | Title: ${questTitle}{/gray-fg}`);\n585:           selectList.setItems(\n586:             (VALID_PRIORITIES as readonly string[]).map((p) => {\n587:               const dot = PRIORITY_COLORS[p] ?? \"white\";\n588:               const marker = p === \"medium\" ? \" {gray-fg}(default){/gray-fg}\" : \"\";\n589:               return `  {${dot}-fg}\\u25CF{/${dot}-fg}  ${p}${marker}`;\n590:             }) as any\n591:           );\n592:           // Pre-select \"medium\" (index 2)\n593:           selectList.select(2);\n594:           selectList.show();\n595:           selectList.focus();\n596:           break;\n597: \n598:         case \"difficulty\":\n599:           content.setContent(\n600:             `{bold}${stepLabel} — Difficulty{/bold}\\n` +\n601:             `{gray-fg}Select with Enter, Esc to go back{/gray-fg}`\n602:           );\n603:           statusLine.setContent(`{gray-fg}ID: ${questId} | Priority: ${questPriority}{/gray-fg}`);\n604:           selectList.setItems(\n605:             (VALID_DIFFICULTIES as readonly string[]).map((d) => {\n606:               const marker = d === \"medium\" ? \" {gray-fg}(default){/gray-fg}\" : \"\";\n607:               return `  ${d}${marker}`;\n608:             }) as any\n609:           );\n610:           selectList.select(2);\n611:           selectList.show();\n612:           selectList.focus();\n613:           break;\n614: \n615:         case \"hitl\":\n616:           content.setContent(\n617:             `{bold}${stepLabel} — HITL Mode{/bold}\\n` +\n618:             `{gray-fg}Human-in-the-loop mode for agents. Select with Enter, Esc to go back{/gray-fg}`\n619:           );\n620:           statusLine.setContent(`{gray-fg}ID: ${questId} | Difficulty: ${questDifficulty}{/gray-fg}`);\n621:           const hitlDescs: Record<string, string> = {\n622:             yolo: \"Full autonomy, no interruptions\",\n623:             cautious: \"Agent blocks on uncertainty, user answers in TUI\",\n624:             supervised: \"Like cautious, but prompt encourages asking often\",\n625:           };\n626:           selectList.setItems(\n627:             (VALID_HITL_MODES as readonly string[]).map((m) => {\n628:               const desc = hitlDescs[m] ?? \"\";\n629:               const marker = m === \"yolo\" ? \" {gray-fg}(default){/gray-fg}\" : \"\";\n630:               return `  ${m}${marker}  {gray-fg}— ${desc}{/gray-fg}`;\n631:             }) as any\n632:           );\n633:           selectList.select(0);\n634:           selectList.show();\n635:           selectList.focus();\n636:           break;\n637:       }\n638: \n639:       this.screen.render();\n640:     };\n641: \n642:     const goBack = () => {\n643:       if (currentStepIdx <= 0) {\n644:         cleanup();\n645:         return;\n646:       }\n647:       currentStepIdx--;\n648:       showStep(steps[currentStepIdx]);\n649:     };\n650: \n651:     const advanceOrFinish = () => {\n652:       currentStepIdx++;\n653:       if (currentStepIdx >= steps.length) {\n654:         // All done — create the quest\n655:         this.finishCreateQuest(\n656:           questId,\n657:           questTitle,\n658:           questGoal,\n659:           questPriority,\n660:           questDifficulty,\n661:           questHitl,\n662:           modal,\n663:           content,\n664:           statusLine\n665:         );\n666:         return;\n667:       }\n668:       showStep(steps[currentStepIdx]);\n669:     };\n670: \n671:     // --- Textbox submit/cancel for ID and Title steps ---\n672:     textbox.on(\"submit\", (value: string) => {\n673:       const trimmed = (value ?? \"\").trim();\n674:       const currentStep = steps[currentStepIdx];\n675: \n676:       if (currentStep === \"id\") {\n677:         // Validate ID\n678:         if (!trimmed) {\n679:           statusLine.setContent(\"{red-fg}ID cannot be empty{/red-fg}\");\n680:           this.screen.render();\n681:           textbox.focus();\n682:           return;\n683:         }\n684:         if (!/^[a-z0-9][a-z0-9-]*[a-z0-9]$|^[a-z0-9]$/.test(trimmed)) {\n685:           statusLine.setContent(\"{red-fg}ID must be kebab-case (lowercase letters, numbers, hyphens){/red-fg}\");\n686:           this.screen.render();\n687:           textbox.focus();\n688:           return;\n689:         }\n690:         // Check duplicate\n691:         const existing = loadQuest(this.projectRoot, trimmed);\n692:         if (existing) {\n693:           statusLine.setContent(`{red-fg}Quest \"${trimmed}\" already exists (${existing.status}){/red-fg}`);\n694:           this.screen.render();\n695:           textbox.focus();\n696:           return;\n697:         }\n698:         questId = trimmed;\n699:         advanceOrFinish();\n700:       } else if (currentStep === \"title\") {\n701:         if (!trimmed) {\n702:           statusLine.setContent(\"{red-fg}Title cannot be empty{/red-fg}\");\n703:           this.screen.render();\n704:           textbox.focus();\n705:           return;\n706:         }\n707:         questTitle = trimmed;\n708:         advanceOrFinish();\n709:       }\n710:     });\n711: \n712:     textbox.on(\"cancel\", () => {\n713:       goBack();\n714:     });\n715: \n716:     // --- Textarea submit/cancel for Goal step ---\n717:     textarea.key([\"enter\"], () => {\n718:       const val = (textarea.getValue() ?? \"\").trim();\n719:       if (!val) {\n720:         statusLine.setContent(\"{red-fg}Goal cannot be empty{/red-fg}\");\n721:         this.screen.render();\n722:         return;\n723:       }\n724:       questGoal = val;\n725:       advanceOrFinish();\n726:     });\n727: \n728:     textarea.key([\"escape\"], () => {\n729:       goBack();\n730:     });\n731: \n732:     // --- Select list for Priority, Difficulty, HITL ---\n733:     selectList.on(\"select item\", (_item: any, index: number) => {\n734:       // This fires on mouse click or manual select event\n735:     });\n736: \n737:     selectList.key([\"enter\", \"space\"], () => {\n738:       const currentStep = steps[currentStepIdx];\n739:       const idx = (selectList as any).selected ?? 0;\n740: \n741:       if (currentStep === \"priority\") {\n742:         questPriority = (VALID_PRIORITIES as readonly string[])[idx] as Priority;\n743:         advanceOrFinish();\n744:       } else if (currentStep === \"difficulty\") {\n745:         questDifficulty = (VALID_DIFFICULTIES as readonly string[])[idx] as Difficulty;\n746:         advanceOrFinish();\n747:       } else if (currentStep === \"hitl\") {\n748:         questHitl = (VALID_HITL_MODES as readonly string[])[idx] as QuestHitlMode;\n749:         advanceOrFinish();\n750:       }\n751:     });\n752: \n753:     selectList.key([\"escape\"], () => {\n754:       goBack();\n755:     });\n756: \n757:     // Start at step 0\n758:     showStep(steps[0]);\n759:   }\n760: \n761:   /**\n762:    * Finalize quest creation: save to store, show confirmation, reload list.\n763:    */\n764:   private finishCreateQuest(\n765:     id: string,\n766:     title: string,\n767:     goal: string,\n768:     priority: Priority,\n769:     difficulty: Difficulty,\n770:     hitlMode: QuestHitlMode,\n771:     modal: Widgets.BoxElement,\n772:     content: Widgets.BoxElement,\n773:     statusLine: Widgets.BoxElement\n774:   ): void {\n775:     try {\n776:       const baseBranch = this.config.baseBranch;\n777:       const quest = createBlankQuest(id, title, goal, baseBranch, {\n778:         priority,\n779:         difficulty,\n780:         hitlMode,\n781:       });\n782: \n783:       saveQuest(this.projectRoot, quest);\n784: \n785:       // Show confirmation briefly\n786:       content.setContent(\n787:         `{bold}{green-fg}\\u2714 Quest created!{/green-fg}{/bold}\\n\\n` +\n788:         `  {white-fg}${id}{/white-fg} — ${escapeBlessedTags(title)}\\n` +\n789:         `  Priority: ${priority}  |  Difficulty: ${difficulty}  |  HITL: ${hitlMode}\\n` +\n790:         `  Branch: quest/${id}  |  Base: ${baseBranch}`\n791:       );\n792:       statusLine.setContent(\"{gray-fg}Returning to quest list...{/gray-fg}\");\n793:       this.screen.render();\n794: \n795:       // After a brief delay, reload and return to picker\n796:       setTimeout(() => {\n797:         modal.destroy();\n798:         this.creatingQuest = false;\n799:         this.loadQuests();\n800:         // Select the newly created quest\n801:         const newIdx = this.items.findIndex(\n802:           (item) => item.type === \"quest\" && item.summary.quest.id === id\n803:         );\n804:         if (newIdx >= 0) this.selectedIndex = newIdx;\n805:         this.refreshAll();\n806:         this.questList.focus();\n807:         this.screen.render();\n808:       }, 1500);\n809:     } catch (err: unknown) {\n810:       const msg = err instanceof Error ? err.message : String(err);\n811:       content.setContent(\n812:         `{bold}{red-fg}\\u2718 Failed to create quest{/red-fg}{/bold}\\n\\n` +\n813:         `  ${escapeBlessedTags(msg)}`\n814:       );\n815:       statusLine.setContent(\"{gray-fg}Press Esc to return{/gray-fg}\");\n816:       this.screen.render();\n817: \n818:       const escHandler = () => {\n819:         modal.destroy();\n820:         this.creatingQuest = false;\n821:         this.questList.focus();\n822:         this.screen.render();\n823:       };\n824:       modal.key([\"escape\"], escHandler);\n825:     }\n826:   }\n827: \n828:   // -----------------------------------------------------------------------\n829:   // Refresh Logic\n830:   // -----------------------------------------------------------------------\n831: \n832:   private refreshAll(): void {\n833:     this.refreshHeader();\n834:     this.refreshList();\n835:     this.refreshDetail();\n836:     this.refreshStatusBar();\n837:   }\n838: \n839:   private refreshHeader(): void {\n840:     const questCount = this.items.length - 1; // exclude \"All Tasks\"\n841:     const activeCount = this.items.filter(\n842:       (i) => i.type === \"quest\" && i.summary.quest.status === \"active\"\n843:     ).length;\n844: \n845:     let line1 = ` {bold}wombo-combo{/bold} {magenta-fg}Quest Picker{/magenta-fg}`;\n846:     line1 += `  {gray-fg}|{/gray-fg}  {white-fg}${questCount}{/white-fg} quest${questCount !== 1 ? \"s\" : \"\"}`;\n847:     if (activeCount > 0) {\n848:       line1 += `  {gray-fg}|{/gray-fg}  {green-fg}${activeCount}{/green-fg} active`;\n849:     }\n850:     line1 += `  {gray-fg}|{/gray-fg}  {white-fg}${this.totalTaskCount}{/white-fg} total tasks`;\n851: \n852:     let line2 = ` {gray-fg}Select a quest to filter tasks, or choose \"All Tasks\" for the full list{/gray-fg}`;\n853: \n854:     this.headerBox.setContent(`${line1}\\n${line2}`);\n855:   }\n856: \n857:   private refreshList(): void {\n858:     const listItems: string[] = [];\n859: \n860:     for (const item of this.items) {\n861:       if (item.type === \"all\") {\n862:         listItems.push(\n863:           ` {bold}{cyan-fg}\\u25C6{/cyan-fg} All Tasks{/bold} {gray-fg}(${this.totalTaskCount}){/gray-fg}`\n864:         );\n865:       } else {\n866:         const { quest, totalTasks, doneTasks, completionPct } = item.summary;\n867: \n868:         // Status badge\n869:         const sColor = STATUS_COLORS[quest.status] ?? \"white\";\n870:         const sAbbr = STATUS_ABBREV[quest.status] ?? quest.status.slice(0, 4).toUpperCase();\n871:         const statusBadge = `{${sColor}-fg}${sAbbr}{/${sColor}-fg}`;\n872: \n873:         // Priority\n874:         const pColor = PRIORITY_COLORS[quest.priority] ?? \"white\";\n875:         const priorityDot = `{${pColor}-fg}\\u25CF{/${pColor}-fg}`;\n876: \n877:         // Title (truncated)\n878:         const maxTitleLen = 28;\n879:         const title = quest.title.length > maxTitleLen\n880:           ? quest.title.slice(0, maxTitleLen - 1) + \"\\u2026\"\n881:           : quest.title;\n882: \n883:         // Completion bar\n884:         const barWidth = 8;\n885:         const filled = Math.round((completionPct / 100) * barWidth);\n886:         const empty = barWidth - filled;\n887:         const bar = `{green-fg}${\"#\".repeat(filled)}{/green-fg}{gray-fg}${\"-\".repeat(empty)}{/gray-fg}`;\n888: \n889:         // Task count\n890:         const taskInfo = totalTasks > 0\n891:           ? `{gray-fg}${doneTasks}/${totalTasks}{/gray-fg}`\n892:           : `{gray-fg}0 tasks{/gray-fg}`;\n893: \n894:         listItems.push(\n895:           ` ${priorityDot} ${statusBadge} ${escapeBlessedTags(title)}  [${bar}] ${taskInfo}`\n896:         );\n897:       }\n898:     }\n899: \n900:     if (listItems.length === 0) {\n901:       listItems.push(\" {gray-fg}No quests found{/gray-fg}\");\n902:     }\n903: \n904:     const prevSelected = this.selectedIndex;\n905:     this.questList.setItems(listItems as any);\n906:     if (prevSelected < listItems.length) {\n907:       this.questList.select(prevSelected);\n908:     }\n909:   }\n910: \n911:   private refreshDetail(): void {\n912:     const item = this.items[this.selectedIndex];\n913:     if (!item) {\n914:       this.detailBox.setContent(\"{gray-fg}No item selected{/gray-fg}\");\n915:       this.detailBox.setLabel(\" Details \");\n916:       return;\n917:     }\n918: \n919:     if (item.type === \"all\") {\n920:       const lines: string[] = [\n921:         \"{bold}{cyan-fg}All Tasks{/cyan-fg}{/bold}\",\n922:         \"\",\n923:         \"  Browse all tasks across all quests\",\n924:         \"  and unassigned tasks.\",\n925:         \"\",\n926:         `  Total: {white-fg}${this.totalTaskCount}{/white-fg} tasks`,\n927:         \"\",\n928:         \"  Press {bold}Enter{/bold} to open the full task browser.\",\n929:       ];\n930:       this.detailBox.setContent(lines.join(\"\\n\"));\n931:       this.detailBox.setLabel(\" All Tasks \");\n932:       return;\n933:     }\n934: \n935:     const { quest, totalTasks, doneTasks, completionPct } = item.summary;\n936:     const lines: string[] = [];\n937: \n938:     // Title\n939:     lines.push(`{bold}{white-fg}${escapeBlessedTags(quest.title)}{/white-fg}{/bold}`);\n940:     lines.push(\"\");\n941: \n942:     // Status\n943:     const sColor = STATUS_COLORS[quest.status] ?? \"white\";\n944:     lines.push(`  Status:     {${sColor}-fg}${quest.status}{/${sColor}-fg}`);\n945: \n946:     // Priority\n947:     const pColor = PRIORITY_COLORS[quest.priority] ?? \"white\";\n948:     lines.push(`  Priority:   {${pColor}-fg}${quest.priority}{/${pColor}-fg}`);\n949: \n950:     // Difficulty\n951:     lines.push(`  Difficulty: ${quest.difficulty}`);\n952: \n953:     // HITL mode\n954:     lines.push(`  HITL:       ${quest.hitlMode}`);\n955:     lines.push(\"\");\n956: \n957:     // Task progress\n958:     if (totalTasks > 0) {\n959:       lines.push(\"{bold}Progress:{/bold}\");\n960:       lines.push(`  Tasks: ${doneTasks}/${totalTasks} done (${completionPct}%)`);\n961: \n962:       // Progress bar (wider in detail view)\n963:       const barWidth = 20;\n964:       const filled = Math.round((completionPct / 100) * barWidth);\n965:       const empty = barWidth - filled;\n966:       const bar = `{green-fg}${\"=\".repeat(filled)}{/green-fg}{gray-fg}${\"-\".repeat(empty)}{/gray-fg}`;\n967:       lines.push(`  [${bar}]`);\n968:     } else {\n969:       lines.push(\"{bold}Progress:{/bold}\");\n970:       lines.push(\"  {gray-fg}No tasks assigned{/gray-fg}\");\n971:     }\n972:     lines.push(\"\");\n973: \n974:     // Goal\n975:     if (quest.goal) {\n976:       lines.push(\"{bold}Goal:{/bold}\");\n977:       const goalText = escapeBlessedTags(quest.goal.trim());\n978:       const words = goalText.split(/\\s+/);\n979:       let line = \" \";\n980:       for (const w of words) {\n981:         if (line.length + w.length > 42) {\n982:           lines.push(line);\n983:           line = \" \" + w;\n984:         } else {\n985:           line += \" \" + w;\n986:         }\n987:       }\n988:       if (line.trim()) lines.push(line);\n989:       lines.push(\"\");\n990:     }\n991: \n992:     // Branch\n993:     lines.push(\"{bold}Branch:{/bold}\");\n994:     lines.push(`  ${quest.branch}`);\n995:     lines.push(`  Base: ${quest.baseBranch}`);\n996:     lines.push(\"\");\n997: \n998:     // Constraints\n999:     if (quest.constraints.add.length > 0) {\n1000:       lines.push(\"{bold}Added Constraints:{/bold}\");\n1001:       for (const c of quest.constraints.add) {\n1002:         lines.push(`  + ${escapeBlessedTags(c)}`);\n1003:       }\n1004:       lines.push(\"\");\n1005:     }\n1006:     if (quest.constraints.ban.length > 0) {\n1007:       lines.push(\"{bold}Banned:{/bold}\");\n1008:       for (const b of quest.constraints.ban) {\n1009:         lines.push(`  - ${escapeBlessedTags(b)}`);\n1010:       }\n1011:       lines.push(\"\");\n1012:     }\n1013: \n1014:     // Dependencies\n1015:     if (quest.depends_on.length > 0) {\n1016:       lines.push(\"{bold}Depends on:{/bold}\");\n1017:       for (const d of quest.depends_on) {\n1018:         lines.push(`  \\u2192 ${d}`);\n1019:       }\n1020:       lines.push(\"\");\n1021:     }\n1022: \n1023:     // Notes\n1024:     if (quest.notes.length > 0) {\n1025:       lines.push(\"{bold}Notes:{/bold}\");\n1026:       for (const n of quest.notes) {\n1027:         lines.push(`  ${escapeBlessedTags(n)}`);\n1028:       }\n1029:       lines.push(\"\");\n1030:     }\n1031: \n1032:     // Timestamps\n1033:     lines.push(\"{bold}Timeline:{/bold}\");\n1034:     lines.push(`  Created: ${quest.created_at.slice(0, 10)}`);\n1035:     if (quest.started_at) lines.push(`  Started: ${quest.started_at.slice(0, 10)}`);\n1036:     if (quest.ended_at) lines.push(`  Ended:   ${quest.ended_at.slice(0, 10)}`);\n1037: \n1038:     this.detailBox.setContent(lines.join(\"\\n\"));\n1039:     this.detailBox.setLabel(` ${quest.id} `);\n1040:   }\n1041: \n1042:   private refreshStatusBar(): void {\n1043:     let line1 = ` {bold}Keys:{/bold}`;\n1044:     line1 += `  {gray-fg}Enter{/gray-fg} select`;\n1045:     line1 += `  {gray-fg}C{/gray-fg} create`;\n1046:     line1 += `  {gray-fg}E{/gray-fg} errand`;\n1047:     line1 += `  {gray-fg}P{/gray-fg} plan`;\n1048:     line1 += `  {gray-fg}G{/gray-fg} genesis`;\n1049:     line1 += `  {gray-fg}A{/gray-fg} activate/pause`;\n1050:     line1 += `  {gray-fg}W{/gray-fg} wishlist`;\n1051:     line1 += `  {gray-fg}Q{/gray-fg} quit`;\n1052: \n1053:     const item = this.items[this.selectedIndex];\n1054:     let line2 = \" \";\n1055:     if (item?.type === \"all\") {\n1056:       line2 += `{cyan-fg}View all tasks across all quests{/cyan-fg}`;\n1057:     } else if (item?.type === \"quest\") {\n1058:       const q = item.summary.quest;\n1059:       line2 += `{white-fg}${escapeBlessedTags(q.id)}{/white-fg}`;\n1060:       line2 += `  {gray-fg}|{/gray-fg}  ${item.summary.totalTasks} task${item.summary.totalTasks !== 1 ? \"s\" : \"\"}`;\n1061:       line2 += `  {gray-fg}|{/gray-fg}  ${item.summary.completionPct}% complete`;\n1062:       if (q.status === \"draft\" || q.status === \"planning\") {\n1063:         line2 += `  {gray-fg}|{/gray-fg}  {magenta-fg}P to plan{/magenta-fg}`;\n1064:       }\n1065:     }\n1066: \n1067:     this.statusBar.setContent(`${line1}\\n${line2}`);\n1068:   }\n1069: }\n\n(End of file - total 1069 lines)\n</content>","title":"src/lib/tui-quest-picker.ts","metadata":{"preview":"/**\n * tui-quest-picker.ts -- Quest picker view for the wombo-combo TUI.\n *\n * Shows all quests as a selectable list with an \"All Tasks\" option at the top.\n * Selecting a quest navigates to the Task Browser filtered to that quest's tasks.\n *\n * Layout:\n *   +-----------------------------------------------------------+\n *   | WOMBO-COMBO Quest Picker  | 4 quests                      |\n *   +---------------------------+-------------------------------+\n *   | > All Tasks (42)          | Quest: auth-overhaul           |\n *   |   auth-overhaul   ACTV    | Status: active                 |\n *   |   search-api      DRFT    | Priority: high                 |\n *   |   perf-optim      PAUS    | Tasks: 8 (3 done, 62%)         |\n *   |   ui-redesign     PLAN    | Goal: Replace basic auth...    |\n *   |                           |                                |\n *   +---------------------------+-------------------------------+\n *   | Enter:select  C:create  Q:quit                            |\n *   +-----------------------------------------------------------+\n *","truncated":false,"loaded":[]},"time":{"start":1773483539270,"end":1773483539273}}}}
{"type":"tool_use","timestamp":1773483539900,"sessionID":"ses_3142777b4ffe3IuXz7qBZaextx","part":{"id":"prt_cebdb3b47001EhZgb5O7GrKR66","sessionID":"ses_3142777b4ffe3IuXz7qBZaextx","messageID":"msg_cebdb2e2f001yk4l1PYw15V1oc","type":"tool","callID":"toolu_vrtx_01NEGARmoUuSdZvLoKTiYWDD","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/token-tui/src/lib/tui-browser.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/token-tui/src/lib/tui-browser.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tui-browser.ts — Task browser view for the wombo-combo TUI.\n3:  *\n4:  * Shows all tasks organized by dependency streams with checkboxes for\n5:  * selection. Users can evaluate tasks, order them, select/deselect\n6:  * entire streams, and launch a wave with the selected tasks.\n7:  *\n8:  * Layout:\n9:  *   ┌───────────────────────────────────────────────────────┐\n10:  *   │ WOMBO-COMBO Task Browser  │ 42 tasks │ 5 selected    │\n11:  *   ├──────────────────────────────┬────────────────────────┤\n12:  *   │ ☑ json-features-check  done │ Title: ...             │\n13:  *   │ ☑ json-features-arch   done │ Status: backlog        │\n14:  *   │   ☐ json-ops-commands  back │ Priority: high         │\n15:  *   │ ── stream 2 ──              │ Effort: PT6H           │\n16:  *   │ ☐ tdd-test-detection   done │ Depends on:            │\n17:  *   │ ...                         │   - json-ops-commands  │\n18:  *   ├──────────────────────────────┴────────────────────────┤\n19:  *   │ Space:toggle  S:stream  L:launch  O:sort  Q:quit    │\n20:  *   └───────────────────────────────────────────────────────┘\n21:  *\n22:  * Keybinds:\n23:  *   Space     — toggle selection of current task\n24:  *   S         — toggle entire stream (select/deselect all tasks in the group)\n25:  *   A         — select all / deselect all (toggle)\n26:  *   L         — launch selected tasks as a new wave\n27:  *   Tab       — cycle sort field / switch to wave monitor (if wave running)\n28:  *   O         — cycle sort field (priority → status → name → effort → stream)\n29:  *   +/-       — change priority of selected task\n30:  *   Enter     — expand/collapse task detail inline\n31:  *   D         — toggle show done tasks (filter)\n32:  *   C         — cycle concurrency level\n33:  *   Q / C-c   — quit (saves session)\n34:  */\n35: \n36: import blessed from \"neo-blessed\";\n37: import type { Widgets } from \"neo-blessed\";\n38: import type { Task, TasksFile, Priority } from \"./tasks.js\";\n39: import { loadTasks, loadArchive, parseDurationMinutes, formatDuration, areDependenciesMet, getDoneTaskIds } from \"./tasks.js\";\n40: import { saveTaskToStore, saveTaskToArchive, removeTaskFromStore } from \"./task-store.js\";\n41: import { PRIORITY_ORDER, DIFFICULTY_ORDER } from \"./task-schema.js\";\n42: import type { TUISession, SortField } from \"./tui-session.js\";\n43: import { saveTUISession } from \"./tui-session.js\";\n44: import type { WomboConfig } from \"../config.js\";\n45: import { WishlistOverlay } from \"./tui-wishlist.js\";\n46: import { loadUsageRecords, totalUsage, groupBy as groupUsageBy } from \"./token-usage.js\";\n47: import type { UsageTotals } from \"./token-usage.js\";\n48: import type { UsageRecord } from \"./token-collector.js\";\n49: \n50: // ---------------------------------------------------------------------------\n51: // Types\n52: // ---------------------------------------------------------------------------\n53: \n54: export interface TaskBrowserOptions {\n55:   projectRoot: string;\n56:   config: WomboConfig;\n57:   session: TUISession;\n58:   /** Called when user presses L to launch selected tasks */\n59:   onLaunch: (selectedIds: string[]) => void;\n60:   /** Called when user presses q to quit */\n61:   onQuit: () => void;\n62:   /** Called when user presses Escape to go back to quest picker */\n63:   onBack?: () => void;\n64:   /** Called when user presses Tab to switch to wave monitor (if a wave is running) */\n65:   onSwitchToMonitor?: () => void;\n66:   /** Called when user presses E to create an errand (quest-less assisted task) */\n67:   onErrand?: () => void;\n68:   /** If set, filter to only tasks belonging to this quest */\n69:   questId?: string | null;\n70:   /** Human-readable quest title for header display */\n71:   questTitle?: string;\n72:   /** Task IDs belonging to the selected quest (used for filtering) */\n73:   questTaskIds?: string[];\n74: }\n75: \n76: /**\n77:  * A task node in the display tree with computed metadata.\n78:  */\n79: interface TaskNode {\n80:   task: Task;\n81:   /** Depth in the dependency chain (0 = leaf/no deps, higher = depends on more) */\n82:   depth: number;\n83:   /** ID of the stream (connected component) this task belongs to */\n84:   streamId: string;\n85:   /** Task IDs that depend on this task */\n86:   dependedOnBy: string[];\n87: }\n88: \n89: /**\n90:  * A stream is a group of related tasks connected by dependencies.\n91:  */\n92: interface Stream {\n93:   id: string;\n94:   nodes: TaskNode[];\n95: }\n96: \n97: // ---------------------------------------------------------------------------\n98: // Status / Priority display helpers\n99: // ---------------------------------------------------------------------------\n100: \n101: const STATUS_ABBREV: Record<string, string> = {\n102:   backlog: \"BACK\",\n103:   planned: \"PLAN\",\n104:   in_progress: \"PROG\",\n105:   blocked: \"BLKD\",\n106:   in_review: \"REVW\",\n107:   done: \"DONE\",\n108:   cancelled: \"CANC\",\n109: };\n110: \n111: const STATUS_COLORS: Record<string, string> = {\n112:   backlog: \"gray\",\n113:   planned: \"blue\",\n114:   in_progress: \"cyan\",\n115:   blocked: \"red\",\n116:   in_review: \"yellow\",\n117:   done: \"green\",\n118:   cancelled: \"gray\",\n119: };\n120: \n121: const PRIORITY_ABBREV: Record<string, string> = {\n122:   critical: \"CRIT\",\n123:   high: \"HIGH\",\n124:   medium: \"MED \",\n125:   low: \"LOW \",\n126:   wishlist: \"WISH\",\n127: };\n128: \n129: const PRIORITY_COLORS: Record<string, string> = {\n130:   critical: \"red\",\n131:   high: \"yellow\",\n132:   medium: \"white\",\n133:   low: \"gray\",\n134:   wishlist: \"gray\",\n135: };\n136: \n137: // ---------------------------------------------------------------------------\n138: // Helpers\n139: // ---------------------------------------------------------------------------\n140: \n141: function escapeBlessedTags(text: string): string {\n142:   return text.replace(/\\{/g, \"\\uFF5B\").replace(/\\}/g, \"\\uFF5D\");\n143: }\n144: \n145: const SORT_FIELDS: SortField[] = [\"priority\", \"status\", \"name\", \"effort\", \"stream\"];\n146: \n147: // ---------------------------------------------------------------------------\n148: // Token Usage Formatting Helpers\n149: // ---------------------------------------------------------------------------\n150: \n151: /**\n152:  * Format a token count with k/M suffixes for compact display.\n153:  */\n154: function formatTokenCount(n: number): string {\n155:   if (n === 0) return \"0\";\n156:   if (n < 1000) return String(n);\n157:   if (n < 1_000_000) return `${(n / 1000).toFixed(1)}k`;\n158:   return `${(n / 1_000_000).toFixed(2)}M`;\n159: }\n160: \n161: /**\n162:  * Format a cost value as a dollar string.\n163:  */\n164: function formatCost(cost: number): string {\n165:   if (cost === 0) return \"$0.00\";\n166:   if (cost < 0.01) return `$${cost.toFixed(4)}`;\n167:   return `$${cost.toFixed(2)}`;\n168: }\n169: \n170: // ---------------------------------------------------------------------------\n171: // Task Graph Builder\n172: // ---------------------------------------------------------------------------\n173: \n174: /**\n175:  * Build a dependency graph from all tasks and organize them into streams\n176:  * (connected components). Within each stream, tasks are topologically sorted.\n177:  */\n178: function buildTaskGraph(tasks: Task[]): Stream[] {\n179:   const taskMap = new Map<string, Task>();\n180:   for (const t of tasks) taskMap.set(t.id, t);\n181: \n182:   // Build reverse dependency map (who depends on me?)\n183:   const dependedOnBy = new Map<string, string[]>();\n184:   for (const t of tasks) {\n185:     for (const dep of t.depends_on) {\n186:       if (!dependedOnBy.has(dep)) dependedOnBy.set(dep, []);\n187:       dependedOnBy.get(dep)!.push(t.id);\n188:     }\n189:   }\n190: \n191:   // Find connected components using undirected graph traversal\n192:   const visited = new Set<string>();\n193:   const components: string[][] = [];\n194: \n195:   function dfs(id: string, component: string[]): void {\n196:     if (visited.has(id)) return;\n197:     if (!taskMap.has(id)) return; // dep references a task not in our list\n198:     visited.add(id);\n199:     component.push(id);\n200:     // Follow forward deps\n201:     const task = taskMap.get(id)!;\n202:     for (const dep of task.depends_on) dfs(dep, component);\n203:     // Follow reverse deps\n204:     for (const rev of (dependedOnBy.get(id) ?? [])) dfs(rev, component);\n205:   }\n206: \n207:   for (const t of tasks) {\n208:     if (!visited.has(t.id)) {\n209:       const comp: string[] = [];\n210:       dfs(t.id, comp);\n211:       components.push(comp);\n212:     }\n213:   }\n214: \n215:   // For each component, compute depths and sort topologically\n216:   const streams: Stream[] = [];\n217:   for (const comp of components) {\n218:     // Compute depth: longest path from any leaf (task with no deps in this component)\n219:     const depthMap = new Map<string, number>();\n220:     const compSet = new Set(comp);\n221: \n222:     function computeDepth(id: string, visiting: Set<string>): number {\n223:       if (depthMap.has(id)) return depthMap.get(id)!;\n224:       if (visiting.has(id)) return 0; // cycle protection\n225:       visiting.add(id);\n226:       const task = taskMap.get(id);\n227:       if (!task) return 0;\n228:       let maxDepth = 0;\n229:       for (const dep of task.depends_on) {\n230:         if (compSet.has(dep)) {\n231:           maxDepth = Math.max(maxDepth, 1 + computeDepth(dep, visiting));\n232:         }\n233:       }\n234:       visiting.delete(id);\n235:       depthMap.set(id, maxDepth);\n236:       return maxDepth;\n237:     }\n238: \n239:     for (const id of comp) computeDepth(id, new Set());\n240: \n241:     // Sort: by depth ascending (leaves first), then by priority\n242:     const sorted = [...comp].sort((a, b) => {\n243:       const dA = depthMap.get(a) ?? 0;\n244:       const dB = depthMap.get(b) ?? 0;\n245:       if (dA !== dB) return dA - dB;\n246:       const tA = taskMap.get(a)!;\n247:       const tB = taskMap.get(b)!;\n248:       return PRIORITY_ORDER[tA.priority] - PRIORITY_ORDER[tB.priority];\n249:     });\n250: \n251:     // Use the deepest task's ID as the stream ID (it's the \"root\" task)\n252:     const maxDepthId = sorted[sorted.length - 1];\n253:     const streamId = maxDepthId;\n254: \n255:     const nodes: TaskNode[] = sorted.map((id) => ({\n256:       task: taskMap.get(id)!,\n257:       depth: depthMap.get(id) ?? 0,\n258:       streamId,\n259:       dependedOnBy: (dependedOnBy.get(id) ?? []).filter((d) => compSet.has(d)),\n260:     }));\n261: \n262:     streams.push({ id: streamId, nodes });\n263:   }\n264: \n265:   // Sort streams by highest-priority task in each\n266:   streams.sort((a, b) => {\n267:     const bestA = Math.min(...a.nodes.map((n) => PRIORITY_ORDER[n.task.priority]));\n268:     const bestB = Math.min(...b.nodes.map((n) => PRIORITY_ORDER[n.task.priority]));\n269:     return bestA - bestB;\n270:   });\n271: \n272:   return streams;\n273: }\n274: \n275: // ---------------------------------------------------------------------------\n276: // Task Browser Class\n277: // ---------------------------------------------------------------------------\n278: \n279: export class TaskBrowser {\n280:   private screen: Widgets.Screen;\n281:   private headerBox: Widgets.BoxElement;\n282:   private taskList: Widgets.ListElement;\n283:   private detailBox: Widgets.BoxElement;\n284:   private statusBar: Widgets.BoxElement;\n285: \n286:   private projectRoot: string;\n287:   private config: WomboConfig;\n288:   private session: TUISession;\n289:   private onLaunch: (selectedIds: string[]) => void;\n290:   private onQuit: () => void;\n291:   private onBack?: () => void;\n292:   private onSwitchToMonitor?: () => void;\n293:   private onErrand?: () => void;\n294: \n295:   /** Quest filtering */\n296:   private questId: string | null = null;\n297:   private questTitle: string | null = null;\n298:   private questTaskIds: Set<string> | null = null;\n299: \n300:   private allTasks: Task[] = [];\n301:   private archiveTasks: Task[] = [];\n302:   private doneIds: Set<string> = new Set();\n303:   private streams: Stream[] = [];\n304:   /** Flat ordered list of task nodes as displayed */\n305:   private displayNodes: TaskNode[] = [];\n306:   private selectedIndex: number = 0;\n307:   private selected: Set<string>;\n308:   private collapsed: Set<string>;\n309:   private hideDone: boolean = false;\n310:   private refreshTimer: ReturnType<typeof setInterval> | null = null;\n311:   private hasRunningWave: boolean = false;\n312:   /** Active wishlist overlay (null when closed) */\n313:   private wishlistOverlay: WishlistOverlay | null = null;\n314:   /** Per-task token usage totals (loaded from usage.jsonl) */\n315:   private taskUsage: Map<string, UsageTotals> = new Map();\n316:   /** Overall usage totals across all records */\n317:   private overallUsage: UsageTotals | null = null;\n318: \n319:   constructor(opts: TaskBrowserOptions) {\n320:     this.projectRoot = opts.projectRoot;\n321:     this.config = opts.config;\n322:     this.session = opts.session;\n323:     this.onLaunch = opts.onLaunch;\n324:     this.onQuit = opts.onQuit;\n325:     this.onBack = opts.onBack;\n326:     this.onSwitchToMonitor = opts.onSwitchToMonitor;\n327:     this.onErrand = opts.onErrand;\n328:     this.selected = new Set(opts.session.selected);\n329:     this.collapsed = new Set(opts.session.collapsed);\n330: \n331:     // Quest filtering\n332:     this.questId = opts.questId ?? null;\n333:     this.questTitle = opts.questTitle ?? null;\n334:     this.questTaskIds = opts.questTaskIds ? new Set(opts.questTaskIds) : null;\n335: \n336:     // Load tasks\n337:     this.reloadTasks();\n338: \n339:     // Create screen\n340:     this.screen = blessed.screen({\n341:       smartCSR: true,\n342:       title: this.questTitle\n343:         ? `wombo-combo -- ${this.questTitle}`\n344:         : \"wombo-combo -- Task Browser\",\n345:       fullUnicode: true,\n346:     });\n347: \n348:     // Header\n349:     this.headerBox = blessed.box({\n350:       top: 0,\n351:       left: 0,\n352:       width: \"100%\",\n353:       height: 3,\n354:       tags: true,\n355:       style: { fg: \"white\", bg: \"black\" },\n356:     });\n357: \n358:     // Task list (left pane)\n359:     this.taskList = blessed.list({\n360:       top: 3,\n361:       left: 0,\n362:       width: \"60%\",\n363:       height: \"100%-6\",\n364:       tags: true,\n365:       scrollable: true,\n366:       mouse: true,\n367:       keys: true,\n368:       vi: true,\n369:       border: { type: \"line\" },\n370:       style: {\n371:         border: { fg: \"gray\" },\n372:         selected: { bg: \"blue\", fg: \"white\", bold: true },\n373:         item: { fg: \"white\" },\n374:       },\n375:       label: \" Tasks \",\n376:     });\n377: \n378:     // Detail pane (right pane)\n379:     this.detailBox = blessed.box({\n380:       top: 3,\n381:       left: \"60%\",\n382:       width: \"40%\",\n383:       height: \"100%-6\",\n384:       tags: true,\n385:       scrollable: true,\n386:       mouse: true,\n387:       border: { type: \"line\" },\n388:       style: {\n389:         border: { fg: \"gray\" },\n390:         fg: \"white\",\n391:       },\n392:       label: \" Details \",\n393:     });\n394: \n395:     // Status bar\n396:     this.statusBar = blessed.box({\n397:       bottom: 0,\n398:       left: 0,\n399:       width: \"100%\",\n400:       height: 3,\n401:       tags: true,\n402:       style: { fg: \"white\", bg: \"black\" },\n403:     });\n404: \n405:     // Assemble\n406:     this.screen.append(this.headerBox);\n407:     this.screen.append(this.taskList);\n408:     this.screen.append(this.detailBox);\n409:     this.screen.append(this.statusBar);\n410:     this.taskList.focus();\n411: \n412:     this.bindKeys();\n413:   }\n414: \n415:   // -------------------------------------------------------------------------\n416:   // Public API\n417:   // -------------------------------------------------------------------------\n418: \n419:   start(): void {\n420:     this.buildDisplay();\n421:     this.refresh();\n422:     this.screen.render();\n423:   }\n424: \n425:   stop(): void {\n426:     this.saveSession();\n427:     if (this.refreshTimer) {\n428:       clearInterval(this.refreshTimer);\n429:       this.refreshTimer = null;\n430:     }\n431:     this.screen.destroy();\n432:   }\n433: \n434:   /**\n435:    * Destroy the browser screen without saving session (caller already saved).\n436:    * Used by the TUI orchestrator after receiving onLaunch — the transition\n437:    * message is already displayed, so we just tear down the blessed screen\n438:    * and clear the terminal for the next view.\n439:    */\n440:   destroy(): void {\n441:     if (this.refreshTimer) {\n442:       clearInterval(this.refreshTimer);\n443:       this.refreshTimer = null;\n444:     }\n445:     this.screen.destroy();\n446:     // Clear terminal so the next view starts fresh\n447:     process.stdout.write(\"\\x1B[2J\\x1B[H\");\n448:   }\n449: \n450:   /** Let the orchestrator tell us a wave is running (enables Tab to switch) */\n451:   setHasRunningWave(running: boolean): void {\n452:     this.hasRunningWave = running;\n453:     this.refreshStatusBar();\n454:     this.screen.render();\n455:   }\n456: \n457:   // -------------------------------------------------------------------------\n458:   // Task Loading\n459:   // -------------------------------------------------------------------------\n460: \n461:   private reloadTasks(): void {\n462:     const tasksData = loadTasks(this.projectRoot, this.config);\n463:     const archiveData = loadArchive(this.projectRoot, this.config);\n464: \n465:     // Filter tasks by quest if a quest is selected\n466:     if (this.questTaskIds) {\n467:       this.allTasks = tasksData.tasks.filter((t) => this.questTaskIds!.has(t.id));\n468:     } else {\n469:       this.allTasks = tasksData.tasks;\n470:     }\n471: \n472:     this.archiveTasks = archiveData.tasks;\n473:     this.doneIds = getDoneTaskIds(tasksData, this.archiveTasks);\n474:     this.streams = buildTaskGraph(this.allTasks);\n475: \n476:     // Prune selected IDs that no longer exist\n477:     const validIds = new Set(this.allTasks.map((t) => t.id));\n478:     for (const id of this.selected) {\n479:       if (!validIds.has(id)) this.selected.delete(id);\n480:     }\n481: \n482:     // Load token usage data\n483:     this.reloadUsage();\n484:   }\n485: \n486:   /**\n487:    * Reload token usage data from the JSONL file and build per-task aggregates.\n488:    */\n489:   private reloadUsage(): void {\n490:     try {\n491:       const records = loadUsageRecords(this.projectRoot);\n492:       if (records.length > 0) {\n493:         const byTask = groupUsageBy(records, \"task_id\");\n494:         this.taskUsage = byTask;\n495:         this.overallUsage = totalUsage(records);\n496:       } else {\n497:         this.taskUsage = new Map();\n498:         this.overallUsage = null;\n499:       }\n500:     } catch {\n501:       // Non-critical — usage display is optional\n502:       this.taskUsage = new Map();\n503:       this.overallUsage = null;\n504:     }\n505:   }\n506: \n507:   // -------------------------------------------------------------------------\n508:   // Display Building\n509:   // -------------------------------------------------------------------------\n510: \n511:   private buildDisplay(): void {\n512:     this.displayNodes = [];\n513:     const sortedStreams = this.sortStreams(this.streams);\n514: \n515:     for (const stream of sortedStreams) {\n516:       const sortedNodes = this.sortNodesInStream(stream.nodes);\n517:       for (const node of sortedNodes) {\n518:         if (this.hideDone && node.task.status === \"done\") continue;\n519:         this.displayNodes.push(node);\n520:       }\n521:     }\n522:   }\n523: \n524:   private sortStreams(streams: Stream[]): Stream[] {\n525:     const field = this.session.sortBy;\n526:     const order = this.session.sortOrder === \"asc\" ? 1 : -1;\n527: \n528:     if (field === \"stream\") return streams; // natural grouping\n529: \n530:     return [...streams].sort((a, b) => {\n531:       const bestA = this.streamSortKey(a, field);\n532:       const bestB = this.streamSortKey(b, field);\n533:       return (bestA - bestB) * order;\n534:     });\n535:   }\n536: \n537:   private streamSortKey(stream: Stream, field: SortField): number {\n538:     switch (field) {\n539:       case \"priority\":\n540:         return Math.min(...stream.nodes.map((n) => PRIORITY_ORDER[n.task.priority]));\n541:       case \"effort\":\n542:         return Math.min(...stream.nodes.map((n) => parseDurationMinutes(n.task.effort)));\n543:       case \"status\": {\n544:         const STATUS_SORT: Record<string, number> = {\n545:           in_progress: 0, backlog: 1, planned: 2, blocked: 3,\n546:           in_review: 4, done: 5, cancelled: 6,\n547:         };\n548:         return Math.min(...stream.nodes.map((n) => STATUS_SORT[n.task.status] ?? 99));\n549:       }\n550:       case \"name\":\n551:         return 0; // alpha sort handled differently\n552:       default:\n553:         return 0;\n554:     }\n555:   }\n556: \n557:   private sortNodesInStream(nodes: TaskNode[]): TaskNode[] {\n558:     // Always sort by depth within a stream (topological order)\n559:     return [...nodes].sort((a, b) => a.depth - b.depth);\n560:   }\n561: \n562:   // -------------------------------------------------------------------------\n563:   // Key Bindings\n564:   // -------------------------------------------------------------------------\n565: \n566:   private bindKeys(): void {\n567:     // Quit (or go back to quest picker if in quest mode)\n568:     this.screen.key([\"q\", \"C-c\"], () => {\n569:       if (this.onBack && this.questId) {\n570:         // In quest-filtered mode: Q goes back to quest picker\n571:         this.saveSession();\n572:         this.destroy();\n573:         this.onBack();\n574:       } else {\n575:         this.stop();\n576:         this.onQuit();\n577:       }\n578:     });\n579: \n580:     // Escape -- go back to quest picker (always, if available)\n581:     this.screen.key([\"escape\"], () => {\n582:       if (this.onBack) {\n583:         this.saveSession();\n584:         this.destroy();\n585:         this.onBack();\n586:       }\n587:     });\n588: \n589:     // Navigate\n590:     this.taskList.on(\"select item\", (_item: any, index: number) => {\n591:       this.selectedIndex = index;\n592:       this.refreshDetail();\n593:       this.screen.render();\n594:     });\n595: \n596:     // Space — toggle selection\n597:     this.screen.key([\"space\"], () => {\n598:       this.toggleCurrent();\n599:     });\n600: \n601:     // s — toggle stream\n602:     this.screen.key([\"s\"], () => {\n603:       this.toggleStream();\n604:     });\n605: \n606:     // a — select all / deselect all\n607:     this.screen.key([\"a\"], () => {\n608:       this.toggleAll();\n609:     });\n610: \n611:     // l — launch selected\n612:     this.screen.key([\"l\"], () => {\n613:       this.launchSelected();\n614:     });\n615: \n616:     // Tab — cycle sort / switch to monitor\n617:     this.screen.key([\"tab\"], () => {\n618:       if (this.hasRunningWave && this.onSwitchToMonitor) {\n619:         this.saveSession();\n620:         this.stop();\n621:         this.onSwitchToMonitor();\n622:       } else {\n623:         this.cycleSort();\n624:       }\n625:     });\n626: \n627:     // O — cycle sort order (laptop-friendly alternative when Tab is used for view switch)\n628:     this.screen.key([\"o\"], () => {\n629:       this.cycleSort();\n630:     });\n631: \n632:     // +/- — change priority\n633:     this.screen.key([\"+\", \"=\"], () => {\n634:       this.changePriority(-1); // higher priority (lower number)\n635:     });\n636:     this.screen.key([\"-\"], () => {\n637:       this.changePriority(1); // lower priority (higher number)\n638:     });\n639: \n640:     // d — toggle hide done\n641:     this.screen.key([\"d\"], () => {\n642:       this.hideDone = !this.hideDone;\n643:       this.buildDisplay();\n644:       this.refreshTaskList();\n645:       this.refreshHeader();\n646:       this.refreshStatusBar();\n647:       this.screen.render();\n648:     });\n649: \n650:     // x — archive done/cancelled tasks\n651:     this.screen.key([\"x\"], () => {\n652:       this.archiveDone();\n653:     });\n654: \n655:     // c — change concurrency\n656:     this.screen.key([\"c\"], () => {\n657:       this.cycleConcurrency();\n658:     });\n659: \n660:     // e — errand (quest-less assisted task generation)\n661:     this.screen.key([\"e\"], () => {\n662:       if (!this.onErrand) return;\n663:       this.saveSession();\n664:       this.destroy();\n665:       this.onErrand();\n666:     });\n667: \n668:     // w — toggle wishlist overlay\n669:     this.screen.key([\"w\"], () => {\n670:       this.toggleWishlist();\n671:     });\n672:   }\n673: \n674:   // -------------------------------------------------------------------------\n675:   // Actions\n676:   // -------------------------------------------------------------------------\n677: \n678:   private toggleCurrent(): void {\n679:     const node = this.displayNodes[this.selectedIndex];\n680:     if (!node) return;\n681:     if (this.selected.has(node.task.id)) {\n682:       this.selected.delete(node.task.id);\n683:     } else {\n684:       this.selected.add(node.task.id);\n685:     }\n686:     this.refreshTaskList();\n687:     this.refreshHeader();\n688:     this.refreshDetail();\n689:     this.refreshStatusBar();\n690:     this.screen.render();\n691:   }\n692: \n693:   private toggleStream(): void {\n694:     const node = this.displayNodes[this.selectedIndex];\n695:     if (!node) return;\n696:     const streamId = node.streamId;\n697:     const streamNodes = this.displayNodes.filter((n) => n.streamId === streamId);\n698: \n699:     // If all in stream are selected, deselect all; otherwise select all\n700:     const allSelected = streamNodes.every((n) => this.selected.has(n.task.id));\n701:     for (const n of streamNodes) {\n702:       if (allSelected) {\n703:         this.selected.delete(n.task.id);\n704:       } else {\n705:         this.selected.add(n.task.id);\n706:       }\n707:     }\n708: \n709:     this.refreshTaskList();\n710:     this.refreshHeader();\n711:     this.refreshDetail();\n712:     this.refreshStatusBar();\n713:     this.screen.render();\n714:   }\n715: \n716:   private toggleAll(): void {\n717:     const allSelected = this.displayNodes.every((n) => this.selected.has(n.task.id));\n718:     for (const n of this.displayNodes) {\n719:       if (allSelected) {\n720:         this.selected.delete(n.task.id);\n721:       } else {\n722:         this.selected.add(n.task.id);\n723:       }\n724:     }\n725:     this.refreshTaskList();\n726:     this.refreshHeader();\n727:     this.refreshStatusBar();\n728:     this.screen.render();\n729:   }\n730: \n731:   private launchSelected(): void {\n732:     if (this.selected.size === 0) return;\n733:     this.saveSession();\n734:     const ids = [...this.selected];\n735: \n736:     // Show a transition message on the existing screen before the caller\n737:     // destroys it — avoids jarring flash of raw console output.\n738:     try {\n739:       this.taskList.setContent(\"\");\n740:       this.detailBox.setContent(\"\");\n741:       this.statusBar.setContent(\"\");\n742:       this.headerBox.setContent(\n743:         ` {bold}{cyan-fg}Launching ${ids.length} task(s)...{/cyan-fg}{/bold}`\n744:       );\n745:       this.screen.render();\n746:     } catch {\n747:       // Screen may already be in a bad state — proceed regardless\n748:     }\n749: \n750:     this.onLaunch(ids);\n751:   }\n752: \n753:   private cycleSort(): void {\n754:     const idx = SORT_FIELDS.indexOf(this.session.sortBy);\n755:     this.session.sortBy = SORT_FIELDS[(idx + 1) % SORT_FIELDS.length];\n756:     this.buildDisplay();\n757:     this.selectedIndex = Math.min(this.selectedIndex, this.displayNodes.length - 1);\n758:     this.refreshTaskList();\n759:     this.refreshHeader();\n760:     this.refreshStatusBar();\n761:     this.screen.render();\n762:   }\n763: \n764:   private changePriority(delta: number): void {\n765:     const node = this.displayNodes[this.selectedIndex];\n766:     if (!node) return;\n767:     const priorities: Priority[] = [\"critical\", \"high\", \"medium\", \"low\", \"wishlist\"];\n768:     const currentIdx = priorities.indexOf(node.task.priority);\n769:     const newIdx = Math.max(0, Math.min(priorities.length - 1, currentIdx + delta));\n770:     if (newIdx === currentIdx) return;\n771: \n772:     node.task.priority = priorities[newIdx];\n773:     // Persist the change\n774:     saveTaskToStore(this.projectRoot, this.config, node.task);\n775:     this.refreshTaskList();\n776:     this.refreshDetail();\n777:     this.screen.render();\n778:   }\n779: \n780:   private cycleConcurrency(): void {\n781:     const levels = [1, 2, 3, 5, 8, 10, 15, 20];\n782:     const idx = levels.indexOf(this.session.maxConcurrent);\n783:     this.session.maxConcurrent = levels[(idx + 1) % levels.length];\n784:     this.refreshStatusBar();\n785:     this.screen.render();\n786:   }\n787: \n788:   /**\n789:    * Archive all done/cancelled tasks. If tasks are selected, only archive\n790:    * those that are done/cancelled. Otherwise archive ALL done/cancelled.\n791:    */\n792:   private archiveDone(): void {\n793:     const candidates =\n794:       this.selected.size > 0\n795:         ? this.allTasks.filter(\n796:             (t) => this.selected.has(t.id) && (t.status === \"done\" || t.status === \"cancelled\")\n797:           )\n798:         : this.allTasks.filter(\n799:             (t) => t.status === \"done\" || t.status === \"cancelled\"\n800:           );\n801: \n802:     if (candidates.length === 0) return;\n803: \n804:     for (const task of candidates) {\n805:       saveTaskToArchive(this.projectRoot, this.config, task);\n806:       removeTaskFromStore(this.projectRoot, this.config, task.id);\n807:       this.selected.delete(task.id);\n808:     }\n809: \n810:     // Reload from disk and rebuild the display\n811:     this.reloadTasks();\n812:     this.buildDisplay();\n813:     this.selectedIndex = Math.min(this.selectedIndex, Math.max(0, this.displayNodes.length - 1));\n814:     this.refresh();\n815:   }\n816: \n817:   private toggleWishlist(): void {\n818:     // Close if already open\n819:     if (this.wishlistOverlay && !this.wishlistOverlay.isDestroyed()) {\n820:       this.wishlistOverlay.close();\n821:       this.wishlistOverlay = null;\n822:       this.taskList.focus();\n823:       this.screen.render();\n824:       return;\n825:     }\n826: \n827:     this.wishlistOverlay = new WishlistOverlay(\n828:       this.screen,\n829:       this.projectRoot,\n830:       {\n831:         onClose: () => {\n832:           this.wishlistOverlay = null;\n833:           this.taskList.focus();\n834:           this.refreshStatusBar();\n835:           this.screen.render();\n836:         },\n837:       }\n838:     );\n839:   }\n840: \n841:   // -------------------------------------------------------------------------\n842:   // Session Persistence\n843:   // -------------------------------------------------------------------------\n844: \n845:   private saveSession(): void {\n846:     this.session.selected = [...this.selected];\n847:     this.session.collapsed = [...this.collapsed];\n848:     saveTUISession(this.projectRoot, this.session);\n849:   }\n850: \n851:   // -------------------------------------------------------------------------\n852:   // Refresh Logic\n853:   // -------------------------------------------------------------------------\n854: \n855:   private refresh(): void {\n856:     this.refreshHeader();\n857:     this.refreshTaskList();\n858:     this.refreshDetail();\n859:     this.refreshStatusBar();\n860:     this.screen.render();\n861:   }\n862: \n863:   private refreshHeader(): void {\n864:     const total = this.allTasks.length;\n865:     const displayed = this.displayNodes.length;\n866:     const selectedCount = this.selected.size;\n867:     const doneCount = this.allTasks.filter((t) => t.status === \"done\").length;\n868:     const readyCount = this.allTasks.filter(\n869:       (t) => t.status === \"backlog\" && areDependenciesMet(t, this.doneIds)\n870:     ).length;\n871: \n872:     let line1 = ` {bold}wombo-combo{/bold}`;\n873:     if (this.questTitle) {\n874:       line1 += ` {magenta-fg}\\u25B6 ${escapeBlessedTags(this.questTitle)}{/magenta-fg}`;\n875:     } else {\n876:       line1 += ` {cyan-fg}Task Browser{/cyan-fg}`;\n877:     }\n878:     line1 += `  {gray-fg}|{/gray-fg}  {white-fg}${total}{/white-fg} tasks`;\n879:     if (this.hideDone) line1 += ` ({white-fg}${displayed}{/white-fg} shown)`;\n880:     line1 += `  {gray-fg}|{/gray-fg}  {green-fg}${selectedCount}{/green-fg} selected`;\n881: \n882:     let line2 = ` {green-fg}${doneCount}{/green-fg} done`;\n883:     line2 += `  {cyan-fg}${readyCount}{/cyan-fg} ready`;\n884:     line2 += `  {gray-fg}|{/gray-fg}  Sort: {yellow-fg}${this.session.sortBy}{/yellow-fg}`;\n885:     line2 += `  {gray-fg}|{/gray-fg}  Concurrency: {yellow-fg}${this.session.maxConcurrent}{/yellow-fg}`;\n886: \n887:     this.headerBox.setContent(`${line1}\\n${line2}`);\n888:   }\n889: \n890:   private refreshTaskList(): void {\n891:     const items: string[] = [];\n892:     let lastStreamId = \"\";\n893: \n894:     for (let i = 0; i < this.displayNodes.length; i++) {\n895:       const node = this.displayNodes[i];\n896:       const t = node.task;\n897: \n898:       // Stream separator\n899:       if (node.streamId !== lastStreamId && lastStreamId !== \"\") {\n900:         // We use a visual separator row — but it's not selectable in blessed list,\n901:         // so we just change the color/style\n902:       }\n903:       lastStreamId = node.streamId;\n904: \n905:       // Checkbox\n906:       const isSelected = this.selected.has(t.id);\n907:       const checkbox = isSelected\n908:         ? \"{green-fg}\\u2611{/green-fg}\" // ☑\n909:         : \"{gray-fg}\\u2610{/gray-fg}\";  // ☐\n910: \n911:       // Indent based on depth\n912:       const indent = \"  \".repeat(node.depth);\n913: \n914:       // Dependency readiness indicator\n915:       const depsReady = areDependenciesMet(t, this.doneIds);\n916:       const readyIcon = t.status === \"done\"\n917:         ? \"{green-fg}\\u2713{/green-fg}\"   // ✓\n918:         : depsReady\n919:           ? \"{cyan-fg}\\u25CF{/cyan-fg}\"   // ● ready\n920:           : \"{red-fg}\\u25CB{/red-fg}\";     // ○ blocked\n921: \n922:       // Task ID (truncated)\n923:       const maxIdLen = 26 - node.depth * 2;\n924:       const fid = t.id.length > maxIdLen\n925:         ? t.id.slice(0, maxIdLen - 1) + \"\\u2026\"\n926:         : t.id.padEnd(maxIdLen);\n927: \n928:       // Priority\n929:       const pColor = PRIORITY_COLORS[t.priority] ?? \"white\";\n930:       const pAbbr = PRIORITY_ABBREV[t.priority] ?? t.priority.slice(0, 4).toUpperCase();\n931:       const priority = `{${pColor}-fg}${pAbbr}{/${pColor}-fg}`;\n932: \n933:       // Status\n934:       const sColor = STATUS_COLORS[t.status] ?? \"white\";\n935:       const sAbbr = STATUS_ABBREV[t.status] ?? t.status.slice(0, 4).toUpperCase();\n936:       const status = `{${sColor}-fg}${sAbbr}{/${sColor}-fg}`;\n937: \n938:       // Effort\n939:       const effort = formatDuration(parseDurationMinutes(t.effort));\n940: \n941:       items.push(\n942:         ` ${checkbox} ${indent}${readyIcon} ${fid} ${priority} ${status} {gray-fg}${effort}{/gray-fg}`\n943:       );\n944:     }\n945: \n946:     if (items.length === 0) {\n947:       items.push(\" {gray-fg}No tasks found{/gray-fg}\");\n948:     }\n949: \n950:     const prevSelected = this.selectedIndex;\n951:     this.taskList.setItems(items as any);\n952:     if (prevSelected < items.length) {\n953:       this.taskList.select(prevSelected);\n954:     }\n955:   }\n956: \n957:   private refreshDetail(): void {\n958:     const node = this.displayNodes[this.selectedIndex];\n959:     if (!node) {\n960:       this.detailBox.setContent(\"{gray-fg}No task selected{/gray-fg}\");\n961:       return;\n962:     }\n963: \n964:     const t = node.task;\n965:     const lines: string[] = [];\n966: \n967:     // Title\n968:     lines.push(`{bold}{white-fg}${escapeBlessedTags(t.title)}{/white-fg}{/bold}`);\n969:     lines.push(\"\");\n970: \n971:     // Status & Priority\n972:     const sColor = STATUS_COLORS[t.status] ?? \"white\";\n973:     lines.push(`  Status:     {${sColor}-fg}${t.status}{/${sColor}-fg}`);\n974:     const pColor = PRIORITY_COLORS[t.priority] ?? \"white\";\n975:     lines.push(`  Priority:   {${pColor}-fg}${t.priority}{/${pColor}-fg}  {gray-fg}(+/- to change){/gray-fg}`);\n976:     lines.push(`  Difficulty:  ${t.difficulty}`);\n977:     lines.push(`  Effort:      ${formatDuration(parseDurationMinutes(t.effort))}`);\n978:     lines.push(`  Completion:  ${t.completion}%`);\n979: \n980:     // Selection state\n981:     const isSelected = this.selected.has(t.id);\n982:     lines.push(`  Selected:   ${isSelected ? \"{green-fg}yes{/green-fg}\" : \"{gray-fg}no{/gray-fg}\"}`);\n983: \n984:     // Dependency readiness\n985:     const depsReady = areDependenciesMet(t, this.doneIds);\n986:     lines.push(`  Deps ready: ${depsReady ? \"{green-fg}yes{/green-fg}\" : \"{red-fg}no{/red-fg}\"}`);\n987: \n988:     // Stream info\n989:     lines.push(`  Stream:      ${node.streamId}`);\n990:     lines.push(`  Depth:       ${node.depth}`);\n991:     lines.push(\"\");\n992: \n993:     // Dependencies\n994:     if (t.depends_on.length > 0) {\n995:       lines.push(\"{bold}Dependencies:{/bold}\");\n996:       for (const dep of t.depends_on) {\n997:         const isDone = this.doneIds.has(dep);\n998:         const icon = isDone ? \"{green-fg}\\u2713{/green-fg}\" : \"{red-fg}\\u2717{/red-fg}\";\n999:         lines.push(`  ${icon} ${dep}`);\n1000:       }\n1001:       lines.push(\"\");\n1002:     }\n1003: \n1004:     // Depended on by\n1005:     if (node.dependedOnBy.length > 0) {\n1006:       lines.push(\"{bold}Depended on by:{/bold}\");\n1007:       for (const id of node.dependedOnBy) {\n1008:         lines.push(`  \\u2192 ${id}`);\n1009:       }\n1010:       lines.push(\"\");\n1011:     }\n1012: \n1013:     // Description\n1014:     if (t.description) {\n1015:       lines.push(\"{bold}Description:{/bold}\");\n1016:       const desc = escapeBlessedTags(t.description.trim());\n1017:       // Word-wrap to roughly 38 chars\n1018:       const words = desc.split(/\\s+/);\n1019:       let line = \" \";\n1020:       for (const w of words) {\n1021:         if (line.length + w.length > 36) {\n1022:           lines.push(line);\n1023:           line = \" \" + w;\n1024:         } else {\n1025:           line += \" \" + w;\n1026:         }\n1027:       }\n1028:       if (line.trim()) lines.push(line);\n1029:       lines.push(\"\");\n1030:     }\n1031: \n1032:     // Agent type\n1033:     if (t.agent_type) {\n1034:       lines.push(`{bold}Agent:{/bold} ${escapeBlessedTags(t.agent_type)}`);\n1035:     }\n1036: \n1037:     // Token usage\n1038:     const usage = this.taskUsage.get(t.id);\n1039:     if (usage) {\n1040:       lines.push(\"\");\n1041:       lines.push(\"{bold}{yellow-fg}Token Usage:{/yellow-fg}{/bold}\");\n1042:       lines.push(`  Input:      {cyan-fg}${formatTokenCount(usage.input_tokens)}{/cyan-fg}`);\n1043:       lines.push(`  Output:     {cyan-fg}${formatTokenCount(usage.output_tokens)}{/cyan-fg}`);\n1044:       if (usage.cache_read > 0) {\n1045:         lines.push(`  Cache read: {gray-fg}${formatTokenCount(usage.cache_read)}{/gray-fg}`);\n1046:       }\n1047:       if (usage.reasoning_tokens > 0) {\n1048:         lines.push(`  Reasoning:  {magenta-fg}${formatTokenCount(usage.reasoning_tokens)}{/magenta-fg}`);\n1049:       }\n1050:       lines.push(`  Total:      {white-fg}${formatTokenCount(usage.total_tokens)}{/white-fg}`);\n1051:       if (usage.total_cost > 0) {\n1052:         lines.push(`  Cost:       {yellow-fg}${formatCost(usage.total_cost)}{/yellow-fg}`);\n1053:       }\n1054:       lines.push(`  Steps:      ${usage.record_count}`);\n1055:     }\n1056: \n1057:     // Constraints\n1058:     if (t.constraints.length > 0) {\n1059:       lines.push(\"{bold}Constraints:{/bold}\");\n1060:       for (const c of t.constraints) {\n1061:         lines.push(`  \\u2022 ${escapeBlessedTags(c)}`);\n1062:       }\n1063:     }\n1064: \n1065:     this.detailBox.setContent(lines.join(\"\\n\"));\n1066:     this.detailBox.setLabel(` ${t.id} `);\n1067:   }\n1068: \n1069:   private refreshStatusBar(): void {\n1070:     const selCount = this.selected.size;\n1071:     const readyInSelection = [...this.selected].filter((id) => {\n1072:       const t = this.allTasks.find((tt) => tt.id === id);\n1073:       return t && (t.status === \"backlog\" || t.status === \"planned\") && areDependenciesMet(t, this.doneIds);\n1074:     }).length;\n1075: \n1076:     let line1 = ` {bold}Keys:{/bold}`;\n1077:     line1 += `  {gray-fg}Space{/gray-fg} toggle`;\n1078:     line1 += `  {gray-fg}S{/gray-fg} stream`;\n1079:     line1 += `  {gray-fg}A{/gray-fg} all`;\n1080:     line1 += `  {gray-fg}+/-{/gray-fg} priority`;\n1081:     line1 += `  {gray-fg}D{/gray-fg} ${this.hideDone ? \"show\" : \"hide\"} done`;\n1082:     line1 += `  {gray-fg}X{/gray-fg} archive done`;\n1083:     line1 += `  {gray-fg}C{/gray-fg} concurrency`;\n1084:     if (this.onErrand) {\n1085:       line1 += `  {gray-fg}E{/gray-fg} errand`;\n1086:     }\n1087:     line1 += `  {gray-fg}W{/gray-fg} wishlist`;\n1088:     line1 += `  {gray-fg}O{/gray-fg} sort`;\n1089: \n1090:     if (selCount > 0) {\n1091:       line1 += `  {bold}{green-fg}L{/green-fg} LAUNCH (${selCount}){/bold}`;\n1092:     }\n1093:     if (this.hasRunningWave) {\n1094:       line1 += `  {gray-fg}Tab{/gray-fg} monitor`;\n1095:     }\n1096:     if (this.onBack) {\n1097:       line1 += `  {gray-fg}Esc{/gray-fg} back`;\n1098:     }\n1099:     if (this.questId) {\n1100:       line1 += `  {gray-fg}Q{/gray-fg} back`;\n1101:     } else {\n1102:       line1 += `  {gray-fg}Q{/gray-fg} quit`;\n1103:     }\n1104: \n1105:     let line2 = ` `;\n1106:     if (selCount > 0) {\n1107:       line2 += `{green-fg}${selCount}{/green-fg} selected`;\n1108:       line2 += `  {cyan-fg}${readyInSelection}{/cyan-fg} launchable now`;\n1109:       const doneInSel = [...this.selected].filter((id) => {\n1110:         const t = this.allTasks.find((tt) => tt.id === id);\n1111:         return t?.status === \"done\";\n1112:       }).length;\n1113:       if (doneInSel > 0) {\n1114:         line2 += `  {yellow-fg}${doneInSel} already done (will be skipped){/yellow-fg}`;\n1115:       }\n1116:     } else {\n1117:       line2 += `{gray-fg}Select tasks with Space, then press L to launch{/gray-fg}`;  \n1118:     }\n1119: \n1120:     this.statusBar.setContent(`${line1}\\n${line2}`);\n1121:   }\n1122: }\n\n(End of file - total 1122 lines)\n</content>","title":"src/lib/tui-browser.ts","metadata":{"preview":"/**\n * tui-browser.ts — Task browser view for the wombo-combo TUI.\n *\n * Shows all tasks organized by dependency streams with checkboxes for\n * selection. Users can evaluate tasks, order them, select/deselect\n * entire streams, and launch a wave with the selected tasks.\n *\n * Layout:\n *   ┌───────────────────────────────────────────────────────┐\n *   │ WOMBO-COMBO Task Browser  │ 42 tasks │ 5 selected    │\n *   ├──────────────────────────────┬────────────────────────┤\n *   │ ☑ json-features-check  done │ Title: ...             │\n *   │ ☑ json-features-arch   done │ Status: backlog        │\n *   │   ☐ json-ops-commands  back │ Priority: high         │\n *   │ ── stream 2 ──              │ Effort: PT6H           │\n *   │ ☐ tdd-test-detection   done │ Depends on:            │\n *   │ ...                         │   - json-ops-commands  │\n *   ├──────────────────────────────┴────────────────────────┤\n *   │ Space:toggle  S:stream  L:launch  O:sort  Q:quit    │\n *   └───────────────────────────────────────────────────────┘","truncated":false,"loaded":[]},"time":{"start":1773483539891,"end":1773483539898}}}}
{"type":"tool_use","timestamp":1773483540151,"sessionID":"ses_3142777b4ffe3IuXz7qBZaextx","part":{"id":"prt_cebdb3db400117HMwhEC52IUgI","sessionID":"ses_3142777b4ffe3IuXz7qBZaextx","messageID":"msg_cebdb2e2f001yk4l1PYw15V1oc","type":"tool","callID":"toolu_vrtx_01SNYy1tcd4FxZcFmC4fciMW","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/token-tui/src/lib/tui.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/token-tui/src/lib/tui.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tui.ts — Blessed-based TUI dashboard for wombo-combo.\n3:  *\n4:  * Layout:\n5:  *   ┌─────────────────────────────────────────────┐\n6:  *   │ Header: Wave ID, base branch, mode, model   │\n7:  *   ├──────────────────────────┬──────────────────┤\n8:  *   │ Agent Table              │ Preview Pane     │\n9:  *   │ (selectable rows with    │ (parsed activity │\n10:  *   │  status, activity,       │  stream for the  │\n11:  *   │  progress bars, elapsed) │  selected agent) │\n12:  *   ├──────────────────────────┴──────────────────┤\n13:  *   │ Status bar: keybinds + summary counts       │\n14:  *   └─────────────────────────────────────────────┘\n15:  *\n16:  * Keybinds:\n17:  *   Up/Down   — navigate agent list\n18:  *   Enter     — attach to selected agent's multiplexer session (interactive mode)\n19:  *   r         — retry a failed/stuck agent\n20:  *   b         — show build log for selected agent\n21:  *   p         — toggle auto-scroll (pause/resume)\n22:  *   q / C-c   — quit\n23:  */\n24: \n25: import blessed from \"neo-blessed\";\n26: import type { Widgets } from \"neo-blessed\";\n27: import type { WaveState, AgentState, AgentStatus } from \"./state.js\";\n28: import { agentCounts } from \"./state.js\";\n29: import type { ProcessMonitor, ActivityEntry } from \"./monitor.js\";\n30: import { execSync } from \"node:child_process\";\n31: import { readFileSync } from \"node:fs\";\n32: import { resolve } from \"node:path\";\n33: import type { WomboConfig } from \"../config.js\";\n34: import {\n35:   detectMultiplexer,\n36:   muxHasSession,\n37:   muxAttach,\n38:   muxDisplayName,\n39: } from \"./multiplexer.js\";\n40: import { QuestionPopup } from \"./tui-question-popup.js\";\n41: import type { HitlQuestion } from \"./hitl-channel.js\";\n42: \n43: // ---------------------------------------------------------------------------\n44: // Types\n45: // ---------------------------------------------------------------------------\n46: \n47: export interface TUIOptions {\n48:   state: WaveState;\n49:   monitor: ProcessMonitor;\n50:   onQuit: () => void;\n51:   /** Whether the wave is running in interactive (multiplexer) mode. */\n52:   interactive?: boolean;\n53:   /** Project root path (for locating log files). */\n54:   projectRoot: string;\n55:   /** Config (for multiplexer session prefix, log dir, etc.) */\n56:   config: WomboConfig;\n57:   /** Callback to retry a failed/stuck agent from the TUI. */\n58:   onRetry?: (featureId: string) => void;\n59:   /** Callback when the user answers an HITL question. */\n60:   onAnswer?: (agentId: string, questionId: string, answerText: string) => void;\n61:   /**\n62:    * Callback invoked during stop() BEFORE the blessed screen is destroyed.\n63:    * Use this to flush pending state writes to disk while the process is\n64:    * still alive and I/O is still functional. This ensures state.json\n65:    * integrity even if the process exits immediately after screen.destroy().\n66:    */\n67:   onBeforeDestroy?: () => void;\n68: }\n69: \n70: // ---------------------------------------------------------------------------\n71: // Color Map\n72: // ---------------------------------------------------------------------------\n73: \n74: const STATUS_COLORS: Record<AgentStatus, string> = {\n75:   queued: \"gray\",\n76:   installing: \"cyan\",\n77:   running: \"blue\",\n78:   completed: \"yellow\",\n79:   verified: \"green\",\n80:   failed: \"red\",\n81:   merged: \"magenta\",\n82:   retry: \"yellow\",\n83:   resolving_conflict: \"cyan\",\n84: };\n85: \n86: const STATUS_ICONS: Record<AgentStatus, string> = {\n87:   queued: \"·\",\n88:   installing: \"⟳\",\n89:   running: \"●\",\n90:   completed: \"○\",\n91:   verified: \"✓\",\n92:   failed: \"✗\",\n93:   merged: \"◆\",\n94:   retry: \"↻\",\n95:   resolving_conflict: \"⚡\",\n96: };\n97: \n98: // ---------------------------------------------------------------------------\n99: // Helpers\n100: // ---------------------------------------------------------------------------\n101: \n102: /**\n103:  * Escape curly braces so blessed doesn't interpret them as formatting tags.\n104:  * Blessed uses {color-fg}...{/color-fg} syntax; unmatched or malformed braces\n105:  * in user-provided text (JSON, Python dicts, shell commands, etc.) crash the\n106:  * renderer. We replace { and } with the Unicode fullwidth equivalents which\n107:  * render visually similar but are not parsed by blessed.\n108:  */\n109: function escapeBlessedTags(text: string): string {\n110:   return text.replace(/\\{/g, \"｛\").replace(/\\}/g, \"｝\");\n111: }\n112: \n113: function elapsed(startedAt: string | null): string {\n114:   if (!startedAt) return \"-\";\n115:   const start = new Date(startedAt).getTime();\n116:   const diffMs = Date.now() - start;\n117:   const secs = Math.floor(diffMs / 1000);\n118:   if (secs < 60) return `${secs}s`;\n119:   const mins = Math.floor(secs / 60);\n120:   if (mins < 60) return `${mins}m`;\n121:   const hours = Math.floor(mins / 60);\n122:   return `${hours}h${mins % 60}m`;\n123: }\n124: \n125: function progressBar(\n126:   elapsedMs: number,\n127:   estimateMs: number,\n128:   width: number = 10\n129: ): string {\n130:   if (estimateMs <= 0) return \"░\".repeat(width);\n131:   const ratio = Math.min(elapsedMs / estimateMs, 1);\n132:   const filled = Math.round(ratio * width);\n133:   return \"█\".repeat(filled) + \"░\".repeat(width - filled);\n134: }\n135: \n136: // ---------------------------------------------------------------------------\n137: // TUI Dashboard Class\n138: // ---------------------------------------------------------------------------\n139: \n140: export class WomboTUI {\n141:   private screen: Widgets.Screen;\n142:   private headerBox: Widgets.BoxElement;\n143:   private agentList: Widgets.ListElement;\n144:   private previewBox: Widgets.Log;\n145:   private statusBar: Widgets.BoxElement;\n146:   private buildLogBox: Widgets.Log;\n147: \n148:   private state: WaveState;\n149:   private monitor: ProcessMonitor;\n150:   private onQuit: () => void;\n151:   private onRetry?: (featureId: string) => void;\n152:   private onAnswer?: (agentId: string, questionId: string, answerText: string) => void;\n153:   private onBeforeDestroy?: () => void;\n154:   private interactive: boolean;\n155:   private projectRoot: string;\n156:   private config: WomboConfig;\n157: \n158:   private selectedIndex: number = 0;\n159:   private autoScroll: boolean = true;\n160:   private showingBuildLog: boolean = false;\n161:   private showingLogFile: boolean = false;\n162:   private logFileBox: Widgets.Log | null = null;\n163:   private refreshTimer: ReturnType<typeof setInterval> | null = null;\n164:   private waveComplete: boolean = false;\n165:   private waveCompleteResolve: (() => void) | null = null;\n166: \n167:   /** Pending HITL questions from agents */\n168:   private pendingQuestions: HitlQuestion[] = [];\n169:   /** Active question popup (null when closed) */\n170:   private questionPopup: QuestionPopup | null = null;\n171: \n172:   /** Saved originals for console interception */\n173:   private origConsoleLog: typeof console.log = console.log;\n174:   private origConsoleError: typeof console.error = console.error;\n175:   private origConsoleWarn: typeof console.warn = console.warn;\n176:   /** System messages captured while TUI is active */\n177:   private systemMessages: ActivityEntry[] = [];\n178: \n179:   constructor(opts: TUIOptions) {\n180:     this.state = opts.state;\n181:     this.monitor = opts.monitor;\n182:     this.onQuit = opts.onQuit;\n183:     this.onRetry = opts.onRetry;\n184:     this.onAnswer = opts.onAnswer;\n185:     this.onBeforeDestroy = opts.onBeforeDestroy;\n186:     this.interactive = opts.interactive ?? false;\n187:     this.projectRoot = opts.projectRoot;\n188:     this.config = opts.config;\n189: \n190:     // Create screen\n191:     this.screen = blessed.screen({\n192:       smartCSR: true,\n193:       title: `wombo-combo — ${opts.state.wave_id}`,\n194:       fullUnicode: true,\n195:     });\n196: \n197:     // Header\n198:     this.headerBox = blessed.box({\n199:       top: 0,\n200:       left: 0,\n201:       width: \"100%\",\n202:       height: 3,\n203:       tags: true,\n204:       style: {\n205:         fg: \"white\",\n206:         bg: \"black\",\n207:       },\n208:     });\n209: \n210:     // Agent list (left pane)\n211:     this.agentList = blessed.list({\n212:       top: 3,\n213:       left: 0,\n214:       width: \"55%\",\n215:       height: \"100%-6\",\n216:       tags: true,\n217:       scrollable: true,\n218:       mouse: true,\n219:       keys: true,\n220:       vi: true,\n221:       border: {\n222:         type: \"line\",\n223:       },\n224:       style: {\n225:         border: { fg: \"gray\" },\n226:         selected: {\n227:           bg: \"blue\",\n228:           fg: \"white\",\n229:           bold: true,\n230:         },\n231:         item: {\n232:           fg: \"white\",\n233:         },\n234:       },\n235:       label: \" Agents \",\n236:     });\n237: \n238:     // Preview pane (right pane)\n239:     this.previewBox = blessed.log({\n240:       top: 3,\n241:       left: \"55%\",\n242:       width: \"45%\",\n243:       height: \"100%-6\",\n244:       tags: true,\n245:       scrollable: true,\n246:       mouse: true,\n247:       keys: false,\n248:       scrollbar: {\n249:         ch: \"│\",\n250:         style: { fg: \"cyan\" },\n251:       },\n252:       border: {\n253:         type: \"line\",\n254:       },\n255:       style: {\n256:         border: { fg: \"gray\" },\n257:         fg: \"white\",\n258:       },\n259:       label: \" Activity \",\n260:     });\n261: \n262:     // Build log overlay (hidden by default)\n263:     this.buildLogBox = blessed.log({\n264:       top: 3,\n265:       left: \"10%\",\n266:       width: \"80%\",\n267:       height: \"100%-6\",\n268:       tags: true,\n269:       scrollable: true,\n270:       mouse: true,\n271:       keys: true,\n272:       scrollbar: {\n273:         ch: \"│\",\n274:         style: { fg: \"yellow\" },\n275:       },\n276:       border: {\n277:         type: \"line\",\n278:       },\n279:       style: {\n280:         border: { fg: \"yellow\" },\n281:         fg: \"white\",\n282:       },\n283:       label: \" Build Log \",\n284:       hidden: true,\n285:     });\n286: \n287:     // Status bar\n288:     this.statusBar = blessed.box({\n289:       bottom: 0,\n290:       left: 0,\n291:       width: \"100%\",\n292:       height: 3,\n293:       tags: true,\n294:       style: {\n295:         fg: \"white\",\n296:         bg: \"black\",\n297:       },\n298:     });\n299: \n300:     // Assemble\n301:     this.screen.append(this.headerBox);\n302:     this.screen.append(this.agentList);\n303:     this.screen.append(this.previewBox);\n304:     this.screen.append(this.buildLogBox);\n305:     this.screen.append(this.statusBar);\n306: \n307:     // Focus the agent list\n308:     this.agentList.focus();\n309: \n310:     // Bind keys\n311:     this.bindKeys();\n312:   }\n313: \n314:   // -------------------------------------------------------------------------\n315:   // Key Bindings\n316:   // -------------------------------------------------------------------------\n317: \n318:   private bindKeys(): void {\n319:     // Quit\n320:     this.screen.key([\"q\", \"C-c\"], () => {\n321:       this.stop();\n322:       if (this.waveComplete && this.waveCompleteResolve) {\n323:         // Wave is done — just close TUI and resolve the wait promise\n324:         this.waveCompleteResolve();\n325:       } else {\n326:         // Wave still running — trigger the abort/interrupt handler\n327:         this.onQuit();\n328:       }\n329:     });\n330: \n331:     // Navigate agent list\n332:     this.agentList.on(\"select item\", (_item: any, index: number) => {\n333:       this.selectedIndex = index;\n334:       this.refreshPreview();\n335:     });\n336: \n337:     // Enter — multiplexer attach\n338:     this.screen.key([\"enter\"], () => {\n339:       this.muxAttach();\n340:     });\n341: \n342:     // b — toggle build log\n343:     this.screen.key([\"b\"], () => {\n344:       this.toggleBuildLog();\n345:     });\n346: \n347:     // p — toggle auto-scroll\n348:     this.screen.key([\"p\"], () => {\n349:       this.autoScroll = !this.autoScroll;\n350:       this.refreshStatusBar();\n351:     });\n352: \n353:     // r — retry failed/stuck agent\n354:     this.screen.key([\"r\"], () => {\n355:       this.retrySelected();\n356:     });\n357: \n358:     // h — open HITL question popup\n359:     this.screen.key([\"h\"], () => {\n360:       this.openQuestionPopup();\n361:     });\n362: \n363:     // Escape — close build log, log file overlay, or question popup\n364:     this.screen.key([\"escape\"], () => {\n365:       if (this.questionPopup && !this.questionPopup.isDestroyed()) {\n366:         this.questionPopup.close();\n367:         this.questionPopup = null;\n368:         this.agentList.focus();\n369:         this.screen.render();\n370:       } else if (this.showingBuildLog) {\n371:         this.showingBuildLog = false;\n372:         this.buildLogBox.hide();\n373:         this.agentList.focus();\n374:         this.screen.render();\n375:       } else if (this.showingLogFile && this.logFileBox) {\n376:         this.showingLogFile = false;\n377:         this.logFileBox.destroy();\n378:         this.logFileBox = null;\n379:         this.agentList.focus();\n380:         this.screen.render();\n381:       }\n382:     });\n383:   }\n384: \n385:   // -------------------------------------------------------------------------\n386:   // Start / Stop\n387:   //\n388:   // ## TUI Lifecycle and Agent Processes (audit: wave-detach-audit)\n389:   //\n390:   // `stop()` only tears down the TUI — it clears the refresh timer and\n391:   // destroys the blessed screen. It does NOT kill agent processes.\n392:   //\n393:   // Agent process termination is handled by the `onQuit` callback, which\n394:   // is set by launch.ts/resume.ts to call `monitor.killAll()` + state save.\n395:   //\n396:   // The separation is intentional:\n397:   //   - `stop()` is also called before mux attach (muxAttach method) where\n398:   //     the TUI is temporarily destroyed and recreated after detach.\n399:   //   - `onQuit()` is only called when the user intends to exit the entire\n400:   //     wave, triggering agent cleanup and process exit.\n401:   //\n402:   // `screen.destroy()` does NOT affect child processes because agents are\n403:   // spawned by the ProcessMonitor (in the launch command), not by the TUI.\n404:   // The TUI only reads from the monitor — it never owns agent processes.\n405:   // -------------------------------------------------------------------------\n406: \n407:   start(): void {\n408:     this.interceptConsole();\n409:     this.refresh();\n410:     this.screen.render();\n411: \n412:     // Auto-refresh every 2 seconds\n413:     this.refreshTimer = setInterval(() => {\n414:       this.refresh();\n415:     }, 2000);\n416:   }\n417: \n418:   stop(): void {\n419:     this.restoreConsole();\n420:     if (this.refreshTimer) {\n421:       clearInterval(this.refreshTimer);\n422:       this.refreshTimer = null;\n423:     }\n424:     // Flush pending state writes before destroying the screen.\n425:     // This ensures state.json integrity even if process.exit() follows.\n426:     if (this.onBeforeDestroy) {\n427:       try {\n428:         this.onBeforeDestroy();\n429:       } catch {\n430:         // Best-effort — don't let flush errors prevent screen cleanup\n431:       }\n432:     }\n433:     this.screen.destroy();\n434:   }\n435: \n436:   /**\n437:    * Intercept console.log/error/warn so they don't corrupt the TUI.\n438:    * Messages are captured into systemMessages and shown in the preview\n439:    * when no specific agent is producing activity.\n440:    */\n441:   private interceptConsole(): void {\n442:     this.origConsoleLog = console.log;\n443:     this.origConsoleError = console.error;\n444:     this.origConsoleWarn = console.warn;\n445: \n446:     const capture = (...args: any[]) => {\n447:       const text = args\n448:         .map((a) => (typeof a === \"string\" ? a : JSON.stringify(a)))\n449:         .join(\" \");\n450:       // Strip ANSI codes for clean TUI display\n451:       const clean = text.replace(/\\x1b\\[[0-9;]*m/g, \"\");\n452:       if (!clean.trim()) return;\n453:       this.systemMessages.push({\n454:         timestamp: new Date().toISOString().slice(11, 19),\n455:         text: clean,\n456:       });\n457:       // Keep bounded\n458:       if (this.systemMessages.length > 200) {\n459:         this.systemMessages.splice(0, this.systemMessages.length - 200);\n460:       }\n461:     };\n462: \n463:     console.log = capture;\n464:     console.error = capture;\n465:     console.warn = capture;\n466:   }\n467: \n468:   /**\n469:    * Restore original console methods.\n470:    */\n471:   private restoreConsole(): void {\n472:     console.log = this.origConsoleLog;\n473:     console.error = this.origConsoleError;\n474:     console.warn = this.origConsoleWarn;\n475:   }\n476: \n477:   /**\n478:    * Update the state reference (called from the monitoring loop).\n479:    */\n480:   updateState(state: WaveState): void {\n481:     this.state = state;\n482:   }\n483: \n484:   /**\n485:    * Mark the wave as complete. The TUI stays open so the user can browse\n486:    * agent logs, build output, etc. The header shows a WAVE COMPLETE banner\n487:    * and the status bar tells the user to press q to exit.\n488:    */\n489:   markWaveComplete(): void {\n490:     this.waveComplete = true;\n491:     this.refresh();\n492:   }\n493: \n494:   /**\n495:    * Returns a Promise that resolves when the user presses q to quit.\n496:    * Used after wave completion so the TUI stays open for post-mortem browsing.\n497:    */\n498:   waitForQuit(): Promise<void> {\n499:     return new Promise<void>((resolve) => {\n500:       this.waveCompleteResolve = resolve;\n501:     });\n502:   }\n503: \n504:   /**\n505:    * Update pending HITL questions. Called from the monitoring loop.\n506:    * If the question popup is open, it gets live-updated too.\n507:    */\n508:   setPendingQuestions(questions: HitlQuestion[]): void {\n509:     this.pendingQuestions = questions;\n510:     if (this.questionPopup && !this.questionPopup.isDestroyed()) {\n511:       this.questionPopup.updateQuestions(questions);\n512:     }\n513:     // Status bar will pick up the badge on next refresh cycle\n514:   }\n515: \n516:   /**\n517:    * Open the HITL question popup modal.\n518:    */\n519:   private openQuestionPopup(): void {\n520:     // Don't open if already open\n521:     if (this.questionPopup && !this.questionPopup.isDestroyed()) return;\n522: \n523:     // Don't open if there are no pending questions\n524:     if (this.pendingQuestions.length === 0) {\n525:       // Flash a message in the preview\n526:       const agent = this.state.agents[this.selectedIndex];\n527:       if (agent) {\n528:         const logs = this.monitor.activityLogs.get(agent.feature_id);\n529:         if (logs) {\n530:           logs.push({\n531:             timestamp: new Date().toISOString().slice(11, 19),\n532:             text: `-- No pending HITL questions`,\n533:           });\n534:         }\n535:         this.refreshPreview();\n536:         this.screen.render();\n537:       }\n538:       return;\n539:     }\n540: \n541:     this.questionPopup = new QuestionPopup(\n542:       this.screen,\n543:       [...this.pendingQuestions], // copy so popup can mutate internally\n544:       {\n545:         onAnswer: (agentId, questionId, answerText) => {\n546:           // Forward to the external callback (which calls submitAnswer)\n547:           if (this.onAnswer) {\n548:             this.onAnswer(agentId, questionId, answerText);\n549:           }\n550:           // Remove from our pending list\n551:           this.pendingQuestions = this.pendingQuestions.filter(\n552:             (q) => !(q.agentId === agentId && q.id === questionId)\n553:           );\n554:         },\n555:         onClose: () => {\n556:           this.questionPopup = null;\n557:           this.agentList.focus();\n558:           this.refreshStatusBar();\n559:           this.screen.render();\n560:         },\n561:       }\n562:     );\n563:   }\n564: \n565:   // -------------------------------------------------------------------------\n566:   // Refresh Logic\n567:   // -------------------------------------------------------------------------\n568: \n569:   private refresh(): void {\n570:     this.refreshHeader();\n571:     this.refreshAgentList();\n572:     this.refreshPreview();\n573:     this.refreshStatusBar();\n574:     this.screen.render();\n575:   }\n576: \n577:   private refreshHeader(): void {\n578:     const s = this.state;\n579:     const counts = agentCounts(s);\n580:     const total = s.agents.length;\n581:     const done = counts.verified + counts.merged;\n582: \n583:     let line1 = ` {bold}wombo-combo{/bold} {gray-fg}${s.wave_id}{/gray-fg}`;\n584:     if (this.waveComplete) {\n585:       line1 += `  {gray-fg}│{/gray-fg}  {bold}{green-fg}WAVE COMPLETE{/green-fg}{/bold}`;\n586:     }\n587:     line1 += `  {gray-fg}│{/gray-fg}  Base: {cyan-fg}${s.base_branch}{/cyan-fg}`;\n588:     line1 += `  {gray-fg}│{/gray-fg}  Mode: ${s.interactive ? \"{green-fg}interactive{/green-fg}\" : \"{blue-fg}headless{/blue-fg}\"}`;\n589:     if (s.model) {\n590:       line1 += `  {gray-fg}│{/gray-fg}  Model: {yellow-fg}${s.model}{/yellow-fg}`;\n591:     }\n592: \n593:     let line2 = ` Progress: {green-fg}${done}{/green-fg}/{white-fg}${total}{/white-fg}`;\n594:     if (counts.running > 0)\n595:       line2 += `  {blue-fg}${counts.running} running{/blue-fg}`;\n596:     if (counts.failed > 0)\n597:       line2 += `  {red-fg}${counts.failed} failed{/red-fg}`;\n598:     if (counts.queued > 0)\n599:       line2 += `  {gray-fg}${counts.queued} queued{/gray-fg}`;\n600:     if (counts.retry > 0)\n601:       line2 += `  {yellow-fg}${counts.retry} retrying{/yellow-fg}`;\n602:     if (counts.resolving_conflict > 0)\n603:       line2 += `  {cyan-fg}${counts.resolving_conflict} resolving{/cyan-fg}`;\n604: \n605:     this.headerBox.setContent(`${line1}\\n${line2}`);\n606:   }\n607: \n608:   private refreshAgentList(): void {\n609:     const items: string[] = [];\n610: \n611:     for (let i = 0; i < this.state.agents.length; i++) {\n612:       const a = this.state.agents[i];\n613:       const color = STATUS_COLORS[a.status];\n614:       const icon = STATUS_ICONS[a.status];\n615: \n616:       // Feature ID (padded)\n617:       const fid =\n618:         a.feature_id.length > 24\n619:           ? a.feature_id.slice(0, 23) + \"…\"\n620:           : a.feature_id.padEnd(24);\n621: \n622:       // Status\n623:       const st = `{${color}-fg}${icon} ${a.status.padEnd(10)}{/${color}-fg}`;\n624: \n625:       // Progress bar\n626:       let pbar = \"\";\n627:       if ((a.status === \"running\" || a.status === \"resolving_conflict\") && a.started_at) {\n628:         const elapsedMs = Date.now() - new Date(a.started_at).getTime();\n629:         // Use actual effort estimate from feature data, fallback to 1h\n630:         const estimateMs = a.effort_estimate_ms ?? 60 * 60 * 1000;\n631:         pbar = ` {cyan-fg}${progressBar(elapsedMs, estimateMs, 8)}{/cyan-fg}`;\n632:       } else if (a.status === \"verified\" || a.status === \"merged\") {\n633:         pbar = ` {green-fg}${\"█\".repeat(8)}{/green-fg}`;\n634:       } else if (a.status === \"failed\") {\n635:         pbar = ` {red-fg}${\"█\".repeat(8)}{/red-fg}`;\n636:       }\n637: \n638:       // Activity (for running/resolving agents)\n639:       let act = \"\";\n640:       if ((a.status === \"running\" || a.status === \"resolving_conflict\") && a.activity) {\n641:         const rawAct =\n642:           a.activity.length > 25 ? a.activity.slice(0, 24) + \"…\" : a.activity;\n643:         const actText = escapeBlessedTags(rawAct);\n644:         act = ` {cyan-fg}${actText}{/cyan-fg}`;\n645:       } else if (a.status === \"installing\") {\n646:         act = \" {cyan-fg}setting up…{/cyan-fg}\";\n647:       }\n648: \n649:       // Elapsed\n650:       const el = elapsed(a.started_at);\n651: \n652:       // Retries\n653:       const retries =\n654:         a.retries > 0 ? ` {yellow-fg}↻${a.retries}{/yellow-fg}` : \"\";\n655: \n656:       items.push(\n657:         ` ${fid} ${st}${pbar}${act}${retries} {gray-fg}${el}{/gray-fg}`\n658:       );\n659:     }\n660: \n661:     // Preserve selection\n662:     const prevSelected = this.selectedIndex;\n663:     this.agentList.setItems(items as any);\n664:     if (prevSelected < items.length) {\n665:       this.agentList.select(prevSelected);\n666:     }\n667:   }\n668: \n669:   private refreshPreview(): void {\n670:     const agent = this.state.agents[this.selectedIndex];\n671:     if (!agent) {\n672:       this.previewBox.setContent(\"{gray-fg}No agent selected{/gray-fg}\");\n673:       return;\n674:     }\n675: \n676:     // Update label\n677:     this.previewBox.setLabel(` ${agent.feature_id} — Activity `);\n678: \n679:     // Get activity log from monitor\n680:     const log = this.monitor.getActivityLog(agent.feature_id);\n681: \n682:     // Also include system messages (build verification, etc.)\n683:     // that mention this agent's feature_id\n684:     const relevantSys = this.systemMessages.filter((m) =>\n685:       m.text.includes(agent.feature_id)\n686:     );\n687: \n688:     if (log.length === 0 && relevantSys.length === 0) {\n689:       this.previewBox.setContent(\n690:         \"{gray-fg}No activity yet. Waiting for agent output…{/gray-fg}\"\n691:       );\n692:       return;\n693:     }\n694: \n695:     // Format log entries\n696:     const lines: string[] = [];\n697:     for (const entry of log) {\n698:       lines.push(this.formatActivityLine(entry));\n699:     }\n700: \n701:     // Append relevant system messages\n702:     if (relevantSys.length > 0) {\n703:       lines.push(\"\");\n704:       lines.push(\"{yellow-fg}-- system --{/yellow-fg}\");\n705:       for (const entry of relevantSys) {\n706:         const ts = `{gray-fg}${entry.timestamp}{/gray-fg}`;\n707:         lines.push(`${ts} {yellow-fg}${escapeBlessedTags(entry.text)}{/yellow-fg}`);\n708:       }\n709:     }\n710: \n711:     this.previewBox.setContent(lines.join(\"\\n\"));\n712: \n713:     // Auto-scroll to bottom\n714:     if (this.autoScroll) {\n715:       this.previewBox.setScrollPerc(100);\n716:     }\n717:   }\n718: \n719:   private formatActivityLine(entry: ActivityEntry): string {\n720:     const ts = `{gray-fg}${entry.timestamp}{/gray-fg}`;\n721:     let text = escapeBlessedTags(entry.text);\n722: \n723:     // Color-code different line types\n724:     if (text.startsWith(\">>\")) {\n725:       text = `{cyan-fg}${text}{/cyan-fg}`;\n726:     } else if (text.startsWith(\"!!\")) {\n727:       text = `{red-fg}${text}{/red-fg}`;\n728:     } else if (text.startsWith(\"--\")) {\n729:       text = `{green-fg}${text}{/green-fg}`;\n730:     } else if (text.startsWith(\"[stderr]\")) {\n731:       text = `{red-fg}${text}{/red-fg}`;\n732:     } else if (text.startsWith(\"[raw]\")) {\n733:       text = `{gray-fg}${text}{/gray-fg}`;\n734:     } else if (text.startsWith(\"   \")) {\n735:       text = `{white-fg}${text}{/white-fg}`;\n736:     }\n737: \n738:     return `${ts} ${text}`;\n739:   }\n740: \n741:   private refreshStatusBar(): void {\n742:     const scrollStatus = this.autoScroll\n743:       ? \"{green-fg}auto-scroll{/green-fg}\"\n744:       : \"{yellow-fg}paused{/yellow-fg}\";\n745: \n746:     const agent = this.state.agents[this.selectedIndex];\n747:     const agentInfo = agent\n748:       ? `{gray-fg}Selected: {white-fg}${agent.feature_id}{/white-fg}{/gray-fg}`\n749:       : \"\";\n750: \n751:     const enterHint = this.interactive\n752:       ? \"{gray-fg}Enter{/gray-fg} attach session\"\n753:       : \"{gray-fg}Enter{/gray-fg} view log\";\n754: \n755:     // HITL badge — show only when there are pending questions\n756:     const hitlBadge =\n757:       this.pendingQuestions.length > 0\n758:         ? `  {bold}{yellow-fg}? ${this.pendingQuestions.length} pending{/yellow-fg}{/bold}  {gray-fg}H{/gray-fg} answer`\n759:         : \"\";\n760: \n761:     let line1: string;\n762:     if (this.waveComplete) {\n763:       line1 = ` {bold}{green-fg}Wave complete.{/green-fg}{/bold}  ${enterHint}  {gray-fg}R{/gray-fg} retry  {gray-fg}B{/gray-fg} build log  {gray-fg}P{/gray-fg} ${scrollStatus}${hitlBadge}  {bold}{yellow-fg}Q{/yellow-fg} exit{/bold}`;\n764:     } else {\n765:       line1 = ` {bold}Keys:{/bold} {gray-fg}\\u2191\\u2193{/gray-fg} navigate  ${enterHint}  {gray-fg}R{/gray-fg} retry  {gray-fg}B{/gray-fg} build log  {gray-fg}P{/gray-fg} ${scrollStatus}${hitlBadge}  {gray-fg}Q{/gray-fg} quit`;\n766:     }\n767:     const line2 = ` ${agentInfo}`;\n768: \n769:     this.statusBar.setContent(`${line1}\\n${line2}`);\n770:   }\n771: \n772:   // -------------------------------------------------------------------------\n773:   // Actions\n774:   // -------------------------------------------------------------------------\n775: \n776:   private muxAttach(): void {\n777:     const agent = this.state.agents[this.selectedIndex];\n778:     if (!agent) return;\n779: \n780:     if (!this.interactive) {\n781:       // Headless mode — show the raw log file in an overlay\n782:       this.showLogFile(agent);\n783:       return;\n784:     }\n785: \n786:     const mux = detectMultiplexer(this.config.agent.multiplexer);\n787:     const sessionName = `${this.config.agent.tmuxPrefix}-${agent.feature_id}`;\n788: \n789:     // Check if multiplexer session exists\n790:     if (!muxHasSession(mux, sessionName)) {\n791:       // No session — show message in preview\n792:       this.monitor.activityLogs.get(agent.feature_id)?.push({\n793:         timestamp: new Date().toISOString().slice(11, 19),\n794:         text: `!! No ${muxDisplayName(mux)} session '${sessionName}' found`,\n795:       });\n796:       this.refreshPreview();\n797:       this.screen.render();\n798:       return;\n799:     }\n800: \n801:     // Detach from blessed, attach to multiplexer session\n802:     this.restoreConsole();\n803:     this.screen.destroy();\n804:     try {\n805:       muxAttach(mux, sessionName);\n806:     } catch {\n807:       // User detached from session — resume TUI\n808:     }\n809: \n810:     // Re-create screen after returning from multiplexer\n811:     this.recreateScreen();\n812:   }\n813: \n814:   /**\n815:    * Retry the selected agent (only if failed or stuck in retry).\n816:    * Resets it to \"queued\" so the polling loop picks it up for a fresh launch.\n817:    */\n818:   private retrySelected(): void {\n819:     const agent = this.state.agents[this.selectedIndex];\n820:     if (!agent) return;\n821: \n822:     const retryableStatuses: AgentStatus[] = [\"failed\", \"retry\"];\n823:     if (!retryableStatuses.includes(agent.status)) {\n824:       // Flash a message in the preview — agent isn't in a retryable state\n825:       const logs = this.monitor.activityLogs.get(agent.feature_id);\n826:       if (logs) {\n827:         logs.push({\n828:           timestamp: new Date().toISOString().slice(11, 19),\n829:           text: `!! Cannot retry — agent status is \"${agent.status}\" (must be failed or retry)`,\n830:         });\n831:       }\n832:       this.refreshPreview();\n833:       this.screen.render();\n834:       return;\n835:     }\n836: \n837:     if (this.onRetry) {\n838:       this.onRetry(agent.feature_id);\n839: \n840:       // Show feedback in preview\n841:       const logs = this.monitor.activityLogs.get(agent.feature_id);\n842:       if (logs) {\n843:         logs.push({\n844:           timestamp: new Date().toISOString().slice(11, 19),\n845:           text: `>> Retry requested — agent will be relaunched`,\n846:         });\n847:       }\n848:       this.refresh();\n849:       this.screen.render();\n850:     }\n851:   }\n852: \n853:   /**\n854:    * Show the raw log file for an agent in an overlay (headless mode).\n855:    */\n856:   private showLogFile(agent: AgentState): void {\n857:     if (this.showingLogFile) {\n858:       // Toggle off\n859:       this.showingLogFile = false;\n860:       if (this.logFileBox) {\n861:         this.logFileBox.destroy();\n862:         this.logFileBox = null;\n863:       }\n864:       this.agentList.focus();\n865:       this.screen.render();\n866:       return;\n867:     }\n868: \n869:     const logPath = resolve(\n870:       this.projectRoot,\n871:       \".wombo-combo\",\n872:       \"logs\",\n873:       `${agent.feature_id}.log`\n874:     );\n875:     let content: string;\n876:     try {\n877:       content = readFileSync(logPath, \"utf-8\");\n878:       if (!content.trim()) {\n879:         content =\n880:           \"{gray-fg}Log file is empty. Agent may not have started producing output yet.{/gray-fg}\";\n881:       }\n882:     } catch {\n883:       content = \"{gray-fg}No log file found at \" + logPath + \"{/gray-fg}\";\n884:     }\n885: \n886:     // Create overlay\n887:     this.logFileBox = blessed.log({\n888:       top: 3,\n889:       left: \"5%\",\n890:       width: \"90%\",\n891:       height: \"100%-6\",\n892:       tags: true,\n893:       scrollable: true,\n894:       mouse: true,\n895:       keys: true,\n896:       scrollbar: {\n897:         ch: \"│\",\n898:         style: { fg: \"cyan\" },\n899:       },\n900:       border: {\n901:         type: \"line\",\n902:       },\n903:       style: {\n904:         border: { fg: \"cyan\" },\n905:         fg: \"white\",\n906:       },\n907:       label: ` Log — ${agent.feature_id} (Esc to close) `,\n908:     });\n909: \n910:     this.screen.append(this.logFileBox);\n911: \n912:     // Truncate to last 200 lines to keep TUI responsive\n913:     const lines = content.split(\"\\n\");\n914:     const truncated =\n915:       lines.length > 200 ? lines.slice(-200).join(\"\\n\") : content;\n916:     this.logFileBox.setContent(escapeBlessedTags(truncated));\n917:     this.logFileBox.setScrollPerc(100);\n918:     this.logFileBox.focus();\n919:     this.showingLogFile = true;\n920:     this.screen.render();\n921:   }\n922: \n923:   private toggleBuildLog(): void {\n924:     const agent = this.state.agents[this.selectedIndex];\n925:     if (!agent) return;\n926: \n927:     if (this.showingBuildLog) {\n928:       this.showingBuildLog = false;\n929:       this.buildLogBox.hide();\n930:       this.agentList.focus();\n931:     } else {\n932:       this.showingBuildLog = true;\n933:       this.buildLogBox.setLabel(` Build Log — ${agent.feature_id} `);\n934: \n935:       if (agent.build_output) {\n936:         this.buildLogBox.setContent(escapeBlessedTags(agent.build_output));\n937:       } else if (agent.build_passed === true) {\n938:         this.buildLogBox.setContent(\n939:           \"{green-fg}Build passed — no errors.{/green-fg}\"\n940:         );\n941:       } else if (agent.build_passed === false) {\n942:         this.buildLogBox.setContent(\n943:           \"{red-fg}Build failed — no output captured.{/red-fg}\"\n944:         );\n945:       } else {\n946:         this.buildLogBox.setContent(\n947:           \"{gray-fg}No build has been run yet.{/gray-fg}\"\n948:         );\n949:       }\n950: \n951:       this.buildLogBox.show();\n952:       this.buildLogBox.focus();\n953:     }\n954:     this.screen.render();\n955:   }\n956: \n957:   /**\n958:    * Re-create the screen after returning from multiplexer attach.\n959:    * Blessed can't resume after destroy, so we rebuild everything.\n960:    */\n961:   private recreateScreen(): void {\n962:     // Re-create screen\n963:     this.screen = blessed.screen({\n964:       smartCSR: true,\n965:       title: `wombo-combo — ${this.state.wave_id}`,\n966:       fullUnicode: true,\n967:     });\n968: \n969:     // Re-create all widgets\n970:     this.headerBox = blessed.box({\n971:       top: 0,\n972:       left: 0,\n973:       width: \"100%\",\n974:       height: 3,\n975:       tags: true,\n976:       style: { fg: \"white\", bg: \"black\" },\n977:     });\n978: \n979:     this.agentList = blessed.list({\n980:       top: 3,\n981:       left: 0,\n982:       width: \"55%\",\n983:       height: \"100%-6\",\n984:       tags: true,\n985:       scrollable: true,\n986:       mouse: true,\n987:       keys: true,\n988:       vi: true,\n989:       border: { type: \"line\" },\n990:       style: {\n991:         border: { fg: \"gray\" },\n992:         selected: { bg: \"blue\", fg: \"white\", bold: true },\n993:         item: { fg: \"white\" },\n994:       },\n995:       label: \" Agents \",\n996:     });\n997: \n998:     this.previewBox = blessed.log({\n999:       top: 3,\n1000:       left: \"55%\",\n1001:       width: \"45%\",\n1002:       height: \"100%-6\",\n1003:       tags: true,\n1004:       scrollable: true,\n1005:       mouse: true,\n1006:       keys: false,\n1007:       scrollbar: { ch: \"│\", style: { fg: \"cyan\" } },\n1008:       border: { type: \"line\" },\n1009:       style: { border: { fg: \"gray\" }, fg: \"white\" },\n1010:       label: \" Activity \",\n1011:     });\n1012: \n1013:     this.buildLogBox = blessed.log({\n1014:       top: 3,\n1015:       left: \"10%\",\n1016:       width: \"80%\",\n1017:       height: \"100%-6\",\n1018:       tags: true,\n1019:       scrollable: true,\n1020:       mouse: true,\n1021:       keys: true,\n1022:       scrollbar: { ch: \"│\", style: { fg: \"yellow\" } },\n1023:       border: { type: \"line\" },\n1024:       style: { border: { fg: \"yellow\" }, fg: \"white\" },\n1025:       label: \" Build Log \",\n1026:       hidden: true,\n1027:     });\n1028: \n1029:     this.statusBar = blessed.box({\n1030:       bottom: 0,\n1031:       left: 0,\n1032:       width: \"100%\",\n1033:       height: 3,\n1034:       tags: true,\n1035:       style: { fg: \"white\", bg: \"black\" },\n1036:     });\n1037: \n1038:     this.screen.append(this.headerBox);\n1039:     this.screen.append(this.agentList);\n1040:     this.screen.append(this.previewBox);\n1041:     this.screen.append(this.buildLogBox);\n1042:     this.screen.append(this.statusBar);\n1043: \n1044:     this.agentList.focus();\n1045:     this.showingBuildLog = false;\n1046:     this.showingLogFile = false;\n1047:     this.logFileBox = null;\n1048:     this.questionPopup = null;\n1049:     this.interceptConsole();\n1050:     this.bindKeys();\n1051:     this.refresh();\n1052:   }\n1053: }\n\n(End of file - total 1053 lines)\n</content>","title":"src/lib/tui.ts","metadata":{"preview":"/**\n * tui.ts — Blessed-based TUI dashboard for wombo-combo.\n *\n * Layout:\n *   ┌─────────────────────────────────────────────┐\n *   │ Header: Wave ID, base branch, mode, model   │\n *   ├──────────────────────────┬──────────────────┤\n *   │ Agent Table              │ Preview Pane     │\n *   │ (selectable rows with    │ (parsed activity │\n *   │  status, activity,       │  stream for the  │\n *   │  progress bars, elapsed) │  selected agent) │\n *   ├──────────────────────────┴──────────────────┤\n *   │ Status bar: keybinds + summary counts       │\n *   └─────────────────────────────────────────────┘\n *\n * Keybinds:\n *   Up/Down   — navigate agent list\n *   Enter     — attach to selected agent's multiplexer session (interactive mode)\n *   r         — retry a failed/stuck agent\n *   b         — show build log for selected agent","truncated":false,"loaded":[]},"time":{"start":1773483540147,"end":1773483540150}}}}
