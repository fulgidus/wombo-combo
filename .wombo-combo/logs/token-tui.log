{"type":"tool_use","timestamp":1773483375139,"sessionID":"ses_3142777b4ffe3IuXz7qBZaextx","part":{"id":"prt_cebd8b484001CptQiZGyqwKKz7","sessionID":"ses_3142777b4ffe3IuXz7qBZaextx","messageID":"msg_cebd8aa0c001nz9ge0Rol13lRP","type":"tool","callID":"toolu_vrtx_01Vgz4W8iDJPY5VrcHvv3rhh","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/token-tui/src/lib/token-usage.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/token-tui/src/lib/token-usage.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * token-usage.ts — Persist and aggregate token usage data.\n3:  *\n4:  * Responsibilities:\n5:  *   - Append UsageRecords to .wombo-combo/usage.jsonl (one JSON object per line)\n6:  *   - Load all records from the JSONL file\n7:  *   - Aggregate: groupBy(field), filterByDateRange(since, until), totalUsage()\n8:  *   - Create a UsageStore that wires into TokenCollector's onUsage callback\n9:  *\n10:  * The JSONL format is append-only and human-readable. Each line is a complete\n11:  * JSON object representing one UsageRecord (one step_finish event). This makes\n12:  * it safe for concurrent writes (append is atomic on most filesystems for\n13:  * small writes) and easy to process with standard unix tools (grep, jq, etc.).\n14:  */\n15: \n16: import { existsSync, mkdirSync, readFileSync, appendFileSync } from \"node:fs\";\n17: import { resolve, dirname } from \"node:path\";\n18: import { WOMBO_DIR } from \"../config.js\";\n19: import type { UsageRecord } from \"./token-collector.js\";\n20: \n21: // ---------------------------------------------------------------------------\n22: // Constants\n23: // ---------------------------------------------------------------------------\n24: \n25: /** Path to the usage JSONL file relative to project root */\n26: const USAGE_FILE = `${WOMBO_DIR}/usage.jsonl`;\n27: \n28: // ---------------------------------------------------------------------------\n29: // Persistence — Append\n30: // ---------------------------------------------------------------------------\n31: \n32: /**\n33:  * Append a single UsageRecord to the usage.jsonl file.\n34:  *\n35:  * Creates the .wombo-combo/ directory and the file if they don't exist.\n36:  * Each record is written as a single JSON line terminated by a newline.\n37:  *\n38:  * @param projectRoot  The project root directory\n39:  * @param record       The UsageRecord to persist\n40:  */\n41: export function appendUsageRecord(\n42:   projectRoot: string,\n43:   record: UsageRecord\n44: ): void {\n45:   const filePath = resolve(projectRoot, USAGE_FILE);\n46:   const dir = dirname(filePath);\n47: \n48:   if (!existsSync(dir)) {\n49:     mkdirSync(dir, { recursive: true });\n50:   }\n51: \n52:   const line = JSON.stringify(record) + \"\\n\";\n53:   appendFileSync(filePath, line, \"utf-8\");\n54: }\n55: \n56: // ---------------------------------------------------------------------------\n57: // Persistence — Load\n58: // ---------------------------------------------------------------------------\n59: \n60: /**\n61:  * Load all UsageRecords from the usage.jsonl file.\n62:  *\n63:  * Skips malformed lines silently (defensive against partial writes or\n64:  * corruption). Returns an empty array if the file doesn't exist.\n65:  *\n66:  * @param projectRoot  The project root directory\n67:  * @returns Array of UsageRecords in chronological order\n68:  */\n69: export function loadUsageRecords(projectRoot: string): UsageRecord[] {\n70:   const filePath = resolve(projectRoot, USAGE_FILE);\n71: \n72:   if (!existsSync(filePath)) return [];\n73: \n74:   const raw = readFileSync(filePath, \"utf-8\");\n75:   const records: UsageRecord[] = [];\n76: \n77:   for (const line of raw.split(\"\\n\")) {\n78:     const trimmed = line.trim();\n79:     if (!trimmed) continue;\n80: \n81:     try {\n82:       const record = JSON.parse(trimmed) as UsageRecord;\n83:       // Basic validation: must have task_id and timestamp\n84:       if (record.task_id && record.timestamp) {\n85:         records.push(record);\n86:       }\n87:     } catch {\n88:       // Skip malformed lines\n89:     }\n90:   }\n91: \n92:   return records;\n93: }\n94: \n95: // ---------------------------------------------------------------------------\n96: // Aggregation — Total Usage\n97: // ---------------------------------------------------------------------------\n98: \n99: /** Aggregated totals across a set of usage records */\n100: export interface UsageTotals {\n101:   /** Total input tokens */\n102:   input_tokens: number;\n103:   /** Total output tokens */\n104:   output_tokens: number;\n105:   /** Total cache read tokens */\n106:   cache_read: number;\n107:   /** Total cache write tokens */\n108:   cache_write: number;\n109:   /** Total reasoning tokens */\n110:   reasoning_tokens: number;\n111:   /** Grand total tokens */\n112:   total_tokens: number;\n113:   /** Total cost */\n114:   total_cost: number;\n115:   /** Number of records (steps) */\n116:   record_count: number;\n117: }\n118: \n119: /**\n120:  * Compute total usage across a set of records.\n121:  *\n122:  * @param records  The records to sum\n123:  * @returns Aggregated totals\n124:  */\n125: export function totalUsage(records: UsageRecord[]): UsageTotals {\n126:   return {\n127:     input_tokens: records.reduce((sum, r) => sum + r.input_tokens, 0),\n128:     output_tokens: records.reduce((sum, r) => sum + r.output_tokens, 0),\n129:     cache_read: records.reduce((sum, r) => sum + r.cache_read, 0),\n130:     cache_write: records.reduce((sum, r) => sum + r.cache_write, 0),\n131:     reasoning_tokens: records.reduce((sum, r) => sum + r.reasoning_tokens, 0),\n132:     total_tokens: records.reduce((sum, r) => sum + r.total_tokens, 0),\n133:     total_cost: records.reduce((sum, r) => sum + r.cost, 0),\n134:     record_count: records.length,\n135:   };\n136: }\n137: \n138: // ---------------------------------------------------------------------------\n139: // Aggregation — Filter by Date Range\n140: // ---------------------------------------------------------------------------\n141: \n142: /**\n143:  * Filter records to those within a date range.\n144:  *\n145:  * Both `since` and `until` are inclusive. If either is omitted, that side\n146:  * of the range is unbounded.\n147:  *\n148:  * @param records  The records to filter\n149:  * @param since    Start of range (ISO 8601 string or Date). Inclusive.\n150:  * @param until    End of range (ISO 8601 string or Date). Inclusive.\n151:  * @returns Filtered records\n152:  */\n153: export function filterByDateRange(\n154:   records: UsageRecord[],\n155:   since?: string | Date,\n156:   until?: string | Date\n157: ): UsageRecord[] {\n158:   const sinceMs = since ? new Date(since).getTime() : -Infinity;\n159:   const untilMs = until ? new Date(until).getTime() : Infinity;\n160: \n161:   if (isNaN(sinceMs) && since) {\n162:     throw new Error(`Invalid 'since' date: ${since}`);\n163:   }\n164:   if (isNaN(untilMs) && until) {\n165:     throw new Error(`Invalid 'until' date: ${until}`);\n166:   }\n167: \n168:   return records.filter((r) => {\n169:     const ts = new Date(r.timestamp).getTime();\n170:     if (isNaN(ts)) return false;\n171:     return ts >= sinceMs && ts <= untilMs;\n172:   });\n173: }\n174: \n175: // ---------------------------------------------------------------------------\n176: // Aggregation — Group By\n177: // ---------------------------------------------------------------------------\n178: \n179: /** Fields that can be used as groupBy keys */\n180: export type GroupableField =\n181:   | \"task_id\"\n182:   | \"quest_id\"\n183:   | \"model\"\n184:   | \"provider\"\n185:   | \"harness\";\n186: \n187: /**\n188:  * Group records by a specified field and compute totals for each group.\n189:  *\n190:  * The grouping key is the string value of the specified field. Null values\n191:  * are grouped under the key \"(unknown)\".\n192:  *\n193:  * @param records  The records to group\n194:  * @param field    The field to group by\n195:  * @returns Map from group key to aggregated totals\n196:  */\n197: export function groupBy(\n198:   records: UsageRecord[],\n199:   field: GroupableField\n200: ): Map<string, UsageTotals> {\n201:   const groups = new Map<string, UsageRecord[]>();\n202: \n203:   for (const record of records) {\n204:     const key = String(record[field] ?? \"(unknown)\");\n205:     if (!groups.has(key)) {\n206:       groups.set(key, []);\n207:     }\n208:     groups.get(key)!.push(record);\n209:   }\n210: \n211:   const result = new Map<string, UsageTotals>();\n212:   for (const [key, groupRecords] of groups) {\n213:     result.set(key, totalUsage(groupRecords));\n214:   }\n215: \n216:   return result;\n217: }\n218: \n219: // ---------------------------------------------------------------------------\n220: // UsageStore — High-level persistence wrapper\n221: // ---------------------------------------------------------------------------\n222: \n223: /**\n224:  * UsageStore provides a high-level interface for persisting token usage data.\n225:  *\n226:  * It is designed to be used as the onUsage callback for TokenCollector, so that\n227:  * every parsed UsageRecord is immediately persisted to the JSONL file.\n228:  *\n229:  * Usage:\n230:  *   const store = new UsageStore(projectRoot);\n231:  *\n232:  *   // Wire into TokenCollector\n233:  *   const collector = new TokenCollector((record) => {\n234:  *     store.append(record);\n235:  *   });\n236:  *\n237:  *   // Or wire into ProcessMonitor callbacks\n238:  *   const monitor = new ProcessMonitor(projectRoot, {\n239:  *     onUsage: (_featureId, record) => store.append(record),\n240:  *   });\n241:  *\n242:  *   // Query historical data\n243:  *   const allRecords = store.load();\n244:  *   const totals = store.totalUsage();\n245:  *   const byModel = store.groupBy(\"model\");\n246:  *   const lastWeek = store.filterByDateRange(weekAgo, now);\n247:  */\n248: export class UsageStore {\n249:   private projectRoot: string;\n250: \n251:   constructor(projectRoot: string) {\n252:     this.projectRoot = projectRoot;\n253:   }\n254: \n255:   /**\n256:    * Append a single UsageRecord to the JSONL file.\n257:    * This is the primary write method — designed to be called from\n258:    * TokenCollector's onUsage callback.\n259:    */\n260:   append(record: UsageRecord): void {\n261:     appendUsageRecord(this.projectRoot, record);\n262:   }\n263: \n264:   /**\n265:    * Load all usage records from the JSONL file.\n266:    */\n267:   load(): UsageRecord[] {\n268:     return loadUsageRecords(this.projectRoot);\n269:   }\n270: \n271:   /**\n272:    * Compute total usage across all persisted records.\n273:    */\n274:   totalUsage(): UsageTotals {\n275:     return totalUsage(this.load());\n276:   }\n277: \n278:   /**\n279:    * Filter persisted records by date range and return totals.\n280:    */\n281:   filterByDateRange(\n282:     since?: string | Date,\n283:     until?: string | Date\n284:   ): UsageRecord[] {\n285:     return filterByDateRange(this.load(), since, until);\n286:   }\n287: \n288:   /**\n289:    * Group persisted records by a field and compute per-group totals.\n290:    */\n291:   groupBy(field: GroupableField): Map<string, UsageTotals> {\n292:     return groupBy(this.load(), field);\n293:   }\n294: }\n\n(End of file - total 294 lines)\n</content>","title":"src/lib/token-usage.ts","metadata":{"preview":"/**\n * token-usage.ts — Persist and aggregate token usage data.\n *\n * Responsibilities:\n *   - Append UsageRecords to .wombo-combo/usage.jsonl (one JSON object per line)\n *   - Load all records from the JSONL file\n *   - Aggregate: groupBy(field), filterByDateRange(since, until), totalUsage()\n *   - Create a UsageStore that wires into TokenCollector's onUsage callback\n *\n * The JSONL format is append-only and human-readable. Each line is a complete\n * JSON object representing one UsageRecord (one step_finish event). This makes\n * it safe for concurrent writes (append is atomic on most filesystems for\n * small writes) and easy to process with standard unix tools (grep, jq, etc.).\n */\n\nimport { existsSync, mkdirSync, readFileSync, appendFileSync } from \"node:fs\";\nimport { resolve, dirname } from \"node:path\";\nimport { WOMBO_DIR } from \"../config.js\";\nimport type { UsageRecord } from \"./token-collector.js\";\n","truncated":false,"loaded":[]},"time":{"start":1773483375136,"end":1773483375139}}}}
{"type":"tool_use","timestamp":1773483375247,"sessionID":"ses_3142777b4ffe3IuXz7qBZaextx","part":{"id":"prt_cebd8ba21001dgx7VLy6V6T1DY","sessionID":"ses_3142777b4ffe3IuXz7qBZaextx","messageID":"msg_cebd8aa0c001nz9ge0Rol13lRP","type":"tool","callID":"toolu_vrtx_01Ts2tGocpbBpyW5KSA7EWZC","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/token-tui/src/lib/token-collector.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/token-tui/src/lib/token-collector.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * token-collector.ts — Parse and collect token usage data from agent events.\n3:  *\n4:  * Responsibilities:\n5:  *   - Define the UsageRecord type for structured token usage data\n6:  *   - Parse step_finish events to extract per-step token counts\n7:  *   - Accumulate usage records per agent (task_id)\n8:  *   - Emit parsed records via callback (storage is handled elsewhere)\n9:  *\n10:  * OpenCode emits step_finish events with this token structure:\n11:  *   {\n12:  *     type: \"step_finish\",\n13:  *     part: {\n14:  *       reason: \"tool-calls\" | \"stop\",\n15:  *       cost: number,\n16:  *       tokens: {\n17:  *         total: number,\n18:  *         input: number,\n19:  *         output: number,\n20:  *         reasoning: number,\n21:  *         cache: { read: number, write: number }\n22:  *       }\n23:  *     }\n24:  *   }\n25:  */\n26: \n27: import type { OpenCodeEvent } from \"./monitor.js\";\n28: \n29: // ---------------------------------------------------------------------------\n30: // Types\n31: // ---------------------------------------------------------------------------\n32: \n33: /**\n34:  * A single token usage record extracted from an agent's step_finish event.\n35:  *\n36:  * Each record represents one step's token consumption. Multiple records\n37:  * are emitted per agent session (one per step_finish event).\n38:  */\n39: export interface UsageRecord {\n40:   /** The task/feature ID this usage belongs to */\n41:   task_id: string;\n42:   /** Optional quest ID if the agent is working within a quest */\n43:   quest_id: string | null;\n44:   /** Model identifier (e.g. \"claude-sonnet-4-20250514\") — from launch context */\n45:   model: string | null;\n46:   /** Provider name (e.g. \"anthropic\", \"openai\") — from launch context */\n47:   provider: string | null;\n48:   /** Agent harness name (e.g. \"opencode\") — from launch context */\n49:   harness: string | null;\n50:   /** Input tokens consumed in this step */\n51:   input_tokens: number;\n52:   /** Output tokens generated in this step */\n53:   output_tokens: number;\n54:   /** Tokens read from cache in this step */\n55:   cache_read: number;\n56:   /** Tokens written to cache in this step */\n57:   cache_write: number;\n58:   /** Reasoning tokens used in this step (e.g. for o1-style models) */\n59:   reasoning_tokens: number;\n60:   /** Total tokens for this step (input + output + reasoning) */\n61:   total_tokens: number;\n62:   /** Cost reported by the agent harness (may be 0 if not available) */\n63:   cost: number;\n64:   /** Whether this was the final step (reason === \"stop\") */\n65:   is_final_step: boolean;\n66:   /** ISO 8601 timestamp when this usage was recorded */\n67:   timestamp: string;\n68: }\n69: \n70: /**\n71:  * Aggregated usage summary for a single agent session.\n72:  */\n73: export interface UsageSummary {\n74:   /** The task/feature ID */\n75:   task_id: string;\n76:   /** Total input tokens across all steps */\n77:   total_input: number;\n78:   /** Total output tokens across all steps */\n79:   total_output: number;\n80:   /** Total cache read tokens across all steps */\n81:   total_cache_read: number;\n82:   /** Total cache write tokens across all steps */\n83:   total_cache_write: number;\n84:   /** Total reasoning tokens across all steps */\n85:   total_reasoning: number;\n86:   /** Grand total tokens across all steps */\n87:   total_tokens: number;\n88:   /** Total cost across all steps */\n89:   total_cost: number;\n90:   /** Number of steps recorded */\n91:   step_count: number;\n92: }\n93: \n94: // ---------------------------------------------------------------------------\n95: // Parsing\n96: // ---------------------------------------------------------------------------\n97: \n98: /**\n99:  * Check if an OpenCode event is a step_finish with token data.\n100:  */\n101: export function isTokenEvent(event: OpenCodeEvent): boolean {\n102:   return (\n103:     event.type === \"step_finish\" &&\n104:     event.part?.tokens != null &&\n105:     typeof event.part.tokens.input === \"number\"\n106:   );\n107: }\n108: \n109: /**\n110:  * Extract a UsageRecord from a step_finish event.\n111:  *\n112:  * Returns null if the event doesn't contain valid token data.\n113:  *\n114:  * @param event     The OpenCode JSON event (must be type \"step_finish\")\n115:  * @param taskId    The task/feature ID this agent is working on\n116:  * @param context   Optional context from the launch environment\n117:  */\n118: export function parseUsageFromEvent(\n119:   event: OpenCodeEvent,\n120:   taskId: string,\n121:   context?: {\n122:     quest_id?: string | null;\n123:     model?: string | null;\n124:     provider?: string | null;\n125:     harness?: string | null;\n126:   }\n127: ): UsageRecord | null {\n128:   if (!isTokenEvent(event)) return null;\n129: \n130:   const tokens = event.part!.tokens!;\n131:   const cache = tokens.cache ?? { read: 0, write: 0 };\n132: \n133:   return {\n134:     task_id: taskId,\n135:     quest_id: context?.quest_id ?? null,\n136:     model: context?.model ?? null,\n137:     provider: context?.provider ?? null,\n138:     harness: context?.harness ?? \"opencode\",\n139:     input_tokens: tokens.input,\n140:     output_tokens: tokens.output,\n141:     cache_read: cache.read,\n142:     cache_write: cache.write,\n143:     reasoning_tokens: tokens.reasoning ?? 0,\n144:     total_tokens: tokens.total,\n145:     cost: event.part?.cost ?? 0,\n146:     is_final_step: event.part?.reason === \"stop\",\n147:     timestamp: new Date(event.timestamp ?? Date.now()).toISOString(),\n148:   };\n149: }\n150: \n151: // ---------------------------------------------------------------------------\n152: // Collector\n153: // ---------------------------------------------------------------------------\n154: \n155: /** Callback invoked when a new usage record is parsed */\n156: export type UsageCallback = (record: UsageRecord) => void;\n157: \n158: /**\n159:  * TokenCollector accumulates usage records for multiple agents.\n160:  *\n161:  * Usage:\n162:  *   const collector = new TokenCollector((record) => {\n163:  *     console.log(\"Usage:\", record);\n164:  *   });\n165:  *\n166:  *   // Register context for an agent before it starts\n167:  *   collector.registerAgent(\"my-feature\", {\n168:  *     quest_id: \"quest-1\",\n169:  *     model: \"claude-sonnet-4-20250514\",\n170:  *   });\n171:  *\n172:  *   // Feed events as they arrive\n173:  *   collector.ingestEvent(\"my-feature\", event);\n174:  *\n175:  *   // Get aggregated summary\n176:  *   const summary = collector.getSummary(\"my-feature\");\n177:  */\n178: export class TokenCollector {\n179:   /** Per-agent usage records */\n180:   private records: Map<string, UsageRecord[]> = new Map();\n181: \n182:   /** Per-agent context (model, provider, quest, etc.) */\n183:   private contexts: Map<\n184:     string,\n185:     {\n186:       quest_id?: string | null;\n187:       model?: string | null;\n188:       provider?: string | null;\n189:       harness?: string | null;\n190:     }\n191:   > = new Map();\n192: \n193:   /** Callback invoked for each new usage record */\n194:   private onUsage: UsageCallback | null;\n195: \n196:   constructor(onUsage?: UsageCallback) {\n197:     this.onUsage = onUsage ?? null;\n198:   }\n199: \n200:   /**\n201:    * Register context for an agent before events start flowing.\n202:    * This context (model, provider, quest_id) is attached to every\n203:    * UsageRecord emitted for this agent.\n204:    */\n205:   registerAgent(\n206:     taskId: string,\n207:     context?: {\n208:       quest_id?: string | null;\n209:       model?: string | null;\n210:       provider?: string | null;\n211:       harness?: string | null;\n212:     }\n213:   ): void {\n214:     this.contexts.set(taskId, context ?? {});\n215:     if (!this.records.has(taskId)) {\n216:       this.records.set(taskId, []);\n217:     }\n218:   }\n219: \n220:   /**\n221:    * Feed an OpenCode event for a specific agent.\n222:    * If the event is a step_finish with token data, a UsageRecord\n223:    * is created and the onUsage callback is invoked.\n224:    *\n225:    * @returns The parsed UsageRecord, or null if the event had no token data\n226:    */\n227:   ingestEvent(taskId: string, event: OpenCodeEvent): UsageRecord | null {\n228:     if (!isTokenEvent(event)) return null;\n229: \n230:     const context = this.contexts.get(taskId);\n231:     const record = parseUsageFromEvent(event, taskId, context);\n232:     if (!record) return null;\n233: \n234:     if (!this.records.has(taskId)) {\n235:       this.records.set(taskId, []);\n236:     }\n237:     this.records.get(taskId)!.push(record);\n238: \n239:     this.onUsage?.(record);\n240: \n241:     return record;\n242:   }\n243: \n244:   /**\n245:    * Get all usage records for an agent.\n246:    */\n247:   getRecords(taskId: string): UsageRecord[] {\n248:     return this.records.get(taskId) ?? [];\n249:   }\n250: \n251:   /**\n252:    * Get all usage records across all agents.\n253:    */\n254:   getAllRecords(): UsageRecord[] {\n255:     const all: UsageRecord[] = [];\n256:     for (const records of this.records.values()) {\n257:       all.push(...records);\n258:     }\n259:     return all;\n260:   }\n261: \n262:   /**\n263:    * Get an aggregated usage summary for an agent.\n264:    * Returns null if no records exist for the agent.\n265:    */\n266:   getSummary(taskId: string): UsageSummary | null {\n267:     const records = this.records.get(taskId);\n268:     if (!records || records.length === 0) return null;\n269: \n270:     return {\n271:       task_id: taskId,\n272:       total_input: records.reduce((sum, r) => sum + r.input_tokens, 0),\n273:       total_output: records.reduce((sum, r) => sum + r.output_tokens, 0),\n274:       total_cache_read: records.reduce((sum, r) => sum + r.cache_read, 0),\n275:       total_cache_write: records.reduce((sum, r) => sum + r.cache_write, 0),\n276:       total_reasoning: records.reduce((sum, r) => sum + r.reasoning_tokens, 0),\n277:       total_tokens: records.reduce((sum, r) => sum + r.total_tokens, 0),\n278:       total_cost: records.reduce((sum, r) => sum + r.cost, 0),\n279:       step_count: records.length,\n280:     };\n281:   }\n282: \n283:   /**\n284:    * Get aggregated summaries for all tracked agents.\n285:    */\n286:   getAllSummaries(): UsageSummary[] {\n287:     const summaries: UsageSummary[] = [];\n288:     for (const taskId of this.records.keys()) {\n289:       const summary = this.getSummary(taskId);\n290:       if (summary) summaries.push(summary);\n291:     }\n292:     return summaries;\n293:   }\n294: \n295:   /**\n296:    * Remove all records for an agent (e.g. after archiving).\n297:    */\n298:   clear(taskId: string): void {\n299:     this.records.delete(taskId);\n300:     this.contexts.delete(taskId);\n301:   }\n302: \n303:   /**\n304:    * Remove all records for all agents.\n305:    */\n306:   clearAll(): void {\n307:     this.records.clear();\n308:     this.contexts.clear();\n309:   }\n310: }\n\n(End of file - total 310 lines)\n</content>","title":"src/lib/token-collector.ts","metadata":{"preview":"/**\n * token-collector.ts — Parse and collect token usage data from agent events.\n *\n * Responsibilities:\n *   - Define the UsageRecord type for structured token usage data\n *   - Parse step_finish events to extract per-step token counts\n *   - Accumulate usage records per agent (task_id)\n *   - Emit parsed records via callback (storage is handled elsewhere)\n *\n * OpenCode emits step_finish events with this token structure:\n *   {\n *     type: \"step_finish\",\n *     part: {\n *       reason: \"tool-calls\" | \"stop\",\n *       cost: number,\n *       tokens: {\n *         total: number,\n *         input: number,\n *         output: number,\n *         reasoning: number,","truncated":false,"loaded":[]},"time":{"start":1773483375244,"end":1773483375246}}}}
{"type":"tool_use","timestamp":1773483375943,"sessionID":"ses_3142777b4ffe3IuXz7qBZaextx","part":{"id":"prt_cebd8ba8d0013jeuGF50UFGBUW","sessionID":"ses_3142777b4ffe3IuXz7qBZaextx","messageID":"msg_cebd8aa0c001nz9ge0Rol13lRP","type":"tool","callID":"toolu_vrtx_01EeKRhJFUvGFwaxGMXdBXkg","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/token-tui/src/lib/tui-browser.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/token-tui/src/lib/tui-browser.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tui-browser.ts — Task browser view for the wombo-combo TUI.\n3:  *\n4:  * Shows all tasks organized by dependency streams with checkboxes for\n5:  * selection. Users can evaluate tasks, order them, select/deselect\n6:  * entire streams, and launch a wave with the selected tasks.\n7:  *\n8:  * Layout:\n9:  *   ┌───────────────────────────────────────────────────────┐\n10:  *   │ WOMBO-COMBO Task Browser  │ 42 tasks │ 5 selected    │\n11:  *   ├──────────────────────────────┬────────────────────────┤\n12:  *   │ ☑ json-features-check  done │ Title: ...             │\n13:  *   │ ☑ json-features-arch   done │ Status: backlog        │\n14:  *   │   ☐ json-ops-commands  back │ Priority: high         │\n15:  *   │ ── stream 2 ──              │ Effort: PT6H           │\n16:  *   │ ☐ tdd-test-detection   done │ Depends on:            │\n17:  *   │ ...                         │   - json-ops-commands  │\n18:  *   ├──────────────────────────────┴────────────────────────┤\n19:  *   │ Space:toggle  S:stream  L:launch  O:sort  Q:quit    │\n20:  *   └───────────────────────────────────────────────────────┘\n21:  *\n22:  * Keybinds:\n23:  *   Space     — toggle selection of current task\n24:  *   S         — toggle entire stream (select/deselect all tasks in the group)\n25:  *   A         — select all / deselect all (toggle)\n26:  *   L         — launch selected tasks as a new wave\n27:  *   Tab       — cycle sort field / switch to wave monitor (if wave running)\n28:  *   O         — cycle sort field (priority → status → name → effort → stream)\n29:  *   +/-       — change priority of selected task\n30:  *   Enter     — expand/collapse task detail inline\n31:  *   D         — toggle show done tasks (filter)\n32:  *   C         — cycle concurrency level\n33:  *   Q / C-c   — quit (saves session)\n34:  */\n35: \n36: import blessed from \"neo-blessed\";\n37: import type { Widgets } from \"neo-blessed\";\n38: import type { Task, TasksFile, Priority } from \"./tasks.js\";\n39: import { loadTasks, loadArchive, parseDurationMinutes, formatDuration, areDependenciesMet, getDoneTaskIds } from \"./tasks.js\";\n40: import { saveTaskToStore, saveTaskToArchive, removeTaskFromStore } from \"./task-store.js\";\n41: import { PRIORITY_ORDER, DIFFICULTY_ORDER } from \"./task-schema.js\";\n42: import type { TUISession, SortField } from \"./tui-session.js\";\n43: import { saveTUISession } from \"./tui-session.js\";\n44: import type { WomboConfig } from \"../config.js\";\n45: import { WishlistOverlay } from \"./tui-wishlist.js\";\n46: \n47: // ---------------------------------------------------------------------------\n48: // Types\n49: // ---------------------------------------------------------------------------\n50: \n51: export interface TaskBrowserOptions {\n52:   projectRoot: string;\n53:   config: WomboConfig;\n54:   session: TUISession;\n55:   /** Called when user presses L to launch selected tasks */\n56:   onLaunch: (selectedIds: string[]) => void;\n57:   /** Called when user presses q to quit */\n58:   onQuit: () => void;\n59:   /** Called when user presses Escape to go back to quest picker */\n60:   onBack?: () => void;\n61:   /** Called when user presses Tab to switch to wave monitor (if a wave is running) */\n62:   onSwitchToMonitor?: () => void;\n63:   /** Called when user presses E to create an errand (quest-less assisted task) */\n64:   onErrand?: () => void;\n65:   /** If set, filter to only tasks belonging to this quest */\n66:   questId?: string | null;\n67:   /** Human-readable quest title for header display */\n68:   questTitle?: string;\n69:   /** Task IDs belonging to the selected quest (used for filtering) */\n70:   questTaskIds?: string[];\n71: }\n72: \n73: /**\n74:  * A task node in the display tree with computed metadata.\n75:  */\n76: interface TaskNode {\n77:   task: Task;\n78:   /** Depth in the dependency chain (0 = leaf/no deps, higher = depends on more) */\n79:   depth: number;\n80:   /** ID of the stream (connected component) this task belongs to */\n81:   streamId: string;\n82:   /** Task IDs that depend on this task */\n83:   dependedOnBy: string[];\n84: }\n85: \n86: /**\n87:  * A stream is a group of related tasks connected by dependencies.\n88:  */\n89: interface Stream {\n90:   id: string;\n91:   nodes: TaskNode[];\n92: }\n93: \n94: // ---------------------------------------------------------------------------\n95: // Status / Priority display helpers\n96: // ---------------------------------------------------------------------------\n97: \n98: const STATUS_ABBREV: Record<string, string> = {\n99:   backlog: \"BACK\",\n100:   planned: \"PLAN\",\n101:   in_progress: \"PROG\",\n102:   blocked: \"BLKD\",\n103:   in_review: \"REVW\",\n104:   done: \"DONE\",\n105:   cancelled: \"CANC\",\n106: };\n107: \n108: const STATUS_COLORS: Record<string, string> = {\n109:   backlog: \"gray\",\n110:   planned: \"blue\",\n111:   in_progress: \"cyan\",\n112:   blocked: \"red\",\n113:   in_review: \"yellow\",\n114:   done: \"green\",\n115:   cancelled: \"gray\",\n116: };\n117: \n118: const PRIORITY_ABBREV: Record<string, string> = {\n119:   critical: \"CRIT\",\n120:   high: \"HIGH\",\n121:   medium: \"MED \",\n122:   low: \"LOW \",\n123:   wishlist: \"WISH\",\n124: };\n125: \n126: const PRIORITY_COLORS: Record<string, string> = {\n127:   critical: \"red\",\n128:   high: \"yellow\",\n129:   medium: \"white\",\n130:   low: \"gray\",\n131:   wishlist: \"gray\",\n132: };\n133: \n134: // ---------------------------------------------------------------------------\n135: // Helpers\n136: // ---------------------------------------------------------------------------\n137: \n138: function escapeBlessedTags(text: string): string {\n139:   return text.replace(/\\{/g, \"\\uFF5B\").replace(/\\}/g, \"\\uFF5D\");\n140: }\n141: \n142: const SORT_FIELDS: SortField[] = [\"priority\", \"status\", \"name\", \"effort\", \"stream\"];\n143: \n144: // ---------------------------------------------------------------------------\n145: // Task Graph Builder\n146: // ---------------------------------------------------------------------------\n147: \n148: /**\n149:  * Build a dependency graph from all tasks and organize them into streams\n150:  * (connected components). Within each stream, tasks are topologically sorted.\n151:  */\n152: function buildTaskGraph(tasks: Task[]): Stream[] {\n153:   const taskMap = new Map<string, Task>();\n154:   for (const t of tasks) taskMap.set(t.id, t);\n155: \n156:   // Build reverse dependency map (who depends on me?)\n157:   const dependedOnBy = new Map<string, string[]>();\n158:   for (const t of tasks) {\n159:     for (const dep of t.depends_on) {\n160:       if (!dependedOnBy.has(dep)) dependedOnBy.set(dep, []);\n161:       dependedOnBy.get(dep)!.push(t.id);\n162:     }\n163:   }\n164: \n165:   // Find connected components using undirected graph traversal\n166:   const visited = new Set<string>();\n167:   const components: string[][] = [];\n168: \n169:   function dfs(id: string, component: string[]): void {\n170:     if (visited.has(id)) return;\n171:     if (!taskMap.has(id)) return; // dep references a task not in our list\n172:     visited.add(id);\n173:     component.push(id);\n174:     // Follow forward deps\n175:     const task = taskMap.get(id)!;\n176:     for (const dep of task.depends_on) dfs(dep, component);\n177:     // Follow reverse deps\n178:     for (const rev of (dependedOnBy.get(id) ?? [])) dfs(rev, component);\n179:   }\n180: \n181:   for (const t of tasks) {\n182:     if (!visited.has(t.id)) {\n183:       const comp: string[] = [];\n184:       dfs(t.id, comp);\n185:       components.push(comp);\n186:     }\n187:   }\n188: \n189:   // For each component, compute depths and sort topologically\n190:   const streams: Stream[] = [];\n191:   for (const comp of components) {\n192:     // Compute depth: longest path from any leaf (task with no deps in this component)\n193:     const depthMap = new Map<string, number>();\n194:     const compSet = new Set(comp);\n195: \n196:     function computeDepth(id: string, visiting: Set<string>): number {\n197:       if (depthMap.has(id)) return depthMap.get(id)!;\n198:       if (visiting.has(id)) return 0; // cycle protection\n199:       visiting.add(id);\n200:       const task = taskMap.get(id);\n201:       if (!task) return 0;\n202:       let maxDepth = 0;\n203:       for (const dep of task.depends_on) {\n204:         if (compSet.has(dep)) {\n205:           maxDepth = Math.max(maxDepth, 1 + computeDepth(dep, visiting));\n206:         }\n207:       }\n208:       visiting.delete(id);\n209:       depthMap.set(id, maxDepth);\n210:       return maxDepth;\n211:     }\n212: \n213:     for (const id of comp) computeDepth(id, new Set());\n214: \n215:     // Sort: by depth ascending (leaves first), then by priority\n216:     const sorted = [...comp].sort((a, b) => {\n217:       const dA = depthMap.get(a) ?? 0;\n218:       const dB = depthMap.get(b) ?? 0;\n219:       if (dA !== dB) return dA - dB;\n220:       const tA = taskMap.get(a)!;\n221:       const tB = taskMap.get(b)!;\n222:       return PRIORITY_ORDER[tA.priority] - PRIORITY_ORDER[tB.priority];\n223:     });\n224: \n225:     // Use the deepest task's ID as the stream ID (it's the \"root\" task)\n226:     const maxDepthId = sorted[sorted.length - 1];\n227:     const streamId = maxDepthId;\n228: \n229:     const nodes: TaskNode[] = sorted.map((id) => ({\n230:       task: taskMap.get(id)!,\n231:       depth: depthMap.get(id) ?? 0,\n232:       streamId,\n233:       dependedOnBy: (dependedOnBy.get(id) ?? []).filter((d) => compSet.has(d)),\n234:     }));\n235: \n236:     streams.push({ id: streamId, nodes });\n237:   }\n238: \n239:   // Sort streams by highest-priority task in each\n240:   streams.sort((a, b) => {\n241:     const bestA = Math.min(...a.nodes.map((n) => PRIORITY_ORDER[n.task.priority]));\n242:     const bestB = Math.min(...b.nodes.map((n) => PRIORITY_ORDER[n.task.priority]));\n243:     return bestA - bestB;\n244:   });\n245: \n246:   return streams;\n247: }\n248: \n249: // ---------------------------------------------------------------------------\n250: // Task Browser Class\n251: // ---------------------------------------------------------------------------\n252: \n253: export class TaskBrowser {\n254:   private screen: Widgets.Screen;\n255:   private headerBox: Widgets.BoxElement;\n256:   private taskList: Widgets.ListElement;\n257:   private detailBox: Widgets.BoxElement;\n258:   private statusBar: Widgets.BoxElement;\n259: \n260:   private projectRoot: string;\n261:   private config: WomboConfig;\n262:   private session: TUISession;\n263:   private onLaunch: (selectedIds: string[]) => void;\n264:   private onQuit: () => void;\n265:   private onBack?: () => void;\n266:   private onSwitchToMonitor?: () => void;\n267:   private onErrand?: () => void;\n268: \n269:   /** Quest filtering */\n270:   private questId: string | null = null;\n271:   private questTitle: string | null = null;\n272:   private questTaskIds: Set<string> | null = null;\n273: \n274:   private allTasks: Task[] = [];\n275:   private archiveTasks: Task[] = [];\n276:   private doneIds: Set<string> = new Set();\n277:   private streams: Stream[] = [];\n278:   /** Flat ordered list of task nodes as displayed */\n279:   private displayNodes: TaskNode[] = [];\n280:   private selectedIndex: number = 0;\n281:   private selected: Set<string>;\n282:   private collapsed: Set<string>;\n283:   private hideDone: boolean = false;\n284:   private refreshTimer: ReturnType<typeof setInterval> | null = null;\n285:   private hasRunningWave: boolean = false;\n286:   /** Active wishlist overlay (null when closed) */\n287:   private wishlistOverlay: WishlistOverlay | null = null;\n288: \n289:   constructor(opts: TaskBrowserOptions) {\n290:     this.projectRoot = opts.projectRoot;\n291:     this.config = opts.config;\n292:     this.session = opts.session;\n293:     this.onLaunch = opts.onLaunch;\n294:     this.onQuit = opts.onQuit;\n295:     this.onBack = opts.onBack;\n296:     this.onSwitchToMonitor = opts.onSwitchToMonitor;\n297:     this.onErrand = opts.onErrand;\n298:     this.selected = new Set(opts.session.selected);\n299:     this.collapsed = new Set(opts.session.collapsed);\n300: \n301:     // Quest filtering\n302:     this.questId = opts.questId ?? null;\n303:     this.questTitle = opts.questTitle ?? null;\n304:     this.questTaskIds = opts.questTaskIds ? new Set(opts.questTaskIds) : null;\n305: \n306:     // Load tasks\n307:     this.reloadTasks();\n308: \n309:     // Create screen\n310:     this.screen = blessed.screen({\n311:       smartCSR: true,\n312:       title: this.questTitle\n313:         ? `wombo-combo -- ${this.questTitle}`\n314:         : \"wombo-combo -- Task Browser\",\n315:       fullUnicode: true,\n316:     });\n317: \n318:     // Header\n319:     this.headerBox = blessed.box({\n320:       top: 0,\n321:       left: 0,\n322:       width: \"100%\",\n323:       height: 3,\n324:       tags: true,\n325:       style: { fg: \"white\", bg: \"black\" },\n326:     });\n327: \n328:     // Task list (left pane)\n329:     this.taskList = blessed.list({\n330:       top: 3,\n331:       left: 0,\n332:       width: \"60%\",\n333:       height: \"100%-6\",\n334:       tags: true,\n335:       scrollable: true,\n336:       mouse: true,\n337:       keys: true,\n338:       vi: true,\n339:       border: { type: \"line\" },\n340:       style: {\n341:         border: { fg: \"gray\" },\n342:         selected: { bg: \"blue\", fg: \"white\", bold: true },\n343:         item: { fg: \"white\" },\n344:       },\n345:       label: \" Tasks \",\n346:     });\n347: \n348:     // Detail pane (right pane)\n349:     this.detailBox = blessed.box({\n350:       top: 3,\n351:       left: \"60%\",\n352:       width: \"40%\",\n353:       height: \"100%-6\",\n354:       tags: true,\n355:       scrollable: true,\n356:       mouse: true,\n357:       border: { type: \"line\" },\n358:       style: {\n359:         border: { fg: \"gray\" },\n360:         fg: \"white\",\n361:       },\n362:       label: \" Details \",\n363:     });\n364: \n365:     // Status bar\n366:     this.statusBar = blessed.box({\n367:       bottom: 0,\n368:       left: 0,\n369:       width: \"100%\",\n370:       height: 3,\n371:       tags: true,\n372:       style: { fg: \"white\", bg: \"black\" },\n373:     });\n374: \n375:     // Assemble\n376:     this.screen.append(this.headerBox);\n377:     this.screen.append(this.taskList);\n378:     this.screen.append(this.detailBox);\n379:     this.screen.append(this.statusBar);\n380:     this.taskList.focus();\n381: \n382:     this.bindKeys();\n383:   }\n384: \n385:   // -------------------------------------------------------------------------\n386:   // Public API\n387:   // -------------------------------------------------------------------------\n388: \n389:   start(): void {\n390:     this.buildDisplay();\n391:     this.refresh();\n392:     this.screen.render();\n393:   }\n394: \n395:   stop(): void {\n396:     this.saveSession();\n397:     if (this.refreshTimer) {\n398:       clearInterval(this.refreshTimer);\n399:       this.refreshTimer = null;\n400:     }\n401:     this.screen.destroy();\n402:   }\n403: \n404:   /**\n405:    * Destroy the browser screen without saving session (caller already saved).\n406:    * Used by the TUI orchestrator after receiving onLaunch — the transition\n407:    * message is already displayed, so we just tear down the blessed screen\n408:    * and clear the terminal for the next view.\n409:    */\n410:   destroy(): void {\n411:     if (this.refreshTimer) {\n412:       clearInterval(this.refreshTimer);\n413:       this.refreshTimer = null;\n414:     }\n415:     this.screen.destroy();\n416:     // Clear terminal so the next view starts fresh\n417:     process.stdout.write(\"\\x1B[2J\\x1B[H\");\n418:   }\n419: \n420:   /** Let the orchestrator tell us a wave is running (enables Tab to switch) */\n421:   setHasRunningWave(running: boolean): void {\n422:     this.hasRunningWave = running;\n423:     this.refreshStatusBar();\n424:     this.screen.render();\n425:   }\n426: \n427:   // -------------------------------------------------------------------------\n428:   // Task Loading\n429:   // -------------------------------------------------------------------------\n430: \n431:   private reloadTasks(): void {\n432:     const tasksData = loadTasks(this.projectRoot, this.config);\n433:     const archiveData = loadArchive(this.projectRoot, this.config);\n434: \n435:     // Filter tasks by quest if a quest is selected\n436:     if (this.questTaskIds) {\n437:       this.allTasks = tasksData.tasks.filter((t) => this.questTaskIds!.has(t.id));\n438:     } else {\n439:       this.allTasks = tasksData.tasks;\n440:     }\n441: \n442:     this.archiveTasks = archiveData.tasks;\n443:     this.doneIds = getDoneTaskIds(tasksData, this.archiveTasks);\n444:     this.streams = buildTaskGraph(this.allTasks);\n445: \n446:     // Prune selected IDs that no longer exist\n447:     const validIds = new Set(this.allTasks.map((t) => t.id));\n448:     for (const id of this.selected) {\n449:       if (!validIds.has(id)) this.selected.delete(id);\n450:     }\n451:   }\n452: \n453:   // -------------------------------------------------------------------------\n454:   // Display Building\n455:   // -------------------------------------------------------------------------\n456: \n457:   private buildDisplay(): void {\n458:     this.displayNodes = [];\n459:     const sortedStreams = this.sortStreams(this.streams);\n460: \n461:     for (const stream of sortedStreams) {\n462:       const sortedNodes = this.sortNodesInStream(stream.nodes);\n463:       for (const node of sortedNodes) {\n464:         if (this.hideDone && node.task.status === \"done\") continue;\n465:         this.displayNodes.push(node);\n466:       }\n467:     }\n468:   }\n469: \n470:   private sortStreams(streams: Stream[]): Stream[] {\n471:     const field = this.session.sortBy;\n472:     const order = this.session.sortOrder === \"asc\" ? 1 : -1;\n473: \n474:     if (field === \"stream\") return streams; // natural grouping\n475: \n476:     return [...streams].sort((a, b) => {\n477:       const bestA = this.streamSortKey(a, field);\n478:       const bestB = this.streamSortKey(b, field);\n479:       return (bestA - bestB) * order;\n480:     });\n481:   }\n482: \n483:   private streamSortKey(stream: Stream, field: SortField): number {\n484:     switch (field) {\n485:       case \"priority\":\n486:         return Math.min(...stream.nodes.map((n) => PRIORITY_ORDER[n.task.priority]));\n487:       case \"effort\":\n488:         return Math.min(...stream.nodes.map((n) => parseDurationMinutes(n.task.effort)));\n489:       case \"status\": {\n490:         const STATUS_SORT: Record<string, number> = {\n491:           in_progress: 0, backlog: 1, planned: 2, blocked: 3,\n492:           in_review: 4, done: 5, cancelled: 6,\n493:         };\n494:         return Math.min(...stream.nodes.map((n) => STATUS_SORT[n.task.status] ?? 99));\n495:       }\n496:       case \"name\":\n497:         return 0; // alpha sort handled differently\n498:       default:\n499:         return 0;\n500:     }\n501:   }\n502: \n503:   private sortNodesInStream(nodes: TaskNode[]): TaskNode[] {\n504:     // Always sort by depth within a stream (topological order)\n505:     return [...nodes].sort((a, b) => a.depth - b.depth);\n506:   }\n507: \n508:   // -------------------------------------------------------------------------\n509:   // Key Bindings\n510:   // -------------------------------------------------------------------------\n511: \n512:   private bindKeys(): void {\n513:     // Quit (or go back to quest picker if in quest mode)\n514:     this.screen.key([\"q\", \"C-c\"], () => {\n515:       if (this.onBack && this.questId) {\n516:         // In quest-filtered mode: Q goes back to quest picker\n517:         this.saveSession();\n518:         this.destroy();\n519:         this.onBack();\n520:       } else {\n521:         this.stop();\n522:         this.onQuit();\n523:       }\n524:     });\n525: \n526:     // Escape -- go back to quest picker (always, if available)\n527:     this.screen.key([\"escape\"], () => {\n528:       if (this.onBack) {\n529:         this.saveSession();\n530:         this.destroy();\n531:         this.onBack();\n532:       }\n533:     });\n534: \n535:     // Navigate\n536:     this.taskList.on(\"select item\", (_item: any, index: number) => {\n537:       this.selectedIndex = index;\n538:       this.refreshDetail();\n539:       this.screen.render();\n540:     });\n541: \n542:     // Space — toggle selection\n543:     this.screen.key([\"space\"], () => {\n544:       this.toggleCurrent();\n545:     });\n546: \n547:     // s — toggle stream\n548:     this.screen.key([\"s\"], () => {\n549:       this.toggleStream();\n550:     });\n551: \n552:     // a — select all / deselect all\n553:     this.screen.key([\"a\"], () => {\n554:       this.toggleAll();\n555:     });\n556: \n557:     // l — launch selected\n558:     this.screen.key([\"l\"], () => {\n559:       this.launchSelected();\n560:     });\n561: \n562:     // Tab — cycle sort / switch to monitor\n563:     this.screen.key([\"tab\"], () => {\n564:       if (this.hasRunningWave && this.onSwitchToMonitor) {\n565:         this.saveSession();\n566:         this.stop();\n567:         this.onSwitchToMonitor();\n568:       } else {\n569:         this.cycleSort();\n570:       }\n571:     });\n572: \n573:     // O — cycle sort order (laptop-friendly alternative when Tab is used for view switch)\n574:     this.screen.key([\"o\"], () => {\n575:       this.cycleSort();\n576:     });\n577: \n578:     // +/- — change priority\n579:     this.screen.key([\"+\", \"=\"], () => {\n580:       this.changePriority(-1); // higher priority (lower number)\n581:     });\n582:     this.screen.key([\"-\"], () => {\n583:       this.changePriority(1); // lower priority (higher number)\n584:     });\n585: \n586:     // d — toggle hide done\n587:     this.screen.key([\"d\"], () => {\n588:       this.hideDone = !this.hideDone;\n589:       this.buildDisplay();\n590:       this.refreshTaskList();\n591:       this.refreshHeader();\n592:       this.refreshStatusBar();\n593:       this.screen.render();\n594:     });\n595: \n596:     // x — archive done/cancelled tasks\n597:     this.screen.key([\"x\"], () => {\n598:       this.archiveDone();\n599:     });\n600: \n601:     // c — change concurrency\n602:     this.screen.key([\"c\"], () => {\n603:       this.cycleConcurrency();\n604:     });\n605: \n606:     // e — errand (quest-less assisted task generation)\n607:     this.screen.key([\"e\"], () => {\n608:       if (!this.onErrand) return;\n609:       this.saveSession();\n610:       this.destroy();\n611:       this.onErrand();\n612:     });\n613: \n614:     // w — toggle wishlist overlay\n615:     this.screen.key([\"w\"], () => {\n616:       this.toggleWishlist();\n617:     });\n618:   }\n619: \n620:   // -------------------------------------------------------------------------\n621:   // Actions\n622:   // -------------------------------------------------------------------------\n623: \n624:   private toggleCurrent(): void {\n625:     const node = this.displayNodes[this.selectedIndex];\n626:     if (!node) return;\n627:     if (this.selected.has(node.task.id)) {\n628:       this.selected.delete(node.task.id);\n629:     } else {\n630:       this.selected.add(node.task.id);\n631:     }\n632:     this.refreshTaskList();\n633:     this.refreshHeader();\n634:     this.refreshDetail();\n635:     this.refreshStatusBar();\n636:     this.screen.render();\n637:   }\n638: \n639:   private toggleStream(): void {\n640:     const node = this.displayNodes[this.selectedIndex];\n641:     if (!node) return;\n642:     const streamId = node.streamId;\n643:     const streamNodes = this.displayNodes.filter((n) => n.streamId === streamId);\n644: \n645:     // If all in stream are selected, deselect all; otherwise select all\n646:     const allSelected = streamNodes.every((n) => this.selected.has(n.task.id));\n647:     for (const n of streamNodes) {\n648:       if (allSelected) {\n649:         this.selected.delete(n.task.id);\n650:       } else {\n651:         this.selected.add(n.task.id);\n652:       }\n653:     }\n654: \n655:     this.refreshTaskList();\n656:     this.refreshHeader();\n657:     this.refreshDetail();\n658:     this.refreshStatusBar();\n659:     this.screen.render();\n660:   }\n661: \n662:   private toggleAll(): void {\n663:     const allSelected = this.displayNodes.every((n) => this.selected.has(n.task.id));\n664:     for (const n of this.displayNodes) {\n665:       if (allSelected) {\n666:         this.selected.delete(n.task.id);\n667:       } else {\n668:         this.selected.add(n.task.id);\n669:       }\n670:     }\n671:     this.refreshTaskList();\n672:     this.refreshHeader();\n673:     this.refreshStatusBar();\n674:     this.screen.render();\n675:   }\n676: \n677:   private launchSelected(): void {\n678:     if (this.selected.size === 0) return;\n679:     this.saveSession();\n680:     const ids = [...this.selected];\n681: \n682:     // Show a transition message on the existing screen before the caller\n683:     // destroys it — avoids jarring flash of raw console output.\n684:     try {\n685:       this.taskList.setContent(\"\");\n686:       this.detailBox.setContent(\"\");\n687:       this.statusBar.setContent(\"\");\n688:       this.headerBox.setContent(\n689:         ` {bold}{cyan-fg}Launching ${ids.length} task(s)...{/cyan-fg}{/bold}`\n690:       );\n691:       this.screen.render();\n692:     } catch {\n693:       // Screen may already be in a bad state — proceed regardless\n694:     }\n695: \n696:     this.onLaunch(ids);\n697:   }\n698: \n699:   private cycleSort(): void {\n700:     const idx = SORT_FIELDS.indexOf(this.session.sortBy);\n701:     this.session.sortBy = SORT_FIELDS[(idx + 1) % SORT_FIELDS.length];\n702:     this.buildDisplay();\n703:     this.selectedIndex = Math.min(this.selectedIndex, this.displayNodes.length - 1);\n704:     this.refreshTaskList();\n705:     this.refreshHeader();\n706:     this.refreshStatusBar();\n707:     this.screen.render();\n708:   }\n709: \n710:   private changePriority(delta: number): void {\n711:     const node = this.displayNodes[this.selectedIndex];\n712:     if (!node) return;\n713:     const priorities: Priority[] = [\"critical\", \"high\", \"medium\", \"low\", \"wishlist\"];\n714:     const currentIdx = priorities.indexOf(node.task.priority);\n715:     const newIdx = Math.max(0, Math.min(priorities.length - 1, currentIdx + delta));\n716:     if (newIdx === currentIdx) return;\n717: \n718:     node.task.priority = priorities[newIdx];\n719:     // Persist the change\n720:     saveTaskToStore(this.projectRoot, this.config, node.task);\n721:     this.refreshTaskList();\n722:     this.refreshDetail();\n723:     this.screen.render();\n724:   }\n725: \n726:   private cycleConcurrency(): void {\n727:     const levels = [1, 2, 3, 5, 8, 10, 15, 20];\n728:     const idx = levels.indexOf(this.session.maxConcurrent);\n729:     this.session.maxConcurrent = levels[(idx + 1) % levels.length];\n730:     this.refreshStatusBar();\n731:     this.screen.render();\n732:   }\n733: \n734:   /**\n735:    * Archive all done/cancelled tasks. If tasks are selected, only archive\n736:    * those that are done/cancelled. Otherwise archive ALL done/cancelled.\n737:    */\n738:   private archiveDone(): void {\n739:     const candidates =\n740:       this.selected.size > 0\n741:         ? this.allTasks.filter(\n742:             (t) => this.selected.has(t.id) && (t.status === \"done\" || t.status === \"cancelled\")\n743:           )\n744:         : this.allTasks.filter(\n745:             (t) => t.status === \"done\" || t.status === \"cancelled\"\n746:           );\n747: \n748:     if (candidates.length === 0) return;\n749: \n750:     for (const task of candidates) {\n751:       saveTaskToArchive(this.projectRoot, this.config, task);\n752:       removeTaskFromStore(this.projectRoot, this.config, task.id);\n753:       this.selected.delete(task.id);\n754:     }\n755: \n756:     // Reload from disk and rebuild the display\n757:     this.reloadTasks();\n758:     this.buildDisplay();\n759:     this.selectedIndex = Math.min(this.selectedIndex, Math.max(0, this.displayNodes.length - 1));\n760:     this.refresh();\n761:   }\n762: \n763:   private toggleWishlist(): void {\n764:     // Close if already open\n765:     if (this.wishlistOverlay && !this.wishlistOverlay.isDestroyed()) {\n766:       this.wishlistOverlay.close();\n767:       this.wishlistOverlay = null;\n768:       this.taskList.focus();\n769:       this.screen.render();\n770:       return;\n771:     }\n772: \n773:     this.wishlistOverlay = new WishlistOverlay(\n774:       this.screen,\n775:       this.projectRoot,\n776:       {\n777:         onClose: () => {\n778:           this.wishlistOverlay = null;\n779:           this.taskList.focus();\n780:           this.refreshStatusBar();\n781:           this.screen.render();\n782:         },\n783:       }\n784:     );\n785:   }\n786: \n787:   // -------------------------------------------------------------------------\n788:   // Session Persistence\n789:   // -------------------------------------------------------------------------\n790: \n791:   private saveSession(): void {\n792:     this.session.selected = [...this.selected];\n793:     this.session.collapsed = [...this.collapsed];\n794:     saveTUISession(this.projectRoot, this.session);\n795:   }\n796: \n797:   // -------------------------------------------------------------------------\n798:   // Refresh Logic\n799:   // -------------------------------------------------------------------------\n800: \n801:   private refresh(): void {\n802:     this.refreshHeader();\n803:     this.refreshTaskList();\n804:     this.refreshDetail();\n805:     this.refreshStatusBar();\n806:     this.screen.render();\n807:   }\n808: \n809:   private refreshHeader(): void {\n810:     const total = this.allTasks.length;\n811:     const displayed = this.displayNodes.length;\n812:     const selectedCount = this.selected.size;\n813:     const doneCount = this.allTasks.filter((t) => t.status === \"done\").length;\n814:     const readyCount = this.allTasks.filter(\n815:       (t) => t.status === \"backlog\" && areDependenciesMet(t, this.doneIds)\n816:     ).length;\n817: \n818:     let line1 = ` {bold}wombo-combo{/bold}`;\n819:     if (this.questTitle) {\n820:       line1 += ` {magenta-fg}\\u25B6 ${escapeBlessedTags(this.questTitle)}{/magenta-fg}`;\n821:     } else {\n822:       line1 += ` {cyan-fg}Task Browser{/cyan-fg}`;\n823:     }\n824:     line1 += `  {gray-fg}|{/gray-fg}  {white-fg}${total}{/white-fg} tasks`;\n825:     if (this.hideDone) line1 += ` ({white-fg}${displayed}{/white-fg} shown)`;\n826:     line1 += `  {gray-fg}|{/gray-fg}  {green-fg}${selectedCount}{/green-fg} selected`;\n827: \n828:     let line2 = ` {green-fg}${doneCount}{/green-fg} done`;\n829:     line2 += `  {cyan-fg}${readyCount}{/cyan-fg} ready`;\n830:     line2 += `  {gray-fg}|{/gray-fg}  Sort: {yellow-fg}${this.session.sortBy}{/yellow-fg}`;\n831:     line2 += `  {gray-fg}|{/gray-fg}  Concurrency: {yellow-fg}${this.session.maxConcurrent}{/yellow-fg}`;\n832: \n833:     this.headerBox.setContent(`${line1}\\n${line2}`);\n834:   }\n835: \n836:   private refreshTaskList(): void {\n837:     const items: string[] = [];\n838:     let lastStreamId = \"\";\n839: \n840:     for (let i = 0; i < this.displayNodes.length; i++) {\n841:       const node = this.displayNodes[i];\n842:       const t = node.task;\n843: \n844:       // Stream separator\n845:       if (node.streamId !== lastStreamId && lastStreamId !== \"\") {\n846:         // We use a visual separator row — but it's not selectable in blessed list,\n847:         // so we just change the color/style\n848:       }\n849:       lastStreamId = node.streamId;\n850: \n851:       // Checkbox\n852:       const isSelected = this.selected.has(t.id);\n853:       const checkbox = isSelected\n854:         ? \"{green-fg}\\u2611{/green-fg}\" // ☑\n855:         : \"{gray-fg}\\u2610{/gray-fg}\";  // ☐\n856: \n857:       // Indent based on depth\n858:       const indent = \"  \".repeat(node.depth);\n859: \n860:       // Dependency readiness indicator\n861:       const depsReady = areDependenciesMet(t, this.doneIds);\n862:       const readyIcon = t.status === \"done\"\n863:         ? \"{green-fg}\\u2713{/green-fg}\"   // ✓\n864:         : depsReady\n865:           ? \"{cyan-fg}\\u25CF{/cyan-fg}\"   // ● ready\n866:           : \"{red-fg}\\u25CB{/red-fg}\";     // ○ blocked\n867: \n868:       // Task ID (truncated)\n869:       const maxIdLen = 26 - node.depth * 2;\n870:       const fid = t.id.length > maxIdLen\n871:         ? t.id.slice(0, maxIdLen - 1) + \"\\u2026\"\n872:         : t.id.padEnd(maxIdLen);\n873: \n874:       // Priority\n875:       const pColor = PRIORITY_COLORS[t.priority] ?? \"white\";\n876:       const pAbbr = PRIORITY_ABBREV[t.priority] ?? t.priority.slice(0, 4).toUpperCase();\n877:       const priority = `{${pColor}-fg}${pAbbr}{/${pColor}-fg}`;\n878: \n879:       // Status\n880:       const sColor = STATUS_COLORS[t.status] ?? \"white\";\n881:       const sAbbr = STATUS_ABBREV[t.status] ?? t.status.slice(0, 4).toUpperCase();\n882:       const status = `{${sColor}-fg}${sAbbr}{/${sColor}-fg}`;\n883: \n884:       // Effort\n885:       const effort = formatDuration(parseDurationMinutes(t.effort));\n886: \n887:       items.push(\n888:         ` ${checkbox} ${indent}${readyIcon} ${fid} ${priority} ${status} {gray-fg}${effort}{/gray-fg}`\n889:       );\n890:     }\n891: \n892:     if (items.length === 0) {\n893:       items.push(\" {gray-fg}No tasks found{/gray-fg}\");\n894:     }\n895: \n896:     const prevSelected = this.selectedIndex;\n897:     this.taskList.setItems(items as any);\n898:     if (prevSelected < items.length) {\n899:       this.taskList.select(prevSelected);\n900:     }\n901:   }\n902: \n903:   private refreshDetail(): void {\n904:     const node = this.displayNodes[this.selectedIndex];\n905:     if (!node) {\n906:       this.detailBox.setContent(\"{gray-fg}No task selected{/gray-fg}\");\n907:       return;\n908:     }\n909: \n910:     const t = node.task;\n911:     const lines: string[] = [];\n912: \n913:     // Title\n914:     lines.push(`{bold}{white-fg}${escapeBlessedTags(t.title)}{/white-fg}{/bold}`);\n915:     lines.push(\"\");\n916: \n917:     // Status & Priority\n918:     const sColor = STATUS_COLORS[t.status] ?? \"white\";\n919:     lines.push(`  Status:     {${sColor}-fg}${t.status}{/${sColor}-fg}`);\n920:     const pColor = PRIORITY_COLORS[t.priority] ?? \"white\";\n921:     lines.push(`  Priority:   {${pColor}-fg}${t.priority}{/${pColor}-fg}  {gray-fg}(+/- to change){/gray-fg}`);\n922:     lines.push(`  Difficulty:  ${t.difficulty}`);\n923:     lines.push(`  Effort:      ${formatDuration(parseDurationMinutes(t.effort))}`);\n924:     lines.push(`  Completion:  ${t.completion}%`);\n925: \n926:     // Selection state\n927:     const isSelected = this.selected.has(t.id);\n928:     lines.push(`  Selected:   ${isSelected ? \"{green-fg}yes{/green-fg}\" : \"{gray-fg}no{/gray-fg}\"}`);\n929: \n930:     // Dependency readiness\n931:     const depsReady = areDependenciesMet(t, this.doneIds);\n932:     lines.push(`  Deps ready: ${depsReady ? \"{green-fg}yes{/green-fg}\" : \"{red-fg}no{/red-fg}\"}`);\n933: \n934:     // Stream info\n935:     lines.push(`  Stream:      ${node.streamId}`);\n936:     lines.push(`  Depth:       ${node.depth}`);\n937:     lines.push(\"\");\n938: \n939:     // Dependencies\n940:     if (t.depends_on.length > 0) {\n941:       lines.push(\"{bold}Dependencies:{/bold}\");\n942:       for (const dep of t.depends_on) {\n943:         const isDone = this.doneIds.has(dep);\n944:         const icon = isDone ? \"{green-fg}\\u2713{/green-fg}\" : \"{red-fg}\\u2717{/red-fg}\";\n945:         lines.push(`  ${icon} ${dep}`);\n946:       }\n947:       lines.push(\"\");\n948:     }\n949: \n950:     // Depended on by\n951:     if (node.dependedOnBy.length > 0) {\n952:       lines.push(\"{bold}Depended on by:{/bold}\");\n953:       for (const id of node.dependedOnBy) {\n954:         lines.push(`  \\u2192 ${id}`);\n955:       }\n956:       lines.push(\"\");\n957:     }\n958: \n959:     // Description\n960:     if (t.description) {\n961:       lines.push(\"{bold}Description:{/bold}\");\n962:       const desc = escapeBlessedTags(t.description.trim());\n963:       // Word-wrap to roughly 38 chars\n964:       const words = desc.split(/\\s+/);\n965:       let line = \" \";\n966:       for (const w of words) {\n967:         if (line.length + w.length > 36) {\n968:           lines.push(line);\n969:           line = \" \" + w;\n970:         } else {\n971:           line += \" \" + w;\n972:         }\n973:       }\n974:       if (line.trim()) lines.push(line);\n975:       lines.push(\"\");\n976:     }\n977: \n978:     // Agent type\n979:     if (t.agent_type) {\n980:       lines.push(`{bold}Agent:{/bold} ${escapeBlessedTags(t.agent_type)}`);\n981:     }\n982: \n983:     // Constraints\n984:     if (t.constraints.length > 0) {\n985:       lines.push(\"{bold}Constraints:{/bold}\");\n986:       for (const c of t.constraints) {\n987:         lines.push(`  \\u2022 ${escapeBlessedTags(c)}`);\n988:       }\n989:     }\n990: \n991:     this.detailBox.setContent(lines.join(\"\\n\"));\n992:     this.detailBox.setLabel(` ${t.id} `);\n993:   }\n994: \n995:   private refreshStatusBar(): void {\n996:     const selCount = this.selected.size;\n997:     const readyInSelection = [...this.selected].filter((id) => {\n998:       const t = this.allTasks.find((tt) => tt.id === id);\n999:       return t && (t.status === \"backlog\" || t.status === \"planned\") && areDependenciesMet(t, this.doneIds);\n1000:     }).length;\n1001: \n1002:     let line1 = ` {bold}Keys:{/bold}`;\n1003:     line1 += `  {gray-fg}Space{/gray-fg} toggle`;\n1004:     line1 += `  {gray-fg}S{/gray-fg} stream`;\n1005:     line1 += `  {gray-fg}A{/gray-fg} all`;\n1006:     line1 += `  {gray-fg}+/-{/gray-fg} priority`;\n1007:     line1 += `  {gray-fg}D{/gray-fg} ${this.hideDone ? \"show\" : \"hide\"} done`;\n1008:     line1 += `  {gray-fg}X{/gray-fg} archive done`;\n1009:     line1 += `  {gray-fg}C{/gray-fg} concurrency`;\n1010:     if (this.onErrand) {\n1011:       line1 += `  {gray-fg}E{/gray-fg} errand`;\n1012:     }\n1013:     line1 += `  {gray-fg}W{/gray-fg} wishlist`;\n1014:     line1 += `  {gray-fg}O{/gray-fg} sort`;\n1015: \n1016:     if (selCount > 0) {\n1017:       line1 += `  {bold}{green-fg}L{/green-fg} LAUNCH (${selCount}){/bold}`;\n1018:     }\n1019:     if (this.hasRunningWave) {\n1020:       line1 += `  {gray-fg}Tab{/gray-fg} monitor`;\n1021:     }\n1022:     if (this.onBack) {\n1023:       line1 += `  {gray-fg}Esc{/gray-fg} back`;\n1024:     }\n1025:     if (this.questId) {\n1026:       line1 += `  {gray-fg}Q{/gray-fg} back`;\n1027:     } else {\n1028:       line1 += `  {gray-fg}Q{/gray-fg} quit`;\n1029:     }\n1030: \n1031:     let line2 = ` `;\n1032:     if (selCount > 0) {\n1033:       line2 += `{green-fg}${selCount}{/green-fg} selected`;\n1034:       line2 += `  {cyan-fg}${readyInSelection}{/cyan-fg} launchable now`;\n1035:       const doneInSel = [...this.selected].filter((id) => {\n1036:         const t = this.allTasks.find((tt) => tt.id === id);\n1037:         return t?.status === \"done\";\n1038:       }).length;\n1039:       if (doneInSel > 0) {\n1040:         line2 += `  {yellow-fg}${doneInSel} already done (will be skipped){/yellow-fg}`;\n1041:       }\n1042:     } else {\n1043:       line2 += `{gray-fg}Select tasks with Space, then press L to launch{/gray-fg}`;  \n1044:     }\n1045: \n1046:     this.statusBar.setContent(`${line1}\\n${line2}`);\n1047:   }\n1048: }\n\n(End of file - total 1048 lines)\n</content>","title":"src/lib/tui-browser.ts","metadata":{"preview":"/**\n * tui-browser.ts — Task browser view for the wombo-combo TUI.\n *\n * Shows all tasks organized by dependency streams with checkboxes for\n * selection. Users can evaluate tasks, order them, select/deselect\n * entire streams, and launch a wave with the selected tasks.\n *\n * Layout:\n *   ┌───────────────────────────────────────────────────────┐\n *   │ WOMBO-COMBO Task Browser  │ 42 tasks │ 5 selected    │\n *   ├──────────────────────────────┬────────────────────────┤\n *   │ ☑ json-features-check  done │ Title: ...             │\n *   │ ☑ json-features-arch   done │ Status: backlog        │\n *   │   ☐ json-ops-commands  back │ Priority: high         │\n *   │ ── stream 2 ──              │ Effort: PT6H           │\n *   │ ☐ tdd-test-detection   done │ Depends on:            │\n *   │ ...                         │   - json-ops-commands  │\n *   ├──────────────────────────────┴────────────────────────┤\n *   │ Space:toggle  S:stream  L:launch  O:sort  Q:quit    │\n *   └───────────────────────────────────────────────────────┘","truncated":false,"loaded":[]},"time":{"start":1773483375939,"end":1773483375942}}}}
