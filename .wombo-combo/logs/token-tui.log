{"type":"tool_use","timestamp":1773483391363,"sessionID":"ses_3142777b4ffe3IuXz7qBZaextx","part":{"id":"prt_cebd8f5a6001oh83V7FokW9cPg","sessionID":"ses_3142777b4ffe3IuXz7qBZaextx","messageID":"msg_cebd8ea0f001mudSncHQfgAcMB","type":"tool","callID":"toolu_vrtx_011X9Lhzo1vuHW3ERbsWx1cU","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/token-tui/src/lib/quest-store.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/token-tui/src/lib/quest-store.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * quest-store.ts — Folder-based quest storage.\n3:  *\n4:  * Layout inside .wombo-combo/:\n5:  *   quests/\n6:  *     <quest-id>.yml       — one file per quest\n7:  *\n8:  * Each quest file is a plain YAML mapping of a single Quest object.\n9:  * Unlike the task store, quests have no _meta.yml — each quest file\n10:  * is self-contained with its own timestamps.\n11:  *\n12:  * Quests also support a knowledge file per quest:\n13:  *   quests/<quest-id>/knowledge.md\n14:  * This is a shared read-only file seeded by the planner with\n15:  * architectural decisions, API contracts, and shared types.\n16:  */\n17: \n18: import {\n19:   readFileSync,\n20:   writeFileSync,\n21:   existsSync,\n22:   mkdirSync,\n23:   readdirSync,\n24:   renameSync,\n25:   unlinkSync,\n26:   rmdirSync,\n27: } from \"node:fs\";\n28: import { resolve, join, basename } from \"node:path\";\n29: import { parse as parseYaml, stringify as stringifyYaml } from \"yaml\";\n30: import { WOMBO_DIR } from \"../config.js\";\n31: import type { Quest } from \"./quest.js\";\n32: import { normalizeQuest, validateQuest } from \"./quest.js\";\n33: \n34: // ---------------------------------------------------------------------------\n35: // Constants\n36: // ---------------------------------------------------------------------------\n37: \n38: /** Directory name for quests inside .wombo-combo/ */\n39: const QUESTS_DIR = \"quests\";\n40: \n41: const YAML_OPTS = {\n42:   lineWidth: 120,\n43:   defaultKeyType: \"PLAIN\" as const,\n44:   defaultStringType: \"PLAIN\" as const,\n45: };\n46: \n47: // ---------------------------------------------------------------------------\n48: // Path helpers\n49: // ---------------------------------------------------------------------------\n50: \n51: function questsDir(projectRoot: string): string {\n52:   return resolve(projectRoot, WOMBO_DIR, QUESTS_DIR);\n53: }\n54: \n55: function questFilePath(projectRoot: string, questId: string): string {\n56:   return join(questsDir(projectRoot), `${questId}.yml`);\n57: }\n58: \n59: function knowledgeDir(projectRoot: string, questId: string): string {\n60:   return join(questsDir(projectRoot), questId);\n61: }\n62: \n63: function knowledgeFilePath(projectRoot: string, questId: string): string {\n64:   return join(knowledgeDir(projectRoot, questId), \"knowledge.md\");\n65: }\n66: \n67: // ---------------------------------------------------------------------------\n68: // Internal helpers\n69: // ---------------------------------------------------------------------------\n70: \n71: function ensureDir(dir: string): void {\n72:   if (!existsSync(dir)) {\n73:     mkdirSync(dir, { recursive: true });\n74:   }\n75: }\n76: \n77: function atomicWrite(filePath: string, content: string): void {\n78:   const tmp = filePath + \".tmp\";\n79:   writeFileSync(tmp, content, \"utf-8\");\n80:   renameSync(tmp, filePath);\n81: }\n82: \n83: // ---------------------------------------------------------------------------\n84: // Public API — Load\n85: // ---------------------------------------------------------------------------\n86: \n87: /**\n88:  * Check if the quests directory exists.\n89:  */\n90: export function questsStoreExists(projectRoot: string): boolean {\n91:   return existsSync(questsDir(projectRoot));\n92: }\n93: \n94: /**\n95:  * Load a single quest by ID. Returns null if not found.\n96:  */\n97: export function loadQuest(\n98:   projectRoot: string,\n99:   questId: string\n100: ): Quest | null {\n101:   const filePath = questFilePath(projectRoot, questId);\n102:   if (!existsSync(filePath)) return null;\n103: \n104:   try {\n105:     const raw = readFileSync(filePath, \"utf-8\");\n106:     const parsed = parseYaml(raw);\n107:     if (!parsed || typeof parsed !== \"object\") return null;\n108: \n109:     normalizeQuest(parsed as Quest);\n110: \n111:     // Validate and warn\n112:     const issues = validateQuest(parsed);\n113:     for (const issue of issues) {\n114:       if (issue.level === \"error\") {\n115:         console.error(`  [quest-schema] ${issue.questId}: ${issue.message}`);\n116:       } else {\n117:         console.warn(`  [quest-schema] ${issue.questId}: ${issue.message}`);\n118:       }\n119:     }\n120: \n121:     return parsed as Quest;\n122:   } catch (err: unknown) {\n123:     const reason = err instanceof Error ? err.message : String(err);\n124:     console.error(`Failed to parse quest ${questId}: ${reason}`);\n125:     return null;\n126:   }\n127: }\n128: \n129: /**\n130:  * List all quest IDs in the store (sorted alphabetically).\n131:  */\n132: export function listQuestIds(projectRoot: string): string[] {\n133:   const dir = questsDir(projectRoot);\n134:   if (!existsSync(dir)) return [];\n135: \n136:   return readdirSync(dir)\n137:     .filter((f) => f.endsWith(\".yml\"))\n138:     .map((f) => f.replace(/\\.yml$/, \"\"))\n139:     .sort();\n140: }\n141: \n142: /**\n143:  * Load all quests from the store.\n144:  */\n145: export function loadAllQuests(projectRoot: string): Quest[] {\n146:   const ids = listQuestIds(projectRoot);\n147:   const quests: Quest[] = [];\n148: \n149:   for (const id of ids) {\n150:     const quest = loadQuest(projectRoot, id);\n151:     if (quest) quests.push(quest);\n152:   }\n153: \n154:   return quests;\n155: }\n156: \n157: // ---------------------------------------------------------------------------\n158: // Public API — Save\n159: // ---------------------------------------------------------------------------\n160: \n161: /**\n162:  * Save a quest to the store. Creates the quests directory if needed.\n163:  * Updates the quest's updated_at timestamp.\n164:  */\n165: export function saveQuest(\n166:   projectRoot: string,\n167:   quest: Quest\n168: ): void {\n169:   const dir = questsDir(projectRoot);\n170:   ensureDir(dir);\n171: \n172:   quest.updated_at = new Date().toISOString();\n173: \n174:   const yaml = stringifyYaml(quest, YAML_OPTS);\n175:   const filePath = questFilePath(projectRoot, quest.id);\n176:   atomicWrite(filePath, yaml);\n177: }\n178: \n179: // ---------------------------------------------------------------------------\n180: // Public API — Delete\n181: // ---------------------------------------------------------------------------\n182: \n183: /**\n184:  * Delete a quest from the store. Also removes its knowledge directory.\n185:  */\n186: export function deleteQuest(\n187:   projectRoot: string,\n188:   questId: string\n189: ): void {\n190:   const filePath = questFilePath(projectRoot, questId);\n191:   if (existsSync(filePath)) {\n192:     unlinkSync(filePath);\n193:   }\n194: \n195:   // Clean up knowledge directory if it exists\n196:   const kDir = knowledgeDir(projectRoot, questId);\n197:   if (existsSync(kDir)) {\n198:     // Remove knowledge.md\n199:     const kFile = knowledgeFilePath(projectRoot, questId);\n200:     if (existsSync(kFile)) unlinkSync(kFile);\n201:     // Try to remove the directory (only works if empty)\n202:     try {\n203:       rmdirSync(kDir);\n204:     } catch {\n205:       // Not critical — leave it if non-empty\n206:     }\n207:   }\n208: }\n209: \n210: // ---------------------------------------------------------------------------\n211: // Public API — Knowledge file\n212: // ---------------------------------------------------------------------------\n213: \n214: /**\n215:  * Load the knowledge file for a quest. Returns null if not found.\n216:  */\n217: export function loadQuestKnowledge(\n218:   projectRoot: string,\n219:   questId: string\n220: ): string | null {\n221:   const filePath = knowledgeFilePath(projectRoot, questId);\n222:   if (!existsSync(filePath)) return null;\n223:   return readFileSync(filePath, \"utf-8\");\n224: }\n225: \n226: /**\n227:  * Save or update the knowledge file for a quest.\n228:  */\n229: export function saveQuestKnowledge(\n230:   projectRoot: string,\n231:   questId: string,\n232:   content: string\n233: ): void {\n234:   const dir = knowledgeDir(projectRoot, questId);\n235:   ensureDir(dir);\n236:   const filePath = knowledgeFilePath(projectRoot, questId);\n237:   atomicWrite(filePath, content);\n238: }\n239: \n240: // ---------------------------------------------------------------------------\n241: // Public API — Quest directory path (for external consumers)\n242: // ---------------------------------------------------------------------------\n243: \n244: /**\n245:  * Get the quests directory path.\n246:  */\n247: export function getQuestsDir(projectRoot: string): string {\n248:   return questsDir(projectRoot);\n249: }\n\n(End of file - total 249 lines)\n</content>","title":"src/lib/quest-store.ts","metadata":{"preview":"/**\n * quest-store.ts — Folder-based quest storage.\n *\n * Layout inside .wombo-combo/:\n *   quests/\n *     <quest-id>.yml       — one file per quest\n *\n * Each quest file is a plain YAML mapping of a single Quest object.\n * Unlike the task store, quests have no _meta.yml — each quest file\n * is self-contained with its own timestamps.\n *\n * Quests also support a knowledge file per quest:\n *   quests/<quest-id>/knowledge.md\n * This is a shared read-only file seeded by the planner with\n * architectural decisions, API contracts, and shared types.\n */\n\nimport {\n  readFileSync,\n  writeFileSync,","truncated":false,"loaded":[]},"time":{"start":1773483391360,"end":1773483391362}}}}
