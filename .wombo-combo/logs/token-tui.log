"content":"Add dedicated token usage overlay view accessible via U keybind from Task Browser","status":"pending","priority":"medium"},{"content":"Add token usage summary to the wave monitor TUI (header or agent list)","status":"pending","priority":"medium"},{"content":"Run typecheck and build to verify","status":"pending","priority":"high"}],"truncated":false},"time":{"start":1773483387266,"end":1773483387267}}}}
