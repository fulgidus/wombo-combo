{"type":"tool_use","timestamp":1773483376320,"sessionID":"ses_3142777b4ffe3IuXz7qBZaextx","part":{"id":"prt_cebd8bd44001yEkjB0vRHj7oT7","sessionID":"ses_3142777b4ffe3IuXz7qBZaextx","messageID":"msg_cebd8aa0c001nz9ge0Rol13lRP","type":"tool","callID":"toolu_vrtx_01HEPZf9yauKGysb1M6qirUn","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/token-tui/src/lib/tui-quest-picker.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/token-tui/src/lib/tui-quest-picker.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tui-quest-picker.ts -- Quest picker view for the wombo-combo TUI.\n3:  *\n4:  * Shows all quests as a selectable list with an \"All Tasks\" option at the top.\n5:  * Selecting a quest navigates to the Task Browser filtered to that quest's tasks.\n6:  *\n7:  * Layout:\n8:  *   +-----------------------------------------------------------+\n9:  *   | WOMBO-COMBO Quest Picker  | 4 quests                      |\n10:  *   +---------------------------+-------------------------------+\n11:  *   | > All Tasks (42)          | Quest: auth-overhaul           |\n12:  *   |   auth-overhaul   ACTV    | Status: active                 |\n13:  *   |   search-api      DRFT    | Priority: high                 |\n14:  *   |   perf-optim      PAUS    | Tasks: 8 (3 done, 62%)         |\n15:  *   |   ui-redesign     PLAN    | Goal: Replace basic auth...    |\n16:  *   |                           |                                |\n17:  *   +---------------------------+-------------------------------+\n18:  *   | Enter:select  C:create  Q:quit                            |\n19:  *   +-----------------------------------------------------------+\n20:  *\n21:  * Keybinds:\n22:  *   Enter/Space  -- select quest (or \"All Tasks\") and proceed to browser\n23:  *   C            -- create new quest (Phase 2 p2-quest-create-tui)\n24:  *   A            -- activate/pause selected quest\n25:  *   Q / C-c      -- quit the TUI\n26:  */\n27: \n28: import blessed from \"neo-blessed\";\n29: import type { Widgets } from \"neo-blessed\";\n30: import type { Quest, QuestHitlMode } from \"./quest.js\";\n31: import { QUEST_STATUS_ORDER, createBlankQuest, VALID_HITL_MODES } from \"./quest.js\";\n32: import { loadAllQuests, saveQuest, loadQuest } from \"./quest-store.js\";\n33: import { VALID_PRIORITIES, VALID_DIFFICULTIES } from \"./task-schema.js\";\n34: import type { Priority, Difficulty } from \"./tasks.js\";\n35: import { loadTasks, getDoneTaskIds, loadArchive } from \"./tasks.js\";\n36: import type { WomboConfig } from \"../config.js\";\n37: // ---------------------------------------------------------------------------\n38: // Types\n39: // ---------------------------------------------------------------------------\n40: \n41: export type QuestPickerAction =\n42:   | { type: \"select\"; questId: string | null }\n43:   | { type: \"plan\"; questId: string }\n44:   | { type: \"genesis\" }\n45:   | { type: \"errand\" }\n46:   | { type: \"wishlist\" }\n47:   | { type: \"quit\" };\n48: \n49: export interface QuestPickerOptions {\n50:   projectRoot: string;\n51:   config: WomboConfig;\n52:   onSelect: (questId: string | null) => void;\n53:   onPlan?: (questId: string) => void;\n54:   onGenesis?: () => void;\n55:   onErrand?: () => void;\n56:   onWishlist?: () => void;\n57:   onQuit: () => void;\n58: }\n59: \n60: // ---------------------------------------------------------------------------\n61: // Display helpers\n62: // ---------------------------------------------------------------------------\n63: \n64: const STATUS_ABBREV: Record<string, string> = {\n65:   draft: \"DRFT\",\n66:   planning: \"PLAN\",\n67:   active: \"ACTV\",\n68:   paused: \"PAUS\",\n69:   completed: \"DONE\",\n70:   abandoned: \"ABAN\",\n71: };\n72: \n73: const STATUS_COLORS: Record<string, string> = {\n74:   draft: \"gray\",\n75:   planning: \"blue\",\n76:   active: \"green\",\n77:   paused: \"yellow\",\n78:   completed: \"cyan\",\n79:   abandoned: \"red\",\n80: };\n81: \n82: const PRIORITY_COLORS: Record<string, string> = {\n83:   critical: \"red\",\n84:   high: \"yellow\",\n85:   medium: \"white\",\n86:   low: \"gray\",\n87:   wishlist: \"gray\",\n88: };\n89: \n90: function escapeBlessedTags(text: string): string {\n91:   return text.replace(/\\{/g, \"\\uFF5B\").replace(/\\}/g, \"\\uFF5D\");\n92: }\n93: \n94: // ---------------------------------------------------------------------------\n95: // Quest summary for display\n96: // ---------------------------------------------------------------------------\n97: \n98: interface QuestSummary {\n99:   quest: Quest;\n100:   totalTasks: number;\n101:   doneTasks: number;\n102:   completionPct: number;\n103: }\n104: \n105: // ---------------------------------------------------------------------------\n106: // QuestPicker Class\n107: // ---------------------------------------------------------------------------\n108: \n109: export class QuestPicker {\n110:   private screen: Widgets.Screen;\n111:   private headerBox: Widgets.BoxElement;\n112:   private questList: Widgets.ListElement;\n113:   private detailBox: Widgets.BoxElement;\n114:   private statusBar: Widgets.BoxElement;\n115: \n116:   private projectRoot: string;\n117:   private config: WomboConfig;\n118:   private onSelect: (questId: string | null) => void;\n119:   private onPlan?: (questId: string) => void;\n120:   private onGenesis?: () => void;\n121:   private onErrand?: () => void;\n122:   private onWishlist?: () => void;\n123:   private onQuit: () => void;\n124: \n125:   /** \"All Tasks\" + quest summaries */\n126:   private items: Array<{ type: \"all\" } | { type: \"quest\"; summary: QuestSummary }> = [];\n127:   private selectedIndex: number = 0;\n128:   private totalTaskCount: number = 0;\n129: \n130:   constructor(opts: QuestPickerOptions) {\n131:     this.projectRoot = opts.projectRoot;\n132:     this.config = opts.config;\n133:     this.onSelect = opts.onSelect;\n134:     this.onPlan = opts.onPlan;\n135:     this.onGenesis = opts.onGenesis;\n136:     this.onErrand = opts.onErrand;\n137:     this.onWishlist = opts.onWishlist;\n138:     this.onQuit = opts.onQuit;\n139: \n140:     this.loadQuests();\n141: \n142:     // Create screen\n143:     this.screen = blessed.screen({\n144:       smartCSR: true,\n145:       title: \"wombo-combo -- Quest Picker\",\n146:       fullUnicode: true,\n147:     });\n148: \n149:     // Header\n150:     this.headerBox = blessed.box({\n151:       top: 0,\n152:       left: 0,\n153:       width: \"100%\",\n154:       height: 3,\n155:       tags: true,\n156:       style: { fg: \"white\", bg: \"black\" },\n157:     });\n158: \n159:     // Quest list (left pane)\n160:     this.questList = blessed.list({\n161:       top: 3,\n162:       left: 0,\n163:       width: \"50%\",\n164:       height: \"100%-6\",\n165:       tags: true,\n166:       scrollable: true,\n167:       mouse: true,\n168:       keys: true,\n169:       vi: true,\n170:       border: { type: \"line\" },\n171:       style: {\n172:         border: { fg: \"gray\" },\n173:         selected: { bg: \"blue\", fg: \"white\", bold: true },\n174:         item: { fg: \"white\" },\n175:       },\n176:       label: \" Quests \",\n177:     });\n178: \n179:     // Detail pane (right pane)\n180:     this.detailBox = blessed.box({\n181:       top: 3,\n182:       left: \"50%\",\n183:       width: \"50%\",\n184:       height: \"100%-6\",\n185:       tags: true,\n186:       scrollable: true,\n187:       mouse: true,\n188:       border: { type: \"line\" },\n189:       style: {\n190:         border: { fg: \"gray\" },\n191:         fg: \"white\",\n192:       },\n193:       label: \" Details \",\n194:     });\n195: \n196:     // Status bar\n197:     this.statusBar = blessed.box({\n198:       bottom: 0,\n199:       left: 0,\n200:       width: \"100%\",\n201:       height: 3,\n202:       tags: true,\n203:       style: { fg: \"white\", bg: \"black\" },\n204:     });\n205: \n206:     // Assemble\n207:     this.screen.append(this.headerBox);\n208:     this.screen.append(this.questList);\n209:     this.screen.append(this.detailBox);\n210:     this.screen.append(this.statusBar);\n211:     this.questList.focus();\n212: \n213:     this.bindKeys();\n214:   }\n215: \n216:   // -----------------------------------------------------------------------\n217:   // Public API\n218:   // -----------------------------------------------------------------------\n219: \n220:   start(): void {\n221:     this.refreshAll();\n222:     this.screen.render();\n223:   }\n224: \n225:   stop(): void {\n226:     this.screen.destroy();\n227:   }\n228: \n229:   destroy(): void {\n230:     this.screen.destroy();\n231:     process.stdout.write(\"\\x1B[2J\\x1B[H\");\n232:   }\n233: \n234:   // -----------------------------------------------------------------------\n235:   // Data Loading\n236:   // -----------------------------------------------------------------------\n237: \n238:   private loadQuests(): void {\n239:     const quests = loadAllQuests(this.projectRoot);\n240:     const tasksData = loadTasks(this.projectRoot, this.config);\n241:     const archiveData = loadArchive(this.projectRoot, this.config);\n242:     const doneIds = getDoneTaskIds(tasksData, archiveData.tasks);\n243:     this.totalTaskCount = tasksData.tasks.length;\n244: \n245:     // Build task lookup for quest summaries\n246:     const taskMap = new Map(tasksData.tasks.map((t) => [t.id, t]));\n247: \n248:     // Sort quests: active first, then by status order, then by priority\n249:     const sorted = [...quests].sort((a, b) => {\n250:       const statusDiff = (QUEST_STATUS_ORDER[a.status] ?? 99) - (QUEST_STATUS_ORDER[b.status] ?? 99);\n251:       if (statusDiff !== 0) return statusDiff;\n252:       return 0;\n253:     });\n254: \n255:     // Build items list\n256:     this.items = [{ type: \"all\" as const }];\n257:     for (const quest of sorted) {\n258:       const totalTasks = quest.taskIds.length;\n259:       const doneTasks = quest.taskIds.filter((id) => doneIds.has(id)).length;\n260:       const completionPct = totalTasks > 0 ? Math.round((doneTasks / totalTasks) * 100) : 0;\n261: \n262:       this.items.push({\n263:         type: \"quest\" as const,\n264:         summary: { quest, totalTasks, doneTasks, completionPct },\n265:       });\n266:     }\n267:   }\n268: \n269:   // -----------------------------------------------------------------------\n270:   // Key Bindings\n271:   // -----------------------------------------------------------------------\n272: \n273:   private bindKeys(): void {\n274:     // Quit\n275:     this.screen.key([\"q\", \"C-c\"], () => {\n276:       this.stop();\n277:       this.onQuit();\n278:     });\n279: \n280:     // Navigate\n281:     this.questList.on(\"select item\", (_item: any, index: number) => {\n282:       this.selectedIndex = index;\n283:       this.refreshDetail();\n284:       this.screen.render();\n285:     });\n286: \n287:     // Enter/Space -- select\n288:     this.screen.key([\"enter\", \"space\"], () => {\n289:       this.selectCurrent();\n290:     });\n291: \n292:     // A -- activate/pause quest\n293:     this.screen.key([\"a\"], () => {\n294:       this.toggleQuestActive();\n295:     });\n296: \n297:     // C -- create new quest\n298:     this.screen.key([\"c\"], () => {\n299:       this.showCreateQuestModal();\n300:     });\n301: \n302:     // P -- plan quest (run planner agent)\n303:     this.screen.key([\"p\"], () => {\n304:       this.planQuest();\n305:     });\n306: \n307:     // G -- genesis (project-level decomposition)\n308:     this.screen.key([\"g\"], () => {\n309:       this.triggerGenesis();\n310:     });\n311: \n312:     // E -- errand (quick task generation without a quest)\n313:     this.screen.key([\"e\"], () => {\n314:       this.triggerErrand();\n315:     });\n316: \n317:     // W -- wishlist browser\n318:     this.screen.key([\"w\"], () => {\n319:       this.triggerWishlist();\n320:     });\n321:   }\n322: \n323:   // -----------------------------------------------------------------------\n324:   // Actions\n325:   // -----------------------------------------------------------------------\n326: \n327:   private selectCurrent(): void {\n328:     const item = this.items[this.selectedIndex];\n329:     if (!item) return;\n330: \n331:     if (item.type === \"all\") {\n332:       this.destroy();\n333:       this.onSelect(null);\n334:     } else {\n335:       this.destroy();\n336:       this.onSelect(item.summary.quest.id);\n337:     }\n338:   }\n339: \n340:   private toggleQuestActive(): void {\n341:     const item = this.items[this.selectedIndex];\n342:     if (!item || item.type === \"all\") return;\n343: \n344:     const quest = item.summary.quest;\n345:     if (quest.status === \"active\") {\n346:       quest.status = \"paused\";\n347:     } else if (quest.status === \"draft\" || quest.status === \"paused\" || quest.status === \"planning\") {\n348:       quest.status = \"active\";\n349:       if (!quest.started_at) {\n350:         quest.started_at = new Date().toISOString();\n351:       }\n352:     } else {\n353:       // completed/abandoned -- can't toggle\n354:       return;\n355:     }\n356: \n357:     saveQuest(this.projectRoot, quest);\n358:     this.loadQuests();\n359:     this.refreshAll();\n360:     this.screen.render();\n361:   }\n362: \n363:   private planQuest(): void {\n364:     if (this.creatingQuest) return;\n365:     const item = this.items[this.selectedIndex];\n366:     if (!item || item.type === \"all\") return;\n367: \n368:     const quest = item.summary.quest;\n369:     // Only allow planning for draft or planning quests\n370:     if (quest.status !== \"draft\" && quest.status !== \"planning\") {\n371:       return;\n372:     }\n373: \n374:     if (!this.onPlan) return;\n375: \n376:     this.destroy();\n377:     this.onPlan(quest.id);\n378:   }\n379: \n380:   private triggerGenesis(): void {\n381:     if (this.creatingQuest) return;\n382:     if (!this.onGenesis) return;\n383: \n384:     this.destroy();\n385:     this.onGenesis();\n386:   }\n387: \n388:   private triggerErrand(): void {\n389:     if (this.creatingQuest) return;\n390:     if (!this.onErrand) return;\n391: \n392:     this.destroy();\n393:     this.onErrand();\n394:   }\n395: \n396:   private triggerWishlist(): void {\n397:     if (this.creatingQuest) return;\n398:     if (!this.onWishlist) return;\n399: \n400:     this.destroy();\n401:     this.onWishlist();\n402:   }\n403: \n404:   // -----------------------------------------------------------------------\n405:   // Create Quest Modal\n406:   // -----------------------------------------------------------------------\n407: \n408:   /** Whether the create modal is currently showing (blocks other key handlers) */\n409:   private creatingQuest = false;\n410: \n411:   /**\n412:    * Show a multi-step modal form to create a new quest.\n413:    * Steps: ID -> Title -> Goal -> Priority -> Difficulty -> HITL -> Confirm\n414:    */\n415:   private showCreateQuestModal(): void {\n416:     if (this.creatingQuest) return;\n417:     this.creatingQuest = true;\n418: \n419:     // Overlay box that covers the detail pane\n420:     const modal = blessed.box({\n421:       parent: this.screen,\n422:       top: \"center\",\n423:       left: \"center\",\n424:       width: \"70%\",\n425:       height: \"80%\",\n426:       tags: true,\n427:       border: { type: \"line\" },\n428:       style: {\n429:         border: { fg: \"magenta\" },\n430:         fg: \"white\",\n431:         bg: \"black\",\n432:       },\n433:       label: \" {magenta-fg}New Quest{/magenta-fg} \",\n434:       shadow: true,\n435:     });\n436: \n437:     // Content area (instructions)\n438:     const content = blessed.box({\n439:       parent: modal,\n440:       top: 0,\n441:       left: 1,\n442:       right: 1,\n443:       height: 3,\n444:       tags: true,\n445:       style: { fg: \"white\", bg: \"black\" },\n446:     });\n447: \n448:     // Textbox for text input steps\n449:     const textbox = blessed.textbox({\n450:       parent: modal,\n451:       top: 3,\n452:       left: 1,\n453:       right: 1,\n454:       height: 3,\n455:       border: { type: \"line\" },\n456:       style: {\n457:         border: { fg: \"cyan\" },\n458:         fg: \"white\",\n459:         bg: \"black\",\n460:         focus: { border: { fg: \"magenta\" } },\n461:       },\n462:       inputOnFocus: true,\n463:     });\n464: \n465:     // Textarea for goal (multi-line)\n466:     const textarea = blessed.textarea({\n467:       parent: modal,\n468:       top: 3,\n469:       left: 1,\n470:       right: 1,\n471:       height: 10,\n472:       border: { type: \"line\" },\n473:       style: {\n474:         border: { fg: \"cyan\" },\n475:         fg: \"white\",\n476:         bg: \"black\",\n477:         focus: { border: { fg: \"magenta\" } },\n478:       },\n479:       inputOnFocus: true,\n480:       hidden: true,\n481:     });\n482: \n483:     // Selection list for enum steps (priority, difficulty, hitl)\n484:     const selectList = blessed.list({\n485:       parent: modal,\n486:       top: 3,\n487:       left: 1,\n488:       right: 1,\n489:       height: \"100%-8\",\n490:       tags: true,\n491:       keys: true,\n492:       vi: true,\n493:       border: { type: \"line\" },\n494:       style: {\n495:         border: { fg: \"cyan\" },\n496:         selected: { bg: \"blue\", fg: \"white\", bold: true },\n497:         item: { fg: \"white\" },\n498:         bg: \"black\",\n499:       },\n500:       hidden: true,\n501:     });\n502: \n503:     // Status line at bottom of modal\n504:     const statusLine = blessed.box({\n505:       parent: modal,\n506:       bottom: 0,\n507:       left: 1,\n508:       right: 1,\n509:       height: 1,\n510:       tags: true,\n511:       style: { fg: \"gray\", bg: \"black\" },\n512:     });\n513: \n514:     // Collected values\n515:     let questId = \"\";\n516:     let questTitle = \"\";\n517:     let questGoal = \"\";\n518:     let questPriority: Priority = \"medium\";\n519:     let questDifficulty: Difficulty = \"medium\";\n520:     let questHitl: QuestHitlMode = \"yolo\";\n521: \n522:     type Step = \"id\" | \"title\" | \"goal\" | \"priority\" | \"difficulty\" | \"hitl\";\n523:     const steps: Step[] = [\"id\", \"title\", \"goal\", \"priority\", \"difficulty\", \"hitl\"];\n524:     let currentStepIdx = 0;\n525: \n526:     const cleanup = () => {\n527:       modal.destroy();\n528:       this.creatingQuest = false;\n529:       this.questList.focus();\n530:       this.screen.render();\n531:     };\n532: \n533:     const showStep = (step: Step) => {\n534:       textbox.hide();\n535:       textarea.hide();\n536:       selectList.hide();\n537: \n538:       const stepLabel = `Step ${currentStepIdx + 1}/${steps.length}`;\n539: \n540:       switch (step) {\n541:         case \"id\":\n542:           content.setContent(\n543:             `{bold}${stepLabel} — Quest ID{/bold}\\n` +\n544:             `{gray-fg}Kebab-case identifier (e.g. auth-overhaul, search-api){/gray-fg}\\n` +\n545:             `{gray-fg}Esc to cancel{/gray-fg}`\n546:           );\n547:           statusLine.setContent(\"{gray-fg}Enter a unique ID for the quest{/gray-fg}\");\n548:           textbox.setValue(\"\");\n549:           textbox.show();\n550:           textbox.focus();\n551:           break;\n552: \n553:         case \"title\":\n554:           content.setContent(\n555:             `{bold}${stepLabel} — Title{/bold}\\n` +\n556:             `{gray-fg}Human-readable name for the quest{/gray-fg}\\n` +\n557:             `{gray-fg}Esc to go back{/gray-fg}`\n558:           );\n559:           statusLine.setContent(`{gray-fg}ID: ${questId}{/gray-fg}`);\n560:           textbox.setValue(\"\");\n561:           textbox.show();\n562:           textbox.focus();\n563:           break;\n564: \n565:         case \"goal\":\n566:           content.setContent(\n567:             `{bold}${stepLabel} — Goal{/bold}\\n` +\n568:             `{gray-fg}What should this quest achieve? (Enter to submit, Esc to go back){/gray-fg}\\n` +\n569:             `{gray-fg}Shift+Enter or \\\\n for newlines{/gray-fg}`\n570:           );\n571:           statusLine.setContent(`{gray-fg}ID: ${questId} | Title: ${questTitle}{/gray-fg}`);\n572:           textarea.setValue(\"\");\n573:           textarea.show();\n574:           textarea.focus();\n575:           break;\n576: \n577:         case \"priority\":\n578:           content.setContent(\n579:             `{bold}${stepLabel} — Priority{/bold}\\n` +\n580:             `{gray-fg}Select with Enter, Esc to go back{/gray-fg}`\n581:           );\n582:           statusLine.setContent(`{gray-fg}ID: ${questId} | Title: ${questTitle}{/gray-fg}`);\n583:           selectList.setItems(\n584:             (VALID_PRIORITIES as readonly string[]).map((p) => {\n585:               const dot = PRIORITY_COLORS[p] ?? \"white\";\n586:               const marker = p === \"medium\" ? \" {gray-fg}(default){/gray-fg}\" : \"\";\n587:               return `  {${dot}-fg}\\u25CF{/${dot}-fg}  ${p}${marker}`;\n588:             }) as any\n589:           );\n590:           // Pre-select \"medium\" (index 2)\n591:           selectList.select(2);\n592:           selectList.show();\n593:           selectList.focus();\n594:           break;\n595: \n596:         case \"difficulty\":\n597:           content.setContent(\n598:             `{bold}${stepLabel} — Difficulty{/bold}\\n` +\n599:             `{gray-fg}Select with Enter, Esc to go back{/gray-fg}`\n600:           );\n601:           statusLine.setContent(`{gray-fg}ID: ${questId} | Priority: ${questPriority}{/gray-fg}`);\n602:           selectList.setItems(\n603:             (VALID_DIFFICULTIES as readonly string[]).map((d) => {\n604:               const marker = d === \"medium\" ? \" {gray-fg}(default){/gray-fg}\" : \"\";\n605:               return `  ${d}${marker}`;\n606:             }) as any\n607:           );\n608:           selectList.select(2);\n609:           selectList.show();\n610:           selectList.focus();\n611:           break;\n612: \n613:         case \"hitl\":\n614:           content.setContent(\n615:             `{bold}${stepLabel} — HITL Mode{/bold}\\n` +\n616:             `{gray-fg}Human-in-the-loop mode for agents. Select with Enter, Esc to go back{/gray-fg}`\n617:           );\n618:           statusLine.setContent(`{gray-fg}ID: ${questId} | Difficulty: ${questDifficulty}{/gray-fg}`);\n619:           const hitlDescs: Record<string, string> = {\n620:             yolo: \"Full autonomy, no interruptions\",\n621:             cautious: \"Agent blocks on uncertainty, user answers in TUI\",\n622:             supervised: \"Like cautious, but prompt encourages asking often\",\n623:           };\n624:           selectList.setItems(\n625:             (VALID_HITL_MODES as readonly string[]).map((m) => {\n626:               const desc = hitlDescs[m] ?? \"\";\n627:               const marker = m === \"yolo\" ? \" {gray-fg}(default){/gray-fg}\" : \"\";\n628:               return `  ${m}${marker}  {gray-fg}— ${desc}{/gray-fg}`;\n629:             }) as any\n630:           );\n631:           selectList.select(0);\n632:           selectList.show();\n633:           selectList.focus();\n634:           break;\n635:       }\n636: \n637:       this.screen.render();\n638:     };\n639: \n640:     const goBack = () => {\n641:       if (currentStepIdx <= 0) {\n642:         cleanup();\n643:         return;\n644:       }\n645:       currentStepIdx--;\n646:       showStep(steps[currentStepIdx]);\n647:     };\n648: \n649:     const advanceOrFinish = () => {\n650:       currentStepIdx++;\n651:       if (currentStepIdx >= steps.length) {\n652:         // All done — create the quest\n653:         this.finishCreateQuest(\n654:           questId,\n655:           questTitle,\n656:           questGoal,\n657:           questPriority,\n658:           questDifficulty,\n659:           questHitl,\n660:           modal,\n661:           content,\n662:           statusLine\n663:         );\n664:         return;\n665:       }\n666:       showStep(steps[currentStepIdx]);\n667:     };\n668: \n669:     // --- Textbox submit/cancel for ID and Title steps ---\n670:     textbox.on(\"submit\", (value: string) => {\n671:       const trimmed = (value ?? \"\").trim();\n672:       const currentStep = steps[currentStepIdx];\n673: \n674:       if (currentStep === \"id\") {\n675:         // Validate ID\n676:         if (!trimmed) {\n677:           statusLine.setContent(\"{red-fg}ID cannot be empty{/red-fg}\");\n678:           this.screen.render();\n679:           textbox.focus();\n680:           return;\n681:         }\n682:         if (!/^[a-z0-9][a-z0-9-]*[a-z0-9]$|^[a-z0-9]$/.test(trimmed)) {\n683:           statusLine.setContent(\"{red-fg}ID must be kebab-case (lowercase letters, numbers, hyphens){/red-fg}\");\n684:           this.screen.render();\n685:           textbox.focus();\n686:           return;\n687:         }\n688:         // Check duplicate\n689:         const existing = loadQuest(this.projectRoot, trimmed);\n690:         if (existing) {\n691:           statusLine.setContent(`{red-fg}Quest \"${trimmed}\" already exists (${existing.status}){/red-fg}`);\n692:           this.screen.render();\n693:           textbox.focus();\n694:           return;\n695:         }\n696:         questId = trimmed;\n697:         advanceOrFinish();\n698:       } else if (currentStep === \"title\") {\n699:         if (!trimmed) {\n700:           statusLine.setContent(\"{red-fg}Title cannot be empty{/red-fg}\");\n701:           this.screen.render();\n702:           textbox.focus();\n703:           return;\n704:         }\n705:         questTitle = trimmed;\n706:         advanceOrFinish();\n707:       }\n708:     });\n709: \n710:     textbox.on(\"cancel\", () => {\n711:       goBack();\n712:     });\n713: \n714:     // --- Textarea submit/cancel for Goal step ---\n715:     textarea.key([\"enter\"], () => {\n716:       const val = (textarea.getValue() ?? \"\").trim();\n717:       if (!val) {\n718:         statusLine.setContent(\"{red-fg}Goal cannot be empty{/red-fg}\");\n719:         this.screen.render();\n720:         return;\n721:       }\n722:       questGoal = val;\n723:       advanceOrFinish();\n724:     });\n725: \n726:     textarea.key([\"escape\"], () => {\n727:       goBack();\n728:     });\n729: \n730:     // --- Select list for Priority, Difficulty, HITL ---\n731:     selectList.on(\"select item\", (_item: any, index: number) => {\n732:       // This fires on mouse click or manual select event\n733:     });\n734: \n735:     selectList.key([\"enter\", \"space\"], () => {\n736:       const currentStep = steps[currentStepIdx];\n737:       const idx = (selectList as any).selected ?? 0;\n738: \n739:       if (currentStep === \"priority\") {\n740:         questPriority = (VALID_PRIORITIES as readonly string[])[idx] as Priority;\n741:         advanceOrFinish();\n742:       } else if (currentStep === \"difficulty\") {\n743:         questDifficulty = (VALID_DIFFICULTIES as readonly string[])[idx] as Difficulty;\n744:         advanceOrFinish();\n745:       } else if (currentStep === \"hitl\") {\n746:         questHitl = (VALID_HITL_MODES as readonly string[])[idx] as QuestHitlMode;\n747:         advanceOrFinish();\n748:       }\n749:     });\n750: \n751:     selectList.key([\"escape\"], () => {\n752:       goBack();\n753:     });\n754: \n755:     // Start at step 0\n756:     showStep(steps[0]);\n757:   }\n758: \n759:   /**\n760:    * Finalize quest creation: save to store, show confirmation, reload list.\n761:    */\n762:   private finishCreateQuest(\n763:     id: string,\n764:     title: string,\n765:     goal: string,\n766:     priority: Priority,\n767:     difficulty: Difficulty,\n768:     hitlMode: QuestHitlMode,\n769:     modal: Widgets.BoxElement,\n770:     content: Widgets.BoxElement,\n771:     statusLine: Widgets.BoxElement\n772:   ): void {\n773:     try {\n774:       const baseBranch = this.config.baseBranch;\n775:       const quest = createBlankQuest(id, title, goal, baseBranch, {\n776:         priority,\n777:         difficulty,\n778:         hitlMode,\n779:       });\n780: \n781:       saveQuest(this.projectRoot, quest);\n782: \n783:       // Show confirmation briefly\n784:       content.setContent(\n785:         `{bold}{green-fg}\\u2714 Quest created!{/green-fg}{/bold}\\n\\n` +\n786:         `  {white-fg}${id}{/white-fg} — ${escapeBlessedTags(title)}\\n` +\n787:         `  Priority: ${priority}  |  Difficulty: ${difficulty}  |  HITL: ${hitlMode}\\n` +\n788:         `  Branch: quest/${id}  |  Base: ${baseBranch}`\n789:       );\n790:       statusLine.setContent(\"{gray-fg}Returning to quest list...{/gray-fg}\");\n791:       this.screen.render();\n792: \n793:       // After a brief delay, reload and return to picker\n794:       setTimeout(() => {\n795:         modal.destroy();\n796:         this.creatingQuest = false;\n797:         this.loadQuests();\n798:         // Select the newly created quest\n799:         const newIdx = this.items.findIndex(\n800:           (item) => item.type === \"quest\" && item.summary.quest.id === id\n801:         );\n802:         if (newIdx >= 0) this.selectedIndex = newIdx;\n803:         this.refreshAll();\n804:         this.questList.focus();\n805:         this.screen.render();\n806:       }, 1500);\n807:     } catch (err: unknown) {\n808:       const msg = err instanceof Error ? err.message : String(err);\n809:       content.setContent(\n810:         `{bold}{red-fg}\\u2718 Failed to create quest{/red-fg}{/bold}\\n\\n` +\n811:         `  ${escapeBlessedTags(msg)}`\n812:       );\n813:       statusLine.setContent(\"{gray-fg}Press Esc to return{/gray-fg}\");\n814:       this.screen.render();\n815: \n816:       const escHandler = () => {\n817:         modal.destroy();\n818:         this.creatingQuest = false;\n819:         this.questList.focus();\n820:         this.screen.render();\n821:       };\n822:       modal.key([\"escape\"], escHandler);\n823:     }\n824:   }\n825: \n826:   // -----------------------------------------------------------------------\n827:   // Refresh Logic\n828:   // -----------------------------------------------------------------------\n829: \n830:   private refreshAll(): void {\n831:     this.refreshHeader();\n832:     this.refreshList();\n833:     this.refreshDetail();\n834:     this.refreshStatusBar();\n835:   }\n836: \n837:   private refreshHeader(): void {\n838:     const questCount = this.items.length - 1; // exclude \"All Tasks\"\n839:     const activeCount = this.items.filter(\n840:       (i) => i.type === \"quest\" && i.summary.quest.status === \"active\"\n841:     ).length;\n842: \n843:     let line1 = ` {bold}wombo-combo{/bold} {magenta-fg}Quest Picker{/magenta-fg}`;\n844:     line1 += `  {gray-fg}|{/gray-fg}  {white-fg}${questCount}{/white-fg} quest${questCount !== 1 ? \"s\" : \"\"}`;\n845:     if (activeCount > 0) {\n846:       line1 += `  {gray-fg}|{/gray-fg}  {green-fg}${activeCount}{/green-fg} active`;\n847:     }\n848:     line1 += `  {gray-fg}|{/gray-fg}  {white-fg}${this.totalTaskCount}{/white-fg} total tasks`;\n849: \n850:     let line2 = ` {gray-fg}Select a quest to filter tasks, or choose \"All Tasks\" for the full list{/gray-fg}`;\n851: \n852:     this.headerBox.setContent(`${line1}\\n${line2}`);\n853:   }\n854: \n855:   private refreshList(): void {\n856:     const listItems: string[] = [];\n857: \n858:     for (const item of this.items) {\n859:       if (item.type === \"all\") {\n860:         listItems.push(\n861:           ` {bold}{cyan-fg}\\u25C6{/cyan-fg} All Tasks{/bold} {gray-fg}(${this.totalTaskCount}){/gray-fg}`\n862:         );\n863:       } else {\n864:         const { quest, totalTasks, doneTasks, completionPct } = item.summary;\n865: \n866:         // Status badge\n867:         const sColor = STATUS_COLORS[quest.status] ?? \"white\";\n868:         const sAbbr = STATUS_ABBREV[quest.status] ?? quest.status.slice(0, 4).toUpperCase();\n869:         const statusBadge = `{${sColor}-fg}${sAbbr}{/${sColor}-fg}`;\n870: \n871:         // Priority\n872:         const pColor = PRIORITY_COLORS[quest.priority] ?? \"white\";\n873:         const priorityDot = `{${pColor}-fg}\\u25CF{/${pColor}-fg}`;\n874: \n875:         // Title (truncated)\n876:         const maxTitleLen = 28;\n877:         const title = quest.title.length > maxTitleLen\n878:           ? quest.title.slice(0, maxTitleLen - 1) + \"\\u2026\"\n879:           : quest.title;\n880: \n881:         // Completion bar\n882:         const barWidth = 8;\n883:         const filled = Math.round((completionPct / 100) * barWidth);\n884:         const empty = barWidth - filled;\n885:         const bar = `{green-fg}${\"#\".repeat(filled)}{/green-fg}{gray-fg}${\"-\".repeat(empty)}{/gray-fg}`;\n886: \n887:         // Task count\n888:         const taskInfo = totalTasks > 0\n889:           ? `{gray-fg}${doneTasks}/${totalTasks}{/gray-fg}`\n890:           : `{gray-fg}0 tasks{/gray-fg}`;\n891: \n892:         listItems.push(\n893:           ` ${priorityDot} ${statusBadge} ${escapeBlessedTags(title)}  [${bar}] ${taskInfo}`\n894:         );\n895:       }\n896:     }\n897: \n898:     if (listItems.length === 0) {\n899:       listItems.push(\" {gray-fg}No quests found{/gray-fg}\");\n900:     }\n901: \n902:     const prevSelected = this.selectedIndex;\n903:     this.questList.setItems(listItems as any);\n904:     if (prevSelected < listItems.length) {\n905:       this.questList.select(prevSelected);\n906:     }\n907:   }\n908: \n909:   private refreshDetail(): void {\n910:     const item = this.items[this.selectedIndex];\n911:     if (!item) {\n912:       this.detailBox.setContent(\"{gray-fg}No item selected{/gray-fg}\");\n913:       this.detailBox.setLabel(\" Details \");\n914:       return;\n915:     }\n916: \n917:     if (item.type === \"all\") {\n918:       const lines: string[] = [\n919:         \"{bold}{cyan-fg}All Tasks{/cyan-fg}{/bold}\",\n920:         \"\",\n921:         \"  Browse all tasks across all quests\",\n922:         \"  and unassigned tasks.\",\n923:         \"\",\n924:         `  Total: {white-fg}${this.totalTaskCount}{/white-fg} tasks`,\n925:         \"\",\n926:         \"  Press {bold}Enter{/bold} to open the full task browser.\",\n927:       ];\n928:       this.detailBox.setContent(lines.join(\"\\n\"));\n929:       this.detailBox.setLabel(\" All Tasks \");\n930:       return;\n931:     }\n932: \n933:     const { quest, totalTasks, doneTasks, completionPct } = item.summary;\n934:     const lines: string[] = [];\n935: \n936:     // Title\n937:     lines.push(`{bold}{white-fg}${escapeBlessedTags(quest.title)}{/white-fg}{/bold}`);\n938:     lines.push(\"\");\n939: \n940:     // Status\n941:     const sColor = STATUS_COLORS[quest.status] ?? \"white\";\n942:     lines.push(`  Status:     {${sColor}-fg}${quest.status}{/${sColor}-fg}`);\n943: \n944:     // Priority\n945:     const pColor = PRIORITY_COLORS[quest.priority] ?? \"white\";\n946:     lines.push(`  Priority:   {${pColor}-fg}${quest.priority}{/${pColor}-fg}`);\n947: \n948:     // Difficulty\n949:     lines.push(`  Difficulty: ${quest.difficulty}`);\n950: \n951:     // HITL mode\n952:     lines.push(`  HITL:       ${quest.hitlMode}`);\n953:     lines.push(\"\");\n954: \n955:     // Task progress\n956:     if (totalTasks > 0) {\n957:       lines.push(\"{bold}Progress:{/bold}\");\n958:       lines.push(`  Tasks: ${doneTasks}/${totalTasks} done (${completionPct}%)`);\n959: \n960:       // Progress bar (wider in detail view)\n961:       const barWidth = 20;\n962:       const filled = Math.round((completionPct / 100) * barWidth);\n963:       const empty = barWidth - filled;\n964:       const bar = `{green-fg}${\"=\".repeat(filled)}{/green-fg}{gray-fg}${\"-\".repeat(empty)}{/gray-fg}`;\n965:       lines.push(`  [${bar}]`);\n966:     } else {\n967:       lines.push(\"{bold}Progress:{/bold}\");\n968:       lines.push(\"  {gray-fg}No tasks assigned{/gray-fg}\");\n969:     }\n970:     lines.push(\"\");\n971: \n972:     // Goal\n973:     if (quest.goal) {\n974:       lines.push(\"{bold}Goal:{/bold}\");\n975:       const goalText = escapeBlessedTags(quest.goal.trim());\n976:       const words = goalText.split(/\\s+/);\n977:       let line = \" \";\n978:       for (const w of words) {\n979:         if (line.length + w.length > 42) {\n980:           lines.push(line);\n981:           line = \" \" + w;\n982:         } else {\n983:           line += \" \" + w;\n984:         }\n985:       }\n986:       if (line.trim()) lines.push(line);\n987:       lines.push(\"\");\n988:     }\n989: \n990:     // Branch\n991:     lines.push(\"{bold}Branch:{/bold}\");\n992:     lines.push(`  ${quest.branch}`);\n993:     lines.push(`  Base: ${quest.baseBranch}`);\n994:     lines.push(\"\");\n995: \n996:     // Constraints\n997:     if (quest.constraints.add.length > 0) {\n998:       lines.push(\"{bold}Added Constraints:{/bold}\");\n999:       for (const c of quest.constraints.add) {\n1000:         lines.push(`  + ${escapeBlessedTags(c)}`);\n1001:       }\n1002:       lines.push(\"\");\n1003:     }\n1004:     if (quest.constraints.ban.length > 0) {\n1005:       lines.push(\"{bold}Banned:{/bold}\");\n1006:       for (const b of quest.constraints.ban) {\n1007:         lines.push(`  - ${escapeBlessedTags(b)}`);\n1008:       }\n1009:       lines.push(\"\");\n1010:     }\n1011: \n1012:     // Dependencies\n1013:     if (quest.depends_on.length > 0) {\n1014:       lines.push(\"{bold}Depends on:{/bold}\");\n1015:       for (const d of quest.depends_on) {\n1016:         lines.push(`  \\u2192 ${d}`);\n1017:       }\n1018:       lines.push(\"\");\n1019:     }\n1020: \n1021:     // Notes\n1022:     if (quest.notes.length > 0) {\n1023:       lines.push(\"{bold}Notes:{/bold}\");\n1024:       for (const n of quest.notes) {\n1025:         lines.push(`  ${escapeBlessedTags(n)}`);\n1026:       }\n1027:       lines.push(\"\");\n1028:     }\n1029: \n1030:     // Timestamps\n1031:     lines.push(\"{bold}Timeline:{/bold}\");\n1032:     lines.push(`  Created: ${quest.created_at.slice(0, 10)}`);\n1033:     if (quest.started_at) lines.push(`  Started: ${quest.started_at.slice(0, 10)}`);\n1034:     if (quest.ended_at) lines.push(`  Ended:   ${quest.ended_at.slice(0, 10)}`);\n1035: \n1036:     this.detailBox.setContent(lines.join(\"\\n\"));\n1037:     this.detailBox.setLabel(` ${quest.id} `);\n1038:   }\n1039: \n1040:   private refreshStatusBar(): void {\n1041:     let line1 = ` {bold}Keys:{/bold}`;\n1042:     line1 += `  {gray-fg}Enter{/gray-fg} select`;\n1043:     line1 += `  {gray-fg}C{/gray-fg} create`;\n1044:     line1 += `  {gray-fg}E{/gray-fg} errand`;\n1045:     line1 += `  {gray-fg}P{/gray-fg} plan`;\n1046:     line1 += `  {gray-fg}G{/gray-fg} genesis`;\n1047:     line1 += `  {gray-fg}A{/gray-fg} activate/pause`;\n1048:     line1 += `  {gray-fg}W{/gray-fg} wishlist`;\n1049:     line1 += `  {gray-fg}Q{/gray-fg} quit`;\n1050: \n1051:     const item = this.items[this.selectedIndex];\n1052:     let line2 = \" \";\n1053:     if (item?.type === \"all\") {\n1054:       line2 += `{cyan-fg}View all tasks across all quests{/cyan-fg}`;\n1055:     } else if (item?.type === \"quest\") {\n1056:       const q = item.summary.quest;\n1057:       line2 += `{white-fg}${escapeBlessedTags(q.id)}{/white-fg}`;\n1058:       line2 += `  {gray-fg}|{/gray-fg}  ${item.summary.totalTasks} task${item.summary.totalTasks !== 1 ? \"s\" : \"\"}`;\n1059:       line2 += `  {gray-fg}|{/gray-fg}  ${item.summary.completionPct}% complete`;\n1060:       if (q.status === \"draft\" || q.status === \"planning\") {\n1061:         line2 += `  {gray-fg}|{/gray-fg}  {magenta-fg}P to plan{/magenta-fg}`;\n1062:       }\n1063:     }\n1064: \n1065:     this.statusBar.setContent(`${line1}\\n${line2}`);\n1066:   }\n1067: }\n\n(End of file - total 1067 lines)\n</content>","title":"src/lib/tui-quest-picker.ts","metadata":{"preview":"/**\n * tui-quest-picker.ts -- Quest picker view for the wombo-combo TUI.\n *\n * Shows all quests as a selectable list with an \"All Tasks\" option at the top.\n * Selecting a quest navigates to the Task Browser filtered to that quest's tasks.\n *\n * Layout:\n *   +-----------------------------------------------------------+\n *   | WOMBO-COMBO Quest Picker  | 4 quests                      |\n *   +---------------------------+-------------------------------+\n *   | > All Tasks (42)          | Quest: auth-overhaul           |\n *   |   auth-overhaul   ACTV    | Status: active                 |\n *   |   search-api      DRFT    | Priority: high                 |\n *   |   perf-optim      PAUS    | Tasks: 8 (3 done, 62%)         |\n *   |   ui-redesign     PLAN    | Goal: Replace basic auth...    |\n *   |                           |                                |\n *   +---------------------------+-------------------------------+\n *   | Enter:select  C:create  Q:quit                            |\n *   +-----------------------------------------------------------+\n *","truncated":false,"loaded":[]},"time":{"start":1773483376315,"end":1773483376318}}}}
