{"type":"text","timestamp":1773483616079,"sessionID":"ses_3142777b4ffe3IuXz7qBZaextx","part":{"id":"prt_cebdc5c72001RleqqzMia5bYGN","sessionID":"ses_3142777b4ffe3IuXz7qBZaextx","messageID":"msg_cebdc5508001yfoQcAvGDAWpdZ","type":"text","text":"Now let me implement the dedicated usage overlay (U keybind) in the Task Browser. This should be a blessed overlay that shows overall and per-task usage breakdown. Let me look at how the WishlistOverlay pattern works, since it's already an overlay in the browser:","time":{"start":1773483616079,"end":1773483616079}}}
{"type":"tool_use","timestamp":1773483616082,"sessionID":"ses_3142777b4ffe3IuXz7qBZaextx","part":{"id":"prt_cebdc63ae0018C0SM3BKhBgV7C","sessionID":"ses_3142777b4ffe3IuXz7qBZaextx","messageID":"msg_cebdc5508001yfoQcAvGDAWpdZ","type":"tool","callID":"toolu_vrtx_012RdHYogncEkQxmNyEPvbET","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/token-tui/src/lib/tui-wishlist.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/token-tui/src/lib/tui-wishlist.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tui-wishlist.ts -- Wishlist views for the wombo-combo TUI.\n3:  *\n4:  * Contains two complementary views:\n5:  *\n6:  * 1. WishlistPicker — Full-screen standalone TUI for browsing and promoting\n7:  *    wishlist items to errands (E key) or genesis input (G key). After\n8:  *    promotion, the user is asked whether to delete the wishlist item.\n9:  *\n10:  *    Layout:\n11:  *      ┌───────────────────────────────────────────────────────┐\n12:  *      │ WOMBO-COMBO Wishlist  │ 5 items                      │\n13:  *      ├──────────────────────────┬────────────────────────────┤\n14:  *      │ • Fix login timeout...   │ Text: Fix login timeout    │\n15:  *      │ • Add dark mode support  │   for SSO users on slow    │\n16:  *      │ • Refactor DB layer      │   connections               │\n17:  *      │ • Update docs for v2     │                             │\n18:  *      │                          │ Tags: auth, ux              │\n19:  *      │                          │ Created: 2025-01-15         │\n20:  *      ├──────────────────────────┴────────────────────────────┤\n21:  *      │ E:errand  G:genesis  D:delete  Esc:back  Q:quit      │\n22:  *      └───────────────────────────────────────────────────────┘\n23:  *\n24:  *    Keybinds:\n25:  *      E         — promote selected item to errand (pre-fill description)\n26:  *      G         — promote selected item to genesis (pre-fill vision)\n27:  *      D / Del   — delete selected item\n28:  *      Esc / Q   — go back to quest picker\n29:  *\n30:  * 2. WishlistOverlay — Modal popup overlay for quick wishlist browsing and\n31:  *    adding items. Accessible via W key from Quest Picker and Task Browser.\n32:  *\n33:  *    Layout:\n34:  *      +----------------------------------------------+\n35:  *      | Wishlist (3 items)                            |\n36:  *      +----------------------------------------------+\n37:  *      | > Buy new keyboard           2025-12-01      |\n38:  *      |   Research TUI frameworks    2025-12-05      |\n39:  *      |   Add dark mode support      2025-12-10      |\n40:  *      +----------------------------------------------+\n41:  *      | [____________________________________]       |\n42:  *      +----------------------------------------------+\n43:  *      | A:add  D/X:delete  Esc/W:close               |\n44:  *      +----------------------------------------------+\n45:  *\n46:  *    Keybinds:\n47:  *      Up/Down   -- navigate items\n48:  *      A         -- add new item (textarea input)\n49:  *      D / X     -- delete selected item\n50:  *      Escape/W  -- close the overlay\n51:  */\n52: \n53: import blessed from \"neo-blessed\";\n54: import type { Widgets } from \"neo-blessed\";\n55: import type { WishlistItem } from \"./wishlist-store.js\";\n56: import { loadWishlist, addItem, deleteItem } from \"./wishlist-store.js\";\n57: \n58: // ---------------------------------------------------------------------------\n59: // Types\n60: // ---------------------------------------------------------------------------\n61: \n62: export type WishlistAction =\n63:   | { type: \"promote-errand\"; item: WishlistItem }\n64:   | { type: \"promote-genesis\"; item: WishlistItem }\n65:   | { type: \"back\" }\n66:   | { type: \"quit\" };\n67: \n68: export interface WishlistPickerOptions {\n69:   projectRoot: string;\n70:   onPromoteErrand: (item: WishlistItem) => void;\n71:   onPromoteGenesis: (item: WishlistItem) => void;\n72:   onBack: () => void;\n73:   onQuit: () => void;\n74: }\n75: \n76: export interface WishlistOverlayCallbacks {\n77:   /** Called when the overlay is closed (Esc or W). */\n78:   onClose: () => void;\n79: }\n80: \n81: // ---------------------------------------------------------------------------\n82: // Helpers\n83: // ---------------------------------------------------------------------------\n84: \n85: function escapeBlessedTags(text: string): string {\n86:   return text.replace(/\\{/g, \"\\uFF5B\").replace(/\\}/g, \"\\uFF5D\");\n87: }\n88: \n89: function formatDate(isoTimestamp: string): string {\n90:   try {\n91:     return isoTimestamp.slice(0, 10);\n92:   } catch {\n93:     return \"unknown\";\n94:   }\n95: }\n96: \n97: // ---------------------------------------------------------------------------\n98: // WishlistPicker Class (full-screen, promotion flow)\n99: // ---------------------------------------------------------------------------\n100: \n101: export class WishlistPicker {\n102:   private screen: Widgets.Screen;\n103:   private headerBox: Widgets.BoxElement;\n104:   private itemList: Widgets.ListElement;\n105:   private detailBox: Widgets.BoxElement;\n106:   private statusBar: Widgets.BoxElement;\n107: \n108:   private projectRoot: string;\n109:   private onPromoteErrand: (item: WishlistItem) => void;\n110:   private onPromoteGenesis: (item: WishlistItem) => void;\n111:   private onBack: () => void;\n112:   private onQuit: () => void;\n113: \n114:   private items: WishlistItem[] = [];\n115:   private selectedIndex: number = 0;\n116: \n117:   constructor(opts: WishlistPickerOptions) {\n118:     this.projectRoot = opts.projectRoot;\n119:     this.onPromoteErrand = opts.onPromoteErrand;\n120:     this.onPromoteGenesis = opts.onPromoteGenesis;\n121:     this.onBack = opts.onBack;\n122:     this.onQuit = opts.onQuit;\n123: \n124:     this.loadItems();\n125: \n126:     // Create screen\n127:     this.screen = blessed.screen({\n128:       smartCSR: true,\n129:       title: \"wombo-combo -- Wishlist\",\n130:       fullUnicode: true,\n131:     });\n132: \n133:     // Header\n134:     this.headerBox = blessed.box({\n135:       top: 0,\n136:       left: 0,\n137:       width: \"100%\",\n138:       height: 3,\n139:       tags: true,\n140:       style: { fg: \"white\", bg: \"black\" },\n141:     });\n142: \n143:     // Item list (left pane)\n144:     this.itemList = blessed.list({\n145:       top: 3,\n146:       left: 0,\n147:       width: \"50%\",\n148:       height: \"100%-6\",\n149:       tags: true,\n150:       scrollable: true,\n151:       mouse: true,\n152:       keys: true,\n153:       vi: true,\n154:       border: { type: \"line\" },\n155:       style: {\n156:         border: { fg: \"gray\" },\n157:         selected: { bg: \"blue\", fg: \"white\", bold: true },\n158:         item: { fg: \"white\" },\n159:       },\n160:       label: \" Wishlist \",\n161:     });\n162: \n163:     // Detail pane (right pane)\n164:     this.detailBox = blessed.box({\n165:       top: 3,\n166:       left: \"50%\",\n167:       width: \"50%\",\n168:       height: \"100%-6\",\n169:       tags: true,\n170:       scrollable: true,\n171:       mouse: true,\n172:       border: { type: \"line\" },\n173:       style: {\n174:         border: { fg: \"gray\" },\n175:         fg: \"white\",\n176:       },\n177:       label: \" Details \",\n178:     });\n179: \n180:     // Status bar\n181:     this.statusBar = blessed.box({\n182:       bottom: 0,\n183:       left: 0,\n184:       width: \"100%\",\n185:       height: 3,\n186:       tags: true,\n187:       style: { fg: \"white\", bg: \"black\" },\n188:     });\n189: \n190:     // Assemble\n191:     this.screen.append(this.headerBox);\n192:     this.screen.append(this.itemList);\n193:     this.screen.append(this.detailBox);\n194:     this.screen.append(this.statusBar);\n195:     this.itemList.focus();\n196: \n197:     this.bindKeys();\n198:   }\n199: \n200:   // -----------------------------------------------------------------------\n201:   // Public API\n202:   // -----------------------------------------------------------------------\n203: \n204:   start(): void {\n205:     this.refreshAll();\n206:     this.screen.render();\n207:   }\n208: \n209:   stop(): void {\n210:     this.screen.destroy();\n211:   }\n212: \n213:   destroy(): void {\n214:     this.screen.destroy();\n215:     process.stdout.write(\"\\x1B[2J\\x1B[H\");\n216:   }\n217: \n218:   // -----------------------------------------------------------------------\n219:   // Data Loading\n220:   // -----------------------------------------------------------------------\n221: \n222:   private loadItems(): void {\n223:     this.items = loadWishlist(this.projectRoot);\n224:   }\n225: \n226:   // -----------------------------------------------------------------------\n227:   // Key Bindings\n228:   // -----------------------------------------------------------------------\n229: \n230:   private bindKeys(): void {\n231:     // Quit\n232:     this.screen.key([\"q\", \"C-c\"], () => {\n233:       this.stop();\n234:       this.onQuit();\n235:     });\n236: \n237:     // Escape -- go back\n238:     this.screen.key([\"escape\"], () => {\n239:       this.destroy();\n240:       this.onBack();\n241:     });\n242: \n243:     // Navigate\n244:     this.itemList.on(\"select item\", (_item: any, index: number) => {\n245:       this.selectedIndex = index;\n246:       this.refreshDetail();\n247:       this.screen.render();\n248:     });\n249: \n250:     // E -- promote to errand\n251:     this.screen.key([\"e\"], () => {\n252:       this.promoteToErrand();\n253:     });\n254: \n255:     // G -- promote to genesis\n256:     this.screen.key([\"g\"], () => {\n257:       this.promoteToGenesis();\n258:     });\n259: \n260:     // D / Delete -- delete item\n261:     this.screen.key([\"d\", \"delete\"], () => {\n262:       this.deleteSelected();\n263:     });\n264:   }\n265: \n266:   // -----------------------------------------------------------------------\n267:   // Actions\n268:   // -----------------------------------------------------------------------\n269: \n270:   private promoteToErrand(): void {\n271:     const item = this.items[this.selectedIndex];\n272:     if (!item) return;\n273: \n274:     this.destroy();\n275:     this.onPromoteErrand(item);\n276:   }\n277: \n278:   private promoteToGenesis(): void {\n279:     const item = this.items[this.selectedIndex];\n280:     if (!item) return;\n281: \n282:     this.destroy();\n283:     this.onPromoteGenesis(item);\n284:   }\n285: \n286:   private deleteSelected(): void {\n287:     const item = this.items[this.selectedIndex];\n288:     if (!item) return;\n289: \n290:     deleteItem(this.projectRoot, item.id);\n291:     this.loadItems();\n292:     this.selectedIndex = Math.min(\n293:       this.selectedIndex,\n294:       Math.max(0, this.items.length - 1)\n295:     );\n296:     this.refreshAll();\n297:     this.screen.render();\n298:   }\n299: \n300:   // -----------------------------------------------------------------------\n301:   // Refresh Logic\n302:   // -----------------------------------------------------------------------\n303: \n304:   private refreshAll(): void {\n305:     this.refreshHeader();\n306:     this.refreshList();\n307:     this.refreshDetail();\n308:     this.refreshStatusBar();\n309:   }\n310: \n311:   private refreshHeader(): void {\n312:     const count = this.items.length;\n313:     let line1 = ` {bold}wombo-combo{/bold} {yellow-fg}Wishlist{/yellow-fg}`;\n314:     line1 += `  {gray-fg}|{/gray-fg}  {white-fg}${count}{/white-fg} item${count !== 1 ? \"s\" : \"\"}`;\n315: \n316:     let line2 = ` {gray-fg}Promote items to errands or genesis quests{/gray-fg}`;\n317: \n318:     this.headerBox.setContent(`${line1}\\n${line2}`);\n319:   }\n320: \n321:   private refreshList(): void {\n322:     const listItems: string[] = [];\n323: \n324:     for (const item of this.items) {\n325:       // Truncate text for list display\n326:       const maxLen = 40;\n327:       const text = item.text.length > maxLen\n328:         ? item.text.slice(0, maxLen - 1) + \"\\u2026\"\n329:         : item.text;\n330: \n331:       // Tags badge\n332:       const tagsBadge = item.tags.length > 0\n333:         ? ` {gray-fg}[${item.tags.join(\", \")}]{/gray-fg}`\n334:         : \"\";\n335: \n336:       // Date\n337:       const created = item.created_at.slice(0, 10);\n338: \n339:       listItems.push(\n340:         ` {yellow-fg}\\u2022{/yellow-fg} ${escapeBlessedTags(text)}${tagsBadge} {gray-fg}${created}{/gray-fg}`\n341:       );\n342:     }\n343: \n344:     if (listItems.length === 0) {\n345:       listItems.push(\" {gray-fg}No wishlist items{/gray-fg}\");\n346:     }\n347: \n348:     const prevSelected = this.selectedIndex;\n349:     this.itemList.setItems(listItems as any);\n350:     if (prevSelected < listItems.length) {\n351:       this.itemList.select(prevSelected);\n352:     }\n353:   }\n354: \n355:   private refreshDetail(): void {\n356:     const item = this.items[this.selectedIndex];\n357:     if (!item) {\n358:       this.detailBox.setContent(\"{gray-fg}No item selected{/gray-fg}\");\n359:       this.detailBox.setLabel(\" Details \");\n360:       return;\n361:     }\n362: \n363:     const lines: string[] = [];\n364: \n365:     // Full text\n366:     lines.push(\"{bold}{white-fg}Description:{/white-fg}{/bold}\");\n367:     // Word-wrap the text to roughly 42 chars\n368:     const text = escapeBlessedTags(item.text.trim());\n369:     const words = text.split(/\\s+/);\n370:     let line = \" \";\n371:     for (const w of words) {\n372:       if (line.length + w.length > 42) {\n373:         lines.push(line);\n374:         line = \" \" + w;\n375:       } else {\n376:         line += \" \" + w;\n377:       }\n378:     }\n379:     if (line.trim()) lines.push(line);\n380:     lines.push(\"\");\n381: \n382:     // Tags\n383:     if (item.tags.length > 0) {\n384:       lines.push(\"{bold}Tags:{/bold}\");\n385:       lines.push(`  ${item.tags.map((t) => `{cyan-fg}${escapeBlessedTags(t)}{/cyan-fg}`).join(\"  \")}`);\n386:       lines.push(\"\");\n387:     }\n388: \n389:     // Created date\n390:     lines.push(\"{bold}Created:{/bold}\");\n391:     lines.push(`  ${item.created_at.slice(0, 10)} ${item.created_at.slice(11, 19)}`);\n392:     lines.push(\"\");\n393: \n394:     // ID\n395:     lines.push(\"{bold}ID:{/bold}\");\n396:     lines.push(`  {gray-fg}${item.id}{/gray-fg}`);\n397:     lines.push(\"\");\n398: \n399:     // Promotion hints\n400:     lines.push(\"{bold}Promote:{/bold}\");\n401:     lines.push(\"  {green-fg}E{/green-fg} \\u2192 Create errand from this item\");\n402:     lines.push(\"  {magenta-fg}G{/magenta-fg} \\u2192 Use as genesis vision\");\n403: \n404:     this.detailBox.setContent(lines.join(\"\\n\"));\n405:     this.detailBox.setLabel(` Item ${this.selectedIndex + 1}/${this.items.length} `);\n406:   }\n407: \n408:   private refreshStatusBar(): void {\n409:     let line1 = ` {bold}Keys:{/bold}`;\n410:     line1 += `  {gray-fg}E{/gray-fg} promote to errand`;\n411:     line1 += `  {gray-fg}G{/gray-fg} promote to genesis`;\n412:     line1 += `  {gray-fg}D{/gray-fg} delete`;\n413:     line1 += `  {gray-fg}Esc{/gray-fg} back`;\n414:     line1 += `  {gray-fg}Q{/gray-fg} quit`;\n415: \n416:     let line2 = ` `;\n417:     const item = this.items[this.selectedIndex];\n418:     if (item) {\n419:       const truncText = item.text.length > 60\n420:         ? item.text.slice(0, 57) + \"...\"\n421:         : item.text;\n422:       line2 += `{white-fg}${escapeBlessedTags(truncText)}{/white-fg}`;\n423:     } else {\n424:       line2 += `{gray-fg}Add items with: woco wishlist add \"your idea\"{/gray-fg}`;\n425:     }\n426: \n427:     this.statusBar.setContent(`${line1}\\n${line2}`);\n428:   }\n429: }\n430: \n431: // ---------------------------------------------------------------------------\n432: // WishlistOverlay (modal popup, add/delete/browse)\n433: // ---------------------------------------------------------------------------\n434: \n435: export class WishlistOverlay {\n436:   private modal: Widgets.BoxElement;\n437:   private itemList: Widgets.ListElement;\n438:   private inputBox: Widgets.TextboxElement;\n439:   private footerBox: Widgets.BoxElement;\n440: \n441:   private screen: Widgets.Screen;\n442:   private projectRoot: string;\n443:   private callbacks: WishlistOverlayCallbacks;\n444:   private destroyed: boolean = false;\n445:   private items: WishlistItem[] = [];\n446:   private selectedIndex: number = 0;\n447:   private addingItem: boolean = false;\n448: \n449:   constructor(\n450:     screen: Widgets.Screen,\n451:     projectRoot: string,\n452:     callbacks: WishlistOverlayCallbacks\n453:   ) {\n454:     this.screen = screen;\n455:     this.projectRoot = projectRoot;\n456:     this.callbacks = callbacks;\n457: \n458:     // Load initial items\n459:     this.items = loadWishlist(projectRoot);\n460: \n461:     // --- Modal container ---\n462:     this.modal = blessed.box({\n463:       parent: screen,\n464:       top: \"center\",\n465:       left: \"center\",\n466:       width: \"75%\",\n467:       height: \"80%\",\n468:       tags: true,\n469:       border: { type: \"line\" },\n470:       style: {\n471:         border: { fg: \"magenta\" },\n472:         fg: \"white\",\n473:         bg: \"black\",\n474:       },\n475:       label: this.buildLabel(),\n476:       shadow: true,\n477:     });\n478: \n479:     // --- Scrollable item list ---\n480:     this.itemList = blessed.list({\n481:       parent: this.modal,\n482:       top: 0,\n483:       left: 1,\n484:       right: 1,\n485:       height: \"100%-7\",\n486:       tags: true,\n487:       scrollable: true,\n488:       mouse: true,\n489:       keys: true,\n490:       vi: true,\n491:       scrollbar: {\n492:         ch: \"\\u2502\",\n493:         style: { fg: \"magenta\" },\n494:       },\n495:       style: {\n496:         selected: { bg: \"blue\", fg: \"white\", bold: true },\n497:         item: { fg: \"white\" },\n498:         bg: \"black\",\n499:       },\n500:     });\n501: \n502:     // --- Text input for adding new items ---\n503:     this.inputBox = blessed.textbox({\n504:       parent: this.modal,\n505:       bottom: 2,\n506:       left: 1,\n507:       right: 1,\n508:       height: 3,\n509:       border: { type: \"line\" },\n510:       style: {\n511:         border: { fg: \"gray\" },\n512:         fg: \"white\",\n513:         bg: \"black\",\n514:         focus: { border: { fg: \"magenta\" } },\n515:       },\n516:       inputOnFocus: true,\n517:       hidden: true,\n518:     });\n519: \n520:     // --- Footer: keybind hints ---\n521:     this.footerBox = blessed.box({\n522:       parent: this.modal,\n523:       bottom: 0,\n524:       left: 1,\n525:       right: 1,\n526:       height: 1,\n527:       tags: true,\n528:       style: { fg: \"gray\", bg: \"black\" },\n529:     });\n530: \n531:     this.refreshList();\n532:     this.refreshFooter();\n533:     this.bindKeys();\n534:     this.itemList.focus();\n535:     this.screen.render();\n536:   }\n537: \n538:   // -------------------------------------------------------------------------\n539:   // Key Bindings\n540:   // -------------------------------------------------------------------------\n541: \n542:   private bindKeys(): void {\n543:     // Navigate — track selection changes\n544:     this.itemList.on(\"select item\", (_item: any, index: number) => {\n545:       this.selectedIndex = index;\n546:     });\n547: \n548:     // Close overlay with Escape or W\n549:     this.itemList.key([\"escape\", \"w\"], () => {\n550:       if (this.addingItem) return;\n551:       this.close();\n552:     });\n553: \n554:     // A — add new item\n555:     this.itemList.key([\"a\"], () => {\n556:       if (this.addingItem) return;\n557:       this.showAddInput();\n558:     });\n559: \n560:     // D or X — delete selected item\n561:     this.itemList.key([\"d\", \"x\"], () => {\n562:       if (this.addingItem) return;\n563:       this.deleteSelected();\n564:     });\n565: \n566:     // --- Input box bindings ---\n567:     this.inputBox.on(\"submit\", (value: string) => {\n568:       this.submitNewItem(value);\n569:     });\n570: \n571:     this.inputBox.on(\"cancel\", () => {\n572:       this.hideAddInput();\n573:     });\n574:   }\n575: \n576:   // -------------------------------------------------------------------------\n577:   // Rendering\n578:   // -------------------------------------------------------------------------\n579: \n580:   private buildLabel(): string {\n581:     const count = this.items.length;\n582:     return ` {magenta-fg}Wishlist{/magenta-fg} (${count} item${count !== 1 ? \"s\" : \"\"}) `;\n583:   }\n584: \n585:   private refreshList(): void {\n586:     if (this.items.length === 0) {\n587:       this.itemList.setItems([\n588:         \" {gray-fg}No wishlist items. Press A to add one.{/gray-fg}\",\n589:       ] as any);\n590:       return;\n591:     }\n592: \n593:     const listItems: string[] = [];\n594: \n595:     for (const item of this.items) {\n596:       const date = formatDate(item.created_at);\n597:       const text =\n598:         item.text.length > 50\n599:           ? item.text.slice(0, 49) + \"\\u2026\"\n600:           : item.text;\n601:       const tags =\n602:         item.tags.length > 0\n603:           ? ` {gray-fg}[${item.tags.join(\", \")}]{/gray-fg}`\n604:           : \"\";\n605: \n606:       listItems.push(\n607:         ` ${escapeBlessedTags(text)}${tags}  {gray-fg}${date}{/gray-fg}`\n608:       );\n609:     }\n610: \n611:     const prevSelected = this.selectedIndex;\n612:     this.itemList.setItems(listItems as any);\n613:     if (prevSelected < listItems.length) {\n614:       this.itemList.select(prevSelected);\n615:     } else if (listItems.length > 0) {\n616:       this.itemList.select(listItems.length - 1);\n617:       this.selectedIndex = listItems.length - 1;\n618:     }\n619:   }\n620: \n621:   private refreshFooter(): void {\n622:     if (this.addingItem) {\n623:       this.footerBox.setContent(\n624:         \" {gray-fg}Enter{/gray-fg} save  {gray-fg}Esc{/gray-fg} cancel\"\n625:       );\n626:     } else {\n627:       this.footerBox.setContent(\n628:         \" {gray-fg}A{/gray-fg} add  {gray-fg}D/X{/gray-fg} delete  {gray-fg}Esc/W{/gray-fg} close\"\n629:       );\n630:     }\n631:   }\n632: \n633:   // -------------------------------------------------------------------------\n634:   // Actions\n635:   // -------------------------------------------------------------------------\n636: \n637:   private showAddInput(): void {\n638:     this.addingItem = true;\n639:     this.inputBox.setValue(\"\");\n640:     this.inputBox.show();\n641:     this.inputBox.focus();\n642:     this.refreshFooter();\n643:     this.screen.render();\n644:   }\n645: \n646:   private hideAddInput(): void {\n647:     this.addingItem = false;\n648:     this.inputBox.hide();\n649:     this.inputBox.clearValue();\n650:     this.itemList.focus();\n651:     this.refreshFooter();\n652:     this.screen.render();\n653:   }\n654: \n655:   private submitNewItem(value: string): void {\n656:     const text = (value ?? \"\").trim();\n657:     if (!text) {\n658:       // Flash border red briefly to indicate empty input\n659:       this.inputBox.style.border = { fg: \"red\" } as any;\n660:       this.screen.render();\n661:       setTimeout(() => {\n662:         if (!this.destroyed) {\n663:           this.inputBox.style.border = { fg: \"gray\" } as any;\n664:           this.screen.render();\n665:         }\n666:       }, 500);\n667:       return;\n668:     }\n669: \n670:     // Add item to store\n671:     addItem(this.projectRoot, text);\n672: \n673:     // Reload items\n674:     this.items = loadWishlist(this.projectRoot);\n675: \n676:     // Select the newly added item (it's at the end)\n677:     this.selectedIndex = this.items.length - 1;\n678: \n679:     // Update display\n680:     this.hideAddInput();\n681:     this.refreshList();\n682:     this.modal.setLabel(this.buildLabel());\n683:     this.screen.render();\n684:   }\n685: \n686:   private deleteSelected(): void {\n687:     if (this.items.length === 0) return;\n688:     if (this.selectedIndex < 0 || this.selectedIndex >= this.items.length) return;\n689: \n690:     const item = this.items[this.selectedIndex];\n691:     deleteItem(this.projectRoot, item.id);\n692: \n693:     // Reload items\n694:     this.items = loadWishlist(this.projectRoot);\n695: \n696:     // Adjust selection\n697:     if (this.selectedIndex >= this.items.length && this.items.length > 0) {\n698:       this.selectedIndex = this.items.length - 1;\n699:     }\n700: \n701:     // Update display\n702:     this.refreshList();\n703:     this.modal.setLabel(this.buildLabel());\n704:     this.screen.render();\n705:   }\n706: \n707:   /**\n708:    * Close and destroy the overlay.\n709:    */\n710:   close(): void {\n711:     if (this.destroyed) return;\n712:     this.destroyed = true;\n713:     this.modal.destroy();\n714:     this.callbacks.onClose();\n715:     this.screen.render();\n716:   }\n717: \n718:   /**\n719:    * Whether the overlay has been destroyed.\n720:    */\n721:   isDestroyed(): boolean {\n722:     return this.destroyed;\n723:   }\n724: }\n\n(End of file - total 724 lines)\n</content>","title":"src/lib/tui-wishlist.ts","metadata":{"preview":"/**\n * tui-wishlist.ts -- Wishlist views for the wombo-combo TUI.\n *\n * Contains two complementary views:\n *\n * 1. WishlistPicker — Full-screen standalone TUI for browsing and promoting\n *    wishlist items to errands (E key) or genesis input (G key). After\n *    promotion, the user is asked whether to delete the wishlist item.\n *\n *    Layout:\n *      ┌───────────────────────────────────────────────────────┐\n *      │ WOMBO-COMBO Wishlist  │ 5 items                      │\n *      ├──────────────────────────┬────────────────────────────┤\n *      │ • Fix login timeout...   │ Text: Fix login timeout    │\n *      │ • Add dark mode support  │   for SSO users on slow    │\n *      │ • Refactor DB layer      │   connections               │\n *      │ • Update docs for v2     │                             │\n *      │                          │ Tags: auth, ux              │\n *      │                          │ Created: 2025-01-15         │\n *      ├──────────────────────────┴────────────────────────────┤","truncated":false,"loaded":[]},"time":{"start":1773483616078,"end":1773483616081}}}}
