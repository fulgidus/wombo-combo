{"type":"tool_use","timestamp":1773482657591,"sessionID":"ses_3143284c2ffeAaKW1jZQzt4vTf","part":{"id":"prt_cebcdc20e001NR1U6Z1mbHuTnQ","sessionID":"ses_3143284c2ffeAaKW1jZQzt4vTf","messageID":"msg_cebcdb4f8001MQsCqMDErCjqmf","type":"tool","callID":"toolu_vrtx_01NrJEVRJWJcyVQXTjpENwYA","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/wishlist-tui/src/lib/tui-question-popup.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/wishlist-tui/src/lib/tui-question-popup.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tui-question-popup.ts — Modal overlay for answering agent HITL questions.\n3:  *\n4:  * Shows a queue of pending questions from agents. The human can navigate\n5:  * between questions (when multiple agents are waiting) and type an answer.\n6:  *\n7:  * Layout:\n8:  *   +----------------------------------------------+\n9:  *   | ? HITL Questions (2 pending)                  |\n10:  *   +----------------------------------------------+\n11:  *   | Agent: my-feature-task                        |\n12:  *   | Asked: 2 minutes ago                          |\n13:  *   +----------------------------------------------+\n14:  *   | Question:                                     |\n15:  *   | How should I handle the edge case where the   |\n16:  *   | user provides an empty array?                 |\n17:  *   |                                               |\n18:  *   | Context:                                      |\n19:  *   | Working on input validation in parser.ts      |\n20:  *   +----------------------------------------------+\n21:  *   | Your answer:                                  |\n22:  *   | [____________________________________]        |\n23:  *   +----------------------------------------------+\n24:  *   | Enter submit | Tab next | S-Tab prev | Esc    |\n25:  *   +----------------------------------------------+\n26:  */\n27: \n28: import blessed from \"neo-blessed\";\n29: import type { Widgets } from \"neo-blessed\";\n30: import type { HitlQuestion } from \"./hitl-channel.js\";\n31: \n32: // ---------------------------------------------------------------------------\n33: // Types\n34: // ---------------------------------------------------------------------------\n35: \n36: export interface QuestionPopupCallbacks {\n37:   /** Called when the user submits an answer to a question. */\n38:   onAnswer: (agentId: string, questionId: string, answerText: string) => void;\n39:   /** Called when the popup is closed (Esc). */\n40:   onClose: () => void;\n41: }\n42: \n43: // ---------------------------------------------------------------------------\n44: // Helpers\n45: // ---------------------------------------------------------------------------\n46: \n47: function escapeBlessedTags(text: string): string {\n48:   return text.replace(/\\{/g, \"\\uFF5B\").replace(/\\}/g, \"\\uFF5D\");\n49: }\n50: \n51: function timeAgo(isoTimestamp: string): string {\n52:   const diffMs = Date.now() - new Date(isoTimestamp).getTime();\n53:   const secs = Math.floor(diffMs / 1000);\n54:   if (secs < 60) return `${secs}s ago`;\n55:   const mins = Math.floor(secs / 60);\n56:   if (mins < 60) return `${mins}m ago`;\n57:   const hours = Math.floor(mins / 60);\n58:   return `${hours}h ${mins % 60}m ago`;\n59: }\n60: \n61: // ---------------------------------------------------------------------------\n62: // QuestionPopup\n63: // ---------------------------------------------------------------------------\n64: \n65: export class QuestionPopup {\n66:   private modal: Widgets.BoxElement;\n67:   private headerBox: Widgets.BoxElement;\n68:   private questionBox: Widgets.BoxElement;\n69:   private answerLabel: Widgets.BoxElement;\n70:   private answerInput: Widgets.TextareaElement;\n71:   private footerBox: Widgets.BoxElement;\n72: \n73:   private screen: Widgets.Screen;\n74:   private questions: HitlQuestion[];\n75:   private currentIndex: number = 0;\n76:   private callbacks: QuestionPopupCallbacks;\n77:   private destroyed: boolean = false;\n78: \n79:   constructor(\n80:     screen: Widgets.Screen,\n81:     questions: HitlQuestion[],\n82:     callbacks: QuestionPopupCallbacks\n83:   ) {\n84:     this.screen = screen;\n85:     this.questions = questions;\n86:     this.callbacks = callbacks;\n87: \n88:     // --- Modal container ---\n89:     this.modal = blessed.box({\n90:       parent: screen,\n91:       top: \"center\",\n92:       left: \"center\",\n93:       width: \"75%\",\n94:       height: \"80%\",\n95:       tags: true,\n96:       border: { type: \"line\" },\n97:       style: {\n98:         border: { fg: \"yellow\" },\n99:         fg: \"white\",\n100:         bg: \"black\",\n101:       },\n102:       label: this.buildLabel(),\n103:       shadow: true,\n104:     });\n105: \n106:     // --- Header: agent info ---\n107:     this.headerBox = blessed.box({\n108:       parent: this.modal,\n109:       top: 0,\n110:       left: 1,\n111:       right: 1,\n112:       height: 2,\n113:       tags: true,\n114:       style: { fg: \"white\", bg: \"black\" },\n115:     });\n116: \n117:     // --- Question display area ---\n118:     this.questionBox = blessed.box({\n119:       parent: this.modal,\n120:       top: 3,\n121:       left: 1,\n122:       right: 1,\n123:       height: \"100%-12\",\n124:       tags: true,\n125:       scrollable: true,\n126:       mouse: true,\n127:       scrollbar: {\n128:         ch: \"\\u2502\",\n129:         style: { fg: \"yellow\" },\n130:       },\n131:       style: {\n132:         fg: \"white\",\n133:         bg: \"black\",\n134:       },\n135:     });\n136: \n137:     // --- Answer label ---\n138:     this.answerLabel = blessed.box({\n139:       parent: this.modal,\n140:       bottom: 4,\n141:       left: 1,\n142:       right: 1,\n143:       height: 1,\n144:       tags: true,\n145:       style: { fg: \"yellow\", bg: \"black\" },\n146:       content: \" {bold}Your answer:{/bold}\",\n147:     });\n148: \n149:     // --- Answer text input ---\n150:     this.answerInput = blessed.textarea({\n151:       parent: this.modal,\n152:       bottom: 2,\n153:       left: 1,\n154:       right: 1,\n155:       height: 3,\n156:       border: { type: \"line\" },\n157:       style: {\n158:         border: { fg: \"cyan\" },\n159:         fg: \"white\",\n160:         bg: \"black\",\n161:         focus: { border: { fg: \"yellow\" } },\n162:       },\n163:       inputOnFocus: true,\n164:       mouse: true,\n165:       keys: true,\n166:     });\n167: \n168:     // --- Footer: keybind hints ---\n169:     this.footerBox = blessed.box({\n170:       parent: this.modal,\n171:       bottom: 0,\n172:       left: 1,\n173:       right: 1,\n174:       height: 1,\n175:       tags: true,\n176:       style: { fg: \"gray\", bg: \"black\" },\n177:     });\n178: \n179:     this.refreshContent();\n180:     this.bindKeys();\n181:     this.answerInput.focus();\n182:     this.screen.render();\n183:   }\n184: \n185:   // -------------------------------------------------------------------------\n186:   // Key Bindings\n187:   // -------------------------------------------------------------------------\n188: \n189:   private bindKeys(): void {\n190:     // Submit answer on C-s (Ctrl+S) — we can't intercept bare Enter inside\n191:     // a textarea (blessed uses it for newlines), so Ctrl+S is the submit key.\n192:     this.answerInput.key([\"C-s\"], () => {\n193:       this.submitCurrentAnswer();\n194:     });\n195: \n196:     // Also support Escape from the textarea to close\n197:     this.answerInput.key([\"escape\"], () => {\n198:       this.close();\n199:     });\n200: \n201:     // Tab — next question\n202:     this.answerInput.key([\"tab\"], () => {\n203:       if (this.questions.length > 1) {\n204:         this.currentIndex = (this.currentIndex + 1) % this.questions.length;\n205:         this.refreshContent();\n206:         this.screen.render();\n207:       }\n208:     });\n209: \n210:     // S-tab — previous question\n211:     this.answerInput.key([\"S-tab\"], () => {\n212:       if (this.questions.length > 1) {\n213:         this.currentIndex =\n214:           (this.currentIndex - 1 + this.questions.length) %\n215:           this.questions.length;\n216:         this.refreshContent();\n217:         this.screen.render();\n218:       }\n219:     });\n220: \n221:     // Escape on modal itself (if focus is somehow elsewhere)\n222:     this.modal.key([\"escape\"], () => {\n223:       this.close();\n224:     });\n225:   }\n226: \n227:   // -------------------------------------------------------------------------\n228:   // Rendering\n229:   // -------------------------------------------------------------------------\n230: \n231:   private buildLabel(): string {\n232:     const count = this.questions.length;\n233:     return ` {yellow-fg}? HITL Questions{/yellow-fg} (${count} pending) `;\n234:   }\n235: \n236:   private refreshContent(): void {\n237:     if (this.questions.length === 0) {\n238:       this.headerBox.setContent(\n239:         \"{gray-fg}No pending questions.{/gray-fg}\"\n240:       );\n241:       this.questionBox.setContent(\"\");\n242:       this.footerBox.setContent(\" {gray-fg}Esc{/gray-fg} close\");\n243:       return;\n244:     }\n245: \n246:     const q = this.questions[this.currentIndex];\n247: \n248:     // Header: agent info + timestamp\n249:     const agentLine = `{bold}Agent:{/bold} {cyan-fg}${escapeBlessedTags(q.agentId)}{/cyan-fg}`;\n250:     const timeLine = `{bold}Asked:{/bold} {gray-fg}${timeAgo(q.timestamp)}{/gray-fg}`;\n251:     this.headerBox.setContent(`${agentLine}    ${timeLine}`);\n252: \n253:     // Question body\n254:     let body = `{bold}{yellow-fg}Question:{/yellow-fg}{/bold}\\n`;\n255:     body += escapeBlessedTags(q.text);\n256: \n257:     if (q.context) {\n258:       body += `\\n\\n{bold}{gray-fg}Context:{/gray-fg}{/bold}\\n`;\n259:       body += `{gray-fg}${escapeBlessedTags(q.context)}{/gray-fg}`;\n260:     }\n261: \n262:     this.questionBox.setContent(body);\n263: \n264:     // Footer\n265:     const nav =\n266:       this.questions.length > 1\n267:         ? `{gray-fg}Tab{/gray-fg} next  {gray-fg}S-Tab{/gray-fg} prev  (${this.currentIndex + 1}/${this.questions.length})  `\n268:         : \"\";\n269:     this.footerBox.setContent(\n270:       ` ${nav}{gray-fg}Ctrl+S{/gray-fg} submit  {gray-fg}Esc{/gray-fg} close`\n271:     );\n272: \n273:     // Update label\n274:     this.modal.setLabel(this.buildLabel());\n275: \n276:     // Clear answer input\n277:     this.answerInput.clearValue();\n278:   }\n279: \n280:   // -------------------------------------------------------------------------\n281:   // Actions\n282:   // -------------------------------------------------------------------------\n283: \n284:   private submitCurrentAnswer(): void {\n285:     if (this.destroyed) return;\n286:     if (this.questions.length === 0) return;\n287: \n288:     const answerText = this.answerInput.getValue().trim();\n289:     if (!answerText) {\n290:       // Flash the border red briefly to indicate empty answer\n291:       this.answerInput.style.border = { fg: \"red\" } as any;\n292:       this.screen.render();\n293:       setTimeout(() => {\n294:         if (!this.destroyed) {\n295:           this.answerInput.style.border = { fg: \"cyan\" } as any;\n296:           this.screen.render();\n297:         }\n298:       }, 500);\n299:       return;\n300:     }\n301: \n302:     const q = this.questions[this.currentIndex];\n303: \n304:     // Fire callback\n305:     this.callbacks.onAnswer(q.agentId, q.id, answerText);\n306: \n307:     // Remove this question from the list\n308:     this.questions.splice(this.currentIndex, 1);\n309: \n310:     if (this.questions.length === 0) {\n311:       // No more questions — close popup\n312:       this.close();\n313:       return;\n314:     }\n315: \n316:     // Adjust index if needed\n317:     if (this.currentIndex >= this.questions.length) {\n318:       this.currentIndex = 0;\n319:     }\n320: \n321:     this.refreshContent();\n322:     this.answerInput.focus();\n323:     this.screen.render();\n324:   }\n325: \n326:   /**\n327:    * Update the question list (e.g. when new questions arrive while popup is open).\n328:    */\n329:   updateQuestions(questions: HitlQuestion[]): void {\n330:     if (this.destroyed) return;\n331: \n332:     // Preserve current question selection if possible\n333:     const currentQ =\n334:       this.questions.length > 0\n335:         ? this.questions[this.currentIndex]\n336:         : null;\n337: \n338:     this.questions = questions;\n339: \n340:     if (currentQ) {\n341:       // Try to find the same question in the new list\n342:       const idx = questions.findIndex(\n343:         (q) => q.id === currentQ.id && q.agentId === currentQ.agentId\n344:       );\n345:       this.currentIndex = idx >= 0 ? idx : 0;\n346:     } else {\n347:       this.currentIndex = 0;\n348:     }\n349: \n350:     this.refreshContent();\n351:     this.modal.setLabel(this.buildLabel());\n352:     this.screen.render();\n353:   }\n354: \n355:   /**\n356:    * Close and destroy the popup.\n357:    */\n358:   close(): void {\n359:     if (this.destroyed) return;\n360:     this.destroyed = true;\n361:     this.modal.destroy();\n362:     this.callbacks.onClose();\n363:     this.screen.render();\n364:   }\n365: \n366:   /**\n367:    * Whether the popup has been destroyed.\n368:    */\n369:   isDestroyed(): boolean {\n370:     return this.destroyed;\n371:   }\n372: }\n\n(End of file - total 372 lines)\n</content>","title":"src/lib/tui-question-popup.ts","metadata":{"preview":"/**\n * tui-question-popup.ts — Modal overlay for answering agent HITL questions.\n *\n * Shows a queue of pending questions from agents. The human can navigate\n * between questions (when multiple agents are waiting) and type an answer.\n *\n * Layout:\n *   +----------------------------------------------+\n *   | ? HITL Questions (2 pending)                  |\n *   +----------------------------------------------+\n *   | Agent: my-feature-task                        |\n *   | Asked: 2 minutes ago                          |\n *   +----------------------------------------------+\n *   | Question:                                     |\n *   | How should I handle the edge case where the   |\n *   | user provides an empty array?                 |\n *   |                                               |\n *   | Context:                                      |\n *   | Working on input validation in parser.ts      |\n *   +----------------------------------------------+","truncated":false,"loaded":[]},"time":{"start":1773482657588,"end":1773482657590}}}}
{"type":"text","timestamp":1773482658342,"sessionID":"ses_3143284c2ffeAaKW1jZQzt4vTf","part":{"id":"prt_cebcdbe85002zRJyxrLsX9qP14","sessionID":"ses_3143284c2ffeAaKW1jZQzt4vTf","messageID":"msg_cebcdb4f8001MQsCqMDErCjqmf","type":"text","text":"Now let me look at the TUI question popup for pattern reference (it's an overlay on the TUI, similar to what I need to build):","time":{"start":1773482658341,"end":1773482658341}}}
{"type":"tool_use","timestamp":1773482658343,"sessionID":"ses_3143284c2ffeAaKW1jZQzt4vTf","part":{"id":"prt_cebcdc735001EdlKeLCGW2Gd3J","sessionID":"ses_3143284c2ffeAaKW1jZQzt4vTf","messageID":"msg_cebcdb4f8001MQsCqMDErCjqmf","type":"tool","callID":"toolu_vrtx_01EYrF9SjnAz45gnszbTxPKK","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/wishlist-tui/src/lib/tui-session.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/wishlist-tui/src/lib/tui-session.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tui-session.ts — Persist TUI session state across opens/closes.\n3:  *\n4:  * Stores task selection, sort preferences, and view state so the user\n5:  * can close the TUI and reopen it without losing work.\n6:  *\n7:  * File: .wombo-combo/tui-session.json\n8:  */\n9: \n10: import { existsSync, readFileSync, writeFileSync, mkdirSync } from \"node:fs\";\n11: import { resolve } from \"node:path\";\n12: import { WOMBO_DIR } from \"../config.js\";\n13: \n14: // ---------------------------------------------------------------------------\n15: // Types\n16: // ---------------------------------------------------------------------------\n17: \n18: export type SortField = \"priority\" | \"status\" | \"name\" | \"stream\" | \"effort\";\n19: export type SortOrder = \"asc\" | \"desc\";\n20: \n21: export interface TUISession {\n22:   /** IDs of tasks selected for the next wave launch */\n23:   selected: string[];\n24:   /** Current sort field */\n25:   sortBy: SortField;\n26:   /** Sort direction */\n27:   sortOrder: SortOrder;\n28:   /** Max concurrent agents for launches from the TUI */\n29:   maxConcurrent: number;\n30:   /** Which view was last active */\n31:   lastView: \"browser\" | \"monitor\";\n32:   /** Collapsed stream group IDs (for tree display) */\n33:   collapsed: string[];\n34: }\n35: \n36: // ---------------------------------------------------------------------------\n37: // Defaults\n38: // ---------------------------------------------------------------------------\n39: \n40: const SESSION_FILE = \"tui-session.json\";\n41: \n42: const DEFAULT_SESSION: TUISession = {\n43:   selected: [],\n44:   sortBy: \"priority\",\n45:   sortOrder: \"desc\",\n46:   maxConcurrent: 5,\n47:   lastView: \"browser\",\n48:   collapsed: [],\n49: };\n50: \n51: // ---------------------------------------------------------------------------\n52: // Path\n53: // ---------------------------------------------------------------------------\n54: \n55: function sessionPath(projectRoot: string): string {\n56:   return resolve(projectRoot, WOMBO_DIR, SESSION_FILE);\n57: }\n58: \n59: // ---------------------------------------------------------------------------\n60: // Load / Save\n61: // ---------------------------------------------------------------------------\n62: \n63: /**\n64:  * Load TUI session from disk. Returns defaults if not found.\n65:  */\n66: export function loadTUISession(projectRoot: string): TUISession {\n67:   const fp = sessionPath(projectRoot);\n68:   try {\n69:     if (existsSync(fp)) {\n70:       const raw = readFileSync(fp, \"utf-8\");\n71:       const data = JSON.parse(raw);\n72:       return { ...DEFAULT_SESSION, ...data };\n73:     }\n74:   } catch {\n75:     // Corrupt file — use defaults\n76:   }\n77:   return { ...DEFAULT_SESSION };\n78: }\n79: \n80: /**\n81:  * Save TUI session to disk.\n82:  */\n83: export function saveTUISession(projectRoot: string, session: TUISession): void {\n84:   const dir = resolve(projectRoot, WOMBO_DIR);\n85:   if (!existsSync(dir)) mkdirSync(dir, { recursive: true });\n86:   const fp = sessionPath(projectRoot);\n87:   writeFileSync(fp, JSON.stringify(session, null, 2) + \"\\n\");\n88: }\n\n(End of file - total 88 lines)\n</content>","title":"src/lib/tui-session.ts","metadata":{"preview":"/**\n * tui-session.ts — Persist TUI session state across opens/closes.\n *\n * Stores task selection, sort preferences, and view state so the user\n * can close the TUI and reopen it without losing work.\n *\n * File: .wombo-combo/tui-session.json\n */\n\nimport { existsSync, readFileSync, writeFileSync, mkdirSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\nimport { WOMBO_DIR } from \"../config.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type SortField = \"priority\" | \"status\" | \"name\" | \"stream\" | \"effort\";\nexport type SortOrder = \"asc\" | \"desc\";\n","truncated":false,"loaded":[]},"time":{"start":1773482658340,"end":1773482658343}}}}
