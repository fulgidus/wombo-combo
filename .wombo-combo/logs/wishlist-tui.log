{"type":"tool_use","timestamp":1773482647460,"sessionID":"ses_3143284c2ffeAaKW1jZQzt4vTf","part":{"id":"prt_cebcd9de6001f6o63BcPp56QGn","sessionID":"ses_3143284c2ffeAaKW1jZQzt4vTf","messageID":"msg_cebcd903c0014Zf3rr9krXWnrx","type":"tool","callID":"toolu_vrtx_01EU7wwUpfGDHmioLqZL6tTA","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/wishlist-tui/src/lib/tui.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/wishlist-tui/src/lib/tui.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tui.ts — Blessed-based TUI dashboard for wombo-combo.\n3:  *\n4:  * Layout:\n5:  *   ┌─────────────────────────────────────────────┐\n6:  *   │ Header: Wave ID, base branch, mode, model   │\n7:  *   ├──────────────────────────┬──────────────────┤\n8:  *   │ Agent Table              │ Preview Pane     │\n9:  *   │ (selectable rows with    │ (parsed activity │\n10:  *   │  status, activity,       │  stream for the  │\n11:  *   │  progress bars, elapsed) │  selected agent) │\n12:  *   ├──────────────────────────┴──────────────────┤\n13:  *   │ Status bar: keybinds + summary counts       │\n14:  *   └─────────────────────────────────────────────┘\n15:  *\n16:  * Keybinds:\n17:  *   Up/Down   — navigate agent list\n18:  *   Enter     — attach to selected agent's multiplexer session (interactive mode)\n19:  *   r         — retry a failed/stuck agent\n20:  *   b         — show build log for selected agent\n21:  *   p         — toggle auto-scroll (pause/resume)\n22:  *   q / C-c   — quit\n23:  */\n24: \n25: import blessed from \"neo-blessed\";\n26: import type { Widgets } from \"neo-blessed\";\n27: import type { WaveState, AgentState, AgentStatus } from \"./state.js\";\n28: import { agentCounts } from \"./state.js\";\n29: import type { ProcessMonitor, ActivityEntry } from \"./monitor.js\";\n30: import { execSync } from \"node:child_process\";\n31: import { readFileSync } from \"node:fs\";\n32: import { resolve } from \"node:path\";\n33: import type { WomboConfig } from \"../config.js\";\n34: import {\n35:   detectMultiplexer,\n36:   muxHasSession,\n37:   muxAttach,\n38:   muxDisplayName,\n39: } from \"./multiplexer.js\";\n40: import { QuestionPopup } from \"./tui-question-popup.js\";\n41: import type { HitlQuestion } from \"./hitl-channel.js\";\n42: \n43: // ---------------------------------------------------------------------------\n44: // Types\n45: // ---------------------------------------------------------------------------\n46: \n47: export interface TUIOptions {\n48:   state: WaveState;\n49:   monitor: ProcessMonitor;\n50:   onQuit: () => void;\n51:   /** Whether the wave is running in interactive (multiplexer) mode. */\n52:   interactive?: boolean;\n53:   /** Project root path (for locating log files). */\n54:   projectRoot: string;\n55:   /** Config (for multiplexer session prefix, log dir, etc.) */\n56:   config: WomboConfig;\n57:   /** Callback to retry a failed/stuck agent from the TUI. */\n58:   onRetry?: (featureId: string) => void;\n59:   /** Callback when the user answers an HITL question. */\n60:   onAnswer?: (agentId: string, questionId: string, answerText: string) => void;\n61: }\n62: \n63: // ---------------------------------------------------------------------------\n64: // Color Map\n65: // ---------------------------------------------------------------------------\n66: \n67: const STATUS_COLORS: Record<AgentStatus, string> = {\n68:   queued: \"gray\",\n69:   installing: \"cyan\",\n70:   running: \"blue\",\n71:   completed: \"yellow\",\n72:   verified: \"green\",\n73:   failed: \"red\",\n74:   merged: \"magenta\",\n75:   retry: \"yellow\",\n76:   resolving_conflict: \"cyan\",\n77: };\n78: \n79: const STATUS_ICONS: Record<AgentStatus, string> = {\n80:   queued: \"·\",\n81:   installing: \"⟳\",\n82:   running: \"●\",\n83:   completed: \"○\",\n84:   verified: \"✓\",\n85:   failed: \"✗\",\n86:   merged: \"◆\",\n87:   retry: \"↻\",\n88:   resolving_conflict: \"⚡\",\n89: };\n90: \n91: // ---------------------------------------------------------------------------\n92: // Helpers\n93: // ---------------------------------------------------------------------------\n94: \n95: /**\n96:  * Escape curly braces so blessed doesn't interpret them as formatting tags.\n97:  * Blessed uses {color-fg}...{/color-fg} syntax; unmatched or malformed braces\n98:  * in user-provided text (JSON, Python dicts, shell commands, etc.) crash the\n99:  * renderer. We replace { and } with the Unicode fullwidth equivalents which\n100:  * render visually similar but are not parsed by blessed.\n101:  */\n102: function escapeBlessedTags(text: string): string {\n103:   return text.replace(/\\{/g, \"｛\").replace(/\\}/g, \"｝\");\n104: }\n105: \n106: function elapsed(startedAt: string | null): string {\n107:   if (!startedAt) return \"-\";\n108:   const start = new Date(startedAt).getTime();\n109:   const diffMs = Date.now() - start;\n110:   const secs = Math.floor(diffMs / 1000);\n111:   if (secs < 60) return `${secs}s`;\n112:   const mins = Math.floor(secs / 60);\n113:   if (mins < 60) return `${mins}m`;\n114:   const hours = Math.floor(mins / 60);\n115:   return `${hours}h${mins % 60}m`;\n116: }\n117: \n118: function progressBar(\n119:   elapsedMs: number,\n120:   estimateMs: number,\n121:   width: number = 10\n122: ): string {\n123:   if (estimateMs <= 0) return \"░\".repeat(width);\n124:   const ratio = Math.min(elapsedMs / estimateMs, 1);\n125:   const filled = Math.round(ratio * width);\n126:   return \"█\".repeat(filled) + \"░\".repeat(width - filled);\n127: }\n128: \n129: // ---------------------------------------------------------------------------\n130: // TUI Dashboard Class\n131: // ---------------------------------------------------------------------------\n132: \n133: export class WomboTUI {\n134:   private screen: Widgets.Screen;\n135:   private headerBox: Widgets.BoxElement;\n136:   private agentList: Widgets.ListElement;\n137:   private previewBox: Widgets.Log;\n138:   private statusBar: Widgets.BoxElement;\n139:   private buildLogBox: Widgets.Log;\n140: \n141:   private state: WaveState;\n142:   private monitor: ProcessMonitor;\n143:   private onQuit: () => void;\n144:   private onRetry?: (featureId: string) => void;\n145:   private onAnswer?: (agentId: string, questionId: string, answerText: string) => void;\n146:   private interactive: boolean;\n147:   private projectRoot: string;\n148:   private config: WomboConfig;\n149: \n150:   private selectedIndex: number = 0;\n151:   private autoScroll: boolean = true;\n152:   private showingBuildLog: boolean = false;\n153:   private showingLogFile: boolean = false;\n154:   private logFileBox: Widgets.Log | null = null;\n155:   private refreshTimer: ReturnType<typeof setInterval> | null = null;\n156:   private waveComplete: boolean = false;\n157:   private waveCompleteResolve: (() => void) | null = null;\n158: \n159:   /** Pending HITL questions from agents */\n160:   private pendingQuestions: HitlQuestion[] = [];\n161:   /** Active question popup (null when closed) */\n162:   private questionPopup: QuestionPopup | null = null;\n163: \n164:   /** Saved originals for console interception */\n165:   private origConsoleLog: typeof console.log = console.log;\n166:   private origConsoleError: typeof console.error = console.error;\n167:   private origConsoleWarn: typeof console.warn = console.warn;\n168:   /** System messages captured while TUI is active */\n169:   private systemMessages: ActivityEntry[] = [];\n170: \n171:   constructor(opts: TUIOptions) {\n172:     this.state = opts.state;\n173:     this.monitor = opts.monitor;\n174:     this.onQuit = opts.onQuit;\n175:     this.onRetry = opts.onRetry;\n176:     this.onAnswer = opts.onAnswer;\n177:     this.interactive = opts.interactive ?? false;\n178:     this.projectRoot = opts.projectRoot;\n179:     this.config = opts.config;\n180: \n181:     // Create screen\n182:     this.screen = blessed.screen({\n183:       smartCSR: true,\n184:       title: `wombo-combo — ${opts.state.wave_id}`,\n185:       fullUnicode: true,\n186:     });\n187: \n188:     // Header\n189:     this.headerBox = blessed.box({\n190:       top: 0,\n191:       left: 0,\n192:       width: \"100%\",\n193:       height: 3,\n194:       tags: true,\n195:       style: {\n196:         fg: \"white\",\n197:         bg: \"black\",\n198:       },\n199:     });\n200: \n201:     // Agent list (left pane)\n202:     this.agentList = blessed.list({\n203:       top: 3,\n204:       left: 0,\n205:       width: \"55%\",\n206:       height: \"100%-6\",\n207:       tags: true,\n208:       scrollable: true,\n209:       mouse: true,\n210:       keys: true,\n211:       vi: true,\n212:       border: {\n213:         type: \"line\",\n214:       },\n215:       style: {\n216:         border: { fg: \"gray\" },\n217:         selected: {\n218:           bg: \"blue\",\n219:           fg: \"white\",\n220:           bold: true,\n221:         },\n222:         item: {\n223:           fg: \"white\",\n224:         },\n225:       },\n226:       label: \" Agents \",\n227:     });\n228: \n229:     // Preview pane (right pane)\n230:     this.previewBox = blessed.log({\n231:       top: 3,\n232:       left: \"55%\",\n233:       width: \"45%\",\n234:       height: \"100%-6\",\n235:       tags: true,\n236:       scrollable: true,\n237:       mouse: true,\n238:       keys: false,\n239:       scrollbar: {\n240:         ch: \"│\",\n241:         style: { fg: \"cyan\" },\n242:       },\n243:       border: {\n244:         type: \"line\",\n245:       },\n246:       style: {\n247:         border: { fg: \"gray\" },\n248:         fg: \"white\",\n249:       },\n250:       label: \" Activity \",\n251:     });\n252: \n253:     // Build log overlay (hidden by default)\n254:     this.buildLogBox = blessed.log({\n255:       top: 3,\n256:       left: \"10%\",\n257:       width: \"80%\",\n258:       height: \"100%-6\",\n259:       tags: true,\n260:       scrollable: true,\n261:       mouse: true,\n262:       keys: true,\n263:       scrollbar: {\n264:         ch: \"│\",\n265:         style: { fg: \"yellow\" },\n266:       },\n267:       border: {\n268:         type: \"line\",\n269:       },\n270:       style: {\n271:         border: { fg: \"yellow\" },\n272:         fg: \"white\",\n273:       },\n274:       label: \" Build Log \",\n275:       hidden: true,\n276:     });\n277: \n278:     // Status bar\n279:     this.statusBar = blessed.box({\n280:       bottom: 0,\n281:       left: 0,\n282:       width: \"100%\",\n283:       height: 3,\n284:       tags: true,\n285:       style: {\n286:         fg: \"white\",\n287:         bg: \"black\",\n288:       },\n289:     });\n290: \n291:     // Assemble\n292:     this.screen.append(this.headerBox);\n293:     this.screen.append(this.agentList);\n294:     this.screen.append(this.previewBox);\n295:     this.screen.append(this.buildLogBox);\n296:     this.screen.append(this.statusBar);\n297: \n298:     // Focus the agent list\n299:     this.agentList.focus();\n300: \n301:     // Bind keys\n302:     this.bindKeys();\n303:   }\n304: \n305:   // -------------------------------------------------------------------------\n306:   // Key Bindings\n307:   // -------------------------------------------------------------------------\n308: \n309:   private bindKeys(): void {\n310:     // Quit\n311:     this.screen.key([\"q\", \"C-c\"], () => {\n312:       this.stop();\n313:       if (this.waveComplete && this.waveCompleteResolve) {\n314:         // Wave is done — just close TUI and resolve the wait promise\n315:         this.waveCompleteResolve();\n316:       } else {\n317:         // Wave still running — trigger the abort/interrupt handler\n318:         this.onQuit();\n319:       }\n320:     });\n321: \n322:     // Navigate agent list\n323:     this.agentList.on(\"select item\", (_item: any, index: number) => {\n324:       this.selectedIndex = index;\n325:       this.refreshPreview();\n326:     });\n327: \n328:     // Enter — multiplexer attach\n329:     this.screen.key([\"enter\"], () => {\n330:       this.muxAttach();\n331:     });\n332: \n333:     // b — toggle build log\n334:     this.screen.key([\"b\"], () => {\n335:       this.toggleBuildLog();\n336:     });\n337: \n338:     // p — toggle auto-scroll\n339:     this.screen.key([\"p\"], () => {\n340:       this.autoScroll = !this.autoScroll;\n341:       this.refreshStatusBar();\n342:     });\n343: \n344:     // r — retry failed/stuck agent\n345:     this.screen.key([\"r\"], () => {\n346:       this.retrySelected();\n347:     });\n348: \n349:     // h — open HITL question popup\n350:     this.screen.key([\"h\"], () => {\n351:       this.openQuestionPopup();\n352:     });\n353: \n354:     // Escape — close build log, log file overlay, or question popup\n355:     this.screen.key([\"escape\"], () => {\n356:       if (this.questionPopup && !this.questionPopup.isDestroyed()) {\n357:         this.questionPopup.close();\n358:         this.questionPopup = null;\n359:         this.agentList.focus();\n360:         this.screen.render();\n361:       } else if (this.showingBuildLog) {\n362:         this.showingBuildLog = false;\n363:         this.buildLogBox.hide();\n364:         this.agentList.focus();\n365:         this.screen.render();\n366:       } else if (this.showingLogFile && this.logFileBox) {\n367:         this.showingLogFile = false;\n368:         this.logFileBox.destroy();\n369:         this.logFileBox = null;\n370:         this.agentList.focus();\n371:         this.screen.render();\n372:       }\n373:     });\n374:   }\n375: \n376:   // -------------------------------------------------------------------------\n377:   // Start / Stop\n378:   //\n379:   // ## TUI Lifecycle and Agent Processes (audit: wave-detach-audit)\n380:   //\n381:   // `stop()` only tears down the TUI — it clears the refresh timer and\n382:   // destroys the blessed screen. It does NOT kill agent processes.\n383:   //\n384:   // Agent process termination is handled by the `onQuit` callback, which\n385:   // is set by launch.ts/resume.ts to call `monitor.killAll()` + state save.\n386:   //\n387:   // The separation is intentional:\n388:   //   - `stop()` is also called before mux attach (muxAttach method) where\n389:   //     the TUI is temporarily destroyed and recreated after detach.\n390:   //   - `onQuit()` is only called when the user intends to exit the entire\n391:   //     wave, triggering agent cleanup and process exit.\n392:   //\n393:   // `screen.destroy()` does NOT affect child processes because agents are\n394:   // spawned by the ProcessMonitor (in the launch command), not by the TUI.\n395:   // The TUI only reads from the monitor — it never owns agent processes.\n396:   // -------------------------------------------------------------------------\n397: \n398:   start(): void {\n399:     this.interceptConsole();\n400:     this.refresh();\n401:     this.screen.render();\n402: \n403:     // Auto-refresh every 2 seconds\n404:     this.refreshTimer = setInterval(() => {\n405:       this.refresh();\n406:     }, 2000);\n407:   }\n408: \n409:   stop(): void {\n410:     this.restoreConsole();\n411:     if (this.refreshTimer) {\n412:       clearInterval(this.refreshTimer);\n413:       this.refreshTimer = null;\n414:     }\n415:     this.screen.destroy();\n416:   }\n417: \n418:   /**\n419:    * Intercept console.log/error/warn so they don't corrupt the TUI.\n420:    * Messages are captured into systemMessages and shown in the preview\n421:    * when no specific agent is producing activity.\n422:    */\n423:   private interceptConsole(): void {\n424:     this.origConsoleLog = console.log;\n425:     this.origConsoleError = console.error;\n426:     this.origConsoleWarn = console.warn;\n427: \n428:     const capture = (...args: any[]) => {\n429:       const text = args\n430:         .map((a) => (typeof a === \"string\" ? a : JSON.stringify(a)))\n431:         .join(\" \");\n432:       // Strip ANSI codes for clean TUI display\n433:       const clean = text.replace(/\\x1b\\[[0-9;]*m/g, \"\");\n434:       if (!clean.trim()) return;\n435:       this.systemMessages.push({\n436:         timestamp: new Date().toISOString().slice(11, 19),\n437:         text: clean,\n438:       });\n439:       // Keep bounded\n440:       if (this.systemMessages.length > 200) {\n441:         this.systemMessages.splice(0, this.systemMessages.length - 200);\n442:       }\n443:     };\n444: \n445:     console.log = capture;\n446:     console.error = capture;\n447:     console.warn = capture;\n448:   }\n449: \n450:   /**\n451:    * Restore original console methods.\n452:    */\n453:   private restoreConsole(): void {\n454:     console.log = this.origConsoleLog;\n455:     console.error = this.origConsoleError;\n456:     console.warn = this.origConsoleWarn;\n457:   }\n458: \n459:   /**\n460:    * Update the state reference (called from the monitoring loop).\n461:    */\n462:   updateState(state: WaveState): void {\n463:     this.state = state;\n464:   }\n465: \n466:   /**\n467:    * Mark the wave as complete. The TUI stays open so the user can browse\n468:    * agent logs, build output, etc. The header shows a WAVE COMPLETE banner\n469:    * and the status bar tells the user to press q to exit.\n470:    */\n471:   markWaveComplete(): void {\n472:     this.waveComplete = true;\n473:     this.refresh();\n474:   }\n475: \n476:   /**\n477:    * Returns a Promise that resolves when the user presses q to quit.\n478:    * Used after wave completion so the TUI stays open for post-mortem browsing.\n479:    */\n480:   waitForQuit(): Promise<void> {\n481:     return new Promise<void>((resolve) => {\n482:       this.waveCompleteResolve = resolve;\n483:     });\n484:   }\n485: \n486:   /**\n487:    * Update pending HITL questions. Called from the monitoring loop.\n488:    * If the question popup is open, it gets live-updated too.\n489:    */\n490:   setPendingQuestions(questions: HitlQuestion[]): void {\n491:     this.pendingQuestions = questions;\n492:     if (this.questionPopup && !this.questionPopup.isDestroyed()) {\n493:       this.questionPopup.updateQuestions(questions);\n494:     }\n495:     // Status bar will pick up the badge on next refresh cycle\n496:   }\n497: \n498:   /**\n499:    * Open the HITL question popup modal.\n500:    */\n501:   private openQuestionPopup(): void {\n502:     // Don't open if already open\n503:     if (this.questionPopup && !this.questionPopup.isDestroyed()) return;\n504: \n505:     // Don't open if there are no pending questions\n506:     if (this.pendingQuestions.length === 0) {\n507:       // Flash a message in the preview\n508:       const agent = this.state.agents[this.selectedIndex];\n509:       if (agent) {\n510:         const logs = this.monitor.activityLogs.get(agent.feature_id);\n511:         if (logs) {\n512:           logs.push({\n513:             timestamp: new Date().toISOString().slice(11, 19),\n514:             text: `-- No pending HITL questions`,\n515:           });\n516:         }\n517:         this.refreshPreview();\n518:         this.screen.render();\n519:       }\n520:       return;\n521:     }\n522: \n523:     this.questionPopup = new QuestionPopup(\n524:       this.screen,\n525:       [...this.pendingQuestions], // copy so popup can mutate internally\n526:       {\n527:         onAnswer: (agentId, questionId, answerText) => {\n528:           // Forward to the external callback (which calls submitAnswer)\n529:           if (this.onAnswer) {\n530:             this.onAnswer(agentId, questionId, answerText);\n531:           }\n532:           // Remove from our pending list\n533:           this.pendingQuestions = this.pendingQuestions.filter(\n534:             (q) => !(q.agentId === agentId && q.id === questionId)\n535:           );\n536:         },\n537:         onClose: () => {\n538:           this.questionPopup = null;\n539:           this.agentList.focus();\n540:           this.refreshStatusBar();\n541:           this.screen.render();\n542:         },\n543:       }\n544:     );\n545:   }\n546: \n547:   // -------------------------------------------------------------------------\n548:   // Refresh Logic\n549:   // -------------------------------------------------------------------------\n550: \n551:   private refresh(): void {\n552:     this.refreshHeader();\n553:     this.refreshAgentList();\n554:     this.refreshPreview();\n555:     this.refreshStatusBar();\n556:     this.screen.render();\n557:   }\n558: \n559:   private refreshHeader(): void {\n560:     const s = this.state;\n561:     const counts = agentCounts(s);\n562:     const total = s.agents.length;\n563:     const done = counts.verified + counts.merged;\n564: \n565:     let line1 = ` {bold}wombo-combo{/bold} {gray-fg}${s.wave_id}{/gray-fg}`;\n566:     if (this.waveComplete) {\n567:       line1 += `  {gray-fg}│{/gray-fg}  {bold}{green-fg}WAVE COMPLETE{/green-fg}{/bold}`;\n568:     }\n569:     line1 += `  {gray-fg}│{/gray-fg}  Base: {cyan-fg}${s.base_branch}{/cyan-fg}`;\n570:     line1 += `  {gray-fg}│{/gray-fg}  Mode: ${s.interactive ? \"{green-fg}interactive{/green-fg}\" : \"{blue-fg}headless{/blue-fg}\"}`;\n571:     if (s.model) {\n572:       line1 += `  {gray-fg}│{/gray-fg}  Model: {yellow-fg}${s.model}{/yellow-fg}`;\n573:     }\n574: \n575:     let line2 = ` Progress: {green-fg}${done}{/green-fg}/{white-fg}${total}{/white-fg}`;\n576:     if (counts.running > 0)\n577:       line2 += `  {blue-fg}${counts.running} running{/blue-fg}`;\n578:     if (counts.failed > 0)\n579:       line2 += `  {red-fg}${counts.failed} failed{/red-fg}`;\n580:     if (counts.queued > 0)\n581:       line2 += `  {gray-fg}${counts.queued} queued{/gray-fg}`;\n582:     if (counts.retry > 0)\n583:       line2 += `  {yellow-fg}${counts.retry} retrying{/yellow-fg}`;\n584:     if (counts.resolving_conflict > 0)\n585:       line2 += `  {cyan-fg}${counts.resolving_conflict} resolving{/cyan-fg}`;\n586: \n587:     this.headerBox.setContent(`${line1}\\n${line2}`);\n588:   }\n589: \n590:   private refreshAgentList(): void {\n591:     const items: string[] = [];\n592: \n593:     for (let i = 0; i < this.state.agents.length; i++) {\n594:       const a = this.state.agents[i];\n595:       const color = STATUS_COLORS[a.status];\n596:       const icon = STATUS_ICONS[a.status];\n597: \n598:       // Feature ID (padded)\n599:       const fid =\n600:         a.feature_id.length > 24\n601:           ? a.feature_id.slice(0, 23) + \"…\"\n602:           : a.feature_id.padEnd(24);\n603: \n604:       // Status\n605:       const st = `{${color}-fg}${icon} ${a.status.padEnd(10)}{/${color}-fg}`;\n606: \n607:       // Progress bar\n608:       let pbar = \"\";\n609:       if ((a.status === \"running\" || a.status === \"resolving_conflict\") && a.started_at) {\n610:         const elapsedMs = Date.now() - new Date(a.started_at).getTime();\n611:         // Use actual effort estimate from feature data, fallback to 1h\n612:         const estimateMs = a.effort_estimate_ms ?? 60 * 60 * 1000;\n613:         pbar = ` {cyan-fg}${progressBar(elapsedMs, estimateMs, 8)}{/cyan-fg}`;\n614:       } else if (a.status === \"verified\" || a.status === \"merged\") {\n615:         pbar = ` {green-fg}${\"█\".repeat(8)}{/green-fg}`;\n616:       } else if (a.status === \"failed\") {\n617:         pbar = ` {red-fg}${\"█\".repeat(8)}{/red-fg}`;\n618:       }\n619: \n620:       // Activity (for running/resolving agents)\n621:       let act = \"\";\n622:       if ((a.status === \"running\" || a.status === \"resolving_conflict\") && a.activity) {\n623:         const rawAct =\n624:           a.activity.length > 25 ? a.activity.slice(0, 24) + \"…\" : a.activity;\n625:         const actText = escapeBlessedTags(rawAct);\n626:         act = ` {cyan-fg}${actText}{/cyan-fg}`;\n627:       } else if (a.status === \"installing\") {\n628:         act = \" {cyan-fg}setting up…{/cyan-fg}\";\n629:       }\n630: \n631:       // Elapsed\n632:       const el = elapsed(a.started_at);\n633: \n634:       // Retries\n635:       const retries =\n636:         a.retries > 0 ? ` {yellow-fg}↻${a.retries}{/yellow-fg}` : \"\";\n637: \n638:       items.push(\n639:         ` ${fid} ${st}${pbar}${act}${retries} {gray-fg}${el}{/gray-fg}`\n640:       );\n641:     }\n642: \n643:     // Preserve selection\n644:     const prevSelected = this.selectedIndex;\n645:     this.agentList.setItems(items as any);\n646:     if (prevSelected < items.length) {\n647:       this.agentList.select(prevSelected);\n648:     }\n649:   }\n650: \n651:   private refreshPreview(): void {\n652:     const agent = this.state.agents[this.selectedIndex];\n653:     if (!agent) {\n654:       this.previewBox.setContent(\"{gray-fg}No agent selected{/gray-fg}\");\n655:       return;\n656:     }\n657: \n658:     // Update label\n659:     this.previewBox.setLabel(` ${agent.feature_id} — Activity `);\n660: \n661:     // Get activity log from monitor\n662:     const log = this.monitor.getActivityLog(agent.feature_id);\n663: \n664:     // Also include system messages (build verification, etc.)\n665:     // that mention this agent's feature_id\n666:     const relevantSys = this.systemMessages.filter((m) =>\n667:       m.text.includes(agent.feature_id)\n668:     );\n669: \n670:     if (log.length === 0 && relevantSys.length === 0) {\n671:       this.previewBox.setContent(\n672:         \"{gray-fg}No activity yet. Waiting for agent output…{/gray-fg}\"\n673:       );\n674:       return;\n675:     }\n676: \n677:     // Format log entries\n678:     const lines: string[] = [];\n679:     for (const entry of log) {\n680:       lines.push(this.formatActivityLine(entry));\n681:     }\n682: \n683:     // Append relevant system messages\n684:     if (relevantSys.length > 0) {\n685:       lines.push(\"\");\n686:       lines.push(\"{yellow-fg}-- system --{/yellow-fg}\");\n687:       for (const entry of relevantSys) {\n688:         const ts = `{gray-fg}${entry.timestamp}{/gray-fg}`;\n689:         lines.push(`${ts} {yellow-fg}${escapeBlessedTags(entry.text)}{/yellow-fg}`);\n690:       }\n691:     }\n692: \n693:     this.previewBox.setContent(lines.join(\"\\n\"));\n694: \n695:     // Auto-scroll to bottom\n696:     if (this.autoScroll) {\n697:       this.previewBox.setScrollPerc(100);\n698:     }\n699:   }\n700: \n701:   private formatActivityLine(entry: ActivityEntry): string {\n702:     const ts = `{gray-fg}${entry.timestamp}{/gray-fg}`;\n703:     let text = escapeBlessedTags(entry.text);\n704: \n705:     // Color-code different line types\n706:     if (text.startsWith(\">>\")) {\n707:       text = `{cyan-fg}${text}{/cyan-fg}`;\n708:     } else if (text.startsWith(\"!!\")) {\n709:       text = `{red-fg}${text}{/red-fg}`;\n710:     } else if (text.startsWith(\"--\")) {\n711:       text = `{green-fg}${text}{/green-fg}`;\n712:     } else if (text.startsWith(\"[stderr]\")) {\n713:       text = `{red-fg}${text}{/red-fg}`;\n714:     } else if (text.startsWith(\"[raw]\")) {\n715:       text = `{gray-fg}${text}{/gray-fg}`;\n716:     } else if (text.startsWith(\"   \")) {\n717:       text = `{white-fg}${text}{/white-fg}`;\n718:     }\n719: \n720:     return `${ts} ${text}`;\n721:   }\n722: \n723:   private refreshStatusBar(): void {\n724:     const scrollStatus = this.autoScroll\n725:       ? \"{green-fg}auto-scroll{/green-fg}\"\n726:       : \"{yellow-fg}paused{/yellow-fg}\";\n727: \n728:     const agent = this.state.agents[this.selectedIndex];\n729:     const agentInfo = agent\n730:       ? `{gray-fg}Selected: {white-fg}${agent.feature_id}{/white-fg}{/gray-fg}`\n731:       : \"\";\n732: \n733:     const enterHint = this.interactive\n734:       ? \"{gray-fg}Enter{/gray-fg} attach session\"\n735:       : \"{gray-fg}Enter{/gray-fg} view log\";\n736: \n737:     // HITL badge — show only when there are pending questions\n738:     const hitlBadge =\n739:       this.pendingQuestions.length > 0\n740:         ? `  {bold}{yellow-fg}? ${this.pendingQuestions.length} pending{/yellow-fg}{/bold}  {gray-fg}H{/gray-fg} answer`\n741:         : \"\";\n742: \n743:     let line1: string;\n744:     if (this.waveComplete) {\n745:       line1 = ` {bold}{green-fg}Wave complete.{/green-fg}{/bold}  ${enterHint}  {gray-fg}R{/gray-fg} retry  {gray-fg}B{/gray-fg} build log  {gray-fg}P{/gray-fg} ${scrollStatus}${hitlBadge}  {bold}{yellow-fg}Q{/yellow-fg} exit{/bold}`;\n746:     } else {\n747:       line1 = ` {bold}Keys:{/bold} {gray-fg}\\u2191\\u2193{/gray-fg} navigate  ${enterHint}  {gray-fg}R{/gray-fg} retry  {gray-fg}B{/gray-fg} build log  {gray-fg}P{/gray-fg} ${scrollStatus}${hitlBadge}  {gray-fg}Q{/gray-fg} quit`;\n748:     }\n749:     const line2 = ` ${agentInfo}`;\n750: \n751:     this.statusBar.setContent(`${line1}\\n${line2}`);\n752:   }\n753: \n754:   // -------------------------------------------------------------------------\n755:   // Actions\n756:   // -------------------------------------------------------------------------\n757: \n758:   private muxAttach(): void {\n759:     const agent = this.state.agents[this.selectedIndex];\n760:     if (!agent) return;\n761: \n762:     if (!this.interactive) {\n763:       // Headless mode — show the raw log file in an overlay\n764:       this.showLogFile(agent);\n765:       return;\n766:     }\n767: \n768:     const mux = detectMultiplexer(this.config.agent.multiplexer);\n769:     const sessionName = `${this.config.agent.tmuxPrefix}-${agent.feature_id}`;\n770: \n771:     // Check if multiplexer session exists\n772:     if (!muxHasSession(mux, sessionName)) {\n773:       // No session — show message in preview\n774:       this.monitor.activityLogs.get(agent.feature_id)?.push({\n775:         timestamp: new Date().toISOString().slice(11, 19),\n776:         text: `!! No ${muxDisplayName(mux)} session '${sessionName}' found`,\n777:       });\n778:       this.refreshPreview();\n779:       this.screen.render();\n780:       return;\n781:     }\n782: \n783:     // Detach from blessed, attach to multiplexer session\n784:     this.restoreConsole();\n785:     this.screen.destroy();\n786:     try {\n787:       muxAttach(mux, sessionName);\n788:     } catch {\n789:       // User detached from session — resume TUI\n790:     }\n791: \n792:     // Re-create screen after returning from multiplexer\n793:     this.recreateScreen();\n794:   }\n795: \n796:   /**\n797:    * Retry the selected agent (only if failed or stuck in retry).\n798:    * Resets it to \"queued\" so the polling loop picks it up for a fresh launch.\n799:    */\n800:   private retrySelected(): void {\n801:     const agent = this.state.agents[this.selectedIndex];\n802:     if (!agent) return;\n803: \n804:     const retryableStatuses: AgentStatus[] = [\"failed\", \"retry\"];\n805:     if (!retryableStatuses.includes(agent.status)) {\n806:       // Flash a message in the preview — agent isn't in a retryable state\n807:       const logs = this.monitor.activityLogs.get(agent.feature_id);\n808:       if (logs) {\n809:         logs.push({\n810:           timestamp: new Date().toISOString().slice(11, 19),\n811:           text: `!! Cannot retry — agent status is \"${agent.status}\" (must be failed or retry)`,\n812:         });\n813:       }\n814:       this.refreshPreview();\n815:       this.screen.render();\n816:       return;\n817:     }\n818: \n819:     if (this.onRetry) {\n820:       this.onRetry(agent.feature_id);\n821: \n822:       // Show feedback in preview\n823:       const logs = this.monitor.activityLogs.get(agent.feature_id);\n824:       if (logs) {\n825:         logs.push({\n826:           timestamp: new Date().toISOString().slice(11, 19),\n827:           text: `>> Retry requested — agent will be relaunched`,\n828:         });\n829:       }\n830:       this.refresh();\n831:       this.screen.render();\n832:     }\n833:   }\n834: \n835:   /**\n836:    * Show the raw log file for an agent in an overlay (headless mode).\n837:    */\n838:   private showLogFile(agent: AgentState): void {\n839:     if (this.showingLogFile) {\n840:       // Toggle off\n841:       this.showingLogFile = false;\n842:       if (this.logFileBox) {\n843:         this.logFileBox.destroy();\n844:         this.logFileBox = null;\n845:       }\n846:       this.agentList.focus();\n847:       this.screen.render();\n848:       return;\n849:     }\n850: \n851:     const logPath = resolve(\n852:       this.projectRoot,\n853:       \".wombo-combo\",\n854:       \"logs\",\n855:       `${agent.feature_id}.log`\n856:     );\n857:     let content: string;\n858:     try {\n859:       content = readFileSync(logPath, \"utf-8\");\n860:       if (!content.trim()) {\n861:         content =\n862:           \"{gray-fg}Log file is empty. Agent may not have started producing output yet.{/gray-fg}\";\n863:       }\n864:     } catch {\n865:       content = \"{gray-fg}No log file found at \" + logPath + \"{/gray-fg}\";\n866:     }\n867: \n868:     // Create overlay\n869:     this.logFileBox = blessed.log({\n870:       top: 3,\n871:       left: \"5%\",\n872:       width: \"90%\",\n873:       height: \"100%-6\",\n874:       tags: true,\n875:       scrollable: true,\n876:       mouse: true,\n877:       keys: true,\n878:       scrollbar: {\n879:         ch: \"│\",\n880:         style: { fg: \"cyan\" },\n881:       },\n882:       border: {\n883:         type: \"line\",\n884:       },\n885:       style: {\n886:         border: { fg: \"cyan\" },\n887:         fg: \"white\",\n888:       },\n889:       label: ` Log — ${agent.feature_id} (Esc to close) `,\n890:     });\n891: \n892:     this.screen.append(this.logFileBox);\n893: \n894:     // Truncate to last 200 lines to keep TUI responsive\n895:     const lines = content.split(\"\\n\");\n896:     const truncated =\n897:       lines.length > 200 ? lines.slice(-200).join(\"\\n\") : content;\n898:     this.logFileBox.setContent(escapeBlessedTags(truncated));\n899:     this.logFileBox.setScrollPerc(100);\n900:     this.logFileBox.focus();\n901:     this.showingLogFile = true;\n902:     this.screen.render();\n903:   }\n904: \n905:   private toggleBuildLog(): void {\n906:     const agent = this.state.agents[this.selectedIndex];\n907:     if (!agent) return;\n908: \n909:     if (this.showingBuildLog) {\n910:       this.showingBuildLog = false;\n911:       this.buildLogBox.hide();\n912:       this.agentList.focus();\n913:     } else {\n914:       this.showingBuildLog = true;\n915:       this.buildLogBox.setLabel(` Build Log — ${agent.feature_id} `);\n916: \n917:       if (agent.build_output) {\n918:         this.buildLogBox.setContent(escapeBlessedTags(agent.build_output));\n919:       } else if (agent.build_passed === true) {\n920:         this.buildLogBox.setContent(\n921:           \"{green-fg}Build passed — no errors.{/green-fg}\"\n922:         );\n923:       } else if (agent.build_passed === false) {\n924:         this.buildLogBox.setContent(\n925:           \"{red-fg}Build failed — no output captured.{/red-fg}\"\n926:         );\n927:       } else {\n928:         this.buildLogBox.setContent(\n929:           \"{gray-fg}No build has been run yet.{/gray-fg}\"\n930:         );\n931:       }\n932: \n933:       this.buildLogBox.show();\n934:       this.buildLogBox.focus();\n935:     }\n936:     this.screen.render();\n937:   }\n938: \n939:   /**\n940:    * Re-create the screen after returning from multiplexer attach.\n941:    * Blessed can't resume after destroy, so we rebuild everything.\n942:    */\n943:   private recreateScreen(): void {\n944:     // Re-create screen\n945:     this.screen = blessed.screen({\n946:       smartCSR: true,\n947:       title: `wombo-combo — ${this.state.wave_id}`,\n948:       fullUnicode: true,\n949:     });\n950: \n951:     // Re-create all widgets\n952:     this.headerBox = blessed.box({\n953:       top: 0,\n954:       left: 0,\n955:       width: \"100%\",\n956:       height: 3,\n957:       tags: true,\n958:       style: { fg: \"white\", bg: \"black\" },\n959:     });\n960: \n961:     this.agentList = blessed.list({\n962:       top: 3,\n963:       left: 0,\n964:       width: \"55%\",\n965:       height: \"100%-6\",\n966:       tags: true,\n967:       scrollable: true,\n968:       mouse: true,\n969:       keys: true,\n970:       vi: true,\n971:       border: { type: \"line\" },\n972:       style: {\n973:         border: { fg: \"gray\" },\n974:         selected: { bg: \"blue\", fg: \"white\", bold: true },\n975:         item: { fg: \"white\" },\n976:       },\n977:       label: \" Agents \",\n978:     });\n979: \n980:     this.previewBox = blessed.log({\n981:       top: 3,\n982:       left: \"55%\",\n983:       width: \"45%\",\n984:       height: \"100%-6\",\n985:       tags: true,\n986:       scrollable: true,\n987:       mouse: true,\n988:       keys: false,\n989:       scrollbar: { ch: \"│\", style: { fg: \"cyan\" } },\n990:       border: { type: \"line\" },\n991:       style: { border: { fg: \"gray\" }, fg: \"white\" },\n992:       label: \" Activity \",\n993:     });\n994: \n995:     this.buildLogBox = blessed.log({\n996:       top: 3,\n997:       left: \"10%\",\n998:       width: \"80%\",\n999:       height: \"100%-6\",\n1000:       tags: true,\n1001:       scrollable: true,\n1002:       mouse: true,\n1003:       keys: true,\n1004:       scrollbar: { ch: \"│\", style: { fg: \"yellow\" } },\n1005:       border: { type: \"line\" },\n1006:       style: { border: { fg: \"yellow\" }, fg: \"white\" },\n1007:       label: \" Build Log \",\n1008:       hidden: true,\n1009:     });\n1010: \n1011:     this.statusBar = blessed.box({\n1012:       bottom: 0,\n1013:       left: 0,\n1014:       width: \"100%\",\n1015:       height: 3,\n1016:       tags: true,\n1017:       style: { fg: \"white\", bg: \"black\" },\n1018:     });\n1019: \n1020:     this.screen.append(this.headerBox);\n1021:     this.screen.append(this.agentList);\n1022:     this.screen.append(this.previewBox);\n1023:     this.screen.append(this.buildLogBox);\n1024:     this.screen.append(this.statusBar);\n1025: \n1026:     this.agentList.focus();\n1027:     this.showingBuildLog = false;\n1028:     this.showingLogFile = false;\n1029:     this.logFileBox = null;\n1030:     this.questionPopup = null;\n1031:     this.interceptConsole();\n1032:     this.bindKeys();\n1033:     this.refresh();\n1034:   }\n1035: }\n\n(End of file - total 1035 lines)\n</content>","title":"src/lib/tui.ts","metadata":{"preview":"/**\n * tui.ts — Blessed-based TUI dashboard for wombo-combo.\n *\n * Layout:\n *   ┌─────────────────────────────────────────────┐\n *   │ Header: Wave ID, base branch, mode, model   │\n *   ├──────────────────────────┬──────────────────┤\n *   │ Agent Table              │ Preview Pane     │\n *   │ (selectable rows with    │ (parsed activity │\n *   │  status, activity,       │  stream for the  │\n *   │  progress bars, elapsed) │  selected agent) │\n *   ├──────────────────────────┴──────────────────┤\n *   │ Status bar: keybinds + summary counts       │\n *   └─────────────────────────────────────────────┘\n *\n * Keybinds:\n *   Up/Down   — navigate agent list\n *   Enter     — attach to selected agent's multiplexer session (interactive mode)\n *   r         — retry a failed/stuck agent\n *   b         — show build log for selected agent","truncated":false,"loaded":[]},"time":{"start":1773482647454,"end":1773482647459}}}}
