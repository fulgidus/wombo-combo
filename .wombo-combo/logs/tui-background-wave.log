{"type":"tool_use","timestamp":1773483622125,"sessionID":"ses_31423da25ffebo9V1CTFH0IpgT","part":{"id":"prt_cebdc7a3d001Ar2Q4LlfDEqrWh","sessionID":"ses_31423da25ffebo9V1CTFH0IpgT","messageID":"msg_cebdc6d24001vwRuP49Ld6IsbZ","type":"tool","callID":"toolu_vrtx_016xGCcUTQsiLsxHR45sGWHP","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/wave-detach-audit/src/lib/tui.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/wave-detach-audit/src/lib/tui.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tui.ts — Blessed-based TUI dashboard for wombo-combo.\n3:  *\n4:  * Layout:\n5:  *   ┌─────────────────────────────────────────────┐\n6:  *   │ Header: Wave ID, base branch, mode, model   │\n7:  *   ├──────────────────────────┬──────────────────┤\n8:  *   │ Agent Table              │ Preview Pane     │\n9:  *   │ (selectable rows with    │ (parsed activity │\n10:  *   │  status, activity,       │  stream for the  │\n11:  *   │  progress bars, elapsed) │  selected agent) │\n12:  *   ├──────────────────────────┴──────────────────┤\n13:  *   │ Status bar: keybinds + summary counts       │\n14:  *   └─────────────────────────────────────────────┘\n15:  *\n16:  * Keybinds:\n17:  *   Up/Down   — navigate agent list\n18:  *   Enter     — attach to selected agent's multiplexer session (interactive mode)\n19:  *   r         — retry a failed/stuck agent\n20:  *   b         — show build log for selected agent\n21:  *   p         — toggle auto-scroll (pause/resume)\n22:  *   q / C-c   — quit\n23:  */\n24: \n25: import blessed from \"neo-blessed\";\n26: import type { Widgets } from \"neo-blessed\";\n27: import type { WaveState, AgentState, AgentStatus } from \"./state.js\";\n28: import { agentCounts } from \"./state.js\";\n29: import type { ProcessMonitor, ActivityEntry } from \"./monitor.js\";\n30: import { execSync } from \"node:child_process\";\n31: import { readFileSync } from \"node:fs\";\n32: import { resolve } from \"node:path\";\n33: import type { WomboConfig } from \"../config.js\";\n34: import {\n35:   detectMultiplexer,\n36:   muxHasSession,\n37:   muxAttach,\n38:   muxDisplayName,\n39: } from \"./multiplexer.js\";\n40: import { QuestionPopup } from \"./tui-question-popup.js\";\n41: import type { HitlQuestion } from \"./hitl-channel.js\";\n42: \n43: // ---------------------------------------------------------------------------\n44: // Types\n45: // ---------------------------------------------------------------------------\n46: \n47: export interface TUIOptions {\n48:   state: WaveState;\n49:   monitor: ProcessMonitor;\n50:   onQuit: () => void;\n51:   /** Whether the wave is running in interactive (multiplexer) mode. */\n52:   interactive?: boolean;\n53:   /** Project root path (for locating log files). */\n54:   projectRoot: string;\n55:   /** Config (for multiplexer session prefix, log dir, etc.) */\n56:   config: WomboConfig;\n57:   /** Callback to retry a failed/stuck agent from the TUI. */\n58:   onRetry?: (featureId: string) => void;\n59:   /** Callback when the user answers an HITL question. */\n60:   onAnswer?: (agentId: string, questionId: string, answerText: string) => void;\n61:   /**\n62:    * Callback invoked during stop() BEFORE the blessed screen is destroyed.\n63:    * Use this to flush pending state writes to disk while the process is\n64:    * still alive and I/O is still functional. This ensures state.json\n65:    * integrity even if the process exits immediately after screen.destroy().\n66:    */\n67:   onBeforeDestroy?: () => void;\n68: }\n69: \n70: // ---------------------------------------------------------------------------\n71: // Color Map\n72: // ---------------------------------------------------------------------------\n73: \n74: const STATUS_COLORS: Record<AgentStatus, string> = {\n75:   queued: \"gray\",\n76:   installing: \"cyan\",\n77:   running: \"blue\",\n78:   completed: \"yellow\",\n79:   verified: \"green\",\n80:   failed: \"red\",\n81:   merged: \"magenta\",\n82:   retry: \"yellow\",\n83:   resolving_conflict: \"cyan\",\n84: };\n85: \n86: const STATUS_ICONS: Record<AgentStatus, string> = {\n87:   queued: \"·\",\n88:   installing: \"⟳\",\n89:   running: \"●\",\n90:   completed: \"○\",\n91:   verified: \"✓\",\n92:   failed: \"✗\",\n93:   merged: \"◆\",\n94:   retry: \"↻\",\n95:   resolving_conflict: \"⚡\",\n96: };\n97: \n98: // ---------------------------------------------------------------------------\n99: // Helpers\n100: // ---------------------------------------------------------------------------\n101: \n102: /**\n103:  * Escape curly braces so blessed doesn't interpret them as formatting tags.\n104:  * Blessed uses {color-fg}...{/color-fg} syntax; unmatched or malformed braces\n105:  * in user-provided text (JSON, Python dicts, shell commands, etc.) crash the\n106:  * renderer. We replace { and } with the Unicode fullwidth equivalents which\n107:  * render visually similar but are not parsed by blessed.\n108:  */\n109: function escapeBlessedTags(text: string): string {\n110:   return text.replace(/\\{/g, \"｛\").replace(/\\}/g, \"｝\");\n111: }\n112: \n113: function elapsed(startedAt: string | null): string {\n114:   if (!startedAt) return \"-\";\n115:   const start = new Date(startedAt).getTime();\n116:   const diffMs = Date.now() - start;\n117:   const secs = Math.floor(diffMs / 1000);\n118:   if (secs < 60) return `${secs}s`;\n119:   const mins = Math.floor(secs / 60);\n120:   if (mins < 60) return `${mins}m`;\n121:   const hours = Math.floor(mins / 60);\n122:   return `${hours}h${mins % 60}m`;\n123: }\n124: \n125: function progressBar(\n126:   elapsedMs: number,\n127:   estimateMs: number,\n128:   width: number = 10\n129: ): string {\n130:   if (estimateMs <= 0) return \"░\".repeat(width);\n131:   const ratio = Math.min(elapsedMs / estimateMs, 1);\n132:   const filled = Math.round(ratio * width);\n133:   return \"█\".repeat(filled) + \"░\".repeat(width - filled);\n134: }\n135: \n136: // ---------------------------------------------------------------------------\n137: // TUI Dashboard Class\n138: // ---------------------------------------------------------------------------\n139: \n140: export class WomboTUI {\n141:   private screen: Widgets.Screen;\n142:   private headerBox: Widgets.BoxElement;\n143:   private agentList: Widgets.ListElement;\n144:   private previewBox: Widgets.Log;\n145:   private statusBar: Widgets.BoxElement;\n146:   private buildLogBox: Widgets.Log;\n147: \n148:   private state: WaveState;\n149:   private monitor: ProcessMonitor;\n150:   private onQuit: () => void;\n151:   private onRetry?: (featureId: string) => void;\n152:   private onAnswer?: (agentId: string, questionId: string, answerText: string) => void;\n153:   private onBeforeDestroy?: () => void;\n154:   private interactive: boolean;\n155:   private projectRoot: string;\n156:   private config: WomboConfig;\n157: \n158:   private selectedIndex: number = 0;\n159:   private autoScroll: boolean = true;\n160:   private showingBuildLog: boolean = false;\n161:   private showingLogFile: boolean = false;\n162:   private logFileBox: Widgets.Log | null = null;\n163:   private refreshTimer: ReturnType<typeof setInterval> | null = null;\n164:   private waveComplete: boolean = false;\n165:   private waveCompleteResolve: (() => void) | null = null;\n166: \n167:   /** Pending HITL questions from agents */\n168:   private pendingQuestions: HitlQuestion[] = [];\n169:   /** Active question popup (null when closed) */\n170:   private questionPopup: QuestionPopup | null = null;\n171: \n172:   /** Saved originals for console interception */\n173:   private origConsoleLog: typeof console.log = console.log;\n174:   private origConsoleError: typeof console.error = console.error;\n175:   private origConsoleWarn: typeof console.warn = console.warn;\n176:   /** System messages captured while TUI is active */\n177:   private systemMessages: ActivityEntry[] = [];\n178: \n179:   constructor(opts: TUIOptions) {\n180:     this.state = opts.state;\n181:     this.monitor = opts.monitor;\n182:     this.onQuit = opts.onQuit;\n183:     this.onRetry = opts.onRetry;\n184:     this.onAnswer = opts.onAnswer;\n185:     this.onBeforeDestroy = opts.onBeforeDestroy;\n186:     this.interactive = opts.interactive ?? false;\n187:     this.projectRoot = opts.projectRoot;\n188:     this.config = opts.config;\n189: \n190:     // Create screen\n191:     this.screen = blessed.screen({\n192:       smartCSR: true,\n193:       title: `wombo-combo — ${opts.state.wave_id}`,\n194:       fullUnicode: true,\n195:     });\n196: \n197:     // Header\n198:     this.headerBox = blessed.box({\n199:       top: 0,\n200:       left: 0,\n201:       width: \"100%\",\n202:       height: 3,\n203:       tags: true,\n204:       style: {\n205:         fg: \"white\",\n206:         bg: \"black\",\n207:       },\n208:     });\n209: \n210:     // Agent list (left pane)\n211:     this.agentList = blessed.list({\n212:       top: 3,\n213:       left: 0,\n214:       width: \"55%\",\n215:       height: \"100%-6\",\n216:       tags: true,\n217:       scrollable: true,\n218:       mouse: true,\n219:       keys: true,\n220:       vi: true,\n221:       border: {\n222:         type: \"line\",\n223:       },\n224:       style: {\n225:         border: { fg: \"gray\" },\n226:         selected: {\n227:           bg: \"blue\",\n228:           fg: \"white\",\n229:           bold: true,\n230:         },\n231:         item: {\n232:           fg: \"white\",\n233:         },\n234:       },\n235:       label: \" Agents \",\n236:     });\n237: \n238:     // Preview pane (right pane)\n239:     this.previewBox = blessed.log({\n240:       top: 3,\n241:       left: \"55%\",\n242:       width: \"45%\",\n243:       height: \"100%-6\",\n244:       tags: true,\n245:       scrollable: true,\n246:       mouse: true,\n247:       keys: false,\n248:       scrollbar: {\n249:         ch: \"│\",\n250:         style: { fg: \"cyan\" },\n251:       },\n252:       border: {\n253:         type: \"line\",\n254:       },\n255:       style: {\n256:         border: { fg: \"gray\" },\n257:         fg: \"white\",\n258:       },\n259:       label: \" Activity \",\n260:     });\n261: \n262:     // Build log overlay (hidden by default)\n263:     this.buildLogBox = blessed.log({\n264:       top: 3,\n265:       left: \"10%\",\n266:       width: \"80%\",\n267:       height: \"100%-6\",\n268:       tags: true,\n269:       scrollable: true,\n270:       mouse: true,\n271:       keys: true,\n272:       scrollbar: {\n273:         ch: \"│\",\n274:         style: { fg: \"yellow\" },\n275:       },\n276:       border: {\n277:         type: \"line\",\n278:       },\n279:       style: {\n280:         border: { fg: \"yellow\" },\n281:         fg: \"white\",\n282:       },\n283:       label: \" Build Log \",\n284:       hidden: true,\n285:     });\n286: \n287:     // Status bar\n288:     this.statusBar = blessed.box({\n289:       bottom: 0,\n290:       left: 0,\n291:       width: \"100%\",\n292:       height: 3,\n293:       tags: true,\n294:       style: {\n295:         fg: \"white\",\n296:         bg: \"black\",\n297:       },\n298:     });\n299: \n300:     // Assemble\n301:     this.screen.append(this.headerBox);\n302:     this.screen.append(this.agentList);\n303:     this.screen.append(this.previewBox);\n304:     this.screen.append(this.buildLogBox);\n305:     this.screen.append(this.statusBar);\n306: \n307:     // Focus the agent list\n308:     this.agentList.focus();\n309: \n310:     // Bind keys\n311:     this.bindKeys();\n312:   }\n313: \n314:   // -------------------------------------------------------------------------\n315:   // Key Bindings\n316:   // -------------------------------------------------------------------------\n317: \n318:   private bindKeys(): void {\n319:     // Quit\n320:     this.screen.key([\"q\", \"C-c\"], () => {\n321:       this.stop();\n322:       if (this.waveComplete && this.waveCompleteResolve) {\n323:         // Wave is done — just close TUI and resolve the wait promise\n324:         this.waveCompleteResolve();\n325:       } else {\n326:         // Wave still running — trigger the abort/interrupt handler\n327:         this.onQuit();\n328:       }\n329:     });\n330: \n331:     // Navigate agent list\n332:     this.agentList.on(\"select item\", (_item: any, index: number) => {\n333:       this.selectedIndex = index;\n334:       this.refreshPreview();\n335:     });\n336: \n337:     // Enter — multiplexer attach\n338:     this.screen.key([\"enter\"], () => {\n339:       this.muxAttach();\n340:     });\n341: \n342:     // b — toggle build log\n343:     this.screen.key([\"b\"], () => {\n344:       this.toggleBuildLog();\n345:     });\n346: \n347:     // p — toggle auto-scroll\n348:     this.screen.key([\"p\"], () => {\n349:       this.autoScroll = !this.autoScroll;\n350:       this.refreshStatusBar();\n351:     });\n352: \n353:     // r — retry failed/stuck agent\n354:     this.screen.key([\"r\"], () => {\n355:       this.retrySelected();\n356:     });\n357: \n358:     // h — open HITL question popup\n359:     this.screen.key([\"h\"], () => {\n360:       this.openQuestionPopup();\n361:     });\n362: \n363:     // Escape — close build log, log file overlay, or question popup\n364:     this.screen.key([\"escape\"], () => {\n365:       if (this.questionPopup && !this.questionPopup.isDestroyed()) {\n366:         this.questionPopup.close();\n367:         this.questionPopup = null;\n368:         this.agentList.focus();\n369:         this.screen.render();\n370:       } else if (this.showingBuildLog) {\n371:         this.showingBuildLog = false;\n372:         this.buildLogBox.hide();\n373:         this.agentList.focus();\n374:         this.screen.render();\n375:       } else if (this.showingLogFile && this.logFileBox) {\n376:         this.showingLogFile = false;\n377:         this.logFileBox.destroy();\n378:         this.logFileBox = null;\n379:         this.agentList.focus();\n380:         this.screen.render();\n381:       }\n382:     });\n383:   }\n384: \n385:   // -------------------------------------------------------------------------\n386:   // Start / Stop\n387:   //\n388:   // ## TUI Lifecycle and Agent Processes (audit: wave-detach-audit)\n389:   //\n390:   // `stop()` only tears down the TUI — it clears the refresh timer and\n391:   // destroys the blessed screen. It does NOT kill agent processes.\n392:   //\n393:   // Agent process termination is handled by the `onQuit` callback, which\n394:   // is set by launch.ts/resume.ts to call `monitor.killAll()` + state save.\n395:   //\n396:   // The separation is intentional:\n397:   //   - `stop()` is also called before mux attach (muxAttach method) where\n398:   //     the TUI is temporarily destroyed and recreated after detach.\n399:   //   - `onQuit()` is only called when the user intends to exit the entire\n400:   //     wave, triggering agent cleanup and process exit.\n401:   //\n402:   // `screen.destroy()` does NOT affect child processes because agents are\n403:   // spawned by the ProcessMonitor (in the launch command), not by the TUI.\n404:   // The TUI only reads from the monitor — it never owns agent processes.\n405:   // -------------------------------------------------------------------------\n406: \n407:   start(): void {\n408:     this.interceptConsole();\n409:     this.refresh();\n410:     this.screen.render();\n411: \n412:     // Auto-refresh every 2 seconds\n413:     this.refreshTimer = setInterval(() => {\n414:       this.refresh();\n415:     }, 2000);\n416:   }\n417: \n418:   stop(): void {\n419:     this.restoreConsole();\n420:     if (this.refreshTimer) {\n421:       clearInterval(this.refreshTimer);\n422:       this.refreshTimer = null;\n423:     }\n424:     // Flush pending state writes before destroying the screen.\n425:     // This ensures state.json integrity even if process.exit() follows.\n426:     if (this.onBeforeDestroy) {\n427:       try {\n428:         this.onBeforeDestroy();\n429:       } catch {\n430:         // Best-effort — don't let flush errors prevent screen cleanup\n431:       }\n432:     }\n433:     this.screen.destroy();\n434:   }\n435: \n436:   /**\n437:    * Intercept console.log/error/warn so they don't corrupt the TUI.\n438:    * Messages are captured into systemMessages and shown in the preview\n439:    * when no specific agent is producing activity.\n440:    */\n441:   private interceptConsole(): void {\n442:     this.origConsoleLog = console.log;\n443:     this.origConsoleError = console.error;\n444:     this.origConsoleWarn = console.warn;\n445: \n446:     const capture = (...args: any[]) => {\n447:       const text = args\n448:         .map((a) => (typeof a === \"string\" ? a : JSON.stringify(a)))\n449:         .join(\" \");\n450:       // Strip ANSI codes for clean TUI display\n451:       const clean = text.replace(/\\x1b\\[[0-9;]*m/g, \"\");\n452:       if (!clean.trim()) return;\n453:       this.systemMessages.push({\n454:         timestamp: new Date().toISOString().slice(11, 19),\n455:         text: clean,\n456:       });\n457:       // Keep bounded\n458:       if (this.systemMessages.length > 200) {\n459:         this.systemMessages.splice(0, this.systemMessages.length - 200);\n460:       }\n461:     };\n462: \n463:     console.log = capture;\n464:     console.error = capture;\n465:     console.warn = capture;\n466:   }\n467: \n468:   /**\n469:    * Restore original console methods.\n470:    */\n471:   private restoreConsole(): void {\n472:     console.log = this.origConsoleLog;\n473:     console.error = this.origConsoleError;\n474:     console.warn = this.origConsoleWarn;\n475:   }\n476: \n477:   /**\n478:    * Update the state reference (called from the monitoring loop).\n479:    */\n480:   updateState(state: WaveState): void {\n481:     this.state = state;\n482:   }\n483: \n484:   /**\n485:    * Mark the wave as complete. The TUI stays open so the user can browse\n486:    * agent logs, build output, etc. The header shows a WAVE COMPLETE banner\n487:    * and the status bar tells the user to press q to exit.\n488:    */\n489:   markWaveComplete(): void {\n490:     this.waveComplete = true;\n491:     this.refresh();\n492:   }\n493: \n494:   /**\n495:    * Returns a Promise that resolves when the user presses q to quit.\n496:    * Used after wave completion so the TUI stays open for post-mortem browsing.\n497:    */\n498:   waitForQuit(): Promise<void> {\n499:     return new Promise<void>((resolve) => {\n500:       this.waveCompleteResolve = resolve;\n501:     });\n502:   }\n503: \n504:   /**\n505:    * Update pending HITL questions. Called from the monitoring loop.\n506:    * If the question popup is open, it gets live-updated too.\n507:    */\n508:   setPendingQuestions(questions: HitlQuestion[]): void {\n509:     this.pendingQuestions = questions;\n510:     if (this.questionPopup && !this.questionPopup.isDestroyed()) {\n511:       this.questionPopup.updateQuestions(questions);\n512:     }\n513:     // Status bar will pick up the badge on next refresh cycle\n514:   }\n515: \n516:   /**\n517:    * Open the HITL question popup modal.\n518:    */\n519:   private openQuestionPopup(): void {\n520:     // Don't open if already open\n521:     if (this.questionPopup && !this.questionPopup.isDestroyed()) return;\n522: \n523:     // Don't open if there are no pending questions\n524:     if (this.pendingQuestions.length === 0) {\n525:       // Flash a message in the preview\n526:       const agent = this.state.agents[this.selectedIndex];\n527:       if (agent) {\n528:         const logs = this.monitor.activityLogs.get(agent.feature_id);\n529:         if (logs) {\n530:           logs.push({\n531:             timestamp: new Date().toISOString().slice(11, 19),\n532:             text: `-- No pending HITL questions`,\n533:           });\n534:         }\n535:         this.refreshPreview();\n536:         this.screen.render();\n537:       }\n538:       return;\n539:     }\n540: \n541:     this.questionPopup = new QuestionPopup(\n542:       this.screen,\n543:       [...this.pendingQuestions], // copy so popup can mutate internally\n544:       {\n545:         onAnswer: (agentId, questionId, answerText) => {\n546:           // Forward to the external callback (which calls submitAnswer)\n547:           if (this.onAnswer) {\n548:             this.onAnswer(agentId, questionId, answerText);\n549:           }\n550:           // Remove from our pending list\n551:           this.pendingQuestions = this.pendingQuestions.filter(\n552:             (q) => !(q.agentId === agentId && q.id === questionId)\n553:           );\n554:         },\n555:         onClose: () => {\n556:           this.questionPopup = null;\n557:           this.agentList.focus();\n558:           this.refreshStatusBar();\n559:           this.screen.render();\n560:         },\n561:       }\n562:     );\n563:   }\n564: \n565:   // -------------------------------------------------------------------------\n566:   // Refresh Logic\n567:   // -------------------------------------------------------------------------\n568: \n569:   private refresh(): void {\n570:     this.refreshHeader();\n571:     this.refreshAgentList();\n572:     this.refreshPreview();\n573:     this.refreshStatusBar();\n574:     this.screen.render();\n575:   }\n576: \n577:   private refreshHeader(): void {\n578:     const s = this.state;\n579:     const counts = agentCounts(s);\n580:     const total = s.agents.length;\n581:     const done = counts.verified + counts.merged;\n582: \n583:     let line1 = ` {bold}wombo-combo{/bold} {gray-fg}${s.wave_id}{/gray-fg}`;\n584:     if (this.waveComplete) {\n585:       line1 += `  {gray-fg}│{/gray-fg}  {bold}{green-fg}WAVE COMPLETE{/green-fg}{/bold}`;\n586:     }\n587:     line1 += `  {gray-fg}│{/gray-fg}  Base: {cyan-fg}${s.base_branch}{/cyan-fg}`;\n588:     line1 += `  {gray-fg}│{/gray-fg}  Mode: ${s.interactive ? \"{green-fg}interactive{/green-fg}\" : \"{blue-fg}headless{/blue-fg}\"}`;\n589:     if (s.model) {\n590:       line1 += `  {gray-fg}│{/gray-fg}  Model: {yellow-fg}${s.model}{/yellow-fg}`;\n591:     }\n592: \n593:     let line2 = ` Progress: {green-fg}${done}{/green-fg}/{white-fg}${total}{/white-fg}`;\n594:     if (counts.running > 0)\n595:       line2 += `  {blue-fg}${counts.running} running{/blue-fg}`;\n596:     if (counts.failed > 0)\n597:       line2 += `  {red-fg}${counts.failed} failed{/red-fg}`;\n598:     if (counts.queued > 0)\n599:       line2 += `  {gray-fg}${counts.queued} queued{/gray-fg}`;\n600:     if (counts.retry > 0)\n601:       line2 += `  {yellow-fg}${counts.retry} retrying{/yellow-fg}`;\n602:     if (counts.resolving_conflict > 0)\n603:       line2 += `  {cyan-fg}${counts.resolving_conflict} resolving{/cyan-fg}`;\n604: \n605:     this.headerBox.setContent(`${line1}\\n${line2}`);\n606:   }\n607: \n608:   private refreshAgentList(): void {\n609:     const items: string[] = [];\n610: \n611:     for (let i = 0; i < this.state.agents.length; i++) {\n612:       const a = this.state.agents[i];\n613:       const color = STATUS_COLORS[a.status];\n614:       const icon = STATUS_ICONS[a.status];\n615: \n616:       // Feature ID (padded)\n617:       const fid =\n618:         a.feature_id.length > 24\n619:           ? a.feature_id.slice(0, 23) + \"…\"\n620:           : a.feature_id.padEnd(24);\n621: \n622:       // Status\n623:       const st = `{${color}-fg}${icon} ${a.status.padEnd(10)}{/${color}-fg}`;\n624: \n625:       // Progress bar\n626:       let pbar = \"\";\n627:       if ((a.status === \"running\" || a.status === \"resolving_conflict\") && a.started_at) {\n628:         const elapsedMs = Date.now() - new Date(a.started_at).getTime();\n629:         // Use actual effort estimate from feature data, fallback to 1h\n630:         const estimateMs = a.effort_estimate_ms ?? 60 * 60 * 1000;\n631:         pbar = ` {cyan-fg}${progressBar(elapsedMs, estimateMs, 8)}{/cyan-fg}`;\n632:       } else if (a.status === \"verified\" || a.status === \"merged\") {\n633:         pbar = ` {green-fg}${\"█\".repeat(8)}{/green-fg}`;\n634:       } else if (a.status === \"failed\") {\n635:         pbar = ` {red-fg}${\"█\".repeat(8)}{/red-fg}`;\n636:       }\n637: \n638:       // Activity (for running/resolving agents)\n639:       let act = \"\";\n640:       if ((a.status === \"running\" || a.status === \"resolving_conflict\") && a.activity) {\n641:         const rawAct =\n642:           a.activity.length > 25 ? a.activity.slice(0, 24) + \"…\" : a.activity;\n643:         const actText = escapeBlessedTags(rawAct);\n644:         act = ` {cyan-fg}${actText}{/cyan-fg}`;\n645:       } else if (a.status === \"installing\") {\n646:         act = \" {cyan-fg}setting up…{/cyan-fg}\";\n647:       }\n648: \n649:       // Elapsed\n650:       const el = elapsed(a.started_at);\n651: \n652:       // Retries\n653:       const retries =\n654:         a.retries > 0 ? ` {yellow-fg}↻${a.retries}{/yellow-fg}` : \"\";\n655: \n656:       items.push(\n657:         ` ${fid} ${st}${pbar}${act}${retries} {gray-fg}${el}{/gray-fg}`\n658:       );\n659:     }\n660: \n661:     // Preserve selection\n662:     const prevSelected = this.selectedIndex;\n663:     this.agentList.setItems(items as any);\n664:     if (prevSelected < items.length) {\n665:       this.agentList.select(prevSelected);\n666:     }\n667:   }\n668: \n669:   private refreshPreview(): void {\n670:     const agent = this.state.agents[this.selectedIndex];\n671:     if (!agent) {\n672:       this.previewBox.setContent(\"{gray-fg}No agent selected{/gray-fg}\");\n673:       return;\n674:     }\n675: \n676:     // Update label\n677:     this.previewBox.setLabel(` ${agent.feature_id} — Activity `);\n678: \n679:     // Get activity log from monitor\n680:     const log = this.monitor.getActivityLog(agent.feature_id);\n681: \n682:     // Also include system messages (build verification, etc.)\n683:     // that mention this agent's feature_id\n684:     const relevantSys = this.systemMessages.filter((m) =>\n685:       m.text.includes(agent.feature_id)\n686:     );\n687: \n688:     if (log.length === 0 && relevantSys.length === 0) {\n689:       this.previewBox.setContent(\n690:         \"{gray-fg}No activity yet. Waiting for agent output…{/gray-fg}\"\n691:       );\n692:       return;\n693:     }\n694: \n695:     // Format log entries\n696:     const lines: string[] = [];\n697:     for (const entry of log) {\n698:       lines.push(this.formatActivityLine(entry));\n699:     }\n700: \n701:     // Append relevant system messages\n702:     if (relevantSys.length > 0) {\n703:       lines.push(\"\");\n704:       lines.push(\"{yellow-fg}-- system --{/yellow-fg}\");\n705:       for (const entry of relevantSys) {\n706:         const ts = `{gray-fg}${entry.timestamp}{/gray-fg}`;\n707:         lines.push(`${ts} {yellow-fg}${escapeBlessedTags(entry.text)}{/yellow-fg}`);\n708:       }\n709:     }\n710: \n711:     this.previewBox.setContent(lines.join(\"\\n\"));\n712: \n713:     // Auto-scroll to bottom\n714:     if (this.autoScroll) {\n715:       this.previewBox.setScrollPerc(100);\n716:     }\n717:   }\n718: \n719:   private formatActivityLine(entry: ActivityEntry): string {\n720:     const ts = `{gray-fg}${entry.timestamp}{/gray-fg}`;\n721:     let text = escapeBlessedTags(entry.text);\n722: \n723:     // Color-code different line types\n724:     if (text.startsWith(\">>\")) {\n725:       text = `{cyan-fg}${text}{/cyan-fg}`;\n726:     } else if (text.startsWith(\"!!\")) {\n727:       text = `{red-fg}${text}{/red-fg}`;\n728:     } else if (text.startsWith(\"--\")) {\n729:       text = `{green-fg}${text}{/green-fg}`;\n730:     } else if (text.startsWith(\"[stderr]\")) {\n731:       text = `{red-fg}${text}{/red-fg}`;\n732:     } else if (text.startsWith(\"[raw]\")) {\n733:       text = `{gray-fg}${text}{/gray-fg}`;\n734:     } else if (text.startsWith(\"   \")) {\n735:       text = `{white-fg}${text}{/white-fg}`;\n736:     }\n737: \n738:     return `${ts} ${text}`;\n739:   }\n740: \n741:   private refreshStatusBar(): void {\n742:     const scrollStatus = this.autoScroll\n743:       ? \"{green-fg}auto-scroll{/green-fg}\"\n744:       : \"{yellow-fg}paused{/yellow-fg}\";\n745: \n746:     const agent = this.state.agents[this.selectedIndex];\n747:     const agentInfo = agent\n748:       ? `{gray-fg}Selected: {white-fg}${agent.feature_id}{/white-fg}{/gray-fg}`\n749:       : \"\";\n750: \n751:     const enterHint = this.interactive\n752:       ? \"{gray-fg}Enter{/gray-fg} attach session\"\n753:       : \"{gray-fg}Enter{/gray-fg} view log\";\n754: \n755:     // HITL badge — show only when there are pending questions\n756:     const hitlBadge =\n757:       this.pendingQuestions.length > 0\n758:         ? `  {bold}{yellow-fg}? ${this.pendingQuestions.length} pending{/yellow-fg}{/bold}  {gray-fg}H{/gray-fg} answer`\n759:         : \"\";\n760: \n761:     let line1: string;\n762:     if (this.waveComplete) {\n763:       line1 = ` {bold}{green-fg}Wave complete.{/green-fg}{/bold}  ${enterHint}  {gray-fg}R{/gray-fg} retry  {gray-fg}B{/gray-fg} build log  {gray-fg}P{/gray-fg} ${scrollStatus}${hitlBadge}  {bold}{yellow-fg}Q{/yellow-fg} exit{/bold}`;\n764:     } else {\n765:       line1 = ` {bold}Keys:{/bold} {gray-fg}\\u2191\\u2193{/gray-fg} navigate  ${enterHint}  {gray-fg}R{/gray-fg} retry  {gray-fg}B{/gray-fg} build log  {gray-fg}P{/gray-fg} ${scrollStatus}${hitlBadge}  {gray-fg}Q{/gray-fg} quit`;\n766:     }\n767:     const line2 = ` ${agentInfo}`;\n768: \n769:     this.statusBar.setContent(`${line1}\\n${line2}`);\n770:   }\n771: \n772:   // -------------------------------------------------------------------------\n773:   // Actions\n774:   // -------------------------------------------------------------------------\n775: \n776:   private muxAttach(): void {\n777:     const agent = this.state.agents[this.selectedIndex];\n778:     if (!agent) return;\n779: \n780:     if (!this.interactive) {\n781:       // Headless mode — show the raw log file in an overlay\n782:       this.showLogFile(agent);\n783:       return;\n784:     }\n785: \n786:     const mux = detectMultiplexer(this.config.agent.multiplexer);\n787:     const sessionName = `${this.config.agent.tmuxPrefix}-${agent.feature_id}`;\n788: \n789:     // Check if multiplexer session exists\n790:     if (!muxHasSession(mux, sessionName)) {\n791:       // No session — show message in preview\n792:       this.monitor.activityLogs.get(agent.feature_id)?.push({\n793:         timestamp: new Date().toISOString().slice(11, 19),\n794:         text: `!! No ${muxDisplayName(mux)} session '${sessionName}' found`,\n795:       });\n796:       this.refreshPreview();\n797:       this.screen.render();\n798:       return;\n799:     }\n800: \n801:     // Detach from blessed, attach to multiplexer session\n802:     this.restoreConsole();\n803:     this.screen.destroy();\n804:     try {\n805:       muxAttach(mux, sessionName);\n806:     } catch {\n807:       // User detached from session — resume TUI\n808:     }\n809: \n810:     // Re-create screen after returning from multiplexer\n811:     this.recreateScreen();\n812:   }\n813: \n814:   /**\n815:    * Retry the selected agent (only if failed or stuck in retry).\n816:    * Resets it to \"queued\" so the polling loop picks it up for a fresh launch.\n817:    */\n818:   private retrySelected(): void {\n819:     const agent = this.state.agents[this.selectedIndex];\n820:     if (!agent) return;\n821: \n822:     const retryableStatuses: AgentStatus[] = [\"failed\", \"retry\"];\n823:     if (!retryableStatuses.includes(agent.status)) {\n824:       // Flash a message in the preview — agent isn't in a retryable state\n825:       const logs = this.monitor.activityLogs.get(agent.feature_id);\n826:       if (logs) {\n827:         logs.push({\n828:           timestamp: new Date().toISOString().slice(11, 19),\n829:           text: `!! Cannot retry — agent status is \"${agent.status}\" (must be failed or retry)`,\n830:         });\n831:       }\n832:       this.refreshPreview();\n833:       this.screen.render();\n834:       return;\n835:     }\n836: \n837:     if (this.onRetry) {\n838:       this.onRetry(agent.feature_id);\n839: \n840:       // Show feedback in preview\n841:       const logs = this.monitor.activityLogs.get(agent.feature_id);\n842:       if (logs) {\n843:         logs.push({\n844:           timestamp: new Date().toISOString().slice(11, 19),\n845:           text: `>> Retry requested — agent will be relaunched`,\n846:         });\n847:       }\n848:       this.refresh();\n849:       this.screen.render();\n850:     }\n851:   }\n852: \n853:   /**\n854:    * Show the raw log file for an agent in an overlay (headless mode).\n855:    */\n856:   private showLogFile(agent: AgentState): void {\n857:     if (this.showingLogFile) {\n858:       // Toggle off\n859:       this.showingLogFile = false;\n860:       if (this.logFileBox) {\n861:         this.logFileBox.destroy();\n862:         this.logFileBox = null;\n863:       }\n864:       this.agentList.focus();\n865:       this.screen.render();\n866:       return;\n867:     }\n868: \n869:     const logPath = resolve(\n870:       this.projectRoot,\n871:       \".wombo-combo\",\n872:       \"logs\",\n873:       `${agent.feature_id}.log`\n874:     );\n875:     let content: string;\n876:     try {\n877:       content = readFileSync(logPath, \"utf-8\");\n878:       if (!content.trim()) {\n879:         content =\n880:           \"{gray-fg}Log file is empty. Agent may not have started producing output yet.{/gray-fg}\";\n881:       }\n882:     } catch {\n883:       content = \"{gray-fg}No log file found at \" + logPath + \"{/gray-fg}\";\n884:     }\n885: \n886:     // Create overlay\n887:     this.logFileBox = blessed.log({\n888:       top: 3,\n889:       left: \"5%\",\n890:       width: \"90%\",\n891:       height: \"100%-6\",\n892:       tags: true,\n893:       scrollable: true,\n894:       mouse: true,\n895:       keys: true,\n896:       scrollbar: {\n897:         ch: \"│\",\n898:         style: { fg: \"cyan\" },\n899:       },\n900:       border: {\n901:         type: \"line\",\n902:       },\n903:       style: {\n904:         border: { fg: \"cyan\" },\n905:         fg: \"white\",\n906:       },\n907:       label: ` Log — ${agent.feature_id} (Esc to close) `,\n908:     });\n909: \n910:     this.screen.append(this.logFileBox);\n911: \n912:     // Truncate to last 200 lines to keep TUI responsive\n913:     const lines = content.split(\"\\n\");\n914:     const truncated =\n915:       lines.length > 200 ? lines.slice(-200).join(\"\\n\") : content;\n916:     this.logFileBox.setContent(escapeBlessedTags(truncated));\n917:     this.logFileBox.setScrollPerc(100);\n918:     this.logFileBox.focus();\n919:     this.showingLogFile = true;\n920:     this.screen.render();\n921:   }\n922: \n923:   private toggleBuildLog(): void {\n924:     const agent = this.state.agents[this.selectedIndex];\n925:     if (!agent) return;\n926: \n927:     if (this.showingBuildLog) {\n928:       this.showingBuildLog = false;\n929:       this.buildLogBox.hide();\n930:       this.agentList.focus();\n931:     } else {\n932:       this.showingBuildLog = true;\n933:       this.buildLogBox.setLabel(` Build Log — ${agent.feature_id} `);\n934: \n935:       if (agent.build_output) {\n936:         this.buildLogBox.setContent(escapeBlessedTags(agent.build_output));\n937:       } else if (agent.build_passed === true) {\n938:         this.buildLogBox.setContent(\n939:           \"{green-fg}Build passed — no errors.{/green-fg}\"\n940:         );\n941:       } else if (agent.build_passed === false) {\n942:         this.buildLogBox.setContent(\n943:           \"{red-fg}Build failed — no output captured.{/red-fg}\"\n944:         );\n945:       } else {\n946:         this.buildLogBox.setContent(\n947:           \"{gray-fg}No build has been run yet.{/gray-fg}\"\n948:         );\n949:       }\n950: \n951:       this.buildLogBox.show();\n952:       this.buildLogBox.focus();\n953:     }\n954:     this.screen.render();\n955:   }\n956: \n957:   /**\n958:    * Re-create the screen after returning from multiplexer attach.\n959:    * Blessed can't resume after destroy, so we rebuild everything.\n960:    */\n961:   private recreateScreen(): void {\n962:     // Re-create screen\n963:     this.screen = blessed.screen({\n964:       smartCSR: true,\n965:       title: `wombo-combo — ${this.state.wave_id}`,\n966:       fullUnicode: true,\n967:     });\n968: \n969:     // Re-create all widgets\n970:     this.headerBox = blessed.box({\n971:       top: 0,\n972:       left: 0,\n973:       width: \"100%\",\n974:       height: 3,\n975:       tags: true,\n976:       style: { fg: \"white\", bg: \"black\" },\n977:     });\n978: \n979:     this.agentList = blessed.list({\n980:       top: 3,\n981:       left: 0,\n982:       width: \"55%\",\n983:       height: \"100%-6\",\n984:       tags: true,\n985:       scrollable: true,\n986:       mouse: true,\n987:       keys: true,\n988:       vi: true,\n989:       border: { type: \"line\" },\n990:       style: {\n991:         border: { fg: \"gray\" },\n992:         selected: { bg: \"blue\", fg: \"white\", bold: true },\n993:         item: { fg: \"white\" },\n994:       },\n995:       label: \" Agents \",\n996:     });\n997: \n998:     this.previewBox = blessed.log({\n999:       top: 3,\n1000:       left: \"55%\",\n1001:       width: \"45%\",\n1002:       height: \"100%-6\",\n1003:       tags: true,\n1004:       scrollable: true,\n1005:       mouse: true,\n1006:       keys: false,\n1007:       scrollbar: { ch: \"│\", style: { fg: \"cyan\" } },\n1008:       border: { type: \"line\" },\n1009:       style: { border: { fg: \"gray\" }, fg: \"white\" },\n1010:       label: \" Activity \",\n1011:     });\n1012: \n1013:     this.buildLogBox = blessed.log({\n1014:       top: 3,\n1015:       left: \"10%\",\n1016:       width: \"80%\",\n1017:       height: \"100%-6\",\n1018:       tags: true,\n1019:       scrollable: true,\n1020:       mouse: true,\n1021:       keys: true,\n1022:       scrollbar: { ch: \"│\", style: { fg: \"yellow\" } },\n1023:       border: { type: \"line\" },\n1024:       style: { border: { fg: \"yellow\" }, fg: \"white\" },\n1025:       label: \" Build Log \",\n1026:       hidden: true,\n1027:     });\n1028: \n1029:     this.statusBar = blessed.box({\n1030:       bottom: 0,\n1031:       left: 0,\n1032:       width: \"100%\",\n1033:       height: 3,\n1034:       tags: true,\n1035:       style: { fg: \"white\", bg: \"black\" },\n1036:     });\n1037: \n1038:     this.screen.append(this.headerBox);\n1039:     this.screen.append(this.agentList);\n1040:     this.screen.append(this.previewBox);\n1041:     this.screen.append(this.buildLogBox);\n1042:     this.screen.append(this.statusBar);\n1043: \n1044:     this.agentList.focus();\n1045:     this.showingBuildLog = false;\n1046:     this.showingLogFile = false;\n1047:     this.logFileBox = null;\n1048:     this.questionPopup = null;\n1049:     this.interceptConsole();\n1050:     this.bindKeys();\n1051:     this.refresh();\n1052:   }\n1053: }\n\n(End of file - total 1053 lines)\n</content>","title":"src/lib/tui.ts","metadata":{"preview":"/**\n * tui.ts — Blessed-based TUI dashboard for wombo-combo.\n *\n * Layout:\n *   ┌─────────────────────────────────────────────┐\n *   │ Header: Wave ID, base branch, mode, model   │\n *   ├──────────────────────────┬──────────────────┤\n *   │ Agent Table              │ Preview Pane     │\n *   │ (selectable rows with    │ (parsed activity │\n *   │  status, activity,       │  stream for the  │\n *   │  progress bars, elapsed) │  selected agent) │\n *   ├──────────────────────────┴──────────────────┤\n *   │ Status bar: keybinds + summary counts       │\n *   └─────────────────────────────────────────────┘\n *\n * Keybinds:\n *   Up/Down   — navigate agent list\n *   Enter     — attach to selected agent's multiplexer session (interactive mode)\n *   r         — retry a failed/stuck agent\n *   b         — show build log for selected agent","truncated":false,"loaded":[]},"time":{"start":1773483622116,"end":1773483622123}}}}
