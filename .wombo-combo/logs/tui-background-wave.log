\n836:   private refreshTaskList(): void {\n837:     const items: string[] = [];\n838:     let lastStreamId = \"\";\n839: \n840:     for (let i = 0; i < this.displayNodes.length; i++) {\n841:       const node = this.displayNodes[i];\n842:       const t = node.task;\n843: \n844:       // Stream separator\n845:       if (node.streamId !== lastStreamId && lastStreamId !== \"\") {\n846:         // We use a visual separator row — but it's not selectable in blessed list,\n847:         // so we just change the color/style\n848:       }\n\n(Showing lines 809-848 of 1048. Use offset=849 to continue.)\n</content>","title":"src/lib/tui-browser.ts","metadata":{"preview":"  private refreshHeader(): void {\n    const total = this.allTasks.length;\n    const displayed = this.displayNodes.length;\n    const selectedCount = this.selected.size;\n    const doneCount = this.allTasks.filter((t) => t.status === \"done\").length;\n    const readyCount = this.allTasks.filter(\n      (t) => t.status === \"backlog\" && areDependenciesMet(t, this.doneIds)\n    ).length;\n\n    let line1 = ` {bold}wombo-combo{/bold}`;\n    if (this.questTitle) {\n      line1 += ` {magenta-fg}\\u25B6 ${escapeBlessedTags(this.questTitle)}{/magenta-fg}`;\n    } else {\n      line1 += ` {cyan-fg}Task Browser{/cyan-fg}`;\n    }\n    line1 += `  {gray-fg}|{/gray-fg}  {white-fg}${total}{/white-fg} tasks`;\n    if (this.hideDone) line1 += ` ({white-fg}${displayed}{/white-fg} shown)`;\n    line1 += `  {gray-fg}|{/gray-fg}  {green-fg}${selectedCount}{/green-fg} selected`;\n\n    let line2 = ` {green-fg}${doneCount}{/green-fg} done`;","truncated":true,"loaded":[]},"time":{"start":1773484056094,"end":1773484056097}}}}
