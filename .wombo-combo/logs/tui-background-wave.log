ve: false,\n          noTui: false,\n          autoPush: opts.autoPush ?? false,\n          baseBranch: opts.baseBranch,\n          maxRetries: opts.maxRetries,\n        });\n      } catch (err: any) {\n        console.error(`\\nResume error: ${err.message}\\n`);\n        await sleep(2000);\n      }\n      process.stdout.write(\"\\x1B[2J\\x1B[H\");\n      continue;\n    }\n\n    if (action.type === \"launch\") {","oldString":"    // -----------------------------------------------------------------------\n    // Task Browser (filtered by quest if one was selected)\n    // -----------------------------------------------------------------------\n    const action = await showBrowser(\n      projectRoot,\n      config,\n      session,\n      opts,\n      selectedQuestId,\n      hasQuests\n    );\n\n    if (action.type === \"quit\") {\n      // User pressed Q in browser with no quest context -- exit cleanly\n      session.lastView = \"browser\";\n      saveTUISession(projectRoot, session);\n      break;\n    }\n\n    if (action.type === \"back\") {\n      // User pressed Q/Esc in quest-filtered browser -- back to quest picker\n      process.stdout.write(\"\\x1B[2J\\x1B[H\");\n      continue;\n    }\n\n    if (action.type === \"errand\") {\n      // User pressed E in browser to create an errand\n      await handleErrandFlow(projectRoot, config, opts);\n      process.stdout.write(\"\\x1B[2J\\x1B[H\");\n      continue;\n    }\n\n    if (action.type === \"launch\") {"},"output":"Edit applied successfully.","title":"src/commands/tui.ts","metadata":{"diagnostics":{"/home/fulgidus/Documents/wombo-combo-worktrees/wave-detach-audit/src/lib/tui.ts":[{"range":{"start":{"line":29,"character":0},"end":{"line":29,"character":46}},"message":"'execSync' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"}],"/home/fulgidus/Documents/wombo-combo-worktrees/wave-detach-audit/src/commands/launch.ts":[{"range":{"start":{"line":33,"character":2},"end":{"line