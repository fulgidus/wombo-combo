he status change. This prevents callers\n185:  * from accidentally marking verified-but-unmerged features as done.\n\n(Showing lines 146-185 of 1959. Use offset=186 to continue.)\n</content>","title":"src/commands/launch.ts","metadata":{"preview":"export interface LaunchCommandOptions {\n  projectRoot: string;\n  config: WomboConfig;\n  // Selection\n  topPriority?: number;\n  quickestWins?: number;\n  priority?: Priority;\n  difficulty?: Difficulty;\n  features?: string[];\n  allReady?: boolean;\n  // Launch\n  maxConcurrent: number;\n  model?: string;\n  interactive: boolean;\n  dryRun: boolean;\n  baseBranch: string;\n  maxRetries: number;\n  noTui: boolean;\n  autoPush: boolean;\n  // Agent selection","truncated":true,"loaded":[]},"time":{"start":1773484228992,"end":1773484228998}}}}
