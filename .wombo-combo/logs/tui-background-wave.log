{"type":"tool_use","timestamp":1773483701865,"sessionID":"ses_31423da25ffebo9V1CTFH0IpgT","part":{"id":"prt_cebddb0e4001geHL0pt4zu7Rb0","sessionID":"ses_31423da25ffebo9V1CTFH0IpgT","messageID":"msg_cebdda6800018Lwd1UbrYBDHPy","type":"tool","callID":"toolu_vrtx_01NGcBPSGjKCnGKLupgtWsfr","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/wave-detach-audit/src/commands/launch.ts","offset":1100,"limit":100},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/wave-detach-audit/src/commands/launch.ts</path>\n<type>file</type>\n<content>1100:         activity,\n1101:         activity_updated_at: new Date().toISOString(),\n1102:       });\n1103:       // Don't save to disk on every activity — too frequent.\n1104:     },\n1105:   });\n1106: \n1107:   // Create the TUI — it will auto-refresh and show activity from the monitor\n1108:   const tuiRef = { current: null as WomboTUI | null };\n1109:   const startTUI = () => {\n1110:     tuiRef.current = new WomboTUI({\n1111:       state,\n1112:       monitor,\n1113:       projectRoot,\n1114:       interactive: false,\n1115:       config,\n1116:       onQuit: () => {\n1117:           // Audit (wave-detach-audit): This is the TUI quit path — equivalent\n1118:           // to the SIGINT handler. Kills all agents, saves state, and exits.\n1119:           // Agents are non-detached children, so they die when we exit anyway,\n1120:           // but explicit killAll() gives them SIGTERM for graceful shutdown.\n1121:           for (const agent of state.agents) {\n1122:             if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n1123:             updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n1124:           }\n1125:         }\n1126:         monitor.killAll();\n1127:         flushState(projectRoot, state);\n1128:         if (fmt === \"text\") console.log(\"State saved. Use 'woco resume' to continue.\");\n1129:         process.exit(0);\n1130:       },\n1131:       onBeforeDestroy: () => {\n1132:         // Flush state to disk before the blessed screen is destroyed.\n1133:         // This is called from TUI.stop() which runs before screen.destroy(),\n1134:         // ensuring state.json is complete even if process.exit() follows.\n1135:         flushState(projectRoot, state);\n1136:       },\n1137:       onRetry: (featureId: string) => {\n1138:         const agent = state.agents.find((a) => a.feature_id === featureId);\n1139:         if (!agent) return;\n1140:         if (agent.status !== \"failed\" && agent.status !== \"retry\") return;\n1141: \n1142:         // Reset retries if exhausted, give it one more shot\n1143:         if (agent.retries >= agent.max_retries) {\n1144:           updateAgent(state, featureId, { max_retries: agent.retries + 1 });\n1145:         }\n1146: \n1147:         wtLog(featureId, `manual retry requested from TUI — resetting to queued`);\n1148:         updateAgent(state, featureId, {\n1149:           status: \"queued\",\n1150:           error: null,\n1151:           activity: \"waiting for relaunch (manual retry)...\",\n1152:         });\n1153:         saveState(projectRoot, state);\n1154:         // The polling loop will call launchAllReady() and pick this up\n1155:       },\n1156:       onAnswer: (agentId: string, questionId: string, answerText: string) => {\n1157:         try {\n1158:           submitAnswer(projectRoot, agentId, questionId, answerText);\n1159:           wtLog(agentId, `HITL answer submitted: \"${answerText.slice(0, 80)}${answerText.length > 80 ? \"...\" : \"\"}\"`);\n1160:         } catch (err: any) {\n1161:           wtLog(agentId, `HITL answer error: ${err.message}`);\n1162:         }\n1163:       },\n1164:     });\n1165:     tuiRef.current.start();\n1166:   };\n1167: \n1168:   // Handle graceful shutdown\n1169:   //\n1170:   // Audit (wave-detach-audit): This is the critical shutdown path for headless\n1171:   // agents. Because agents are spawned with `detached: false` (see launcher.ts),\n1172:   // they would be killed by the OS when the parent exits anyway. However, calling\n1173:   // `monitor.killAll()` explicitly before `process.exit(0)` ensures:\n1174:   //   1. Each agent gets SIGTERM (not SIGKILL), allowing graceful shutdown\n1175:   //   2. Wave state is saved BEFORE agents die, preserving progress\n1176:   //   3. The TUI is cleanly destroyed before terminal restoration\n1177:   //\n1178:   // If the parent is killed with SIGKILL (uncatchable), agents die immediately\n1179:   // with no state save. `woco resume` recovers from this by detecting orphaned\n1180:   // worktrees with commits and re-verifying or re-launching as appropriate.\n1181:   const gracefulShutdown = (signal: string) => {\n1182:     if (tuiRef.current) tuiRef.current.stop();\n1183:     for (const agent of state.agents) {\n1184:       if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n1185:         updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n1186:       }\n1187:     }\n1188:     monitor.killAll();\n1189:     flushState(projectRoot, state);\n1190:     if (fmt === \"text\") console.log(`\\nState saved (${signal}). Use 'woco resume' to continue.`);\n1191:     process.exit(0);\n1192:   };\n1193:   process.on(\"SIGINT\", () => gracefulShutdown(\"SIGINT\"));\n1194:   process.on(\"SIGTERM\", () => gracefulShutdown(\"SIGTERM\"));\n1195:   process.on(\"SIGHUP\", () => gracefulShutdown(\"SIGHUP\"));\n1196: \n1197:   // Launch initial batch — only agents whose dependencies are already satisfied\n1198:   // Stagger launches to avoid SQLite race conditions in agent processes:\n1199:   // each agent spawns its own DB, and simultaneous CREATE TABLE calls collide.\n\n(Showing lines 1100-1199 of 1950. Use offset=1200 to continue.)\n</content>","title":"src/commands/launch.ts","metadata":{"preview":"        activity,\n        activity_updated_at: new Date().toISOString(),\n    