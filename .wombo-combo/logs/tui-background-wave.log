});\n324:       },\n325: \n326:       onQuit: () => {\n327:         resolve({ type: \"quit\" });\n328:       },\n329:     });\n330: \n331:     picker.start();\n332:   });\n333: }\n334: \n335: // ---------------------------------------------------------------------------\n336: // Plan Flow -- Planner + Review\n337: // ---------------------------------------------------------------------------\n338: \n339: /**\n340:  * Run the quest planner agent, then show the plan review TUI.\n341:  * Handles the full flow: spinner → planner → review → approve/cancel.\n342:  */\n343: async function handlePlanFlow(\n344:   projectRoot: string,\n345:   config: WomboConfig,\n346:   opts: TUICommandOptions,\n347:   questId: string\n348: ): Promise<void> {\n349:   const quest = loadQuest(projectRoot, questId);\n350:   if (!quest) {\n351:     console.error(`\\nQuest \"${questId}\" not found.\\n`);\n352:     await sleep(2000);\n353:     return;\n354:   }\n355: \n356:   // Set quest to planning status\n357:   const prevStatus = quest.status;\n358:   quest.status = \"planning\";\n359:   saveQuest(projectRoot, quest);\n\n(Showing lines 180-359 of 1017. Use offset=360 to continue.)\n</content>","title":"src/commands/tui.ts","metadata":{"preview":"\n      if (questAction.type === \"plan\") {\n        // User pressed P to plan a quest -- run planner + review\n        await handlePlanFlow(projectRoot, config, opts, questAction.questId);\n        // After planning (approve or cancel), loop back to quest picker\n        process.stdout.write(\"\\x1B[2J\\x1B[H\");\n        continue;\n      }\n\n      if (questAction.type === \"genesis\") {\n        // User pressed G to run genesis -- run genesis planner + review\n        await handleGenesisFlow(projectRoot, config, opts);\n        // After genesis (approve or cancel), loop back to quest picker\n        process.stdout.write(\"\\x1B[2J\\x1B[H\");\n        continue;\n      }\n\n      if (questAction.type === \"errand\") {\n        // User pressed E to c