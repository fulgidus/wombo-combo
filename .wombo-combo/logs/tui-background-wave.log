{"type":"tool_use","timestamp":1773484322036,"sessionID":"ses_31423da25ffebo9V1CTFH0IpgT","part":{"id":"prt_cebe729ba001qN5mkS9r2zN9qx","sessionID":"ses_31423da25ffebo9V1CTFH0IpgT","messageID":"msg_cebe71aff001dSMTBqkqOqvetS","type":"tool","callID":"toolu_vrtx_01A2radKwzP4v2aB1DDHjYAE","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/wave-detach-audit/src/commands/resume.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/wave-detach-audit/src/commands/resume.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * resume.ts — Resume a previously stopped wave.\n3:  *\n4:  * Usage: woco resume [options] [--output json]\n5:  *\n6:  * Restores from .wombo-combo/state.json:\n7:  *   - Agents in \"running\"/\"installing\" whose PID is dead → re-check or re-launch\n8:  *   - Agents in \"queued\" → launch them\n9:  *   - Agents in terminal states (verified/failed/merged) → leave alone\n10:  *\n11:  * ## Agent Recovery (audit: wave-detach-audit)\n12:  *\n13:  * This is the primary recovery mechanism for agents that died when the parent\n14:  * process was terminated (gracefully via SIGINT, or ungracefully via SIGKILL/crash).\n15:  *\n16:  * Recovery triage for each agent:\n17:  *   - PID still alive → leave it running (another wombo instance may still be active)\n18:  *   - PID dead + worktree has commits → run build verification on existing work\n19:  *   - PID dead + no commits → reset to \"queued\" for a fresh re-launch\n20:  *   - \"completed\" → verify build\n21:  *   - \"verified\" → attempt merge\n22:  *   - \"failed\" with retries remaining + worktree has commits → re-verify\n23:  *   - \"failed\" with retries remaining + no commits → re-launch\n24:  *   - \"failed\" with retries exhausted → leave alone (user can `woco retry`)\n25:  *\n26:  * This design means no agent work is permanently lost unless the worktree\n27:  * itself is destroyed (e.g., by `woco cleanup`).\n28:  */\n29: \n30: import type { WomboConfig } from \"../config.js\";\n31: import type { Feature } from \"../lib/tasks.js\";\n32: import { loadFeatures } from \"../lib/tasks.js\";\n33: import {\n34:   loadState,\n35:   saveState,\n36:   flushState,\n37:   updateAgent,\n38:   queuedAgents,\n39:   readyToLaunchAgents,\n40:   cancelDownstream,\n41:   isWaveComplete,\n42:   type WaveState,\n43:   type AgentState,\n44: } from \"../lib/state.js\";\n45: import {\n46:   createWorktree,\n47:   installDeps,\n48:   worktreeReady,\n49:   worktreeExists,\n50:   branchHasChanges,\n51:   removeWorktree,\n52:   log as wtLog,\n53: } from \"../lib/worktree.js\";\n54: import { generatePrompt, type QuestPromptContext } from \"../lib/prompt.js\";\n55: import {\n56:   launchInteractive,\n57:   isProcessRunning,\n58:   getMultiplexerName,\n59: } from \"../lib/launcher.js\";\n60: import { ProcessMonitor } from \"../lib/monitor.js\";\n61: import { pushBaseBranch } from \"../lib/merger.js\";\n62: import { runBuild } from \"../lib/verifier.js\";\n63: import { printDashboard, printAgentUpdate } from \"../lib/ui.js\";\n64: import { WomboTUI } from \"../lib/tui.js\";\n65: import {\n66:   launchSingleHeadless,\n67:   handleBuildVerification,\n68:   handleRetry,\n69:   launchNextQueued,\n70:   launchAllReady,\n71:   markFeatureDone,\n72:   attemptMerge,\n73:   dumpFailedAgentLogs,\n74: } from \"./launch.js\";\n75: import {\n76:   detectMultiplexer,\n77:   muxAttachCommand,\n78: } from \"../lib/multiplexer.js\";\n79: import { exportWaveHistory } from \"../lib/history.js\";\n80: import { outputError, outputMessage, type OutputFormat } from \"../lib/output.js\";\n81: import {\n82:   prepareAgentDefinitions,\n83:   isSpecializedAgent,\n84:   type AgentResolution,\n85: } from \"../lib/agent-registry.js\";\n86: import { patchImportedAgent } from \"../lib/templates.js\";\n87: import { writeAgentToWorktree } from \"../lib/agent-registry.js\";\n88: import { loadQuest, loadQuestKnowledge } from \"../lib/quest-store.js\";\n89: import { resolveQuestConfig, type QuestHitlMode } from \"../lib/quest.js\";\n90: import { getPendingQuestions, cleanupAll as cleanupHitl, submitAnswer, type HitlQuestion } from \"../lib/hitl-channel.js\";\n91: \n92: // ---------------------------------------------------------------------------\n93: // Types\n94: // ---------------------------------------------------------------------------\n95: \n96: export interface ResumeCommandOptions {\n97:   projectRoot: string;\n98:   config: WomboConfig;\n99:   maxConcurrent?: number;\n100:   model?: string;\n101:   interactive: boolean;\n102:   noTui: boolean;\n103:   autoPush: boolean;\n104:   baseBranch?: string;\n105:   maxRetries?: number;\n106:   outputFmt?: OutputFormat;\n107:   /**\n108:    * When true, pressing Q in the monitor detaches (returns to caller) instead\n109:    * of killing agents and exiting. Used by cmdTui so the user can switch\n110:    * between the monitor and task browser while agents keep running.\n111:    */\n112:   detachOnQuit?: boolean;\n113: }\n114: \n115: // ---------------------------------------------------------------------------\n116: // Command\n117: // ---------------------------------------------------------------------------\n118: \n119: export async function cmdResume(opts: ResumeCommandOptions): Promise<void> {\n120:   const { projectRoot } = opts;\n121:   let { config } = opts;\n122:   const fmt = opts.outputFmt ?? \"text\";\n123: \n124:   const state = loadState(projectRoot);\n125:   if (!state) {\n126:     outputError(fmt, \"No wave state found. Use 'woco launch' to start a new wave.\");\n127:     return; // unreachable — outputError calls process.exit\n128:   }\n129: \n130:   if (fmt === \"text\") {\n131:     console.log(`\\n--- wombo-combo: Resume ${state.wave_id} ---\\n`);\n132:   }\n133: \n134:   // Reconstruct quest context from wave state (if quest-scoped)\n135:   let questContext: QuestPromptContext | undefined;\n136:   let hitlMode: string | undefined;\n137:   if (state.quest_id) {\n138:     const quest = loadQuest(projectRoot, state.quest_id);\n139:     if (quest) {\n140:       config = resolveQuestConfig(config, quest);\n141:       hitlMode = quest.hitlMode;\n142:       const knowledge = loadQuestKnowledge(projectRoot, state.quest_id);\n143:       questContext = {\n144:         questId: quest.id,\n145:         goal: quest.goal,\n146:         addedConstraints: quest.constraints.add ?? [],\n147:         addedForbidden: quest.constraints.ban ?? [],\n148:         knowledge,\n149:       };\n150:       if (fmt === \"text\") {\n151:         console.log(`Quest: ${quest.title} (${quest.id})\\n`);\n152:       }\n153:     } else if (fmt === \"text\") {\n154:       console.warn(`Warning: wave references quest \"${state.quest_id}\" but it was not found.\\n`);\n155:     }\n156:   }\n157: \n158:   // Load feature data for prompt generation\n159:   const data = loadFeatures(projectRoot, config);\n160:   const featureMap = new Map(data.tasks.map((f: Feature) => [f.id, f]));\n161: \n162:   // Triage agents by current state\n163:   let toRelaunch: AgentState[] = [];\n164:   let toVerify: AgentState[] = [];\n165:   let stillAlive: AgentState[] = [];\n166: \n167:   for (const agent of state.agents) {\n168:     switch (agent.status) {\n169:       case \"running\":\n170:       case \"installing\":\n171:       case \"retry\":\n172:       case \"resolving_conflict\":\n173:         // Was in-flight when we stopped — check if PID is still alive\n174:         if (agent.pid && isProcessRunning(agent.pid)) {\n175:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: still running (PID ${agent.pid})`);\n176:           stillAlive.push(agent);\n177:         } else {\n178:           // Process is dead — check if worktree exists with meaningful changes.\n179:           // Use worktreeExists (not worktreeReady) because node_modules may be\n180:           // missing — the worktree still has code that should be verified.\n181:           if (worktreeExists(agent.worktree) && branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n182:             // Worktree exists AND branch has commits — try build verification\n183:             if (fmt === \"text\") console.log(`  ${agent.feature_id}: process dead, worktree has changes — will verify build`);\n184:             toVerify.push(agent);\n185:           } else {\n186:             // No worktree, or worktree exists but branch has no commits (agent did nothing)\n187:             const reason = worktreeExists(agent.worktree)\n188:               ? \"worktree exists but no code changes\"\n189:               : \"no worktree\";\n190:             if (fmt === \"text\") console.log(`  ${agent.feature_id}: process dead, ${reason} — will re-launch`);\n191:             updateAgent(state, agent.feature_id, {\n192:               status: \"queued\",\n193:               pid: null,\n194:               activity: null,\n195:               session_id: null,\n196:             });\n197:             toRelaunch.push(agent);\n198:           }\n199:         }\n200:         break;\n201: \n202:       case \"queued\":\n203:         if (fmt === \"text\") console.log(`  ${agent.feature_id}: queued — will launch`);\n204:         toRelaunch.push(agent);\n205:         break;\n206: \n207:       case \"completed\":\n208:         // Completed but not verified — verify\n209:         if (fmt === \"text\") console.log(`  ${agent.feature_id}: completed — will verify build`);\n210:         toVerify.push(agent);\n211:         break;\n212: \n213:       case \"verified\":\n214:         // Build passed but NOT yet merged — need to attempt merge (+ conflict resolution)\n215:         if (fmt === \"text\") console.log(`  ${agent.feature_id}: verified — will attempt merge`);\n216:         toVerify.push(agent);\n217:         break;\n218: \n219:       case \"merged\":\n220:         if (fmt === \"text\") console.log(`  ${agent.feature_id}: merged — marking feature as done`);\n221:         markFeatureDone(projectRoot, agent.feature_id, config, state.base_branch, fmt);\n222:         try {\n223:           removeWorktree(projectRoot, agent.worktree, true);\n224:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: worktree and branch removed`);\n225:         } catch {\n226:           // Already cleaned — not critical\n227:         }\n228:         break;\n229: \n230:       case \"failed\":\n231:         // If the worktree exists with code changes and retries remain,\n232:         // attempt build verification rather than discarding the work.\n233:         if (agent.retries < agent.max_retries &&\n234:             worktreeExists(agent.worktree) &&\n235:             branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n236:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: failed but has work (retry ${agent.retries}/${agent.max_retries}) — will verify build`);\n237:           // Clear stale error and mark as completed so handleBuildVerification\n238:           // processes it correctly (it expects a non-failed agent)\n239:           updateAgent(state, agent.feature_id, {\n240:             status: \"completed\",\n241:             error: null,\n242:             build_passed: null,\n243:             build_output: null,\n244:             completed_at: new Date().toISOString(),\n245:           });\n246:           toVerify.push(agent);\n247:         } else if (agent.retries < agent.max_retries) {\n248:           // No worktree or no changes — re-launch from scratch\n249:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: failed, no salvageable work (retry ${agent.retries}/${agent.max_retries}) — will re-launch`);\n250:           updateAgent(state, agent.feature_id, {\n251:             status: \"queued\",\n252:             pid: null,\n253:             error: null,\n254:             build_passed: null,\n255:             build_output: null,\n256:             activity: null,\n257:             session_id: null,\n258:             completed_at: null,\n259:           });\n260:           toRelaunch.push(agent);\n261:         } else {\n262:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: failed — max retries reached (use 'woco retry' to reset)`);\n263:         }\n264:         break;\n265:     }\n266:   }\n267: \n268:   saveState(projectRoot, state);\n269: \n270:   // ---------------------------------------------------------------------------\n271:   // Phase 1: Parallel build verification\n272:   // Each agent's worktree is independent, so dep install + build can run\n273:   // concurrently. Merges must remain sequential (they mutate the project root).\n274:   // ---------------------------------------------------------------------------\n275:   if (toVerify.length > 0) {\n276:     if (fmt === \"text\") console.log(`\\nVerifying ${toVerify.length} agent(s) in parallel...\\n`);\n277: \n278:     const verifyResults = await Promise.all(\n279:       toVerify.map(async (agent): Promise<{ agent: AgentState; needsMerge: boolean }> => {\n280:         const feature = featureMap.get(agent.feature_id);\n281:         if (!feature) return { agent, needsMerge: false };\n282: \n283:         // Already verified — skip build, go straight to merge\n284:         if (agent.status === \"verified\") {\n285:           printAgentUpdate(agent, \"already verified — queued for merge\");\n286:           return { agent, needsMerge: true };\n287:         }\n288: \n289:         printAgentUpdate(agent, \"verifying build...\");\n290: \n291:         // Ensure deps are installed — worktree may exist without node_modules\n292:         // (e.g., failed agents whose setup was interrupted)\n293:         if (!worktreeReady(agent.worktree) && worktreeExists(agent.worktree)) {\n294:           try {\n295:             printAgentUpdate(agent, \"installing deps...\");\n296:             await installDeps(agent.worktree, agent.feature_id, config);\n297:           } catch (depErr: any) {\n298:             printAgentUpdate(agent, `dep install failed: ${depErr.message}`);\n299:             updateAgent(state, agent.feature_id, {\n300:               status: \"failed\",\n301:               error: `Dependency install failed: ${depErr.message}`,\n302:               retries: agent.retries + 1,\n303:               completed_at: new Date().toISOString(),\n304:             });\n305:             saveState(projectRoot, state);\n306:             return { agent, needsMerge: false };\n307:           }\n308:         }\n309: \n310:         try {\n311:           const buildResult = await runBuild(agent.worktree, config);\n312:           if (buildResult.passed) {\n313:             updateAgent(state, agent.feature_id, {\n314:               status: \"verified\",\n315:               build_passed: true,\n316:               build_output: null,\n317:             });\n318:             saveState(projectRoot, state);\n319:             printAgentUpdate(agent, `BUILD PASSED (${Math.round(buildResult.durationMs / 1000)}s)`);\n320:             return { agent, needsMerge: true };\n321:           } else {\n322:             // Build failed\n323:             if (agent.retries < agent.max_retries) {\n324:               updateAgent(state, agent.feature_id, {\n325:                 status: \"retry\",\n326:                 retries: agent.retries + 1,\n327:                 build_passed: false,\n328:                 build_output: buildResult.errorSummary,\n329:               });\n330:               saveState(projectRoot, state);\n331:               printAgentUpdate(agent, `BUILD FAILED — will retry (${agent.retries + 1}/${agent.max_retries})`);\n332:             } else {\n333:               updateAgent(state, agent.feature_id, {\n334:                 status: \"failed\",\n335:                 build_passed: false,\n336:                 build_output: buildResult.errorSummary,\n337:                 error: `Build failed after ${agent.max_retries} retries`,\n338:                 completed_at: new Date().toISOString(),\n339:               });\n340:               saveState(projectRoot, state);\n341:               printAgentUpdate(agent, \"BUILD FAILED — max retries reached\");\n342:             }\n343:             return { agent, needsMerge: false };\n344:           }\n345:         } catch (err: any) {\n346:           printAgentUpdate(agent, `verify error: ${err.message}`);\n347:           updateAgent(state, agent.feature_id, {\n348:             status: \"failed\",\n349:             error: `Build verification error: ${err.message}`,\n350:             completed_at: new Date().toISOString(),\n351:           });\n352:           saveState(projectRoot, state);\n353:           return { agent, needsMerge: false };\n354:         }\n355:       })\n356:     );\n357: \n358:     saveState(projectRoot, state);\n359: \n360:     // -------------------------------------------------------------------------\n361:     // Phase 2: Sequential merge for verified agents\n362:     // Merges must be sequential because they operate on the project root.\n363:     // -------------------------------------------------------------------------\n364:     const toMerge = verifyResults.filter((r) => r.needsMerge);\n365:     if (toMerge.length > 0) {\n366:       if (fmt === \"text\") console.log(`\\nMerging ${toMerge.length} verified agent(s)...\\n`);\n367:       for (const { agent } of toMerge) {\n368:         const feature = featureMap.get(agent.feature_id);\n369:         if (!feature) continue;\n370:         try {\n371:           await attemptMerge(projectRoot, state, agent, feature, config, opts.model);\n372:         } catch (err: any) {\n373:           printAgentUpdate(agent, `merge error: ${err.message}`);\n374:         }\n375:       }\n376:     }\n377: \n378:     // Collect agents that need re-launching from verify results\n379:     for (const { agent } of verifyResults) {\n380:       if (agent.status === \"retry\" || agent.status === \"running\") {\n381:         toRelaunch.push(agent);\n382:       }\n383:     }\n384:   }\n385: \n386:   // Re-launch agents\n387:   const maxConcurrent = opts.maxConcurrent ?? state.max_concurrent;\n388:   const toLaunchNow = toRelaunch.slice(0, maxConcurrent);\n389:   if (toLaunchNow.length === 0 && stillAlive.length === 0) {\n390:     outputMessage(fmt, \"No agents need (re)launching.\", {\n391:       wave_id: state.wave_id,\n392:       triage: {\n393:         to_verify: toVerify.length,\n394:         to_relaunch: 0,\n395:       },\n396:       agents: state.agents.map((a) => ({\n397:         feature_id: a.feature_id,\n398:         status: a.status,\n399:         build_passed: a.build_passed,\n400:         error: a.error,\n401:       })),\n402:     });\n403:     if (fmt === \"text\") printDashboard(state);\n404:     return;\n405:   }\n406: \n407:   // ---------------------------------------------------------------------------\n408:   // Re-resolve specialized agents for relaunched tasks that have agent_type\n409:   // ---------------------------------------------------------------------------\n410:   let agentResolutions: Map<string, AgentResolution> | undefined;\n411: \n412:   if (config.agentRegistry.mode !== \"disabled\") {\n413:     const agentsWithType = toLaunchNow.filter((a) => a.agent_type);\n414:     if (agentsWithType.length > 0) {\n415:       // Build feature list for tasks being relaunched\n416:       const featuresToResolve = agentsWithType\n417:         .map((a) => featureMap.get(a.feature_id))\n418:         .filter((f): f is Feature => !!f);\n419:       if (featuresToResolve.length > 0) {\n420:         if (fmt === \"text\") console.log(`\\nRe-resolving ${featuresToResolve.length} specialized agent(s) from registry...`);\n421:         try {\n422:           agentResolutions = await prepareAgentDefinitions(featuresToResolve, config, projectRoot);\n423:         } catch (err: any) {\n424:           if (fmt === \"text\") console.log(`  WARN: agent resolution failed, using cached agent names: ${err.message}`);\n425:         }\n426:       }\n427:     }\n428:   }\n429: \n430:   if (fmt === \"text\") {\n431:     const parts: string[] = [];\n432:     if (toLaunchNow.length > 0) parts.push(`re-launching ${toLaunchNow.length}`);\n433:     if (stillAlive.length > 0) parts.push(`reconnecting ${stillAlive.length}`);\n434:     console.log(`\\n${parts.join(\", \")} agent(s)...\\n`);\n435:     printDashboard(state);\n436:   }\n437:   const model = opts.model ?? state.model ?? undefined;\n438: \n439:   if (opts.interactive) {\n440:     // Interactive resume\n441:     await Promise.all(\n442:       toLaunchNow.map(async (agent) => {\n443:         const feature = featureMap.get(agent.feature_id);\n444:         if (!feature) return;\n445: \n446:         updateAgent(state, agent.feature_id, {\n447:           status: \"installing\",\n448:           started_at: new Date().toISOString(),\n449:           activity: \"resuming...\",\n450:         });\n451:         saveState(projectRoot, state);\n452: \n453:         try {\n454:           if (!worktreeReady(agent.worktree)) {\n455:             await createWorktree(projectRoot, agent.feature_id, state.base_branch, config);\n456:             await installDeps(agent.worktree, agent.feature_id, config);\n457:           }\n458: \n459:           // Write specialized agent to worktree if applicable\n460:           const resolution = agentResolutions?.get(agent.feature_id);\n461:           const agentName = agent.agent_name ?? undefined;\n462:           if (resolution && isSpecializedAgent(resolution)) {\n463:             try {\n464:               const patchedContent = patchImportedAgent(resolution.rawContent, config, projectRoot);\n465:               writeAgentToWorktree(agent.worktree, resolution.name, patchedContent);\n466:               wtLog(agent.feature_id, `wrote specialized agent: ${resolution.name}`);\n467:             } catch (err: any) {\n468:               wtLog(agent.feature_id, `WARN: failed to write specialized agent: ${err.message}`);\n469:             }\n470:           }\n471: \n472:           const prompt = generatePrompt(feature, state.base_branch, config, questContext, hitlMode as QuestHitlMode | undefined);\n473:           const result = launchInteractive({\n474:             worktreePath: agent.worktree,\n475:             featureId: feature.id,\n476:             prompt,\n477:             model,\n478:             interactive: true,\n479:             config,\n480:             agentName,\n481:           });\n482: \n483:           const muxName = getMultiplexerName(config);\n484:           updateAgent(state, agent.feature_id, {\n485:             status: \"running\",\n486:             pid: result.pid,\n487:             activity: `${muxName} session active`,\n488:           });\n489:           saveState(projectRoot, state);\n490:         } catch (err: any) {\n491:           updateAgent(state, agent.feature_id, {\n492:             status: \"failed\",\n493:             error: err.message,\n494:             activity: null,\n495:             completed_at: new Date().toISOString(),\n496:           });\n497:           saveState(projectRoot, state);\n498:         }\n499:       })\n500:     );\n501: \n502:     if (fmt === \"text\") {\n503:       printDashboard(state);\n504:       const mux = detectMultiplexer(config.agent.multiplexer);\n505:       console.log(`\\nResume complete. Use '${muxAttachCommand(mux, `${config.agent.tmuxPrefix}-<id>`)}' to check sessions.`);\n506:     }\n507:   } else {\n508:     // Headless resume — re-enter monitoring loop\n509:     const monitor = new ProcessMonitor(projectRoot, {\n510:       onSessionId: (featureId, sessionId) => {\n511:         updateAgent(state, featureId, { session_id: sessionId });\n512:         saveState(projectRoot, state);\n513:       },\n514:       onComplete: (featureId) => {\n515:         updateAgent(state, featureId, {\n516:           status: \"completed\",\n517:           completed_at: new Date().toISOString(),\n518:           activity: \"done\",\n519:         });\n520:         saveState(projectRoot, state);\n521:         wtLog(featureId, \"agent completed — verifying build...\");\n522: \n523:         const agent = state.agents.find((a) => a.feature_id === featureId)!;\n524:         const feature = featureMap.get(featureId)!;\n525:         handleBuildVerification(projectRoot, state, agent, feature, config, model, monitor, undefined, hitlMode)\n526:           .then(() => launchAllReady(projectRoot, state, featureMap, monitor, config, model, undefined, questContext, hitlMode))\n527:           .catch((err) => {\n528:             wtLog(featureId, `BUILD VERIFICATION UNHANDLED ERROR: ${err.message}`);\n529:             launchAllReady(projectRoot, state, featureMap, monitor, config, model, undefined, questContext, hitlMode);\n530:           });\n531:       },\n532:       onError: (featureId, error) => {\n533:         const agent = state.agents.find((a) => a.feature_id === featureId)!;\n534:         if (agent.retries < agent.max_retries) {\n535:           updateAgent(state, featureId, {\n536:             status: \"retry\",\n537:             retries: agent.retries + 1,\n538:             error,\n539:             activity: \"retrying...\",\n540:           });\n541:           saveState(projectRoot, state);\n542:           handleRetry(projectRoot, state, agent, monitor, config, model, hitlMode);\n543:         } else {\n544:           updateAgent(state, featureId, {\n545:             status: \"failed\",\n546:             error,\n547:             activity: null,\n548:             completed_at: new Date().toISOString(),\n549:           });\n550:           saveState(projectRoot, state);\n551: \n552:           // Cascade failure to downstream agents\n553:           const cancelled = cancelDownstream(state, featureId);\n554:           if (cancelled.length > 0) {\n555:             wtLog(featureId, `downstream cancelled: ${cancelled.join(\", \")}`);\n556:             saveState(projectRoot, state);\n557:           }\n558:         }\n559:         launchAllReady(projectRoot, state, featureMap, monitor, config, model, undefined, questContext, hitlMode);\n560:       },\n561:       onActivity: (featureId, activity) => {\n562:         updateAgent(state, featureId, {\n563:           activity,\n564:           activity_updated_at: new Date().toISOString(),\n565:         });\n566:       },\n567:     });\n568: \n569:     // Handle graceful shutdown\n570:     // Audit (wave-detach-audit): Same pattern as launch.ts — see launch.ts\n571:     // SIGINT handler for detailed lifecycle documentation. Agents are\n572:     // non-detached children; killAll() gives them SIGTERM before exit.\n573:     let detached = false;\n574:     const tuiRef = { current: null as WomboTUI | null };\n575:     const gracefulShutdown = (signal: string) => {\n576:       if (tuiRef.current) tuiRef.current.stop();\n577:       for (const agent of state.agents) {\n578:         if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n579:           updateAgent(state, agent.feature_id, {\n580:             activity: \"interrupted\",\n581:           });\n582:         }\n583:       }\n584:       monitor.killAll();\n585:       flushState(projectRoot, state);\n586:       if (fmt === \"text\") console.log(`\\nState saved (${signal}). Use 'woco resume' to continue.`);\n587:       process.exit(0);\n588:     };\n589:     process.on(\"SIGINT\", () => gracefulShutdown(\"SIGINT\"));\n590:     process.on(\"SIGTERM\", () => gracefulShutdown(\"SIGTERM\"));\n591:     process.on(\"SIGHUP\", () => gracefulShutdown(\"SIGHUP\"));\n592: \n593:     // Reconnect to agents that are still alive — register them in the monitor\n594:     // so the TUI shows their activity and the polling loop detects their death.\n595:     for (const agent of stillAlive) {\n596:       monitor.reconnectProcess(agent.feature_id, agent.pid!, agent.session_id);\n597:       if (fmt === \"text\") console.log(`  ${agent.feature_id}: reconnected to PID ${agent.pid}`);\n598:     }\n599: \n600:     await Promise.all(\n601:       toLaunchNow.map((agent) => {\n602:         const feature = featureMap.get(agent.feature_id);\n603:         if (!feature) return Promise.resolve();\n604:         return launchSingleHeadless(projectRoot, state, agent, feature, monitor, config, model, agentResolutions, questContext, hitlMode);\n605:       })\n606:     );\n607: \n608:     // Start TUI dashboard (or skip if --no-tui)\n609:     if (!opts.noTui) {\n610:       tuiRef.current = new WomboTUI({\n611:         state,\n612:         monitor,\n613:         projectRoot,\n614:         interactive: false,\n615:         config,\n616:         onQuit: () => {\n617:           // Detach from the wave monitor — agents keep running in the background.\n618:           // The monitoring loop checks `detached` and exits, returning control\n619:           // to the caller (cmdTui main loop or standalone cmdResume).\n620:           flushState(projectRoot, state);\n621:           // Null out the TUI ref so the monitoring loop stops trying to update\n622:           // the destroyed screen during remaining poll iterations.\n623:           tuiRef.current = null;\n624:           detached = true;\n625:         },\n626:         onBeforeDestroy: () => {\n627:           // Flush state to disk before the blessed screen is destroyed.\n628:           flushState(projectRoot, state);\n629:         },\n630:         onRetry: (featureId: string) => {\n631:           const agent = state.agents.find((a) => a.feature_id === featureId);\n632:           if (!agent) return;\n633:           if (agent.status !== \"failed\" && agent.status !== \"retry\") return;\n634: \n635:           // Reset retries if exhausted, give it one more shot\n636:           if (agent.retries >= agent.max_retries) {\n637:             updateAgent(state, featureId, { max_retries: agent.retries + 1 });\n638:           }\n639: \n640:           wtLog(featureId, `manual retry requested from TUI — resetting to queued`);\n641:           updateAgent(state, featureId, {\n642:             status: \"queued\",\n643:             error: null,\n644:             activity: \"waiting for relaunch (manual retry)...\",\n645:           });\n646:           saveState(projectRoot, state);\n647:         },\n648:         onAnswer: (agentId: string, questionId: string, answerText: string) => {\n649:           try {\n650:             submitAnswer(projectRoot, agentId, questionId, answerText);\n651:             wtLog(agentId, `HITL answer submitted: \"${answerText.slice(0, 80)}${answerText.length > 80 ? \"...\" : \"\"}\"`);\n652:           } catch (err: any) {\n653:             wtLog(agentId, `HITL answer error: ${err.message}`);\n654:           }\n655:         },\n656:       });\n657:       tuiRef.current.start();\n658:     } else {\n659:       if (fmt === \"text\") console.log(\"(--no-tui mode, dashboard prints every 15s)\\n\");\n660:       printDashboard(state);\n661:     }\n662: \n663:     // Monitoring loop\n664:     const POLL_INTERVAL = 5000;\n665:     let dashboardCounter = 0;\n666:     while (!isWaveComplete(state) && !detached) {\n667:       await new Promise((r) => setTimeout(r, POLL_INTERVAL));\n668: \n669:       for (const agent of state.agents) {\n670:         if (\n671:           (agent.status === \"running\" || agent.status === \"resolving_conflict\") &&\n672:           agent.pid &&\n673:           !isProcessRunning(agent.pid) &&\n674:           !monitor.isRunning(agent.feature_id)\n675:         ) {\n676:           if (agent.status === \"resolving_conflict\") {\n677:             // Conflict resolver died unexpectedly — mark as failed\n678:             updateAgent(state, agent.feature_id, {\n679:               status: \"failed\",\n680:               error: \"Conflict resolver process died unexpectedly\",\n681:               activity: null,\n682:               completed_at: new Date().toISOString(),\n683:             });\n684:             saveState(projectRoot, state);\n685:             wtLog(agent.feature_id, \"conflict resolver died — marked failed\");\n686: \n687:             // Cascade failure to downstream agents\n688:             const cancelled = cancelDownstream(state, agent.feature_id);\n689:             if (cancelled.length > 0) {\n690:               wtLog(agent.feature_id, `downstream cancelled: ${cancelled.join(\", \")}`);\n691:               saveState(projectRoot, state);\n692:             }\n693: \n694:             launchAllReady(projectRoot, state, featureMap, monitor, config, model, undefined, questContext, hitlMode);\n695:             continue;\n696:           }\n697:           // Check if the agent actually made any commits\n698:           if (!branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n699:             // Agent died without producing any code — mark as failed\n700:             updateAgent(state, agent.feature_id, {\n701:               status: \"failed\",\n702:               error: \"Agent process exited without making any commits\",\n703:               activity: null,\n704:               completed_at: new Date().toISOString(),\n705:             });\n706:             saveState(projectRoot, state);\n707:             wtLog(agent.feature_id, \"process died with no code changes — marked failed\");\n708: \n709:             // Cascade failure to downstream agents\n710:             const cancelled = cancelDownstream(state, agent.feature_id);\n711:             if (cancelled.length > 0) {\n712:               wtLog(agent.feature_id, `downstream cancelled: ${cancelled.join(\", \")}`);\n713:               saveState(projectRoot, state);\n714:             }\n715:           } else {\n716:             updateAgent(state, agent.feature_id, {\n717:               status: \"completed\",\n718:               completed_at: new Date().toISOString(),\n719:               activity: \"done\",\n720:             });\n721:             saveState(projectRoot, state);\n722:             const feature = featureMap.get(agent.feature_id)!;\n723:             try {\n724:               await handleBuildVerification(projectRoot, state, agent, feature, config, model, monitor, undefined, hitlMode);\n725:             } catch (err: any) {\n726:               wtLog(agent.feature_id, `POLL VERIFY ERROR: ${err.message}`);\n727:             }\n728:           }\n729:           launchAllReady(projectRoot, state, featureMap, monitor, config, model, undefined, questContext, hitlMode);\n730:         }\n731:       }\n732: \n733:       saveState(projectRoot, state);\n734: \n735:       // Poll for HITL questions from agents and forward to TUI\n736:       if (hitlMode && hitlMode !== \"yolo\") {\n737:         try {\n738:           const pendingQuestions = getPendingQuestions(projectRoot);\n739:           if (tuiRef.current && pendingQuestions.length > 0) {\n740:             tuiRef.current.setPendingQuestions(pendingQuestions);\n741:           }\n742:         } catch {\n743:           // Non-fatal — HITL dir may not exist yet\n744:         }\n745:       }\n746: \n747:       if (tuiRef.current) {\n748:         tuiRef.current.updateState(state);\n749:       } else if (opts.noTui) {\n750:         dashboardCounter++;\n751:         if (dashboardCounter % 3 === 0) {\n752:           printDashboard(state);\n753:         }\n754:       }\n755:     }\n756: \n757:     // If user detached (pressed Q while agents are still running), save state\n758:     // and return without doing post-wave cleanup. The caller (cmdTui) will\n759:     // loop back to the task browser, showing the running wave indicator.\n760:     if (detached) {\n761:       flushState(projectRoot, state);\n762:       return;\n763:     }\n764: \n765:     // Wave complete — keep TUI open for post-mortem browsing\n766:     if (tuiRef.current) {\n767:       tuiRef.current.updateState(state);\n768:       tuiRef.current.markWaveComplete();\n769:       await tuiRef.current.waitForQuit();\n770:     }\n771: \n772:     if (fmt === \"text\") {\n773:       printDashboard(state);\n774: \n775:       // Dump full logs for failed agents (post-mortem)\n776:       dumpFailedAgentLogs(projectRoot, state, fmt);\n777:     }\n778: \n779:     // Clean up HITL files\n780:     try {\n781:       cleanupHitl(projectRoot);\n782:     } catch {\n783:       // Non-fatal\n784:     }\n785: \n786:     // Auto-export wave history\n787:     try {\n788:       const historyPath = exportWaveHistory(projectRoot, state);\n789:       if (fmt === \"text\") console.log(`Wave history exported to ${historyPath}`);\n790:     } catch (err: any) {\n791:       if (fmt === \"text\") console.error(`Warning: failed to export wave history: ${err.message}`);\n792:     }\n793: \n794:     // Auto-push base branch if requested\n795:     if (opts.autoPush) {\n796:       await pushBaseBranch(projectRoot, state.base_branch, config);\n797:     }\n798: \n799:     if (fmt === \"text\") console.log(\"Wave complete.\");\n800:   }\n801: }\n\n(End of file - total 801 lines)\n</content>","title":"src/commands/resume.ts","metadata":{"preview":"/**\n * resume.ts — Resume a previously stopped wave.\n *\n * Usage: woco resume [options] [--output json]\n *\n * Restores from .wombo-combo/state.json:\n *   - Agents in \"running\"/\"installing\" whose PID is dead → re-check or re-launch\n *   - Agents in \"queued\" → launch them\n *   - Agents in terminal states (verified/failed/merged) → leave alone\n *\n * ## Agent Recovery (audit: wave-detach-audit)\n *\n * This is the primary recovery mechanism for agents that died when the parent\n * process was terminated (gracefully via SIGINT, or ungracefully via SIGKILL/crash).\n *\n * Recovery triage for each agent:\n *   - PID still alive → leave it running (another wombo instance may still be active)\n *   - PID dead + worktree has commits → run build verification on existing work\n *   - PID dead + no commits → reset to \"queued\" for a fresh re-launch\n *   - \"completed\" → verify build","truncated":false,"loaded":[]},"time":{"start":1773484322031,"end":1773484322035}}}}
{"type":"tool_use","timestamp":1773484322649,"sessionID":"ses_31423da25ffebo9V1CTFH0IpgT","part":{"id":"prt_cebe72cf0001pBRowz7mpFFwAR","sessionID":"ses_31423da25ffebo9V1CTFH0IpgT","messageID":"msg_cebe71aff001dSMTBqkqOqvetS","type":"tool","callID":"toolu_vrtx_01KmLFJCioAMd95KGba1uv2c","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/wave-detach-audit/src/commands/tui.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/wave-detach-audit/src/commands/tui.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tui.ts -- Unified TUI command entry point for wombo-combo.\n3:  *\n4:  * Orchestrates multiple views in a persistent loop:\n5:  *   1. Quest Picker (tui-quest-picker.ts) -- select a quest or \"All Tasks\"\n6:  *   2. Task Browser (tui-browser.ts) -- select tasks, change priorities, launch\n7:  *   3. Wave Monitor (tui.ts) -- watch running wave, view logs, retry agents\n8:  *   4. Plan Review (tui-plan-review.ts) -- review/edit/approve planner output\n9:  *   5. Genesis Review (tui-genesis-review.ts) -- review/edit/approve genesis plan\n10:  *\n11:  * Flow:\n12:  *   `woco` -> Quest Picker (if quests exist) -> Task Browser -> L -> launches\n13:  *   wave -> wave completes -> Q in monitor -> back to Quest Picker -> ...\n14:  *\n15:  *   Quest Picker -> P (plan) -> spinner -> Plan Review -> approve/cancel ->\n16:  *   back to Quest Picker\n17:  *\n18:  *   Quest Picker -> G (genesis) -> vision prompt -> spinner -> Genesis Review\n19:  *   -> approve/cancel -> back to Quest Picker\n20:  *\n21:  *   Quest Picker/Browser -> E (errand) -> description prompt -> spinner ->\n22:  *   Plan Review -> approve/cancel -> creates quest-less tasks -> back\n23:  *\n24:  * If no quests exist, the Quest Picker is skipped entirely and the flow goes\n25:  * straight to the Task Browser (backward compatible).\n26:  *\n27:  * Exit behavior:\n28:  *   - Q from Quest Picker: exits the process\n29:  *   - Q/Esc from Task Browser: back to Quest Picker (or exits if no quests)\n30:  *   - Q from Wave Monitor: back to Quest Picker\n31:  *   - Q/Esc from Plan Review: discard plan, back to Quest Picker\n32:  *\n33:  * Session state is persisted to .wombo-combo/tui-session.json so the user can\n34:  * close and reopen the TUI without losing their task selections.\n35:  */\n36: \n37: import type { WomboConfig } from \"../config.js\";\n38: import { ensureTasksFile } from \"../lib/tasks.js\";\n39: import { loadState } from \"../lib/state.js\";\n40: import { loadTUISession, saveTUISession } from \"../lib/tui-session.js\";\n41: import type { TUISession } from \"../lib/tui-session.js\";\n42: import { TaskBrowser } from \"../lib/tui-browser.js\";\n43: import { QuestPicker } from \"../lib/tui-quest-picker.js\";\n44: import type { QuestPickerAction } from \"../lib/tui-quest-picker.js\";\n45: import { PlanReview } from \"../lib/tui-plan-review.js\";\n46: import type { ProposedTask } from \"../lib/quest-planner.js\";\n47: import { runQuestPlanner, applyPlanToQuest } from \"../lib/quest-planner.js\";\n48: import type { PlanResult } from \"../lib/quest-planner.js\";\n49: import { loadAllQuests, loadQuest, saveQuest, listQuestIds, saveQuestKnowledge } from \"../lib/quest-store.js\";\n50: import { GenesisReview } from \"../lib/tui-genesis-review.js\";\n51: import type { GenesisReviewAction } from \"../lib/tui-genesis-review.js\";\n52: import { runGenesisPlanner } from \"../lib/genesis-planner.js\";\n53: import type { GenesisResult, ProposedQuest } from \"../lib/genesis-planner.js\";\n54: import { createBlankQuest } from \"../lib/quest.js\";\n55: import { runErrandPlanner, applyErrandPlan } from \"../lib/errand-planner.js\";\n56: import { WishlistPicker } from \"../lib/tui-wishlist.js\";\n57: import type { WishlistAction } from \"../lib/tui-wishlist.js\";\n58: import { deleteItem as deleteWishlistItem } from \"../lib/wishlist-store.js\";\n59: import type { WishlistItem } from \"../lib/wishlist-store.js\";\n60: import { cmdLaunch } from \"./launch.js\";\n61: import type { LaunchCommandOptions } from \"./launch.js\";\n62: import { cmdResume } from \"./resume.js\";\n63: \n64: // ---------------------------------------------------------------------------\n65: // Types\n66: // ---------------------------------------------------------------------------\n67: \n68: export interface TUICommandOptions {\n69:   projectRoot: string;\n70:   config: WomboConfig;\n71:   /** Max concurrent agents (override, or null to use session/config default) */\n72:   maxConcurrent?: number;\n73:   /** Model override */\n74:   model?: string;\n75:   /** Base branch override */\n76:   baseBranch?: string;\n77:   /** Max retries override */\n78:   maxRetries?: number;\n79:   /** Auto-push after merge */\n80:   autoPush?: boolean;\n81:   /** Skip TDD tests */\n82:   skipTests?: boolean;\n83:   /** Strict TDD mode */\n84:   strictTdd?: boolean;\n85:   /** Agent definition override */\n86:   agent?: string;\n87: }\n88: \n89: type BrowserAction =\n90:   | { type: \"launch\"; ids: string[] }\n91:   | { type: \"errand\" }\n92:   | { type: \"back\" }\n93:   | { type: \"monitor\" }\n94:   | { type: \"quit\" };\n95: \n96: type PlanReviewResult =\n97:   | { type: \"approve\"; tasks: ProposedTask[]; knowledge: string | null }\n98:   | { type: \"cancel\" };\n99: \n100: // ---------------------------------------------------------------------------\n101: // Command -- Main Loop\n102: // ---------------------------------------------------------------------------\n103: \n104: export async function cmdTui(opts: TUICommandOptions): Promise<void> {\n105:   const { projectRoot, config } = opts;\n106: \n107:   // Ensure tasks file exists\n108:   await ensureTasksFile(projectRoot, config);\n109: \n110:   // Load session state (persisted selections, sort, concurrency)\n111:   const session = loadTUISession(projectRoot);\n112: \n113:   // Apply concurrency override from CLI if provided\n114:   if (opts.maxConcurrent !== undefined) {\n115:     session.maxConcurrent = opts.maxConcurrent;\n116:   }\n117: \n118:   // Main TUI loop:\n119:   //   Quest Picker -> Task Browser -> Launch -> Monitor -> back to Quest Picker\n120:   // Only exits when the user presses Q from the Quest Picker (or browser if no quests).\n121:   //\n122:   // Wave detach support: When the user presses Q in the monitor while agents\n123:   // are still running, the monitor returns without killing agents. The loop\n124:   // goes to the browser, which shows a \"running wave\" indicator and allows\n125:   // the user to press Tab to switch back to the monitor.\n126:   //\n127:   // `skipAutoResume` prevents the loop from immediately re-entering the\n128:   // monitor after the user explicitly detached from it.\n129:   let skipAutoResume = false;\n130:   while (true) {\n131:     // Check for an active wave on each iteration\n132:     const existingState = loadState(projectRoot);\n133:     const hasRunningWave =\n134:       existingState !== null &&\n135:       existingState.agents.some(\n136:         (a) =>\n137:           a.status === \"running\" ||\n138:           a.status === \"queued\" ||\n139:           a.status === \"installing\" ||\n140:           a.status === \"resolving_conflict\" ||\n141:           a.status === \"retry\"\n142:       );\n143: \n144:     if (hasRunningWave && !skipAutoResume) {\n145:       // A wave is already running -- resume it (wave monitor TUI).\n146:       // When the wave completes, cmdResume returns and we loop back.\n147:       // When the user detaches (Q while agents running), cmdResume also\n148:       // returns and we fall through to the browser with running wave indicator.\n149:       console.log(\n150:         `Active wave detected: ${existingState!.wave_id}. Resuming...`\n151:       );\n152:       try {\n153:         await cmdResume({\n154:           projectRoot,\n155:           config,\n156:           maxConcurrent: opts.maxConcurrent,\n157:           model: opts.model,\n158:           interactive: false,\n159:           noTui: false,\n160:           autoPush: opts.autoPush ?? false,\n161:           baseBranch: opts.baseBranch,\n162:           maxRetries: opts.maxRetries,\n163:         });\n164:       } catch (err: any) {\n165:         // Don't crash -- show error and loop back\n166:         console.error(`\\nResume error: ${err.message}\\n`);\n167:         await sleep(2000);\n168:       }\n169:       // After resume returns, don't auto-resume again — let the user\n170:       // browse tasks and use Tab to switch back to the monitor if needed.\n171:       skipAutoResume = true;\n172:       // Clear terminal before showing picker/browser again\n173:       process.stdout.write(\"\\x1B[2J\\x1B[H\");\n174:       continue;\n175:     }\n176: \n177:     // Reset the skip flag — if we reach the browser and the user launches\n178:     // a new wave, we should auto-resume when we loop back.\n179:     skipAutoResume = false;\n180: \n181:     // -----------------------------------------------------------------------\n182:     // Quest Picker (skip if no quests exist)\n183:     // -----------------------------------------------------------------------\n184:     const quests = loadAllQuests(projectRoot);\n185:     const hasQuests = quests.length > 0;\n186: \n187:     let selectedQuestId: string | null = null;\n188: \n189:     if (hasQuests) {\n190:       const questAction = await showQuestPicker(projectRoot, config, opts);\n191: \n192:       if (questAction.type === \"quit\") {\n193:         // User pressed Q in quest picker -- exit cleanly\n194:         session.lastView = \"browser\";\n195:         saveTUISession(projectRoot, session);\n196:         break;\n197:       }\n198: \n199:       if (questAction.type === \"plan\") {\n200:         // User pressed P to plan a quest -- run planner + review\n201:         await handlePlanFlow(projectRoot, config, opts, questAction.questId);\n202:         // After planning (approve or cancel), loop back to quest picker\n203:         process.stdout.write(\"\\x1B[2J\\x1B[H\");\n204:         continue;\n205:       }\n206: \n207:       if (questAction.type === \"genesis\") {\n208:         // User pressed G to run genesis -- run genesis planner + review\n209:         await handleGenesisFlow(projectRoot, config, opts);\n210:         // After genesis (approve or cancel), loop back to quest picker\n211:         process.stdout.write(\"\\x1B[2J\\x1B[H\");\n212:         continue;\n213:       }\n214: \n215:       if (questAction.type === \"errand\") {\n216:         // User pressed E to create an errand (quest-less assisted task)\n217:         await handleErrandFlow(projectRoot, config, opts);\n218:         // After errand (approve or cancel), loop back to quest picker\n219:         process.stdout.write(\"\\x1B[2J\\x1B[H\");\n220:         continue;\n221:       }\n222: \n223:       if (questAction.type === \"wishlist\") {\n224:         // User pressed W to browse wishlist\n225:         await handleWishlistFlow(projectRoot, config, opts);\n226:         // After wishlist (promote, back, or quit), loop back to quest picker\n227:         process.stdout.write(\"\\x1B[2J\\x1B[H\");\n228:         continue;\n229:       }\n230: \n231:       selectedQuestId = questAction.questId;\n232:     }\n233: \n234:     // -----------------------------------------------------------------------\n235:     // Task Browser (filtered by quest if one was selected)\n236:     // -----------------------------------------------------------------------\n237:     const action = await showBrowser(\n238:       projectRoot,\n239:       config,\n240:       session,\n241:       opts,\n242:       selectedQuestId,\n243:       hasQuests,\n244:       hasRunningWave\n245:     );\n246: \n247:     if (action.type === \"quit\") {\n248:       // User pressed Q in browser with no quest context -- exit cleanly\n249:       session.lastView = \"browser\";\n250:       saveTUISession(projectRoot, session);\n251:       break;\n252:     }\n253: \n254:     if (action.type === \"back\") {\n255:       // User pressed Q/Esc in quest-filtered browser -- back to quest picker\n256:       process.stdout.write(\"\\x1B[2J\\x1B[H\");\n257:       continue;\n258:     }\n259: \n260:     if (action.type === \"errand\") {\n261:       // User pressed E in browser to create an errand\n262:       await handleErrandFlow(projectRoot, config, opts);\n263:       process.stdout.write(\"\\x1B[2J\\x1B[H\");\n264:       continue;\n265:     }\n266: \n267:     if (action.type === \"monitor\") {\n268:       // User pressed Tab to switch to the running wave monitor.\n269:       // Resume connects to the existing wave and opens the monitor TUI.\n270:       // When the user presses Q in the monitor, cmdResume returns (detached)\n271:       // and we loop back to the browser with the running wave indicator.\n272:       try {\n273:         await cmdResume({\n274:           projectRoot,\n275:           config,\n276:           maxConcurrent: opts.maxConcurrent,\n277:           model: opts.model,\n278:           interactive: false,\n279:           noTui: false,\n280:           autoPush: opts.autoPush ?? false,\n281:           baseBranch: opts.baseBranch,\n282:           maxRetries: opts.maxRetries,\n283:         });\n284:       } catch (err: any) {\n285:         console.error(`\\nResume error: ${err.message}\\n`);\n286:         await sleep(2000);\n287:       }\n288:       process.stdout.write(\"\\x1B[2J\\x1B[H\");\n289:       // Don't auto-resume — let user browse tasks and Tab to monitor\n290:       skipAutoResume = true;\n291:       continue;\n292:     }\n293: \n294:     if (action.type === \"launch\") {\n295:       // Save session before launching\n296:       session.selected = action.ids;\n297:       session.lastView = \"monitor\";\n298:       saveTUISession(projectRoot, session);\n299: \n300:       // Build launch options\n301:       const launchOpts: LaunchCommandOptions = {\n302:         projectRoot,\n303:         config,\n304:         features: action.ids,\n305:         maxConcurrent: session.maxConcurrent,\n306:         model: opts.model,\n307:         interactive: false,\n308:         dryRun: false,\n309:         baseBranch: opts.baseBranch ?? config.baseBranch,\n310:         maxRetries: opts.maxRetries ?? config.defaults.maxRetries,\n311:         noTui: false,\n312:         autoPush: opts.autoPush ?? false,\n313:         agent: opts.agent,\n314:         outputFmt: \"text\",\n315:         // Pass quest ID so launch uses quest branch and constraints\n316:         questId: selectedQuestId ?? undefined,\n317:       };\n318: \n319:       try {\n320:         await cmdLaunch(launchOpts);\n321:       } catch (err: any) {\n322:         // Don't crash -- show error and loop back\n323:         console.error(`\\nLaunch error: ${err.message}\\n`);\n324:         await sleep(2000);\n325:       }\n326: \n327:       // Clear terminal before showing picker/browser again\n328:       process.stdout.write(\"\\x1B[2J\\x1B[H\");\n329:       // Don't auto-resume — let user browse tasks and Tab to monitor\n330:       skipAutoResume = true;\n331:       continue;\n332:     }\n333:   }\n334: }\n335: \n336: // ---------------------------------------------------------------------------\n337: // Quest Picker View -- Promise-based\n338: // ---------------------------------------------------------------------------\n339: \n340: /**\n341:  * Show the Quest Picker and return a Promise that resolves when the user\n342:  * takes an action (select quest, plan quest, or quit).\n343:  */\n344: function showQuestPicker(\n345:   projectRoot: string,\n346:   config: WomboConfig,\n347:   opts: TUICommandOptions\n348: ): Promise<QuestPickerAction> {\n349:   return new Promise<QuestPickerAction>((resolve) => {\n350:     const picker = new QuestPicker({\n351:       projectRoot,\n352:       config,\n353: \n354:       onSelect: (questId: string | null) => {\n355:         resolve({ type: \"select\", questId });\n356:       },\n357: \n358:       onPlan: (questId: string) => {\n359:         resolve({ type: \"plan\", questId });\n360:       },\n361: \n362:       onGenesis: () => {\n363:         resolve({ type: \"genesis\" });\n364:       },\n365: \n366:       onErrand: () => {\n367:         resolve({ type: \"errand\" });\n368:       },\n369: \n370:       onWishlist: () => {\n371:         resolve({ type: \"wishlist\" });\n372:       },\n373: \n374:       onQuit: () => {\n375:         resolve({ type: \"quit\" });\n376:       },\n377:     });\n378: \n379:     picker.start();\n380:   });\n381: }\n382: \n383: // ---------------------------------------------------------------------------\n384: // Plan Flow -- Planner + Review\n385: // ---------------------------------------------------------------------------\n386: \n387: /**\n388:  * Run the quest planner agent, then show the plan review TUI.\n389:  * Handles the full flow: spinner → planner → review → approve/cancel.\n390:  */\n391: async function handlePlanFlow(\n392:   projectRoot: string,\n393:   config: WomboConfig,\n394:   opts: TUICommandOptions,\n395:   questId: string\n396: ): Promise<void> {\n397:   const quest = loadQuest(projectRoot, questId);\n398:   if (!quest) {\n399:     console.error(`\\nQuest \"${questId}\" not found.\\n`);\n400:     await sleep(2000);\n401:     return;\n402:   }\n403: \n404:   // Set quest to planning status\n405:   const prevStatus = quest.status;\n406:   quest.status = \"planning\";\n407:   saveQuest(projectRoot, quest);\n408: \n409:   // Show a planning spinner on the terminal (no blessed screen here)\n410:   console.log(`\\n  Planning quest: ${quest.title} (${quest.id})`);\n411:   console.log(`  Running quest planner agent...\\n`);\n412: \n413:   const spinChars = [\"\\u2802\", \"\\u2806\", \"\\u2807\", \"\\u2803\", \"\\u2809\", \"\\u280C\", \"\\u280E\", \"\\u280B\"];\n414:   let spinIdx = 0;\n415:   let lastProgress = \"\";\n416:   const spinTimer = setInterval(() => {\n417:     const ch = spinChars[spinIdx % spinChars.length];\n418:     spinIdx++;\n419:     process.stdout.write(`\\r  ${ch} ${lastProgress}`);\n420:   }, 120);\n421: \n422:   let planResult: PlanResult;\n423: \n424:   try {\n425:     planResult = await runQuestPlanner(quest, projectRoot, config, {\n426:       model: opts.model,\n427:       onProgress: (msg) => {\n428:         lastProgress = msg;\n429:       },\n430:     });\n431:   } catch (err: any) {\n432:     clearInterval(spinTimer);\n433:     process.stdout.write(\"\\r\" + \" \".repeat(80) + \"\\r\");\n434:     console.error(`\\n  Planner error: ${err.message}\\n`);\n435:     // Revert quest status\n436:     quest.status = prevStatus;\n437:     saveQuest(projectRoot, quest);\n438:     await sleep(3000);\n439:     return;\n440:   }\n441: \n442:   clearInterval(spinTimer);\n443:   process.stdout.write(\"\\r\" + \" \".repeat(80) + \"\\r\");\n444: \n445:   if (!planResult.success && planResult.tasks.length === 0) {\n446:     // Total failure — no tasks produced\n447:     console.error(`\\n  Planner failed: ${planResult.error ?? \"No tasks produced\"}\\n`);\n448:     quest.status = prevStatus;\n449:     saveQuest(projectRoot, quest);\n450:     await sleep(3000);\n451:     return;\n452:   }\n453: \n454:   console.log(`  Planner produced ${planResult.tasks.length} tasks.`);\n455:   if (planResult.issues.length > 0) {\n456:     const errors = planResult.issues.filter((i) => i.level === \"error\").length;\n457:     const warnings = planResult.issues.filter((i) => i.level === \"warning\").length;\n458:     if (errors > 0) console.log(`  ${errors} validation error(s).`);\n459:     if (warnings > 0) console.log(`  ${warnings} validation warning(s).`);\n460:   }\n461:   console.log(`  Opening plan review...\\n`);\n462:   await sleep(1000);\n463: \n464:   // Clear terminal before showing the plan review TUI\n465:   process.stdout.write(\"\\x1B[2J\\x1B[H\");\n466: \n467:   // Show the plan review TUI\n468:   const reviewAction = await showPlanReview(\n469:     questId,\n470:     quest.title,\n471:     planResult\n472:   );\n473: \n474:   if (reviewAction.type === \"cancel\") {\n475:     // User cancelled — revert quest status\n476:     quest.status = prevStatus;\n477:     saveQuest(projectRoot, quest);\n478:     console.log(`\\n  Plan discarded. Quest \"${questId}\" reverted to \"${prevStatus}\".\\n`);\n479:     await sleep(1500);\n480:     return;\n481:   }\n482: \n483:   // User approved — apply the plan\n484:   try {\n485:     // Update planResult with only the accepted tasks\n486:     const approvedResult: PlanResult = {\n487:       ...planResult,\n488:       tasks: reviewAction.tasks,\n489:       knowledge: reviewAction.knowledge,\n490:     };\n491: \n492:     const tasks = applyPlanToQuest(approvedResult, quest, projectRoot, config);\n493:     console.log(`\\n  Plan approved! Created ${tasks.length} tasks.`);\n494:     console.log(`  Quest \"${questId}\" is now active.`);\n495:     if (reviewAction.knowledge) {\n496:       console.log(`  Saved knowledge file (${reviewAction.knowledge.length} chars).`);\n497:     }\n498:     console.log();\n499:     await sleep(2000);\n500:   } catch (err: any) {\n501:     console.error(`\\n  Failed to apply plan: ${err.message}\\n`);\n502:     quest.status = prevStatus;\n503:     saveQuest(projectRoot, quest);\n504:     await sleep(3000);\n505:   }\n506: }\n507: \n508: // ---------------------------------------------------------------------------\n509: // Genesis Flow -- Vision Prompt + Planner + Review\n510: // ---------------------------------------------------------------------------\n511: \n512: /**\n513:  * Run the genesis planner: prompt user for a vision, run the genesis planner\n514:  * agent, then show the genesis review TUI.\n515:  * Handles the full flow: readline prompt → spinner → planner → review → create quests.\n516:  */\n517: async function handleGenesisFlow(\n518:   projectRoot: string,\n519:   config: WomboConfig,\n520:   opts: TUICommandOptions,\n521:   prefill?: string\n522: ): Promise<void> {\n523:   let vision: string;\n524: \n525:   if (prefill) {\n526:     // Pre-filled from wishlist promotion — show the pre-filled text\n527:     console.log();\n528:     console.log(\"  ╔══════════════════════════════════════╗\");\n529:     console.log(\"  ║         GENESIS PLANNER              ║\");\n530:     console.log(\"  ╚══════════════════════════════════════╝\");\n531:     console.log();\n532:     console.log(`  Pre-filled from wishlist: ${prefill}`);\n533:     console.log();\n534:     vision = prefill;\n535:   } else {\n536:     // Prompt the user for a project vision via readline (no blessed screen is active)\n537:     const readline = await import(\"node:readline\");\n538:     const rl = readline.createInterface({\n539:       input: process.stdin,\n540:       output: process.stdout,\n541:     });\n542: \n543:     vision = await new Promise<string>((resolve) => {\n544:       console.log();\n545:       console.log(\"  ╔══════════════════════════════════════╗\");\n546:       console.log(\"  ║         GENESIS PLANNER              ║\");\n547:       console.log(\"  ╚══════════════════════════════════════╝\");\n548:       console.log();\n549:       console.log(\"  Describe your project vision. The genesis planner will\");\n550:       console.log(\"  decompose it into a set of quests.\");\n551:       console.log();\n552:       rl.question(\"  Vision: \", (answer) => {\n553:         rl.close();\n554:         resolve(answer.trim());\n555:       });\n556:     });\n557:   }\n558: \n559:   if (!vision) {\n560:     console.log(\"\\n  No vision provided. Returning to quest picker.\\n\");\n561:     await sleep(1500);\n562:     return;\n563:   }\n564: \n565:   // Gather existing quest IDs so the planner can avoid duplicates\n566:   const existingQuestIds = listQuestIds(projectRoot);\n567: \n568:   // Show a planning spinner on the terminal\n569:   console.log();\n570:   console.log(`  Running genesis planner agent...`);\n571:   console.log();\n572: \n573:   const spinChars = [\"\\u2802\", \"\\u2806\", \"\\u2807\", \"\\u2803\", \"\\u2809\", \"\\u280C\", \"\\u280E\", \"\\u280B\"];\n574:   let spinIdx = 0;\n575:   let lastProgress = \"\";\n576:   const spinTimer = setInterval(() => {\n577:     const ch = spinChars[spinIdx % spinChars.length];\n578:     spinIdx++;\n579:     process.stdout.write(`\\r  ${ch} ${lastProgress}`);\n580:   }, 120);\n581: \n582:   let genesisResult: GenesisResult;\n583: \n584:   try {\n585:     genesisResult = await runGenesisPlanner(vision, projectRoot, config, {\n586:       existingQuestIds,\n587:       model: opts.model,\n588:       onProgress: (msg) => {\n589:         lastProgress = msg;\n590:       },\n591:     });\n592:   } catch (err: any) {\n593:     clearInterval(spinTimer);\n594:     process.stdout.write(\"\\r\" + \" \".repeat(80) + \"\\r\");\n595:     console.error(`\\n  Genesis planner error: ${err.message}\\n`);\n596:     await sleep(3000);\n597:     return;\n598:   }\n599: \n600:   clearInterval(spinTimer);\n601:   process.stdout.write(\"\\r\" + \" \".repeat(80) + \"\\r\");\n602: \n603:   if (!genesisResult.success && genesisResult.quests.length === 0) {\n604:     // Total failure — no quests produced\n605:     console.error(`\\n  Genesis planner failed: ${genesisResult.error ?? \"No quests produced\"}\\n`);\n606:     await sleep(3000);\n607:     return;\n608:   }\n609: \n610:   console.log(`  Genesis planner produced ${genesisResult.quests.length} quests.`);\n611:   if (genesisResult.issues.length > 0) {\n612:     const errors = genesisResult.issues.filter((i) => i.level === \"error\").length;\n613:     const warnings = genesisResult.issues.filter((i) => i.level === \"warning\").length;\n614:     if (errors > 0) console.log(`  ${errors} validation error(s).`);\n615:     if (warnings > 0) console.log(`  ${warnings} validation warning(s).`);\n616:   }\n617:   console.log(`  Opening genesis review...\\n`);\n618:   await sleep(1000);\n619: \n620:   // Clear terminal before showing the genesis review TUI\n621:   process.stdout.write(\"\\x1B[2J\\x1B[H\");\n622: \n623:   // Show the genesis review TUI\n624:   const reviewAction = await showGenesisReview(genesisResult);\n625: \n626:   if (reviewAction.type === \"cancel\") {\n627:     console.log(`\\n  Genesis plan discarded.\\n`);\n628:     await sleep(1500);\n629:     return;\n630:   }\n631: \n632:   // User approved — create quests from accepted proposals\n633:   const baseBranch = opts.baseBranch ?? config.baseBranch;\n634:   const created: string[] = [];\n635: \n636:   for (const proposed of reviewAction.quests) {\n637:     const quest = createBlankQuest(proposed.id, proposed.title, proposed.goal, baseBranch, {\n638:       priority: proposed.priority,\n639:       difficulty: proposed.difficulty,\n640:       hitlMode: proposed.hitl_mode,\n641:     });\n642: \n643:     // Apply constraints from the genesis planner\n644:     quest.constraints.add = proposed.constraints.add ?? [];\n645:     quest.constraints.ban = proposed.constraints.ban ?? [];\n646:     quest.depends_on = proposed.depends_on ?? [];\n647:     quest.notes = proposed.notes ?? [];\n648: \n649:     saveQuest(projectRoot, quest);\n650:     created.push(quest.id);\n651:   }\n652: \n653:   console.log(`\\n  Genesis plan approved! Created ${created.length} quests:`);\n654:   for (const id of created) {\n655:     console.log(`    - ${id}`);\n656:   }\n657: \n658:   // Save knowledge if the planner produced any (attach to the first quest)\n659:   const knowledge = reviewAction.knowledge;\n660:   if (knowledge && created.length > 0) {\n661:     saveQuestKnowledge(projectRoot, created[0], knowledge);\n662:     console.log(`  Saved knowledge file (${knowledge.length} chars) to quest \"${created[0]}\".`);\n663:   }\n664: \n665:   console.log();\n666:   await sleep(2000);\n667: }\n668: \n669: // ---------------------------------------------------------------------------\n670: // Errand Flow -- Quick Task Generation (quest-less)\n671: // ---------------------------------------------------------------------------\n672: \n673: /**\n674:  * Run the errand planner: prompt user for a brief description, run the quest\n675:  * planner agent with an errand-specific prompt, then show plan review to let\n676:  * the user accept/reject/edit the proposed tasks.\n677:  *\n678:  * Created tasks go directly into the task store without any quest association.\n679:  */\n680: async function handleErrandFlow(\n681:   projectRoot: string,\n682:   config: WomboConfig,\n683:   opts: TUICommandOptions,\n684:   prefill?: string\n685: ): Promise<void> {\n686:   let description: string;\n687: \n688:   if (prefill) {\n689:     // Pre-filled from wishlist promotion — show the pre-filled text\n690:     console.log();\n691:     console.log(\"  ╔══════════════════════════════════════╗\");\n692:     console.log(\"  ║           ERRAND PLANNER             ║\");\n693:     console.log(\"  ╚══════════════════════════════════════╝\");\n694:     console.log();\n695:     console.log(`  Pre-filled from wishlist: ${prefill}`);\n696:     console.log();\n697:     description = prefill;\n698:   } else {\n699:     // Prompt the user for a description via readline (no blessed screen is active)\n700:     const readline = await import(\"node:readline\");\n701:     const rl = readline.createInterface({\n702:       input: process.stdin,\n703:       output: process.stdout,\n704:     });\n705: \n706:     description = await new Promise<string>((resolve) => {\n707:       console.log();\n708:       console.log(\"  ╔══════════════════════════════════════╗\");\n709:       console.log(\"  ║           ERRAND PLANNER             ║\");\n710:       console.log(\"  ╚══════════════════════════════════════╝\");\n711:       console.log();\n712:       console.log(\"  Describe the errand. The planner will explore the\");\n713:       console.log(\"  codebase and generate tasks for you.\");\n714:       console.log();\n715:       rl.question(\"  Errand: \", (answer) => {\n716:         rl.close();\n717:         resolve(answer.trim());\n718:       });\n719:     });\n720:   }\n721: \n722:   if (!description) {\n723:     console.log(\"\\n  No description provided. Returning.\\n\");\n724:     await sleep(1500);\n725:     return;\n726:   }\n727: \n728:   // Show a planning spinner on the terminal\n729:   console.log();\n730:   console.log(`  Running errand planner...`);\n731:   console.log();\n732: \n733:   const spinChars = [\"\\u2802\", \"\\u2806\", \"\\u2807\", \"\\u2803\", \"\\u2809\", \"\\u280C\", \"\\u280E\", \"\\u280B\"];\n734:   let spinIdx = 0;\n735:   let lastProgress = \"\";\n736:   const spinTimer = setInterval(() => {\n737:     const ch = spinChars[spinIdx % spinChars.length];\n738:     spinIdx++;\n739:     process.stdout.write(`\\r  ${ch} ${lastProgress}`);\n740:   }, 120);\n741: \n742:   let planResult: PlanResult;\n743: \n744:   try {\n745:     planResult = await runErrandPlanner(description, projectRoot, config, {\n746:       model: opts.model,\n747:       onProgress: (msg) => {\n748:         lastProgress = msg;\n749:       },\n750:     });\n751:   } catch (err: any) {\n752:     clearInterval(spinTimer);\n753:     process.stdout.write(\"\\r\" + \" \".repeat(80) + \"\\r\");\n754:     console.error(`\\n  Errand planner error: ${err.message}\\n`);\n755:     await sleep(3000);\n756:     return;\n757:   }\n758: \n759:   clearInterval(spinTimer);\n760:   process.stdout.write(\"\\r\" + \" \".repeat(80) + \"\\r\");\n761: \n762:   if (!planResult.success && planResult.tasks.length === 0) {\n763:     console.error(`\\n  Errand planner failed: ${planResult.error ?? \"No tasks produced\"}\\n`);\n764:     await sleep(3000);\n765:     return;\n766:   }\n767: \n768:   console.log(`  Errand planner produced ${planResult.tasks.length} task(s).`);\n769:   if (planResult.issues.length > 0) {\n770:     const errors = planResult.issues.filter((i) => i.level === \"error\").length;\n771:     const warnings = planResult.issues.filter((i) => i.level === \"warning\").length;\n772:     if (errors > 0) console.log(`  ${errors} validation error(s).`);\n773:     if (warnings > 0) console.log(`  ${warnings} validation warning(s).`);\n774:   }\n775:   console.log(`  Opening plan review...\\n`);\n776:   await sleep(1000);\n777: \n778:   // Clear terminal before showing the plan review TUI\n779:   process.stdout.write(\"\\x1B[2J\\x1B[H\");\n780: \n781:   // Reuse the plan review TUI (it works for any set of proposed tasks)\n782:   const reviewAction = await showPlanReview(\n783:     \"(errand)\",\n784:     description.length > 50 ? description.slice(0, 47) + \"...\" : description,\n785:     planResult\n786:   );\n787: \n788:   if (reviewAction.type === \"cancel\") {\n789:     console.log(`\\n  Errand plan discarded.\\n`);\n790:     await sleep(1500);\n791:     return;\n792:   }\n793: \n794:   // User approved -- create tasks directly (no quest)\n795:   try {\n796:     const approvedResult: PlanResult = {\n797:       ...planResult,\n798:       tasks: reviewAction.tasks,\n799:       knowledge: reviewAction.knowledge,\n800:     };\n801: \n802:     const tasks = applyErrandPlan(approvedResult, projectRoot, config);\n803:     console.log(`\\n  Errand approved! Created ${tasks.length} task(s):`);\n804:     for (const t of tasks) {\n805:       console.log(`    - ${t.id}: ${t.title}`);\n806:     }\n807:     console.log();\n808:     await sleep(2000);\n809:   } catch (err: any) {\n810:     console.error(`\\n  Failed to create errand tasks: ${err.message}\\n`);\n811:     await sleep(3000);\n812:   }\n813: }\n814: \n815: // ---------------------------------------------------------------------------\n816: // Wishlist Flow -- Browse + Promote to Errand/Genesis\n817: // ---------------------------------------------------------------------------\n818: \n819: /**\n820:  * Show the wishlist picker. When the user promotes an item, run the\n821:  * appropriate flow (errand or genesis) with the item text pre-filled.\n822:  * After promotion completes, offer to delete the wishlist item.\n823:  */\n824: async function handleWishlistFlow(\n825:   projectRoot: string,\n826:   config: WomboConfig,\n827:   opts: TUICommandOptions\n828: ): Promise<void> {\n829:   const action = await showWishlistPicker(projectRoot);\n830: \n831:   if (action.type === \"back\" || action.type === \"quit\") {\n832:     return;\n833:   }\n834: \n835:   if (action.type === \"promote-errand\") {\n836:     const item = action.item;\n837:     await handleErrandFlow(projectRoot, config, opts, item.text);\n838:     await maybeDeleteWishlistItem(projectRoot, item);\n839:     return;\n840:   }\n841: \n842:   if (action.type === \"promote-genesis\") {\n843:     const item = action.item;\n844:     await handleGenesisFlow(projectRoot, config, opts, item.text);\n845:     await maybeDeleteWishlistItem(projectRoot, item);\n846:     return;\n847:   }\n848: }\n849: \n850: /**\n851:  * Show the Wishlist Picker TUI and return a Promise that resolves when the\n852:  * user takes an action.\n853:  */\n854: function showWishlistPicker(projectRoot: string): Promise<WishlistAction> {\n855:   return new Promise<WishlistAction>((resolve) => {\n856:     const picker = new WishlistPicker({\n857:       projectRoot,\n858: \n859:       onPromoteErrand: (item) => {\n860:         resolve({ type: \"promote-errand\", item });\n861:       },\n862: \n863:       onPromoteGenesis: (item) => {\n864:         resolve({ type: \"promote-genesis\", item });\n865:       },\n866: \n867:       onBack: () => {\n868:         resolve({ type: \"back\" });\n869:       },\n870: \n871:       onQuit: () => {\n872:         resolve({ type: \"quit\" });\n873:       },\n874:     });\n875: \n876:     picker.start();\n877:   });\n878: }\n879: \n880: /**\n881:  * After a wishlist item has been promoted, ask the user whether to delete it.\n882:  * Uses a simple readline prompt (no blessed screen is active at this point).\n883:  */\n884: async function maybeDeleteWishlistItem(\n885:   projectRoot: string,\n886:   item: WishlistItem\n887: ): Promise<void> {\n888:   const readline = await import(\"node:readline\");\n889:   const rl = readline.createInterface({\n890:     input: process.stdin,\n891:     output: process.stdout,\n892:   });\n893: \n894:   const truncText =\n895:     item.text.length > 50 ? item.text.slice(0, 47) + \"...\" : item.text;\n896: \n897:   const answer = await new Promise<string>((resolve) => {\n898:     rl.question(\n899:       `\\n  Delete wishlist item \"${truncText}\"? [y/N] `,\n900:       (ans) => {\n901:         rl.close();\n902:         resolve(ans.trim().toLowerCase());\n903:       }\n904:     );\n905:   });\n906: \n907:   if (answer === \"y\" || answer === \"yes\") {\n908:     const deleted = deleteWishlistItem(projectRoot, item.id);\n909:     if (deleted) {\n910:       console.log(`  Wishlist item deleted.\\n`);\n911:     } else {\n912:       console.log(`  Item not found (may have been already deleted).\\n`);\n913:     }\n914:   } else {\n915:     console.log(`  Wishlist item kept.\\n`);\n916:   }\n917: \n918:   await sleep(1000);\n919: }\n920: \n921: // ---------------------------------------------------------------------------\n922: // Genesis Review View -- Promise-based\n923: // ---------------------------------------------------------------------------\n924: \n925: /**\n926:  * Show the Genesis Review TUI and return a Promise that resolves when the\n927:  * user approves or cancels.\n928:  */\n929: function showGenesisReview(\n930:   genesisResult: GenesisResult\n931: ): Promise<GenesisReviewAction> {\n932:   return new Promise<GenesisReviewAction>((resolve) => {\n933:     const review = new GenesisReview({\n934:       genesisResult,\n935: \n936:       onApprove: (quests, knowledge) => {\n937:         resolve({ type: \"approve\", quests, knowledge });\n938:       },\n939: \n940:       onCancel: () => {\n941:         resolve({ type: \"cancel\" });\n942:       },\n943:     });\n944: \n945:     review.start();\n946:   });\n947: }\n948: \n949: // ---------------------------------------------------------------------------\n950: // Plan Review View -- Promise-based\n951: // ---------------------------------------------------------------------------\n952: \n953: /**\n954:  * Show the Plan Review TUI and return a Promise that resolves when the user\n955:  * approves or cancels.\n956:  */\n957: function showPlanReview(\n958:   questId: string,\n959:   questTitle: string,\n960:   planResult: PlanResult\n961: ): Promise<PlanReviewResult> {\n962:   return new Promise<PlanReviewResult>((resolve) => {\n963:     const review = new PlanReview({\n964:       questId,\n965:       questTitle,\n966:       planResult,\n967: \n968:       onApprove: (tasks, knowledge) => {\n969:         resolve({ type: \"approve\", tasks, knowledge });\n970:       },\n971: \n972:       onCancel: () => {\n973:         resolve({ type: \"cancel\" });\n974:       },\n975:     });\n976: \n977:     review.start();\n978:   });\n979: }\n980: \n981: // ---------------------------------------------------------------------------\n982: // Browser View -- Promise-based\n983: // ---------------------------------------------------------------------------\n984: \n985: /**\n986:  * Show the Task Browser and return a Promise that resolves when the user\n987:  * takes an action (launch, back, quit, or switch to monitor).\n988:  */\n989: function showBrowser(\n990:   projectRoot: string,\n991:   config: WomboConfig,\n992:   session: TUISession,\n993:   opts: TUICommandOptions,\n994:   questId: string | null,\n995:   hasQuestPicker: boolean,\n996:   hasRunningWave: boolean = false\n997: ): Promise<BrowserAction> {\n998:   // Reload session from disk in case state changed after a wave\n999:   const freshSession = loadTUISession(projectRoot);\n1000:   // Merge any runtime overrides\n1001:   if (opts.maxConcurrent !== undefined) {\n1002:     freshSession.maxConcurrent = opts.maxConcurrent;\n1003:   }\n1004:   // Copy fresh values back into the shared session object\n1005:   Object.assign(session, freshSession);\n1006: \n1007:   // Load quest details for filtering if a quest was selected\n1008:   let questTitle: string | undefined;\n1009:   let questTaskIds: string[] | undefined;\n1010:   if (questId) {\n1011:     const quest = loadQuest(projectRoot, questId);\n1012:     if (quest) {\n1013:       questTitle = quest.title;\n1014:       questTaskIds = quest.taskIds;\n1015:     }\n1016:   }\n1017: \n1018:   return new Promise<BrowserAction>((resolve) => {\n1019:     const browser = new TaskBrowser({\n1020:       projectRoot,\n1021:       config,\n1022:       session,\n1023:       questId,\n1024:       questTitle,\n1025:       questTaskIds,\n1026: \n1027:       onLaunch: (selectedIds: string[]) => {\n1028:         if (selectedIds.length === 0) return;\n1029:         // The browser has already shown a transition message on-screen.\n1030:         // Destroy the blessed screen and clear the terminal.\n1031:         browser.destroy();\n1032:         resolve({ type: \"launch\", ids: selectedIds });\n1033:       },\n1034: \n1035:       onQuit: () => {\n1036:         browser.stop();\n1037:         resolve({ type: \"quit\" });\n1038:       },\n1039: \n1040:       onBack: hasQuestPicker\n1041:         ? () => {\n1042:             resolve({ type: \"back\" });\n1043:           }\n1044:         : undefined,\n1045: \n1046:       // Errand is available when not in quest-filtered mode\n1047:       onErrand: !questId\n1048:         ? () => {\n1049:             resolve({ type: \"errand\" });\n1050:           }\n1051:         : undefined,\n1052: \n1053:       // Switch to monitor is available when a wave is running in the background\n1054:       onSwitchToMonitor: hasRunningWave\n1055:         ? () => {\n1056:             resolve({ type: \"monitor\" });\n1057:           }\n1058:         : undefined,\n1059:     });\n1060: \n1061:     // Tell the browser about the running wave so it shows the Tab hint\n1062:     if (hasRunningWave) {\n1063:       browser.setHasRunningWave(true);\n1064:     }\n1065: \n1066:     browser.start();\n1067:   });\n1068: }\n1069: \n1070: // ---------------------------------------------------------------------------\n1071: // Helpers\n1072: // ---------------------------------------------------------------------------\n1073: \n1074: function sleep(ms: number): Promise<void> {\n1075:   return new Promise((r) => setTimeout(r, ms));\n1076: }\n\n(End of file - total 1076 lines)\n</content>","title":"src/commands/tui.ts","metadata":{"preview":"/**\n * tui.ts -- Unified TUI command entry point for wombo-combo.\n *\n * Orchestrates multiple views in a persistent loop:\n *   1. Quest Picker (tui-quest-picker.ts) -- select a quest or \"All Tasks\"\n *   2. Task Browser (tui-browser.ts) -- select tasks, change priorities, launch\n *   3. Wave Monitor (tui.ts) -- watch running wave, view logs, retry agents\n *   4. Plan Review (tui-plan-review.ts) -- review/edit/approve planner output\n *   5. Genesis Review (tui-genesis-review.ts) -- review/edit/approve genesis plan\n *\n * Flow:\n *   `woco` -> Quest Picker (if quests exist) -> Task Browser -> L -> launches\n *   wave -> wave completes -> Q in monitor -> back to Quest Picker -> ...\n *\n *   Quest Picker -> P (plan) -> spinner -> Plan Review -> approve/cancel ->\n *   back to Quest Picker\n *\n *   Quest Picker -> G (genesis) -> vision prompt -> spinner -> Genesis Review\n *   -> approve/cancel -> back to Quest Picker\n *","truncated":false,"loaded":[]},"time":{"start":1773484322644,"end":1773484322648}}}}
{"type":"text","timestamp":1773484322946,"sessionID":"ses_31423da25ffebo9V1CTFH0IpgT","part":{"id":"prt_cebe722f5002PN4DNEf5ocrpm1","sessionID":"ses_31423da25ffebo9V1CTFH0IpgT","messageID":"msg_cebe71aff001dSMTBqkqOqvetS","type":"text","text":"\n\nLet me pick up where we left off. I need to:\n\n1. Fix `resume.ts` `onQuit` handler to conditionally check `detachOnQuit`\n2. Pass `detachOnQuit: true` in all `cmdResume()`/`cmdLaunch()` calls from `tui.ts`\n3. Verify typecheck and build pass\n4. Commit all changes\n\nLet me start by reading the current state of the files.","time":{"start":1773484322946,"end":1773484322946}}}
{"type":"tool_use","timestamp":1773484322949,"sessionID":"ses_31423da25ffebo9V1CTFH0IpgT","part":{"id":"prt_cebe72f55001lq6q5ADgtuLh8k","sessionID":"ses_31423da25ffebo9V1CTFH0IpgT","messageID":"msg_cebe71aff001dSMTBqkqOqvetS","type":"tool","callID":"toolu_vrtx_014XjaA7Ypz5N1ZDpirHrYCK","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/wave-detach-audit/src/commands/launch.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/wave-detach-audit/src/commands/launch.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * launch.ts — Launch a wave of agents.\n3:  *\n4:  * Usage: woco launch [selection options] [launch options]\n5:  *\n6:  * This is the primary entry point for starting a new wave. It selects features\n7:  * from the features file, creates a wave state, sets up worktrees, and launches\n8:  * agent processes (either headless or interactive via dmux/tmux).\n9:  *\n10:  * IMPORTANT: This file also exports shared helper functions that are reused\n11:  * by resume.ts and other commands:\n12:  *   - launchSingleHeadless\n13:  *   - handleBuildVerification\n14:  *   - handleRetry\n15:  *   - launchNextQueued\n16:  */\n17: \n18: import { execSync } from \"node:child_process\";\n19: import { existsSync, readFileSync } from \"node:fs\";\n20: import { resolve } from \"node:path\";\n21: import type { WomboConfig } from \"../config.js\";\n22: import type { Feature, SelectionOptions, Priority, Difficulty } from \"../lib/tasks.js\";\n23: import { loadFeatures, selectFeatures, parseDurationMinutes, saveFeatures } from \"../lib/tasks.js\";\n24: import {\n25:   loadState,\n26:   saveState,\n27:   flushState,\n28:   createWaveState,\n29:   createAgentState,\n30:   updateAgent,\n31:   activeAgents,\n32:   queuedAgents,\n33:   readyToLaunchAgents,\n34:   areAgentDepsReady,\n35:   cancelDownstream,\n36:   isWaveComplete,\n37:   type WaveState,\n38:   type AgentState,\n39:   type SerializedSchedulePlan,\n40: } from \"../lib/state.js\";\n41: import {\n42:   createWorktree,\n43:   installDeps,\n44:   featureBranchName,\n45:   worktreePath,\n46:   worktreeReady,\n47:   branchHasChanges,\n48:   isWorktreesDirEmpty,\n49:   branchExists,\n50:   removeWorktree,\n51:   log as wtLog,\n52: } from \"../lib/worktree.js\";\n53: import { generatePrompt, generateConflictResolutionPrompt, type QuestPromptContext } from \"../lib/prompt.js\";\n54: import {\n55:   launchHeadless,\n56:   retryHeadless,\n57:   launchInteractive,\n58:   retryInteractive,\n59:   launchConflictResolver,\n60:   isProcessRunning,\n61:   getMultiplexerName,\n62: } from \"../lib/launcher.js\";\n63: import { ProcessMonitor } from \"../lib/monitor.js\";\n64: import { runBuild, runFullVerification, type FullVerificationOptions } from \"../lib/verifier.js\";\n65: import { mergeBranch, mergeBaseIntoFeature, pushBaseBranch, canMerge, enqueueMerge, tieredMergeBaseIntoFeature } from \"../lib/merger.js\";\n66: import {\n67:   printDashboard,\n68:   printFeatureSelection,\n69:   printAgentUpdate,\n70: } from \"../lib/ui.js\";\n71: import { WomboTUI } from \"../lib/tui.js\";\n72: import { ensureAgentDefinition } from \"../lib/templates.js\";\n73: import {\n74:   buildDepGraph,\n75:   validateDepGraph,\n76:   buildSchedulePlan,\n77:   formatSchedulePlan,\n78:   getStreamForFeature,\n79:   type DepGraph,\n80:   type SchedulePlan,\n81: } from \"../lib/dependency-graph.js\";\n82: import { ensureProxyRunning, isPortlessAvailable, portlessUrl } from \"../lib/portless.js\";\n83: import { output, outputError, outputMessage, type OutputFormat } from \"../lib/output.js\";\n84: import { renderLaunchDryRun } from \"../lib/toon.js\";\n85: import {\n86:   detectMultiplexer,\n87:   muxAttachCommand,\n88:   muxListCommand,\n89: } from \"../lib/multiplexer.js\";\n90: import { exportWaveHistory } from \"../lib/history.js\";\n91: import {\n92:   prepareAgentDefinitions,\n93:   isSpecializedAgent,\n94:   writeAgentToWorktree,\n95:   type AgentResolution,\n96: } from \"../lib/agent-registry.js\";\n97: import { patchImportedAgent } from \"../lib/templates.js\";\n98: import {\n99:   tuiPreflightConfirm,\n100:   consolePreflightConfirm,\n101: } from \"../lib/preflight.js\";\n102: import { loadQuest, loadQuestKnowledge } from \"../lib/quest-store.js\";\n103: import { resolveQuestConfig, applyQuestConstraintsToTask, type QuestHitlMode } from \"../lib/quest.js\";\n104: import { questBranchExists, createQuestBranch } from \"../lib/worktree.js\";\n105: import { getPendingQuestions, cleanupAll as cleanupHitl, submitAnswer, type HitlQuestion } from \"../lib/hitl-channel.js\";\n106: \n107: // ---------------------------------------------------------------------------\n108: // Constants\n109: // ---------------------------------------------------------------------------\n110: \n111: /**\n112:  * Build a QuestPromptContext from a wave's quest_id.\n113:  * Returns undefined if the wave is not quest-scoped.\n114:  * Used by internal functions that can't receive questContext from their caller.\n115:  */\n116: function buildQuestContext(\n117:   projectRoot: string,\n118:   questId: string | null\n119: ): QuestPromptContext | undefined {\n120:   if (!questId) return undefined;\n121: \n122:   const quest = loadQuest(projectRoot, questId);\n123:   if (!quest) return undefined;\n124: \n125:   const knowledge = loadQuestKnowledge(projectRoot, questId);\n126:   return {\n127:     questId: quest.id,\n128:     goal: quest.goal,\n129:     addedConstraints: quest.constraints.add ?? [],\n130:     addedForbidden: quest.constraints.ban ?? [],\n131:     knowledge,\n132:   };\n133: }\n134: \n135: /**\n136:  * Delay (ms) between sequential agent launches to avoid SQLite race conditions.\n137:  * Each agent spawns its own process which runs DB migrations on startup.\n138:  * Launching them simultaneously causes `CREATE TABLE` collisions.\n139:  */\n140: const LAUNCH_STAGGER_MS = 500;\n141: \n142: // ---------------------------------------------------------------------------\n143: // Types\n144: // ---------------------------------------------------------------------------\n145: \n146: export interface LaunchCommandOptions {\n147:   projectRoot: string;\n148:   config: WomboConfig;\n149:   // Selection\n150:   topPriority?: number;\n151:   quickestWins?: number;\n152:   priority?: Priority;\n153:   difficulty?: Difficulty;\n154:   features?: string[];\n155:   allReady?: boolean;\n156:   // Launch\n157:   maxConcurrent: number;\n158:   model?: string;\n159:   interactive: boolean;\n160:   dryRun: boolean;\n161:   baseBranch: string;\n162:   maxRetries: number;\n163:   noTui: boolean;\n164:   autoPush: boolean;\n165:   // Agent selection\n166:   /** CLI override: use this local agent definition for all launched tasks */\n167:   agent?: string;\n168:   // Quest scoping\n169:   /** Quest ID to scope this launch to (uses quest branch as base) */\n170:   questId?: string;\n171:   // Output\n172:   outputFmt?: OutputFormat;\n173:   /**\n174:    * When true, pressing Q in the monitor detaches (returns to caller) instead\n175:    * of killing agents and exiting. Used by cmdTui so the user can switch\n176:    * between the monitor and task browser while agents keep running.\n177:    */\n178:   detachOnQuit?: boolean;\n179: }\n180: \n181: // ---------------------------------------------------------------------------\n182: // Shared Helpers (exported for resume.ts and others)\n183: // ---------------------------------------------------------------------------\n184: \n185: /**\n186:  * Mark a feature as done in the features file after a successful merge.\n187:  * Updates status to \"done\", completion to 100, and sets ended_at.\n188:  *\n189:  * GUARD: Verifies that the feature branch has actually been merged into\n190:  * baseBranch before allowing the status change. This prevents callers\n191:  * from accidentally marking verified-but-unmerged features as done.\n192:  *\n193:  * @param fmt - Output format. When \"json\" or \"toon\", suppresses console warnings.\n194:  */\n195: export function markFeatureDone(\n196:   projectRoot: string,\n197:   featureId: string,\n198:   config: WomboConfig,\n199:   baseBranch: string,\n200:   fmt: OutputFormat = \"text\"\n201: ): void {\n202:   try {\n203:     // Verify the feature branch was actually merged into base\n204:     const branch = featureBranchName(featureId, config);\n205:     try {\n206:       execSync(`git merge-base --is-ancestor \"${branch}\" \"${baseBranch}\"`, {\n207:         cwd: projectRoot,\n208:         stdio: \"pipe\",\n209:       });\n210:     } catch {\n211:       // git merge-base --is-ancestor exits non-zero if NOT an ancestor\n212:       if (fmt === \"text\") {\n213:         console.error(\n214:           `Warning: ${featureId} branch \"${branch}\" is not merged into \"${baseBranch}\" — refusing to mark as done`\n215:         );\n216:       }\n217:       return;\n218:     }\n219: \n220:     const data = loadFeatures(projectRoot, config);\n221:     const feature = data.tasks.find((f: Feature) => f.id === featureId);\n222:     if (feature && feature.status !== \"done\") {\n223:       feature.status = \"done\";\n224:       feature.completion = 100;\n225:       feature.ended_at = new Date().toISOString();\n226:       saveFeatures(projectRoot, config, data);\n227:     }\n228:   } catch (err: any) {\n229:     // Non-fatal — log but don't crash the wave\n230:     if (fmt === \"text\") {\n231:       console.error(`Warning: failed to update feature status for ${featureId}: ${err.message}`);\n232:     }\n233:   }\n234: }\n235: \n236: /**\n237:  * Launch a single agent in headless mode.\n238:  * Sets up worktree, installs deps, generates prompt, launches agent process.\n239:  * If agentResolutions is provided and contains a specialized agent for this\n240:  * feature, the patched agent definition is written into the worktree.\n241:  */\n242: export async function launchSingleHeadless(\n243:   projectRoot: string,\n244:   state: WaveState,\n245:   agent: AgentState,\n246:   feature: Feature,\n247:   monitor: ProcessMonitor,\n248:   config: WomboConfig,\n249:   model?: string,\n250:   agentResolutions?: Map<string, AgentResolution>,\n251:   questContext?: QuestPromptContext,\n252:   hitlMode?: string\n253: ): Promise<void> {\n254:   updateAgent(state, agent.feature_id, {\n255:     status: \"installing\",\n256:     started_at: new Date().toISOString(),\n257:     activity: \"setting up worktree...\",\n258:   });\n259:   saveState(projectRoot, state);\n260: \n261:   try {\n262:     // Check if this agent is reusing a chain predecessor's worktree\n263:     const isChainReuse = agent.depends_on.some((depId) => {\n264:       const depAgent = state.agents.find((a) => a.feature_id === depId);\n265:       return depAgent && depAgent.worktree === agent.worktree;\n266:     });\n267: \n268:     if (isChainReuse && worktreeReady(agent.worktree)) {\n269:       // Chain worktree reuse: the worktree already exists from a predecessor.\n270:       // Create a new branch for this feature and switch the worktree to it.\n271:       wtLog(agent.feature_id, \"reusing chain worktree — switching branch...\");\n272:       updateAgent(state, agent.feature_id, { activity: \"switching branch (chain reuse)...\" });\n273: \n274:       try {\n275:         // Create the new feature branch from base (in the worktree)\n276:         execSync(`git checkout -B \"${agent.branch}\" \"${state.base_branch}\"`, {\n277:           cwd: agent.worktree,\n278:           stdio: \"pipe\",\n279:         });\n280:         wtLog(agent.feature_id, `switched to branch ${agent.branch}`);\n281:       } catch (branchErr: any) {\n282:         wtLog(agent.feature_id, `branch switch failed: ${branchErr.message}`);\n283:         // Fall through to normal worktree creation\n284:         await createWorktree(projectRoot, feature.id, state.base_branch, config);\n285:       }\n286:     } else if (worktreeReady(agent.worktree)) {\n287:       // Skip worktree setup if already ready (resume case)\n288:       wtLog(agent.feature_id, \"worktree already exists, skipping setup\");\n289:     } else {\n290:       // Create worktree (async — doesn't block other agents)\n291:       await createWorktree(projectRoot, feature.id, state.base_branch, config);\n292: \n293:       // Install dependencies (async)\n294:       updateAgent(state, agent.feature_id, { activity: \"installing deps...\" });\n295:       await installDeps(agent.worktree, feature.id, config);\n296:     }\n297: \n298:     // Generate prompt\n299:     const prompt = generatePrompt(feature, state.base_branch, config, questContext, hitlMode as QuestHitlMode | undefined);\n300: \n301:     // Write specialized agent to worktree if applicable\n302:     const resolution = agentResolutions?.get(feature.id);\n303:     const agentName = agent.agent_name ?? undefined;\n304:     if (resolution && isSpecializedAgent(resolution)) {\n305:       try {\n306:         const patchedContent = patchImportedAgent(resolution.rawContent, config, projectRoot);\n307:         writeAgentToWorktree(agent.worktree, resolution.name, patchedContent);\n308:         wtLog(agent.feature_id, `wrote specialized agent: ${resolution.name}`);\n309:       } catch (err: any) {\n310:         wtLog(agent.feature_id, `WARN: failed to write specialized agent, using generalist: ${err.message}`);\n311:       }\n312:     }\n313: \n314:     // Launch agent\n315:     wtLog(agent.feature_id, \"launching agent...\");\n316:     const result = launchHeadless({\n317:       worktreePath: agent.worktree,\n318:       featureId: feature.id,\n319:       prompt,\n320:       model,\n321:       config,\n322:       agentName,\n323:       hitlMode,\n324:       projectRoot,\n325:     });\n326: \n327:     updateAgent(state, agent.feature_id, {\n328:       status: \"running\",\n329:       pid: result.pid,\n330:       activity: \"starting...\",\n331:     });\n332:     saveState(projectRoot, state);\n333: \n334:     monitor.addProcess(feature.id, result.process);\n335:     wtLog(agent.feature_id, `running (PID: ${result.pid})`);\n336:   } catch (err: any) {\n337:     updateAgent(state, agent.feature_id, {\n338:       status: \"failed\",\n339:       error: err.message,\n340:       activity: null,\n341:       completed_at: new Date().toISOString(),\n342:     });\n343:     saveState(projectRoot, state);\n344:     wtLog(agent.feature_id, `SETUP FAILED: ${err.message.split(\"\\n\")[0]}`);\n345:   }\n346: }\n347: \n348: /**\n349:  * Handle build verification after agent completion.\n350:  * Runs build, auto-merges on pass, retries on failure if retries remain.\n351:  *\n352:  * ASYNC — runs build and merge without blocking the event loop.\n353:  */\n354: export async function handleBuildVerification(\n355:   projectRoot: string,\n356:   state: WaveState,\n357:   agent: AgentState,\n358:   feature: Feature,\n359:   config: WomboConfig,\n360:   model?: string,\n361:   monitor?: ProcessMonitor,\n362:   tddOpts?: FullVerificationOptions,\n363:   hitlMode?: string\n364: ): Promise<void> {\n365:   try {\n366:     printAgentUpdate(agent, \"verifying build...\");\n367: \n368:     // Use full verification pipeline (build + optional browser tests + optional TDD)\n369:     const fullResult = await runFullVerification(agent.worktree, agent.feature_id, config, tddOpts);\n370:     const buildResult = fullResult.build;\n371: \n372:     // Report browser test status if they ran\n373:     if (fullResult.browser.ran && fullResult.browser.browserResult) {\n374:       const br = fullResult.browser.browserResult;\n375:       printAgentUpdate(\n376:         agent,\n377:         `BROWSER: ${br.summary} (${Math.round(br.totalDurationMs / 1000)}s)`\n378:       );\n379:     } else if (fullResult.browser.skipReason && config.browser.enabled) {\n380:       printAgentUpdate(agent, `BROWSER: skipped — ${fullResult.browser.skipReason}`);\n381:     }\n382: \n383:     // Report TDD verification status if it ran\n384:     if (fullResult.tdd.ran) {\n385:       const tdd = fullResult.tdd;\n386:       const tddIcon = tdd.passed ? \"✓\" : \"✗\";\n387:       printAgentUpdate(agent, `TDD: ${tddIcon} ${tdd.summary}`);\n388:       if (tdd.hasWarnings) {\n389:         printAgentUpdate(agent, `TDD: ⚠ Missing tests detected (non-blocking)`);\n390:       }\n391:     } else if (fullResult.tdd.skipReason && config.tdd?.enabled) {\n392:       printAgentUpdate(agent, `TDD: skipped — ${fullResult.tdd.skipReason}`);\n393:     }\n394: \n395:     if (fullResult.overallPassed) {\n396:       updateAgent(state, agent.feature_id, {\n397:         status: \"verified\",\n398:         build_passed: true,\n399:         build_output: null,\n400:       });\n401:       saveState(projectRoot, state);\n402:       printAgentUpdate(agent, `BUILD PASSED (${Math.round(buildResult.durationMs / 1000)}s)`);\n403: \n404:       // Auto-merge: attempt merge + conflict resolution\n405:       await attemptMerge(projectRoot, state, agent, feature, config, model);\n406:     } else {\n407:       const errorSummary = fullResult.combinedErrorSummary;\n408: \n409:       if (agent.retries < agent.max_retries) {\n410:         updateAgent(state, agent.feature_id, {\n411:           status: \"retry\",\n412:           retries: agent.retries + 1,\n413:           build_passed: false,\n414:           build_output: errorSummary,\n415:         });\n416:         saveState(projectRoot, state);\n417:         printAgentUpdate(\n418:           agent,\n419:           `VERIFICATION FAILED — retrying (${agent.retries}/${agent.max_retries})`\n420:         );\n421: \n422:         // Retry with error details\n423:         if (agent.session_id) {\n424:           const retryResult = retryHeadless({\n425:             worktreePath: agent.worktree,\n426:             featureId: agent.feature_id,\n427:             sessionId: agent.session_id,\n428:             buildErrors: errorSummary,\n429:             model,\n430:             config,\n431:             hitlMode,\n432:             projectRoot,\n433:           });\n434: \n435:           updateAgent(state, agent.feature_id, {\n436:             status: \"running\",\n437:             pid: retryResult.pid,\n438:           });\n439:           saveState(projectRoot, state);\n440: \n441:           // Add retry process to monitor so events are tracked\n442:           if (monitor) {\n443:             monitor.addProcess(agent.feature_id, retryResult.process);\n444:           }\n445:         } else {\n446:           // Agent has no session — reset to queued for a fresh launch\n447:           wtLog(agent.feature_id, `no session — resetting to queued for fresh launch (retry ${agent.retries}/${agent.max_retries})`);\n448:           updateAgent(state, agent.feature_id, {\n449:             status: \"queued\",\n450:             error: null,\n451:             activity: \"waiting for relaunch...\",\n452:           });\n453:           saveState(projectRoot, state);\n454:         }\n455:       } else {\n456:         updateAgent(state, agent.feature_id, {\n457:           status: \"failed\",\n458:           build_passed: false,\n459:           build_output: errorSummary,\n460:           error: `Verification failed after ${agent.max_retries} retries`,\n461:           completed_at: new Date().toISOString(),\n462:         });\n463:         saveState(projectRoot, state);\n464:         printAgentUpdate(agent, \"VERIFICATION FAILED — max retries reached\");\n465: \n466:         // Cascade failure to downstream agents\n467:         const cancelled = cancelDownstream(state, agent.feature_id);\n468:         if (cancelled.length > 0) {\n469:           printAgentUpdate(agent, `downstream cancelled: ${cancelled.join(\", \")}`);\n470:           saveState(projectRoot, state);\n471:         }\n472:       }\n473:     }\n474:   } catch (err: any) {\n475:     // Catch-all — never let build verification crash the process\n476:     printAgentUpdate(agent, `VERIFY ERROR: ${err.message?.slice(0, 100)}`);\n477:     updateAgent(state, agent.feature_id, {\n478:       status: \"failed\",\n479:       error: `Build verification error: ${err.message}`,\n480:       completed_at: new Date().toISOString(),\n481:     });\n482:     saveState(projectRoot, state);\n483:   }\n484: }\n485: \n486: /**\n487:  * Attempt to merge a verified agent's branch into the base branch.\n488:  *\n489:  * Handles conflict detection, base-into-feature merge, and resolver agent\n490:  * launch. Extracted from handleBuildVerification so it can be called\n491:  * independently (e.g., from resume's sequential merge phase).\n492:  *\n493:  * All merge operations are serialized via enqueueMerge() to prevent\n494:  * concurrent checkout races on the project root.\n495:  */\n496: export async function attemptMerge(\n497:   projectRoot: string,\n498:   state: WaveState,\n499:   agent: AgentState,\n500:   feature: Feature,\n501:   config: WomboConfig,\n502:   model?: string,\n503: ): Promise<void> {\n504:   return enqueueMerge(async () => {\n505:     printAgentUpdate(agent, \"auto-merging...\");\n506:     try {\n507:       // Pre-flight check: detect conflicts before attempting the real merge.\n508:       // This avoids the expensive merge-then-abort dance for known conflicts.\n509:       const preCheck = await canMerge(projectRoot, agent.branch, state.base_branch);\n510:       if (!preCheck.canMerge) {\n511:         printAgentUpdate(agent, `conflict detected (pre-flight) — attempting resolution...`);\n512:         await handleMergeConflict(\n513:           projectRoot, state, agent, feature, config, model,\n514:           preCheck.reason\n515:         );\n516:         return;\n517:       }\n518: \n519:       const mergeResult = await mergeBranch(projectRoot, agent.branch, state.base_branch, config);\n520: \n521:       if (mergeResult.success) {\n522:         handleMergeSuccess(projectRoot, state, agent, config, mergeResult.commitHash);\n523:         return;\n524:       }\n525: \n526:       // Merge failed despite clean pre-flight — race with another merge or\n527:       // a git state issue. Fall through to conflict resolution.\n528:       printAgentUpdate(agent, `MERGE CONFLICT — attempting resolution...`);\n529:       await handleMergeConflict(\n530:         projectRoot, state, agent, feature, config, model,\n531:         mergeResult.error ?? \"Unknown merge error\"\n532:       );\n533:     } catch (mergeErr: any) {\n534:       // Unexpected exception — stay in \"verified\" (retryable) but record the\n535:       // error so the user can see what went wrong instead of silent stalling.\n536:       printAgentUpdate(agent, `AUTO-MERGE ERROR: ${mergeErr.message?.slice(0, 100)}`);\n537:       updateAgent(state, agent.feature_id, {\n538:         error: `Auto-merge error: ${mergeErr.message}`,\n539:       });\n540:       saveState(projectRoot, state);\n541:     }\n542:   });\n543: }\n544: \n545: /**\n546:  * Handle a successful merge: update state, mark feature done, clean up.\n547:  */\n548: function handleMergeSuccess(\n549:   projectRoot: string,\n550:   state: WaveState,\n551:   agent: AgentState,\n552:   config: WomboConfig,\n553:   commitHash: string | null,\n554:   label = \"MERGED\",\n555: ): void {\n556:   updateAgent(state, agent.feature_id, {\n557:     status: \"merged\",\n558:     completed_at: new Date().toISOString(),\n559:   });\n560:   saveState(projectRoot, state);\n561:   printAgentUpdate(agent, `${label} (${commitHash?.slice(0, 7)})`);\n562: \n563:   markFeatureDone(projectRoot, agent.feature_id, config, state.base_branch);\n564: \n565:   // Clean up worktree — but preserve it if downstream agents in the same\n566:   // chain share this worktree.\n567:   const hasChainSuccessor = agent.depended_on_by.some((depId) => {\n568:     const depAgent = state.agents.find((a) => a.feature_id === depId);\n569:     return depAgent && depAgent.worktree === agent.worktree;\n570:   });\n571: \n572:   if (hasChainSuccessor) {\n573:     printAgentUpdate(agent, \"worktree preserved for chain successor\");\n574:   } else {\n575:     try {\n576:       removeWorktree(projectRoot, agent.worktree, true);\n577:       printAgentUpdate(agent, \"worktree and branch removed\");\n578:     } catch (err: any) {\n579:       // Log the failure so it's visible — stale worktrees waste disk space\n580:       printAgentUpdate(agent, `WARN: worktree cleanup failed: ${err.message?.split(\"\\n\")[0]}`);\n581:     }\n582:   }\n583: }\n584: \n585: /**\n586:  * Handle a merge conflict: use tiered merge strategy.\n587:  *\n588:  * Tier 1: Already failed (we got here because the direct merge failed).\n589:  * Tier 2: Merge base into feature, then auto-resolve trivial conflicts.\n590:  * Tier 3: Real conflicts remain — launch a resolver agent.\n591:  *\n592:  * If tier 3 also fails after max attempts, mark as needs_manual_merge.\n593:  *\n594:  * All failure paths record the error on the agent (which stays \"verified\")\n595:  * so the merge can be retried without silently stalling.\n596:  */\n597: async function handleMergeConflict(\n598:   projectRoot: string,\n599:   state: WaveState,\n600:   agent: AgentState,\n601:   feature: Feature,\n602:   config: WomboConfig,\n603:   model: string | undefined,\n604:   mergeError: string,\n605: ): Promise<void> {\n606:   try {\n607:     // Tiered merge: attempts tier 1 (clean merge) and tier 2 (trivial auto-resolve)\n608:     const tieredResult = await tieredMergeBaseIntoFeature(\n609:       agent.worktree,\n610:       state.base_branch,\n611:       config\n612:     );\n613: \n614:     if (tieredResult.success && tieredResult.tier === 1) {\n615:       // Clean merge of base into feature — retry merge into base\n616:       printAgentUpdate(agent, \"base merged cleanly into feature — retrying merge...\");\n617:       const retryMerge = await mergeBranch(projectRoot, agent.branch, state.base_branch, config);\n618:       if (retryMerge.success) {\n619:         handleMergeSuccess(projectRoot, state, agent, config, retryMerge.commitHash, \"MERGED after rebase\");\n620:         return;\n621:       }\n622: \n623:       // Retry still failed — need conflict resolution. Re-merge base into\n624:       // feature to get conflict files for the resolver.\n625:       printAgentUpdate(agent, `retry merge still failed — launching resolver agent...`);\n626:       const secondConflict = await mergeBaseIntoFeature(\n627:         agent.worktree,\n628:         state.base_branch,\n629:         config\n630:       );\n631: \n632:       const conflictFiles = secondConflict.conflicting\n633:         ? secondConflict.files\n634:         : [\"(unknown — merge direction mismatch)\"];\n635: \n636:       await launchResolverAndRetryMerge(\n637:         projectRoot, state, agent, feature, config, model,\n638:         retryMerge.error ?? mergeError, conflictFiles\n639:       );\n640:       return;\n641:     }\n642: \n643:     if (tieredResult.success && tieredResult.tier === 2) {\n644:       // Trivial conflicts auto-resolved — retry merge into base\n645:       printAgentUpdate(agent, \"trivial conflicts auto-resolved (whitespace only) — retrying merge...\");\n646:       const retryMerge = await mergeBranch(projectRoot, agent.branch, state.base_branch, config);\n647:       if (retryMerge.success) {\n648:         handleMergeSuccess(projectRoot, state, agent, config, retryMerge.commitHash, \"MERGED after trivial auto-resolve\");\n649:         return;\n650:       }\n651: \n652:       // Still failed after auto-resolve — fall through to agent resolver\n653:       printAgentUpdate(agent, `merge still failed after auto-resolve — launching resolver agent...`);\n654:       const postAutoConflict = await mergeBaseIntoFeature(\n655:         agent.worktree,\n656:         state.base_branch,\n657:         config\n658:       );\n659:       const conflictFiles = postAutoConflict.conflicting\n660:         ? postAutoConflict.files\n661:         : [\"(unknown — merge direction mismatch)\"];\n662: \n663:       await launchResolverAndRetryMerge(\n664:         projectRoot, state, agent, feature, config, model,\n665:         retryMerge.error ?? mergeError, conflictFiles\n666:       );\n667:       return;\n668:     }\n669: \n670:     if (tieredResult.tier === null && tieredResult.error) {\n671:       // Setup itself failed — stay as \"verified\" (retryable) with error\n672:       printAgentUpdate(agent, `CONFLICT SETUP FAILED: ${tieredResult.error.slice(0, 100)}`);\n673:       updateAgent(state, agent.feature_id, {\n674:         error: `Conflict setup failed: ${tieredResult.error}`,\n675:       });\n676:       saveState(projectRoot, state);\n677:       return;\n678:     }\n679: \n680:     // Tier 3: Real conflicts remain — launch resolver agent\n681:     printAgentUpdate(\n682:       agent,\n683:       `${tieredResult.conflictFiles.length} non-trivial conflict(s): ${tieredResult.conflictFiles.join(\", \")}`\n684:     );\n685: \n686:     await launchResolverAndRetryMerge(\n687:       projectRoot, state, agent, feature, config, model,\n688:       mergeError, tieredResult.conflictFiles\n689:     );\n690:   } catch (conflictErr: any) {\n691:     // Unexpected error during conflict handling — stay \"verified\" with error\n692:     printAgentUpdate(agent, `CONFLICT RESOLUTION ERROR: ${conflictErr.message?.slice(0, 100)}`);\n693:     updateAgent(state, agent.feature_id, {\n694:       error: `Conflict resolution error: ${conflictErr.message}`,\n695:     });\n696:     saveState(projectRoot, state);\n697:   }\n698: }\n699: \n700: /**\n701:  * Launch a conflict resolver agent, wait for it to finish, re-verify build,\n702:  * and retry the merge. Supports configurable retry attempts (defaults to 1,\n703:  * up to config.defaults.maxRetries + 1).\n704:  *\n705:  * The resolver is re-launched with updated conflict state on each attempt,\n706:  * so it sees the current conflict markers, not stale ones.\n707:  */\n708: async function launchResolverAndRetryMerge(\n709:   projectRoot: string,\n710:   state: WaveState,\n711:   agent: AgentState,\n712:   feature: Feature,\n713:   config: WomboConfig,\n714:   model: string | undefined,\n715:   mergeError: string,\n716:   conflictFiles: string[]\n717: ): Promise<void> {\n718:   const maxResolverAttempts = Math.max(1, (config.defaults.maxRetries ?? 0) + 1);\n719: \n720:   for (let attempt = 1; attempt <= maxResolverAttempts; attempt++) {\n721:     const conflictPrompt = generateConflictResolutionPrompt(\n722:       feature,\n723:       state.base_branch,\n724:       mergeError,\n725:       config,\n726:       buildQuestContext(projectRoot, state.quest_id)\n727:     );\n728: \n729:     const attemptLabel = maxResolverAttempts > 1\n730:       ? ` (attempt ${attempt}/${maxResolverAttempts})`\n731:       : \"\";\n732: \n733:     updateAgent(state, agent.feature_id, {\n734:       status: \"resolving_conflict\",\n735:       activity: `resolving ${conflictFiles.length} conflict(s)${attemptLabel}...`,\n736:     });\n737:     saveState(projectRoot, state);\n738: \n739:     const resolverResult = launchConflictResolver({\n740:       worktreePath: agent.worktree,\n741:       featureId: agent.feature_id,\n742:       prompt: conflictPrompt,\n743:       model,\n744:       config,\n745:     });\n746: \n747:     updateAgent(state, agent.feature_id, {\n748:       pid: resolverResult.pid,\n749:     });\n750:     saveState(projectRoot, state);\n751: \n752:     // Wait for the resolver process to complete, then re-verify and retry merge.\n753:     // We intentionally do NOT add the resolver to the ProcessMonitor because\n754:     // the monitor's onComplete callback would trigger handleBuildVerification\n755:     // again, causing infinite recursion. Instead we await the process directly.\n756:     const resolverExitCode = await new Promise<number | null>((resolve) => {\n757:       resolverResult.process.on(\"exit\", (code) => resolve(code));\n758:       resolverResult.process.on(\"error\", () => resolve(null));\n759:     });\n760: \n761:     printAgentUpdate(\n762:       agent,\n763:       `conflict resolver exited (code ${resolverExitCode})${attemptLabel} — re-verifying build...`\n764:     );\n765: \n766:     // Re-verify build after conflict resolution\n767:     const rebuildResult = await runBuild(agent.worktree, config);\n768: \n769:     if (!rebuildResult.passed) {\n770:       if (attempt < maxResolverAttempts) {\n771:         printAgentUpdate(agent, `POST-CONFLICT BUILD FAILED${attemptLabel} — retrying resolver...`);\n772:         continue; // Try again with a fresh resolver\n773:       }\n774:       printAgentUpdate(agent, `POST-CONFLICT BUILD FAILED (all ${maxResolverAttempts} attempts exhausted)`);\n775:       updateAgent(state, agent.feature_id, {\n776:         status: \"failed\",\n777:         build_passed: false,\n778:         build_output: rebuildResult.errorSummary,\n779:         error: \"Build failed after conflict resolution\",\n780:         completed_at: new Date().toISOString(),\n781:       });\n782:       saveState(projectRoot, state);\n783:       cancelDownstream(state, agent.feature_id);\n784:       saveState(projectRoot, state);\n785:       return;\n786:     }\n787: \n788:     printAgentUpdate(agent, \"post-conflict build passed — retrying merge...\");\n789: \n790:     const retryMerge = await mergeBranch(\n791:       projectRoot,\n792:       agent.branch,\n793:       state.base_branch,\n794:       config\n795:     );\n796: \n797:     if (retryMerge.success) {\n798:       handleMergeSuccess(\n799:         projectRoot, state, agent, config,\n800:         retryMerge.commitHash, \"MERGED after conflict resolution\"\n801:       );\n802:       return;\n803:     }\n804: \n805:     // Merge still failed after resolver. If we have attempts left, re-merge\n806:     // base into feature to refresh conflict markers and try again.\n807:     if (attempt < maxResolverAttempts) {\n808:       printAgentUpdate(agent, `POST-CONFLICT MERGE FAILED${attemptLabel} — retrying resolver...`);\n809:       const refreshConflict = await mergeBaseIntoFeature(\n810:         agent.worktree,\n811:         state.base_branch,\n812:         config\n813:       );\n814:       conflictFiles = refreshConflict.conflicting\n815:         ? refreshConflict.files\n816:         : conflictFiles;\n817:       mergeError = retryMerge.error ?? mergeError;\n818:       continue;\n819:     }\n820: \n821:     // All attempts exhausted\n822:     printAgentUpdate(agent, `POST-CONFLICT MERGE FAILED (all ${maxResolverAttempts} attempts exhausted): ${retryMerge.error}`);\n823:     updateAgent(state, agent.feature_id, {\n824:       status: \"failed\",\n825:       error: `Merge still failed after ${maxResolverAttempts} conflict resolution attempt(s): ${retryMerge.error}`,\n826:       completed_at: new Date().toISOString(),\n827:     });\n828:     saveState(projectRoot, state);\n829:     cancelDownstream(state, agent.feature_id);\n830:     saveState(projectRoot, state);\n831:     return;\n832:   }\n833: }\n834: \n835: /**\n836:  * Handle retry of a failed agent (error-based, not build-based).\n837:  *\n838:  * If the agent has a session_id, resumes the existing session with error context.\n839:  * If the agent crashed before establishing a session (session_id is null),\n840:  * resets it to \"queued\" so it gets relaunched from scratch on the next\n841:  * launchAllReady() cycle. This prevents the \"stuck retry\" state where an\n842:  * agent sits in \"retry\" forever with no process running.\n843:  */\n844: export function handleRetry(\n845:   projectRoot: string,\n846:   state: WaveState,\n847:   agent: AgentState,\n848:   monitor: ProcessMonitor,\n849:   config: WomboConfig,\n850:   model?: string,\n851:   hitlMode?: string\n852: ): void {\n853:   if (!agent.session_id) {\n854:     // Agent crashed before establishing a session (e.g. SQLite race condition).\n855:     // Reset to queued so it gets a fresh launch on the next cycle.\n856:     wtLog(agent.feature_id, `no session — resetting to queued for fresh launch (retry ${agent.retries}/${agent.max_retries})`);\n857:     updateAgent(state, agent.feature_id, {\n858:       status: \"queued\",\n859:       error: null,\n860:       activity: \"waiting for relaunch...\",\n861:     });\n862:     saveState(projectRoot, state);\n863:     return;\n864:   }\n865: \n866:   if (!agent.error) return;\n867: \n868:   const retryResult = retryHeadless({\n869:     worktreePath: agent.worktree,\n870:     featureId: agent.feature_id,\n871:     sessionId: agent.session_id,\n872:     buildErrors: agent.error,\n873:     model,\n874:     config,\n875:     hitlMode,\n876:     projectRoot,\n877:   });\n878: \n879:   updateAgent(state, agent.feature_id, {\n880:     status: \"running\",\n881:     pid: retryResult.pid,\n882:   });\n883:   saveState(projectRoot, state);\n884: \n885:   monitor.addProcess(agent.feature_id, retryResult.process);\n886: }\n887: \n888: /**\n889:  * Launch the next queued agent if capacity allows.\n890:  * Dependency-aware: only launches agents whose dependencies are satisfied.\n891:  */\n892: export async function launchNextQueued(\n893:   projectRoot: string,\n894:   state: WaveState,\n895:   featureMap: Map<string, Feature>,\n896:   monitor: ProcessMonitor,\n897:   config: WomboConfig,\n898:   model?: string,\n899:   agentResolutions?: Map<string, AgentResolution>,\n900:   questContext?: QuestPromptContext,\n901:   hitlMode?: string\n902: ): Promise<void> {\n903:   const active = activeAgents(state);\n904:   const ready = readyToLaunchAgents(state);\n905: \n906:   if (active.length < state.max_concurrent && ready.length > 0) {\n907:     const next = ready[0];\n908:     const feature = featureMap.get(next.feature_id);\n909:     if (feature) {\n910:       await launchSingleHeadless(projectRoot, state, next, feature, monitor, config, model, agentResolutions, questContext, hitlMode);\n911:     }\n912:   }\n913: }\n914: \n915: /**\n916:  * Launch ALL ready agents up to capacity.\n917:  * After a dependency completes, multiple downstream agents may become unblocked.\n918:  * This launches as many as capacity allows, not just one.\n919:  *\n920:  * Launches are staggered to avoid SQLite race conditions.\n921:  *\n922:  * Also logs merge gate events when diamond-dependency features become unblocked.\n923:  */\n924: export async function launchAllReady(\n925:   projectRoot: string,\n926:   state: WaveState,\n927:   featureMap: Map<string, Feature>,\n928:   monitor: ProcessMonitor,\n929:   config: WomboConfig,\n930:   model?: string,\n931:   agentResolutions?: Map<string, AgentResolution>,\n932:   questContext?: QuestPromptContext,\n933:   hitlMode?: string\n934: ): Promise<void> {\n935:   const active = activeAgents(state);\n936:   const ready = readyToLaunchAgents(state);\n937:   const available = state.max_concurrent - active.length;\n938: \n939:   if (available <= 0 || ready.length === 0) return;\n940: \n941:   const toLaunch = ready.slice(0, available);\n942:   for (let i = 0; i < toLaunch.length; i++) {\n943:     const next = toLaunch[i];\n944:     const feature = featureMap.get(next.feature_id);\n945:     if (!feature) continue;\n946: \n947:     // Log merge gate opening for diamond dependencies\n948:     if (next.depends_on.length > 1 && state.schedule_plan) {\n949:       const isMergeGate = state.schedule_plan.merge_gates.some(\n950:         (g) => g.feature_id === next.feature_id\n951:       );\n952:       if (isMergeGate) {\n953:         wtLog(\n954:           next.feature_id,\n955:           `merge gate opened — all ${next.depends_on.length} dependencies satisfied`\n956:         );\n957:       }\n958:     }\n959: \n960:     await launchSingleHeadless(projectRoot, state, next, feature, monitor, config, model, agentResolutions, questContext, hitlMode);\n961:     // Stagger between launches to avoid SQLite race conditions\n962:     if (i < toLaunch.length - 1) {\n963:       await new Promise((r) => setTimeout(r, LAUNCH_STAGGER_MS));\n964:     }\n965:   }\n966: }\n967: \n968: // ---------------------------------------------------------------------------\n969: // Post-mortem: dump failed agent logs\n970: // ---------------------------------------------------------------------------\n971: \n972: /**\n973:  * Print full log contents for every failed agent so the user can diagnose\n974:  * issues after the wave finishes. Handles missing log files gracefully.\n975:  *\n976:  * In JSON/TOON mode, this function is a no-op — callers should emit\n977:  * structured failure data through the output() helper instead.\n978:  *\n979:  * @param fmt - Output format. Only prints when \"text\".\n980:  */\n981: export function dumpFailedAgentLogs(projectRoot: string, state: WaveState, fmt: OutputFormat = \"text\"): void {\n982:   if (fmt !== \"text\") return; // suppress in JSON/TOON mode\n983: \n984:   const failed = state.agents.filter((a) => a.status === \"failed\");\n985:   if (failed.length === 0) return;\n986: \n987:   const logDir = resolve(projectRoot, \".wombo-combo/logs\");\n988: \n989:   console.log(\n990:     `\\n${\"=\".repeat(72)}\\n` +\n991:     `  FAILED AGENT LOGS (${failed.length} agent${failed.length > 1 ? \"s\" : \"\"})\\n` +\n992:     `${\"=\".repeat(72)}`\n993:   );\n994: \n995:   for (const agent of failed) {\n996:     const logFile = resolve(logDir, `${agent.feature_id}.log`);\n997: \n998:     console.log(\n999:       `\\n${\"─\".repeat(72)}\\n` +\n1000:       `  Feature: ${agent.feature_id}\\n` +\n1001:       (agent.error ? `  Error:   ${agent.error}\\n` : \"\") +\n1002:       `${\"─\".repeat(72)}`\n1003:     );\n1004: \n1005:     if (!existsSync(logFile)) {\n1006:       console.log(\"  (no log file found)\");\n1007:       continue;\n1008:     }\n1009: \n1010:     try {\n1011:       const contents = readFileSync(logFile, \"utf-8\");\n1012:       if (contents.trim().length === 0) {\n1013:         console.log(\"  (log file is empty)\");\n1014:       } else {\n1015:         console.log(contents);\n1016:       }\n1017:     } catch (err: any) {\n1018:       console.log(`  (error reading log: ${err.message})`);\n1019:     }\n1020:   }\n1021: \n1022:   console.log(`\\n${\"=\".repeat(72)}\\n`);\n1023: }\n1024: \n1025: // ---------------------------------------------------------------------------\n1026: // Headless Wave Launch\n1027: // ---------------------------------------------------------------------------\n1028: \n1029: async function launchWaveHeadless(\n1030:   projectRoot: string,\n1031:   state: WaveState,\n1032:   features: Feature[],\n1033:   opts: LaunchCommandOptions,\n1034:   agentResolutions?: Map<string, AgentResolution>,\n1035:   questContext?: QuestPromptContext,\n1036:   hitlMode?: string\n1037: ): Promise<void> {\n1038:   const { config, model } = opts;\n1039:   const fmt = opts.outputFmt ?? \"text\";\n1040:   const featureMap = new Map(features.map((f) => [f.id, f]));\n1041: \n1042:   const monitor = new ProcessMonitor(projectRoot, {\n1043:     onSessionId: (featureId, sessionId) => {\n1044:       updateAgent(state, featureId, { session_id: sessionId });\n1045:       saveState(projectRoot, state);\n1046:     },\n1047:     onComplete: (featureId) => {\n1048:       updateAgent(state, featureId, {\n1049:         status: \"completed\",\n1050:         completed_at: new Date().toISOString(),\n1051:       });\n1052:       saveState(projectRoot, state);\n1053: \n1054:       // Run build verification — fire-and-forget\n1055:       const agent = state.agents.find((a) => a.feature_id === featureId)!;\n1056:       handleBuildVerification(projectRoot, state, agent, featureMap.get(featureId)!, config, model, monitor, undefined, hitlMode)\n1057:         .then(() => {\n1058:           // After verification/merge, try to launch dependency-ready agents\n1059:           // Multiple queued agents may now be unblocked\n1060:           launchAllReady(projectRoot, state, featureMap, monitor, config, model, agentResolutions, questContext, hitlMode)\n1061:             .catch((err) => wtLog(featureId, `LAUNCH ERROR: ${err.message}`));\n1062:         })\n1063:         .catch((err) => {\n1064:           wtLog(featureId, `BUILD VERIFICATION UNHANDLED ERROR: ${err.message}`);\n1065:           launchAllReady(projectRoot, state, featureMap, monitor, config, model, agentResolutions, questContext, hitlMode)\n1066:             .catch((err2) => wtLog(featureId, `LAUNCH ERROR: ${err2.message}`));\n1067:         });\n1068:     },\n1069:     onError: (featureId, error) => {\n1070:       const agent = state.agents.find((a) => a.feature_id === featureId)!;\n1071:       if (agent.retries < agent.max_retries) {\n1072:         updateAgent(state, featureId, {\n1073:           status: \"retry\",\n1074:           retries: agent.retries + 1,\n1075:           error,\n1076:         });\n1077:         saveState(projectRoot, state);\n1078: \n1079:         // Retry\n1080:         handleRetry(projectRoot, state, agent, monitor, config, model, hitlMode);\n1081:       } else {\n1082:         updateAgent(state, featureId, {\n1083:           status: \"failed\",\n1084:           error,\n1085:           completed_at: new Date().toISOString(),\n1086:         });\n1087:         saveState(projectRoot, state);\n1088: \n1089:         // Cascade failure to downstream agents\n1090:         const cancelled = cancelDownstream(state, featureId);\n1091:         if (cancelled.length > 0) {\n1092:           wtLog(featureId, `downstream cancelled: ${cancelled.join(\", \")}`);\n1093:           saveState(projectRoot, state);\n1094:         }\n1095:       }\n1096: \n1097:       // Try to launch dependency-ready agents\n1098:       launchAllReady(projectRoot, state, featureMap, monitor, config, model, agentResolutions, questContext, hitlMode)\n1099:         .catch((err) => wtLog(featureId, `LAUNCH ERROR: ${err.message}`));\n1100:     },\n1101:     onOutput: (_featureId, _data) => {\n1102:       // Raw output — logged to file by ProcessMonitor\n1103:     },\n1104:     onActivity: (featureId, activity) => {\n1105:       updateAgent(state, featureId, {\n1106:         activity,\n1107:         activity_updated_at: new Date().toISOString(),\n1108:       });\n1109:       // Don't save to disk on every activity — too frequent.\n1110:     },\n1111:   });\n1112: \n1113:   // Create the TUI — it will auto-refresh and show activity from the monitor\n1114:   //\n1115:   // Detach support: When the user presses Q in the monitor TUI, we no longer\n1116:   // kill agents and exit. Instead, we set a `detached` flag and let the\n1117:   // monitoring loop exit naturally. The caller (cmdTui) then loops back to\n1118:   // the task browser, which shows a \"running wave\" indicator.\n1119:   let detached = false;\n1120:   const tuiRef = { current: null as WomboTUI | null };\n1121:   const startTUI = () => {\n1122:     tuiRef.current = new WomboTUI({\n1123:       state,\n1124:       monitor,\n1125:       projectRoot,\n1126:       interactive: false,\n1127:       config,\n1128:       onQuit: () => {\n1129:           if (opts.detachOnQuit) {\n1130:             // Detach from the wave monitor — agents keep running in the background.\n1131:             // The monitoring loop checks `detached` and exits, returning control\n1132:             // to the caller (cmdTui main loop).\n1133:             flushState(projectRoot, state);\n1134:             // Null out the TUI ref so the monitoring loop stops trying to update\n1135:             // the destroyed screen during remaining poll iterations.\n1136:             tuiRef.current = null;\n1137:             detached = true;\n1138:           } else {\n1139:             // Standalone mode — kill agents and exit (traditional behavior).\n1140:             for (const agent of state.agents) {\n1141:               if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n1142:                 updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n1143:               }\n1144:             }\n1145:             monitor.killAll();\n1146:             flushState(projectRoot, state);\n1147:             if (fmt === \"text\") console.log(\"State saved. Use 'woco resume' to continue.\");\n1148:             process.exit(0);\n1149:           }\n1150:       },\n1151:       onBeforeDestroy: () => {\n1152:         // Flush state to disk before the blessed screen is destroyed.\n1153:         // This is called from TUI.stop() which runs before screen.destroy(),\n1154:         // ensuring state.json is complete even if process.exit() follows.\n1155:         flushState(projectRoot, state);\n1156:       },\n1157:       onRetry: (featureId: string) => {\n1158:         const agent = state.agents.find((a) => a.feature_id === featureId);\n1159:         if (!agent) return;\n1160:         if (agent.status !== \"failed\" && agent.status !== \"retry\") return;\n1161: \n1162:         // Reset retries if exhausted, give it one more shot\n1163:         if (agent.retries >= agent.max_retries) {\n1164:           updateAgent(state, featureId, { max_retries: agent.retries + 1 });\n1165:         }\n1166: \n1167:         wtLog(featureId, `manual retry requested from TUI — resetting to queued`);\n1168:         updateAgent(state, featureId, {\n1169:           status: \"queued\",\n1170:           error: null,\n1171:           activity: \"waiting for relaunch (manual retry)...\",\n1172:         });\n1173:         saveState(projectRoot, state);\n1174:         // The polling loop will call launchAllReady() and pick this up\n1175:       },\n1176:       onAnswer: (agentId: string, questionId: string, answerText: string) => {\n1177:         try {\n1178:           submitAnswer(projectRoot, agentId, questionId, answerText);\n1179:           wtLog(agentId, `HITL answer submitted: \"${answerText.slice(0, 80)}${answerText.length > 80 ? \"...\" : \"\"}\"`);\n1180:         } catch (err: any) {\n1181:           wtLog(agentId, `HITL answer error: ${err.message}`);\n1182:         }\n1183:       },\n1184:     });\n1185:     tuiRef.current.start();\n1186:   };\n1187: \n1188:   // Handle graceful shutdown\n1189:   //\n1190:   // Audit (wave-detach-audit): This is the critical shutdown path for headless\n1191:   // agents. Because agents are spawned with `detached: false` (see launcher.ts),\n1192:   // they would be killed by the OS when the parent exits anyway. However, calling\n1193:   // `monitor.killAll()` explicitly before `process.exit(0)` ensures:\n1194:   //   1. Each agent gets SIGTERM (not SIGKILL), allowing graceful shutdown\n1195:   //   2. Wave state is saved BEFORE agents die, preserving progress\n1196:   //   3. The TUI is cleanly destroyed before terminal restoration\n1197:   //\n1198:   // If the parent is killed with SIGKILL (uncatchable), agents die immediately\n1199:   // with no state save. `woco resume` recovers from this by detecting orphaned\n1200:   // worktrees with commits and re-verifying or re-launching as appropriate.\n1201:   const gracefulShutdown = (signal: string) => {\n1202:     if (tuiRef.current) tuiRef.current.stop();\n1203:     for (const agent of state.agents) {\n1204:       if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n1205:         updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n1206:       }\n1207:     }\n1208:     monitor.killAll();\n1209:     flushState(projectRoot, state);\n1210:     if (fmt === \"text\") console.log(`\\nState saved (${signal}). Use 'woco resume' to continue.`);\n1211:     process.exit(0);\n1212:   };\n1213:   process.on(\"SIGINT\", () => gracefulShutdown(\"SIGINT\"));\n1214:   process.on(\"SIGTERM\", () => gracefulShutdown(\"SIGTERM\"));\n1215:   process.on(\"SIGHUP\", () => gracefulShutdown(\"SIGHUP\"));\n1216: \n1217:   // Launch initial batch — only agents whose dependencies are already satisfied\n1218:   // Stagger launches to avoid SQLite race conditions in agent processes:\n1219:   // each agent spawns its own DB, and simultaneous CREATE TABLE calls collide.\n1220:   const ready = readyToLaunchAgents(state);\n1221:   const tolaunch = ready.slice(0, opts.maxConcurrent);\n1222:   if (fmt === \"text\") console.log(`Setting up ${tolaunch.length} agent(s) (staggered)...\\n`);\n1223: \n1224:   for (let i = 0; i < tolaunch.length; i++) {\n1225:     await launchSingleHeadless(\n1226:       projectRoot,\n1227:       state,\n1228:       tolaunch[i],\n1229:       featureMap.get(tolaunch[i].feature_id)!,\n1230:       monitor,\n1231:       config,\n1232:       model,\n1233:       agentResolutions,\n1234:       questContext,\n1235:       hitlMode\n1236:     );\n1237:     // Brief delay between spawns so each agent's DB migration settles\n1238:     if (i < tolaunch.length - 1) {\n1239:       await new Promise((r) => setTimeout(r, LAUNCH_STAGGER_MS));\n1240:     }\n1241:   }\n1242: \n1243:   const launched = state.agents.filter((a) => a.status === \"running\").length;\n1244: \n1245:   // Start the TUI dashboard (or skip if --no-tui)\n1246:   if (opts.noTui) {\n1247:     if (fmt === \"text\") {\n1248:       console.log(`${launched} agent(s) running. (--no-tui mode, dashboard prints every 15s)\\n`);\n1249:       printDashboard(state);\n1250:     }\n1251:   } else {\n1252:     if (fmt === \"text\") console.log(`${launched} agent(s) running. Launching TUI...\\n`);\n1253:     startTUI();\n1254:   }\n1255: \n1256:   // Background monitoring loop — checks for dead processes and launches queued\n1257:   const POLL_INTERVAL = 5000;\n1258:   let dashboardCounter = 0;\n1259:   while (!isWaveComplete(state) && !detached) {\n1260:     await new Promise((r) => setTimeout(r, POLL_INTERVAL));\n1261: \n1262:     // Check for completed processes that weren't caught by event handlers\n1263:     for (const agent of state.agents) {\n1264:       if (\n1265:         (agent.status === \"running\" || agent.status === \"resolving_conflict\") &&\n1266:         agent.pid &&\n1267:         !isProcessRunning(agent.pid) &&\n1268:         !monitor.isRunning(agent.feature_id)\n1269:       ) {\n1270:         if (agent.status === \"resolving_conflict\") {\n1271:           // Conflict resolver died — the await in handleBuildVerification\n1272:           // will resolve via the 'exit' event, so nothing to do here\n1273:           continue;\n1274:         }\n1275:         // Process exited but we didn't get a callback\n1276:         // Check if the agent actually made any commits\n1277:         if (!branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n1278:           // Agent died without producing any code — mark as failed, not completed\n1279:           updateAgent(state, agent.feature_id, {\n1280:             status: \"failed\",\n1281:             error: \"Agent process exited without making any commits\",\n1282:             activity: null,\n1283:             completed_at: new Date().toISOString(),\n1284:           });\n1285:           saveState(projectRoot, state);\n1286:           wtLog(agent.feature_id, \"process died with no code changes — marked failed\");\n1287: \n1288:           // Cascade failure to downstream agents\n1289:           const cancelled = cancelDownstream(state, agent.feature_id);\n1290:           if (cancelled.length > 0) {\n1291:             wtLog(agent.feature_id, `downstream cancelled: ${cancelled.join(\", \")}`);\n1292:             saveState(projectRoot, state);\n1293:           }\n1294:         } else {\n1295:           updateAgent(state, agent.feature_id, {\n1296:             status: \"completed\",\n1297:             completed_at: new Date().toISOString(),\n1298:             activity: \"done\",\n1299:           });\n1300:           saveState(projectRoot, state);\n1301:           try {\n1302:             await handleBuildVerification(projectRoot, state, agent, featureMap.get(agent.feature_id)!, config, model, monitor, undefined, hitlMode);\n1303:           } catch (err: any) {\n1304:             wtLog(agent.feature_id, `POLL VERIFY ERROR: ${err.message}`);\n1305:           }\n1306:         }\n1307:         await launchAllReady(projectRoot, state, featureMap, monitor, config, model, agentResolutions, questContext, hitlMode);\n1308:       }\n1309:     }\n1310: \n1311:     // Safety net: detect agents stuck in \"retry\" with no running process.\n1312:     // This catches edge cases where handleRetry() wasn't called or failed\n1313:     // to reset the agent (e.g. race between onError callback and poll loop).\n1314:     for (const agent of state.agents) {\n1315:       if (\n1316:         agent.status === \"retry\" &&\n1317:         (!agent.pid || !isProcessRunning(agent.pid)) &&\n1318:         !monitor.isRunning(agent.feature_id)\n1319:       ) {\n1320:         if (agent.retries >= agent.max_retries) {\n1321:           // Out of retries — mark as failed and cascade\n1322:           wtLog(agent.feature_id, `stuck in retry with no process and retries exhausted (${agent.retries}/${agent.max_retries}) — marking failed`);\n1323:           updateAgent(state, agent.feature_id, {\n1324:             status: \"failed\",\n1325:             error: agent.error ?? \"Agent stuck in retry state with no running process\",\n1326:             activity: null,\n1327:             completed_at: new Date().toISOString(),\n1328:           });\n1329:           saveState(projectRoot, state);\n1330:           const cancelled = cancelDownstream(state, agent.feature_id);\n1331:           if (cancelled.length > 0) {\n1332:             wtLog(agent.feature_id, `downstream cancelled: ${cancelled.join(\", \")}`);\n1333:             saveState(projectRoot, state);\n1334:           }\n1335:         } else {\n1336:           // Has retries left — reset to queued for a fresh launch\n1337:           wtLog(agent.feature_id, `stuck in retry with no process — resetting to queued (retry ${agent.retries}/${agent.max_retries})`);\n1338:           updateAgent(state, agent.feature_id, {\n1339:             status: \"queued\",\n1340:             error: null,\n1341:             activity: \"waiting for relaunch...\",\n1342:           });\n1343:           saveState(projectRoot, state);\n1344:         }\n1345:       }\n1346:     }\n1347: \n1348:     // After recovering stuck agents, try launching any that are now ready\n1349:     await launchAllReady(projectRoot, state, featureMap, monitor, config, model, agentResolutions, questContext, hitlMode);\n1350: \n1351:     // Persist state periodically\n1352:     saveState(projectRoot, state);\n1353: \n1354:     // Poll for HITL questions from agents and forward to TUI\n1355:     if (hitlMode && hitlMode !== \"yolo\") {\n1356:       try {\n1357:         const pendingQuestions = getPendingQuestions(projectRoot);\n1358:         if (tuiRef.current && pendingQuestions.length > 0) {\n1359:           tuiRef.current.setPendingQuestions(pendingQuestions);\n1360:         }\n1361:       } catch {\n1362:         // Non-fatal — HITL dir may not exist yet\n1363:       }\n1364:     }\n1365: \n1366:     // Update TUI state reference (or print dashboard in --no-tui mode)\n1367:     if (tuiRef.current) {\n1368:       tuiRef.current.updateState(state);\n1369:     } else if (opts.noTui && fmt === \"text\") {\n1370:       dashboardCounter++;\n1371:       if (dashboardCounter % 3 === 0) {\n1372:         printDashboard(state);\n1373: \n1374:         // Auto-push base branch if requested\n1375:         if (opts.autoPush) {\n1376:           const anyMerged = state.agents.some((a) => a.status === \"merged\");\n1377:           if (anyMerged) {\n1378:             await pushBaseBranch(projectRoot, state.base_branch, config);\n1379:           } else {\n1380:             console.log(\"No branches were merged — skipping push.\");\n1381:           }\n1382:         }\n1383:       }\n1384:     }\n1385:   }\n1386: \n1387:   // If user detached (pressed Q while agents are still running), save state\n1388:   // and return without doing post-wave cleanup. The caller (cmdTui) will\n1389:   // loop back to the task browser, showing the running wave indicator.\n1390:   if (detached) {\n1391:     flushState(projectRoot, state);\n1392:     return;\n1393:   }\n1394: \n1395:   // Wave complete — keep TUI open for post-mortem browsing\n1396:   if (tuiRef.current) {\n1397:     tuiRef.current.updateState(state);\n1398:     tuiRef.current.markWaveComplete();\n1399:     // Wait for the user to press q to exit the TUI\n1400:     await tuiRef.current.waitForQuit();\n1401:   }\n1402: \n1403:   // Print final dashboard after TUI is closed\n1404:   if (fmt === \"text\") printDashboard(state);\n1405: \n1406:   // Clean up HITL files\n1407:   try {\n1408:     cleanupHitl(projectRoot);\n1409:   } catch {\n1410:     // Non-fatal\n1411:   }\n1412: \n1413:   // Dump full logs for failed agents (post-mortem)\n1414:   dumpFailedAgentLogs(projectRoot, state, fmt);\n1415: \n1416:   // Auto-export wave history\n1417:   try {\n\n(Output capped at 50 KB. Showing lines 1-1417. Use offset=1418 to continue.)\n</content>","title":"src/commands/launch.ts","metadata":{"preview":"/**\n * launch.ts — Launch a wave of agents.\n *\n * Usage: woco launch [selection options] [launch options]\n *\n * This is the primary entry point for starting a new wave. It selects features\n * from the features file, creates a wave state, sets up worktrees, and launches\n * agent processes (either headless or interactive via dmux/tmux).\n *\n * IMPORTANT: This file also exports shared helper functions that are reused\n * by resume.ts and other commands:\n *   - launchSingleHeadless\n *   - handleBuildVerification\n *   - handleRetry\n *   - launchNextQueued\n */\n\nimport { execSync } from \"node:child_process\";\nimport { existsSync, readFileSync } from \"node:fs\";\nimport { resolve } from \"node:path\";","truncated":true,"loaded":[]},"time":{"start":1773484322945,"end":1773484322948}}}}
