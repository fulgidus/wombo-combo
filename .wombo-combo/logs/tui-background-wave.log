{"type":"tool_use","timestamp":1773483640446,"sessionID":"ses_31423da25ffebo9V1CTFH0IpgT","part":{"id":"prt_cebdcc43e001Fm4ie60t7piaju","sessionID":"ses_31423da25ffebo9V1CTFH0IpgT","messageID":"msg_cebdcac9a0016dbKjDb14RpuP6","type":"tool","callID":"toolu_vrtx_01E6BSFsewunHEHGwN3j5XYz","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/wave-detach-audit/src/commands/tui.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/wave-detach-audit/src/commands/tui.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tui.ts -- Unified TUI command entry point for wombo-combo.\n3:  *\n4:  * Orchestrates multiple views in a persistent loop:\n5:  *   1. Quest Picker (tui-quest-picker.ts) -- select a quest or \"All Tasks\"\n6:  *   2. Task Browser (tui-browser.ts) -- select tasks, change priorities, launch\n7:  *   3. Wave Monitor (tui.ts) -- watch running wave, view logs, retry agents\n8:  *   4. Plan Review (tui-plan-review.ts) -- review/edit/approve planner output\n9:  *   5. Genesis Review (tui-genesis-review.ts) -- review/edit/approve genesis plan\n10:  *\n11:  * Flow:\n12:  *   `woco` -> Quest Picker (if quests exist) -> Task Browser -> L -> launches\n13:  *   wave -> wave completes -> Q in monitor -> back to Quest Picker -> ...\n14:  *\n15:  *   Quest Picker -> P (plan) -> spinner -> Plan Review -> approve/cancel ->\n16:  *   back to Quest Picker\n17:  *\n18:  *   Quest Picker -> G (genesis) -> vision prompt -> spinner -> Genesis Review\n19:  *   -> approve/cancel -> back to Quest Picker\n20:  *\n21:  *   Quest Picker/Browser -> E (errand) -> description prompt -> spinner ->\n22:  *   Plan Review -> approve/cancel -> creates quest-less tasks -> back\n23:  *\n24:  * If no quests exist, the Quest Picker is skipped entirely and the flow goes\n25:  * straight to the Task Browser (backward compatible).\n26:  *\n27:  * Exit behavior:\n28:  *   - Q from Quest Picker: exits the process\n29:  *   - Q/Esc from Task Browser: back to Quest Picker (or exits if no quests)\n30:  *   - Q from Wave Monitor: back to Quest Picker\n31:  *   - Q/Esc from Plan Review: discard plan, back to Quest Picker\n32:  *\n33:  * Session state is persisted to .wombo-combo/tui-session.json so the user can\n34:  * close and reopen the TUI without losing their task selections.\n35:  */\n36: \n37: import type { WomboConfig } from \"../config.js\";\n38: import { ensureTasksFile } from \"../lib/tasks.js\";\n39: import { loadState } from \"../lib/state.js\";\n40: import { loadTUISession, saveTUISession } from \"../lib/tui-session.js\";\n41: import type { TUISession } from \"../lib/tui-session.js\";\n42: import { TaskBrowser } from \"../lib/tui-browser.js\";\n43: import { QuestPicker } from \"../lib/tui-quest-picker.js\";\n44: import type { QuestPickerAction } from \"../lib/tui-quest-picker.js\";\n45: import { PlanReview } from \"../lib/tui-plan-review.js\";\n46: import type { ProposedTask } from \"../lib/quest-planner.js\";\n47: import { runQuestPlanner, applyPlanToQuest } from \"../lib/quest-planner.js\";\n48: import type { PlanResult } from \"../lib/quest-planner.js\";\n49: import { loadAllQuests, loadQuest, saveQuest, listQuestIds, saveQuestKnowledge } from \"../lib/quest-store.js\";\n50: import { GenesisReview } from \"../lib/tui-genesis-review.js\";\n51: import type { GenesisReviewAction } from \"../lib/tui-genesis-review.js\";\n52: import { runGenesisPlanner } from \"../lib/genesis-planner.js\";\n53: import type { GenesisResult, ProposedQuest } from \"../lib/genesis-planner.js\";\n54: import { createBlankQuest } from \"../lib/quest.js\";\n55: import { runErrandPlanner, applyErrandPlan } from \"../lib/errand-planner.js\";\n56: import { WishlistPicker } from \"../lib/tui-wishlist.js\";\n57: import type { WishlistAction } from \"../lib/tui-wishlist.js\";\n58: import { deleteItem as deleteWishlistItem } from \"../lib/wishlist-store.js\";\n59: import type { WishlistItem } from \"../lib/wishlist-store.js\";\n60: import { cmdLaunch } from \"./launch.js\";\n61: import type { LaunchCommandOptions } from \"./launch.js\";\n62: import { cmdResume } from \"./resume.js\";\n63: \n64: // ---------------------------------------------------------------------------\n65: // Types\n66: // ---------------------------------------------------------------------------\n67: \n68: export interface TUICommandOptions {\n69:   projectRoot: string;\n70:   config: WomboConfig;\n71:   /** Max concurrent agents (override, or null to use session/config default) */\n72:   maxConcurrent?: number;\n73:   /** Model override */\n74:   model?: string;\n75:   /** Base branch override */\n76:   baseBranch?: string;\n77:   /** Max retries override */\n78:   maxRetries?: number;\n79:   /** Auto-push after merge */\n80:   autoPush?: boolean;\n81:   /** Skip TDD tests */\n82:   skipTests?: boolean;\n83:   /** Strict TDD mode */\n84:   strictTdd?: boolean;\n85:   /** Agent definition override */\n86:   agent?: string;\n87: }\n88: \n89: type BrowserAction =\n90:   | { type: \"launch\"; ids: string[] }\n91:   | { type: \"errand\" }\n92:   | { type: \"back\" }\n93:   | { type: \"quit\" };\n94: \n95: type PlanReviewResult =\n96:   | { type: \"approve\"; tasks: ProposedTask[]; knowledge: string | null }\n97:   | { type: \"cancel\" };\n98: \n99: // ---------------------------------------------------------------------------\n100: // Command -- Main Loop\n101: // ---------------------------------------------------------------------------\n102: \n103: export async function cmdTui(opts: TUICommandOptions): Promise<void> {\n104:   const { projectRoot, config } = opts;\n105: \n106:   // Ensure tasks file exists\n107:   await ensureTasksFile(projectRoot, config);\n108: \n109:   // Load session state (persisted selections, sort, concurrency)\n110:   const session = loadTUISession(projectRoot);\n111: \n112:   // Apply concurrency override from CLI if provided\n113:   if (opts.maxConcurrent !== undefined) {\n114:     session.maxConcurrent = opts.maxConcurrent;\n115:   }\n116: \n117:   // Main TUI loop:\n118:   //   Quest Picker -> Task Browser -> Launch -> Monitor -> back to Quest Picker\n119:   // Only exits when the user presses Q from the Quest Picker (or browser if no quests).\n120:   while (true) {\n121:     // Check for an active wave on each iteration\n122:     const existingState = loadState(projectRoot);\n123:     const hasRunningWave =\n124:       existingState !== null &&\n125:       existingState.agents.some(\n126:         (a) =>\n127:           a.status === \"running\" ||\n128:           a.status === \"queued\" ||\n129:           a.status === \"installing\" ||\n130:           a.status === \"resolving_conflict\" ||\n131:           a.status === \"retry\"\n132:       );\n133: \n134:     if (hasRunningWave) {\n135:       // A wave is already running -- resume it (wave monitor TUI).\n136:       // When the wave completes and the user presses Q, cmdResume returns\n137:       // and we loop back to the quest picker / browser.\n138:       console.log(\n139:         `Active wave detected: ${existingState!.wave_id}. Resuming...`\n140:       );\n141:       try {\n142:         await cmdResume({\n143:           projectRoot,\n144:           config,\n145:           maxConcurrent: opts.maxConcurrent,\n146:           model: opts.model,\n147:           interactive: false,\n148:           noTui: false,\n149:           autoPush: opts.autoPush ?? false,\n150:           baseBranch: opts.baseBranch,\n151:           maxRetries: opts.maxRetries,\n152:         });\n153:       } catch (err: any) {\n154:         // Don't crash -- show error and loop back\n155:         console.error(`\\nResume error: ${err.message}\\n`);\n156:         await sleep(2000);\n157:       }\n158:       // Clear terminal before showing picker/browser again\n159:       process.stdout.write(\"\\x1B[2J\\x1B[H\");\n160:       continue;\n161:     }\n162: \n163:     // -----------------------------------------------------------------------\n164:     // Quest Picker (skip if no quests exist)\n165:     // -----------------------------------------------------------------------\n166:     const quests = loadAllQuests(projectRoot);\n167:     const hasQuests = quests.length > 0;\n168: \n169:     let selectedQuestId: string | null = null;\n170: \n171:     if (hasQuests) {\n172:       const questAction = await showQuestPicker(projectRoot, config, opts);\n173: \n174:       if (questAction.type === \"quit\") {\n175:         // User pressed Q in quest picker -- exit cleanly\n176:         session.lastView = \"browser\";\n177:         saveTUISession(projectRoot, session);\n178:         break;\n179:       }\n180: \n181:       if (questAction.type === \"plan\") {\n182:         // User pressed P to plan a quest -- run planner + review\n183:         await handlePlanFlow(projectRoot, config, opts, questAction.questId);\n184:         // After planning (approve or cancel), loop back to quest picker\n185:         process.stdout.write(\"\\x1B[2J\\x1B[H\");\n186:         continue;\n187:       }\n188: \n189:       if (questAction.type === \"genesis\") {\n190:         // User pressed G to run genesis -- run genesis planner + review\n191:         await handleGenesisFlow(projectRoot, config, opts);\n192:         // After genesis (approve or cancel), loop back to quest picker\n193:         process.stdout.write(\"\\x1B[2J\\x1B[H\");\n194:         continue;\n195:       }\n196: \n197:       if (questAction.type === \"errand\") {\n198:         // User pressed E to create an errand (quest-less assisted task)\n199:         await handleErrandFlow(projectRoot, config, opts);\n200:         // After errand (approve or cancel), loop back to quest picker\n201:         process.stdout.write(\"\\x1B[2J\\x1B[H\");\n202:         continue;\n203:       }\n204: \n205:       if (questAction.type === \"wishlist\") {\n206:         // User pressed W to browse wishlist\n207:         await handleWishlistFlow(projectRoot, config, opts);\n208:         // After wishlist (promote, back, or quit), loop back to quest picker\n209:         process.stdout.write(\"\\x1B[2J\\x1B[H\");\n210:         continue;\n211:       }\n212: \n213:       selectedQuestId = questAction.questId;\n214:     }\n215: \n216:     // -----------------------------------------------------------------------\n217:     // Task Browser (filtered by quest if one was selected)\n218:     // -----------------------------------------------------------------------\n219:     const action = await showBrowser(\n220:       projectRoot,\n221:       config,\n222:       session,\n223:       opts,\n224:       selectedQuestId,\n225:       hasQuests\n226:     );\n227: \n228:     if (action.type === \"quit\") {\n229:       // User pressed Q in browser with no quest context -- exit cleanly\n230:       session.lastView = \"browser\";\n231:       saveTUISession(projectRoot, session);\n232:       break;\n233:     }\n234: \n235:     if (action.type === \"back\") {\n236:       // User pressed Q/Esc in quest-filtered browser -- back to quest picker\n237:       process.stdout.write(\"\\x1B[2J\\x1B[H\");\n238:       continue;\n239:     }\n240: \n241:     if (action.type === \"errand\") {\n242:       // User pressed E in browser to create an errand\n243:       await handleErrandFlow(projectRoot, config, opts);\n244:       process.stdout.write(\"\\x1B[2J\\x1B[H\");\n245:       continue;\n246:     }\n247: \n248:     if (action.type === \"launch\") {\n249:       // Save session before launching\n250:       session.selected = action.ids;\n251:       session.lastView = \"monitor\";\n252:       saveTUISession(projectRoot, session);\n253: \n254:       // Build launch options\n255:       const launchOpts: LaunchCommandOptions = {\n256:         projectRoot,\n257:         config,\n258:         features: action.ids,\n259:         maxConcurrent: session.maxConcurrent,\n260:         model: opts.model,\n261:         interactive: false,\n262:         dryRun: false,\n263:         baseBranch: opts.baseBranch ?? config.baseBranch,\n264:         maxRetries: opts.maxRetries ?? config.defaults.maxRetries,\n265:         noTui: false,\n266:         autoPush: opts.autoPush ?? false,\n267:         agent: opts.agent,\n268:         outputFmt: \"text\",\n269:         // Pass quest ID so launch uses quest branch and constraints\n270:         questId: selectedQuestId ?? undefined,\n271:       };\n272: \n273:       try {\n274:         await cmdLaunch(launchOpts);\n275:       } catch (err: any) {\n276:         // Don't crash -- show error and loop back\n277:         console.error(`\\nLaunch error: ${err.message}\\n`);\n278:         await sleep(2000);\n279:       }\n280: \n281:       // Clear terminal before showing picker/browser again\n282:       process.stdout.write(\"\\x1B[2J\\x1B[H\");\n283:       continue;\n284:     }\n285:   }\n286: }\n287: \n288: // ---------------------------------------------------------------------------\n289: // Quest Picker View -- Promise-based\n290: // ---------------------------------------------------------------------------\n291: \n292: /**\n293:  * Show the Quest Picker and return a Promise that resolves when the user\n294:  * takes an action (select quest, plan quest, or quit).\n295:  */\n296: function showQuestPicker(\n297:   projectRoot: string,\n298:   config: WomboConfig,\n299:   opts: TUICommandOptions\n300: ): Promise<QuestPickerAction> {\n301:   return new Promise<QuestPickerAction>((resolve) => {\n302:     const picker = new QuestPicker({\n303:       projectRoot,\n304:       config,\n305: \n306:       onSelect: (questId: string | null) => {\n307:         resolve({ type: \"select\", questId });\n308:       },\n309: \n310:       onPlan: (questId: string) => {\n311:         resolve({ type: \"plan\", questId });\n312:       },\n313: \n314:       onGenesis: () => {\n315:         resolve({ type: \"genesis\" });\n316:       },\n317: \n318:       onErrand: () => {\n319:         resolve({ type: \"errand\" });\n320:       },\n321: \n322:       onWishlist: () => {\n323:         resolve({ type: \"wishlist\" });\n324:       },\n325: \n326:       onQuit: () => {\n327:         resolve({ type: \"quit\" });\n328:       },\n329:     });\n330: \n331:     picker.start();\n332:   });\n333: }\n334: \n335: // ---------------------------------------------------------------------------\n336: // Plan Flow -- Planner + Review\n337: // ---------------------------------------------------------------------------\n338: \n339: /**\n340:  * Run the quest planner agent, then show the plan review TUI.\n341:  * Handles the full flow: spinner → planner → review → approve/cancel.\n342:  */\n343: async function handlePlanFlow(\n344:   projectRoot: string,\n345:   config: WomboConfig,\n346:   opts: TUICommandOptions,\n347:   questId: string\n348: ): Promise<void> {\n349:   const quest = loadQuest(projectRoot, questId);\n350:   if (!quest) {\n351:     console.error(`\\nQuest \"${questId}\" not found.\\n`);\n352:     await sleep(2000);\n353:     return;\n354:   }\n355: \n356:   // Set quest to planning status\n357:   const prevStatus = quest.status;\n358:   quest.status = \"planning\";\n359:   saveQuest(projectRoot, quest);\n360: \n361:   // Show a planning spinner on the terminal (no blessed screen here)\n362:   console.log(`\\n  Planning quest: ${quest.title} (${quest.id})`);\n363:   console.log(`  Running quest planner agent...\\n`);\n364: \n365:   const spinChars = [\"\\u2802\", \"\\u2806\", \"\\u2807\", \"\\u2803\", \"\\u2809\", \"\\u280C\", \"\\u280E\", \"\\u280B\"];\n366:   let spinIdx = 0;\n367:   let lastProgress = \"\";\n368:   const spinTimer = setInterval(() => {\n369:     const ch = spinChars[spinIdx % spinChars.length];\n370:     spinIdx++;\n371:     process.stdout.write(`\\r  ${ch} ${lastProgress}`);\n372:   }, 120);\n373: \n374:   let planResult: PlanResult;\n375: \n376:   try {\n377:     planResult = await runQuestPlanner(quest, projectRoot, config, {\n378:       model: opts.model,\n379:       onProgress: (msg) => {\n380:         lastProgress = msg;\n381:       },\n382:     });\n383:   } catch (err: any) {\n384:     clearInterval(spinTimer);\n385:     process.stdout.write(\"\\r\" + \" \".repeat(80) + \"\\r\");\n386:     console.error(`\\n  Planner error: ${err.message}\\n`);\n387:     // Revert quest status\n388:     quest.status = prevStatus;\n389:     saveQuest(projectRoot, quest);\n390:     await sleep(3000);\n391:     return;\n392:   }\n393: \n394:   clearInterval(spinTimer);\n395:   process.stdout.write(\"\\r\" + \" \".repeat(80) + \"\\r\");\n396: \n397:   if (!planResult.success && planResult.tasks.length === 0) {\n398:     // Total failure — no tasks produced\n399:     console.error(`\\n  Planner failed: ${planResult.error ?? \"No tasks produced\"}\\n`);\n400:     quest.status = prevStatus;\n401:     saveQuest(projectRoot, quest);\n402:     await sleep(3000);\n403:     return;\n404:   }\n405: \n406:   console.log(`  Planner produced ${planResult.tasks.length} tasks.`);\n407:   if (planResult.issues.length > 0) {\n408:     const errors = planResult.issues.filter((i) => i.level === \"error\").length;\n409:     const warnings = planResult.issues.filter((i) => i.level === \"warning\").length;\n410:     if (errors > 0) console.log(`  ${errors} validation error(s).`);\n411:     if (warnings > 0) console.log(`  ${warnings} validation warning(s).`);\n412:   }\n413:   console.log(`  Opening plan review...\\n`);\n414:   await sleep(1000);\n415: \n416:   // Clear terminal before showing the plan review TUI\n417:   process.stdout.write(\"\\x1B[2J\\x1B[H\");\n418: \n419:   // Show the plan review TUI\n420:   const reviewAction = await showPlanReview(\n421:     questId,\n422:     quest.title,\n423:     planResult\n424:   );\n425: \n426:   if (reviewAction.type === \"cancel\") {\n427:     // User cancelled — revert quest status\n428:     quest.status = prevStatus;\n429:     saveQuest(projectRoot, quest);\n430:     console.log(`\\n  Plan discarded. Quest \"${questId}\" reverted to \"${prevStatus}\".\\n`);\n431:     await sleep(1500);\n432:     return;\n433:   }\n434: \n435:   // User approved — apply the plan\n436:   try {\n437:     // Update planResult with only the accepted tasks\n438:     const approvedResult: PlanResult = {\n439:       ...planResult,\n440:       tasks: reviewAction.tasks,\n441:       knowledge: reviewAction.knowledge,\n442:     };\n443: \n444:     const tasks = applyPlanToQuest(approvedResult, quest, projectRoot, config);\n445:     console.log(`\\n  Plan approved! Created ${tasks.length} tasks.`);\n446:     console.log(`  Quest \"${questId}\" is now active.`);\n447:     if (reviewAction.knowledge) {\n448:       console.log(`  Saved knowledge file (${reviewAction.knowledge.length} chars).`);\n449:     }\n450:     console.log();\n451:     await sleep(2000);\n452:   } catch (err: any) {\n453:     console.error(`\\n  Failed to apply plan: ${err.message}\\n`);\n454:     quest.status = prevStatus;\n455:     saveQuest(projectRoot, quest);\n456:     await sleep(3000);\n457:   }\n458: }\n459: \n460: // ---------------------------------------------------------------------------\n461: // Genesis Flow -- Vision Prompt + Planner + Review\n462: // ---------------------------------------------------------------------------\n463: \n464: /**\n465:  * Run the genesis planner: prompt user for a vision, run the genesis planner\n466:  * agent, then show the genesis review TUI.\n467:  * Handles the full flow: readline prompt → spinner → planner → review → create quests.\n468:  */\n469: async function handleGenesisFlow(\n470:   projectRoot: string,\n471:   config: WomboConfig,\n472:   opts: TUICommandOptions,\n473:   prefill?: string\n474: ): Promise<void> {\n475:   let vision: string;\n476: \n477:   if (prefill) {\n478:     // Pre-filled from wishlist promotion — show the pre-filled text\n479:     console.log();\n480:     console.log(\"  ╔══════════════════════════════════════╗\");\n481:     console.log(\"  ║         GENESIS PLANNER              ║\");\n482:     console.log(\"  ╚══════════════════════════════════════╝\");\n483:     console.log();\n484:     console.log(`  Pre-filled from wishlist: ${prefill}`);\n485:     console.log();\n486:     vision = prefill;\n487:   } else {\n488:     // Prompt the user for a project vision via readline (no blessed screen is active)\n489:     const readline = await import(\"node:readline\");\n490:     const rl = readline.createInterface({\n491:       input: process.stdin,\n492:       output: process.stdout,\n493:     });\n494: \n495:     vision = await new Promise<string>((resolve) => {\n496:       console.log();\n497:       console.log(\"  ╔══════════════════════════════════════╗\");\n498:       console.log(\"  ║         GENESIS PLANNER              ║\");\n499:       console.log(\"  ╚══════════════════════════════════════╝\");\n500:       console.log();\n501:       console.log(\"  Describe your project vision. The genesis planner will\");\n502:       console.log(\"  decompose it into a set of quests.\");\n503:       console.log();\n504:       rl.question(\"  Vision: \", (answer) => {\n505:         rl.close();\n506:         resolve(answer.trim());\n507:       });\n508:     });\n509:   }\n510: \n511:   if (!vision) {\n512:     console.log(\"\\n  No vision provided. Returning to quest picker.\\n\");\n513:     await sleep(1500);\n514:     return;\n515:   }\n516: \n517:   // Gather existing quest IDs so the planner can avoid duplicates\n518:   const existingQuestIds = listQuestIds(projectRoot);\n519: \n520:   // Show a planning spinner on the terminal\n521:   console.log();\n522:   console.log(`  Running genesis planner agent...`);\n523:   console.log();\n524: \n525:   const spinChars = [\"\\u2802\", \"\\u2806\", \"\\u2807\", \"\\u2803\", \"\\u2809\", \"\\u280C\", \"\\u280E\", \"\\u280B\"];\n526:   let spinIdx = 0;\n527:   let lastProgress = \"\";\n528:   const spinTimer = setInterval(() => {\n529:     const ch = spinChars[spinIdx % spinChars.length];\n530:     spinIdx++;\n531:     process.stdout.write(`\\r  ${ch} ${lastProgress}`);\n532:   }, 120);\n533: \n534:   let genesisResult: GenesisResult;\n535: \n536:   try {\n537:     genesisResult = await runGenesisPlanner(vision, projectRoot, config, {\n538:       existingQuestIds,\n539:       model: opts.model,\n540:       onProgress: (msg) => {\n541:         lastProgress = msg;\n542:       },\n543:     });\n544:   } catch (err: any) {\n545:     clearInterval(spinTimer);\n546:     process.stdout.write(\"\\r\" + \" \".repeat(80) + \"\\r\");\n547:     console.error(`\\n  Genesis planner error: ${err.message}\\n`);\n548:     await sleep(3000);\n549:     return;\n550:   }\n551: \n552:   clearInterval(spinTimer);\n553:   process.stdout.write(\"\\r\" + \" \".repeat(80) + \"\\r\");\n554: \n555:   if (!genesisResult.success && genesisResult.quests.length === 0) {\n556:     // Total failure — no quests produced\n557:     console.error(`\\n  Genesis planner failed: ${genesisResult.error ?? \"No quests produced\"}\\n`);\n558:     await sleep(3000);\n559:     return;\n560:   }\n561: \n562:   console.log(`  Genesis planner produced ${genesisResult.quests.length} quests.`);\n563:   if (genesisResult.issues.length > 0) {\n564:     const errors = genesisResult.issues.filter((i) => i.level === \"error\").length;\n565:     const warnings = genesisResult.issues.filter((i) => i.level === \"warning\").length;\n566:     if (errors > 0) console.log(`  ${errors} validation error(s).`);\n567:     if (warnings > 0) console.log(`  ${warnings} validation warning(s).`);\n568:   }\n569:   console.log(`  Opening genesis review...\\n`);\n570:   await sleep(1000);\n571: \n572:   // Clear terminal before showing the genesis review TUI\n573:   process.stdout.write(\"\\x1B[2J\\x1B[H\");\n574: \n575:   // Show the genesis review TUI\n576:   const reviewAction = await showGenesisReview(genesisResult);\n577: \n578:   if (reviewAction.type === \"cancel\") {\n579:     console.log(`\\n  Genesis plan discarded.\\n`);\n580:     await sleep(1500);\n581:     return;\n582:   }\n583: \n584:   // User approved — create quests from accepted proposals\n585:   const baseBranch = opts.baseBranch ?? config.baseBranch;\n586:   const created: string[] = [];\n587: \n588:   for (const proposed of reviewAction.quests) {\n589:     const quest = createBlankQuest(proposed.id, proposed.title, proposed.goal, baseBranch, {\n590:       priority: proposed.priority,\n591:       difficulty: proposed.difficulty,\n592:       hitlMode: proposed.hitl_mode,\n593:     });\n594: \n595:     // Apply constraints from the genesis planner\n596:     quest.constraints.add = proposed.constraints.add ?? [];\n597:     quest.constraints.ban = proposed.constraints.ban ?? [];\n598:     quest.depends_on = proposed.depends_on ?? [];\n599:     quest.notes = proposed.notes ?? [];\n600: \n601:     saveQuest(projectRoot, quest);\n602:     created.push(quest.id);\n603:   }\n604: \n605:   console.log(`\\n  Genesis plan approved! Created ${created.length} quests:`);\n606:   for (const id of created) {\n607:     console.log(`    - ${id}`);\n608:   }\n609: \n610:   // Save knowledge if the planner produced any (attach to the first quest)\n611:   const knowledge = reviewAction.knowledge;\n612:   if (knowledge && created.length > 0) {\n613:     saveQuestKnowledge(projectRoot, created[0], knowledge);\n614:     console.log(`  Saved knowledge file (${knowledge.length} chars) to quest \"${created[0]}\".`);\n615:   }\n616: \n617:   console.log();\n618:   await sleep(2000);\n619: }\n620: \n621: // ---------------------------------------------------------------------------\n622: // Errand Flow -- Quick Task Generation (quest-less)\n623: // ---------------------------------------------------------------------------\n624: \n625: /**\n626:  * Run the errand planner: prompt user for a brief description, run the quest\n627:  * planner agent with an errand-specific prompt, then show plan review to let\n628:  * the user accept/reject/edit the proposed tasks.\n629:  *\n630:  * Created tasks go directly into the task store without any quest association.\n631:  */\n632: async function handleErrandFlow(\n633:   projectRoot: string,\n634:   config: WomboConfig,\n635:   opts: TUICommandOptions,\n636:   prefill?: string\n637: ): Promise<void> {\n638:   let description: string;\n639: \n640:   if (prefill) {\n641:     // Pre-filled from wishlist promotion — show the pre-filled text\n642:     console.log();\n643:     console.log(\"  ╔══════════════════════════════════════╗\");\n644:     console.log(\"  ║           ERRAND PLANNER             ║\");\n645:     console.log(\"  ╚══════════════════════════════════════╝\");\n646:     console.log();\n647:     console.log(`  Pre-filled from wishlist: ${prefill}`);\n648:     console.log();\n649:     description = prefill;\n650:   } else {\n651:     // Prompt the user for a description via readline (no blessed screen is active)\n652:     const readline = await import(\"node:readline\");\n653:     const rl = readline.createInterface({\n654:       input: process.stdin,\n655:       output: process.stdout,\n656:     });\n657: \n658:     description = await new Promise<string>((resolve) => {\n659:       console.log();\n660:       console.log(\"  ╔══════════════════════════════════════╗\");\n661:       console.log(\"  ║           ERRAND PLANNER             ║\");\n662:       console.log(\"  ╚══════════════════════════════════════╝\");\n663:       console.log();\n664:       console.log(\"  Describe the errand. The planner will explore the\");\n665:       console.log(\"  codebase and generate tasks for you.\");\n666:       console.log();\n667:       rl.question(\"  Errand: \", (answer) => {\n668:         rl.close();\n669:         resolve(answer.trim());\n670:       });\n671:     });\n672:   }\n673: \n674:   if (!description) {\n675:     console.log(\"\\n  No description provided. Returning.\\n\");\n676:     await sleep(1500);\n677:     return;\n678:   }\n679: \n680:   // Show a planning spinner on the terminal\n681:   console.log();\n682:   console.log(`  Running errand planner...`);\n683:   console.log();\n684: \n685:   const spinChars = [\"\\u2802\", \"\\u2806\", \"\\u2807\", \"\\u2803\", \"\\u2809\", \"\\u280C\", \"\\u280E\", \"\\u280B\"];\n686:   let spinIdx = 0;\n687:   let lastProgress = \"\";\n688:   const spinTimer = setInterval(() => {\n689:     const ch = spinChars[spinIdx % spinChars.length];\n690:     spinIdx++;\n691:     process.stdout.write(`\\r  ${ch} ${lastProgress}`);\n692:   }, 120);\n693: \n694:   let planResult: PlanResult;\n695: \n696:   try {\n697:     planResult = await runErrandPlanner(description, projectRoot, config, {\n698:       model: opts.model,\n699:       onProgress: (msg) => {\n700:         lastProgress = msg;\n701:       },\n702:     });\n703:   } catch (err: any) {\n704:     clearInterval(spinTimer);\n705:     process.stdout.write(\"\\r\" + \" \".repeat(80) + \"\\r\");\n706:     console.error(`\\n  Errand planner error: ${err.message}\\n`);\n707:     await sleep(3000);\n708:     return;\n709:   }\n710: \n711:   clearInterval(spinTimer);\n712:   process.stdout.write(\"\\r\" + \" \".repeat(80) + \"\\r\");\n713: \n714:   if (!planResult.success && planResult.tasks.length === 0) {\n715:     console.error(`\\n  Errand planner failed: ${planResult.error ?? \"No tasks produced\"}\\n`);\n716:     await sleep(3000);\n717:     return;\n718:   }\n719: \n720:   console.log(`  Errand planner produced ${planResult.tasks.length} task(s).`);\n721:   if (planResult.issues.length > 0) {\n722:     const errors = planResult.issues.filter((i) => i.level === \"error\").length;\n723:     const warnings = planResult.issues.filter((i) => i.level === \"warning\").length;\n724:     if (errors > 0) console.log(`  ${errors} validation error(s).`);\n725:     if (warnings > 0) console.log(`  ${warnings} validation warning(s).`);\n726:   }\n727:   console.log(`  Opening plan review...\\n`);\n728:   await sleep(1000);\n729: \n730:   // Clear terminal before showing the plan review TUI\n731:   process.stdout.write(\"\\x1B[2J\\x1B[H\");\n732: \n733:   // Reuse the plan review TUI (it works for any set of proposed tasks)\n734:   const reviewAction = await showPlanReview(\n735:     \"(errand)\",\n736:     description.length > 50 ? description.slice(0, 47) + \"...\" : description,\n737:     planResult\n738:   );\n739: \n740:   if (reviewAction.type === \"cancel\") {\n741:     console.log(`\\n  Errand plan discarded.\\n`);\n742:     await sleep(1500);\n743:     return;\n744:   }\n745: \n746:   // User approved -- create tasks directly (no quest)\n747:   try {\n748:     const approvedResult: PlanResult = {\n749:       ...planResult,\n750:       tasks: reviewAction.tasks,\n751:       knowledge: reviewAction.knowledge,\n752:     };\n753: \n754:     const tasks = applyErrandPlan(approvedResult, projectRoot, config);\n755:     console.log(`\\n  Errand approved! Created ${tasks.length} task(s):`);\n756:     for (const t of tasks) {\n757:       console.log(`    - ${t.id}: ${t.title}`);\n758:     }\n759:     console.log();\n760:     await sleep(2000);\n761:   } catch (err: any) {\n762:     console.error(`\\n  Failed to create errand tasks: ${err.message}\\n`);\n763:     await sleep(3000);\n764:   }\n765: }\n766: \n767: // ---------------------------------------------------------------------------\n768: // Wishlist Flow -- Browse + Promote to Errand/Genesis\n769: // ---------------------------------------------------------------------------\n770: \n771: /**\n772:  * Show the wishlist picker. When the user promotes an item, run the\n773:  * appropriate flow (errand or genesis) with the item text pre-filled.\n774:  * After promotion completes, offer to delete the wishlist item.\n775:  */\n776: async function handleWishlistFlow(\n777:   projectRoot: string,\n778:   config: WomboConfig,\n779:   opts: TUICommandOptions\n780: ): Promise<void> {\n781:   const action = await showWishlistPicker(projectRoot);\n782: \n783:   if (action.type === \"back\" || action.type === \"quit\") {\n784:     return;\n785:   }\n786: \n787:   if (action.type === \"promote-errand\") {\n788:     const item = action.item;\n789:     await handleErrandFlow(projectRoot, config, opts, item.text);\n790:     await maybeDeleteWishlistItem(projectRoot, item);\n791:     return;\n792:   }\n793: \n794:   if (action.type === \"promote-genesis\") {\n795:     const item = action.item;\n796:     await handleGenesisFlow(projectRoot, config, opts, item.text);\n797:     await maybeDeleteWishlistItem(projectRoot, item);\n798:     return;\n799:   }\n800: }\n801: \n802: /**\n803:  * Show the Wishlist Picker TUI and return a Promise that resolves when the\n804:  * user takes an action.\n805:  */\n806: function showWishlistPicker(projectRoot: string): Promise<WishlistAction> {\n807:   return new Promise<WishlistAction>((resolve) => {\n808:     const picker = new WishlistPicker({\n809:       projectRoot,\n810: \n811:       onPromoteErrand: (item) => {\n812:         resolve({ type: \"promote-errand\", item });\n813:       },\n814: \n815:       onPromoteGenesis: (item) => {\n816:         resolve({ type: \"promote-genesis\", item });\n817:       },\n818: \n819:       onBack: () => {\n820:         resolve({ type: \"back\" });\n821:       },\n822: \n823:       onQuit: () => {\n824:         resolve({ type: \"quit\" });\n825:       },\n826:     });\n827: \n828:     picker.start();\n829:   });\n830: }\n831: \n832: /**\n833:  * After a wishlist item has been promoted, ask the user whether to delete it.\n834:  * Uses a simple readline prompt (no blessed screen is active at this point).\n835:  */\n836: async function maybeDeleteWishlistItem(\n837:   projectRoot: string,\n838:   item: WishlistItem\n839: ): Promise<void> {\n840:   const readline = await import(\"node:readline\");\n841:   const rl = readline.createInterface({\n842:     input: process.stdin,\n843:     output: process.stdout,\n844:   });\n845: \n846:   const truncText =\n847:     item.text.length > 50 ? item.text.slice(0, 47) + \"...\" : item.text;\n848: \n849:   const answer = await new Promise<string>((resolve) => {\n850:     rl.question(\n851:       `\\n  Delete wishlist item \"${truncText}\"? [y/N] `,\n852:       (ans) => {\n853:         rl.close();\n854:         resolve(ans.trim().toLowerCase());\n855:       }\n856:     );\n857:   });\n858: \n859:   if (answer === \"y\" || answer === \"yes\") {\n860:     const deleted = deleteWishlistItem(projectRoot, item.id);\n861:     if (deleted) {\n862:       console.log(`  Wishlist item deleted.\\n`);\n863:     } else {\n864:       console.log(`  Item not found (may have been already deleted).\\n`);\n865:     }\n866:   } else {\n867:     console.log(`  Wishlist item kept.\\n`);\n868:   }\n869: \n870:   await sleep(1000);\n871: }\n872: \n873: // ---------------------------------------------------------------------------\n874: // Genesis Review View -- Promise-based\n875: // ---------------------------------------------------------------------------\n876: \n877: /**\n878:  * Show the Genesis Review TUI and return a Promise that resolves when the\n879:  * user approves or cancels.\n880:  */\n881: function showGenesisReview(\n882:   genesisResult: GenesisResult\n883: ): Promise<GenesisReviewAction> {\n884:   return new Promise<GenesisReviewAction>((resolve) => {\n885:     const review = new GenesisReview({\n886:       genesisResult,\n887: \n888:       onApprove: (quests, knowledge) => {\n889:         resolve({ type: \"approve\", quests, knowledge });\n890:       },\n891: \n892:       onCancel: () => {\n893:         resolve({ type: \"cancel\" });\n894:       },\n895:     });\n896: \n897:     review.start();\n898:   });\n899: }\n900: \n901: // ---------------------------------------------------------------------------\n902: // Plan Review View -- Promise-based\n903: // ---------------------------------------------------------------------------\n904: \n905: /**\n906:  * Show the Plan Review TUI and return a Promise that resolves when the user\n907:  * approves or cancels.\n908:  */\n909: function showPlanReview(\n910:   questId: string,\n911:   questTitle: string,\n912:   planResult: PlanResult\n913: ): Promise<PlanReviewResult> {\n914:   return new Promise<PlanReviewResult>((resolve) => {\n915:     const review = new PlanReview({\n916:       questId,\n917:       questTitle,\n918:       planResult,\n919: \n920:       onApprove: (tasks, knowledge) => {\n921:         resolve({ type: \"approve\", tasks, knowledge });\n922:       },\n923: \n924:       onCancel: () => {\n925:         resolve({ type: \"cancel\" });\n926:       },\n927:     });\n928: \n929:     review.start();\n930:   });\n931: }\n932: \n933: // ---------------------------------------------------------------------------\n934: // Browser View -- Promise-based\n935: // ---------------------------------------------------------------------------\n936: \n937: /**\n938:  * Show the Task Browser and return a Promise that resolves when the user\n939:  * takes an action (launch, back, or quit).\n940:  */\n941: function showBrowser(\n942:   projectRoot: string,\n943:   config: WomboConfig,\n944:   session: TUISession,\n945:   opts: TUICommandOptions,\n946:   questId: string | null,\n947:   hasQuestPicker: boolean\n948: ): Promise<BrowserAction> {\n949:   // Reload session from disk in case state changed after a wave\n950:   const freshSession = loadTUISession(projectRoot);\n951:   // Merge any runtime overrides\n952:   if (opts.maxConcurrent !== undefined) {\n953:     freshSession.maxConcurrent = opts.maxConcurrent;\n954:   }\n955:   // Copy fresh values back into the shared session object\n956:   Object.assign(session, freshSession);\n957: \n958:   // Load quest details for filtering if a quest was selected\n959:   let questTitle: string | undefined;\n960:   let questTaskIds: string[] | undefined;\n961:   if (questId) {\n962:     const quest = loadQuest(projectRoot, questId);\n963:     if (quest) {\n964:       questTitle = quest.title;\n965:       questTaskIds = quest.taskIds;\n966:     }\n967:   }\n968: \n969:   return new Promise<BrowserAction>((resolve) => {\n970:     const browser = new TaskBrowser({\n971:       projectRoot,\n972:       config,\n973:       session,\n974:       questId,\n975:       questTitle,\n976:       questTaskIds,\n977: \n978:       onLaunch: (selectedIds: string[]) => {\n979:         if (selectedIds.length === 0) return;\n980:         // The browser has already shown a transition message on-screen.\n981:         // Destroy the blessed screen and clear the terminal.\n982:         browser.destroy();\n983:         resolve({ type: \"launch\", ids: selectedIds });\n984:       },\n985: \n986:       onQuit: () => {\n987:         browser.stop();\n988:         resolve({ type: \"quit\" });\n989:       },\n990: \n991:       onBack: hasQuestPicker\n992:         ? () => {\n993:             resolve({ type: \"back\" });\n994:           }\n995:         : undefined,\n996: \n997:       // Errand is available when not in quest-filtered mode\n998:       onErrand: !questId\n999:         ? () => {\n1000:             resolve({ type: \"errand\" });\n1001:           }\n1002:         : undefined,\n1003: \n1004:       onSwitchToMonitor: undefined,\n1005:     });\n1006: \n1007:     browser.start();\n1008:   });\n1009: }\n1010: \n1011: // ---------------------------------------------------------------------------\n1012: // Helpers\n1013: // ---------------------------------------------------------------------------\n1014: \n1015: function sleep(ms: number): Promise<void> {\n1016:   return new Promise((r) => setTimeout(r, ms));\n1017: }\n\n(End of file - total 1017 lines)\n</content>","title":"src/commands/tui.ts","metadata":{"preview":"/**\n * tui.ts -- Unified TUI command entry point for wombo-combo.\n *\n * Orchestrates multiple views in a persistent loop:\n *   1. Quest Picker (tui-quest-picker.ts) -- select a quest or \"All Tasks\"\n *   2. Task Browser (tui-browser.ts) -- select tasks, change priorities, launch\n *   3. Wave Monitor (tui.ts) -- watch running wave, view logs, retry agents\n *   4. Plan Review (tui-plan-review.ts) -- review/edit/approve planner output\n *   5. Genesis Review (tui-genesis-review.ts) -- review/edit/approve genesis plan\n *\n * Flow:\n *   `woco` -> Quest Picker (if quests exist) -> Task Browser -> L -> launches\n *   wave -> wave completes -> Q in monitor -> back to Quest Picker -> ...\n *\n *   Quest Picker -> P (plan) -> spinner -> Plan Review -> approve/cancel ->\n *   back to Quest Picker\n *\n *   Quest Picker -> G (genesis) -> vision prompt -> spinner -> Genesis Review\n *   -> approve/cancel -> back to Quest Picker\n *","truncated":false,"loaded":[]},"time":{"start":1773483640440,"end":1773483640445}}}}
