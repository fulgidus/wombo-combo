e: WaveState,\n1426:   features: Feature[],\n1427:   opts: LaunchCommandOptions,\n1428:   agentResolutions?: Map<string, AgentResolution>,\n1429:   questContext?: QuestPromptContext,\n1430:   hitlMode?: string\n1431: ): Promise<void> {\n1432:   const { config, model } = opts;\n1433:   const fmt = opts.outputFmt ?? \"text\";\n1434:   const featureMap = new Map(features.map((f) => [f.id, f]));\n1435: \n1436:   // Show dashboard immediately\n1437:   if (fmt === \"text\") printDashboard(state);\n1438: \n1439:   // Launch initial batch — parallelize setup\n1440:   const tolaunch = queuedAgents(state).slice(0, opts.maxConcurrent);\n1441:   if (fmt === \"text\") console.log(`Setting up ${tolaunch.length} agent(s) in parallel...\\n`);\n1442: \n1443:   await Promise.all(\n1444:     tolaunch.map(async (agent) => {\n1445:       updateAgent(state, agent.feature_id, {\n1446:         status: \"installing\",\n1447:         started_at: new Date().toISOString(),\n1448:         activity: \"setting up worktree...\",\n1449:       });\n1450:       saveState(projectRoot, state);\n1451: \n1452:       try {\n1453:         if (worktreeReady(agent.worktree)) {\n1454:           wtLog(agent.feature_id, \"worktree already exists, skipping setup\");\n1455:         } else {\n1456:           await createWorktree(projectRoot, agent.feature_id, state.base_branch, config);\n1457:           updateAgent(state, agent.feature_id, { activity: \"installing deps...\" });\n1458:           await installDeps(agent.worktree, agent.feature_id, config);\n1459:         }\n1460: \n1461:         const prompt = generatePrompt(\n1462:           featureMap.get(agent.feature_id)!,\n1463:           state.base_branch,\n1464:           config,\n1465:           questContext,\n1466:           hitlMode as QuestHitlMode | undefined\n1467:         );\n1468: \n1469:         // Write specialized agent to worktree if applicable\n1470:         const resolution = agentResolutions?.get(agent.feature_id);\n1471:         const agentName = agent.agent_name ?? undefined;\n1472:         if (resolution && isSpecializedAgent(resolution)) {\n1473:           try {\n1474:             const patchedContent = patchImportedAgent(resolution.rawContent, config, projectRoot);\n1475:             writeAgentToWorktree(agent.worktree, resolution.name, patchedContent);\n1476:             wtLog(agent.feature_id, `wrote specialized agent: ${resolution.name}`);\n1477:           } catch (err: any) {\n1478:             wtLog(agent.feature_id, `WARN: failed to write specialized agent, using generalist: ${err.message}`);\n1479:           }\n1480:         }\n1481: \n1482:         wtLog(agent.feature_id, \"launching interactive session...\");\n1483:         const result = launchInteractive({\n1484:           worktreePath: agent.worktree,\n1485:           featureId: agent.feature_id,\n1486:           prompt,\n1487:           model,\n1488:           interactive: true,\n1489:           config,\n1490:           agentName,\n1491:         });\n1492: \n1493:         const muxName = getMultiplexerName(config);\n1494:         updateAgent(state, agent.feature_id, {\n\n(Showing lines 1395-1494 of 1950. Use offset=1495 to continue.)\n</content>","title":"src/commands/launch.ts","metadata":{"preview":"\n  // Auto-push base branch if requested\n  if (opts.autoPush) {\n    await pushBaseBranch(projectRoot, state.base_branch, config);\n  }\n\n  // Completion double-check: verify worktrees directory is empty\n  if (fmt === \"text\") {\n    if (isWorktreesDirEmpty(projectRoot)) {\n      console.log(\"All worktrees cleaned up — worktrees directory is empty.\");\n    } else {\n      console.log(\"\\x1b[33mNote:\\x1b[0m worktrees directory still has contents. Run 'woco cleanup' to clean up.\");\n    }\n\n    console.log(\"Wave complete.\");\n  }\n}\n\n// ---------------------------------------------------------------------------\n// Interactive Wave Launch","truncated":true,"loaded":[]},"time":{"start":1773483731173,"end":1773483731177}}}}
