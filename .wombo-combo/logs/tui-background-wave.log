it pushBaseBranch(projectRoot, state.base_branch, config);\n785:     }\n786: \n787:     if (fmt === \"text\") console.log(\"Wave complete.\");\n788:   }\n789: }\n\n(End of file - total 789 lines)\n</content>","title":"src/commands/resume.ts","metadata":{"preview":"    const POLL_INTERVAL = 5000;\n    let dashboardCounter = 0;\n    while (!isWaveComplete(state)) {\n      await new Promise((r) => setTimeout(r, POLL_INTERVAL));\n\n      for (const agent of state.agents) {\n        if (\n          (agent.status === \"running\" || agent.status === \"resolving_conflict\") &&\n          agent.pid &&\n          !isProcessRunning(agent.pid) &&\n          !monitor.isRunning(agent.feature_id)\n        ) {\n          if (agent.status === \"resolving_conflict\") {\n            // Conflict resolver died unexpectedly — mark as failed\n            updateAgent(state, agent.feature_id, {\n              status: \"failed\",\n              error: \"Conflict resolver process died unexpectedly\",\n              activity: null,\n              completed_at: new Date().toISOString(),\n            });","truncated":false,"loaded":[]},"time":{"start":1773483708794,"end":1773483708796}}}}
{"type":"tool_use","timestamp":1773483709672,"sessionID":"ses_31423da25ffebo9V1CTFH0IpgT","part":{"id":"prt_cebddd17b001ZAMu2iFvdSSiud","sessionID":"ses_31423da25ffebo9V1CTFH0IpgT","messageID":"msg_cebddc095001iCjgHbpnfLOoYT","type":"tool","callID":"toolu_vrtx_019BzpDWRLoD74uRgtTe1oXR","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/wave-detach-audit/src/commands/launch.ts","limit":200,"offset":1200},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/wave-detach-audit/src/commands/launch.ts</path>\n<type>file</type>\n<content>1200:   const ready = readyToLaunchAgents(state);\n1201:   const tolaunch = ready.slice(0, opts.maxConcurrent);\n1202:   if (fmt === \"text\") console.log(`Setting up ${tolaunch.length} agent(s) (staggered)...\\n`);\n1203: \n1204:   for (let i = 0; i < tolaunch.length; i++) {\n1205:     await launchSingleHeadless(\n1206:       projectRoot,\n1207:       state,\n1208:       tolaunch[i],\n1209:       featureMap.get(tolaunch[i].feature_id)!,\n1210:       monitor,\n1211:       config,\n1212:       model,\n1213:       agentResolutions,\n1214:       questContext,\n1215:       hitlMode\n1216:     );\n1217:     // Brief delay between spawns so each agent's DB migration settles\n1218:     if (i < tolaunch.length - 1) {\n1219:       await new Promise((r) => setTimeout(r, LAUNCH_STAGGER_MS));\n1220:     }\n1221:   }\n1222: \n1223:   const launched = state.agents.filter((a) => a.status === \"running\").length;\n1224: \n1225:   // Start the TUI dashboard (or skip if --no-tui)\n1226:   if (opts.noTui) {\n1227:     if (fmt === \"text\") {\n1228:       console.log(`${launched} agent(s) running. (--no-tui mode, dashboard prints every 15s)\\n`);\n1229:       printDashboard(state);\n1230:     }\n1231:   } else {\n1232:     if (fmt === \"text\") console.log(`${launched} agent(s) running. Launching TUI...\\n`);\n1233:     startTUI();\n1234:   }\n1235: \n1236:   // Background monitoring loop — checks for dead processes and launches queued\n1237:   const POLL_INTERVAL = 5000;\n1238:   let dashboardCounter = 0;\n1239:   while (!isWaveComplete(state)) {\n1240:     await new Promise((r) => setTimeout(r, POLL_INTERVAL));\n1241: \n1242:     // Check for completed processes that weren't caught by event handlers\n1243:     for (const agent of state.agents) {\n1244:       if (\n1245:         (agent.status === \"running\" || agent.status === \"resolving_conflict\") &&\n1246:         agent.pid &&\n1247:         !isProcessRunning(agent.pid) &&\n1248:         !monitor.isRunning(agent.feature_id)\n1249:       ) {\n1250:         if (agent.status === \"resolving_conflict\") {\n1251:           // Conflict resolver died — the await in handleBuildVerification\n1252:           // will resolve via the 'exit' event, so nothing to do here\n1253:           continue;\n1254:         }\n1255:         // Process exited but we didn't get a callback\n1256:         // Check if the agent actually made any commits\n1257:         if (!branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n1258:           // Agent died without producing any code — mark as failed, not completed\n1259:           updateAgent(state, agent.feature_id, {\n1260:             status: \"failed\",\n1261:             error: \"Agent process exited without making any commits\",\n1262:             activity: null,\n1263:             completed_at: new Date().toISOString(),\n1264:           });\n1265:           saveState(projectRoot, state);\n1266:           wtLog(agent.feature_id, \"process died with no code changes — marked failed\");\n1267: \n1268:           // Cascade failure to downstream agents\n1269:           const cancelled = cancelDownstream(state, agent.feature_id);\n1270:           if (cancelled.length > 0) {\n1271:             wtLog(agent.feature_id, `downstream cancelled: ${cancelled.join(\", \")}`);\n1272:             saveState(projectRoot, state);\n1273:           }\n1274:         } else {\n1275:           updateAgent(state, agent.feature_id, {\n1276:             status: \"completed\",\n1277:             completed_at: new Date().toISOString(),\n1278:             activity: \"done\",\n1279:           });\n1280:           saveState(projectRoot, state);\n1281:           try {\n1282:             await handleBuildVerification(projectRoot, state, agent, featureMap.get(agent.feature_id)!, config, model, monitor, undefined, hitlMode);\n1283:           } catch (err: any) {\n1284:             wtLog(agent.feature_id, `POLL VERIFY ERROR: ${err.message}`);\n1285:           }\n1286:         }\n1287:         await launchAllReady(projectRoot, state, featureMap, monitor, config, model, agentResolutions, questContext, hitlMode);\n1288:       }\n1289:     }\n1290: \n1291:     // Safety net: detect agents stuck in \"retry\" with no running process.\n1292:     // This catches edge cases where handleRetry() wasn't called or failed\n1293:     // to reset the agent (e.g. race between onError callback and poll loop).\n1294:     for (const agent of state.agents) {\n1295:       if (\n1296:         agent.status === \"retry\" &&\n1297:         (!agent.pid || !isProcessRunning(agent.pid)) &&\n1298:         !monitor.isRunning(agent.feature_id)\n1299:       ) {\n1300:         if (agent.retries >= agent.max_retries) {\n1301:           // Out of retries — mark as failed and cascade\n1302:           wtLog(agent.feature_id, `stuck in retry with no process and retries exhausted (${agent.retries}/${agent.max_retries}) — marking failed`);\n1303:           updateAgent(state, agent.feature_id, {\n1304:             status: \"failed\",\n1305:             error: agent.error ?? \"Agent stuck in retry state with no running process\",\n1306:             activity: null,\n1307:             completed_at: new Date().toISOString(),\n1308:           });\n1309:           saveState(projectRoot, state);\n1310:           const cancelled = cancelDownstream(state, agent.feature_id);\n1311:           if (cancelled.length > 0) {\n1312:             wtLog(agent.feature_id, `downstream cancelled: ${cancelled.join(\", \")}`);\n1313:             saveState(projectRoot, state);\n1314:           }\n1315:         } else {\n1316:           // Has retries left — reset to queued for a fresh launch\n1317:           wtLog(agent.feature_id, `stuck in retry with no process — resetting to queued (retry ${agent.retries}/${agent.max_retries})`);\n1318:           updateAgent(state, agent.feature_id, {\n1319:             status: \"queued\",\n1320:             error: null,\n1321:             activity: \"waiting for relaunch...\",\n1322:           });\n1323:           saveState(projectRoot, state);\n1324:         }\n1325:       }\n1326:     }\n1327: \n1328:     // After recovering stuck agents, try launching any that are now ready\n1329:     await launchAllReady(projectRoot, state, featureMap, monitor, config, model, agentResolutions, questContext, hitlMode);\n1330: \n1331:     // Persist state periodically\n1332:     saveState(projectRoot, state);\n1333: \n1334:     // Poll for HITL questions from agents and forward to TUI\n1335:     if (hitlMode && hitlMode !== \"yolo\") {\n1336:       try {\n1337:         const pendingQuestions = getPendingQuestions(projectRoot);\n1338:         if (tuiRef.current && pendingQuestions.length > 0) {\n1339:           tuiRef.current.setPendingQuestions(pendingQuestions);\n1340:         }\n1341:       } catch {\n1342:         // Non-fatal — HITL dir may not exist yet\n1343:       }\n1344:     }\n1345: \n1346:     // Update TUI state reference (or print dashboard in --no-tui mode)\n1347:     if (tuiRef.current) {\n1348:       tuiRef.current.updateState(state);\n1349:     } else if (opts.noTui && fmt === \"text\") {\n1350:       dashboardCounter++;\n1351:       if (dashboardCounter % 3 === 0) {\n1352:         printDashboard(state);\n1353: \n1354:         // Auto-push base branch if requested\n1355:         if (opts.autoPush) {\n1356:           const anyMerged = state.agents.some((a) => a.status === \"merged\");\n1357:           if (anyMerged) {\n1358:             await pushBaseBranch(projectRoot, state.base_branch, config);\n1359:           } else {\n1360:             console.log(\"No branches were merged — skipping push.\");\n1361:           }\n1362:         }\n1363:       }\n1364:     }\n1365:   }\n1366: \n1367:   // Wave complete — keep TUI open for post-mortem browsing\n1368:   if (tuiRef.current) {\n1369:     tuiRef.current.updateState(state);\n1370:     tuiRef.current.markWaveComplete();\n1371:     // Wait for the user to press q to exit the TUI\n1372:     await tuiRef.current.waitForQuit();\n1373:   }\n1374: \n1375:   // Print final dashboard after TUI is closed\n1376:   if (fmt === \"text\") printDashboard(state);\n1377: \n1378:   // Clean up HITL files\n1379:   try {\n1380:     cleanupHitl(projectRoot);\n1381:   } catch {\n1382:     // Non-fatal\n1383:   }\n1384: \n1385:   // Dump full logs for failed agents (post-mortem)\n1386:   dumpFailedAgentLogs(projectRoot, state, fmt);\n1387: \n1388:   // Auto-export wave history\n1389:   try {\n1390:     const historyPath = exportWaveHistory(projectRoot, state);\n1391:     if (fmt === \"text\") console.log(`Wave history exported to ${historyPath}`);\n1392:   } catch (err: any) {\n1393:     if (fmt === \"text\") console.error(`Warning: failed to export wave history: ${err.message}`);\n1394:   }\n1395: \n1396:   // Auto-push base branch if requested\n1397:   if (opts.autoPush) {\n1398:     await pushBaseBranch(projectRoot, state.base_branch, config);\n1399:   }\n\n(Showing lines 1200-1399 of 1950. Use offset=1400 to continue.)\n</content>","title":"src/commands/launch.ts","metadata":{"preview":"  const ready = readyToLaunchAgents(state);\n  const tolaunch = ready.slice(0, opts.maxConcurrent);\n  if (fmt === \"text\") console.log(`Setting up ${tolaunch.length} agent(s) (staggered)...\\n`);\n\n  for (let i = 0; i < tolaunch.length; i++) {\n    await launchSingleHeadless(\n      project