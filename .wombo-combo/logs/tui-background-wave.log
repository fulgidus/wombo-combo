{"type":"tool_use","timestamp":1773484327836,"sessionID":"ses_31423da25ffebo9V1CTFH0IpgT","part":{"id":"prt_cebe73e88001kE8PE07q3382Fd","sessionID":"ses_31423da25ffebo9V1CTFH0IpgT","messageID":"msg_cebe730a000198I43jD5Hsl6rI","type":"tool","callID":"toolu_vrtx_01ByWc3314gwT3skyoRHDdpf","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/wave-detach-audit/src/commands/launch.ts","offset":1418},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/wave-detach-audit/src/commands/launch.ts</path>\n<type>file</type>\n<content>1418:     const historyPath = exportWaveHistory(projectRoot, state);\n1419:     if (fmt === \"text\") console.log(`Wave history exported to ${historyPath}`);\n1420:   } catch (err: any) {\n1421:     if (fmt === \"text\") console.error(`Warning: failed to export wave history: ${err.message}`);\n1422:   }\n1423: \n1424:   // Auto-push base branch if requested\n1425:   if (opts.autoPush) {\n1426:     await pushBaseBranch(projectRoot, state.base_branch, config);\n1427:   }\n1428: \n1429:   // Completion double-check: verify worktrees directory is empty\n1430:   if (fmt === \"text\") {\n1431:     if (isWorktreesDirEmpty(projectRoot)) {\n1432:       console.log(\"All worktrees cleaned up — worktrees directory is empty.\");\n1433:     } else {\n1434:       console.log(\"\\x1b[33mNote:\\x1b[0m worktrees directory still has contents. Run 'woco cleanup' to clean up.\");\n1435:     }\n1436: \n1437:     console.log(\"Wave complete.\");\n1438:   }\n1439: }\n1440: \n1441: // ---------------------------------------------------------------------------\n1442: // Interactive Wave Launch\n1443: //\n1444: // Audit (wave-detach-audit): Interactive agents run inside dmux/tmux sessions.\n1445: // Unlike headless agents, they are NOT child processes of the wombo parent —\n1446: // they survive parent death, SIGINT, and crashes naturally. No explicit\n1447: // cleanup is needed when the parent exits. The `launchInteractive()` function\n1448: // in launcher.ts returns `process: null as any` (no ChildProcess handle).\n1449: // ---------------------------------------------------------------------------\n1450: \n1451: async function launchWaveInteractive(\n1452:   projectRoot: string,\n1453:   state: WaveState,\n1454:   features: Feature[],\n1455:   opts: LaunchCommandOptions,\n1456:   agentResolutions?: Map<string, AgentResolution>,\n1457:   questContext?: QuestPromptContext,\n1458:   hitlMode?: string\n1459: ): Promise<void> {\n1460:   const { config, model } = opts;\n1461:   const fmt = opts.outputFmt ?? \"text\";\n1462:   const featureMap = new Map(features.map((f) => [f.id, f]));\n1463: \n1464:   // Show dashboard immediately\n1465:   if (fmt === \"text\") printDashboard(state);\n1466: \n1467:   // Launch initial batch — parallelize setup\n1468:   const tolaunch = queuedAgents(state).slice(0, opts.maxConcurrent);\n1469:   if (fmt === \"text\") console.log(`Setting up ${tolaunch.length} agent(s) in parallel...\\n`);\n1470: \n1471:   await Promise.all(\n1472:     tolaunch.map(async (agent) => {\n1473:       updateAgent(state, agent.feature_id, {\n1474:         status: \"installing\",\n1475:         started_at: new Date().toISOString(),\n1476:         activity: \"setting up worktree...\",\n1477:       });\n1478:       saveState(projectRoot, state);\n1479: \n1480:       try {\n1481:         if (worktreeReady(agent.worktree)) {\n1482:           wtLog(agent.feature_id, \"worktree already exists, skipping setup\");\n1483:         } else {\n1484:           await createWorktree(projectRoot, agent.feature_id, state.base_branch, config);\n1485:           updateAgent(state, agent.feature_id, { activity: \"installing deps...\" });\n1486:           await installDeps(agent.worktree, agent.feature_id, config);\n1487:         }\n1488: \n1489:         const prompt = generatePrompt(\n1490:           featureMap.get(agent.feature_id)!,\n1491:           state.base_branch,\n1492:           config,\n1493:           questContext,\n1494:           hitlMode as QuestHitlMode | undefined\n1495:         );\n1496: \n1497:         // Write specialized agent to worktree if applicable\n1498:         const resolution = agentResolutions?.get(agent.feature_id);\n1499:         const agentName = agent.agent_name ?? undefined;\n1500:         if (resolution && isSpecializedAgent(resolution)) {\n1501:           try {\n1502:             const patchedContent = patchImportedAgent(resolution.rawContent, config, projectRoot);\n1503:             writeAgentToWorktree(agent.worktree, resolution.name, patchedContent);\n1504:             wtLog(agent.feature_id, `wrote specialized agent: ${resolution.name}`);\n1505:           } catch (err: any) {\n1506:             wtLog(agent.feature_id, `WARN: failed to write specialized agent, using generalist: ${err.message}`);\n1507:           }\n1508:         }\n1509: \n1510:         wtLog(agent.feature_id, \"launching interactive session...\");\n1511:         const result = launchInteractive({\n1512:           worktreePath: agent.worktree,\n1513:           featureId: agent.feature_id,\n1514:           prompt,\n1515:           model,\n1516:           interactive: true,\n1517:           config,\n1518:           agentName,\n1519:         });\n1520: \n1521:         const muxName = getMultiplexerName(config);\n1522:         updateAgent(state, agent.feature_id, {\n1523:           status: \"running\",\n1524:           pid: result.pid,\n1525:           activity: `${muxName} session active`,\n1526:         });\n1527:         saveState(projectRoot, state);\n1528:         wtLog(agent.feature_id, `${muxName} session: ${config.agent.tmuxPrefix}-${agent.feature_id}`);\n1529:       } catch (err: any) {\n1530:         updateAgent(state, agent.feature_id, {\n1531:           status: \"failed\",\n1532:           error: err.message,\n1533:           activity: null,\n1534:           completed_at: new Date().toISOString(),\n1535:         });\n1536:         saveState(projectRoot, state);\n1537:         wtLog(agent.feature_id, `SETUP FAILED: ${err.message.split(\"\\n\")[0]}`);\n1538:       }\n1539:     })\n1540:   );\n1541: \n1542:   const mux = detectMultiplexer(config.agent.multiplexer);\n1543:   const muxName = getMultiplexerName(config);\n1544:   if (fmt === \"text\") {\n1545:     console.log(\"\\nInteractive sessions launched. Use these commands:\");\n1546:     console.log(`  ${muxAttachCommand(mux, `${config.agent.tmuxPrefix}-<feature-id>`)}   # attach to a session`);\n1547:     console.log(`  ${muxListCommand(mux)}${\" \".repeat(Math.max(1, 54 - muxListCommand(mux).length))}# list sessions`);\n1548:     console.log(\"  woco status                                             # check status\");\n1549:     console.log(\"  woco verify                                             # verify builds\");\n1550:     console.log(\"  woco merge                                              # merge verified\");\n1551:     console.log(\"  woco cleanup                                            # remove worktrees\");\n1552: \n1553:     printDashboard(state);\n1554:   }\n1555: }\n1556: \n1557: // ---------------------------------------------------------------------------\n1558: // Main Command\n1559: // ---------------------------------------------------------------------------\n1560: \n1561: export async function cmdLaunch(opts: LaunchCommandOptions): Promise<void> {\n1562:   const { projectRoot } = opts;\n1563:   let { config } = opts;\n1564:   const fmt = opts.outputFmt ?? \"text\";\n1565: \n1566:   if (fmt === \"text\") console.log(\"\\n--- wombo-combo: Launch ---\\n\");\n1567: \n1568:   // Ensure agent definition exists — reinstall from template if missing\n1569:   ensureAgentDefinition(projectRoot, config, opts.agent);\n1570: \n1571:   // -------------------------------------------------------------------------\n1572:   // Quest resolution — if --quest was specified, scope the wave to that quest\n1573:   // -------------------------------------------------------------------------\n1574:   let questContext: QuestPromptContext | undefined;\n1575:   let questId: string | null = opts.questId ?? null;\n1576: \n1577:   if (questId) {\n1578:     const quest = loadQuest(projectRoot, questId);\n1579:     if (!quest) {\n1580:       outputError(fmt, `Quest \"${questId}\" not found. Use 'woco quest list' to see available quests.`);\n1581:       return; // unreachable\n1582:     }\n1583: \n1584:     if (quest.status !== \"active\") {\n1585:       outputError(fmt, `Quest \"${questId}\" is in status \"${quest.status}\" — only active quests can be launched. Use 'woco quest activate ${questId}' first.`);\n1586:       return; // unreachable\n1587:     }\n1588: \n1589:     // Ensure the quest branch exists (create from baseBranch if needed)\n1590:     if (!questBranchExists(projectRoot, questId)) {\n1591:       if (fmt === \"text\") console.log(`Creating quest branch \"${quest.branch}\" from \"${quest.baseBranch}\"...`);\n1592:       createQuestBranch(projectRoot, questId, quest.baseBranch);\n1593:     }\n1594: \n1595:     // Override baseBranch — task branches will fork from the quest branch\n1596:     opts.baseBranch = quest.branch;\n1597:     if (fmt === \"text\") {\n1598:       console.log(`Quest: ${quest.title} (${questId})`);\n1599:       console.log(`  Base branch overridden to: ${quest.branch}`);\n1600:     }\n1601: \n1602:     // Apply quest config overrides (layered on top of project config)\n1603:     config = resolveQuestConfig(config, quest);\n1604: \n1605:     // Build quest prompt context for agent prompts\n1606:     const knowledge = loadQuestKnowledge(projectRoot, questId);\n1607:     questContext = {\n1608:       questId: quest.id,\n1609:       goal: quest.goal,\n1610:       addedConstraints: quest.constraints.add ?? [],\n1611:       addedForbidden: quest.constraints.ban ?? [],\n1612:       knowledge,\n1613:     };\n1614: \n1615:     if (fmt === \"text\") {\n1616:       const constraintCount = questContext.addedConstraints.length + questContext.addedForbidden.length;\n1617:       if (constraintCount > 0) {\n1618:         console.log(`  Quest constraints: ${questContext.addedConstraints.length} added, ${questContext.addedForbidden.length} banned`);\n1619:       }\n1620:       if (knowledge) {\n1621:         console.log(`  Quest knowledge: loaded (${knowledge.length} bytes)`);\n1622:       }\n1623:       console.log(\"\");\n1624:     }\n1625:   }\n1626: \n1627:   // Extract HITL mode from quest (defaults to undefined / yolo for non-quest waves)\n1628:   const hitlMode = questId ? loadQuest(projectRoot, questId)?.hitlMode : undefined;\n1629: \n1630:   // Ensure portless proxy is running (if enabled) to prevent port collisions\n1631:   if (config.portless.enabled) {\n1632:     if (isPortlessAvailable(config)) {\n1633:       const proxyOk = ensureProxyRunning(config);\n1634:       if (!proxyOk && fmt === \"text\") {\n1635:         console.warn(\n1636:           \"\\x1b[33m[portless]\\x1b[0m proxy could not be started — agents may encounter port collisions\"\n1637:         );\n1638:       }\n1639:     } else if (fmt === \"text\") {\n1640:       console.warn(\n1641:         \"\\x1b[33m[portless]\\x1b[0m enabled but not installed. Install with: npm install -g portless\"\n1642:       );\n1643:       console.warn(\n1644:         \"  Agents will run without portless — concurrent dev servers may have port collisions.\\n\"\n1645:       );\n1646:     }\n1647:   }\n1648: \n1649:   // -------------------------------------------------------------------------\n1650:   // Validate that the configured baseBranch exists as a local branch\n1651:   // -------------------------------------------------------------------------\n1652:   if (!branchExists(projectRoot, opts.baseBranch)) {\n1653:     const msg = `Base branch \"${opts.baseBranch}\" does not exist as a local branch. ` +\n1654:       `Create it first (e.g. \"git checkout -b ${opts.baseBranch}\") or specify ` +\n1655:       `a different branch with --base-branch.`;\n1656:     outputError(fmt, msg);\n1657:   }\n1658: \n1659:   // -------------------------------------------------------------------------\n1660:   // Check for existing wave state — don't overwrite work in progress\n1661:   // -------------------------------------------------------------------------\n1662:   const existingState = loadState(projectRoot);\n1663:   if (existingState) {\n1664:     const merged = existingState.agents.filter((a) => a.status === \"merged\");\n1665:     const verified = existingState.agents.filter((a) => a.status === \"verified\");\n1666:     const completed = existingState.agents.filter((a) => a.status === \"completed\");\n1667:     const running = existingState.agents.filter((a) => a.status === \"running\");\n1668:     const queued = existingState.agents.filter((a) => a.status === \"queued\");\n1669:     const failed = existingState.agents.filter((a) => a.status === \"failed\");\n1670: \n1671:     const hasWork = merged.length > 0 || verified.length > 0 || completed.length > 0 || running.length > 0;\n1672: \n1673:     if (hasWork) {\n1674:       if (fmt === \"text\") {\n1675:         console.log(`Existing wave found: ${existingState.wave_id}`);\n1676:         console.log(`  ${merged.length} merged, ${verified.length} verified, ${completed.length} completed, ${running.length} running, ${queued.length} queued, ${failed.length} failed`);\n1677:       }\n1678: \n1679:       // Finalize any merged agents by marking their features as done\n1680:       const finalizedIds: string[] = [];\n1681:       if (merged.length > 0) {\n1682:         if (fmt === \"text\") console.log(\"\\nFinalizing merged tasks in tasks file...\");\n1683:         for (const agent of merged) {\n1684:           markFeatureDone(projectRoot, agent.feature_id, config, existingState.base_branch, fmt);\n1685:           finalizedIds.push(agent.feature_id);\n1686:           // Clean up worktree and branch (already merged, safe to delete)\n1687:           try {\n1688:             removeWorktree(projectRoot, agent.worktree, true);\n1689:             if (fmt === \"text\") console.log(`  ${agent.feature_id}: marked done, worktree removed`);\n1690:           } catch {\n1691:             if (fmt === \"text\") console.log(`  ${agent.feature_id}: marked done (worktree already cleaned)`);\n1692:           }\n1693:         }\n1694:       }\n1695: \n1696:       // Strip finalized task IDs from explicit selection so we don't\n1697:       // try to re-launch tasks that were just marked done\n1698:       if (finalizedIds.length > 0 && opts.features?.length) {\n1699:         const finalizedSet = new Set(finalizedIds);\n1700:         opts.features = opts.features.filter((id) => !finalizedSet.has(id));\n1701:       }\n1702: \n1703:       // Verified agents: build passed but NOT merged — do NOT mark done.\n1704:       // Leave them for 'woco resume' to attempt the merge.\n1705:       if (verified.length > 0) {\n1706:         for (const agent of verified) {\n1707:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: verified (not yet merged) — use 'woco resume' to merge`);\n1708:         }\n1709:       }\n1710: \n1711:       const activeCount = running.length + completed.length + queued.length;\n1712:       if (activeCount > 0) {\n1713:         outputError(fmt, `Wave ${existingState.wave_id} has ${activeCount} unfinished agent(s). Use 'woco resume' to continue the existing wave, or 'woco cleanup' to clear it before starting a new one.`);\n1714:       }\n1715: \n1716:       // All agents are in terminal states (merged/verified/failed) — safe to start fresh\n1717:       if (fmt === \"text\") console.log(\"\\nAll agents in previous wave are finished. Starting fresh wave.\\n\");\n1718:     }\n1719:   }\n1720: \n1721:   // Load features\n1722:   const data = loadFeatures(projectRoot, config);\n1723: \n1724:   // Build selection options\n1725:   const selOpts: SelectionOptions = {};\n1726:   if (opts.topPriority) selOpts.topPriority = opts.topPriority;\n1727:   if (opts.quickestWins) selOpts.quickestWins = opts.quickestWins;\n1728:   if (opts.priority) selOpts.priority = opts.priority;\n1729:   if (opts.difficulty) selOpts.difficulty = opts.difficulty;\n1730:   if (opts.features) selOpts.taskIds = opts.features;\n1731:   if (opts.allReady) selOpts.allReady = true;\n1732: \n1733:   // Select features\n1734:   let selected = selectFeatures(data, selOpts);\n1735: \n1736:   if (selected.length === 0) {\n1737:     // Build a context-aware message based on which flags were passed\n1738:     const activeFilters: string[] = [];\n1739:     if (opts.allReady) activeFilters.push(\"--all-ready\");\n1740:     if (opts.topPriority) activeFilters.push(`--top-priority ${opts.topPriority}`);\n1741:     if (opts.quickestWins) activeFilters.push(`--quickest-wins ${opts.quickestWins}`);\n1742:     if (opts.priority) activeFilters.push(`--priority ${opts.priority}`);\n1743:     if (opts.difficulty) activeFilters.push(`--difficulty ${opts.difficulty}`);\n1744:     if (opts.features?.length) activeFilters.push(`--tasks ${opts.features.join(\",\")}`);\n1745: \n1746:     let msg: string;\n1747:     if (opts.allReady && activeFilters.length === 1) {\n1748:       msg = \"No launchable tasks found (all tasks are done, cancelled, or have unmet dependencies).\";\n1749:     } else if (activeFilters.length > 0) {\n1750:       msg = `No tasks matched the current filters: ${activeFilters.join(\", \")}.`;\n1751:     } else {\n1752:       msg = \"No launchable tasks found.\";\n1753:     }\n1754: \n1755:     // Throw instead of outputError so TUI callers can catch gracefully.\n1756:     // CLI callers catch this in the command handler (index.ts).\n1757:     throw new Error(msg);\n1758:   }\n1759: \n1760:   // Apply quest constraints to selected tasks (add/ban layered on each task)\n1761:   if (questId && questContext) {\n1762:     const quest = loadQuest(projectRoot, questId)!;\n1763:     selected = selected.map((f) => applyQuestConstraintsToTask(f, quest));\n1764:   }\n1765: \n1766:   // Show selection\n1767:   if (fmt === \"text\") {\n1768:     printFeatureSelection(\n1769:       selected.map((f) => ({\n1770:         id: f.id,\n1771:         title: f.title,\n1772:         priority: f.priority,\n1773:         difficulty: f.difficulty,\n1774:         effort: f.effort,\n1775:       }))\n1776:     );\n1777:   }\n1778: \n1779:   // Check per-task agent definitions exist\n1780:   if (!opts.agent) {\n1781:     const taskAgents = new Set(\n1782:       selected.map((f) => f.agent).filter((a): a is string => !!a)\n1783:     );\n1784:     for (const agentName of taskAgents) {\n1785:       ensureAgentDefinition(projectRoot, config, agentName);\n1786:     }\n1787:   }\n1788: \n1789:   // ---------------------------------------------------------------------------\n1790:   // Dependency graph analysis\n1791:   // ---------------------------------------------------------------------------\n1792:   const depGraph = buildDepGraph(selected, data.tasks);\n1793:   let schedulePlan: SchedulePlan | null = null;\n1794: \n1795:   // Check if any features actually have dependencies within the selected set\n1796:   const hasDeps = selected.some(\n1797:     (f) => f.depends_on.some((d) => selected.find((s) => s.id === d))\n1798:   );\n1799: \n1800:   if (hasDeps) {\n1801:     // Validate graph — throws on cycles or dangling deps\n1802:     try {\n1803:       validateDepGraph(depGraph);\n1804:     } catch (err: any) {\n1805:       outputError(fmt, `${err.message}\\nFix dependency issues before launching.`);\n1806:     }\n1807: \n1808:     // Build scheduling plan\n1809:     schedulePlan = buildSchedulePlan(depGraph);\n1810:     if (fmt === \"text\") console.log(`\\n${formatSchedulePlan(schedulePlan)}\\n`);\n1811:   }\n1812: \n1813:   if (opts.dryRun) {\n1814:     const dryRunResult = {\n1815:       dry_run: true,\n1816:       base_branch: opts.baseBranch,\n1817:       max_concurrent: opts.maxConcurrent,\n1818:       model: opts.model ?? null,\n1819:       interactive: opts.interactive,\n1820:       selected: selected.map((f) => ({\n1821:         id: f.id,\n1822:         title: f.title,\n1823:         priority: f.priority,\n1824:         difficulty: f.difficulty,\n1825:         effort: f.effort,\n1826:       })),\n1827:       schedule_plan: schedulePlan ? {\n1828:         streams: schedulePlan.streams.map((s) => s.featureIds),\n1829:         merge_gates: schedulePlan.mergeGates.map((g) => ({\n1830:           feature_id: g.featureId,\n1831:           wait_for: g.waitFor,\n1832:         })),\n1833:         topological_order: schedulePlan.topologicalOrder,\n1834:       } : null,\n1835:     };\n1836: \n1837:     output(fmt, dryRunResult, () => {\n1838:       console.log(\"Dry run — not launching agents.\");\n1839:     }, () => {\n1840:       console.log(renderLaunchDryRun(dryRunResult));\n1841:     });\n1842:     return;\n1843:   }\n1844: \n1845:   // ---------------------------------------------------------------------------\n1846:   // Agent registry: resolve specialized agents for tasks with agent_type\n1847:   // ---------------------------------------------------------------------------\n1848:   let agentResolutions: Map<string, AgentResolution> | undefined;\n1849: \n1850:   if (config.agentRegistry.mode !== \"disabled\") {\n1851:     const tasksWithAgentType = selected.filter((t) => t.agent_type);\n1852:     if (tasksWithAgentType.length > 0) {\n1853:       if (fmt === \"text\") console.log(`\\nResolving ${tasksWithAgentType.length} specialized agent(s) from registry...`);\n1854:       agentResolutions = await prepareAgentDefinitions(selected, config, projectRoot);\n1855: \n1856:       const specialized = [...agentResolutions.values()].filter(isSpecializedAgent);\n1857:       const cached = specialized.filter((r) => r.fromCache);\n1858:       if (fmt === \"text\") {\n1859:         console.log(\n1860:           `  ${specialized.length} specialized (${cached.length} cached, ${specialized.length - cached.length} fetched), ` +\n1861:           `${selected.length - specialized.length} generalist`\n1862:         );\n1863:       }\n1864:     }\n1865:   }\n1866: \n1867:   // ---------------------------------------------------------------------------\n1868:   // Preflight confirmation\n1869:   // ---------------------------------------------------------------------------\n1870:   if (agentResolutions && agentResolutions.size > 0) {\n1871:     const isTTY = process.stdout.isTTY && process.stdin.isTTY;\n1872:     const preflight = isTTY && !opts.noTui\n1873:       ? await tuiPreflightConfirm(selected, agentResolutions, config)\n1874:       : await consolePreflightConfirm(selected, agentResolutions, config);\n1875: \n1876:     if (!preflight.proceed) {\n1877:       outputMessage(fmt, \"Launch cancelled.\");\n1878:       return;\n1879:     }\n1880: \n1881:     // Apply user's changes (rejected agents, mode changes)\n1882:     agentResolutions = preflight.agents;\n1883:   }\n1884: \n1885:   // Create wave state\n1886:   const state = createWaveState({\n1887:     baseBranch: opts.baseBranch,\n1888:     maxConcurrent: opts.maxConcurrent,\n1889:     model: opts.model ?? null,\n1890:     interactive: opts.interactive,\n1891:     questId,\n1892:   });\n1893: \n1894:   // Store serialized schedule plan in wave state\n1895:   if (schedulePlan) {\n1896:     state.schedule_plan = {\n1897:       streams: schedulePlan.streams.map((s) => s.featureIds),\n1898:       merge_gates: schedulePlan.mergeGates.map((g) => ({\n1899:         feature_id: g.featureId,\n1900:         wait_for: g.waitFor,\n1901:       })),\n1902:       topological_order: schedulePlan.topologicalOrder,\n1903:     };\n1904:   }\n1905: \n1906:   // Create agent entries for all selected features\n1907:   const selectedIds = new Set(selected.map((f) => f.id));\n1908: \n1909:   // Build a map from feature ID → shared worktree path for chain reuse.\n1910:   // All features