{"type":"tool_use","timestamp":1773483826719,"sessionID":"ses_31423da25ffebo9V1CTFH0IpgT","part":{"id":"prt_cebdf9c1a001d3o2Mrdlzqugvz","sessionID":"ses_31423da25ffebo9V1CTFH0IpgT","messageID":"msg_cebdf8ef4001y8hy5mFB5EPG2i","type":"tool","callID":"toolu_vrtx_01XpLhrExKbn7hR1dBgoRSdc","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/wave-detach-audit/src/commands/launch.ts","limit":60,"offset":1362},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/wave-detach-audit/src/commands/launch.ts</path>\n<type>file</type>\n<content>1362:     }\n1363:   }\n1364: \n1365:   // Wave complete — keep TUI open for post-mortem browsing\n1366:   if (tuiRef.current) {\n1367:     tuiRef.current.updateState(state);\n1368:     tuiRef.current.markWaveComplete();\n1369:     // Wait for the user to press q to exit the TUI\n1370:     await tuiRef.current.waitForQuit();\n1371:   }\n1372: \n1373:   // Print final dashboard after TUI is closed\n1374:   if (fmt === \"text\") printDashboard(state);\n1375: \n1376:   // Clean up HITL files\n1377:   try {\n1378:     cleanupHitl(projectRoot);\n1379:   } catch {\n1380:     // Non-fatal\n1381:   }\n1382: \n1383:   // Dump full logs for failed agents (post-mortem)\n1384:   dumpFailedAgentLogs(projectRoot, state, fmt);\n1385: \n1386:   // Auto-export wave history\n1387:   try {\n1388:     const historyPath = exportWaveHistory(projectRoot, state);\n1389:     if (fmt === \"text\") console.log(`Wave history exported to ${historyPath}`);\n1390:   } catch (err: any) {\n1391:     if (fmt === \"text\") console.error(`Warning: failed to export wave history: ${err.message}`);\n1392:   }\n1393: \n1394:   // Auto-push base branch if requested\n1395:   if (opts.autoPush) {\n1396:     await pushBaseBranch(projectRoot, state.base_branch, config);\n1397:   }\n1398: \n1399:   // Completion double-check: verify worktrees directory is empty\n1400:   if (fmt === \"text\") {\n1401:     if (isWorktreesDirEmpty(projectRoot)) {\n1402:       console.log(\"All worktrees cleaned up — worktrees directory is empty.\");\n1403:     } else {\n1404:       console.log(\"\\x1b[33mNote:\\x1b[0m worktrees directory still has contents. Run 'woco cleanup' to clean up.\");\n1405:     }\n1406: \n1407:     console.log(\"Wave complete.\");\n1408:   }\n1409: }\n1410: \n1411: // ---------------------------------------------------------------------------\n1412: // Interactive Wave Launch\n1413: //\n1414: // Audit (wave-detach-audit): Interactive agents run inside dmux/tmux sessions.\n1415: // Unlike headless agents, they are NOT child processes of the wombo parent —\n1416: // they survive parent death, SIGINT, and crashes naturally. No explicit\n1417: // cleanup is needed when the parent exits. The `launchInteractive()` function\n1418: // in launcher.ts returns `process: null as any` (no ChildProcess handle).\n1419: // ---------------------------------------------------------------------------\n1420: \n1421: async function launchWaveInteractive(\n\n(Showing lines 1362-1421 of 1948. Use offset=1422 to continue.)\n</content>","title":"src/commands/launch.ts","metadata":{"preview":"    }\n  }\n\n  // Wave complete — keep TUI open for post-mortem browsing\n  if (tuiRef.current) {\n    tuiRef.current.updateState(state);\n    tuiRef.current.markWaveComplete();\n    // Wait for the user to press q to exit the TUI\n    await tuiRef.current.waitForQuit();\n  }\n\n  // Print final dashboard after TUI is closed\n  if (fmt === \"text\") printDashboard(state);\n\n  // Clean up HITL files\n  try {\n    cleanupHitl(projectRoot);\n  } catch {\n    // Non-fatal\n  }","truncated":true,"loaded":[]},"time":{"start":1773483826714,"end":1773483826718}}}}
