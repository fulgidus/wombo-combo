ame\": \"renderDashboard\",\n      \"signature\": \"function renderDashboard(state: WaveState): string\",\n      \"summary\": \"function renderDashboard(state: WaveState): string\",\n      \"line\": 99\n    },\n    {\n      \"id\": \"src/lib/ui.ts::printDashboard#function\",\n      \"kind\": \"function\",\n      \"name\": \"printDashboard\",\n      \"signature\": \"function printDashboard(state: WaveState): void\",\n      \"summary\": \"function printDashboard(state: WaveState): void\",\n      \"line\": 249\n    },\n    {\n      \"id\": \"src/lib/ui.ts::printAgentUpdate#function\",\n      \"kind\": \"function\",\n      \"name\": \"printAgentUpdate\",\n      \"signature\": \"function printAgentUpdate(\\n  agent: AgentState,\\n  message: string\\n): void\",\n      \"summary\": \"function printAgentUpdate(\\n  agent: AgentState,\\n  message: string\\n): void\",\n      \"line\": 256\n    },\n    {\n      \"id\": \"src/lib/ui.ts::printSummary#function\",\n      \"kind\": \"function\",\n      \"name\": \"printSummary\",\n      \"signature\": \"function printSummary(state: WaveState): void\",\n      \"summary\": \"function printSummary(state: WaveState): void\",\n      \"line\": 270\n    },\n    {\n      \"id\": \"src/lib/ui.ts::clearScreen#function\",\n      \"kind\": \"function\",\n      \"name\": \"clearScreen\",\n      \"signature\": \"function clearScreen(): void\",\n      \"summary\": \"function clearScreen(): void\",\n      \"line\": 282\n    },\n    {\n      \"id\": \"src/lib/ui.ts::printFeatureSelection#function\",\n      \"kind\": \"function\",\n      \"name\": \"printFeatureSelection\",\n      \"signature\": \"function printFeatureSelection(\\n  features: Array<{\\n    id: string;\\n    title: string;\\n    priority: string;\\n    difficulty: string;\\n    effort: string;\\n  }>\\n): void\",\n      \"summary\": \"function printFeatureSelection(\\n  features: Array<{\\n    id: string;\\n    title: string;\\n    priority: string;\\n    difficu\",\n      \"line\": 289\n    }\n  ],\n  \"_meta\": {\n    \"timing_ms\": 4.9,\n    \"symbol_count\": 10,\n    \"tokens_saved\": 565,\n    \"total_tokens_saved\": 2089760,\n    \"cost_avoided\": {\n      \"claude_opus_4_6\": 0.0028,\n      \"claude_sonnet_4_6\": 0.0017,\n      \"claude_haiku_4_5\": 0.0006,\n      \"gpt5_latest\": 0.0057\n    },\n    \"total_cost_avoided\": {\n      \"claude_opus_4_6\": 10.4488,\n      \"claude_sonnet_4_6\": 6.2693,\n      \"claude_haiku_4_5\": 2.0898,\n      \"gpt5_latest\": 20.8976\n    },\n    \"powered_by\": \"jcodemunch-mcp by jgravelle \\u00b7 https://github.com/jgravelle/jcodemunch-mcp\"\n  }\n}","title":"","metadata":{"truncated":false},"time":{"start":1773483617431,"end":1773483617448},"attachments":[]}}}
