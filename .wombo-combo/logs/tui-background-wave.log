{"type":"tool_use","timestamp":1773483626649,"sessionID":"ses_31423da25ffebo9V1CTFH0IpgT","part":{"id":"prt_cebdc8f49001Y3vIiHLrYiFpFV","sessionID":"ses_31423da25ffebo9V1CTFH0IpgT","messageID":"msg_cebdc7f7b001Rbcges7qGgGYc5","type":"tool","callID":"toolu_vrtx_01TMt64orC36PXDtxatS7twZ","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/wave-detach-audit/src/commands/resume.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/wave-detach-audit/src/commands/resume.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * resume.ts — Resume a previously stopped wave.\n3:  *\n4:  * Usage: woco resume [options] [--output json]\n5:  *\n6:  * Restores from .wombo-combo/state.json:\n7:  *   - Agents in \"running\"/\"installing\" whose PID is dead → re-check or re-launch\n8:  *   - Agents in \"queued\" → launch them\n9:  *   - Agents in terminal states (verified/failed/merged) → leave alone\n10:  *\n11:  * ## Agent Recovery (audit: wave-detach-audit)\n12:  *\n13:  * This is the primary recovery mechanism for agents that died when the parent\n14:  * process was terminated (gracefully via SIGINT, or ungracefully via SIGKILL/crash).\n15:  *\n16:  * Recovery triage for each agent:\n17:  *   - PID still alive → leave it running (another wombo instance may still be active)\n18:  *   - PID dead + worktree has commits → run build verification on existing work\n19:  *   - PID dead + no commits → reset to \"queued\" for a fresh re-launch\n20:  *   - \"completed\" → verify build\n21:  *   - \"verified\" → attempt merge\n22:  *   - \"failed\" with retries remaining + worktree has commits → re-verify\n23:  *   - \"failed\" with retries remaining + no commits → re-launch\n24:  *   - \"failed\" with retries exhausted → leave alone (user can `woco retry`)\n25:  *\n26:  * This design means no agent work is permanently lost unless the worktree\n27:  * itself is destroyed (e.g., by `woco cleanup`).\n28:  */\n29: \n30: import type { WomboConfig } from \"../config.js\";\n31: import type { Feature } from \"../lib/tasks.js\";\n32: import { loadFeatures } from \"../lib/tasks.js\";\n33: import {\n34:   loadState,\n35:   saveState,\n36:   flushState,\n37:   updateAgent,\n38:   queuedAgents,\n39:   readyToLaunchAgents,\n40:   cancelDownstream,\n41:   isWaveComplete,\n42:   type WaveState,\n43:   type AgentState,\n44: } from \"../lib/state.js\";\n45: import {\n46:   createWorktree,\n47:   installDeps,\n48:   worktreeReady,\n49:   worktreeExists,\n50:   branchHasChanges,\n51:   removeWorktree,\n52:   log as wtLog,\n53: } from \"../lib/worktree.js\";\n54: import { generatePrompt, type QuestPromptContext } from \"../lib/prompt.js\";\n55: import {\n56:   launchInteractive,\n57:   isProcessRunning,\n58:   getMultiplexerName,\n59: } from \"../lib/launcher.js\";\n60: import { ProcessMonitor } from \"../lib/monitor.js\";\n61: import { pushBaseBranch } from \"../lib/merger.js\";\n62: import { runBuild } from \"../lib/verifier.js\";\n63: import { printDashboard, printAgentUpdate } from \"../lib/ui.js\";\n64: import { WomboTUI } from \"../lib/tui.js\";\n65: import {\n66:   launchSingleHeadless,\n67:   handleBuildVerification,\n68:   handleRetry,\n69:   launchNextQueued,\n70:   launchAllReady,\n71:   markFeatureDone,\n72:   attemptMerge,\n73:   dumpFailedAgentLogs,\n74: } from \"./launch.js\";\n75: import {\n76:   detectMultiplexer,\n77:   muxAttachCommand,\n78: } from \"../lib/multiplexer.js\";\n79: import { exportWaveHistory } from \"../lib/history.js\";\n80: import { outputError, outputMessage, type OutputFormat } from \"../lib/output.js\";\n81: import {\n82:   prepareAgentDefinitions,\n83:   isSpecializedAgent,\n84:   type AgentResolution,\n85: } from \"../lib/agent-registry.js\";\n86: import { patchImportedAgent } from \"../lib/templates.js\";\n87: import { writeAgentToWorktree } from \"../lib/agent-registry.js\";\n88: import { loadQuest, loadQuestKnowledge } from \"../lib/quest-store.js\";\n89: import { resolveQuestConfig, type QuestHitlMode } from \"../lib/quest.js\";\n90: import { getPendingQuestions, cleanupAll as cleanupHitl, submitAnswer, type HitlQuestion } from \"../lib/hitl-channel.js\";\n91: \n92: // ---------------------------------------------------------------------------\n93: // Types\n94: // ---------------------------------------------------------------------------\n95: \n96: export interface ResumeCommandOptions {\n97:   projectRoot: string;\n98:   config: WomboConfig;\n99:   maxConcurrent?: number;\n100:   model?: string;\n101:   interactive: boolean;\n102:   noTui: boolean;\n103:   autoPush: boolean;\n104:   baseBranch?: string;\n105:   maxRetries?: number;\n106:   outputFmt?: OutputFormat;\n107: }\n108: \n109: // ---------------------------------------------------------------------------\n110: // Command\n111: // ---------------------------------------------------------------------------\n112: \n113: export async function cmdResume(opts: ResumeCommandOptions): Promise<void> {\n114:   const { projectRoot } = opts;\n115:   let { config } = opts;\n116:   const fmt = opts.outputFmt ?? \"text\";\n117: \n118:   const state = loadState(projectRoot);\n119:   if (!state) {\n120:     outputError(fmt, \"No wave state found. Use 'woco launch' to start a new wave.\");\n121:     return; // unreachable — outputError calls process.exit\n122:   }\n123: \n124:   if (fmt === \"text\") {\n125:     console.log(`\\n--- wombo-combo: Resume ${state.wave_id} ---\\n`);\n126:   }\n127: \n128:   // Reconstruct quest context from wave state (if quest-scoped)\n129:   let questContext: QuestPromptContext | undefined;\n130:   let hitlMode: string | undefined;\n131:   if (state.quest_id) {\n132:     const quest = loadQuest(projectRoot, state.quest_id);\n133:     if (quest) {\n134:       config = resolveQuestConfig(config, quest);\n135:       hitlMode = quest.hitlMode;\n136:       const knowledge = loadQuestKnowledge(projectRoot, state.quest_id);\n137:       questContext = {\n138:         questId: quest.id,\n139:         goal: quest.goal,\n140:         addedConstraints: quest.constraints.add ?? [],\n141:         addedForbidden: quest.constraints.ban ?? [],\n142:         knowledge,\n143:       };\n144:       if (fmt === \"text\") {\n145:         console.log(`Quest: ${quest.title} (${quest.id})\\n`);\n146:       }\n147:     } else if (fmt === \"text\") {\n148:       console.warn(`Warning: wave references quest \"${state.quest_id}\" but it was not found.\\n`);\n149:     }\n150:   }\n151: \n152:   // Load feature data for prompt generation\n153:   const data = loadFeatures(projectRoot, config);\n154:   const featureMap = new Map(data.tasks.map((f: Feature) => [f.id, f]));\n155: \n156:   // Triage agents by current state\n157:   let toRelaunch: AgentState[] = [];\n158:   let toVerify: AgentState[] = [];\n159:   let stillAlive: AgentState[] = [];\n160: \n161:   for (const agent of state.agents) {\n162:     switch (agent.status) {\n163:       case \"running\":\n164:       case \"installing\":\n165:       case \"retry\":\n166:       case \"resolving_conflict\":\n167:         // Was in-flight when we stopped — check if PID is still alive\n168:         if (agent.pid && isProcessRunning(agent.pid)) {\n169:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: still running (PID ${agent.pid})`);\n170:           stillAlive.push(agent);\n171:         } else {\n172:           // Process is dead — check if worktree exists with meaningful changes.\n173:           // Use worktreeExists (not worktreeReady) because node_modules may be\n174:           // missing — the worktree still has code that should be verified.\n175:           if (worktreeExists(agent.worktree) && branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n176:             // Worktree exists AND branch has commits — try build verification\n177:             if (fmt === \"text\") console.log(`  ${agent.feature_id}: process dead, worktree has changes — will verify build`);\n178:             toVerify.push(agent);\n179:           } else {\n180:             // No worktree, or worktree exists but branch has no commits (agent did nothing)\n181:             const reason = worktreeExists(agent.worktree)\n182:               ? \"worktree exists but no code changes\"\n183:               : \"no worktree\";\n184:             if (fmt === \"text\") console.log(`  ${agent.feature_id}: process dead, ${reason} — will re-launch`);\n185:             updateAgent(state, agent.feature_id, {\n186:               status: \"queued\",\n187:               pid: null,\n188:               activity: null,\n189:               session_id: null,\n190:             });\n191:             toRelaunch.push(agent);\n192:           }\n193:         }\n194:         break;\n195: \n196:       case \"queued\":\n197:         if (fmt === \"text\") console.log(`  ${agent.feature_id}: queued — will launch`);\n198:         toRelaunch.push(agent);\n199:         break;\n200: \n201:       case \"completed\":\n202:         // Completed but not verified — verify\n203:         if (fmt === \"text\") console.log(`  ${agent.feature_id}: completed — will verify build`);\n204:         toVerify.push(agent);\n205:         break;\n206: \n207:       case \"verified\":\n208:         // Build passed but NOT yet merged — need to attempt merge (+ conflict resolution)\n209:         if (fmt === \"text\") console.log(`  ${agent.feature_id}: verified — will attempt merge`);\n210:         toVerify.push(agent);\n211:         break;\n212: \n213:       case \"merged\":\n214:         if (fmt === \"text\") console.log(`  ${agent.feature_id}: merged — marking feature as done`);\n215:         markFeatureDone(projectRoot, agent.feature_id, config, state.base_branch, fmt);\n216:         try {\n217:           removeWorktree(projectRoot, agent.worktree, true);\n218:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: worktree and branch removed`);\n219:         } catch {\n220:           // Already cleaned — not critical\n221:         }\n222:         break;\n223: \n224:       case \"failed\":\n225:         // If the worktree exists with code changes and retries remain,\n226:         // attempt build verification rather than discarding the work.\n227:         if (agent.retries < agent.max_retries &&\n228:             worktreeExists(agent.worktree) &&\n229:             branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n230:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: failed but has work (retry ${agent.retries}/${agent.max_retries}) — will verify build`);\n231:           // Clear stale error and mark as completed so handleBuildVerification\n232:           // processes it correctly (it expects a non-failed agent)\n233:           updateAgent(state, agent.feature_id, {\n234:             status: \"completed\",\n235:             error: null,\n236:             build_passed: null,\n237:             build_output: null,\n238:             completed_at: new Date().toISOString(),\n239:           });\n240:           toVerify.push(agent);\n241:         } else if (agent.retries < agent.max_retries) {\n242:           // No worktree or no changes — re-launch from scratch\n243:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: failed, no salvageable work (retry ${agent.retries}/${agent.max_retries}) — will re-launch`);\n244:           updateAgent(state, agent.feature_id, {\n245:             status: \"queued\",\n246:             pid: null,\n247:             error: null,\n248:             build_passed: null,\n249:             build_output: null,\n250:             activity: null,\n251:             session_id: null,\n252:             completed_at: null,\n253:           });\n254:           toRelaunch.push(agent);\n255:         } else {\n256:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: failed — max retries reached (use 'woco retry' to reset)`);\n257:         }\n258:         break;\n259:     }\n260:   }\n261: \n262:   saveState(projectRoot, state);\n263: \n264:   // ---------------------------------------------------------------------------\n265:   // Phase 1: Parallel build verification\n266:   // Each agent's worktree is independent, so dep install + build can run\n267:   // concurrently. Merges must remain sequential (they mutate the project root).\n268:   // ---------------------------------------------------------------------------\n269:   if (toVerify.length > 0) {\n270:     if (fmt === \"text\") console.log(`\\nVerifying ${toVerify.length} agent(s) in parallel...\\n`);\n271: \n272:     const verifyResults = await Promise.all(\n273:       toVerify.map(async (agent): Promise<{ agent: AgentState; needsMerge: boolean }> => {\n274:         const feature = featureMap.get(agent.feature_id);\n275:         if (!feature) return { agent, needsMerge: false };\n276: \n277:         // Already verified — skip build, go straight to merge\n278:         if (agent.status === \"verified\") {\n279:           printAgentUpdate(agent, \"already verified — queued for merge\");\n280:           return { agent, needsMerge: true };\n281:         }\n282: \n283:         printAgentUpdate(agent, \"verifying build...\");\n284: \n285:         // Ensure deps are installed — worktree may exist without node_modules\n286:         // (e.g., failed agents whose setup was interrupted)\n287:         if (!worktreeReady(agent.worktree) && worktreeExists(agent.worktree)) {\n288:           try {\n289:             printAgentUpdate(agent, \"installing deps...\");\n290:             await installDeps(agent.worktree, agent.feature_id, config);\n291:           } catch (depErr: any) {\n292:             printAgentUpdate(agent, `dep install failed: ${depErr.message}`);\n293:             updateAgent(state, agent.feature_id, {\n294:               status: \"failed\",\n295:               error: `Dependency install failed: ${depErr.message}`,\n296:               retries: agent.retries + 1,\n297:               completed_at: new Date().toISOString(),\n298:             });\n299:             saveState(projectRoot, state);\n300:             return { agent, needsMerge: false };\n301:           }\n302:         }\n303: \n304:         try {\n305:           const buildResult = await runBuild(agent.worktree, config);\n306:           if (buildResult.passed) {\n307:             updateAgent(state, agent.feature_id, {\n308:               status: \"verified\",\n309:               build_passed: true,\n310:               build_output: null,\n311:             });\n312:             saveState(projectRoot, state);\n313:             printAgentUpdate(agent, `BUILD PASSED (${Math.round(buildResult.durationMs / 1000)}s)`);\n314:             return { agent, needsMerge: true };\n315:           } else {\n316:             // Build failed\n317:             if (agent.retries < agent.max_retries) {\n318:               updateAgent(state, agent.feature_id, {\n319:                 status: \"retry\",\n320:                 retries: agent.retries + 1,\n321:                 build_passed: false,\n322:                 build_output: buildResult.errorSummary,\n323:               });\n324:               saveState(projectRoot, state);\n325:               printAgentUpdate(agent, `BUILD FAILED — will retry (${agent.retries + 1}/${agent.max_retries})`);\n326:             } else {\n327:               updateAgent(state, agent.feature_id, {\n328:                 status: \"failed\",\n329:                 build_passed: false,\n330:                 build_output: buildResult.errorSummary,\n331:                 error: `Build failed after ${agent.max_retries} retries`,\n332:                 completed_at: new Date().toISOString(),\n333:               });\n334:               saveState(projectRoot, state);\n335:               printAgentUpdate(agent, \"BUILD FAILED — max retries reached\");\n336:             }\n337:             return { agent, needsMerge: false };\n338:           }\n339:         } catch (err: any) {\n340:           printAgentUpdate(agent, `verify error: ${err.message}`);\n341:           updateAgent(state, agent.feature_id, {\n342:             status: \"failed\",\n343:             error: `Build verification error: ${err.message}`,\n344:             completed_at: new Date().toISOString(),\n345:           });\n346:           saveState(projectRoot, state);\n347:           return { agent, needsMerge: false };\n348:         }\n349:       })\n350:     );\n351: \n352:     saveState(projectRoot, state);\n353: \n354:     // -------------------------------------------------------------------------\n355:     // Phase 2: Sequential merge for verified agents\n356:     // Merges must be sequential because they operate on the project root.\n357:     // -------------------------------------------------------------------------\n358:     const toMerge = verifyResults.filter((r) => r.needsMerge);\n359:     if (toMerge.length > 0) {\n360:       if (fmt === \"text\") console.log(`\\nMerging ${toMerge.length} verified agent(s)...\\n`);\n361:       for (const { agent } of toMerge) {\n362:         const feature = featureMap.get(agent.feature_id);\n363:         if (!feature) continue;\n364:         try {\n365:           await attemptMerge(projectRoot, state, agent, feature, config, opts.model);\n366:         } catch (err: any) {\n367:           printAgentUpdate(agent, `merge error: ${err.message}`);\n368:         }\n369:       }\n370:     }\n371: \n372:     // Collect agents that need re-launching from verify results\n373:     for (const { agent } of verifyResults) {\n374:       if (agent.status === \"retry\" || agent.status === \"running\") {\n375:         toRelaunch.push(agent);\n376:       }\n377:     }\n378:   }\n379: \n380:   // Re-launch agents\n381:   const maxConcurrent = opts.maxConcurrent ?? state.max_concurrent;\n382:   const toLaunchNow = toRelaunch.slice(0, maxConcurrent);\n383:   if (toLaunchNow.length === 0 && stillAlive.length === 0) {\n384:     outputMessage(fmt, \"No agents need (re)launching.\", {\n385:       wave_id: state.wave_id,\n386:       triage: {\n387:         to_verify: toVerify.length,\n388:         to_relaunch: 0,\n389:       },\n390:       agents: state.agents.map((a) => ({\n391:         feature_id: a.feature_id,\n392:         status: a.status,\n393:         build_passed: a.build_passed,\n394:         error: a.error,\n395:       })),\n396:     });\n397:     if (fmt === \"text\") printDashboard(state);\n398:     return;\n399:   }\n400: \n401:   // ---------------------------------------------------------------------------\n402:   // Re-resolve specialized agents for relaunched tasks that have agent_type\n403:   // ---------------------------------------------------------------------------\n404:   let agentResolutions: Map<string, AgentResolution> | undefined;\n405: \n406:   if (config.agentRegistry.mode !== \"disabled\") {\n407:     const agentsWithType = toLaunchNow.filter((a) => a.agent_type);\n408:     if (agentsWithType.length > 0) {\n409:       // Build feature list for tasks being relaunched\n410:       const featuresToResolve = agentsWithType\n411:         .map((a) => featureMap.get(a.feature_id))\n412:         .filter((f): f is Feature => !!f);\n413:       if (featuresToResolve.length > 0) {\n414:         if (fmt === \"text\") console.log(`\\nRe-resolving ${featuresToResolve.length} specialized agent(s) from registry...`);\n415:         try {\n416:           agentResolutions = await prepareAgentDefinitions(featuresToResolve, config, projectRoot);\n417:         } catch (err: any) {\n418:           if (fmt === \"text\") console.log(`  WARN: agent resolution failed, using cached agent names: ${err.message}`);\n419:         }\n420:       }\n421:     }\n422:   }\n423: \n424:   if (fmt === \"text\") {\n425:     const parts: string[] = [];\n426:     if (toLaunchNow.length > 0) parts.push(`re-launching ${toLaunchNow.length}`);\n427:     if (stillAlive.length > 0) parts.push(`reconnecting ${stillAlive.length}`);\n428:     console.log(`\\n${parts.join(\", \")} agent(s)...\\n`);\n429:     printDashboard(state);\n430:   }\n431:   const model = opts.model ?? state.model ?? undefined;\n432: \n433:   if (opts.interactive) {\n434:     // Interactive resume\n435:     await Promise.all(\n436:       toLaunchNow.map(async (agent) => {\n437:         const feature = featureMap.get(agent.feature_id);\n438:         if (!feature) return;\n439: \n440:         updateAgent(state, agent.feature_id, {\n441:           status: \"installing\",\n442:           started_at: new Date().toISOString(),\n443:           activity: \"resuming...\",\n444:         });\n445:         saveState(projectRoot, state);\n446: \n447:         try {\n448:           if (!worktreeReady(agent.worktree)) {\n449:             await createWorktree(projectRoot, agent.feature_id, state.base_branch, config);\n450:             await installDeps(agent.worktree, agent.feature_id, config);\n451:           }\n452: \n453:           // Write specialized agent to worktree if applicable\n454:           const resolution = agentResolutions?.get(agent.feature_id);\n455:           const agentName = agent.agent_name ?? undefined;\n456:           if (resolution && isSpecializedAgent(resolution)) {\n457:             try {\n458:               const patchedContent = patchImportedAgent(resolution.rawContent, config, projectRoot);\n459:               writeAgentToWorktree(agent.worktree, resolution.name, patchedContent);\n460:               wtLog(agent.feature_id, `wrote specialized agent: ${resolution.name}`);\n461:             } catch (err: any) {\n462:               wtLog(agent.feature_id, `WARN: failed to write specialized agent: ${err.message}`);\n463:             }\n464:           }\n465: \n466:           const prompt = generatePrompt(feature, state.base_branch, config, questContext, hitlMode as QuestHitlMode | undefined);\n467:           const result = launchInteractive({\n468:             worktreePath: agent.worktree,\n469:             featureId: feature.id,\n470:             prompt,\n471:             model,\n472:             interactive: true,\n473:             config,\n474:             agentName,\n475:           });\n476: \n477:           const muxName = getMultiplexerName(config);\n478:           updateAgent(state, agent.feature_id, {\n479:             status: \"running\",\n480:             pid: result.pid,\n481:             activity: `${muxName} session active`,\n482:           });\n483:           saveState(projectRoot, state);\n484:         } catch (err: any) {\n485:           updateAgent(state, agent.feature_id, {\n486:             status: \"failed\",\n487:             error: err.message,\n488:             activity: null,\n489:             completed_at: new Date().toISOString(),\n490:           });\n491:           saveState(projectRoot, state);\n492:         }\n493:       })\n494:     );\n495: \n496:     if (fmt === \"text\") {\n497:       printDashboard(state);\n498:       const mux = detectMultiplexer(config.agent.multiplexer);\n499:       console.log(`\\nResume complete. Use '${muxAttachCommand(mux, `${config.agent.tmuxPrefix}-<id>`)}' to check sessions.`);\n500:     }\n501:   } else {\n502:     // Headless resume — re-enter monitoring loop\n503:     const monitor = new ProcessMonitor(projectRoot, {\n504:       onSessionId: (featureId, sessionId) => {\n505:         updateAgent(state, featureId, { session_id: sessionId });\n506:         saveState(projectRoot, state);\n507:       },\n508:       onComplete: (featureId) => {\n509:         updateAgent(state, featureId, {\n510:           status: \"completed\",\n511:           completed_at: new Date().toISOString(),\n512:           activity: \"done\",\n513:         });\n514:         saveState(projectRoot, state);\n515:         wtLog(featureId, \"agent completed — verifying build...\");\n516: \n517:         const agent = state.agents.find((a) => a.feature_id === featureId)!;\n518:         const feature = featureMap.get(featureId)!;\n519:         handleBuildVerification(projectRoot, state, agent, feature, config, model, monitor, undefined, hitlMode)\n520:           .then(() => launchAllReady(projectRoot, state, featureMap, monitor, config, model, undefined, questContext, hitlMode))\n521:           .catch((err) => {\n522:             wtLog(featureId, `BUILD VERIFICATION UNHANDLED ERROR: ${err.message}`);\n523:             launchAllReady(projectRoot, state, featureMap, monitor, config, model, undefined, questContext, hitlMode);\n524:           });\n525:       },\n526:       onError: (featureId, error) => {\n527:         const agent = state.agents.find((a) => a.feature_id === featureId)!;\n528:         if (agent.retries < agent.max_retries) {\n529:           updateAgent(state, featureId, {\n530:             status: \"retry\",\n531:             retries: agent.retries + 1,\n532:             error,\n533:             activity: \"retrying...\",\n534:           });\n535:           saveState(projectRoot, state);\n536:           handleRetry(projectRoot, state, agent, monitor, config, model, hitlMode);\n537:         } else {\n538:           updateAgent(state, featureId, {\n539:             status: \"failed\",\n540:             error,\n541:             activity: null,\n542:             completed_at: new Date().toISOString(),\n543:           });\n544:           saveState(projectRoot, state);\n545: \n546:           // Cascade failure to downstream agents\n547:           const cancelled = cancelDownstream(state, featureId);\n548:           if (cancelled.length > 0) {\n549:             wtLog(featureId, `downstream cancelled: ${cancelled.join(\", \")}`);\n550:             saveState(projectRoot, state);\n551:           }\n552:         }\n553:         launchAllReady(projectRoot, state, featureMap, monitor, config, model, undefined, questContext, hitlMode);\n554:       },\n555:       onActivity: (featureId, activity) => {\n556:         updateAgent(state, featureId, {\n557:           activity,\n558:           activity_updated_at: new Date().toISOString(),\n559:         });\n560:       },\n561:     });\n562: \n563:     // Handle graceful shutdown\n564:     // Audit (wave-detach-audit): Same pattern as launch.ts — see launch.ts\n565:     // SIGINT handler for detailed lifecycle documentation. Agents are\n566:     // non-detached children; killAll() gives them SIGTERM before exit.\n567:     const tuiRef = { current: null as WomboTUI | null };\n568:     const gracefulShutdown = (signal: string) => {\n569:       if (tuiRef.current) tuiRef.current.stop();\n570:       for (const agent of state.agents) {\n571:         if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n572:           updateAgent(state, agent.feature_id, {\n573:             activity: \"interrupted\",\n574:           });\n575:         }\n576:       }\n577:       monitor.killAll();\n578:       flushState(projectRoot, state);\n579:       if (fmt === \"text\") console.log(`\\nState saved (${signal}). Use 'woco resume' to continue.`);\n580:       process.exit(0);\n581:     };\n582:     process.on(\"SIGINT\", () => gracefulShutdown(\"SIGINT\"));\n583:     process.on(\"SIGTERM\", () => gracefulShutdown(\"SIGTERM\"));\n584:     process.on(\"SIGHUP\", () => gracefulShutdown(\"SIGHUP\"));\n585: \n586:     // Reconnect to agents that are still alive — register them in the monitor\n587:     // so the TUI shows their activity and the polling loop detects their death.\n588:     for (const agent of stillAlive) {\n589:       monitor.reconnectProcess(agent.feature_id, agent.pid!, agent.session_id);\n590:       if (fmt === \"text\") console.log(`  ${agent.feature_id}: reconnected to PID ${agent.pid}`);\n591:     }\n592: \n593:     await Promise.all(\n594:       toLaunchNow.map((agent) => {\n595:         const feature = featureMap.get(agent.feature_id);\n596:         if (!feature) return Promise.resolve();\n597:         return launchSingleHeadless(projectRoot, state, agent, feature, monitor, config, model, agentResolutions, questContext, hitlMode);\n598:       })\n599:     );\n600: \n601:     // Start TUI dashboard (or skip if --no-tui)\n602:     if (!opts.noTui) {\n603:       tuiRef.current = new WomboTUI({\n604:         state,\n605:         monitor,\n606:         projectRoot,\n607:         interactive: false,\n608:         config,\n609:         onQuit: () => {\n610:           // Audit (wave-detach-audit): Same killAll() + flushState pattern as\n611:           // launch.ts onQuit. See launch.ts for full lifecycle documentation.\n612:           for (const agent of state.agents) {\n613:             if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n614:               updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n615:             }\n616:           }\n617:           monitor.killAll();\n618:           flushState(projectRoot, state);\n619:           if (fmt === \"text\") console.log(\"State saved. Use 'woco resume' to continue.\");\n620:           process.exit(0);\n621:         },\n622:         onBeforeDestroy: () => {\n623:           // Flush state to disk before the blessed screen is destroyed.\n624:           flushState(projectRoot, state);\n625:         },\n626:         onRetry: (featureId: string) => {\n627:           const agent = state.agents.find((a) => a.feature_id === featureId);\n628:           if (!agent) return;\n629:           if (agent.status !== \"failed\" && agent.status !== \"retry\") return;\n630: \n631:           // Reset retries if exhausted, give it one more shot\n632:           if (agent.retries >= agent.max_retries) {\n633:             updateAgent(state, featureId, { max_retries: agent.retries + 1 });\n634:           }\n635: \n636:           wtLog(featureId, `manual retry requested from TUI — resetting to queued`);\n637:           updateAgent(state, featureId, {\n638:             status: \"queued\",\n639:             error: null,\n640:             activity: \"waiting for relaunch (manual retry)...\",\n641:           });\n642:           saveState(projectRoot, state);\n643:         },\n644:         onAnswer: (agentId: string, questionId: string, answerText: string) => {\n645:           try {\n646:             submitAnswer(projectRoot, agentId, questionId, answerText);\n647:             wtLog(agentId, `HITL answer submitted: \"${answerText.slice(0, 80)}${answerText.length > 80 ? \"...\" : \"\"}\"`);\n648:           } catch (err: any) {\n649:             wtLog(agentId, `HITL answer error: ${err.message}`);\n650:           }\n651:         },\n652:       });\n653:       tuiRef.current.start();\n654:     } else {\n655:       if (fmt === \"text\") console.log(\"(--no-tui mode, dashboard prints every 15s)\\n\");\n656:       printDashboard(state);\n657:     }\n658: \n659:     // Monitoring loop\n660:     const POLL_INTERVAL = 5000;\n661:     let dashboardCounter = 0;\n662:     while (!isWaveComplete(state)) {\n663:       await new Promise((r) => setTimeout(r, POLL_INTERVAL));\n664: \n665:       for (const agent of state.agents) {\n666:         if (\n667:           (agent.status === \"running\" || agent.status === \"resolving_conflict\") &&\n668:           agent.pid &&\n669:           !isProcessRunning(agent.pid) &&\n670:           !monitor.isRunning(agent.feature_id)\n671:         ) {\n672:           if (agent.status === \"resolving_conflict\") {\n673:             // Conflict resolver died unexpectedly — mark as failed\n674:             updateAgent(state, agent.feature_id, {\n675:               status: \"failed\",\n676:               error: \"Conflict resolver process died unexpectedly\",\n677:               activity: null,\n678:               completed_at: new Date().toISOString(),\n679:             });\n680:             saveState(projectRoot, state);\n681:             wtLog(agent.feature_id, \"conflict resolver died — marked failed\");\n682: \n683:             // Cascade failure to downstream agents\n684:             const cancelled = cancelDownstream(state, agent.feature_id);\n685:             if (cancelled.length > 0) {\n686:               wtLog(agent.feature_id, `downstream cancelled: ${cancelled.join(\", \")}`);\n687:               saveState(projectRoot, state);\n688:             }\n689: \n690:             launchAllReady(projectRoot, state, featureMap, monitor, config, model, undefined, questContext, hitlMode);\n691:             continue;\n692:           }\n693:           // Check if the agent actually made any commits\n694:           if (!branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n695:             // Agent died without producing any code — mark as failed\n696:             updateAgent(state, agent.feature_id, {\n697:               status: \"failed\",\n698:               error: \"Agent process exited without making any commits\",\n699:               activity: null,\n700:               completed_at: new Date().toISOString(),\n701:             });\n702:             saveState(projectRoot, state);\n703:             wtLog(agent.feature_id, \"process died with no code changes — marked failed\");\n704: \n705:             // Cascade failure to downstream agents\n706:             const cancelled = cancelDownstream(state, agent.feature_id);\n707:             if (cancelled.length > 0) {\n708:               wtLog(agent.feature_id, `downstream cancelled: ${cancelled.join(\", \")}`);\n709:               saveState(projectRoot, state);\n710:             }\n711:           } else {\n712:             updateAgent(state, agent.feature_id, {\n713:               status: \"completed\",\n714:               completed_at: new Date().toISOString(),\n715:               activity: \"done\",\n716:             });\n717:             saveState(projectRoot, state);\n718:             const feature = featureMap.get(agent.feature_id)!;\n719:             try {\n720:               await handleBuildVerification(projectRoot, state, agent, feature, config, model, monitor, undefined, hitlMode);\n721:             } catch (err: any) {\n722:               wtLog(agent.feature_id, `POLL VERIFY ERROR: ${err.message}`);\n723:             }\n724:           }\n725:           launchAllReady(projectRoot, state, featureMap, monitor, config, model, undefined, questContext, hitlMode);\n726:         }\n727:       }\n728: \n729:       saveState(projectRoot, state);\n730: \n731:       // Poll for HITL questions from agents and forward to TUI\n732:       if (hitlMode && hitlMode !== \"yolo\") {\n733:         try {\n734:           const pendingQuestions = getPendingQuestions(projectRoot);\n735:           if (tuiRef.current && pendingQuestions.length > 0) {\n736:             tuiRef.current.setPendingQuestions(pendingQuestions);\n737:           }\n738:         } catch {\n739:           // Non-fatal — HITL dir may not exist yet\n740:         }\n741:       }\n742: \n743:       if (tuiRef.current) {\n744:         tuiRef.current.updateState(state);\n745:       } else if (opts.noTui) {\n746:         dashboardCounter++;\n747:         if (dashboardCounter % 3 === 0) {\n748:           printDashboard(state);\n749:         }\n750:       }\n751:     }\n752: \n753:     // Wave complete — keep TUI open for post-mortem browsing\n754:     if (tuiRef.current) {\n755:       tuiRef.current.updateState(state);\n756:       tuiRef.current.markWaveComplete();\n757:       await tuiRef.current.waitForQuit();\n758:     }\n759: \n760:     if (fmt === \"text\") {\n761:       printDashboard(state);\n762: \n763:       // Dump full logs for failed agents (post-mortem)\n764:       dumpFailedAgentLogs(projectRoot, state, fmt);\n765:     }\n766: \n767:     // Clean up HITL files\n768:     try {\n769:       cleanupHitl(projectRoot);\n770:     } catch {\n771:       // Non-fatal\n772:     }\n773: \n774:     // Auto-export wave history\n775:     try {\n776:       const historyPath = exportWaveHistory(projectRoot, state);\n777:       if (fmt === \"text\") console.log(`Wave history exported to ${historyPath}`);\n778:     } catch (err: any) {\n779:       if (fmt === \"text\") console.error(`Warning: failed to export wave history: ${err.message}`);\n780:     }\n781: \n782:     // Auto-push base branch if requested\n783:     if (opts.autoPush) {\n784:       await pushBaseBranch(projectRoot, state.base_branch, config);\n785:     }\n786: \n787:     if (fmt === \"text\") console.log(\"Wave complete.\");\n788:   }\n789: }\n\n(End of file - total 789 lines)\n</content>","title":"src/commands/resume.ts","metadata":{"preview":"/**\n * resume.ts — Resume a previously stopped wave.\n *\n * Usage: woco resume [options] [--output json]\n *\n * Restores from .wombo-combo/state.json:\n *   - Agents in \"running\"/\"installing\" whose PID is dead → re-check or re-launch\n *   - Agents in \"queued\" → launch them\n *   - Agents in terminal states (verified/failed/merged) → leave alone\n *\n * ## Agent Recovery (audit: wave-detach-audit)\n *\n * This is the primary recovery mechanism for agents that died when the parent\n * process was terminated (gracefully via SIGINT, or ungracefully via SIGKILL/crash).\n *\n * Recovery triage for each agent:\n *   - PID still alive → leave it running (another wombo instance may still be active)\n *   - PID dead + worktree has commits → run build verification on existing work\n *   - PID dead + no commits → reset to \"queued\" for a fresh re-launch\n *   - \"completed\" → verify build","truncated":false,"loaded":[]},"time":{"start":1773483626644,"end":1773483626648}}}}
