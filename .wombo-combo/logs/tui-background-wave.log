ent(resolution)) {\n1950:       agent.agent_name = resolution.name;\n1951:       agent.agent_type = resolution.agentType;\n1952:     }\n1953: \n1954:     // Per-task local agent override: CLI --agent flag takes precedence,\n1955:     // then task-level `agent` field, then registry resolution (above).\n1956:     // This is for local agent definitions in .opencode/agents/<name>.md.\n1957:     const localAgent = opts.agent ?? feature.agent;\n1958:     if (localAgent && !agent.agent_name) {\n1959:       // Only set if not already resolved from the external registry\n1960:       agent.agent_name = localAgent;\n1961:     } else if (opts.agent) {\n1962:       // CLI --agent flag overrides even registry agents\n1963:       agent.agent_name = opts.agent;\n1964:     }\n1965: \n1966:     state.agents.push(agent);\n1967:   }\n1968: \n1969:   saveState(projectRoot, state);\n1970:   if (fmt === \"text\") console.log(`Wave ${state.wave_id} created with ${selected.length} agents.`);\n1971: \n1972:   // Launch agents up to max_concurrent\n1973:   if (opts.interactive) {\n1974:     await launchWaveInteractive(projectRoot, state, selected, opts, agentResolutions, questContext, hitlMode);\n1975:   } else {\n1976:     await launchWaveHeadless(projectRoot, state, selected, opts, agentResolutions, questContext, hitlMode);\n1977:   }\n1978: }\n\n(End of file - total 1978 lines)\n</content>","title":"src/commands/launch.ts","metadata":{"preview":"    const historyPath = exportWaveHistory(projectRoot, state);\n    if (fmt === \"text\") console.log(`Wave history exported to ${historyPath}`);\n  } catch (err: any) {\n    if (fmt === \"text\") console.error(`Warning: failed to export wave history: ${err.message}`);\n  }\n\n  // Auto-push base branch if requested\n  if (opts.autoPush) {\n    await pushBaseBranch(projectRoot, state.base_branch, config);\n  }\n\n  // Completion double-check: verify worktrees directory is empty\n  if (fmt === \"text\") {\n    if (isWorktreesDirEmpty(projectRoot)) {\n      console.log(\"All worktrees cleaned up — worktrees directory is empty.\");\n    } else {\n      console.log(\"\\x1b[33mNote:\\x1b[0m worktrees directory still has contents. Run 'woco cleanup' to clean up.\");\n    }\n\n    console.log(\"Wave complete.\");","truncated":false,"loaded":[]},"time":{"start":1773484327832,"end":1773484327835}}}}
