{"type":"tool_use","timestamp":1773483703418,"sessionID":"ses_31423da25ffebo9V1CTFH0IpgT","part":{"id":"prt_cebddba9b001GtbIJonDLpvU3I","sessionID":"ses_31423da25ffebo9V1CTFH0IpgT","messageID":"msg_cebdda6800018Lwd1UbrYBDHPy","type":"tool","callID":"toolu_vrtx_01RHSNiyDj7Rt2SEHoyyZyKK","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/wave-detach-audit/src/commands/tui.ts","offset":100,"limit":80},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/wave-detach-audit/src/commands/tui.ts</path>\n<type>file</type>\n<content>100: // Command -- Main Loop\n101: // ---------------------------------------------------------------------------\n102: \n103: export async function cmdTui(opts: TUICommandOptions): Promise<void> {\n104:   const { projectRoot, config } = opts;\n105: \n106:   // Ensure tasks file exists\n107:   await ensureTasksFile(projectRoot, config);\n108: \n109:   // Load session state (persisted selections, sort, concurrency)\n110:   const session = loadTUISession(projectRoot);\n111: \n112:   // Apply concurrency override from CLI if provided\n113:   if (opts.maxConcurrent !== undefined) {\n114:     session.maxConcurrent = opts.maxConcurrent;\n115:   }\n116: \n117:   // Main TUI loop:\n118:   //   Quest Picker -> Task Browser -> Launch -> Monitor -> back to Quest Picker\n119:   // Only exits when the user presses Q from the Quest Picker (or browser if no quests).\n120:   while (true) {\n121:     // Check for an active wave on each iteration\n122:     const existingState = loadState(projectRoot);\n123:     const hasRunningWave =\n124:       existingState !== null &&\n125:       existingState.agents.some(\n126:         (a) =>\n127:           a.status === \"running\" ||\n128:           a.status === \"queued\" ||\n129:           a.status === \"installing\" ||\n130:           a.status === \"resolving_conflict\" ||\n131:           a.status === \"retry\"\n132:       );\n133: \n134:     if (hasRunningWave) {\n135:       // A wave is already running -- resume it (wave monitor TUI).\n136:       // When the wave completes and the user presses Q, cmdResume returns\n137:       // and we loop back to the quest picker / browser.\n138:       console.log(\n139:         `Active wave detected: ${existingState!.wave_id}. Resuming...`\n140:       );\n141:       try {\n142:         await cmdResume({\n143:           projectRoot,\n144:           config,\n145:           maxConcurrent: opts.maxConcurrent,\n146:           model: opts.model,\n147:           interactive: false,\n148:           noTui: false,\n149:           autoPush: opts.autoPush ?? false,\n150:           baseBranch: opts.baseBranch,\n151:           maxRetries: opts.maxRetries,\n152:         });\n153:       } catch (err: any) {\n154:         // Don't crash -- show error and loop back\n155:         console.error(`\\nResume error: ${err.message}\\n`);\n156:         await sleep(2000);\n157:       }\n158:       // Clear terminal before showing picker/browser again\n159:       process.stdout.write(\"\\x1B[2J\\x1B[H\");\n160:       continue;\n161:     }\n162: \n163:     // -----------------------------------------------------------------------\n164:     // Quest Picker (skip if no quests exist)\n165:     // -----------------------------------------------------------------------\n166:     const quests = loadAllQuests(projectRoot);\n167:     const hasQuests = quests.length > 0;\n168: \n169:     let selectedQuestId: string | null = null;\n170: \n171:     if (hasQuests) {\n172:       const questAction = await showQuestPicker(projectRoot, config, opts);\n173: \n174:       if (questAction.type === \"quit\") {\n175:         // User pressed Q in quest picker -- exit cleanly\n176:         session.lastView = \"browser\";\n177:         saveTUISession(projectRoot, session);\n178:         break;\n179:       }\n\n(Showing lines 100-179 of 1017. Use offset=180 to continue.)\n</content>","title":"src/commands/tui.ts","metadata":{"preview":"// Command -- Main Loop\n// ---------------------------------------------------------------------------\n\nexport async function cmdTui(opts: TUICommandOptions): Promise<void> {\n  const { projectRoot, config } = opts;\n\n  // Ensure tasks file exists\n  await ensureTasksFile(projectRoot, config);\n\n  // Load session state (persisted selections, sort, concurrency)\n  const session = loadTUISession(projectRoot);\n\n  // Apply concurrency override from CLI if provided\n  if (opts.maxConcurrent !== undefined) {\n    session.maxConcurrent = opts.maxConcurrent;\n  }\n\n  // Main TUI loop:\n  //   Quest Picker -> Task Browser -> Launch -> Monitor -> back to Quest Picker\n  // Only exits when the user presses Q from the Quest Picker (or browser if no quests).","truncated":true,"loaded":[]},"time":{"start":1773483703415,"end":1773483703418}}}}
