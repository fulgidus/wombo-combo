{"type":"tool_use","timestamp":1773484171825,"sessionID":"ses_31423da25ffebo9V1CTFH0IpgT","part":{"id":"prt_cebe4df52001Rzm332ilitWFNm","sessionID":"ses_31423da25ffebo9V1CTFH0IpgT","messageID":"msg_cebe4d10f001beHKMiyLa9Uu7C","type":"tool","callID":"toolu_vrtx_014z35UpqgGKvVxHhKeE8zEp","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/wave-detach-audit/src/commands/launch.ts","limit":25,"offset":1170},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/wave-detach-audit/src/commands/launch.ts</path>\n<type>file</type>\n<content>1170:   //\n1171:   // Audit (wave-detach-audit): This is the critical shutdown path for headless\n1172:   // agents. Because agents are spawned with `detached: false` (see launcher.ts),\n1173:   // they would be killed by the OS when the parent exits anyway. However, calling\n1174:   // `monitor.killAll()` explicitly before `process.exit(0)` ensures:\n1175:   //   1. Each agent gets SIGTERM (not SIGKILL), allowing graceful shutdown\n1176:   //   2. Wave state is saved BEFORE agents die, preserving progress\n1177:   //   3. The TUI is cleanly destroyed before terminal restoration\n1178:   //\n1179:   // If the parent is killed with SIGKILL (uncatchable), agents die immediately\n1180:   // with no state save. `woco resume` recovers from this by detecting orphaned\n1181:   // worktrees with commits and re-verifying or re-launching as appropriate.\n1182:   const gracefulShutdown = (signal: string) => {\n1183:     if (tuiRef.current) tuiRef.current.stop();\n1184:     for (const agent of state.agents) {\n1185:       if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n1186:         updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n1187:       }\n1188:     }\n1189:     monitor.killAll();\n1190:     flushState(projectRoot, state);\n1191:     if (fmt === \"text\") console.log(`\\nState saved (${signal}). Use 'woco resume' to continue.`);\n1192:     process.exit(0);\n1193:   };\n1194:   process.on(\"SIGINT\", () => gracefulShutdown(\"SIGINT\"));\n\n(Showing lines 1170-1194 of 1959. Use offset=1195 to continue.)\n</content>","title":"src/commands/launch.ts","metadata":{"preview":"  //\n  // Audit (wave-detach-audit): This is the critical shutdown path for headless\n  // agents. Because agents are spawned with `detached: false` (see launcher.ts),\n  // they would be killed by the OS when the parent exits anyway. However, calling\n  // `monitor.killAll()` explicitly before `process.exit(0)` ensures:\n  //   1. Each agent gets SIGTERM (not SIGKILL), allowing graceful shutdown\n  //   2. Wave state is saved BEFORE agents die, preserving progress\n  //   3. The TUI is cleanly destroyed before terminal restoration\n  //\n  // If the parent is killed with SIGKILL (uncatchable), agents die immediately\n  // with no state save. `woco resume` recovers from this by detecting orphaned\n  // worktrees with commits and re-verifying or re-launching as appropriate.\n  const gracefulShutdown = (signal: string) => {\n    if (tuiRef.current) tuiRef.current.stop();\n    for (const agent of state.agents) {\n      if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n        updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n      }\n    }\n    monitor.killAll();","truncated":true,"loaded":[]},"time":{"start":1773484171820,"end":1773484171824}}}}
