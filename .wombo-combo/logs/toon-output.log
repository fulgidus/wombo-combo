{"type":"tool_use","timestamp":1773439952203,"sessionID":"ses_316be8edcffeznA8v4atF4wsHM","part":{"id":"prt_ce9422029001bwCTuMoU1clw0K","sessionID":"ses_316be8edcffeznA8v4atF4wsHM","messageID":"msg_ce9420c69001f9H7CY04IS7Yvq","type":"tool","callID":"toolu_vrtx_018dSCDcbkb52UFUMmYVmWAE","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/toon-output/src/commands/tasks/set-priority.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/toon-output/src/commands/tasks/set-priority.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tasks/set-priority.ts — Change a task's priority.\n3:  *\n4:  * Usage:\n5:  *   woco tasks set-priority <task-id> <priority>\n6:  *\n7:  * Valid priorities: critical, high, medium, low, wishlist\n8:  *\n9:  * Supports --output json and --dry-run.\n10:  * Works on both top-level tasks and subtasks.\n11:  */\n12: \n13: import type { WomboConfig } from \"../../config.js\";\n14: import {\n15:   loadFeatures,\n16:   saveFeatures,\n17:   findFeatureById,\n18:   type Priority,\n19: } from \"../../lib/tasks.js\";\n20: import { VALID_PRIORITIES } from \"../../lib/task-schema.js\";\n21: import { outputError, outputMessage, type OutputFormat } from \"../../lib/output.js\";\n22: \n23: // ---------------------------------------------------------------------------\n24: // Types\n25: // ---------------------------------------------------------------------------\n26: \n27: export interface TasksSetPriorityOptions {\n28:   projectRoot: string;\n29:   config: WomboConfig;\n30:   featureId: string;\n31:   newPriority: string;\n32:   outputFmt?: OutputFormat;\n33:   dryRun?: boolean;\n34: }\n35: \n36: // ---------------------------------------------------------------------------\n37: // Command\n38: // ---------------------------------------------------------------------------\n39: \n40: export async function cmdTasksSetPriority(opts: TasksSetPriorityOptions): Promise<void> {\n41:   const { projectRoot, config } = opts;\n42:   const fmt = opts.outputFmt ?? \"text\";\n43: \n44:   if (!opts.featureId || !opts.newPriority) {\n45:     outputError(fmt, `Usage: woco tasks set-priority <task-id> <priority>\\nValid priorities: ${VALID_PRIORITIES.join(\", \")}`);\n46:     return;\n47:   }\n48: \n49:   // Validate priority\n50:   if (!(VALID_PRIORITIES as readonly string[]).includes(opts.newPriority)) {\n51:     outputError(fmt, `Invalid priority: \"${opts.newPriority}\"\\nValid priorities: ${VALID_PRIORITIES.join(\", \")}`);\n52:     return;\n53:   }\n54: \n55:   const data = loadFeatures(projectRoot, config);\n56:   const feature = findFeatureById(data, opts.featureId);\n57: \n58:   if (!feature) {\n59:     outputError(fmt, `Task \"${opts.featureId}\" not found.`);\n60:     return;\n61:   }\n62: \n63:   const oldPriority = feature.priority;\n64:   const newPriority = opts.newPriority as Priority;\n65: \n66:   if (oldPriority === newPriority) {\n67:     outputMessage(fmt, `Task \"${opts.featureId}\" already has priority \"${newPriority}\".`, {\n68:       id: opts.featureId,\n69:       priority: newPriority,\n70:       changed: false,\n71:     });\n72:     return;\n73:   }\n74: \n75:   // Dry-run: show what would change without writing\n76:   if (opts.dryRun) {\n77:     outputMessage(fmt, `[dry-run] Would change \"${opts.featureId}\" priority: ${oldPriority} → ${newPriority}`, {\n78:       dry_run: true,\n79:       id: opts.featureId,\n80:       old_priority: oldPriority,\n81:       new_priority: newPriority,\n82:       changed: false,\n83:     });\n84:     return;\n85:   }\n86: \n87:   // Apply priority change\n88:   feature.priority = newPriority;\n89: \n90:   saveFeatures(projectRoot, config, data);\n91: \n92:   outputMessage(fmt, `Task \"${opts.featureId}\" priority: ${oldPriority} → ${newPriority}`, {\n93:     id: opts.featureId,\n94:     old_priority: oldPriority,\n95:     new_priority: newPriority,\n96:     changed: true,\n97:   });\n98: }\n\n(End of file - total 98 lines)\n</content>","title":"src/commands/tasks/set-priority.ts","metadata":{"preview":"/**\n * tasks/set-priority.ts — Change a task's priority.\n *\n * Usage:\n *   woco tasks set-priority <task-id> <priority>\n *\n * Valid priorities: critical, high, medium, low, wishlist\n *\n * Supports --output json and --dry-run.\n * Works on both top-level tasks and subtasks.\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  saveFeatures,\n  findFeatureById,\n  type Priority,\n} from \"../../lib/tasks.js\";\nimport { VALID_PRIORITIES } from \"../../lib/task-schema.js\";","truncated":false,"loaded":[]},"time":{"start":1773439952200,"end":1773439952202}}}}
