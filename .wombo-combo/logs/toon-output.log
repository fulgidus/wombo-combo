{"type":"tool_use","timestamp":1773440692243,"sessionID":"ses_316b2af3bffeauPmrTvOGPlpJe","part":{"id":"prt_ce94d6fb5001Td5R4skReWo0RY","sessionID":"ses_316b2af3bffeauPmrTvOGPlpJe","messageID":"msg_ce94d662d001e2i85z1Dnx941R","type":"tool","callID":"toolu_vrtx_01C7YFXTGskFm2bwQeU4tRfs","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/toon-output/src/index.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/toon-output/src/index.ts</path>\n<type>file</type>\n<content>1: #!/usr/bin/env bun\n2: /**\n3:  * index.ts — CLI entry point for the wombo-combo agent orchestration system.\n4:  *\n5:  * Every command has a short alias (e.g., woco i = woco init, woco t ls = woco tasks list).\n6:  *\n7:  * Usage:\n8:  *   woco init                                         (alias: i)\n9:  *   woco launch --top-priority 3                      (alias: l)\n10:  *   woco launch --quickest-wins 5\n11:  *   woco launch --priority high\n12:  *   woco launch --difficulty easy\n13:  *   woco launch --tasks \"feat-a,feat-b\"\n14:  *   woco launch --all-ready\n15:  *   woco launch ... --max-concurrent 3 --model \"anthropic/claude-sonnet-4-20250514\"\n16:  *   woco launch ... --interactive\n17:  *   woco resume                                       (alias: r)\n18:  *   woco status                                       (alias: s)\n19:  *   woco verify [feature-id]                          (alias: v)\n20:  *   woco merge [feature-id]                           (alias: m)\n21:  *   woco retry <feature-id>                           (alias: re)\n22:  *   woco abort <feature-id> [--requeue] [--output json]  (alias: a)\n23:  *   woco logs <feature-id> [--tail N] [--follow]      (alias: lo)\n24:  *   woco cleanup                                      (alias: c)\n25:  *   woco history [wave-id] [--output json]            (alias: h)\n26:  *   woco tasks list [--status <s>] [--priority <p>]   (alias: t ls)\n27:  *   woco tasks add <id> <title> [options]             (alias: t a)\n28:  *   woco tasks set-status <task-id> <status>          (alias: t ss)\n29:  *   woco tasks set-priority <task-id> <priority>      (alias: t sp)\n30:  *   woco tasks set-difficulty <task-id> <difficulty>   (alias: t sd)\n31:  *   woco tasks check                                  (alias: t ch)\n32:  *   woco tasks archive [task-id] [--dry-run]          (alias: t ar)\n33:  *   woco tasks show <task-id>                         (alias: t sh)\n34:  *   woco tasks graph [--ascii] [--mermaid]            (alias: t g)\n35:  *   woco completion <bash|zsh|fish>                   (alias: comp)\n36:  *   woco help\n37:  *   woco version\n38:  *   woco -v\n39:  */\n40: \n41: import { resolve } from \"node:path\";\n42: import { existsSync, readFileSync } from \"node:fs\";\n43: import { loadConfig, validateConfig } from \"./config.js\";\n44: import { loadState, saveState } from \"./lib/state.js\";\n45: \n46: // ---------------------------------------------------------------------------\n47: // Dev-mode guard: warn if running the global binary inside the wombo-combo repo\n48: // ---------------------------------------------------------------------------\n49: \n50: function checkDevModeGuard(): void {\n51:   const cwd = process.cwd();\n52:   const pkgPath = resolve(cwd, \"package.json\");\n53: \n54:   // Are we inside the wombo-combo repo?\n55:   if (!existsSync(pkgPath)) return;\n56: \n57:   let pkgName: string | undefined;\n58:   try {\n59:     const raw = readFileSync(pkgPath, \"utf-8\");\n60:     pkgName = JSON.parse(raw).name;\n61:   } catch {\n62:     return;\n63:   }\n64:   if (pkgName !== \"wombo-combo\") return;\n65: \n66:   // We're in the wombo-combo repo. Is the source being run from a different location?\n67:   // import.meta.dir = directory of THIS file (index.ts). If it's under cwd,\n68:   // we're running local source (bun dev). If it's elsewhere (e.g. ~/.bun/install),\n69:   // we're running the globally installed binary.\n70:   const sourceDir = resolve(import.meta.dir);\n71:   const projectSrc = resolve(cwd, \"src\");\n72: \n73:   if (!sourceDir.startsWith(projectSrc)) {\n74:     console.warn(\n75:       \"\\x1b[33m[WARNING]\\x1b[0m You are running the globally installed woco binary \" +\n76:       \"inside the wombo-combo repo.\\n\" +\n77:       \"  Use \\x1b[1mbun dev <command>\\x1b[0m instead to run from local source.\\n\" +\n78:       \"  See AGENTS.md for details.\\n\"\n79:     );\n80:   }\n81: }\n82: \n83: import { cmdInit } from \"./commands/init.js\";\n84: import { cmdLaunch } from \"./commands/launch.js\";\n85: import { cmdResume } from \"./commands/resume.js\";\n86: import { cmdStatus } from \"./commands/status.js\";\n87: import { cmdVerify } from \"./commands/verify.js\";\n88: import { cmdMerge } from \"./commands/merge.js\";\n89: import { cmdRetry } from \"./commands/retry.js\";\n90: import { cmdCleanup } from \"./commands/cleanup.js\";\n91: import { cmdAbort } from \"./commands/abort.js\";\n92: import { cmdLogs } from \"./commands/logs.js\";\n93: import { cmdUpgrade } from \"./commands/upgrade.js\";\n94: import { cmdHistory } from \"./commands/history.js\";\n95: import { cmdCompletion } from \"./commands/completion.js\";\n96: import { cmdTasksList } from \"./commands/tasks/list.js\";\n97: import { cmdTasksAdd } from \"./commands/tasks/add.js\";\n98: import { cmdTasksSetStatus } from \"./commands/tasks/set-status.js\";\n99: import { cmdTasksSetPriority } from \"./commands/tasks/set-priority.js\";\n100: import { cmdTasksSetDifficulty } from \"./commands/tasks/set-difficulty.js\";\n101: import { cmdTasksCheck } from \"./commands/tasks/check.js\";\n102: import { cmdTasksArchive } from \"./commands/tasks/archive.js\";\n103: import { cmdTasksShow } from \"./commands/tasks/show.js\";\n104: import { cmdTasksGraph } from \"./commands/tasks/graph.js\";\n105: \n106: import { ensureTasksFile } from \"./lib/tasks.js\";\n107: import type { Priority, Difficulty, FeatureStatus } from \"./lib/tasks.js\";\n108: import { resolveOutputFormat, type OutputFormat } from \"./lib/output.js\";\n109: import { validateId, validateText, validateBranchName, validateDuration, assertValid } from \"./lib/validate.js\";\n110: import { findCommandDef, commandToSchema, allCommandSchemas } from \"./lib/schema.js\";\n111: import { buildToonSpec, renderToonLegend } from \"./lib/toon-spec.js\";\n112: \n113: // ---------------------------------------------------------------------------\n114: // Types\n115: // ---------------------------------------------------------------------------\n116: \n117: export interface CLIArgs {\n118:   command: string;\n119:   subcommand?: string;\n120:   // Selection options (launch)\n121:   topPriority?: number;\n122:   quickestWins?: number;\n123:   priority?: Priority;\n124:   difficulty?: Difficulty;\n125:   tasks?: string[];\n126:   allReady?: boolean;\n127:   // Launch / runtime options\n128:   maxConcurrent?: number;\n129:   model?: string;\n130:   interactive: boolean;\n131:   dryRun: boolean;\n132:   baseBranch?: string;\n133:   maxRetries?: number;\n134:   noTui: boolean;\n135:   autoPush: boolean;\n136:   // Abort options\n137:   requeue: boolean;\n138:   // General\n139:   featureId?: string;\n140:   force: boolean;\n141:   // Output format\n142:   outputFmt: OutputFormat;\n143:   // Upgrade options\n144:   checkOnly: boolean;\n145:   tag?: string;\n146:   // Features subcommand extras\n147:   status?: string;\n148:   ready?: boolean;\n149:   includeArchive?: boolean;\n150:   title?: string;\n151:   description?: string;\n152:   effort?: string;\n153:   dependsOn?: string[];\n154:   // Logs options\n155:   tail?: number;\n156:   follow?: boolean;\n157:   // Compact output\n158:   fields?: string[];\n159:   // Graph options\n160:   ascii?: boolean;\n161:   mermaidRaw?: boolean;\n162:   graphSubtasks?: boolean;\n163:   // Browser verification\n164:   browser?: boolean;\n165:   // TDD verification\n166:   skipTests?: boolean;\n167:   strictTdd?: boolean;\n168:   // Agent selection (per-task override)\n169:   agent?: string;\n170: }\n171: \n172: // ---------------------------------------------------------------------------\n173: // Command & Subcommand Aliases\n174: // ---------------------------------------------------------------------------\n175: \n176: /** Map of short aliases → canonical top-level command names. */\n177: export const COMMAND_ALIASES: Record<string, string> = {\n178:   i: \"init\",\n179:   l: \"launch\",\n180:   r: \"resume\",\n181:   s: \"status\",\n182:   v: \"verify\",\n183:   m: \"merge\",\n184:   re: \"retry\",\n185:   a: \"abort\",\n186:   c: \"cleanup\",\n187:   h: \"history\",\n188:   lo: \"logs\",\n189:   t: \"tasks\",\n190:   features: \"tasks\", // backward-compat full-word alias\n191:   u: \"upgrade\",\n192:   d: \"describe\",\n193:   comp: \"completion\",\n194: };\n195: \n196: /** Map of short aliases → canonical tasks subcommand names. */\n197: export const SUBCOMMAND_ALIASES: Record<string, string> = {\n198:   ls: \"list\",\n199:   a: \"add\",\n200:   ss: \"set-status\",\n201:   sp: \"set-priority\",\n202:   sd: \"set-difficulty\",\n203:   ch: \"check\",\n204:   validate: \"check\", // backward-compat full-word alias\n205:   ar: \"archive\",\n206:   sh: \"show\",\n207:   g: \"graph\",\n208: };\n209: \n210: // ---------------------------------------------------------------------------\n211: // Arg Parsing\n212: // ---------------------------------------------------------------------------\n213: \n214: export function parseArgs(argv: string[]): CLIArgs {\n215:   const args = argv.slice(2); // skip 'bun' and script path\n216:   const result: CLIArgs = {\n217:     command: args[0] || \"help\",\n218:     interactive: false,\n219:     dryRun: false,\n220:     noTui: false,\n221:     autoPush: false,\n222:     requeue: false,\n223:     force: false,\n224:     checkOnly: false,\n225:     outputFmt: resolveOutputFormat(undefined), // auto-detect until --output overrides\n226:   };\n227: \n228:   // Resolve top-level command alias (e.g., \"i\" → \"init\", \"t\" → \"tasks\")\n229:   result.command = COMMAND_ALIASES[result.command] ?? result.command;\n230: \n231:   // If the command is \"tasks\", treat the second positional as the subcommand\n232:   let startIdx = 1;\n233:   if (result.command === \"tasks\") {\n234:     result.subcommand = args[1] || \"list\";\n235:     // Resolve subcommand alias (e.g., \"ls\" → \"list\", \"ss\" → \"set-status\")\n236:     result.subcommand = SUBCOMMAND_ALIASES[result.subcommand] ?? result.subcommand;\n237:     startIdx = 2;\n238:   }\n239: \n240:   for (let i = startIdx; i < args.length; i++) {\n241:     const arg = args[i];\n242: \n243:     // Helper: consume the next argument, or exit with a clear error\n244:     function requireValue(flag: string): string {\n245:       if (i + 1 >= args.length) {\n246:         console.error(`Flag ${flag} requires a value.`);\n247:         process.exit(1);\n248:       }\n249:       return args[++i];\n250:     }\n251: \n252:     switch (arg) {\n253:       // --- Selection options ---\n254:       case \"--top-priority\":\n255:         result.topPriority = parseInt(requireValue(arg), 10);\n256:         break;\n257:       case \"--quickest-wins\":\n258:         result.quickestWins = parseInt(requireValue(arg), 10);\n259:         break;\n260:       case \"--priority\":\n261:         result.priority = requireValue(arg) as Priority;\n262:         break;\n263:       case \"--difficulty\":\n264:         result.difficulty = requireValue(arg) as Difficulty;\n265:         break;\n266:       case \"--tasks\":\n267:       case \"--features\": // backward-compat alias\n268:         result.tasks = requireValue(arg).split(\",\").map((s) => s.trim());\n269:         break;\n270:       case \"--all-ready\":\n271:         result.allReady = true;\n272:         break;\n273: \n274:       // --- Launch / runtime options ---\n275:       case \"--max-concurrent\":\n276:         result.maxConcurrent = parseInt(requireValue(arg), 10);\n277:         break;\n278:       case \"--model\":\n279:       case \"-m\":\n280:         result.model = requireValue(arg);\n281:         break;\n282:       case \"--interactive\":\n283:         result.interactive = true;\n284:         break;\n285:       case \"--dry-run\":\n286:         result.dryRun = true;\n287:         break;\n288:       case \"--no-tui\":\n289:         result.noTui = true;\n290:         break;\n291:       case \"--auto-push\":\n292:         result.autoPush = true;\n293:         break;\n294:       case \"--requeue\":\n295:         result.requeue = true;\n296:         break;\n297:       case \"--base-branch\":\n298:         result.baseBranch = requireValue(arg);\n299:         break;\n300:       case \"--max-retries\":\n301:         result.maxRetries = parseInt(requireValue(arg), 10);\n302:         break;\n303: \n304:       // --- General flags ---\n305:       case \"--force\":\n306:         result.force = true;\n307:         break;\n308:       case \"--check\":\n309:         result.checkOnly = true;\n310:         break;\n311:       case \"--tag\":\n312:       case \"--release\":\n313:         result.tag = requireValue(arg);\n314:         break;\n315:       case \"--output\":\n316:       case \"-o\":\n317:         result.outputFmt = resolveOutputFormat(requireValue(arg));\n318:         break;\n319: \n320:       // --- Tasks subcommand options ---\n321:       case \"--status\":\n322:         result.status = requireValue(arg);\n323:         break;\n324:       case \"--ready\":\n325:         result.ready = true;\n326:         break;\n327:       case \"--include-archive\":\n328:         result.includeArchive = true;\n329:         break;\n330:       case \"--title\":\n331:         result.title = requireValue(arg);\n332:         break;\n333:       case \"--description\":\n334:       case \"--desc\":\n335:         result.description = requireValue(arg);\n336:         break;\n337:       case \"--effort\":\n338:         result.effort = requireValue(arg);\n339:         break;\n340:       case \"--depends-on\":\n341:         result.dependsOn = requireValue(arg).split(\",\").map((s) => s.trim());\n342:         break;\n343:       case \"--fields\":\n344:         result.fields = requireValue(arg).split(\",\").map((s) => s.trim());\n345:         break;\n346: \n347:       // --- Graph options ---\n348:       case \"--ascii\":\n349:         result.ascii = true;\n350:         break;\n351:       case \"--mermaid\":\n352:         result.mermaidRaw = true;\n353:         break;\n354:       case \"--subtasks\":\n355:         result.graphSubtasks = true;\n356:         break;\n357: \n358:       // --- Logs options ---\n359:       case \"--tail\":\n360:         result.tail = parseInt(requireValue(arg), 10);\n361:         break;\n362:       case \"--follow\":\n363:       case \"-f\":\n364:         result.follow = true;\n365:         break;\n366: \n367:       // --- Browser verification ---\n368:       case \"--browser\":\n369:         result.browser = true;\n370:         break;\n371: \n372:       // --- TDD verification ---\n373:       case \"--skip-tests\":\n374:         result.skipTests = true;\n375:         break;\n376:       case \"--strict-tdd\":\n377:         result.strictTdd = true;\n378:         break;\n379: \n380:       // --- Agent selection ---\n381:       case \"--agent\":\n382:         result.agent = requireValue(arg);\n383:         break;\n384: \n385:       // --- Positional (feature-id, title for add, etc.) ---\n386:       default:\n387:         if (!arg.startsWith(\"-\")) {\n388:           if (!result.featureId) {\n389:             result.featureId = arg;\n390:           } else if (!result.title) {\n391:             result.title = arg;\n392:           }\n393:         }\n394:         break;\n395:     }\n396:   }\n397: \n398:   return result;\n399: }\n400: \n401: // ---------------------------------------------------------------------------\n402: // Help\n403: // ---------------------------------------------------------------------------\n404: \n405: function cmdHelp(): void {\n406:   console.log(`\n407: wombo-combo — AI Agent Orchestration System\n408: \n409:   WOMBO COMBO! Parallel feature development with AI agents.\n410: \n411: Commands:                        (alias)\n412:   init                           (i)     Generate .wombo-combo/config.json in the current project\n413:   launch                         (l)     Launch a wave of agents to implement features\n414:   resume                         (r)     Resume a previously stopped wave\n415:   status                         (s)     Show the status of the current wave\n416:   verify                         (v)     Run build verification on completed agents\n417:   merge                          (m)     Merge verified branches into the base branch\n418:   retry                          (re)    Retry a failed agent\n419:   abort                          (a)     Kill a single running agent (--requeue to return to queue)\n420:   logs                           (lo)    Pretty-print agent logs for a feature\n421:   cleanup                        (c)     Remove all wave worktrees and multiplexer sessions\n422:   history                        (h)     List/view past wave results (stored in .wombo-combo/history/)\n423:   tasks                          (t)     Manage tasks file (see below; 'features' also accepted)\n424:   upgrade                        (u)     Check for updates and upgrade wombo-combo\n425:   describe                       (d)     Emit JSON schema or TOON legend (--output toon)\n426:   completion                     (comp)  Generate shell completions (bash, zsh, fish)\n427:   version                                Print version and exit\n428:   help                                   Show this help\n429: \n430: Tasks Subcommands:               (alias)\n431:   tasks list                     (ls)    List tasks (--status, --priority, --difficulty, --ready, --include-archive)\n432:   tasks add <id> <title>         (a)     Add a new task (--desc, --priority, --difficulty, --effort, --depends-on)\n433:   tasks set-status <id> <s>      (ss)    Change a task's status\n434:   tasks set-priority <id> <p>    (sp)    Change a task's priority (critical/high/medium/low/wishlist)\n435:   tasks set-difficulty <id> <d>  (sd)    Change a task's difficulty (trivial/easy/medium/hard/very_hard)\n436:   tasks check                    (ch)    Validate tasks file (schema, deps, duplicates, cycles)\n437:   tasks archive [id]             (ar)    Move done/cancelled to archive (--dry-run)\n438:   tasks show <id>                (sh)    Show task details\n439:   tasks graph                    (g)     Visualize dependency graph (--ascii, --mermaid, --subtasks)\n440: \n441: Selection Options (for launch):\n442:   --top-priority N         Select top N tasks by priority\n443:   --quickest-wins N        Select N tasks with lowest effort\n444:   --priority <level>       Filter by priority (critical/high/medium/low/wishlist)\n445:   --difficulty <level>     Filter by difficulty (trivial/easy/medium/hard/very_hard)\n446:   --tasks \"id1,id2\"        Select specific tasks by ID (--features also accepted)\n447:   --all-ready              Select all tasks whose dependencies are met\n448: \n449: Launch Options:\n450:   --max-concurrent N       Max agents running in parallel (default: from config)\n451:   --model <model>          Model to use (e.g., \"anthropic/claude-sonnet-4-20250514\")\n452:   --interactive            Use multiplexer (dmux/tmux) TUI mode instead of headless\n453:   --no-tui                 Headless mode without neo-blessed TUI (periodic console dashboard)\n454:   --auto-push              Push base branch to remote after all merges complete\n455:   --dry-run                Show what would be launched without launching\n456:   --base-branch <branch>   Base branch (default: from config)\n457:   --max-retries N          Max retries per agent (default: from config)\n458:   --browser                Enable browser-based verification (run after build passes)\n459:   --skip-tests             Skip running tests during TDD verification\n460:   --strict-tdd             Strict TDD: fail verification if new files are missing tests\n461:   --agent <name>           Override agent definition for all launched tasks (name without .md extension)\n462: \n463: General:\n464:   --force                  Force overwrite (e.g., for init) / skip prompts (e.g., for upgrade)\n465:   --output <fmt>           Output format: text (default on TTY), json (default when piped), or toon (WOMBO_OUTPUT=toon)\n466:   -o <fmt>                 Alias for --output\n467:   --dry-run                Show what would happen without performing the action\n468:   --fields <list>          Comma-separated fields to include (e.g., id,status,priority)\n469: \n470: Upgrade Options:\n471:   --check                  Only check for updates, don't install\n472:   --tag <tag>              Install a specific version (e.g., v0.1.0)\n473: \n474: Logs Options:\n475:   --tail N                 Show only the last N lines\n476:   --follow, -f             Stream new output as it arrives (like tail -f)\n477: \n478: Aliases (every command has a short form):\n479:   woco i                         woco init\n480:   woco l --all-ready             woco launch --all-ready\n481:   woco t ls                      woco tasks list\n482:   woco t a my-task \"Title\"       woco tasks add my-task \"Title\"\n483:   woco t ss my-task done         woco tasks set-status my-task done\n484: \n485: Shell Completion:\n486:   eval \"$(woco completion bash)\"    # Bash: add to ~/.bashrc\n487:   eval \"$(woco completion zsh)\"     # Zsh:  add to ~/.zshrc\n488:   woco completion fish | source     # Fish (or save to ~/.config/fish/completions/woco.fish)\n489: \n490: Examples:\n491:   woco init\n492:   woco launch --quickest-wins 3\n493:   woco launch --priority high --interactive\n494:   woco launch --tasks \"auth-flow,search-api\" --max-concurrent 2\n495:   woco resume\n496:   woco status\n497:   woco verify\n498:   woco merge\n499:   woco retry auth-flow\n500:   woco abort auth-flow\n501:   woco abort auth-flow --requeue\n502:   woco abort auth-flow --output json\n503:   woco logs auth-flow\n504:   woco logs auth-flow --tail 50\n505:   woco logs auth-flow --follow\n506:   woco logs auth-flow --output json\n507:   woco cleanup\n508:   woco tasks list --status ready --priority high\n509:   woco tasks list --fields id,status,priority --output json\n510:   woco tasks add my-task \"My Cool Task\" --priority high --difficulty easy\n511:   woco tasks set-status my-task in-progress\n512:   woco tasks check\n513:   woco tasks archive --dry-run\n514:   woco tasks show my-task\n515:   woco history\n516:   woco history wave-2026-03-12-420\n517:   woco history --output json\n518:   woco describe                           # list all commands as JSON\n519:   woco describe launch                    # describe a specific command\n520:   woco describe tasks add                 # describe a subcommand\n521:   woco describe --output toon             # emit TOON format legend/spec\n522: `);\n523: }\n524: \n525: // ---------------------------------------------------------------------------\n526: // Main\n527: // ---------------------------------------------------------------------------\n528: \n529: async function main(): Promise<void> {\n530:   checkDevModeGuard();\n531: \n532:   const PROJECT_ROOT = resolve(process.cwd());\n533:   const args = parseArgs(process.argv);\n534: \n535:   // -----------------------------------------------------------------------\n536:   // Input validation at the CLI boundary\n537:   // -----------------------------------------------------------------------\n538:   if (args.featureId) {\n539:     assertValid(validateId(args.featureId, \"feature ID\"));\n540:   }\n541:   if (args.title) {\n542:     assertValid(validateText(args.title, \"title\"));\n543:   }\n544:   if (args.description) {\n545:     assertValid(validateText(args.description, \"description\"));\n546:   }\n547:   if (args.baseBranch) {\n548:     assertValid(validateBranchName(args.baseBranch, \"base branch\"));\n549:   }\n550:   if (args.effort) {\n551:     assertValid(validateDuration(args.effort, \"effort\"));\n552:   }\n553:   if (args.tasks) {\n554:     for (const fid of args.tasks) {\n555:       assertValid(validateId(fid, \"task ID in --tasks\"));\n556:     }\n557:   }\n558:   if (args.dependsOn) {\n559:     for (const dep of args.dependsOn) {\n560:       assertValid(validateId(dep, \"dependency ID in --depends-on\"));\n561:     }\n562:   }\n563: \n564:   // Validate numeric args are not NaN\n565:   const numericArgs: [string, number | undefined][] = [\n566:     [\"--top-priority\", args.topPriority],\n567:     [\"--quickest-wins\", args.quickestWins],\n568:     [\"--max-concurrent\", args.maxConcurrent],\n569:     [\"--max-retries\", args.maxRetries],\n570:     [\"--tail\", args.tail],\n571:   ];\n572:   for (const [flag, value] of numericArgs) {\n573:     if (value !== undefined && isNaN(value)) {\n574:       console.error(`${flag} requires a numeric value.`);\n575:       process.exit(1);\n576:     }\n577:   }\n578: \n579:   // Commands that don't need config loading\n580:   if (args.command === \"version\" || args.command === \"-v\" || args.command === \"-V\") {\n581:     const pkgPath = resolve(import.meta.dir, \"..\", \"package.json\");\n582:     const pkgFile = Bun.file(pkgPath);\n583:     try {\n584:       const pkg = await pkgFile.json();\n585:       console.log(`wombo-combo ${pkg.version ?? \"(unknown version)\"}`);\n586:     } catch {\n587:       console.log(\"wombo-combo (unknown version)\");\n588:     }\n589:     return;\n590:   }\n591: \n592:   if (args.command === \"help\" || args.command === \"--help\" || args.command === \"-h\") {\n593:     cmdHelp();\n594:     return;\n595:   }\n596: \n597:   if (args.command === \"describe\") {\n598:     // Schema introspection: `woco describe [command]`\n599:     if (args.outputFmt === \"toon\") {\n600:       // Emit TOON format legend — self-describing, cacheable by agents\n601:       const pkgPath = resolve(import.meta.dir, \"..\", \"package.json\");\n602:       let version = \"unknown\";\n603:       try {\n604:         const pkg = await Bun.file(pkgPath).json();\n605:         version = pkg.version ?? \"unknown\";\n606:       } catch {}\n607: \n608:       if (!args.featureId) {\n609:         // Full TOON spec (legend + all commands)\n610:         console.log(renderToonLegend(version));\n611:       } else {\n612:         // JSON structure for the full spec (--output toon with a specific command\n613:         // still emits JSON since TOON is a line-oriented data format, not a schema format)\n614:         const spec = buildToonSpec(version);\n615:         const cmdName = args.title\n616:           ? `${args.featureId} ${args.title}`\n617:           : args.featureId;\n618:         const cmdSpec = spec.commands.find((c) => c.command === cmdName);\n619:         if (!cmdSpec) {\n620:           console.error(`Unknown command: \"${cmdName}\"`);\n621:           console.error(\"Run 'woco describe --output toon' to see the full TOON spec.\");\n622:           process.exit(1);\n623:           return;\n624:         }\n625:         console.log(JSON.stringify(cmdSpec, null, 2));\n626:       }\n627:       return;\n628:     }\n629: \n630:     if (!args.featureId) {\n631:       // No command specified — list all commands\n632:       console.log(JSON.stringify(allCommandSchemas(), null, 2));\n633:     } else {\n634:       // Describe a specific command. Handle compound names: \"features list\"\n635:       const cmdName = args.title\n636:         ? `${args.featureId} ${args.title}`\n637:         : args.featureId;\n638:       const def = findCommandDef(cmdName);\n639:       if (!def) {\n640:         console.error(`Unknown command: \"${cmdName}\"`);\n641:         console.error(\"Run 'woco describe' to list all commands.\");\n642:         process.exit(1);\n643:         return;\n644:       }\n645:       console.log(JSON.stringify(commandToSchema(def), null, 2));\n646:     }\n647:     return;\n648:   }\n649: \n650:   if (args.command === \"init\") {\n651:     await cmdInit({ projectRoot: PROJECT_ROOT, force: args.force });\n652:     return;\n653:   }\n654: \n655:   if (args.command === \"upgrade\") {\n656:     await cmdUpgrade({\n657:       force: args.force,\n658:       tag: args.tag,\n659:       checkOnly: args.checkOnly,\n660:     });\n661:     return;\n662:   }\n663: \n664:   if (args.command === \"completion\") {\n665:     cmdCompletion({ shell: args.featureId }); // first positional = shell name\n666:     return;\n667:   }\n668: \n669:   if (args.command === \"logs\") {\n670:     if (!args.featureId) {\n671:       console.error(\"Usage: woco logs <feature-id> [--tail N] [--follow] [--output json]\");\n672:       process.exit(1);\n673:       return;\n674:     }\n675:     await cmdLogs({\n676:       projectRoot: PROJECT_ROOT,\n677:       featureId: args.featureId,\n678:       tail: args.tail,\n679:       follow: args.follow,\n680:       outputFmt: args.outputFmt,\n681:     });\n682:     return;\n683:   }\n684: \n685:   // Everything else requires config\n686:   const config = loadConfig(PROJECT_ROOT);\n687:   validateConfig(config);\n688: \n689:   // Commands that operate on the tasks file — ensure it exists first\n690:   const needsTasksFile = new Set([\"launch\", \"resume\", \"verify\", \"retry\", \"tasks\"]);\n691:   if (needsTasksFile.has(args.command)) {\n692:     await ensureTasksFile(PROJECT_ROOT, config);\n693:   }\n694: \n695:   switch (args.command) {\n696:     case \"launch\":\n697:       // Apply browser verification override if --browser flag was passed\n698:       if (args.browser !== undefined) {\n699:         config.browser.enabled = args.browser;\n700:       }\n701:       await cmdLaunch({\n702:         projectRoot: PROJECT_ROOT,\n703:         config,\n704:         topPriority: args.topPriority,\n705:         quickestWins: args.quickestWins,\n706:         priority: args.priority,\n707:         difficulty: args.difficulty,\n708:         features: args.tasks,\n709:         allReady: args.allReady,\n710:         maxConcurrent: args.maxConcurrent ?? config.defaults.maxConcurrent,\n711:         model: args.model,\n712:         interactive: args.interactive,\n713:         dryRun: args.dryRun,\n714:         baseBranch: args.baseBranch ?? config.baseBranch,\n715:         maxRetries: args.maxRetries ?? config.defaults.maxRetries,\n716:         noTui: args.noTui,\n717:         autoPush: args.autoPush,\n718:         outputFmt: args.outputFmt,\n719:         agent: args.agent,\n720:       });\n721:       break;\n722: \n723:     case \"resume\":\n724:       await cmdResume({\n725:         projectRoot: PROJECT_ROOT,\n726:         config,\n727:         maxConcurrent: args.maxConcurrent,\n728:         model: args.model,\n729:         interactive: args.interactive,\n730:         noTui: args.noTui,\n731:         autoPush: args.autoPush,\n732:         baseBranch: args.baseBranch,\n733:         maxRetries: args.maxRetries,\n734:         outputFmt: args.outputFmt,\n735:       });\n736:       break;\n737: \n738:     case \"status\":\n739:       await cmdStatus({ projectRoot: PROJECT_ROOT, config, outputFmt: args.outputFmt });\n740:       break;\n741: \n742:     case \"verify\":\n743:       await cmdVerify({\n744:         projectRoot: PROJECT_ROOT,\n745:         config,\n746:         featureId: args.featureId,\n747:         model: args.model,\n748:         maxRetries: args.maxRetries,\n749:         browserVerify: args.browser,\n750:         skipTests: args.skipTests,\n751:         strictTdd: args.strictTdd,\n752:         outputFmt: args.outputFmt,\n753:       });\n754:       break;\n755: \n756:     case \"merge\":\n757:       await cmdMerge({\n758:         projectRoot: PROJECT_ROOT,\n759:         config,\n760:         featureId: args.featureId,\n761:         autoPush: args.autoPush,\n762:         dryRun: args.dryRun,\n763:         model: args.model,\n764:         outputFmt: args.outputFmt,\n765:       });\n766:       break;\n767: \n768:     case \"retry\": {\n769:       if (!args.featureId) {\n770:         console.error(\"Usage: woco retry <feature-id>\");\n771:         process.exit(1);\n772:         return;\n773:       }\n774:       await cmdRetry({\n775:         projectRoot: PROJECT_ROOT,\n776:         config,\n777:         featureId: args.featureId,\n778:         model: args.model,\n779:         interactive: args.interactive,\n780:         dryRun: args.dryRun,\n781:         outputFmt: args.outputFmt,\n782:       });\n783:       break;\n784:     }\n785: \n786:     case \"cleanup\":\n787:       await cmdCleanup({ projectRoot: PROJECT_ROOT, config, dryRun: args.dryRun, outputFmt: args.outputFmt });\n788:       break;\n789: \n790:     case \"history\":\n791:       await cmdHistory({\n792:         projectRoot: PROJECT_ROOT,\n793:         config,\n794:         waveId: args.featureId,\n795:         outputFmt: args.outputFmt,\n796:       });\n797:       break;\n798: \n799:     case \"abort\": {\n800:       if (!args.featureId) {\n801:         console.error(\"Usage: woco abort <feature-id> [--requeue] [--output json]\");\n802:         process.exit(1);\n803:         return;\n804:       }\n805:       await cmdAbort({\n806:         projectRoot: PROJECT_ROOT,\n807:         config,\n808:         featureId: args.featureId,\n809:         requeue: args.requeue,\n810:         outputFmt: args.outputFmt,\n811:       });\n812:       break;\n813:     }\n814: \n815:     case \"tasks\":\n816:       await handleTasksSubcommand(args, PROJECT_ROOT, config);\n817:       break;\n818: \n819:     default:\n820:       console.error(`Unknown command: ${args.command}`);\n821:       cmdHelp();\n822:       process.exit(1);\n823:       return;\n824:   }\n825: }\n826: \n827: // ---------------------------------------------------------------------------\n828: // Tasks Subcommand Router\n829: // ---------------------------------------------------------------------------\n830: \n831: async function handleTasksSubcommand(\n832:   args: CLIArgs,\n833:   projectRoot: string,\n834:   config: import(\"./config.js\").WomboConfig\n835: ): Promise<void> {\n836:   switch (args.subcommand) {\n837:     case \"list\":\n838:       await cmdTasksList({\n839:         projectRoot,\n840:         config,\n841:         status: args.status as FeatureStatus | undefined,\n842:         priority: args.priority,\n843:         difficulty: args.difficulty,\n844:         ready: args.ready,\n845:         includeArchive: args.includeArchive,\n846:         outputFmt: args.outputFmt,\n847:         fields: args.fields,\n848:       });\n849:       break;\n850: \n851:     case \"add\": {\n852:       if (!args.featureId || !args.title) {\n853:         console.error(\"Usage: woco tasks add <id> <title> [--desc <desc>] [--priority <p>] [--difficulty <d>] [--effort <e>] [--depends-on <ids>]\");\n854:         process.exit(1);\n855:         return;\n856:       }\n857:       await cmdTasksAdd({\n858:         projectRoot,\n859:         config,\n860:         id: args.featureId,\n861:         title: args.title,\n862:         description: args.description,\n863:         priority: args.priority,\n864:         difficulty: args.difficulty,\n865:         effort: args.effort,\n866:         dependsOn: args.dependsOn,\n867:         outputFmt: args.outputFmt,\n868:         dryRun: args.dryRun,\n869:       });\n870:       break;\n871:     }\n872: \n873:     case \"set-status\": {\n874:       // The new status can come from the second positional (stored in args.title)\n875:       // or from the --status flag\n876:       const newStatus = args.title || args.status;\n877:       if (!args.featureId || !newStatus) {\n878:         console.error(\"Usage: woco tasks set-status <task-id> <status>\");\n879:         process.exit(1);\n880:         return;\n881:       }\n882:       await cmdTasksSetStatus({\n883:         projectRoot,\n884:         config,\n885:         featureId: args.featureId,\n886:         newStatus,\n887:         outputFmt: args.outputFmt,\n888:         dryRun: args.dryRun,\n889:       });\n890:       break;\n891:     }\n892: \n893:     case \"set-priority\": {\n894:       // The new priority can come from the second positional (stored in args.title)\n895:       // or from the --priority flag\n896:       const newPriority = args.title || (args.priority as string | undefined);\n897:       if (!args.featureId || !newPriority) {\n898:         console.error(\"Usage: woco tasks set-priority <task-id> <priority>\");\n899:         process.exit(1);\n900:         return;\n901:       }\n902:       await cmdTasksSetPriority({\n903:         projectRoot,\n904:         config,\n905:         featureId: args.featureId,\n906:         newPriority,\n907:         outputFmt: args.outputFmt,\n908:         dryRun: args.dryRun,\n909:       });\n910:       break;\n911:     }\n912: \n913:     case \"set-difficulty\": {\n914:       // The new difficulty can come from the second positional (stored in args.title)\n915:       // or from the --difficulty flag\n916:       const newDifficulty = args.title || (args.difficulty as string | undefined);\n917:       if (!args.featureId || !newDifficulty) {\n918:         console.error(\"Usage: woco tasks set-difficulty <task-id> <difficulty>\");\n919:         process.exit(1);\n920:         return;\n921:       }\n922:       await cmdTasksSetDifficulty({\n923:         projectRoot,\n924:         config,\n925:         featureId: args.featureId,\n926:         newDifficulty,\n927:         outputFmt: args.outputFmt,\n928:         dryRun: args.dryRun,\n929:       });\n930:       break;\n931:     }\n932: \n933:     case \"check\":\n934:       await cmdTasksCheck({ projectRoot, config, outputFmt: args.outputFmt });\n935:       break;\n936: \n937:     case \"archive\":\n938:       await cmdTasksArchive({\n939:         projectRoot,\n940:         config,\n941:         featureId: args.featureId,\n942:         dryRun: args.dryRun,\n943:         outputFmt: args.outputFmt,\n944:       });\n945:       break;\n946: \n947:     case \"show\": {\n948:       if (!args.featureId) {\n949:         console.error(\"Usage: woco tasks show <task-id>\");\n950:         process.exit(1);\n951:         return;\n952:       }\n953:       await cmdTasksShow({\n954:         projectRoot,\n955:         config,\n956:         featureId: args.featureId,\n957:         outputFmt: args.outputFmt,\n958:         fields: args.fields,\n959:       });\n960:       break;\n961:     }\n962: \n963:     case \"graph\":\n964:       await cmdTasksGraph({\n965:         projectRoot,\n966:         config,\n967:         status: args.status as FeatureStatus | undefined,\n968:         ascii: args.ascii,\n969:         mermaid: args.mermaidRaw,\n970:         subtasks: args.graphSubtasks,\n971:         outputFmt: args.outputFmt,\n972:       });\n973:       break;\n974: \n975:     case \"help\":\n976:     case \"--help\":\n977:     case \"-h\":\n978:       cmdHelp();\n979:       break;\n980: \n981:     default:\n982:       console.error(`Unknown tasks subcommand: ${args.subcommand}`);\n983:       console.error(\"Run 'woco tasks help' or 'woco help' for usage.\");\n984:       process.exit(1);\n985:       return;\n986:   }\n987: }\n988: \n989: // ---------------------------------------------------------------------------\n990: // Error Handlers & Entry\n991: // ---------------------------------------------------------------------------\n992: \n993: // Global error handlers — prevent silent crashes\n994: process.on(\"uncaughtException\", (err) => {\n995:   console.error(`\\n[FATAL] Uncaught exception: ${err.message}`);\n996:   console.error(err.stack);\n997:   try {\n998:     const state = loadState(process.cwd());\n999:     if (state) saveState(process.cwd(), state);\n1000:   } catch {}\n1001:   process.exit(1);\n1002: });\n1003: \n1004: process.on(\"unhandledRejection\", (reason: any) => {\n1005:   console.error(`\\n[FATAL] Unhandled rejection: ${reason?.message || reason}`);\n1006:   if (reason?.stack) console.error(reason.stack);\n1007:   try {\n1008:     const state = loadState(process.cwd());\n1009:     if (state) saveState(process.cwd(), state);\n1010:   } catch {}\n1011:   process.exit(1);\n1012: });\n1013: \n1014: main().catch((err) => {\n1015:   console.error(\"Fatal error:\", err.message);\n1016:   process.exit(1);\n1017: });\n\n(End of file - total 1017 lines)\n</content>","title":"src/index.ts","metadata":{"preview":"#!/usr/bin/env bun\n/**\n * index.ts — CLI entry point for the wombo-combo agent orchestration system.\n *\n * Every command has a short alias (e.g., woco i = woco init, woco t ls = woco tasks list).\n *\n * Usage:\n *   woco init                                         (alias: i)\n *   woco launch --top-priority 3                      (alias: l)\n *   woco launch --quickest-wins 5\n *   woco launch --priority high\n *   woco launch --difficulty easy\n *   woco launch --tasks \"feat-a,feat-b\"\n *   woco launch --all-ready\n *   woco launch ... --max-concurrent 3 --model \"anthropic/claude-sonnet-4-20250514\"\n *   woco launch ... --interactive\n *   woco resume                                       (alias: r)\n *   woco status                                       (alias: s)\n *   woco verify [feature-id]                          (alias: v)\n *   woco merge [feature-id]                           (alias: m)","truncated":false,"loaded":[]},"time":{"start":1773440692238,"end":1773440692241}}}}
