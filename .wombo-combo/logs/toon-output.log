{"type":"tool_use","timestamp":1773440108153,"sessionID":"ses_316bba7c1ffenLP0vTOciFexZp","part":{"id":"prt_ce9448673001147IxtM3e1yqtK","sessionID":"ses_316bba7c1ffenLP0vTOciFexZp","messageID":"msg_ce94479850011tfy8DzGWUR7TR","type":"tool","callID":"toolu_vrtx_01RS3waAjF32vjUD11CL1eTL","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/toon-output/src/lib/output.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/toon-output/src/lib/output.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * output.ts — Shared output helpers for agent-ready CLI.\n3:  *\n4:  * Provides a centralized way for commands to emit structured data that\n5:  * renders as human-readable text on TTY, as JSON when --output json\n6:  * is specified, or as compact TOON notation when --output toon is used.\n7:  *\n8:  * Usage in commands:\n9:  *   import { output, OutputFormat } from \"../lib/output.js\";\n10:  *\n11:  *   // At the end of a command:\n12:  *   output(format, data, textRenderer, toonRenderer);  // emits JSON, text, or TOON\n13:  *   outputError(format, message);                      // emits error in the right format\n14:  */\n15: \n16: import { renderGeneric } from \"./toon.js\";\n17: \n18: // ---------------------------------------------------------------------------\n19: // Types\n20: // ---------------------------------------------------------------------------\n21: \n22: export type OutputFormat = \"text\" | \"json\" | \"toon\";\n23: \n24: // ---------------------------------------------------------------------------\n25: // Helpers\n26: // ---------------------------------------------------------------------------\n27: \n28: /**\n29:  * Determine the output format. Priority:\n30:  *   1. Explicit --output flag value\n31:  *   2. WOMBO_OUTPUT env var (for agent pipelines)\n32:  *   3. Default to \"text\"\n33:  *\n34:  * Note: We intentionally do NOT auto-detect based on TTY. Many legitimate\n35:  * use cases (bun dev, piped to less/grep, CI) have non-TTY stdout but still\n36:  * want human output. Agents should explicitly pass --output json or set\n37:  * WOMBO_OUTPUT=json.\n38:  */\n39: export function resolveOutputFormat(explicit?: string): OutputFormat {\n40:   if (explicit === \"json\") return \"json\";\n41:   if (explicit === \"toon\") return \"toon\";\n42:   if (explicit === \"text\") return \"text\";\n43:   // Check env var for agent pipelines\n44:   const env = process.env.WOMBO_OUTPUT;\n45:   if (env === \"json\") return \"json\";\n46:   if (env === \"toon\") return \"toon\";\n47:   return \"text\";\n48: }\n49: \n50: /**\n51:  * Emit structured data.\n52:  *   - JSON mode: outputs a single JSON line to stdout\n53:  *   - TOON mode: calls toonRenderer if provided, otherwise uses generic TOON formatter\n54:  *   - Text mode: calls textRenderer\n55:  */\n56: export function output(\n57:   format: OutputFormat,\n58:   data: unknown,\n59:   textRenderer: () => void,\n60:   toonRenderer?: () => void\n61: ): void {\n62:   if (format === \"json\") {\n63:     console.log(JSON.stringify(data));\n64:   } else if (format === \"toon\") {\n65:     if (toonRenderer) {\n66:       toonRenderer();\n67:     } else {\n68:       // Generic fallback: convert structured data to TOON\n69:       console.log(renderGeneric(data));\n70:     }\n71:   } else {\n72:     textRenderer();\n73:   }\n74: }\n75: \n76: /**\n77:  * Emit an error. In JSON mode, outputs {\"error\": message} to stderr.\n78:  * In TOON mode, outputs \"#ERROR message\" to stderr.\n79:  * In text mode, outputs the message to stderr normally.\n80:  */\n81: export function outputError(format: OutputFormat, message: string, exitCode: number = 1): never {\n82:   if (format === \"json\") {\n83:     console.error(JSON.stringify({ error: message }));\n84:   } else if (format === \"toon\") {\n85:     console.error(`#ERROR ${message}`);\n86:   } else {\n87:     console.error(message);\n88:   }\n89:   process.exit(exitCode);\n90: }\n91: \n92: /**\n93:  * Emit a success/info message. In JSON mode, outputs {\"message\": msg, ...extra}.\n94:  * In TOON mode, outputs \"#MSG message\" to stdout.\n95:  * In text mode, outputs the message to stdout normally.\n96:  */\n97: export function outputMessage(\n98:   format: OutputFormat,\n99:   message: string,\n100:   extra?: Record<string, unknown>\n101: ): void {\n102:   if (format === \"json\") {\n103:     console.log(JSON.stringify({ message, ...extra }));\n104:   } else if (format === \"toon\") {\n105:     console.log(`#MSG ${message}`);\n106:   } else {\n107:     console.log(message);\n108:   }\n109: }\n110: \n111: // ---------------------------------------------------------------------------\n112: // Field filtering for compact output (--fields)\n113: // ---------------------------------------------------------------------------\n114: \n115: /**\n116:  * Filter an object to only include the specified fields.\n117:  * If fields is undefined/empty, returns the object unchanged.\n118:  */\n119: export function filterFields<T extends Record<string, unknown>>(\n120:   obj: T,\n121:   fields?: string[]\n122: ): Partial<T> {\n123:   if (!fields || fields.length === 0) return obj;\n124:   const result: Partial<T> = {};\n125:   for (const field of fields) {\n126:     if (field in obj) {\n127:       (result as any)[field] = (obj as any)[field];\n128:     }\n129:   }\n130:   return result;\n131: }\n132: \n133: /**\n134:  * Filter an array of objects to only include specified fields per object.\n135:  * If fields is undefined/empty, returns the array unchanged.\n136:  */\n137: export function filterFieldsArray<T extends Record<string, unknown>>(\n138:   arr: T[],\n139:   fields?: string[]\n140: ): Partial<T>[] {\n141:   if (!fields || fields.length === 0) return arr;\n142:   return arr.map((obj) => filterFields(obj, fields));\n143: }\n144: \n145: /**\n146:  * Render a compact text table from an array of objects with selected fields.\n147:  * Used for text-mode --fields output.\n148:  */\n149: export function renderCompactTable(\n150:   items: Record<string, unknown>[],\n151:   fields: string[]\n152: ): void {\n153:   if (items.length === 0) return;\n154: \n155:   // Calculate column widths\n156:   const widths: Record<string, number> = {};\n157:   for (const field of fields) {\n158:     widths[field] = field.length;\n159:     for (const item of items) {\n160:       const val = String(item[field] ?? \"\");\n161:       widths[field] = Math.max(widths[field], val.length);\n162:     }\n163:   }\n164: \n165:   // Header\n166:   const header = fields.map((f) => f.padEnd(widths[f])).join(\"  \");\n167:   console.log(header);\n168:   console.log(fields.map((f) => \"─\".repeat(widths[f])).join(\"  \"));\n169: \n170:   // Rows\n171:   for (const item of items) {\n172:     const row = fields.map((f) => String(item[f] ?? \"\").padEnd(widths[f])).join(\"  \");\n173:     console.log(row);\n174:   }\n175: }\n\n(End of file - total 175 lines)\n</content>","title":"src/lib/output.ts","metadata":{"preview":"/**\n * output.ts — Shared output helpers for agent-ready CLI.\n *\n * Provides a centralized way for commands to emit structured data that\n * renders as human-readable text on TTY, as JSON when --output json\n * is specified, or as compact TOON notation when --output toon is used.\n *\n * Usage in commands:\n *   import { output, OutputFormat } from \"../lib/output.js\";\n *\n *   // At the end of a command:\n *   output(format, data, textRenderer, toonRenderer);  // emits JSON, text, or TOON\n *   outputError(format, message);                      // emits error in the right format\n */\n\nimport { renderGeneric } from \"./toon.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------","truncated":false,"loaded":[]},"time":{"start":1773440108150,"end":1773440108152}}}}
{"type":"tool_use","timestamp":1773440108641,"sessionID":"ses_316bba7c1ffenLP0vTOciFexZp","part":{"id":"prt_ce9448740001bGRRlhKpLw9dPG","sessionID":"ses_316bba7c1ffenLP0vTOciFexZp","messageID":"msg_ce94479850011tfy8DzGWUR7TR","type":"tool","callID":"toolu_vrtx_01JjAPBekWij4XuXPzFBAM43","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/toon-output/src/lib/toon.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/toon-output/src/lib/toon.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * toon.ts -- Token-Optimized Output Notation (TOON) formatter module.\n3:  *\n4:  * Converts structured command results into compact, pipe-delimited TOON\n5:  * notation. Reduces token count by 60%+ vs JSON for equivalent data.\n6:  *\n7:  * Format:\n8:  *   - Delimiter: pipe (|)\n9:  *   - First line: #FIELDS header listing field names\n10:  *   - One record per line, positional fields\n11:  *   - Status codes: BL/PL/IP/BK/IR/DN/CN\n12:  *   - Priority codes: C/H/M/L/W\n13:  *   - Difficulty codes: T/E/M/H/V\n14:  *   - Duration: compact (30m, 2h, 1d4h)\n15:  *   - Boolean: 1/0\n16:  *   - Null/missing: empty field (||)\n17:  *   - Arrays: comma-separated within a field\n18:  */\n19: \n20: import type { Task, TaskStatus, Priority, Difficulty } from \"./tasks.js\";\n21: import type { AgentState, WaveState } from \"./state.js\";\n22: import type { AgentHistoryRecord, WaveHistoryRecord } from \"./history.js\";\n23: import {\n24:   TOON_STATUS_ENCODE,\n25:   TOON_PRIORITY_ENCODE,\n26:   TOON_DIFFICULTY_ENCODE,\n27:   encodeDuration,\n28:   encodeBool,\n29:   encodeNullable,\n30:   encodeArray,\n31: } from \"./toon-spec.js\";\n32: \n33: // ---------------------------------------------------------------------------\n34: // Generic Helpers\n35: // ---------------------------------------------------------------------------\n36: \n37: /**\n38:  * Join fields with pipe delimiter.\n39:  */\n40: function row(...fields: (string | number | null | undefined)[]): string {\n41:   return fields.map((f) => (f === null || f === undefined ? \"\" : String(f))).join(\"|\");\n42: }\n43: \n44: /**\n45:  * Emit a #FIELDS header line.\n46:  */\n47: function fieldsHeader(names: string[]): string {\n48:   return `#FIELDS ${names.join(\"|\")}`;\n49: }\n50: \n51: /**\n52:  * Encode a status code, falling back to raw value if unknown.\n53:  */\n54: function encodeStatus(status: TaskStatus | string): string {\n55:   return (TOON_STATUS_ENCODE as Record<string, string>)[status] ?? status;\n56: }\n57: \n58: /**\n59:  * Encode a priority code, falling back to raw value if unknown.\n60:  */\n61: function encodePriority(priority: Priority | string): string {\n62:   return (TOON_PRIORITY_ENCODE as Record<string, string>)[priority] ?? priority;\n63: }\n64: \n65: /**\n66:  * Encode a difficulty code, falling back to raw value if unknown.\n67:  */\n68: function encodeDifficulty(difficulty: Difficulty | string): string {\n69:   return (TOON_DIFFICULTY_ENCODE as Record<string, string>)[difficulty] ?? difficulty;\n70: }\n71: \n72: // ---------------------------------------------------------------------------\n73: // Tasks List Renderer\n74: // ---------------------------------------------------------------------------\n75: \n76: /**\n77:  * Render a task list in TOON format.\n78:  *\n79:  * Fields: id|status|priority|difficulty|effort|completion|deps_met|depends_on|title\n80:  *\n81:  * Example:\n82:  *   #FIELDS id|status|priority|difficulty|effort|completion|deps_met|depends_on|title\n83:  *   auth-flow|BL|H|E|2h|0|1||Add authentication flow\n84:  *   search-api|IP|C|M|4h|35|0|auth-flow|Implement search API\n85:  */\n86: export function renderTasksList(\n87:   tasks: Array<{\n88:     id: string;\n89:     title: string;\n90:     status: string;\n91:     priority: string;\n92:     difficulty: string;\n93:     effort: string;\n94:     completion: number;\n95:     depends_on: string[];\n96:   }>,\n97:   depsMetMap?: Map<string, boolean>\n98: ): string {\n99:   const header = fieldsHeader([\n100:     \"id\", \"status\", \"priority\", \"difficulty\", \"effort\",\n101:     \"completion\", \"deps_met\", \"depends_on\", \"title\",\n102:   ]);\n103: \n104:   const lines = [header];\n105: \n106:   for (const t of tasks) {\n107:     const depsMet = depsMetMap?.get(t.id) ?? true;\n108:     lines.push(row(\n109:       t.id,\n110:       encodeStatus(t.status),\n111:       encodePriority(t.priority),\n112:       encodeDifficulty(t.difficulty),\n113:       encodeDuration(t.effort),\n114:       t.completion,\n115:       encodeBool(depsMet),\n116:       encodeArray(t.depends_on),\n117:       t.title,\n118:     ));\n119:   }\n120: \n121:   return lines.join(\"\\n\");\n122: }\n123: \n124: // ---------------------------------------------------------------------------\n125: // Tasks Show Renderer\n126: // ---------------------------------------------------------------------------\n127: \n128: /**\n129:  * Render a single task detail in TOON key:value format.\n130:  *\n131:  * Uses abbreviated keys, one per line.\n132:  * Example:\n133:  *   id:auth-flow\n134:  *   st:BL\n135:  *   pr:H\n136:  *   df:E\n137:  *   ef:2h\n138:  *   cp:35\n139:  *   dm:1\n140:  *   dp:dep-a,dep-b\n141:  *   sa:2026-03-10T08:00:00Z\n142:  *   ea:\n143:  *   ti:Add authentication flow\n144:  *   ds:Description text here\n145:  *   cn:Must use TypeScript\n146:  *   fb:No external deps\n147:  *   rf:https://example.com\n148:  *   nt:Some note\n149:  *   sc:3\n150:  */\n151: export function renderTaskShow(\n152:   task: Task,\n153:   depsMet: boolean\n154: ): string {\n155:   const lines: string[] = [];\n156: \n157:   lines.push(`id:${task.id}`);\n158:   lines.push(`st:${encodeStatus(task.status)}`);\n159:   lines.push(`pr:${encodePriority(task.priority)}`);\n160:   lines.push(`df:${encodeDifficulty(task.difficulty)}`);\n161:   lines.push(`ef:${encodeDuration(task.effort)}`);\n162:   lines.push(`cp:${task.completion}`);\n163:   lines.push(`dm:${encodeBool(depsMet)}`);\n164:   lines.push(`dp:${encodeArray(task.depends_on)}`);\n165:   lines.push(`sa:${encodeNullable(task.started_at)}`);\n166:   lines.push(`ea:${encodeNullable(task.ended_at)}`);\n167:   lines.push(`ti:${task.title}`);\n168: \n169:   if (task.description) {\n170:     // Collapse multi-line descriptions to single line with \\n escape\n171:     lines.push(`ds:${task.description.replace(/\\n/g, \"\\\\n\")}`);\n172:   }\n173: \n174:   if (task.constraints.length > 0) {\n175:     lines.push(`cn:${encodeArray(task.constraints)}`);\n176:   }\n177: \n178:   if (task.forbidden.length > 0) {\n179:     lines.push(`fb:${encodeArray(task.forbidden)}`);\n180:   }\n181: \n182:   if (task.references.length > 0) {\n183:     lines.push(`rf:${encodeArray(task.references)}`);\n184:   }\n185: \n186:   if (task.notes.length > 0) {\n187:     lines.push(`nt:${encodeArray(task.notes)}`);\n188:   }\n189: \n190:   if (task.subtasks.length > 0) {\n191:     lines.push(`sc:${task.subtasks.length}`);\n192:     // Render subtasks as compact lines\n193:     for (const st of task.subtasks) {\n194:       lines.push(`  ${st.id}|${encodeStatus(st.status)}|${encodePriority(st.priority)}|${encodeDifficulty(st.difficulty)}|${encodeDuration(st.effort)}|${st.completion}|${st.title}`);\n195:     }\n196:   }\n197: \n198:   return lines.join(\"\\n\");\n199: }\n200: \n201: // ---------------------------------------------------------------------------\n202: // Status Renderer\n203: // ---------------------------------------------------------------------------\n204: \n205: /**\n206:  * Render wave status in TOON format.\n207:  *\n208:  * Fields: feature_id|agent_status|exit_code|retries|started_at\n209:  *\n210:  * Also emits a summary header line:\n211:  *   #WAVE wave_id|agent_count|active|completed|failed\n212:  */\n213: export function renderStatus(state: WaveState): string {\n214:   const lines: string[] = [];\n215: \n216:   // Summary line\n217:   const counts: Record<string, number> = {};\n218:   for (const a of state.agents) {\n219:     counts[a.status] = (counts[a.status] ?? 0) + 1;\n220:   }\n221: \n222:   const active = (counts[\"running\"] ?? 0) + (counts[\"installing\"] ?? 0) + (counts[\"resolving_conflict\"] ?? 0);\n223:   const completed = (counts[\"completed\"] ?? 0) + (counts[\"verified\"] ?? 0) + (counts[\"merged\"] ?? 0);\n224:   const failed = counts[\"failed\"] ?? 0;\n225: \n226:   lines.push(`#WAVE ${row(\n227:     state.wave_id,\n228:     state.agents.length,\n229:     active,\n230:     completed,\n231:     failed,\n232:   )}`);\n233: \n234:   // Agent detail lines\n235:   lines.push(fieldsHeader([\n236:     \"feature_id\", \"agent_status\", \"exit_code\", \"retries\", \"started_at\",\n237:   ]));\n238: \n239:   for (const a of state.agents) {\n240:     // Determine exit code: build_passed === true -> 0, false -> 1, null -> empty\n241:     const exitCode = a.build_passed === true ? \"0\" : a.build_passed === false ? \"1\" : \"\";\n242:     lines.push(row(\n243:       a.feature_id,\n244:       a.status,\n245:       exitCode,\n246:       a.retries,\n247:       encodeNullable(a.started_at),\n248:     ));\n249:   }\n250: \n251:   return lines.join(\"\\n\");\n252: }\n253: \n254: // ---------------------------------------------------------------------------\n255: // Verify Renderer\n256: // ---------------------------------------------------------------------------\n257: \n258: /**\n259:  * Render verification results in TOON format.\n260:  *\n261:  * Fields: feature_id|pass_fail|duration\n262:  */\n263: export function renderVerify(\n264:   results: Array<{ feature_id: string; passed: boolean; durationMs: number }>\n265: ): string {\n266:   const lines: string[] = [];\n267: \n268:   lines.push(fieldsHeader([\"feature_id\", \"pass_fail\", \"duration\"]));\n269: \n270:   for (const r of results) {\n271:     const durationSec = Math.round(r.durationMs / 1000);\n272:     const duration = durationSec >= 60\n273:       ? `${Math.floor(durationSec / 60)}m${durationSec % 60}s`\n274:       : `${durationSec}s`;\n275:     lines.push(row(\n276:       r.feature_id,\n277:       r.passed ? \"pass\" : \"fail\",\n278:       duration,\n279:     ));\n280:   }\n281: \n282:   return lines.join(\"\\n\");\n283: }\n284: \n285: // ---------------------------------------------------------------------------\n286: // History Renderer\n287: // ---------------------------------------------------------------------------\n288: \n289: /**\n290:  * Render history list in TOON format.\n291:  *\n292:  * Fields: wave_id|started_at|ended_at|total_agents|succeeded|failed\n293:  */\n294: export function renderHistoryList(records: WaveHistoryRecord[]): string {\n295:   const lines: string[] = [];\n296: \n297:   lines.push(fieldsHeader([\n298:     \"wave_id\", \"started_at\", \"ended_at\", \"total_agents\", \"succeeded\", \"failed\",\n299:   ]));\n300: \n301:   for (const rec of records) {\n302:     lines.push(row(\n303:       rec.wave_id,\n304:       rec.started_at,\n305:       rec.exported_at,\n306:       rec.summary.total,\n307:       rec.summary.succeeded,\n308:       rec.summary.failed,\n309:     ));\n310:   }\n311: \n312:   return lines.join(\"\\n\");\n313: }\n314: \n315: /**\n316:  * Render a single history record detail in TOON format.\n317:  *\n318:  * Emits a summary header then per-agent lines.\n319:  */\n320: export function renderHistoryDetail(rec: WaveHistoryRecord): string {\n321:   const lines: string[] = [];\n322: \n323:   // Summary\n324:   lines.push(`#WAVE ${row(\n325:     rec.wave_id,\n326:     rec.summary.total,\n327:     rec.summary.succeeded,\n328:     rec.summary.failed,\n329:     rec.summary.merged,\n330:   )}`);\n331: \n332:   // Agent details\n333:   lines.push(fieldsHeader([\n334:     \"feature_id\", \"status\", \"retries\", \"duration_ms\", \"build_passed\", \"error\",\n335:   ]));\n336: \n337:   for (const a of rec.agents) {\n338:     lines.push(row(\n339:       a.feature_id,\n340:       a.status,\n341:       a.retries,\n342:       a.duration_ms ?? \"\",\n343:       a.build_passed === null ? \"\" : encodeBool(a.build_passed),\n344:       encodeNullable(a.error?.split(\"\\n\")[0]?.slice(0, 60) ?? null),\n345:     ));\n346:   }\n347: \n348:   return lines.join(\"\\n\");\n349: }\n350: \n351: // ---------------------------------------------------------------------------\n352: // Tasks Check Renderer\n353: // ---------------------------------------------------------------------------\n354: \n355: /**\n356:  * Render task check results in TOON format.\n357:  *\n358:  * Fields: level|message\n359:  */\n360: export function renderTasksCheck(result: {\n361:   ok: boolean;\n362:   issues: Array<{ level: string; message: string }>;\n363:   items_checked: number;\n364: }): string {\n365:   const lines: string[] = [];\n366: \n367:   lines.push(`#CHECK ${row(\n368:     encodeBool(result.ok),\n369:     result.items_checked,\n370:     result.issues.length,\n371:   )}`);\n372: \n373:   if (result.issues.length > 0) {\n374:     lines.push(fieldsHeader([\"level\", \"message\"]));\n375:     for (const issue of result.issues) {\n376:       lines.push(row(\n377:         issue.level === \"error\" ? \"E\" : \"W\",\n378:         issue.message,\n379:       ));\n380:     }\n381:   }\n382: \n383:   return lines.join(\"\\n\");\n384: }\n385: \n386: // ---------------------------------------------------------------------------\n387: // Abort Renderer\n388: // ---------------------------------------------------------------------------\n389: \n390: /**\n391:  * Render abort result in TOON format.\n392:  *\n393:  * Uses key:value pairs for the single-record result.\n394:  */\n395: export function renderAbort(result: {\n396:   feature_id: string;\n397:   previous_status: string;\n398:   new_status: string;\n399:   mux_killed: boolean;\n400:   process_killed: boolean;\n401:   requeued: boolean;\n402: }): string {\n403:   const lines: string[] = [];\n404:   lines.push(`fid:${result.feature_id}`);\n405:   lines.push(`prev:${result.previous_status}`);\n406:   lines.push(`new:${result.new_status}`);\n407:   lines.push(`mux:${encodeBool(result.mux_killed)}`);\n408:   lines.push(`proc:${encodeBool(result.process_killed)}`);\n409:   lines.push(`rq:${encodeBool(result.requeued)}`);\n410:   return lines.join(\"\\n\");\n411: }\n412: \n413: // ---------------------------------------------------------------------------\n414: // Cleanup Renderer\n415: // ---------------------------------------------------------------------------\n416: \n417: /**\n418:  * Render cleanup result in TOON format.\n419:  *\n420:  * Uses key:value pairs for summary data.\n421:  */\n422: export function renderCleanup(result: {\n423:   mux_sessions_killed?: number;\n424:   worktrees_removed?: number;\n425:   state_removed?: boolean;\n426:   logs_removed?: boolean;\n427:   remaining_branches?: string[];\n428:   history_preserved?: boolean;\n429:   // dry-run fields\n430:   dry_run?: boolean;\n431:   mux_sessions?: string[];\n432:   mux_sessions_count?: number;\n433:   worktrees?: string[];\n434:   worktrees_count?: number;\n435:   files_to_remove?: string[];\n436: }): string {\n437:   const lines: string[] = [];\n438: \n439:   if (result.dry_run) {\n440:     lines.push(`dry:1`);\n441:     lines.push(`mux:${result.mux_sessions_count ?? 0}`);\n442:     lines.push(`wt:${result.worktrees_count ?? 0}`);\n443:     if (result.mux_sessions && result.mux_sessions.length > 0) {\n444:       lines.push(`mux_list:${encodeArray(result.mux_sessions)}`);\n445:     }\n446:     if (result.worktrees && result.worktrees.length > 0) {\n447:       lines.push(`wt_list:${encodeArray(result.worktrees)}`);\n448:     }\n449:     if (result.files_to_remove && result.files_to_remove.length > 0) {\n450:       lines.push(`files:${encodeArray(result.files_to_remove)}`);\n451:     }\n452:   } else {\n453:     lines.push(`mux:${result.mux_sessions_killed ?? 0}`);\n454:     lines.push(`wt:${result.worktrees_removed ?? 0}`);\n455:     lines.push(`st:${encodeBool(result.state_removed ?? false)}`);\n456:     lines.push(`logs:${encodeBool(result.logs_removed ?? false)}`);\n457:     if (result.remaining_branches && result.remaining_branches.length > 0) {\n458:       lines.push(`branches:${encodeArray(result.remaining_branches)}`);\n459:     }\n460:     lines.push(`hist:${encodeBool(result.history_preserved ?? false)}`);\n461:   }\n462: \n463:   return lines.join(\"\\n\");\n464: }\n465: \n466: // ---------------------------------------------------------------------------\n467: // Merge Renderer\n468: // ---------------------------------------------------------------------------\n469: \n470: /**\n471:  * Render merge results in TOON format.\n472:  *\n473:  * Fields: feature_id|branch|status|error\n474:  */\n475: export function renderMerge(result: {\n476:   wave_id: string;\n477:   base_branch: string;\n478:   merged?: number;\n479:   failed?: number;\n480:   agents: Array<{ feature_id: string; branch: string; status?: string; error?: string | null }>;\n481:   // dry-run fields\n482:   dry_run?: boolean;\n483:   count?: number;\n484:   auto_push?: boolean;\n485: }): string {\n486:   const lines: string[] = [];\n487: \n488:   if (result.dry_run) {\n489:     lines.push(`#DRY wave:${result.wave_id}|base:${result.base_branch}|count:${result.count ?? 0}|push:${encodeBool(result.auto_push ?? false)}`);\n490:     lines.push(fieldsHeader([\"feature_id\", \"branch\"]));\n491:     for (const a of result.agents) {\n492:       lines.push(row(a.feature_id, a.branch));\n493:     }\n494:   } else {\n495:     lines.push(`#MERGE wave:${result.wave_id}|base:${result.base_branch}|merged:${result.merged}|failed:${result.failed}`);\n496:     lines.push(fieldsHeader([\"feature_id\", \"branch\", \"status\", \"error\"]));\n497:     for (const a of result.agents) {\n498:       lines.push(row(a.feature_id, a.branch, a.status, encodeNullable(a.error)));\n499:     }\n500:   }\n501: \n502:   return lines.join(\"\\n\");\n503: }\n504: \n505: // ---------------------------------------------------------------------------\n506: // Retry Renderer\n507: // ---------------------------------------------------------------------------\n508: \n509: /**\n510:  * Render retry result in TOON format.\n511:  *\n512:  * Uses key:value pairs for the single-record result.\n513:  */\n514: export function renderRetry(result: {\n515:   feature_id: string;\n516:   mode?: string;\n517:   status?: string;\n518:   mux_session?: string;\n519:   pid?: number | null;\n520:   // dry-run fields\n521:   dry_run?: boolean;\n522:   current_status?: string;\n523:   retries_so_far?: number;\n524:   worktree?: string;\n525:   model?: string | null;\n526: }): string {\n527:   const lines: string[] = [];\n528: \n529:   if (result.dry_run) {\n530:     lines.push(`dry:1`);\n531:     lines.push(`fid:${result.feature_id}`);\n532:     lines.push(`st:${result.current_status ?? \"\"}`);\n533:     lines.push(`retries:${result.retries_so_far ?? 0}`);\n534:     lines.push(`wt:${result.worktree ?? \"\"}`);\n535:     lines.push(`mode:${result.mode ?? \"\"}`);\n536:     lines.push(`model:${encodeNullable(result.model ?? null)}`);\n537:   } else {\n538:     lines.push(`fid:${result.feature_id}`);\n539:     lines.push(`mode:${result.mode ?? \"\"}`);\n540:     lines.push(`st:${result.status ?? \"\"}`);\n541:     if (result.mux_session) {\n542:       lines.push(`mux:${result.mux_session}`);\n543:     }\n544:     if (result.pid !== undefined && result.pid !== null) {\n545:       lines.push(`pid:${result.pid}`);\n546:     }\n547:   }\n548: \n549:   return lines.join(\"\\n\");\n550: }\n551: \n552: // ---------------------------------------------------------------------------\n553: // Logs Renderer\n554: // ---------------------------------------------------------------------------\n555: \n556: /**\n557:  * Render logs in TOON format.\n558:  *\n559:  * Emits a header line then one line per log entry.\n560:  */\n561: export function renderLogs(result: {\n562:   feature_id: string;\n563:   log_file: string;\n564:   line_count: number;\n565:   first_line: number | null;\n566:   last_line: number | null;\n567:   lines: string[];\n568: }): string {\n569:   const output: string[] = [];\n570:   output.push(`#LOGS fid:${result.feature_id}|count:${result.line_count}|first:${result.first_line ?? \"\"}|last:${result.last_line ?? \"\"}`);\n571:   for (const line of result.lines) {\n572:     output.push(line);\n573:   }\n574:   return output.join(\"\\n\");\n575: }\n576: \n577: // ---------------------------------------------------------------------------\n578: // Launch Dry-Run Renderer\n579: // ---------------------------------------------------------------------------\n580: \n581: /**\n582:  * Render launch dry-run result in TOON format.\n583:  *\n584:  * Fields: id|priority|difficulty|effort\n585:  */\n586: export function renderLaunchDryRun(result: {\n587:   dry_run: boolean;\n588:   base_branch: string;\n589:   max_concurrent: number;\n590:   model: string | null;\n591:   interactive: boolean;\n592:   selected: Array<{ id: string; title: string; priority: string; difficulty: string; effort: string }>;\n593: }): string {\n594:   const lines: string[] = [];\n595: \n596:   lines.push(`#LAUNCH dry:1|base:${result.base_branch}|max:${result.max_concurrent}|model:${encodeNullable(result.model)}|interactive:${encodeBool(result.interactive)}`);\n597:   lines.push(fieldsHeader([\"id\", \"priority\", \"difficulty\", \"effort\", \"title\"]));\n598: \n599:   for (const f of result.selected) {\n600:     lines.push(row(\n601:       f.id,\n602:       encodePriority(f.priority),\n603:       encodeDifficulty(f.difficulty),\n604:       encodeDuration(f.effort),\n605:       f.title,\n606:     ));\n607:   }\n608: \n609:   return lines.join(\"\\n\");\n610: }\n611: \n612: // ---------------------------------------------------------------------------\n613: // Graph Renderer\n614: // ---------------------------------------------------------------------------\n615: \n616: /**\n617:  * Render tasks graph in TOON format.\n618:  *\n619:  * Emits mermaid source (if any), node/edge counts, and orphans.\n620:  */\n621: export function renderGraph(result: {\n622:   mermaid: string | null;\n623:   nodes: number;\n624:   edges: number;\n625:   orphan_count?: number;\n626:   orphans?: Array<{ id: string; title: string; status: string }>;\n627: }): string {\n628:   const lines: string[] = [];\n629: \n630:   lines.push(`#GRAPH nodes:${result.nodes}|edges:${result.edges}|orphans:${result.orphan_count ?? 0}`);\n631: \n632:   if (result.mermaid) {\n633:     lines.push(`#MERMAID`);\n634:     lines.push(result.mermaid);\n635:     lines.push(`#END`);\n636:   }\n637: \n638:   if (result.orphans && result.orphans.length > 0) {\n639:     lines.push(fieldsHeader([\"id\", \"status\", \"title\"]));\n640:     for (const o of result.orphans) {\n641:       lines.push(row(o.id, encodeStatus(o.status), o.title));\n642:     }\n643:   }\n644: \n645:   return lines.join(\"\\n\");\n646: }\n647: \n648: // ---------------------------------------------------------------------------\n649: // Verify Results Renderer (multi-agent)\n650: // ---------------------------------------------------------------------------\n651: \n652: /**\n653:  * Render verify command results in TOON format.\n654:  *\n655:  * Fields: feature_id|branch|status|build_passed|error\n656:  */\n657: export function renderVerifyResults(result: {\n658:   wave_id: string;\n659:   verified: number;\n660:   failed: number;\n661:   agents: Array<{ feature_id: string; branch: string; status: string; build_passed: boolean | null; error?: string | null }>;\n662: }): string {\n663:   const lines: string[] = [];\n664: \n665:   lines.push(`#VERIFY wave:${result.wave_id}|verified:${result.verified}|failed:${result.failed}`);\n666:   lines.push(fieldsHeader([\"feature_id\", \"branch\", \"status\", \"build_passed\", \"error\"]));\n667: \n668:   for (const a of result.agents) {\n669:     lines.push(row(\n670:       a.feature_id,\n671:       a.branch,\n672:       a.status,\n673:       a.build_passed === null ? \"\" : encodeBool(a.build_passed),\n674:       encodeNullable(a.error),\n675:     ));\n676:   }\n677: \n678:   return lines.join(\"\\n\");\n679: }\n680: \n681: // ---------------------------------------------------------------------------\n682: // Generic Fallback Renderer\n683: // ---------------------------------------------------------------------------\n684: \n685: /**\n686:  * Generic TOON renderer for data that doesn't have a specific formatter.\n687:  * Renders objects as key:value pairs, arrays as pipe-delimited rows.\n688:  */\n689: export function renderGeneric(data: unknown): string {\n690:   if (data === null || data === undefined) return \"\";\n691: \n692:   if (Array.isArray(data)) {\n693:     if (data.length === 0) return \"\";\n694:     // If array of objects, use first item's keys as fields\n695:     if (typeof data[0] === \"object\" && data[0] !== null) {\n696:       const keys = Object.keys(data[0] as Record<string, unknown>);\n697:       const lines = [fieldsHeader(keys)];\n698:       for (const item of data) {\n699:         const obj = item as Record<string, unknown>;\n700:         lines.push(row(...keys.map((k) => {\n701:           const v = obj[k];\n702:           if (Array.isArray(v)) return encodeArray(v.map(String));\n703:           if (typeof v === \"boolean\") return encodeBool(v);\n704:           if (v === null || v === undefined) return \"\";\n705:           return String(v);\n706:         })));\n707:       }\n708:       return lines.join(\"\\n\");\n709:     }\n710:     // Array of primitives\n711:     return data.map(String).join(\"\\n\");\n712:   }\n713: \n714:   if (typeof data === \"object\") {\n715:     const obj = data as Record<string, unknown>;\n716:     const lines: string[] = [];\n717:     for (const [key, val] of Object.entries(obj)) {\n718:       if (val === null || val === undefined) {\n719:         lines.push(`${key}:`);\n720:       } else if (Array.isArray(val)) {\n721:         lines.push(`${key}:${encodeArray(val.map(String))}`);\n722:       } else if (typeof val === \"boolean\") {\n723:         lines.push(`${key}:${encodeBool(val)}`);\n724:       } else if (typeof val === \"object\") {\n725:         // Nested object — flatten to key.subkey:value\n726:         for (const [sk, sv] of Object.entries(val as Record<string, unknown>)) {\n727:           lines.push(`${key}.${sk}:${sv === null || sv === undefined ? \"\" : String(sv)}`);\n728:         }\n729:       } else {\n730:         lines.push(`${key}:${String(val)}`);\n731:       }\n732:     }\n733:     return lines.join(\"\\n\");\n734:   }\n735: \n736:   return String(data);\n737: }\n\n(End of file - total 737 lines)\n</content>","title":"src/lib/toon.ts","metadata":{"preview":"/**\n * toon.ts -- Token-Optimized Output Notation (TOON) formatter module.\n *\n * Converts structured command results into compact, pipe-delimited TOON\n * notation. Reduces token count by 60%+ vs JSON for equivalent data.\n *\n * Format:\n *   - Delimiter: pipe (|)\n *   - First line: #FIELDS header listing field names\n *   - One record per line, positional fields\n *   - Status codes: BL/PL/IP/BK/IR/DN/CN\n *   - Priority codes: C/H/M/L/W\n *   - Difficulty codes: T/E/M/H/V\n *   - Duration: compact (30m, 2h, 1d4h)\n *   - Boolean: 1/0\n *   - Null/missing: empty field (||)\n *   - Arrays: comma-separated within a field\n */\n\nimport type { Task, TaskStatus, Priority, Difficulty } from \"./tasks.js\";","truncated":false,"loaded":[]},"time":{"start":1773440108637,"end":1773440108640}}}}
{"type":"tool_use","timestamp":1773440109041,"sessionID":"ses_316bba7c1ffenLP0vTOciFexZp","part":{"id":"prt_ce94488b500115JlV8N7cAYq9P","sessionID":"ses_316bba7c1ffenLP0vTOciFexZp","messageID":"msg_ce94479850011tfy8DzGWUR7TR","type":"tool","callID":"toolu_vrtx_015EGuWWUahKgyaad6NpdsmH","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/toon-output/src/lib/toon-spec.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/toon-output/src/lib/toon-spec.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * toon-spec.ts — Token-Optimized Output Notation (TOON) format specification.\n3:  *\n4:  * TOON is a compact, pipe-delimited encoding designed for AI agent consumption.\n5:  * It minimizes token usage while remaining fully parseable. Agents call\n6:  * `woco describe --output toon` once per session to learn the format, then\n7:  * parse all subsequent TOON output without further context.\n8:  *\n9:  * Format rules:\n10:  *   - Delimiter: pipe character (|)\n11:  *   - Fields are positional (fixed order per command, no field names in output)\n12:  *   - Header line: optional #FIELDS comment listing field order\n13:  *   - Status codes: BL=backlog, PL=planned, IP=in_progress, BK=blocked, IR=in_review, DN=done, CN=cancelled\n14:  *   - Priority codes: C=critical, H=high, M=medium, L=low, W=wishlist\n15:  *   - Difficulty codes: T=trivial, E=easy, M=medium, H=hard, V=very_hard\n16:  *   - Duration: compact format (30m, 2h, 1d4h) instead of ISO 8601\n17:  *   - Boolean: 1/0 instead of true/false\n18:  *   - Null/missing: empty field (||)\n19:  *   - Arrays: comma-separated within a single field (no pipes)\n20:  */\n21: \n22: import type { TaskStatus, Priority, Difficulty } from \"./tasks.js\";\n23: \n24: // ---------------------------------------------------------------------------\n25: // Status Code Mappings\n26: // ---------------------------------------------------------------------------\n27: \n28: export const TOON_STATUS_ENCODE: Readonly<Record<TaskStatus, string>> = {\n29:   backlog: \"BL\",\n30:   planned: \"PL\",\n31:   in_progress: \"IP\",\n32:   blocked: \"BK\",\n33:   in_review: \"IR\",\n34:   done: \"DN\",\n35:   cancelled: \"CN\",\n36: };\n37: \n38: export const TOON_STATUS_DECODE: Readonly<Record<string, TaskStatus>> = {\n39:   BL: \"backlog\",\n40:   PL: \"planned\",\n41:   IP: \"in_progress\",\n42:   BK: \"blocked\",\n43:   IR: \"in_review\",\n44:   DN: \"done\",\n45:   CN: \"cancelled\",\n46: };\n47: \n48: // ---------------------------------------------------------------------------\n49: // Priority Code Mappings\n50: // ---------------------------------------------------------------------------\n51: \n52: export const TOON_PRIORITY_ENCODE: Readonly<Record<Priority, string>> = {\n53:   critical: \"C\",\n54:   high: \"H\",\n55:   medium: \"M\",\n56:   low: \"L\",\n57:   wishlist: \"W\",\n58: };\n59: \n60: export const TOON_PRIORITY_DECODE: Readonly<Record<string, Priority>> = {\n61:   C: \"critical\",\n62:   H: \"high\",\n63:   M: \"medium\",\n64:   L: \"low\",\n65:   W: \"wishlist\",\n66: };\n67: \n68: // ---------------------------------------------------------------------------\n69: // Difficulty Code Mappings\n70: // ---------------------------------------------------------------------------\n71: \n72: export const TOON_DIFFICULTY_ENCODE: Readonly<Record<Difficulty, string>> = {\n73:   trivial: \"T\",\n74:   easy: \"E\",\n75:   medium: \"M\",\n76:   hard: \"H\",\n77:   very_hard: \"V\",\n78: };\n79: \n80: export const TOON_DIFFICULTY_DECODE: Readonly<Record<string, Difficulty>> = {\n81:   T: \"trivial\",\n82:   E: \"easy\",\n83:   M: \"medium\",\n84:   H: \"hard\",\n85:   V: \"very_hard\",\n86: };\n87: \n88: // ---------------------------------------------------------------------------\n89: // Duration Encoding/Decoding\n90: // ---------------------------------------------------------------------------\n91: \n92: /**\n93:  * Convert an ISO 8601 duration to compact TOON format.\n94:  *\n95:  * Examples:\n96:  *   PT30M     -> 30m\n97:  *   PT2H      -> 2h\n98:  *   PT1H30M   -> 1h30m\n99:  *   P1D       -> 1d\n100:  *   P1DT4H    -> 1d4h\n101:  *   P2DT4H30M -> 2d4h30m\n102:  */\n103: export function encodeDuration(iso: string): string {\n104:   if (!iso) return \"\";\n105: \n106:   const match = iso.match(\n107:     /^P(?:(\\d+)Y)?(?:(\\d+)M)?(?:(\\d+)D)?(?:T(?:(\\d+)H)?(?:(\\d+)M)?(?:(\\d+)S)?)?$/\n108:   );\n109:   if (!match) return iso; // return raw if unparseable\n110: \n111:   const years = parseInt(match[1] || \"0\", 10);\n112:   const months = parseInt(match[2] || \"0\", 10);\n113:   const days = parseInt(match[3] || \"0\", 10) + years * 365 + months * 30;\n114:   const hours = parseInt(match[4] || \"0\", 10);\n115:   const minutes = parseInt(match[5] || \"0\", 10);\n116:   const seconds = parseInt(match[6] || \"0\", 10);\n117: \n118:   const parts: string[] = [];\n119:   if (days > 0) parts.push(`${days}d`);\n120:   if (hours > 0) parts.push(`${hours}h`);\n121:   if (minutes > 0) parts.push(`${minutes}m`);\n122:   if (seconds > 0) parts.push(`${seconds}s`);\n123: \n124:   return parts.length > 0 ? parts.join(\"\") : \"0m\";\n125: }\n126: \n127: /**\n128:  * Convert compact TOON duration back to ISO 8601.\n129:  *\n130:  * Examples:\n131:  *   30m    -> PT30M\n132:  *   2h     -> PT2H\n133:  *   1h30m  -> PT1H30M\n134:  *   1d     -> P1D\n135:  *   1d4h   -> P1DT4H\n136:  */\n137: export function decodeDuration(compact: string): string {\n138:   if (!compact) return \"\";\n139: \n140:   const dMatch = compact.match(/(\\d+)d/);\n141:   const hMatch = compact.match(/(\\d+)h/);\n142:   const mMatch = compact.match(/(\\d+)m/);\n143:   const sMatch = compact.match(/(\\d+)s/);\n144: \n145:   const days = dMatch ? parseInt(dMatch[1], 10) : 0;\n146:   const hours = hMatch ? parseInt(hMatch[1], 10) : 0;\n147:   const minutes = mMatch ? parseInt(mMatch[1], 10) : 0;\n148:   const seconds = sMatch ? parseInt(sMatch[1], 10) : 0;\n149: \n150:   let result = \"P\";\n151:   if (days > 0) result += `${days}D`;\n152: \n153:   const hasTime = hours > 0 || minutes > 0 || seconds > 0;\n154:   if (hasTime) {\n155:     result += \"T\";\n156:     if (hours > 0) result += `${hours}H`;\n157:     if (minutes > 0) result += `${minutes}M`;\n158:     if (seconds > 0) result += `${seconds}S`;\n159:   }\n160: \n161:   // If nothing was added, it's zero duration\n162:   if (result === \"P\") return \"PT0S\";\n163: \n164:   return result;\n165: }\n166: \n167: // ---------------------------------------------------------------------------\n168: // Boolean Encoding\n169: // ---------------------------------------------------------------------------\n170: \n171: export function encodeBool(value: boolean): string {\n172:   return value ? \"1\" : \"0\";\n173: }\n174: \n175: export function decodeBool(value: string): boolean {\n176:   return value === \"1\";\n177: }\n178: \n179: // ---------------------------------------------------------------------------\n180: // Null/Missing Encoding\n181: // ---------------------------------------------------------------------------\n182: \n183: export function encodeNullable(value: string | null | undefined): string {\n184:   return value ?? \"\";\n185: }\n186: \n187: // ---------------------------------------------------------------------------\n188: // Array Encoding (comma-separated within a single pipe-delimited field)\n189: // ---------------------------------------------------------------------------\n190: \n191: export function encodeArray(arr: string[] | null | undefined): string {\n192:   if (!arr || arr.length === 0) return \"\";\n193:   return arr.join(\",\");\n194: }\n195: \n196: export function decodeArray(value: string): string[] {\n197:   if (!value) return [];\n198:   return value.split(\",\").map((s) => s.trim()).filter(Boolean);\n199: }\n200: \n201: // ---------------------------------------------------------------------------\n202: // Field Definitions per Command\n203: // ---------------------------------------------------------------------------\n204: \n205: /**\n206:  * Describes a single field in a TOON record.\n207:  */\n208: export interface ToonFieldDef {\n209:   /** Field name (for the #FIELDS header) */\n210:   name: string;\n211:   /** Human-readable description */\n212:   description: string;\n213:   /** Data type (for documentation) */\n214:   type: \"string\" | \"status\" | \"priority\" | \"difficulty\" | \"duration\" | \"bool\" | \"number\" | \"array\" | \"datetime\";\n215: }\n216: \n217: /**\n218:  * Describes the TOON output format for a specific command.\n219:  */\n220: export interface ToonCommandSpec {\n221:   /** Command name (e.g. \"tasks list\", \"tasks show\") */\n222:   command: string;\n223:   /** Fields in positional order */\n224:   fields: ToonFieldDef[];\n225:   /** Optional example line */\n226:   example?: string;\n227: }\n228: \n229: // ---------------------------------------------------------------------------\n230: // Per-command field specs\n231: // ---------------------------------------------------------------------------\n232: \n233: export const TOON_COMMAND_SPECS: readonly ToonCommandSpec[] = [\n234:   {\n235:     command: \"tasks list\",\n236:     fields: [\n237:       { name: \"id\", description: \"Task identifier\", type: \"string\" },\n238:       { name: \"status\", description: \"Task status (BL/PL/IP/BK/IR/DN/CN)\", type: \"status\" },\n239:       { name: \"priority\", description: \"Priority level (C/H/M/L/W)\", type: \"priority\" },\n240:       { name: \"difficulty\", description: \"Difficulty level (T/E/M/H/V)\", type: \"difficulty\" },\n241:       { name: \"effort\", description: \"Effort estimate (compact: 30m, 2h, 1d4h)\", type: \"duration\" },\n242:       { name: \"completion\", description: \"Completion percentage (0-100)\", type: \"number\" },\n243:       { name: \"deps_met\", description: \"All dependencies satisfied (1/0)\", type: \"bool\" },\n244:       { name: \"depends_on\", description: \"Dependency IDs (comma-separated)\", type: \"array\" },\n245:       { name: \"title\", description: \"Task title\", type: \"string\" },\n246:     ],\n247:     example: \"#FIELDS id|status|priority|difficulty|effort|completion|deps_met|depends_on|title\\nauth-flow|BL|H|E|2h|0|1||Add authentication flow\\nsearch-api|IP|C|M|4h|35|0|auth-flow|Implement search API\",\n248:   },\n249:   {\n250:     command: \"tasks show\",\n251:     fields: [\n252:       { name: \"id\", description: \"Task identifier\", type: \"string\" },\n253:       { name: \"status\", description: \"Task status (BL/PL/IP/BK/IR/DN/CN)\", type: \"status\" },\n254:       { name: \"priority\", description: \"Priority level (C/H/M/L/W)\", type: \"priority\" },\n255:       { name: \"difficulty\", description: \"Difficulty level (T/E/M/H/V)\", type: \"difficulty\" },\n256:       { name: \"effort\", description: \"Effort estimate (compact)\", type: \"duration\" },\n257:       { name: \"completion\", description: \"Completion percentage (0-100)\", type: \"number\" },\n258:       { name: \"deps_met\", description: \"All dependencies satisfied (1/0)\", type: \"bool\" },\n259:       { name: \"depends_on\", description: \"Dependency IDs (comma-separated)\", type: \"array\" },\n260:       { name: \"started_at\", description: \"Start timestamp (ISO 8601 or empty)\", type: \"datetime\" },\n261:       { name: \"ended_at\", description: \"End timestamp (ISO 8601 or empty)\", type: \"datetime\" },\n262:       { name: \"title\", description: \"Task title\", type: \"string\" },\n263:     ],\n264:     example: \"#FIELDS id|status|priority|difficulty|effort|completion|deps_met|depends_on|started_at|ended_at|title\\nauth-flow|IP|H|E|2h|35|1||2026-03-10T08:00:00Z||Add authentication flow\",\n265:   },\n266:   {\n267:     command: \"status\",\n268:     fields: [\n269:       { name: \"feature_id\", description: \"Feature/task identifier\", type: \"string\" },\n270:       { name: \"agent_status\", description: \"Agent status (queued/running/done/failed/verified/merged)\", type: \"string\" },\n271:       { name: \"exit_code\", description: \"Process exit code (empty if still running)\", type: \"number\" },\n272:       { name: \"retries\", description: \"Number of retries so far\", type: \"number\" },\n273:       { name: \"started_at\", description: \"Agent start timestamp\", type: \"datetime\" },\n274:     ],\n275:     example: \"#FIELDS feature_id|agent_status|exit_code|retries|started_at\\nauth-flow|running||0|2026-03-10T08:00:00Z\\nsearch-api|done|0|1|2026-03-10T08:05:00Z\",\n276:   },\n277:   {\n278:     command: \"history\",\n279:     fields: [\n280:       { name: \"wave_id\", description: \"Wave identifier\", type: \"string\" },\n281:       { name: \"started_at\", description: \"Wave start timestamp\", type: \"datetime\" },\n282:       { name: \"ended_at\", description: \"Wave end timestamp\", type: \"datetime\" },\n283:       { name: \"total_agents\", description: \"Number of agents in the wave\", type: \"number\" },\n284:       { name: \"succeeded\", description: \"Number of agents that succeeded\", type: \"number\" },\n285:       { name: \"failed\", description: \"Number of agents that failed\", type: \"number\" },\n286:     ],\n287:     example: \"#FIELDS wave_id|started_at|ended_at|total_agents|succeeded|failed\\nwave-2026-03-10-001|2026-03-10T08:00:00Z|2026-03-10T09:30:00Z|5|4|1\",\n288:   },\n289:   {\n290:     command: \"verify\",\n291:     fields: [\n292:       { name: \"feature_id\", description: \"Feature/task identifier\", type: \"string\" },\n293:       { name: \"branch\", description: \"Git branch name\", type: \"string\" },\n294:       { name: \"status\", description: \"Post-verification status (verified/failed)\", type: \"string\" },\n295:       { name: \"build_passed\", description: \"Build passed (1/0 or empty if not run)\", type: \"bool\" },\n296:       { name: \"error\", description: \"Error message (empty if none)\", type: \"string\" },\n297:     ],\n298:     example: \"#VERIFY wave:wave-001|verified:2|failed:0\\n#FIELDS feature_id|branch|status|build_passed|error\\nauth-flow|feature/auth-flow|verified|1|\",\n299:   },\n300:   {\n301:     command: \"abort\",\n302:     fields: [\n303:       { name: \"fid\", description: \"Feature ID that was aborted\", type: \"string\" },\n304:       { name: \"prev\", description: \"Previous agent status\", type: \"string\" },\n305:       { name: \"new\", description: \"New agent status (failed or queued)\", type: \"string\" },\n306:       { name: \"mux\", description: \"Multiplexer session killed (1/0)\", type: \"bool\" },\n307:       { name: \"proc\", description: \"Process killed (1/0)\", type: \"bool\" },\n308:       { name: \"rq\", description: \"Requeued (1/0)\", type: \"bool\" },\n309:     ],\n310:     example: \"fid:auth-flow\\nprev:running\\nnew:failed\\nmux:1\\nproc:1\\nrq:0\",\n311:   },\n312:   {\n313:     command: \"cleanup\",\n314:     fields: [\n315:       { name: \"mux\", description: \"Number of multiplexer sessions killed (or count for dry-run)\", type: \"number\" },\n316:       { name: \"wt\", description: \"Number of worktrees removed (or count for dry-run)\", type: \"number\" },\n317:       { name: \"st\", description: \"State file removed (1/0)\", type: \"bool\" },\n318:       { name: \"logs\", description: \"Logs directory removed (1/0)\", type: \"bool\" },\n319:       { name: \"hist\", description: \"History preserved (1/0)\", type: \"bool\" },\n320:     ],\n321:     example: \"mux:2\\nwt:3\\nst:1\\nlogs:1\\nhist:1\",\n322:   },\n323:   {\n324:     command: \"merge\",\n325:     fields: [\n326:       { name: \"feature_id\", description: \"Feature/task identifier\", type: \"string\" },\n327:       { name: \"branch\", description: \"Git branch name\", type: \"string\" },\n328:       { name: \"status\", description: \"Post-merge status (merged/failed)\", type: \"string\" },\n329:       { name: \"error\", description: \"Error message (empty if none)\", type: \"string\" },\n330:     ],\n331:     example: \"#MERGE wave:wave-001|base:main|merged:2|failed:0\\n#FIELDS feature_id|branch|status|error\\nauth-flow|feature/auth-flow|merged|\",\n332:   },\n333:   {\n334:     command: \"retry\",\n335:     fields: [\n336:       { name: \"fid\", description: \"Feature ID being retried\", type: \"string\" },\n337:       { name: \"mode\", description: \"Launch mode (interactive/headless)\", type: \"string\" },\n338:       { name: \"st\", description: \"Agent status after retry\", type: \"string\" },\n339:     ],\n340:     example: \"fid:auth-flow\\nmode:headless\\nst:running\",\n341:   },\n342:   {\n343:     command: \"logs\",\n344:     fields: [\n345:       { name: \"feature_id\", description: \"Feature ID whose logs are shown\", type: \"string\" },\n346:       { name: \"line_count\", description: \"Number of log lines\", type: \"number\" },\n347:       { name: \"first_line\", description: \"First line number shown\", type: \"number\" },\n348:       { name: \"last_line\", description: \"Last line number shown\", type: \"number\" },\n349:     ],\n350:     example: \"#LOGS fid:auth-flow|count:150|first:1|last:150\\n[log lines follow]\",\n351:   },\n352:   {\n353:     command: \"tasks graph\",\n354:     fields: [\n355:       { name: \"nodes\", description: \"Number of graph nodes\", type: \"number\" },\n356:       { name: \"edges\", description: \"Number of graph edges\", type: \"number\" },\n357:       { name: \"orphans\", description: \"Number of orphan tasks\", type: \"number\" },\n358:     ],\n359:     example: \"#GRAPH nodes:5|edges:3|orphans:2\\n#MERMAID\\nflowchart LR\\n...\\n#END\",\n360:   },\n361:   {\n362:     command: \"launch\",\n363:     fields: [\n364:       { name: \"id\", description: \"Feature/task identifier\", type: \"string\" },\n365:       { name: \"priority\", description: \"Priority level (C/H/M/L/W)\", type: \"priority\" },\n366:       { name: \"difficulty\", description: \"Difficulty level (T/E/M/H/V)\", type: \"difficulty\" },\n367:       { name: \"effort\", description: \"Effort estimate (compact)\", type: \"duration\" },\n368:       { name: \"title\", description: \"Task title\", type: \"string\" },\n369:     ],\n370:     example: \"#LAUNCH dry:1|base:main|max:3|model:|interactive:0\\n#FIELDS id|priority|difficulty|effort|title\\nauth-flow|H|E|2h|Add authentication flow\",\n371:   },\n372: ] as const;\n373: \n374: // ---------------------------------------------------------------------------\n375: // Full TOON Specification (emitted by `woco describe --output toon`)\n376: // ---------------------------------------------------------------------------\n377: \n378: export interface ToonSpec {\n379:   format: \"TOON\";\n380:   version: string;\n381:   description: string;\n382:   delimiter: string;\n383:   rules: {\n384:     status_codes: string;\n385:     priority_codes: string;\n386:     difficulty_codes: string;\n387:     duration: string;\n388:     boolean: string;\n389:     null_missing: string;\n390:     arrays: string;\n391:     field_order: string;\n392:     header_line: string;\n393:   };\n394:   commands: ToonCommandSpec[];\n395: }\n396: \n397: /**\n398:  * Build the complete TOON specification object.\n399:  * This is the payload emitted by `woco describe --output toon`.\n400:  */\n401: export function buildToonSpec(version: string): ToonSpec {\n402:   return {\n403:     format: \"TOON\",\n404:     version,\n405:     description:\n406:       \"Token-Optimized Output Notation — compact pipe-delimited format for AI agent consumption. \" +\n407:       \"Call `woco describe --output toon` once per session to learn the format.\",\n408:     delimiter: \"|\",\n409:     rules: {\n410:       status_codes: \"BL=backlog PL=planned IP=in_progress BK=blocked IR=in_review DN=done CN=cancelled\",\n411:       priority_codes: \"C=critical H=high M=medium L=low W=wishlist\",\n412:       difficulty_codes: \"T=trivial E=easy M=medium H=hard V=very_hard\",\n413:       duration: \"Compact: 30m 2h 1d4h 2d4h30m (no spaces, no ISO prefix)\",\n414:       boolean: \"1=true 0=false\",\n415:       null_missing: \"Empty field between pipes (||)\",\n416:       arrays: \"Comma-separated within a single field (no pipes inside arrays)\",\n417:       field_order: \"Fixed positional per command. See 'commands' array for field order.\",\n418:       header_line: \"#FIELDS comment as first line lists field names in pipe-delimited order\",\n419:     },\n420:     commands: [...TOON_COMMAND_SPECS],\n421:   };\n422: }\n423: \n424: /**\n425:  * Emit the TOON legend as plain text — a compact, self-describing reference\n426:  * that an agent can cache and reuse for the rest of the session.\n427:  */\n428: export function renderToonLegend(version: string): string {\n429:   const lines: string[] = [];\n430: \n431:   lines.push(`# TOON v${version} — Token-Optimized Output Notation`);\n432:   lines.push(`# Delimiter: | (pipe)`);\n433:   lines.push(`# Status: BL=backlog PL=planned IP=in_progress BK=blocked IR=in_review DN=done CN=cancelled`);\n434:   lines.push(`# Priority: C=critical H=high M=medium L=low W=wishlist`);\n435:   lines.push(`# Difficulty: T=trivial E=easy M=medium H=hard V=very_hard`);\n436:   lines.push(`# Duration: compact (30m, 2h, 1d4h) — no ISO prefix`);\n437:   lines.push(`# Bool: 1/0  Null: empty (||)  Arrays: comma-separated`);\n438:   lines.push(`# First line per output: #FIELDS header with pipe-delimited field names`);\n439:   lines.push(`#`);\n440: \n441:   for (const spec of TOON_COMMAND_SPECS) {\n442:     const fieldNames = spec.fields.map((f) => f.name).join(\"|\");\n443:     lines.push(`# ${spec.command}: ${fieldNames}`);\n444:     if (spec.example) {\n445:       // Show only the data lines from the example (skip the #FIELDS line)\n446:       const exampleLines = spec.example.split(\"\\n\").filter((l) => !l.startsWith(\"#FIELDS\"));\n447:       if (exampleLines.length > 0) {\n448:         lines.push(`#   e.g. ${exampleLines[0]}`);\n449:       }\n450:     }\n451:   }\n452: \n453:   return lines.join(\"\\n\");\n454: }\n\n(End of file - total 454 lines)\n</content>","title":"src/lib/toon-spec.ts","metadata":{"preview":"/**\n * toon-spec.ts — Token-Optimized Output Notation (TOON) format specification.\n *\n * TOON is a compact, pipe-delimited encoding designed for AI agent consumption.\n * It minimizes token usage while remaining fully parseable. Agents call\n * `woco describe --output toon` once per session to learn the format, then\n * parse all subsequent TOON output without further context.\n *\n * Format rules:\n *   - Delimiter: pipe character (|)\n *   - Fields are positional (fixed order per command, no field names in output)\n *   - Header line: optional #FIELDS comment listing field order\n *   - Status codes: BL=backlog, PL=planned, IP=in_progress, BK=blocked, IR=in_review, DN=done, CN=cancelled\n *   - Priority codes: C=critical, H=high, M=medium, L=low, W=wishlist\n *   - Difficulty codes: T=trivial, E=easy, M=medium, H=hard, V=very_hard\n *   - Duration: compact format (30m, 2h, 1d4h) instead of ISO 8601\n *   - Boolean: 1/0 instead of true/false\n *   - Null/missing: empty field (||)\n *   - Arrays: comma-separated within a single field (no pipes)\n */","truncated":false,"loaded":[]},"time":{"start":1773440109037,"end":1773440109040}}}}
