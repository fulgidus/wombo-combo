{"type":"tool_use","timestamp":1773440115397,"sessionID":"ses_316bba7c1ffenLP0vTOciFexZp","part":{"id":"prt_ce9449e4a0019midHdgZ3JNjzb","sessionID":"ses_316bba7c1ffenLP0vTOciFexZp","messageID":"msg_ce9448a7b001sAjgD0WN3rB1rU","type":"tool","callID":"toolu_vrtx_01LuZTSwtaXZbn3nPavSiynx","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/toon-output/src/commands/tasks/list.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/toon-output/src/commands/tasks/list.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tasks/list.ts — List and filter tasks from the tasks file.\n3:  *\n4:  * Usage:\n5:  *   woco tasks list                     # list all tasks\n6:  *   woco tasks list --status backlog    # filter by status\n7:  *   woco tasks list --priority high     # filter by priority\n8:  *   woco tasks list --ready             # show only ready tasks\n9:  *   woco tasks list --archive           # include archived tasks\n10:  */\n11: \n12: import type { WomboConfig } from \"../../config.js\";\n13: import {\n14:   loadFeatures,\n15:   getReadyFeatures,\n16:   featureSummary,\n17:   formatDuration,\n18:   parseDurationMinutes,\n19:   type Feature,\n20:   type FeatureStatus,\n21:   type Priority,\n22:   type Difficulty,\n23:   type FeaturesFile,\n24: } from \"../../lib/tasks.js\";\n25: import { output, filterFieldsArray, renderCompactTable, type OutputFormat } from \"../../lib/output.js\";\n26: import { renderTasksList } from \"../../lib/toon.js\";\n27: \n28: // ---------------------------------------------------------------------------\n29: // Types\n30: // ---------------------------------------------------------------------------\n31: \n32: export interface TasksListOptions {\n33:   projectRoot: string;\n34:   config: WomboConfig;\n35:   status?: FeatureStatus;\n36:   priority?: Priority;\n37:   difficulty?: Difficulty;\n38:   ready?: boolean;\n39:   includeArchive?: boolean;\n40:   outputFmt?: OutputFormat;\n41:   fields?: string[];\n42: }\n43: \n44: // ---------------------------------------------------------------------------\n45: // ANSI Helpers\n46: // ---------------------------------------------------------------------------\n47: \n48: const RESET = \"\\x1b[0m\";\n49: const BOLD = \"\\x1b[1m\";\n50: const DIM = \"\\x1b[2m\";\n51: \n52: const STATUS_COLOR: Record<FeatureStatus, string> = {\n53:   backlog: \"\\x1b[37m\",     // white\n54:   planned: \"\\x1b[36m\",     // cyan\n55:   in_progress: \"\\x1b[34m\", // blue\n56:   blocked: \"\\x1b[31m\",     // red\n57:   in_review: \"\\x1b[33m\",   // yellow\n58:   done: \"\\x1b[32m\",        // green\n59:   cancelled: \"\\x1b[90m\",   // gray\n60: };\n61: \n62: // ---------------------------------------------------------------------------\n63: // Command\n64: // ---------------------------------------------------------------------------\n65: \n66: export async function cmdTasksList(opts: TasksListOptions): Promise<void> {\n67:   const { projectRoot, config } = opts;\n68:   const data = loadFeatures(projectRoot, config);\n69: \n70:   let features: Feature[] = [...data.tasks];\n71: \n72:   // Include archive if requested\n73:   if (opts.includeArchive && data.archive?.length) {\n74:     features = [...features, ...data.archive];\n75:   }\n76: \n77:   // Filter by status\n78:   if (opts.status) {\n79:     features = features.filter((f) => f.status === opts.status);\n80:   }\n81: \n82:   // Filter by priority\n83:   if (opts.priority) {\n84:     features = features.filter((f) => f.priority === opts.priority);\n85:   }\n86: \n87:   // Filter by difficulty\n88:   if (opts.difficulty) {\n89:     features = features.filter((f) => f.difficulty === opts.difficulty);\n90:   }\n91: \n92:   // Filter to ready-only\n93:   if (opts.ready) {\n94:     const readyFeatures = getReadyFeatures(data);\n95:     const readyIds = new Set(readyFeatures.map((f) => f.id));\n96:     features = features.filter((f) => readyIds.has(f.id));\n97:   }\n98: \n99:   if (features.length === 0) {\n100:     output(opts.outputFmt ?? \"text\", { features: [], total: 0, effort: \"0m\" }, () => {\n101:       console.log(\"No tasks match the given filters.\");\n102:     }, () => {\n103:       // TOON: emit empty result\n104:       console.log(renderTasksList([]));\n105:     });\n106:     return;\n107:   }\n108: \n109:   // Group by status for display\n110:   const byStatus = new Map<FeatureStatus, Feature[]>();\n111:   for (const f of features) {\n112:     const list = byStatus.get(f.status) ?? [];\n113:     list.push(f);\n114:     byStatus.set(f.status, list);\n115:   }\n116: \n117:   // Display\n118:   const totalEffort = features.reduce(\n119:     (sum, f) => sum + parseDurationMinutes(f.effort),\n120:     0\n121:   );\n122: \n123:   const fmt = opts.outputFmt ?? \"text\";\n124: \n125:   // Build the structured data for each feature\n126:   const featureData = features.map((f) => ({\n127:     id: f.id,\n128:     title: f.title,\n129:     status: f.status,\n130:     priority: f.priority,\n131:     difficulty: f.difficulty,\n132:     effort: f.effort,\n133:     completion: f.completion,\n134:     depends_on: f.depends_on,\n135:   }));\n136: \n137:   // If --fields is specified, use compact output mode\n138:   if (opts.fields?.length) {\n139:     const filtered = filterFieldsArray(featureData, opts.fields);\n140:     output(\n141:       fmt,\n142:       { features: filtered, total: features.length, effort: formatDuration(totalEffort) },\n143:       () => {\n144:         renderCompactTable(\n145:           featureData as Record<string, unknown>[],\n146:           opts.fields!\n147:         );\n148:       },\n149:       () => {\n150:         // TOON: --fields is ignored; emit all fields in compact format\n151:         console.log(renderTasksList(featureData));\n152:       }\n153:     );\n154:     return;\n155:   }\n156: \n157:   output(\n158:     fmt,\n159:     {\n160:       features: featureData,\n161:       total: features.length,\n162:       effort: formatDuration(totalEffort),\n163:     },\n164:     () => {\n165:       console.log(`\\n${BOLD}Tasks (${features.length} total, ~${formatDuration(totalEffort)} effort)${RESET}\\n`);\n166: \n167:       const statusOrder: FeatureStatus[] = [\n168:         \"in_progress\",\n169:         \"planned\",\n170:         \"backlog\",\n171:         \"blocked\",\n172:         \"in_review\",\n173:         \"done\",\n174:         \"cancelled\",\n175:       ];\n176: \n177:       for (const status of statusOrder) {\n178:         const group = byStatus.get(status);\n179:         if (!group?.length) continue;\n180: \n181:         const color = STATUS_COLOR[status] ?? \"\";\n182:         console.log(`  ${color}${BOLD}${status.toUpperCase()}${RESET} (${group.length})`);\n183: \n184:         for (const f of group) {\n185:           const effort = formatDuration(parseDurationMinutes(f.effort));\n186:           const deps = f.depends_on.length > 0 ? ` ${DIM}deps: ${f.depends_on.join(\", \")}${RESET}` : \"\";\n187:           const completion = f.completion > 0 ? ` ${DIM}${f.completion}%${RESET}` : \"\";\n188:           console.log(\n189:             `    ${color}${f.id}${RESET} — ${f.title} [${f.priority}/${f.difficulty}] (${effort})${completion}${deps}`\n190:           );\n191:         }\n192:         console.log(\"\");\n193:       }\n194:     },\n195:     () => {\n196:       // TOON renderer\n197:       console.log(renderTasksList(featureData));\n198:     }\n199:   );\n200: }\n\n(End of file - total 200 lines)\n</content>","title":"src/commands/tasks/list.ts","metadata":{"preview":"/**\n * tasks/list.ts — List and filter tasks from the tasks file.\n *\n * Usage:\n *   woco tasks list                     # list all tasks\n *   woco tasks list --status backlog    # filter by status\n *   woco tasks list --priority high     # filter by priority\n *   woco tasks list --ready             # show only ready tasks\n *   woco tasks list --archive           # include archived tasks\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  getReadyFeatures,\n  featureSummary,\n  formatDuration,\n  parseDurationMinutes,\n  type Feature,\n  type FeatureStatus,","truncated":false,"loaded":[]},"time":{"start":1773440115394,"end":1773440115397}}}}
{"type":"tool_use","timestamp":1773440115878,"sessionID":"ses_316bba7c1ffenLP0vTOciFexZp","part":{"id":"prt_ce944a2c3001QnDKEmuY5rjvpk","sessionID":"ses_316bba7c1ffenLP0vTOciFexZp","messageID":"msg_ce9448a7b001sAjgD0WN3rB1rU","type":"tool","callID":"toolu_vrtx_019fu1EwbCMZgMXcvCxFD5CV","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/toon-output/src/commands/tasks/show.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/toon-output/src/commands/tasks/show.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tasks/show.ts — Show detailed information about a specific task.\n3:  *\n4:  * Usage:\n5:  *   woco tasks show <task-id>\n6:  */\n7: \n8: import type { WomboConfig } from \"../../config.js\";\n9: import {\n10:   loadFeatures,\n11:   findFeatureById,\n12:   formatDuration,\n13:   parseDurationMinutes,\n14:   areDependenciesMet,\n15:   getDoneFeatureIds,\n16:   type Feature,\n17:   type Subtask,\n18: } from \"../../lib/tasks.js\";\n19: import { output, outputError, filterFields, type OutputFormat } from \"../../lib/output.js\";\n20: import { renderTaskShow } from \"../../lib/toon.js\";\n21: \n22: // ---------------------------------------------------------------------------\n23: // Types\n24: // ---------------------------------------------------------------------------\n25: \n26: export interface TasksShowOptions {\n27:   projectRoot: string;\n28:   config: WomboConfig;\n29:   featureId: string;\n30:   outputFmt?: OutputFormat;\n31:   fields?: string[];\n32: }\n33: \n34: // ---------------------------------------------------------------------------\n35: // ANSI Helpers\n36: // ---------------------------------------------------------------------------\n37: \n38: const RESET = \"\\x1b[0m\";\n39: const BOLD = \"\\x1b[1m\";\n40: const DIM = \"\\x1b[2m\";\n41: const GREEN = \"\\x1b[32m\";\n42: const RED = \"\\x1b[31m\";\n43: const YELLOW = \"\\x1b[33m\";\n44: const CYAN = \"\\x1b[36m\";\n45: \n46: // ---------------------------------------------------------------------------\n47: // Display Helpers\n48: // ---------------------------------------------------------------------------\n49: \n50: function statusColor(status: string): string {\n51:   switch (status) {\n52:     case \"done\": return GREEN;\n53:     case \"in_progress\": return CYAN;\n54:     case \"blocked\":\n55:     case \"failed\": return RED;\n56:     case \"cancelled\": return DIM;\n57:     default: return \"\";\n58:   }\n59: }\n60: \n61: function renderSubtask(st: Subtask, indent: number): void {\n62:   const pad = \"  \".repeat(indent);\n63:   const color = statusColor(st.status);\n64:   const effort = formatDuration(parseDurationMinutes(st.effort));\n65:   const completionStr = st.completion > 0 ? ` (${st.completion}%)` : \"\";\n66:   console.log(\n67:     `${pad}${color}[${st.status}]${RESET} ${st.id} — ${st.title} [${st.priority}/${st.difficulty}] (${effort})${completionStr}`\n68:   );\n69:   if (st.subtasks?.length) {\n70:     for (const sub of st.subtasks) {\n71:       renderSubtask(sub, indent + 1);\n72:     }\n73:   }\n74: }\n75: \n76: // ---------------------------------------------------------------------------\n77: // Command\n78: // ---------------------------------------------------------------------------\n79: \n80: export async function cmdTasksShow(opts: TasksShowOptions): Promise<void> {\n81:   const { projectRoot, config } = opts;\n82:   const fmt = opts.outputFmt ?? \"text\";\n83: \n84:   if (!opts.featureId) {\n85:     outputError(fmt, \"Usage: woco tasks show <task-id>\");\n86:     return;\n87:   }\n88: \n89:   const data = loadFeatures(projectRoot, config);\n90:   const feature = findFeatureById(data, opts.featureId);\n91: \n92:   if (!feature) {\n93:     outputError(fmt, `Task \"${opts.featureId}\" not found.`);\n94:     return;\n95:   }\n96: \n97:   const doneIds = getDoneFeatureIds(data);\n98:   const depsMet = areDependenciesMet(feature, doneIds);\n99:   const effort = formatDuration(parseDurationMinutes(feature.effort));\n100: \n101:   const fullData = {\n102:     ...feature,\n103:     deps_met: depsMet,\n104:     effort_formatted: effort,\n105:   };\n106: \n107:   // If --fields is specified, emit only those fields\n108:   if (opts.fields?.length) {\n109:     const filtered = filterFields(fullData as Record<string, unknown>, opts.fields);\n110:     output(fmt, filtered, () => {\n111:       for (const [key, val] of Object.entries(filtered)) {\n112:         const display = Array.isArray(val) ? val.join(\", \") : String(val ?? \"\");\n113:         console.log(`${key}: ${display}`);\n114:       }\n115:     }, () => {\n116:       // TOON: --fields ignored, emit full task in compact format\n117:       console.log(renderTaskShow(feature, depsMet));\n118:     });\n119:     return;\n120:   }\n121: \n122:   output(\n123:     fmt,\n124:     fullData,\n125:     () => {\n126:       console.log(`\\n${BOLD}Task: ${feature.title}${RESET}`);\n127:       console.log(`  ID:          ${feature.id}`);\n128:       console.log(`  Status:      ${statusColor(feature.status)}${feature.status}${RESET}`);\n129:       console.log(`  Priority:    ${feature.priority}`);\n130:       console.log(`  Difficulty:  ${feature.difficulty}`);\n131:       console.log(`  Effort:      ${effort}`);\n132:       console.log(`  Completion:  ${feature.completion}%`);\n133:       console.log(`  Deps met:    ${depsMet ? `${GREEN}yes${RESET}` : `${RED}no${RESET}`}`);\n134: \n135:       if (feature.started_at) {\n136:         console.log(`  Started:     ${feature.started_at}`);\n137:       }\n138:       if (feature.ended_at) {\n139:         console.log(`  Ended:       ${feature.ended_at}`);\n140:       }\n141: \n142:       if (feature.description) {\n143:         console.log(`\\n  ${BOLD}Description:${RESET}`);\n144:         for (const line of feature.description.split(\"\\n\")) {\n145:           console.log(`    ${line}`);\n146:         }\n147:       }\n148: \n149:       if (feature.depends_on.length > 0) {\n150:         console.log(`\\n  ${BOLD}Dependencies:${RESET}`);\n151:         for (const dep of feature.depends_on) {\n152:           const met = doneIds.has(dep);\n153:           const icon = met ? `${GREEN}✓${RESET}` : `${RED}✗${RESET}`;\n154:           console.log(`    ${icon} ${dep}`);\n155:         }\n156:       }\n157: \n158:       if (feature.constraints.length > 0) {\n159:         console.log(`\\n  ${BOLD}Constraints:${RESET}`);\n160:         for (const c of feature.constraints) {\n161:           console.log(`    - ${c}`);\n162:         }\n163:       }\n164: \n165:       if (feature.forbidden.length > 0) {\n166:         console.log(`\\n  ${BOLD}Forbidden:${RESET}`);\n167:         for (const f of feature.forbidden) {\n168:           console.log(`    - ${RED}${f}${RESET}`);\n169:         }\n170:       }\n171: \n172:       if (feature.references.length > 0) {\n173:         console.log(`\\n  ${BOLD}References:${RESET}`);\n174:         for (const r of feature.references) {\n175:           console.log(`    - ${DIM}${r}${RESET}`);\n176:         }\n177:       }\n178: \n179:       if (feature.notes.length > 0) {\n180:         console.log(`\\n  ${BOLD}Notes:${RESET}`);\n181:         for (const n of feature.notes) {\n182:           console.log(`    - ${n}`);\n183:         }\n184:       }\n185: \n186:       if (feature.subtasks.length > 0) {\n187:         console.log(`\\n  ${BOLD}Subtasks (${feature.subtasks.length}):${RESET}`);\n188:         for (const st of feature.subtasks) {\n189:           renderSubtask(st, 2);\n190:         }\n191:       }\n192: \n193:       console.log(\"\");\n194:     },\n195:     () => {\n196:       // TOON renderer\n197:       console.log(renderTaskShow(feature, depsMet));\n198:     }\n199:   );\n200: }\n\n(End of file - total 200 lines)\n</content>","title":"src/commands/tasks/show.ts","metadata":{"preview":"/**\n * tasks/show.ts — Show detailed information about a specific task.\n *\n * Usage:\n *   woco tasks show <task-id>\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  findFeatureById,\n  formatDuration,\n  parseDurationMinutes,\n  areDependenciesMet,\n  getDoneFeatureIds,\n  type Feature,\n  type Subtask,\n} from \"../../lib/tasks.js\";\nimport { output, outputError, filterFields, type OutputFormat } from \"../../lib/output.js\";\nimport { renderTaskShow } from \"../../lib/toon.js\";","truncated":false,"loaded":[]},"time":{"start":1773440115875,"end":1773440115877}}}}
{"type":"tool_use","timestamp":1773440116449,"sessionID":"ses_316bba7c1ffenLP0vTOciFexZp","part":{"id":"prt_ce944a4a4001fdDClKpkOBjG8I","sessionID":"ses_316bba7c1ffenLP0vTOciFexZp","messageID":"msg_ce9448a7b001sAjgD0WN3rB1rU","type":"tool","callID":"toolu_vrtx_01S3a7CPsZjvC27muX7sFfTa","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/toon-output/src/commands/status.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/toon-output/src/commands/status.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * status.ts — Show the status of the current wave.\n3:  *\n4:  * Usage:\n5:  *   woco status                  # human-readable dashboard\n6:  *   woco status --output json    # structured JSON for programmatic access\n7:  *\n8:  * Loads the wave state, checks for dead processes, and prints a dashboard\n9:  * or emits structured JSON with wave metadata, agent states, timing info,\n10:  * and summary statistics.\n11:  */\n12: \n13: import type { WomboConfig } from \"../config.js\";\n14: import { loadState, saveState, updateAgent, agentCounts, isWaveComplete } from \"../lib/state.js\";\n15: import type { WaveState, AgentState, AgentStatus } from \"../lib/state.js\";\n16: import { isProcessRunning } from \"../lib/launcher.js\";\n17: import { branchHasChanges } from \"../lib/worktree.js\";\n18: import { printDashboard } from \"../lib/ui.js\";\n19: import { output, outputMessage, type OutputFormat } from \"../lib/output.js\";\n20: import { renderStatus } from \"../lib/toon.js\";\n21: \n22: export interface StatusOptions {\n23:   projectRoot: string;\n24:   config: WomboConfig;\n25:   outputFmt?: OutputFormat;\n26: }\n27: \n28: // ---------------------------------------------------------------------------\n29: // JSON Output Builder\n30: // ---------------------------------------------------------------------------\n31: \n32: /**\n33:  * Compute elapsed time in milliseconds from a start ISO timestamp to now.\n34:  */\n35: function elapsedMs(startedAt: string | null): number | null {\n36:   if (!startedAt) return null;\n37:   return Date.now() - new Date(startedAt).getTime();\n38: }\n39: \n40: /**\n41:  * Format milliseconds as a human-readable duration string (e.g. \"2h15m\", \"3m\").\n42:  */\n43: function formatElapsed(ms: number | null): string | null {\n44:   if (ms === null) return null;\n45:   const mins = Math.floor(ms / 60000);\n46:   if (mins < 60) return `${mins}m`;\n47:   const hours = Math.floor(mins / 60);\n48:   const remMins = mins % 60;\n49:   return `${hours}h${remMins}m`;\n50: }\n51: \n52: /**\n53:  * Build the structured JSON representation of an agent's state.\n54:  */\n55: function agentToJson(agent: AgentState): Record<string, unknown> {\n56:   const elapsed = elapsedMs(agent.started_at);\n57:   return {\n58:     feature_id: agent.feature_id,\n59:     branch: agent.branch,\n60:     worktree: agent.worktree,\n61:     status: agent.status,\n62:     pid: agent.pid,\n63:     retries: agent.retries,\n64:     max_retries: agent.max_retries,\n65:     started_at: agent.started_at,\n66:     completed_at: agent.completed_at,\n67:     elapsed_ms: elapsed,\n68:     elapsed_formatted: formatElapsed(elapsed),\n69:     build_passed: agent.build_passed,\n70:     error: agent.error,\n71:     activity: agent.activity,\n72:     activity_updated_at: agent.activity_updated_at,\n73:     effort_estimate_ms: agent.effort_estimate_ms,\n74:   };\n75: }\n76: \n77: /**\n78:  * Build the full structured JSON for the wave status.\n79:  * Schema:\n80:  *   {\n81:  *     wave_id: string,\n82:  *     base_branch: string,\n83:  *     started_at: string (ISO 8601),\n84:  *     updated_at: string (ISO 8601),\n85:  *     elapsed_ms: number,\n86:  *     elapsed_formatted: string,\n87:  *     max_concurrent: number,\n88:  *     model: string | null,\n89:  *     interactive: boolean,\n90:  *     is_complete: boolean,\n91:  *     agents: Agent[],\n92:  *     summary: { total, queued, installing, running, completed, verified, failed, merged, retry, resolving_conflict }\n93:  *   }\n94:  */\n95: function buildStatusJson(state: WaveState): Record<string, unknown> {\n96:   const counts = agentCounts(state);\n97:   const waveElapsed = elapsedMs(state.started_at);\n98: \n99:   return {\n100:     wave_id: state.wave_id,\n101:     base_branch: state.base_branch,\n102:     started_at: state.started_at,\n103:     updated_at: state.updated_at,\n104:     elapsed_ms: waveElapsed,\n105:     elapsed_formatted: formatElapsed(waveElapsed),\n106:     max_concurrent: state.max_concurrent,\n107:     model: state.model,\n108:     interactive: state.interactive,\n109:     is_complete: isWaveComplete(state),\n110:     agents: state.agents.map(agentToJson),\n111:     summary: {\n112:       total: state.agents.length,\n113:       ...counts,\n114:     },\n115:   };\n116: }\n117: \n118: // ---------------------------------------------------------------------------\n119: // Command\n120: // ---------------------------------------------------------------------------\n121: \n122: export async function cmdStatus(opts: StatusOptions): Promise<void> {\n123:   const fmt = opts.outputFmt ?? \"text\";\n124:   const state = loadState(opts.projectRoot);\n125: \n126:   if (!state) {\n127:     outputMessage(fmt, \"No active wave. Use 'woco launch' to start one.\", {\n128:       wave_id: null,\n129:       agents: [],\n130:       summary: { total: 0 },\n131:     });\n132:     return;\n133:   }\n134: \n135:   // Update running agent status from process state\n136:   for (const agent of state.agents) {\n137:     if (agent.status === \"running\" && agent.pid) {\n138:       if (!isProcessRunning(agent.pid)) {\n139:         // Check if the agent actually made any commits before marking completed\n140:         if (branchHasChanges(opts.projectRoot, agent.branch, state.base_branch)) {\n141:           updateAgent(state, agent.feature_id, {\n142:             status: \"completed\",\n143:             completed_at: new Date().toISOString(),\n144:           });\n145:         } else {\n146:           // Agent died without producing any code — mark as failed, not completed\n147:           updateAgent(state, agent.feature_id, {\n148:             status: \"failed\",\n149:             error: \"Agent process exited without making any commits\",\n150:             completed_at: new Date().toISOString(),\n151:           });\n152:         }\n153:       }\n154:     }\n155:   }\n156: \n157:   // Repair pass: re-check agents marked \"completed\" but never verified.\n158:   // Catches agents falsely promoted to completed by older versions of status.ts\n159:   // that didn't check branchHasChanges.\n160:   for (const agent of state.agents) {\n161:     if (agent.status === \"completed\" && agent.build_passed === null) {\n162:       if (!branchHasChanges(opts.projectRoot, agent.branch, state.base_branch)) {\n163:         updateAgent(state, agent.feature_id, {\n164:           status: \"failed\",\n165:           error: \"Agent process exited without making any commits\",\n166:         });\n167:       }\n168:     }\n169:   }\n170:   saveState(opts.projectRoot, state);\n171: \n172:   output(fmt, buildStatusJson(state), () => {\n173:     printDashboard(state);\n174:   }, () => {\n175:     // TOON renderer\n176:     console.log(renderStatus(state));\n177:   });\n178: }\n\n(End of file - total 178 lines)\n</content>","title":"src/commands/status.ts","metadata":{"preview":"/**\n * status.ts — Show the status of the current wave.\n *\n * Usage:\n *   woco status                  # human-readable dashboard\n *   woco status --output json    # structured JSON for programmatic access\n *\n * Loads the wave state, checks for dead processes, and prints a dashboard\n * or emits structured JSON with wave metadata, agent states, timing info,\n * and summary statistics.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport { loadState, saveState, updateAgent, agentCounts, isWaveComplete } from \"../lib/state.js\";\nimport type { WaveState, AgentState, AgentStatus } from \"../lib/state.js\";\nimport { isProcessRunning } from \"../lib/launcher.js\";\nimport { branchHasChanges } from \"../lib/worktree.js\";\nimport { printDashboard } from \"../lib/ui.js\";\nimport { output, outputMessage, type OutputFormat } from \"../lib/output.js\";\nimport { renderStatus } from \"../lib/toon.js\";","truncated":false,"loaded":[]},"time":{"start":1773440116446,"end":1773440116449}}}}
{"type":"text","timestamp":1773440116854,"sessionID":"ses_316bba7c1ffenLP0vTOciFexZp","part":{"id":"prt_ce94499e7001C6QbymalX3iu5B","sessionID":"ses_316bba7c1ffenLP0vTOciFexZp","messageID":"msg_ce9448a7b001sAjgD0WN3rB1rU","type":"text","text":"Good — significant TOON infrastructure is already in place. Now let me examine the command files to see which ones already support TOON output and which need it added.","time":{"start":1773440116854,"end":1773440116854}}}
{"type":"tool_use","timestamp":1773440116856,"sessionID":"ses_316bba7c1ffenLP0vTOciFexZp","part":{"id":"prt_ce944a6e0001xKpCnFn6tGKEco","sessionID":"ses_316bba7c1ffenLP0vTOciFexZp","messageID":"msg_ce9448a7b001sAjgD0WN3rB1rU","type":"tool","callID":"toolu_vrtx_01TXgDxNoJoHxYBd9nE4EW1W","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/toon-output/src/commands/history.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/toon-output/src/commands/history.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * history.ts — View wave history and summaries.\n3:  *\n4:  * Usage:\n5:  *   woco history                    List all past waves\n6:  *   woco history <wave-id>          Show details of a specific wave\n7:  *   woco history --output json      Output as JSON\n8:  *\n9:  * Wave history is stored in .wombo-combo/history/<wave-id>.json and survives\n10:  * `woco cleanup`. Records are auto-exported when a wave completes.\n11:  */\n12: \n13: import type { WomboConfig } from \"../config.js\";\n14: import {\n15:   listHistory,\n16:   loadHistory,\n17:   type WaveHistoryRecord,\n18: } from \"../lib/history.js\";\n19: import { output, outputError, type OutputFormat } from \"../lib/output.js\";\n20: import { renderHistoryList, renderHistoryDetail } from \"../lib/toon.js\";\n21: \n22: // ---------------------------------------------------------------------------\n23: // Types\n24: // ---------------------------------------------------------------------------\n25: \n26: export interface HistoryCommandOptions {\n27:   projectRoot: string;\n28:   config: WomboConfig;\n29:   /** Specific wave ID to show details for */\n30:   waveId?: string;\n31:   /** Output format */\n32:   outputFmt: OutputFormat;\n33: }\n34: \n35: // ---------------------------------------------------------------------------\n36: // Formatting Helpers\n37: // ---------------------------------------------------------------------------\n38: \n39: const RESET = \"\\x1b[0m\";\n40: const BOLD = \"\\x1b[1m\";\n41: const DIM = \"\\x1b[2m\";\n42: const FG = {\n43:   red: \"\\x1b[31m\",\n44:   green: \"\\x1b[32m\",\n45:   yellow: \"\\x1b[33m\",\n46:   blue: \"\\x1b[34m\",\n47:   magenta: \"\\x1b[35m\",\n48:   cyan: \"\\x1b[36m\",\n49:   gray: \"\\x1b[90m\",\n50: };\n51: \n52: function pad(text: string, width: number): string {\n53:   if (text.length >= width) return text.slice(0, width);\n54:   return text + \" \".repeat(width - text.length);\n55: }\n56: \n57: function padLeft(text: string, width: number): string {\n58:   if (text.length >= width) return text.slice(0, width);\n59:   return \" \".repeat(width - text.length) + text;\n60: }\n61: \n62: function formatDurationMs(ms: number | null): string {\n63:   if (ms === null || ms === 0) return \"-\";\n64:   const seconds = Math.floor(ms / 1000);\n65:   if (seconds < 60) return `${seconds}s`;\n66:   const minutes = Math.floor(seconds / 60);\n67:   if (minutes < 60) return `${minutes}m ${seconds % 60}s`;\n68:   const hours = Math.floor(minutes / 60);\n69:   return `${hours}h ${minutes % 60}m`;\n70: }\n71: \n72: function formatDate(iso: string): string {\n73:   try {\n74:     const d = new Date(iso);\n75:     return d.toLocaleDateString(\"en-US\", {\n76:       year: \"numeric\",\n77:       month: \"short\",\n78:       day: \"numeric\",\n79:       hour: \"2-digit\",\n80:       minute: \"2-digit\",\n81:     });\n82:   } catch {\n83:     return iso;\n84:   }\n85: }\n86: \n87: function statusColor(status: string): string {\n88:   switch (status) {\n89:     case \"merged\":\n90:       return FG.magenta;\n91:     case \"verified\":\n92:       return FG.green;\n93:     case \"failed\":\n94:       return FG.red;\n95:     case \"completed\":\n96:       return FG.yellow;\n97:     default:\n98:       return FG.gray;\n99:   }\n100: }\n101: \n102: // ---------------------------------------------------------------------------\n103: // List All Waves\n104: // ---------------------------------------------------------------------------\n105: \n106: function renderWaveList(records: WaveHistoryRecord[]): void {\n107:   if (records.length === 0) {\n108:     console.log(\"\\nNo wave history found.\");\n109:     console.log(\"History is auto-exported when a wave completes.\\n\");\n110:     return;\n111:   }\n112: \n113:   console.log(\"\");\n114:   console.log(`${BOLD}Wave History (${records.length} wave(s)):${RESET}`);\n115:   console.log(\"\");\n116: \n117:   const header = [\n118:     pad(\"Wave ID\", 24),\n119:     pad(\"Date\", 22),\n120:     padLeft(\"Total\", 6),\n121:     padLeft(\"OK\", 4),\n122:     padLeft(\"Fail\", 5),\n123:     padLeft(\"Merged\", 7),\n124:     padLeft(\"Retries\", 8),\n125:     padLeft(\"Duration\", 10),\n126:   ].join(\" \");\n127: \n128:   console.log(`${BOLD}${header}${RESET}`);\n129:   console.log(\"-\".repeat(90));\n130: \n131:   for (const rec of records) {\n132:     const s = rec.summary;\n133:     const okColor = s.succeeded === s.total ? FG.green : FG.yellow;\n134:     const failColor = s.failed > 0 ? FG.red : FG.gray;\n135: \n136:     const row = [\n137:       pad(rec.wave_id, 24),\n138:       pad(formatDate(rec.started_at), 22),\n139:       padLeft(String(s.total), 6),\n140:       `${okColor}${padLeft(String(s.succeeded), 4)}${RESET}`,\n141:       `${failColor}${padLeft(String(s.failed), 5)}${RESET}`,\n142:       padLeft(String(s.merged), 7),\n143:       padLeft(String(s.total_retries), 8),\n144:       padLeft(formatDurationMs(s.total_duration_ms), 10),\n145:     ].join(\" \");\n146: \n147:     console.log(row);\n148:   }\n149: \n150:   console.log(\"\");\n151:   console.log(`${DIM}Use 'woco history <wave-id>' for details.${RESET}`);\n152:   console.log(\"\");\n153: }\n154: \n155: // ---------------------------------------------------------------------------\n156: // Show Single Wave Details\n157: // ---------------------------------------------------------------------------\n158: \n159: function renderWaveDetails(rec: WaveHistoryRecord): void {\n160:   console.log(\"\");\n161:   console.log(`${BOLD}Wave: ${rec.wave_id}${RESET}`);\n162:   console.log(`${DIM}Base: ${rec.base_branch} | Concurrency: ${rec.max_concurrent} | Mode: ${rec.interactive ? \"interactive\" : \"headless\"}${RESET}`);\n163:   if (rec.model) {\n164:     console.log(`${DIM}Model: ${rec.model}${RESET}`);\n165:   }\n166:   console.log(`${DIM}Started: ${formatDate(rec.started_at)} | Exported: ${formatDate(rec.exported_at)}${RESET}`);\n167:   console.log(\"\");\n168: \n169:   // Summary\n170:   const s = rec.summary;\n171:   console.log(`${BOLD}Summary:${RESET}`);\n172:   console.log(`  Total agents:    ${s.total}`);\n173:   console.log(`  Succeeded:       ${FG.green}${s.succeeded}${RESET}`);\n174:   console.log(`  Failed:          ${s.failed > 0 ? FG.red : FG.gray}${s.failed}${RESET}`);\n175:   console.log(`  Merged:          ${FG.magenta}${s.merged}${RESET}`);\n176:   console.log(`  Verified:        ${FG.green}${s.verified}${RESET}`);\n177:   console.log(`  Total retries:   ${s.total_retries}`);\n178:   console.log(`  Total duration:  ${formatDurationMs(s.total_duration_ms)}`);\n179:   console.log(\"\");\n180: \n181:   // Agent table\n182:   console.log(`${BOLD}Agents:${RESET}`);\n183:   console.log(\"\");\n184: \n185:   const header = [\n186:     pad(\"Feature\", 30),\n187:     pad(\"Status\", 12),\n188:     padLeft(\"Retries\", 8),\n189:     padLeft(\"Duration\", 10),\n190:     pad(\"Build\", 6),\n191:     pad(\"Conflict\", 9),\n192:     pad(\"Error\", 30),\n193:   ].join(\" \");\n194: \n195:   console.log(`${BOLD}${header}${RESET}`);\n196:   console.log(\"-\".repeat(109));\n197: \n198:   for (const agent of rec.agents) {\n199:     const color = statusColor(agent.status);\n200:     const buildStr = agent.build_passed === true\n201:       ? `${FG.green}pass${RESET}`\n202:       : agent.build_passed === false\n203:         ? `${FG.red}fail${RESET}`\n204:         : `${FG.gray}-${RESET}`;\n205:     const conflictStr = agent.had_merge_conflict\n206:       ? `${FG.yellow}yes${RESET}`\n207:       : `${FG.gray}no${RESET}`;\n208:     const errorStr = agent.error\n209:       ? agent.error.split(\"\\n\")[0].slice(0, 28)\n210:       : \"-\";\n211: \n212:     const row = [\n213:       pad(agent.feature_id, 30),\n214:       `${color}${pad(agent.status, 12)}${RESET}`,\n215:       padLeft(\n216:         agent.retries > 0 ? `${agent.retries}/${agent.max_retries}` : \"-\",\n217:         8\n218:       ),\n219:       padLeft(formatDurationMs(agent.duration_ms), 10),\n220:       pad(buildStr, 6),\n221:       pad(conflictStr, 9),\n222:       pad(errorStr, 30),\n223:     ].join(\" \");\n224: \n225:     console.log(row);\n226:   }\n227: \n228:   console.log(\"\");\n229: }\n230: \n231: // ---------------------------------------------------------------------------\n232: // Command\n233: // ---------------------------------------------------------------------------\n234: \n235: export async function cmdHistory(opts: HistoryCommandOptions): Promise<void> {\n236:   const { projectRoot, outputFmt } = opts;\n237: \n238:   if (opts.waveId) {\n239:     // Show details for a specific wave\n240:     const record = loadHistory(projectRoot, opts.waveId);\n241:     if (!record) {\n242:       outputError(\n243:         outputFmt,\n244:         `Wave history not found: ${opts.waveId}. Use 'woco history' to list available waves.`\n245:       );\n246:       return; // unreachable — helps TypeScript narrow\n247:     }\n248: \n249:     output(outputFmt, record, () => {\n250:       renderWaveDetails(record);\n251:     }, () => {\n252:       // TOON renderer\n253:       console.log(renderHistoryDetail(record));\n254:     });\n255:   } else {\n256:     // List all waves\n257:     const records = listHistory(projectRoot);\n258: \n259:     output(outputFmt, records, () => {\n260:       renderWaveList(records);\n261:     }, () => {\n262:       // TOON renderer\n263:       console.log(renderHistoryList(records));\n264:     });\n265:   }\n266: }\n\n(End of file - total 266 lines)\n</content>","title":"src/commands/history.ts","metadata":{"preview":"/**\n * history.ts — View wave history and summaries.\n *\n * Usage:\n *   woco history                    List all past waves\n *   woco history <wave-id>          Show details of a specific wave\n *   woco history --output json      Output as JSON\n *\n * Wave history is stored in .wombo-combo/history/<wave-id>.json and survives\n * `woco cleanup`. Records are auto-exported when a wave completes.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport {\n  listHistory,\n  loadHistory,\n  type WaveHistoryRecord,\n} from \"../lib/history.js\";\nimport { output, outputError, type OutputFormat } from \"../lib/output.js\";\nimport { renderHistoryList, renderHistoryDetail } from \"../lib/toon.js\";","truncated":false,"loaded":[]},"time":{"start":1773440116853,"end":1773440116855}}}}
