45:     \"dependencies\": {\n46:         \"mermaidtui\": \"^0.0.5\",\n47:         \"neo-blessed\": \"^0.2.0\",\n48:         \"yaml\": \"^2.7.1\"\n49:     },\n50:     \"devDependencies\": {\n51:         \"@types/blessed\": \"^0.1.25\",\n52:         \"@types/bun\": \"latest\",\n53:         \"typescript\": \"^5.8.2\"\n54:     }\n55: }\n\n(End of file - total 55 lines)\n</content>","title":"package.json","metadata":{"preview":"{\n    \"name\": \"wombo-combo\",\n    \"version\": \"0.0.13\",\n    \"description\": \"WOMBO COMBO! — AI agent orchestration system for parallel feature development\",\n    \"type\": \"module\",\n    \"bin\": {\n        \"woco\": \"./src/index.ts\"\n    },\n    \"files\": [\n        \"src/**/*.ts\",\n        \"src/templates/**\",\n        \"schemas/**\"\n    ],\n    \"scripts\": {\n        \"dev\": \"bun src/index.ts\",\n        \"woco\": \"bun src/index.ts\",\n        \"start\": \"bun src/index.ts\",\n        \"build\": \"bun build src/index.ts --outdir dist --target node\",\n        \"typecheck\": \"tsc --noEmit\",\n        \"test\": \"bun test\"","truncated":false,"loaded":[]},"time":{"start":1773440689174,"end":1773440689178}}}}
