{"type":"tool_use","timestamp":1773440138531,"sessionID":"ses_316bba7c1ffenLP0vTOciFexZp","part":{"id":"prt_ce944f61c001ciNuaRuJuIVnO9","sessionID":"ses_316bba7c1ffenLP0vTOciFexZp","messageID":"msg_ce944ec74001JxcBa8MY2L1g34","type":"tool","callID":"toolu_vrtx_01JGHAbG1Wys9zb9Sq4QmVPk","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/toon-output/src/commands/tasks/archive.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/toon-output/src/commands/tasks/archive.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tasks/archive.ts — Move done/cancelled tasks to the archive section.\n3:  *\n4:  * Usage:\n5:  *   woco tasks archive              # archive all done + cancelled\n6:  *   woco tasks archive <task-id>    # archive a specific task\n7:  *   woco tasks archive --dry-run    # show what would be archived\n8:  */\n9: \n10: import type { WomboConfig } from \"../../config.js\";\n11: import {\n12:   loadFeatures,\n13:   saveFeatures,\n14:   type Feature,\n15: } from \"../../lib/tasks.js\";\n16: import { outputError, outputMessage, type OutputFormat } from \"../../lib/output.js\";\n17: \n18: // ---------------------------------------------------------------------------\n19: // Types\n20: // ---------------------------------------------------------------------------\n21: \n22: export interface TasksArchiveOptions {\n23:   projectRoot: string;\n24:   config: WomboConfig;\n25:   featureId?: string;\n26:   dryRun?: boolean;\n27:   outputFmt?: OutputFormat;\n28: }\n29: \n30: // ---------------------------------------------------------------------------\n31: // Command\n32: // ---------------------------------------------------------------------------\n33: \n34: export async function cmdTasksArchive(opts: TasksArchiveOptions): Promise<void> {\n35:   const fmt = opts.outputFmt ?? \"text\";\n36: \n37:   try {\n38:     const { projectRoot, config } = opts;\n39:     const data = loadFeatures(projectRoot, config);\n40: \n41:     // Ensure archive array exists\n42:     if (!data.archive) {\n43:       data.archive = [];\n44:     }\n45: \n46:     let toArchive: Feature[];\n47: \n48:     if (opts.featureId) {\n49:       // Archive a specific feature\n50:       const idx = data.tasks.findIndex((f: Feature) => f.id === opts.featureId);\n51:       if (idx === -1) {\n52:         // Check if already in archive\n53:         if (data.archive.find((f) => f.id === opts.featureId)) {\n54:           outputMessage(fmt, `Task \"${opts.featureId}\" is already in the archive.`, {\n55:             already_archived: true,\n56:             id: opts.featureId,\n57:           });\n58:           return;\n59:         }\n60:         outputError(fmt, `Task \"${opts.featureId}\" not found.`);\n61:         return;\n62:       }\n63:       toArchive = [data.tasks[idx]];\n64:     } else {\n65:       // Archive all done + cancelled features\n66:       toArchive = data.tasks.filter(\n67:         (f: Feature) => f.status === \"done\" || f.status === \"cancelled\"\n68:       );\n69:     }\n70: \n71:     if (toArchive.length === 0) {\n72:       outputMessage(fmt, \"No tasks to archive.\", { count: 0 });\n73:       return;\n74:     }\n75: \n76:     if (opts.dryRun) {\n77:       outputMessage(fmt, `Would archive ${toArchive.length} task(s)`, {\n78:         dry_run: true,\n79:         count: toArchive.length,\n80:         archived: toArchive.map((f) => ({ id: f.id, title: f.title, status: f.status })),\n81:       });\n82:       if (fmt === \"text\") {\n83:         console.log(\"\");\n84:         for (const f of toArchive) {\n85:           console.log(`  ${f.id} — ${f.title} (${f.status})`);\n86:         }\n87:       }\n88:       return;\n89:     }\n90: \n91:     // Move features from active to archive\n92:     const archiveIds = new Set(toArchive.map((f) => f.id));\n93:     data.tasks = data.tasks.filter((f: Feature) => !archiveIds.has(f.id));\n94:     data.archive.push(...toArchive);\n95: \n96:     saveFeatures(projectRoot, config, data);\n97: \n98:     outputMessage(fmt, `Archived ${toArchive.length} task(s)`, {\n99:       count: toArchive.length,\n100:       archived: toArchive.map((f) => ({ id: f.id, title: f.title, status: f.status })),\n101:     });\n102:     if (fmt === \"text\") {\n103:       for (const f of toArchive) {\n104:         console.log(`  ${f.id} — ${f.title} (${f.status})`);\n105:       }\n106:     }\n107:   } catch (err: unknown) {\n108:     const message = err instanceof Error ? err.message : String(err);\n109:     outputError(fmt, `Archive failed: ${message}`);\n110:   }\n111: }\n\n(End of file - total 111 lines)\n</content>","title":"src/commands/tasks/archive.ts","metadata":{"preview":"/**\n * tasks/archive.ts — Move done/cancelled tasks to the archive section.\n *\n * Usage:\n *   woco tasks archive              # archive all done + cancelled\n *   woco tasks archive <task-id>    # archive a specific task\n *   woco tasks archive --dry-run    # show what would be archived\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  saveFeatures,\n  type Feature,\n} from \"../../lib/tasks.js\";\nimport { outputError, outputMessage, type OutputFormat } from \"../../lib/output.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------","truncated":false,"loaded":[]},"time":{"start":1773440138524,"end":1773440138530}}}}
{"type":"tool_use","timestamp":1773440138532,"sessionID":"ses_316bba7c1ffenLP0vTOciFexZp","part":{"id":"prt_ce944fd1d001iElDMdHCDVF61v","sessionID":"ses_316bba7c1ffenLP0vTOciFexZp","messageID":"msg_ce944ec74001JxcBa8MY2L1g34","type":"tool","callID":"toolu_vrtx_01YCe8EfThsv69o8Uh4RsC31","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/toon-output/src/commands/tasks/graph.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/toon-output/src/commands/tasks/graph.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tasks/graph.ts — Visualize the task dependency graph.\n3:  *\n4:  * Usage:\n5:  *   woco tasks graph                     # show full dependency graph\n6:  *   woco tasks graph --status backlog    # filter by status\n7:  *   woco tasks graph --ascii             # ASCII-only rendering\n8:  *   woco tasks graph --output json       # emit mermaid source as JSON\n9:  *   woco tasks graph --mermaid           # emit raw mermaid source text\n10:  *   woco tasks graph --subtasks          # include subtask-level nodes\n11:  *\n12:  * Builds a Mermaid flowchart from the tasks dependency graph and renders\n13:  * it as a Unicode box diagram in the terminal using mermaidtui.\n14:  */\n15: \n16: import type { WomboConfig } from \"../../config.js\";\n17: import {\n18:   loadFeatures,\n19:   type Feature,\n20:   type Subtask,\n21:   type FeatureStatus,\n22:   type FeaturesFile,\n23: } from \"../../lib/tasks.js\";\n24: import { output, type OutputFormat } from \"../../lib/output.js\";\n25: import { renderGraph } from \"../../lib/toon.js\";\n26: \n27: // mermaidtui has no type declarations — import the JS module directly\n28: // @ts-ignore — no .d.ts published\n29: import { renderMermaidToTui } from \"mermaidtui\";\n30: \n31: // ---------------------------------------------------------------------------\n32: // Types\n33: // ---------------------------------------------------------------------------\n34: \n35: export interface TasksGraphOptions {\n36:   projectRoot: string;\n37:   config: WomboConfig;\n38:   status?: FeatureStatus;\n39:   ascii?: boolean;\n40:   mermaid?: boolean;\n41:   subtasks?: boolean;\n42:   outputFmt?: OutputFormat;\n43: }\n44: \n45: // ---------------------------------------------------------------------------\n46: // Status styling for Mermaid classDef\n47: // ---------------------------------------------------------------------------\n48: \n49: // Short status badge for node labels\n50: const STATUS_BADGE: Record<FeatureStatus, string> = {\n51:   backlog: \"BL\",\n52:   planned: \"PL\",\n53:   in_progress: \"IP\",\n54:   blocked: \"BK\",\n55:   in_review: \"IR\",\n56:   done: \"DN\",\n57:   cancelled: \"XX\",\n58: };\n59: \n60: // ---------------------------------------------------------------------------\n61: // Mermaid generation\n62: // ---------------------------------------------------------------------------\n63: \n64: /**\n65:  * Sanitize a string for use inside Mermaid labels.\n66:  * Mermaid uses square brackets for labels — we need to escape them.\n67:  */\n68: function sanitizeLabel(s: string): string {\n69:   return s\n70:     .replace(/\"/g, \"'\")\n71:     .replace(/\\[/g, \"(\")\n72:     .replace(/\\]/g, \")\")\n73:     .replace(/\\n/g, \" \")\n74:     .slice(0, 40); // keep labels short for terminal rendering\n75: }\n76: \n77: /**\n78:  * Generate a safe Mermaid node ID from a feature/subtask ID.\n79:  * Mermaid IDs can't start with numbers and some chars are reserved.\n80:  */\n81: function nodeId(id: string): string {\n82:   return `n_${id.replace(/-/g, \"_\")}`;\n83: }\n84: \n85: /**\n86:  * Collect all node IDs that exist in the graph (for filtering dangling deps).\n87:  */\n88: function collectAllIds(\n89:   features: Feature[],\n90:   includeSubtasks: boolean\n91: ): Set<string> {\n92:   const ids = new Set<string>();\n93:   for (const f of features) {\n94:     ids.add(f.id);\n95:     if (includeSubtasks) {\n96:       collectSubtaskIds(f.subtasks, ids);\n97:     }\n98:   }\n99:   return ids;\n100: }\n101: \n102: function collectSubtaskIds(subtasks: Subtask[], ids: Set<string>): void {\n103:   for (const st of subtasks) {\n104:     ids.add(st.id);\n105:     collectSubtaskIds(st.subtasks, ids);\n106:   }\n107: }\n108: \n109: /**\n110:  * Build the Mermaid flowchart source from the features file.\n111:  * Only includes nodes that participate in at least one dependency edge.\n112:  * Orphan nodes (no deps and nothing depends on them) are excluded from\n113:  * the visual graph and returned separately for a compact summary.\n114:  */\n115: function buildMermaidSource(\n116:   data: FeaturesFile,\n117:   opts: { status?: FeatureStatus; subtasks?: boolean }\n118: ): { source: string; nodeCount: number; edgeCount: number; orphanCount: number; orphans: { id: string; title: string; status: FeatureStatus }[] } {\n119:   let features = [...data.tasks];\n120: \n121:   // Filter by status if requested\n122:   if (opts.status) {\n123:     features = features.filter((f) => f.status === opts.status);\n124:   }\n125: \n126:   if (features.length === 0) {\n127:     return { source: \"\", nodeCount: 0, edgeCount: 0, orphanCount: 0, orphans: [] };\n128:   }\n129: \n130:   const allIds = collectAllIds(features, !!opts.subtasks);\n131: \n132:   // --- First pass: collect all edges to determine connected nodes ---\n133:   const connectedIds = new Set<string>();\n134:   const edges: { from: string; to: string }[] = [];\n135: \n136:   for (const f of features) {\n137:     // Feature-level dependency edges\n138:     for (const dep of f.depends_on) {\n139:       if (allIds.has(dep)) {\n140:         edges.push({ from: dep, to: f.id });\n141:         connectedIds.add(dep);\n142:         connectedIds.add(f.id);\n143:       }\n144:     }\n145: \n146:     // Subtask edges (parent->child + subtask depends_on)\n147:     if (opts.subtasks && f.subtasks.length > 0) {\n148:       collectSubtaskEdges(f.subtasks, f.id, allIds, edges, connectedIds);\n149:     }\n150:   }\n151: \n152:   // If there are no edges at all, every feature is an orphan\n153:   if (edges.length === 0) {\n154:     const orphans = features.map((f) => ({ id: f.id, title: f.title, status: f.status }));\n155:     return { source: \"\", nodeCount: 0, edgeCount: 0, orphanCount: orphans.length, orphans };\n156:   }\n157: \n158:   // --- Second pass: emit only connected nodes and edges ---\n159:   const lines: string[] = [\"flowchart LR\"];\n160:   let nodeCount = 0;\n161:   const emittedNodes = new Set<string>();\n162:   const orphans: { id: string; title: string; status: FeatureStatus }[] = [];\n163: \n164:   // Helper to emit a node if it's connected and not yet emitted\n165:   const emitNode = (id: string, label: string) => {\n166:     if (!emittedNodes.has(id)) {\n167:       lines.push(`    ${nodeId(id)}[${label}]`);\n168:       emittedNodes.add(id);\n169:       nodeCount++;\n170:     }\n171:   };\n172: \n173:   for (const f of features) {\n174:     if (connectedIds.has(f.id)) {\n175:       const badge = STATUS_BADGE[f.status];\n176:       emitNode(f.id, `${badge} ${sanitizeLabel(f.title)}`);\n177:     } else if (!opts.subtasks || f.subtasks.length === 0) {\n178:       // Feature has no deps and nothing depends on it — it's an orphan\n179:       orphans.push({ id: f.id, title: f.title, status: f.status });\n180:     }\n181: \n182:     // Emit connected subtask nodes\n183:     if (opts.subtasks && f.subtasks.length > 0) {\n184:       emitConnectedSubtasks(f.subtasks, connectedIds, emittedNodes, emitNode, orphans);\n185:     }\n186:   }\n187: \n188:   // Emit all edges\n189:   for (const edge of edges) {\n190:     lines.push(`    ${nodeId(edge.from)} --> ${nodeId(edge.to)}`);\n191:   }\n192: \n193:   return {\n194:     source: lines.join(\"\\n\"),\n195:     nodeCount,\n196:     edgeCount: edges.length,\n197:     orphanCount: orphans.length,\n198:     orphans,\n199:   };\n200: }\n201: \n202: /**\n203:  * Recursively collect edges from subtasks (parent->child links + depends_on edges).\n204:  */\n205: function collectSubtaskEdges(\n206:   subtasks: Subtask[],\n207:   parentId: string,\n208:   allIds: Set<string>,\n209:   edges: { from: string; to: string }[],\n210:   connectedIds: Set<string>\n211: ): void {\n212:   for (const st of subtasks) {\n213:     // Parent -> subtask link always creates an edge\n214:     edges.push({ from: parentId, to: st.id });\n215:     connectedIds.add(parentId);\n216:     connectedIds.add(st.id);\n217: \n218:     // Subtask's own dependencies\n219:     for (const dep of st.depends_on) {\n220:       if (allIds.has(dep)) {\n221:         edges.push({ from: dep, to: st.id });\n222:         connectedIds.add(dep);\n223:         connectedIds.add(st.id);\n224:       }\n225:     }\n226: \n227:     // Recurse into nested subtasks\n228:     if (st.subtasks.length > 0) {\n229:       collectSubtaskEdges(st.subtasks, st.id, allIds, edges, connectedIds);\n230:     }\n231:   }\n232: }\n233: \n234: /**\n235:  * Emit subtask nodes that are connected, collect orphans.\n236:  */\n237: function emitConnectedSubtasks(\n238:   subtasks: Subtask[],\n239:   connectedIds: Set<string>,\n240:   emittedNodes: Set<string>,\n241:   emitNode: (id: string, label: string) => void,\n242:   orphans: { id: string; title: string; status: FeatureStatus }[]\n243: ): void {\n244:   for (const st of subtasks) {\n245:     if (connectedIds.has(st.id)) {\n246:       const badge = STATUS_BADGE[st.status];\n247:       emitNode(st.id, `${badge} ${sanitizeLabel(st.title)}`);\n248:     } else {\n249:       orphans.push({ id: st.id, title: st.title, status: st.status });\n250:     }\n251: \n252:     if (st.subtasks.length > 0) {\n253:       emitConnectedSubtasks(st.subtasks, connectedIds, emittedNodes, emitNode, orphans);\n254:     }\n255:   }\n256: }\n257: \n258: // ---------------------------------------------------------------------------\n259: // Text rendering helpers\n260: // ---------------------------------------------------------------------------\n261: \n262: const RESET = \"\\x1b[0m\";\n263: const BOLD = \"\\x1b[1m\";\n264: const DIM = \"\\x1b[2m\";\n265: const RED = \"\\x1b[31m\";\n266: const YELLOW = \"\\x1b[33m\";\n267: const GREEN = \"\\x1b[32m\";\n268: const CYAN = \"\\x1b[36m\";\n269: \n270: /**\n271:  * Print a legend explaining the status badges used in the graph.\n272:  */\n273: function printLegend(features: Feature[]): void {\n274:   const statuses = new Set<FeatureStatus>();\n275:   for (const f of features) {\n276:     statuses.add(f.status);\n277:   }\n278: \n279:   console.log(`\\n${BOLD}Legend:${RESET}`);\n280:   const legendItems: string[] = [];\n281:   for (const [status, badge] of Object.entries(STATUS_BADGE)) {\n282:     if (statuses.has(status as FeatureStatus)) {\n283:       legendItems.push(`  ${badge} = ${status}`);\n284:     }\n285:   }\n286:   console.log(legendItems.join(\"  |\"));\n287: }\n288: \n289: /**\n290:  * Detect potential issues in the dependency graph and print warnings.\n291:  */\n292: function printDiagnostics(data: FeaturesFile, includeSubtasks: boolean): void {\n293:   const allIds = collectAllIds(data.tasks, includeSubtasks);\n294:   const issues: string[] = [];\n295: \n296:   // Check for dangling dependencies (pointing to non-existent IDs)\n297:   for (const f of data.tasks) {\n298:     for (const dep of f.depends_on) {\n299:       if (!allIds.has(dep)) {\n300:         issues.push(`${YELLOW}WARNING${RESET}: ${f.id} depends on \"${dep}\" which does not exist`);\n301:       }\n302:     }\n303:     if (includeSubtasks) {\n304:       checkSubtaskDeps(f.subtasks, allIds, issues);\n305:     }\n306:   }\n307: \n308:   // Check for circular dependencies (simple DFS)\n309:   const circularPaths = detectCycles(data.tasks, includeSubtasks);\n310:   for (const cycle of circularPaths) {\n311:     issues.push(`${RED}CYCLE${RESET}: ${cycle.join(\" -> \")}`);\n312:   }\n313: \n314:   // Check for blocked features whose blockers are done\n315:   for (const f of data.tasks) {\n316:     if (f.status === \"blocked\") {\n317:       const allDepsDone = f.depends_on.every((dep: string) => {\n318:         const depFeature = data.tasks.find((ff: Feature) => ff.id === dep);\n319:         return depFeature?.status === \"done\";\n320:       });\n321:       if (allDepsDone && f.depends_on.length > 0) {\n322:         issues.push(\n323:           `${CYAN}INFO${RESET}: ${f.id} is marked \"blocked\" but all its dependencies are done`\n324:         );\n325:       }\n326:     }\n327:   }\n328: \n329:   if (issues.length > 0) {\n330:     console.log(`\\n${BOLD}Diagnostics (${issues.length} issue${issues.length > 1 ? \"s\" : \"\"}):${RESET}`);\n331:     for (const issue of issues) {\n332:       console.log(`  ${issue}`);\n333:     }\n334:   }\n335: }\n336: \n337: function checkSubtaskDeps(\n338:   subtasks: Subtask[],\n339:   allIds: Set<string>,\n340:   issues: string[]\n341: ): void {\n342:   for (const st of subtasks) {\n343:     for (const dep of st.depends_on) {\n344:       if (!allIds.has(dep)) {\n345:         issues.push(\n346:           `${YELLOW}WARNING${RESET}: subtask ${st.id} depends on \"${dep}\" which does not exist`\n347:         );\n348:       }\n349:     }\n350:     checkSubtaskDeps(st.subtasks, allIds, issues);\n351:   }\n352: }\n353: \n354: /**\n355:  * Detect circular dependencies using DFS.\n356:  * Returns arrays of ID paths that form cycles.\n357:  */\n358: function detectCycles(\n359:   features: Feature[],\n360:   includeSubtasks: boolean\n361: ): string[][] {\n362:   // Build adjacency list: dep -> [dependents]\n363:   const adj = new Map<string, string[]>();\n364:   const allItems = new Map<string, { depends_on: string[] }>();\n365: \n366:   for (const f of features) {\n367:     allItems.set(f.id, f);\n368:     if (includeSubtasks) {\n369:       collectSubtaskItems(f.subtasks, allItems);\n370:     }\n371:   }\n372: \n373:   for (const [id, item] of allItems) {\n374:     for (const dep of item.depends_on) {\n375:       if (!adj.has(id)) adj.set(id, []);\n376:       adj.get(id)!.push(dep);\n377:     }\n378:   }\n379: \n380:   const visited = new Set<string>();\n381:   const inStack = new Set<string>();\n382:   const cycles: string[][] = [];\n383: \n384:   function dfs(node: string, path: string[]): void {\n385:     if (inStack.has(node)) {\n386:       // Found a cycle — extract it\n387:       const cycleStart = path.indexOf(node);\n388:       cycles.push([...path.slice(cycleStart), node]);\n389:       return;\n390:     }\n391:     if (visited.has(node)) return;\n392: \n393:     visited.add(node);\n394:     inStack.add(node);\n395:     path.push(node);\n396: \n397:     for (const neighbor of adj.get(node) ?? []) {\n398:       dfs(neighbor, path);\n399:     }\n400: \n401:     path.pop();\n402:     inStack.delete(node);\n403:   }\n404: \n405:   for (const id of allItems.keys()) {\n406:     if (!visited.has(id)) {\n407:       dfs(id, []);\n408:     }\n409:   }\n410: \n411:   return cycles;\n412: }\n413: \n414: function collectSubtaskItems(\n415:   subtasks: Subtask[],\n416:   map: Map<string, { depends_on: string[] }>\n417: ): void {\n418:   for (const st of subtasks) {\n419:     map.set(st.id, st);\n420:     collectSubtaskItems(st.subtasks, map);\n421:   }\n422: }\n423: \n424: // ---------------------------------------------------------------------------\n425: // Command\n426: // ---------------------------------------------------------------------------\n427: \n428: export async function cmdTasksGraph(opts: TasksGraphOptions): Promise<void> {\n429:   const { projectRoot, config } = opts;\n430:   const data = loadFeatures(projectRoot, config);\n431:   const fmt = opts.outputFmt ?? \"text\";\n432: \n433:   const { source, nodeCount, edgeCount, orphanCount, orphans } = buildMermaidSource(data, {\n434:     status: opts.status,\n435:     subtasks: opts.subtasks,\n436:   });\n437: \n438:   if (nodeCount === 0 && orphanCount === 0) {\n439:     output(fmt, { graph: null, nodes: 0, edges: 0, message: \"No tasks to graph\" }, () => {\n440:       console.log(\"No tasks to graph.\");\n441:     }, () => {\n442:       console.log(renderGraph({ mermaid: null, nodes: 0, edges: 0, orphan_count: 0, orphans: [] }));\n443:     });\n444:     return;\n445:   }\n446: \n447:   // --mermaid: emit raw mermaid source\n448:   if (opts.mermaid) {\n449:     output(fmt, { mermaid: source || null, nodes: nodeCount, edges: edgeCount, orphans }, () => {\n450:       if (source) {\n451:         console.log(source);\n452:       }\n453:       if (orphans.length > 0) {\n454:         console.log(`\\n# ${orphans.length} orphan(s) with no dependency relationships:`);\n455:         for (const o of orphans) {\n456:           console.log(`# ${STATUS_BADGE[o.status]} ${o.id}: ${o.title}`);\n457:         }\n458:       }\n459:     }, () => {\n460:       console.log(renderGraph({\n461:         mermaid: source || null,\n462:         nodes: nodeCount,\n463:         edges: edgeCount,\n464:         orphan_count: orphans.length,\n465:         orphans,\n466:       }));\n467:     });\n468:     return;\n469:   }\n470: \n471:   // --output json: emit structured data\n472:   if (fmt === \"json\") {\n473:     const rendered = source ? renderMermaidToTui(source, { ascii: true }) as string : null;\n474:     console.log(\n475:       JSON.stringify({\n476:         mermaid: source || null,\n477:         rendered,\n478:         nodes: nodeCount,\n479:         edges: edgeCount,\n480:         orphan_count: orphanCount,\n481:         orphans,\n482:       })\n483:     );\n484:     return;\n485:   }\n486: \n487:   // --output toon: emit compact TOON format\n488:   if (fmt === \"toon\") {\n489:     console.log(renderGraph({\n490:       mermaid: source || null,\n491:       nodes: nodeCount,\n492:       edges: edgeCount,\n493:       orphan_count: orphanCount,\n494:       orphans,\n495:     }));\n496:     return;\n497:   }\n498: \n499:   // Default: render the graph in the terminal\n500:   console.log(`\\n${BOLD}Task Dependency Graph${RESET}`);\n501: \n502:   if (nodeCount > 0 && source) {\n503:     const rendered = renderMermaidToTui(source, { ascii: !!opts.ascii }) as string;\n504:     console.log(`${DIM}${nodeCount} nodes, ${edgeCount} edges${RESET}\\n`);\n505:     console.log(rendered);\n506:   } else {\n507:     console.log(`${DIM}No dependency relationships found.${RESET}`);\n508:   }\n509: \n510:   // Print orphan summary\n511:   if (orphans.length > 0) {\n512:     console.log(`\\n${BOLD}Standalone tasks${RESET} ${DIM}(${orphans.length} with no dependencies):${RESET}`);\n513:     for (const o of orphans) {\n514:       const badge = STATUS_BADGE[o.status];\n515:       console.log(`  ${DIM}${badge}${RESET} ${o.id} ${DIM}— ${o.title}${RESET}`);\n516:     }\n517:   }\n518: \n519:   // Print legend and diagnostics\n520:   printLegend(data.tasks);\n521:   printDiagnostics(data, !!opts.subtasks);\n522:   console.log(\"\");\n523: }\n\n(End of file - total 523 lines)\n</content>","title":"src/commands/tasks/graph.ts","metadata":{"preview":"/**\n * tasks/graph.ts — Visualize the task dependency graph.\n *\n * Usage:\n *   woco tasks graph                     # show full dependency graph\n *   woco tasks graph --status backlog    # filter by status\n *   woco tasks graph --ascii             # ASCII-only rendering\n *   woco tasks graph --output json       # emit mermaid source as JSON\n *   woco tasks graph --mermaid           # emit raw mermaid source text\n *   woco tasks graph --subtasks          # include subtask-level nodes\n *\n * Builds a Mermaid flowchart from the tasks dependency graph and renders\n * it as a Unicode box diagram in the terminal using mermaidtui.\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  type Feature,\n  type Subtask,","truncated":false,"loaded":[]},"time":{"start":1773440138527,"end":1773440138531}}}}
