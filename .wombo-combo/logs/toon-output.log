{"type":"tool_use","timestamp":1773440141840,"sessionID":"ses_316bba7c1ffenLP0vTOciFexZp","part":{"id":"prt_ce944fd20001r9dfVFj8qGvtER","sessionID":"ses_316bba7c1ffenLP0vTOciFexZp","messageID":"msg_ce944ec74001JxcBa8MY2L1g34","type":"tool","callID":"toolu_vrtx_01N3rgE16wqFjqgqX48ww5Eo","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/toon-output/src/commands/resume.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/toon-output/src/commands/resume.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * resume.ts — Resume a previously stopped wave.\n3:  *\n4:  * Usage: woco resume [options] [--output json]\n5:  *\n6:  * Restores from .wombo-combo/state.json:\n7:  *   - Agents in \"running\"/\"installing\" whose PID is dead → re-check or re-launch\n8:  *   - Agents in \"queued\" → launch them\n9:  *   - Agents in terminal states (verified/failed/merged) → leave alone\n10:  */\n11: \n12: import type { WomboConfig } from \"../config.js\";\n13: import type { Feature } from \"../lib/tasks.js\";\n14: import { loadFeatures } from \"../lib/tasks.js\";\n15: import {\n16:   loadState,\n17:   saveState,\n18:   updateAgent,\n19:   queuedAgents,\n20:   readyToLaunchAgents,\n21:   cancelDownstream,\n22:   isWaveComplete,\n23:   type WaveState,\n24:   type AgentState,\n25: } from \"../lib/state.js\";\n26: import {\n27:   createWorktree,\n28:   installDeps,\n29:   worktreeReady,\n30:   worktreeExists,\n31:   branchHasChanges,\n32:   removeWorktree,\n33:   log as wtLog,\n34: } from \"../lib/worktree.js\";\n35: import { generatePrompt } from \"../lib/prompt.js\";\n36: import {\n37:   launchInteractive,\n38:   isProcessRunning,\n39:   getMultiplexerName,\n40: } from \"../lib/launcher.js\";\n41: import { ProcessMonitor } from \"../lib/monitor.js\";\n42: import { pushBaseBranch } from \"../lib/merger.js\";\n43: import { runBuild } from \"../lib/verifier.js\";\n44: import { printDashboard, printAgentUpdate } from \"../lib/ui.js\";\n45: import { WomboTUI } from \"../lib/tui.js\";\n46: import {\n47:   launchSingleHeadless,\n48:   handleBuildVerification,\n49:   handleRetry,\n50:   launchNextQueued,\n51:   launchAllReady,\n52:   markFeatureDone,\n53:   attemptMerge,\n54:   dumpFailedAgentLogs,\n55: } from \"./launch.js\";\n56: import {\n57:   detectMultiplexer,\n58:   muxAttachCommand,\n59: } from \"../lib/multiplexer.js\";\n60: import { exportWaveHistory } from \"../lib/history.js\";\n61: import { outputError, outputMessage, type OutputFormat } from \"../lib/output.js\";\n62: \n63: // ---------------------------------------------------------------------------\n64: // Types\n65: // ---------------------------------------------------------------------------\n66: \n67: export interface ResumeCommandOptions {\n68:   projectRoot: string;\n69:   config: WomboConfig;\n70:   maxConcurrent?: number;\n71:   model?: string;\n72:   interactive: boolean;\n73:   noTui: boolean;\n74:   autoPush: boolean;\n75:   baseBranch?: string;\n76:   maxRetries?: number;\n77:   outputFmt?: OutputFormat;\n78: }\n79: \n80: // ---------------------------------------------------------------------------\n81: // Command\n82: // ---------------------------------------------------------------------------\n83: \n84: export async function cmdResume(opts: ResumeCommandOptions): Promise<void> {\n85:   const { projectRoot, config } = opts;\n86:   const fmt = opts.outputFmt ?? \"text\";\n87: \n88:   const state = loadState(projectRoot);\n89:   if (!state) {\n90:     outputError(fmt, \"No wave state found. Use 'woco launch' to start a new wave.\");\n91:     return; // unreachable — outputError calls process.exit\n92:   }\n93: \n94:   if (fmt === \"text\") {\n95:     console.log(`\\n--- wombo-combo: Resume ${state.wave_id} ---\\n`);\n96:   }\n97: \n98:   // Load feature data for prompt generation\n99:   const data = loadFeatures(projectRoot, config);\n100:   const featureMap = new Map(data.tasks.map((f: Feature) => [f.id, f]));\n101: \n102:   // Triage agents by current state\n103:   let toRelaunch: AgentState[] = [];\n104:   let toVerify: AgentState[] = [];\n105: \n106:   for (const agent of state.agents) {\n107:     switch (agent.status) {\n108:       case \"running\":\n109:       case \"installing\":\n110:       case \"retry\":\n111:       case \"resolving_conflict\":\n112:         // Was in-flight when we stopped — check if PID is still alive\n113:         if (agent.pid && isProcessRunning(agent.pid)) {\n114:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: still running (PID ${agent.pid}), leaving alone`);\n115:         } else {\n116:           // Process is dead — check if worktree exists with meaningful changes.\n117:           // Use worktreeExists (not worktreeReady) because node_modules may be\n118:           // missing — the worktree still has code that should be verified.\n119:           if (worktreeExists(agent.worktree) && branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n120:             // Worktree exists AND branch has commits — try build verification\n121:             if (fmt === \"text\") console.log(`  ${agent.feature_id}: process dead, worktree has changes — will verify build`);\n122:             toVerify.push(agent);\n123:           } else {\n124:             // No worktree, or worktree exists but branch has no commits (agent did nothing)\n125:             const reason = worktreeExists(agent.worktree)\n126:               ? \"worktree exists but no code changes\"\n127:               : \"no worktree\";\n128:             if (fmt === \"text\") console.log(`  ${agent.feature_id}: process dead, ${reason} — will re-launch`);\n129:             updateAgent(state, agent.feature_id, {\n130:               status: \"queued\",\n131:               pid: null,\n132:               activity: null,\n133:               session_id: null,\n134:             });\n135:             toRelaunch.push(agent);\n136:           }\n137:         }\n138:         break;\n139: \n140:       case \"queued\":\n141:         if (fmt === \"text\") console.log(`  ${agent.feature_id}: queued — will launch`);\n142:         toRelaunch.push(agent);\n143:         break;\n144: \n145:       case \"completed\":\n146:         // Completed but not verified — verify\n147:         if (fmt === \"text\") console.log(`  ${agent.feature_id}: completed — will verify build`);\n148:         toVerify.push(agent);\n149:         break;\n150: \n151:       case \"verified\":\n152:         // Build passed but NOT yet merged — need to attempt merge (+ conflict resolution)\n153:         if (fmt === \"text\") console.log(`  ${agent.feature_id}: verified — will attempt merge`);\n154:         toVerify.push(agent);\n155:         break;\n156: \n157:       case \"merged\":\n158:         if (fmt === \"text\") console.log(`  ${agent.feature_id}: merged — marking feature as done`);\n159:         markFeatureDone(projectRoot, agent.feature_id, config, state.base_branch);\n160:         try {\n161:           removeWorktree(projectRoot, agent.worktree, true);\n162:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: worktree and branch removed`);\n163:         } catch {\n164:           // Already cleaned — not critical\n165:         }\n166:         break;\n167: \n168:       case \"failed\":\n169:         // If the worktree exists with code changes and retries remain,\n170:         // attempt build verification rather than discarding the work.\n171:         if (agent.retries < agent.max_retries &&\n172:             worktreeExists(agent.worktree) &&\n173:             branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n174:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: failed but has work (retry ${agent.retries}/${agent.max_retries}) — will verify build`);\n175:           // Clear stale error and mark as completed so handleBuildVerification\n176:           // processes it correctly (it expects a non-failed agent)\n177:           updateAgent(state, agent.feature_id, {\n178:             status: \"completed\",\n179:             error: null,\n180:             build_passed: null,\n181:             build_output: null,\n182:             completed_at: new Date().toISOString(),\n183:           });\n184:           toVerify.push(agent);\n185:         } else if (agent.retries < agent.max_retries) {\n186:           // No worktree or no changes — re-launch from scratch\n187:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: failed, no salvageable work (retry ${agent.retries}/${agent.max_retries}) — will re-launch`);\n188:           updateAgent(state, agent.feature_id, {\n189:             status: \"queued\",\n190:             pid: null,\n191:             error: null,\n192:             build_passed: null,\n193:             build_output: null,\n194:             activity: null,\n195:             session_id: null,\n196:             completed_at: null,\n197:           });\n198:           toRelaunch.push(agent);\n199:         } else {\n200:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: failed — max retries reached (use 'woco retry' to reset)`);\n201:         }\n202:         break;\n203:     }\n204:   }\n205: \n206:   saveState(projectRoot, state);\n207: \n208:   // ---------------------------------------------------------------------------\n209:   // Phase 1: Parallel build verification\n210:   // Each agent's worktree is independent, so dep install + build can run\n211:   // concurrently. Merges must remain sequential (they mutate the project root).\n212:   // ---------------------------------------------------------------------------\n213:   if (toVerify.length > 0) {\n214:     if (fmt === \"text\") console.log(`\\nVerifying ${toVerify.length} agent(s) in parallel...\\n`);\n215: \n216:     const verifyResults = await Promise.all(\n217:       toVerify.map(async (agent): Promise<{ agent: AgentState; needsMerge: boolean }> => {\n218:         const feature = featureMap.get(agent.feature_id);\n219:         if (!feature) return { agent, needsMerge: false };\n220: \n221:         // Already verified — skip build, go straight to merge\n222:         if (agent.status === \"verified\") {\n223:           printAgentUpdate(agent, \"already verified — queued for merge\");\n224:           return { agent, needsMerge: true };\n225:         }\n226: \n227:         printAgentUpdate(agent, \"verifying build...\");\n228: \n229:         // Ensure deps are installed — worktree may exist without node_modules\n230:         // (e.g., failed agents whose setup was interrupted)\n231:         if (!worktreeReady(agent.worktree) && worktreeExists(agent.worktree)) {\n232:           try {\n233:             printAgentUpdate(agent, \"installing deps...\");\n234:             await installDeps(agent.worktree, agent.feature_id, config);\n235:           } catch (depErr: any) {\n236:             printAgentUpdate(agent, `dep install failed: ${depErr.message}`);\n237:             updateAgent(state, agent.feature_id, {\n238:               status: \"failed\",\n239:               error: `Dependency install failed: ${depErr.message}`,\n240:               retries: agent.retries + 1,\n241:               completed_at: new Date().toISOString(),\n242:             });\n243:             saveState(projectRoot, state);\n244:             return { agent, needsMerge: false };\n245:           }\n246:         }\n247: \n248:         try {\n249:           const buildResult = await runBuild(agent.worktree, config);\n250:           if (buildResult.passed) {\n251:             updateAgent(state, agent.feature_id, {\n252:               status: \"verified\",\n253:               build_passed: true,\n254:               build_output: null,\n255:             });\n256:             saveState(projectRoot, state);\n257:             printAgentUpdate(agent, `BUILD PASSED (${Math.round(buildResult.durationMs / 1000)}s)`);\n258:             return { agent, needsMerge: true };\n259:           } else {\n260:             // Build failed\n261:             if (agent.retries < agent.max_retries) {\n262:               updateAgent(state, agent.feature_id, {\n263:                 status: \"retry\",\n264:                 retries: agent.retries + 1,\n265:                 build_passed: false,\n266:                 build_output: buildResult.errorSummary,\n267:               });\n268:               saveState(projectRoot, state);\n269:               printAgentUpdate(agent, `BUILD FAILED — will retry (${agent.retries + 1}/${agent.max_retries})`);\n270:             } else {\n271:               updateAgent(state, agent.feature_id, {\n272:                 status: \"failed\",\n273:                 build_passed: false,\n274:                 build_output: buildResult.errorSummary,\n275:                 error: `Build failed after ${agent.max_retries} retries`,\n276:                 completed_at: new Date().toISOString(),\n277:               });\n278:               saveState(projectRoot, state);\n279:               printAgentUpdate(agent, \"BUILD FAILED — max retries reached\");\n280:             }\n281:             return { agent, needsMerge: false };\n282:           }\n283:         } catch (err: any) {\n284:           printAgentUpdate(agent, `verify error: ${err.message}`);\n285:           updateAgent(state, agent.feature_id, {\n286:             status: \"failed\",\n287:             error: `Build verification error: ${err.message}`,\n288:             completed_at: new Date().toISOString(),\n289:           });\n290:           saveState(projectRoot, state);\n291:           return { agent, needsMerge: false };\n292:         }\n293:       })\n294:     );\n295: \n296:     saveState(projectRoot, state);\n297: \n298:     // -------------------------------------------------------------------------\n299:     // Phase 2: Sequential merge for verified agents\n300:     // Merges must be sequential because they operate on the project root.\n301:     // -------------------------------------------------------------------------\n302:     const toMerge = verifyResults.filter((r) => r.needsMerge);\n303:     if (toMerge.length > 0) {\n304:       if (fmt === \"text\") console.log(`\\nMerging ${toMerge.length} verified agent(s)...\\n`);\n305:       for (const { agent } of toMerge) {\n306:         const feature = featureMap.get(agent.feature_id);\n307:         if (!feature) continue;\n308:         try {\n309:           await attemptMerge(projectRoot, state, agent, feature, config, opts.model);\n310:         } catch (err: any) {\n311:           printAgentUpdate(agent, `merge error: ${err.message}`);\n312:         }\n313:       }\n314:     }\n315: \n316:     // Collect agents that need re-launching from verify results\n317:     for (const { agent } of verifyResults) {\n318:       if (agent.status === \"retry\" || agent.status === \"running\") {\n319:         toRelaunch.push(agent);\n320:       }\n321:     }\n322:   }\n323: \n324:   // Re-launch agents\n325:   const maxConcurrent = opts.maxConcurrent ?? state.max_concurrent;\n326:   const toLaunchNow = toRelaunch.slice(0, maxConcurrent);\n327:   if (toLaunchNow.length === 0) {\n328:     outputMessage(fmt, \"No agents need (re)launching.\", {\n329:       wave_id: state.wave_id,\n330:       triage: {\n331:         to_verify: toVerify.length,\n332:         to_relaunch: 0,\n333:       },\n334:       agents: state.agents.map((a) => ({\n335:         feature_id: a.feature_id,\n336:         status: a.status,\n337:         build_passed: a.build_passed,\n338:         error: a.error,\n339:       })),\n340:     });\n341:     if (fmt === \"text\") printDashboard(state);\n342:     return;\n343:   }\n344: \n345:   if (fmt === \"text\") {\n346:     console.log(`\\nRe-launching ${toLaunchNow.length} agent(s)...\\n`);\n347:     printDashboard(state);\n348:   }\n349:   const model = opts.model ?? state.model ?? undefined;\n350: \n351:   if (opts.interactive) {\n352:     // Interactive resume\n353:     await Promise.all(\n354:       toLaunchNow.map(async (agent) => {\n355:         const feature = featureMap.get(agent.feature_id);\n356:         if (!feature) return;\n357: \n358:         updateAgent(state, agent.feature_id, {\n359:           status: \"installing\",\n360:           started_at: new Date().toISOString(),\n361:           activity: \"resuming...\",\n362:         });\n363:         saveState(projectRoot, state);\n364: \n365:         try {\n366:           if (!worktreeReady(agent.worktree)) {\n367:             await createWorktree(projectRoot, agent.feature_id, state.base_branch, config);\n368:             await installDeps(agent.worktree, agent.feature_id, config);\n369:           }\n370: \n371:           const prompt = generatePrompt(feature, state.base_branch, config);\n372:           const result = launchInteractive({\n373:             worktreePath: agent.worktree,\n374:             featureId: feature.id,\n375:             prompt,\n376:             model,\n377:             interactive: true,\n378:             config,\n379:           });\n380: \n381:           const muxName = getMultiplexerName(config);\n382:           updateAgent(state, agent.feature_id, {\n383:             status: \"running\",\n384:             pid: result.pid,\n385:             activity: `${muxName} session active`,\n386:           });\n387:           saveState(projectRoot, state);\n388:         } catch (err: any) {\n389:           updateAgent(state, agent.feature_id, {\n390:             status: \"failed\",\n391:             error: err.message,\n392:             activity: null,\n393:             completed_at: new Date().toISOString(),\n394:           });\n395:           saveState(projectRoot, state);\n396:         }\n397:       })\n398:     );\n399: \n400:     if (fmt === \"text\") {\n401:       printDashboard(state);\n402:       const mux = detectMultiplexer(config.agent.multiplexer);\n403:       console.log(`\\nResume complete. Use '${muxAttachCommand(mux, `${config.agent.tmuxPrefix}-<id>`)}' to check sessions.`);\n404:     }\n405:   } else {\n406:     // Headless resume — re-enter monitoring loop\n407:     const monitor = new ProcessMonitor(projectRoot, {\n408:       onSessionId: (featureId, sessionId) => {\n409:         updateAgent(state, featureId, { session_id: sessionId });\n410:         saveState(projectRoot, state);\n411:       },\n412:       onComplete: (featureId) => {\n413:         updateAgent(state, featureId, {\n414:           status: \"completed\",\n415:           completed_at: new Date().toISOString(),\n416:           activity: \"done\",\n417:         });\n418:         saveState(projectRoot, state);\n419:         wtLog(featureId, \"agent completed — verifying build...\");\n420: \n421:         const agent = state.agents.find((a) => a.feature_id === featureId)!;\n422:         const feature = featureMap.get(featureId)!;\n423:         handleBuildVerification(projectRoot, state, agent, feature, config, model, monitor)\n424:           .then(() => launchAllReady(projectRoot, state, featureMap, monitor, config, model))\n425:           .catch((err) => {\n426:             wtLog(featureId, `BUILD VERIFICATION UNHANDLED ERROR: ${err.message}`);\n427:             launchAllReady(projectRoot, state, featureMap, monitor, config, model);\n428:           });\n429:       },\n430:       onError: (featureId, error) => {\n431:         const agent = state.agents.find((a) => a.feature_id === featureId)!;\n432:         if (agent.retries < agent.max_retries) {\n433:           updateAgent(state, featureId, {\n434:             status: \"retry\",\n435:             retries: agent.retries + 1,\n436:             error,\n437:             activity: \"retrying...\",\n438:           });\n439:           saveState(projectRoot, state);\n440:           handleRetry(projectRoot, state, agent, monitor, config, model);\n441:         } else {\n442:           updateAgent(state, featureId, {\n443:             status: \"failed\",\n444:             error,\n445:             activity: null,\n446:             completed_at: new Date().toISOString(),\n447:           });\n448:           saveState(projectRoot, state);\n449: \n450:           // Cascade failure to downstream agents\n451:           const cancelled = cancelDownstream(state, featureId);\n452:           if (cancelled.length > 0) {\n453:             wtLog(featureId, `downstream cancelled: ${cancelled.join(\", \")}`);\n454:             saveState(projectRoot, state);\n455:           }\n456:         }\n457:         launchAllReady(projectRoot, state, featureMap, monitor, config, model);\n458:       },\n459:       onActivity: (featureId, activity) => {\n460:         updateAgent(state, featureId, {\n461:           activity,\n462:           activity_updated_at: new Date().toISOString(),\n463:         });\n464:       },\n465:     });\n466: \n467:     // Handle graceful shutdown\n468:     const tuiRef = { current: null as WomboTUI | null };\n469:     process.on(\"SIGINT\", () => {\n470:       if (tuiRef.current) tuiRef.current.stop();\n471:       for (const agent of state.agents) {\n472:         if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n473:           updateAgent(state, agent.feature_id, {\n474:             activity: \"interrupted\",\n475:           });\n476:         }\n477:       }\n478:       monitor.killAll();\n479:       saveState(projectRoot, state);\n480:       if (fmt === \"text\") console.log(\"\\nState saved. Use 'woco resume' to continue.\");\n481:       process.exit(0);\n482:     });\n483: \n484:     await Promise.all(\n485:       toLaunchNow.map((agent) => {\n486:         const feature = featureMap.get(agent.feature_id);\n487:         if (!feature) return Promise.resolve();\n488:         return launchSingleHeadless(projectRoot, state, agent, feature, monitor, config, model);\n489:       })\n490:     );\n491: \n492:     // Start TUI dashboard (or skip if --no-tui)\n493:     if (!opts.noTui) {\n494:       tuiRef.current = new WomboTUI({\n495:         state,\n496:         monitor,\n497:         projectRoot,\n498:         interactive: false,\n499:         config,\n500:         onQuit: () => {\n501:           for (const agent of state.agents) {\n502:             if (agent.status === \"running\") {\n503:               updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n504:             }\n505:           }\n506:           monitor.killAll();\n507:           saveState(projectRoot, state);\n508:           if (fmt === \"text\") console.log(\"State saved. Use 'woco resume' to continue.\");\n509:           process.exit(0);\n510:         },\n511:         onRetry: (featureId: string) => {\n512:           const agent = state.agents.find((a) => a.feature_id === featureId);\n513:           if (!agent) return;\n514:           if (agent.status !== \"failed\" && agent.status !== \"retry\") return;\n515: \n516:           // Reset retries if exhausted, give it one more shot\n517:           if (agent.retries >= agent.max_retries) {\n518:             updateAgent(state, featureId, { max_retries: agent.retries + 1 });\n519:           }\n520: \n521:           wtLog(featureId, `manual retry requested from TUI — resetting to queued`);\n522:           updateAgent(state, featureId, {\n523:             status: \"queued\",\n524:             error: null,\n525:             activity: \"waiting for relaunch (manual retry)...\",\n526:           });\n527:           saveState(projectRoot, state);\n528:         },\n529:       });\n530:       tuiRef.current.start();\n531:     } else {\n532:       if (fmt === \"text\") console.log(\"(--no-tui mode, dashboard prints every 15s)\\n\");\n533:       printDashboard(state);\n534:     }\n535: \n536:     // Monitoring loop\n537:     const POLL_INTERVAL = 5000;\n538:     let dashboardCounter = 0;\n539:     while (!isWaveComplete(state)) {\n540:       await new Promise((r) => setTimeout(r, POLL_INTERVAL));\n541: \n542:       for (const agent of state.agents) {\n543:         if (\n544:           (agent.status === \"running\" || agent.status === \"resolving_conflict\") &&\n545:           agent.pid &&\n546:           !isProcessRunning(agent.pid) &&\n547:           !monitor.isRunning(agent.feature_id)\n548:         ) {\n549:           if (agent.status === \"resolving_conflict\") {\n550:             // Conflict resolver died unexpectedly — mark as failed\n551:             updateAgent(state, agent.feature_id, {\n552:               status: \"failed\",\n553:               error: \"Conflict resolver process died unexpectedly\",\n554:               activity: null,\n555:               completed_at: new Date().toISOString(),\n556:             });\n557:             saveState(projectRoot, state);\n558:             wtLog(agent.feature_id, \"conflict resolver died — marked failed\");\n559: \n560:             // Cascade failure to downstream agents\n561:             const cancelled = cancelDownstream(state, agent.feature_id);\n562:             if (cancelled.length > 0) {\n563:               wtLog(agent.feature_id, `downstream cancelled: ${cancelled.join(\", \")}`);\n564:               saveState(projectRoot, state);\n565:             }\n566: \n567:             launchAllReady(projectRoot, state, featureMap, monitor, config, model);\n568:             continue;\n569:           }\n570:           // Check if the agent actually made any commits\n571:           if (!branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n572:             // Agent died without producing any code — mark as failed\n573:             updateAgent(state, agent.feature_id, {\n574:               status: \"failed\",\n575:               error: \"Agent process exited without making any commits\",\n576:               activity: null,\n577:               completed_at: new Date().toISOString(),\n578:             });\n579:             saveState(projectRoot, state);\n580:             wtLog(agent.feature_id, \"process died with no code changes — marked failed\");\n581: \n582:             // Cascade failure to downstream agents\n583:             const cancelled = cancelDownstream(state, agent.feature_id);\n584:             if (cancelled.length > 0) {\n585:               wtLog(agent.feature_id, `downstream cancelled: ${cancelled.join(\", \")}`);\n586:               saveState(projectRoot, state);\n587:             }\n588:           } else {\n589:             updateAgent(state, agent.feature_id, {\n590:               status: \"completed\",\n591:               completed_at: new Date().toISOString(),\n592:               activity: \"done\",\n593:             });\n594:             saveState(projectRoot, state);\n595:             const feature = featureMap.get(agent.feature_id)!;\n596:             try {\n597:               await handleBuildVerification(projectRoot, state, agent, feature, config, model, monitor);\n598:             } catch (err: any) {\n599:               wtLog(agent.feature_id, `POLL VERIFY ERROR: ${err.message}`);\n600:             }\n601:           }\n602:           launchAllReady(projectRoot, state, featureMap, monitor, config, model);\n603:         }\n604:       }\n605: \n606:       saveState(projectRoot, state);\n607:       if (tuiRef.current) {\n608:         tuiRef.current.updateState(state);\n609:       } else if (opts.noTui) {\n610:         dashboardCounter++;\n611:         if (dashboardCounter % 3 === 0) {\n612:           printDashboard(state);\n613:         }\n614:       }\n615:     }\n616: \n617:     // Wave complete — keep TUI open for post-mortem browsing\n618:     if (tuiRef.current) {\n619:       tuiRef.current.updateState(state);\n620:       tuiRef.current.markWaveComplete();\n621:       await tuiRef.current.waitForQuit();\n622:     }\n623: \n624:     if (fmt === \"text\") {\n625:       printDashboard(state);\n626: \n627:       // Dump full logs for failed agents (post-mortem)\n628:       dumpFailedAgentLogs(projectRoot, state);\n629:     }\n630: \n631:     // Auto-export wave history\n632:     try {\n633:       const historyPath = exportWaveHistory(projectRoot, state);\n634:       if (fmt === \"text\") console.log(`Wave history exported to ${historyPath}`);\n635:     } catch (err: any) {\n636:       if (fmt === \"text\") console.error(`Warning: failed to export wave history: ${err.message}`);\n637:     }\n638: \n639:     // Auto-push base branch if requested\n640:     if (opts.autoPush) {\n641:       await pushBaseBranch(projectRoot, state.base_branch, config);\n642:     }\n643: \n644:     if (fmt === \"text\") console.log(\"Wave complete.\");\n645:   }\n646: }\n\n(End of file - total 646 lines)\n</content>","title":"src/commands/resume.ts","metadata":{"preview":"/**\n * resume.ts — Resume a previously stopped wave.\n *\n * Usage: woco resume [options] [--output json]\n *\n * Restores from .wombo-combo/state.json:\n *   - Agents in \"running\"/\"installing\" whose PID is dead → re-check or re-launch\n *   - Agents in \"queued\" → launch them\n *   - Agents in terminal states (verified/failed/merged) → leave alone\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport type { Feature } from \"../lib/tasks.js\";\nimport { loadFeatures } from \"../lib/tasks.js\";\nimport {\n  loadState,\n  saveState,\n  updateAgent,\n  queuedAgents,\n  readyToLaunchAgents,","truncated":false,"loaded":[]},"time":{"start":1773440141836,"end":1773440141839}}}}
