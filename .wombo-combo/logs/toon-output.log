{"type":"tool_use","timestamp":1773439935604,"sessionID":"ses_316be8edcffeznA8v4atF4wsHM","part":{"id":"prt_ce941dfa10010mQufyOBE3iORx","sessionID":"ses_316be8edcffeznA8v4atF4wsHM","messageID":"msg_ce941d143001oUcw4bDMKBILAf","type":"tool","callID":"toolu_vrtx_015aezqMQvujcfBu74BQoShH","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/toon-output/src/commands/abort.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/toon-output/src/commands/abort.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * abort.ts — Kill a single running agent without nuking the entire wave.\n3:  *\n4:  * Usage: woco abort <feature-id> [--requeue] [--output json]\n5:  *\n6:  * Kills the multiplexer session (if any) and the agent process, then updates\n7:  * wave state to mark the agent as \"failed\" (default) or \"queued\"\n8:  * (if --requeue is passed, returning it to the queue for retry).\n9:  */\n10: \n11: import type { WomboConfig } from \"../config.js\";\n12: import {\n13:   loadState,\n14:   saveState,\n15:   updateAgent,\n16:   type AgentState,\n17: } from \"../lib/state.js\";\n18: import {\n19:   killMuxSession,\n20:   getMultiplexerName,\n21:   isProcessRunning,\n22: } from \"../lib/launcher.js\";\n23: import { output, outputError, type OutputFormat } from \"../lib/output.js\";\n24: import { renderAbort } from \"../lib/toon.js\";\n25: \n26: // ---------------------------------------------------------------------------\n27: // Types\n28: // ---------------------------------------------------------------------------\n29: \n30: export interface AbortCommandOptions {\n31:   projectRoot: string;\n32:   config: WomboConfig;\n33:   featureId: string;\n34:   /** Return the feature to \"queued\" instead of marking it \"failed\" */\n35:   requeue?: boolean;\n36:   outputFmt: OutputFormat;\n37: }\n38: \n39: // ---------------------------------------------------------------------------\n40: // Command\n41: // ---------------------------------------------------------------------------\n42: \n43: export async function cmdAbort(opts: AbortCommandOptions): Promise<void> {\n44:   const { projectRoot, config, featureId, outputFmt } = opts;\n45: \n46:   // Load wave state\n47:   const state = loadState(projectRoot);\n48:   if (!state) {\n49:     outputError(outputFmt, \"No active wave. Nothing to abort.\");\n50:     return; // unreachable — helps TypeScript narrow\n51:   }\n52: \n53:   // Find the agent\n54:   const agent = state.agents.find((a: AgentState) => a.feature_id === featureId);\n55:   if (!agent) {\n56:     outputError(\n57:       outputFmt,\n58:       `Agent not found for feature: ${featureId}. Use 'woco status' to see active agents.`\n59:     );\n60:     return; // unreachable — helps TypeScript narrow\n61:   }\n62: \n63:   // Only abort agents that are actually active (running, installing, queued, resolving_conflict)\n64:   const abortable = new Set([\"running\", \"installing\", \"queued\", \"resolving_conflict\"]);\n65:   if (!abortable.has(agent.status)) {\n66:     outputError(\n67:       outputFmt,\n68:       `Agent ${featureId} is not in an abortable state (current: ${agent.status}). ` +\n69:         `Only running, installing, queued, or resolving_conflict agents can be aborted.`\n70:     );\n71:     return; // unreachable — helps TypeScript narrow\n72:   }\n73: \n74:   // 1. Kill the multiplexer session (if any)\n75:   let muxKilled = false;\n76:   try {\n77:     killMuxSession(featureId, config);\n78:     muxKilled = true;\n79:   } catch {\n80:     // Session may not exist — that's fine\n81:   }\n82: \n83:   // 2. Kill the process by PID (if any and still running)\n84:   let processKilled = false;\n85:   if (agent.pid && isProcessRunning(agent.pid)) {\n86:     try {\n87:       process.kill(agent.pid, \"SIGTERM\");\n88:       processKilled = true;\n89:     } catch {\n90:       // Process may have already exited\n91:     }\n92:   }\n93: \n94:   // 3. Update wave state\n95:   const newStatus = opts.requeue ? \"queued\" : \"failed\";\n96:   const updates: Partial<AgentState> = {\n97:     status: newStatus as AgentState[\"status\"],\n98:     error: opts.requeue ? null : \"Aborted by user\",\n99:     completed_at: opts.requeue ? null : new Date().toISOString(),\n100:   };\n101: \n102:   // If requeuing, reset retry-related fields so the agent gets a fresh start\n103:   if (opts.requeue) {\n104:     updates.retries = 0;\n105:     updates.build_passed = null;\n106:     updates.build_output = null;\n107:     updates.started_at = null;\n108:     updates.completed_at = null;\n109:     updates.activity = null;\n110:     updates.activity_updated_at = null;\n111:   }\n112: \n113:   updateAgent(state, featureId, updates);\n114:   saveState(projectRoot, state);\n115: \n116:   // 4. Output result\n117:   const muxName = getMultiplexerName(config);\n118:   const result = {\n119:     feature_id: featureId,\n120:     previous_status: agent.status,\n121:     new_status: newStatus,\n122:     mux_killed: muxKilled,\n123:     process_killed: processKilled,\n124:     requeued: !!opts.requeue,\n125:   };\n126: \n127:   output(outputFmt, result, () => {\n128:     console.log(`\\nAborted agent: ${featureId}`);\n129:     console.log(`  Previous status: ${agent.status}`);\n130:     console.log(`  New status: ${newStatus}`);\n131:     if (muxKilled) console.log(`  Killed ${muxName} session: ${config.agent.tmuxPrefix}-${featureId}`);\n132:     if (processKilled) console.log(`  Killed process: PID ${agent.pid}`);\n133:     if (opts.requeue) {\n134:       console.log(`  Feature returned to queue for retry.`);\n135:     } else {\n136:       console.log(`  Feature marked as failed.`);\n137:     }\n138:   }, () => {\n139:     console.log(renderAbort(result));\n140:   });\n141: }\n\n(End of file - total 141 lines)\n</content>","title":"src/commands/abort.ts","metadata":{"preview":"/**\n * abort.ts — Kill a single running agent without nuking the entire wave.\n *\n * Usage: woco abort <feature-id> [--requeue] [--output json]\n *\n * Kills the multiplexer session (if any) and the agent process, then updates\n * wave state to mark the agent as \"failed\" (default) or \"queued\"\n * (if --requeue is passed, returning it to the queue for retry).\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport {\n  loadState,\n  saveState,\n  updateAgent,\n  type AgentState,\n} from \"../lib/state.js\";\nimport {\n  killMuxSession,\n  getMultiplexerName,","truncated":false,"loaded":[]},"time":{"start":1773439935600,"end":1773439935603}}}}
{"type":"tool_use","timestamp":1773439936144,"sessionID":"ses_316be8edcffeznA8v4atF4wsHM","part":{"id":"prt_ce941e53b001EsSr08yi85lc3Z","sessionID":"ses_316be8edcffeznA8v4atF4wsHM","messageID":"msg_ce941d143001oUcw4bDMKBILAf","type":"tool","callID":"toolu_vrtx_014XGvtQJDVFbDFMpetCVsoF","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/toon-output/src/commands/cleanup.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/toon-output/src/commands/cleanup.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * cleanup.ts — Remove all wave-related resources.\n3:  *\n4:  * Usage: woco cleanup\n5:  *\n6:  * Kills multiplexer sessions (dmux/tmux), removes worktrees, removes state and log files.\n7:  *\n8:  * NOTE: .wombo-combo/history/ is intentionally NOT removed by cleanup.\n9:  * Wave history records are meant to survive cleanup for retrospective\n10:  * analysis. See src/lib/history.ts.\n11:  */\n12: \n13: import { existsSync, unlinkSync, rmSync } from \"node:fs\";\n14: import { execSync } from \"node:child_process\";\n15: import { resolve } from \"node:path\";\n16: import type { WomboConfig } from \"../config.js\";\n17: import { WOMBO_DIR } from \"../config.js\";\n18: import { killAllMuxSessions, getMultiplexerName } from \"../lib/launcher.js\";\n19: import { cleanupAllWorktrees, listWomboWorktrees } from \"../lib/worktree.js\";\n20: import {\n21:   detectMultiplexer,\n22:   muxListSessions,\n23: } from \"../lib/multiplexer.js\";\n24: import { output, outputMessage, type OutputFormat } from \"../lib/output.js\";\n25: import { renderCleanup } from \"../lib/toon.js\";\n26: \n27: export interface CleanupOptions {\n28:   projectRoot: string;\n29:   config: WomboConfig;\n30:   dryRun?: boolean;\n31:   outputFmt?: OutputFormat;\n32: }\n33: \n34: export async function cmdCleanup(opts: CleanupOptions): Promise<void> {\n35:   const { projectRoot, config } = opts;\n36:   const fmt = opts.outputFmt ?? \"text\";\n37: \n38:   // Dry-run: show what would be cleaned up without doing it\n39:   if (opts.dryRun) {\n40:     // List multiplexer sessions that would be killed\n41:     const muxName = getMultiplexerName(config);\n42:     let matchingSessions: string[] = [];\n43:     try {\n44:       const mux = detectMultiplexer(config.agent.multiplexer);\n45:       const sessions = muxListSessions(mux);\n46:       const prefix = config.agent.tmuxPrefix;\n47:       matchingSessions = sessions.filter((s) => s.startsWith(prefix));\n48:     } catch {\n49:       // no mux server running\n50:     }\n51: \n52:     // List worktrees that would be removed (using safe filtering)\n53:     let matchingWorktrees: { path: string }[] = [];\n54:     try {\n55:       matchingWorktrees = listWomboWorktrees(projectRoot, config);\n56:     } catch {\n57:       // no worktrees\n58:     }\n59: \n60:     const statePath = resolve(projectRoot, WOMBO_DIR, \"state.json\");\n61:     const logDir = resolve(projectRoot, WOMBO_DIR, \"logs\");\n62:     const filesToRemove: string[] = [];\n63:     if (existsSync(statePath)) filesToRemove.push(\".wombo-combo/state.json\");\n64:     if (existsSync(logDir)) filesToRemove.push(\".wombo-combo/logs/\");\n65: \n66:     const dryRunResult = {\n67:       dry_run: true,\n68:       mux_sessions: matchingSessions,\n69:       mux_sessions_count: matchingSessions.length,\n70:       worktrees: matchingWorktrees.map((wt) => wt.path),\n71:       worktrees_count: matchingWorktrees.length,\n72:       files_to_remove: filesToRemove,\n73:     };\n74: \n75:     output(fmt, dryRunResult, () => {\n76:       console.log(\"\\n[dry-run] Would perform the following cleanup:\\n\");\n77:       console.log(`  ${muxName} sessions to kill: ${matchingSessions.length}`);\n78:       for (const s of matchingSessions) {\n79:         console.log(`    ${s}`);\n80:       }\n81:       console.log(`  worktrees to remove: ${matchingWorktrees.length}`);\n82:       for (const wt of matchingWorktrees) {\n83:         console.log(`    ${wt.path}`);\n84:       }\n85:       for (const f of filesToRemove) {\n86:         console.log(`  Would remove: ${f}`);\n87:       }\n88:     }, () => {\n89:       console.log(renderCleanup(dryRunResult));\n90:     });\n91: \n92:     return;\n93:   }\n94: \n95:   // Kill multiplexer sessions\n96:   const muxName = getMultiplexerName(config);\n97:   const killed = killAllMuxSessions(config);\n98: \n99:   // Remove worktrees\n100:   const removed = cleanupAllWorktrees(projectRoot, config);\n101: \n102:   // List remaining feature branches\n103:   let remainingBranches: string[] = [];\n104:   try {\n105:     const branchPattern = `\"${config.git.branchPrefix}*\"`;\n106:     const branchesRaw = execSync(`git branch --list ${branchPattern}`, {\n107:       cwd: projectRoot,\n108:       encoding: \"utf-8\",\n109:     }).trim();\n110:     if (branchesRaw) {\n111:       remainingBranches = branchesRaw.split(\"\\n\").map((b) => b.trim());\n112:     }\n113:   } catch {}\n114: \n115:   // Remove state file\n116:   const statePath = resolve(projectRoot, WOMBO_DIR, \"state.json\");\n117:   const stateRemoved = existsSync(statePath);\n118:   if (stateRemoved) {\n119:     unlinkSync(statePath);\n120:   }\n121: \n122:   // Remove log directory\n123:   const logDir = resolve(projectRoot, WOMBO_DIR, \"logs\");\n124:   const logsRemoved = existsSync(logDir);\n125:   if (logsRemoved) {\n126:     rmSync(logDir, { recursive: true, force: true });\n127:   }\n128: \n129:   // Check if history is preserved\n130:   const historyDir = resolve(projectRoot, WOMBO_DIR, \"history\");\n131:   const historyPreserved = existsSync(historyDir);\n132: \n133:   const result = {\n134:     mux_sessions_killed: killed,\n135:     worktrees_removed: removed,\n136:     state_removed: stateRemoved,\n137:     logs_removed: logsRemoved,\n138:     remaining_branches: remainingBranches,\n139:     history_preserved: historyPreserved,\n140:   };\n141: \n142:   output(fmt, result, () => {\n143:     console.log(\"\\n--- wombo-combo: Cleanup ---\\n\");\n144:     console.log(`Killed ${killed} ${muxName} session(s)`);\n145:     console.log(`Removed ${removed} worktree(s)`);\n146: \n147:     if (remainingBranches.length > 0) {\n148:       console.log(`\\nRemaining feature branches:\\n${remainingBranches.map((b) => `  ${b}`).join(\"\\n\")}`);\n149:       console.log('Use \"git branch -D <branch>\" to remove manually.');\n150:     }\n151: \n152:     if (stateRemoved) console.log(\"Removed .wombo-combo/state.json\");\n153:     if (logsRemoved) console.log(\"Removed .wombo-combo/logs/\");\n154: \n155:     console.log(\"\\nCleanup complete.\");\n156: \n157:     if (historyPreserved) {\n158:       console.log(\"Note: .wombo-combo/history/ is preserved. Use 'woco history' to view past waves.\");\n159:     }\n160:   }, () => {\n161:     console.log(renderCleanup(result));\n162:   });\n163: }\n\n(End of file - total 163 lines)\n</content>","title":"src/commands/cleanup.ts","metadata":{"preview":"/**\n * cleanup.ts — Remove all wave-related resources.\n *\n * Usage: woco cleanup\n *\n * Kills multiplexer sessions (dmux/tmux), removes worktrees, removes state and log files.\n *\n * NOTE: .wombo-combo/history/ is intentionally NOT removed by cleanup.\n * Wave history records are meant to survive cleanup for retrospective\n * analysis. See src/lib/history.ts.\n */\n\nimport { existsSync, unlinkSync, rmSync } from \"node:fs\";\nimport { execSync } from \"node:child_process\";\nimport { resolve } from \"node:path\";\nimport type { WomboConfig } from \"../config.js\";\nimport { WOMBO_DIR } from \"../config.js\";\nimport { killAllMuxSessions, getMultiplexerName } from \"../lib/launcher.js\";\nimport { cleanupAllWorktrees, listWomboWorktrees } from \"../lib/worktree.js\";\nimport {","truncated":false,"loaded":[]},"time":{"start":1773439936141,"end":1773439936143}}}}
{"type":"tool_use","timestamp":1773439936536,"sessionID":"ses_316be8edcffeznA8v4atF4wsHM","part":{"id":"prt_ce941e68e0010pGnCbrTgpc2id","sessionID":"ses_316be8edcffeznA8v4atF4wsHM","messageID":"msg_ce941d143001oUcw4bDMKBILAf","type":"tool","callID":"toolu_vrtx_01BGD7a3387pur6XXaEnqQo2","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/toon-output/src/commands/history.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/toon-output/src/commands/history.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * history.ts — View wave history and summaries.\n3:  *\n4:  * Usage:\n5:  *   woco history                    List all past waves\n6:  *   woco history <wave-id>          Show details of a specific wave\n7:  *   woco history --output json      Output as JSON\n8:  *\n9:  * Wave history is stored in .wombo-combo/history/<wave-id>.json and survives\n10:  * `woco cleanup`. Records are auto-exported when a wave completes.\n11:  */\n12: \n13: import type { WomboConfig } from \"../config.js\";\n14: import {\n15:   listHistory,\n16:   loadHistory,\n17:   type WaveHistoryRecord,\n18: } from \"../lib/history.js\";\n19: import { output, outputError, type OutputFormat } from \"../lib/output.js\";\n20: import { renderHistoryList, renderHistoryDetail } from \"../lib/toon.js\";\n21: \n22: // ---------------------------------------------------------------------------\n23: // Types\n24: // ---------------------------------------------------------------------------\n25: \n26: export interface HistoryCommandOptions {\n27:   projectRoot: string;\n28:   config: WomboConfig;\n29:   /** Specific wave ID to show details for */\n30:   waveId?: string;\n31:   /** Output format */\n32:   outputFmt: OutputFormat;\n33: }\n34: \n35: // ---------------------------------------------------------------------------\n36: // Formatting Helpers\n37: // ---------------------------------------------------------------------------\n38: \n39: const RESET = \"\\x1b[0m\";\n40: const BOLD = \"\\x1b[1m\";\n41: const DIM = \"\\x1b[2m\";\n42: const FG = {\n43:   red: \"\\x1b[31m\",\n44:   green: \"\\x1b[32m\",\n45:   yellow: \"\\x1b[33m\",\n46:   blue: \"\\x1b[34m\",\n47:   magenta: \"\\x1b[35m\",\n48:   cyan: \"\\x1b[36m\",\n49:   gray: \"\\x1b[90m\",\n50: };\n51: \n52: function pad(text: string, width: number): string {\n53:   if (text.length >= width) return text.slice(0, width);\n54:   return text + \" \".repeat(width - text.length);\n55: }\n56: \n57: function padLeft(text: string, width: number): string {\n58:   if (text.length >= width) return text.slice(0, width);\n59:   return \" \".repeat(width - text.length) + text;\n60: }\n61: \n62: function formatDurationMs(ms: number | null): string {\n63:   if (ms === null || ms === 0) return \"-\";\n64:   const seconds = Math.floor(ms / 1000);\n65:   if (seconds < 60) return `${seconds}s`;\n66:   const minutes = Math.floor(seconds / 60);\n67:   if (minutes < 60) return `${minutes}m ${seconds % 60}s`;\n68:   const hours = Math.floor(minutes / 60);\n69:   return `${hours}h ${minutes % 60}m`;\n70: }\n71: \n72: function formatDate(iso: string): string {\n73:   try {\n74:     const d = new Date(iso);\n75:     return d.toLocaleDateString(\"en-US\", {\n76:       year: \"numeric\",\n77:       month: \"short\",\n78:       day: \"numeric\",\n79:       hour: \"2-digit\",\n80:       minute: \"2-digit\",\n81:     });\n82:   } catch {\n83:     return iso;\n84:   }\n85: }\n86: \n87: function statusColor(status: string): string {\n88:   switch (status) {\n89:     case \"merged\":\n90:       return FG.magenta;\n91:     case \"verified\":\n92:       return FG.green;\n93:     case \"failed\":\n94:       return FG.red;\n95:     case \"completed\":\n96:       return FG.yellow;\n97:     default:\n98:       return FG.gray;\n99:   }\n100: }\n101: \n102: // ---------------------------------------------------------------------------\n103: // List All Waves\n104: // ---------------------------------------------------------------------------\n105: \n106: function renderWaveList(records: WaveHistoryRecord[]): void {\n107:   if (records.length === 0) {\n108:     console.log(\"\\nNo wave history found.\");\n109:     console.log(\"History is auto-exported when a wave completes.\\n\");\n110:     return;\n111:   }\n112: \n113:   console.log(\"\");\n114:   console.log(`${BOLD}Wave History (${records.length} wave(s)):${RESET}`);\n115:   console.log(\"\");\n116: \n117:   const header = [\n118:     pad(\"Wave ID\", 24),\n119:     pad(\"Date\", 22),\n120:     padLeft(\"Total\", 6),\n121:     padLeft(\"OK\", 4),\n122:     padLeft(\"Fail\", 5),\n123:     padLeft(\"Merged\", 7),\n124:     padLeft(\"Retries\", 8),\n125:     padLeft(\"Duration\", 10),\n126:   ].join(\" \");\n127: \n128:   console.log(`${BOLD}${header}${RESET}`);\n129:   console.log(\"-\".repeat(90));\n130: \n131:   for (const rec of records) {\n132:     const s = rec.summary;\n133:     const okColor = s.succeeded === s.total ? FG.green : FG.yellow;\n134:     const failColor = s.failed > 0 ? FG.red : FG.gray;\n135: \n136:     const row = [\n137:       pad(rec.wave_id, 24),\n138:       pad(formatDate(rec.started_at), 22),\n139:       padLeft(String(s.total), 6),\n140:       `${okColor}${padLeft(String(s.succeeded), 4)}${RESET}`,\n141:       `${failColor}${padLeft(String(s.failed), 5)}${RESET}`,\n142:       padLeft(String(s.merged), 7),\n143:       padLeft(String(s.total_retries), 8),\n144:       padLeft(formatDurationMs(s.total_duration_ms), 10),\n145:     ].join(\" \");\n146: \n147:     console.log(row);\n148:   }\n149: \n150:   console.log(\"\");\n151:   console.log(`${DIM}Use 'woco history <wave-id>' for details.${RESET}`);\n152:   console.log(\"\");\n153: }\n154: \n155: // ---------------------------------------------------------------------------\n156: // Show Single Wave Details\n157: // ---------------------------------------------------------------------------\n158: \n159: function renderWaveDetails(rec: WaveHistoryRecord): void {\n160:   console.log(\"\");\n161:   console.log(`${BOLD}Wave: ${rec.wave_id}${RESET}`);\n162:   console.log(`${DIM}Base: ${rec.base_branch} | Concurrency: ${rec.max_concurrent} | Mode: ${rec.interactive ? \"interactive\" : \"headless\"}${RESET}`);\n163:   if (rec.model) {\n164:     console.log(`${DIM}Model: ${rec.model}${RESET}`);\n165:   }\n166:   console.log(`${DIM}Started: ${formatDate(rec.started_at)} | Exported: ${formatDate(rec.exported_at)}${RESET}`);\n167:   console.log(\"\");\n168: \n169:   // Summary\n170:   const s = rec.summary;\n171:   console.log(`${BOLD}Summary:${RESET}`);\n172:   console.log(`  Total agents:    ${s.total}`);\n173:   console.log(`  Succeeded:       ${FG.green}${s.succeeded}${RESET}`);\n174:   console.log(`  Failed:          ${s.failed > 0 ? FG.red : FG.gray}${s.failed}${RESET}`);\n175:   console.log(`  Merged:          ${FG.magenta}${s.merged}${RESET}`);\n176:   console.log(`  Verified:        ${FG.green}${s.verified}${RESET}`);\n177:   console.log(`  Total retries:   ${s.total_retries}`);\n178:   console.log(`  Total duration:  ${formatDurationMs(s.total_duration_ms)}`);\n179:   console.log(\"\");\n180: \n181:   // Agent table\n182:   console.log(`${BOLD}Agents:${RESET}`);\n183:   console.log(\"\");\n184: \n185:   const header = [\n186:     pad(\"Feature\", 30),\n187:     pad(\"Status\", 12),\n188:     padLeft(\"Retries\", 8),\n189:     padLeft(\"Duration\", 10),\n190:     pad(\"Build\", 6),\n191:     pad(\"Conflict\", 9),\n192:     pad(\"Error\", 30),\n193:   ].join(\" \");\n194: \n195:   console.log(`${BOLD}${header}${RESET}`);\n196:   console.log(\"-\".repeat(109));\n197: \n198:   for (const agent of rec.agents) {\n199:     const color = statusColor(agent.status);\n200:     const buildStr = agent.build_passed === true\n201:       ? `${FG.green}pass${RESET}`\n202:       : agent.build_passed === false\n203:         ? `${FG.red}fail${RESET}`\n204:         : `${FG.gray}-${RESET}`;\n205:     const conflictStr = agent.had_merge_conflict\n206:       ? `${FG.yellow}yes${RESET}`\n207:       : `${FG.gray}no${RESET}`;\n208:     const errorStr = agent.error\n209:       ? agent.error.split(\"\\n\")[0].slice(0, 28)\n210:       : \"-\";\n211: \n212:     const row = [\n213:       pad(agent.feature_id, 30),\n214:       `${color}${pad(agent.status, 12)}${RESET}`,\n215:       padLeft(\n216:         agent.retries > 0 ? `${agent.retries}/${agent.max_retries}` : \"-\",\n217:         8\n218:       ),\n219:       padLeft(formatDurationMs(agent.duration_ms), 10),\n220:       pad(buildStr, 6),\n221:       pad(conflictStr, 9),\n222:       pad(errorStr, 30),\n223:     ].join(\" \");\n224: \n225:     console.log(row);\n226:   }\n227: \n228:   console.log(\"\");\n229: }\n230: \n231: // ---------------------------------------------------------------------------\n232: // Command\n233: // ---------------------------------------------------------------------------\n234: \n235: export async function cmdHistory(opts: HistoryCommandOptions): Promise<void> {\n236:   const { projectRoot, outputFmt } = opts;\n237: \n238:   if (opts.waveId) {\n239:     // Show details for a specific wave\n240:     const record = loadHistory(projectRoot, opts.waveId);\n241:     if (!record) {\n242:       outputError(\n243:         outputFmt,\n244:         `Wave history not found: ${opts.waveId}. Use 'woco history' to list available waves.`\n245:       );\n246:       return; // unreachable — helps TypeScript narrow\n247:     }\n248: \n249:     output(outputFmt, record, () => {\n250:       renderWaveDetails(record);\n251:     }, () => {\n252:       // TOON renderer\n253:       console.log(renderHistoryDetail(record));\n254:     });\n255:   } else {\n256:     // List all waves\n257:     const records = listHistory(projectRoot);\n258: \n259:     output(outputFmt, records, () => {\n260:       renderWaveList(records);\n261:     }, () => {\n262:       // TOON renderer\n263:       console.log(renderHistoryList(records));\n264:     });\n265:   }\n266: }\n\n(End of file - total 266 lines)\n</content>","title":"src/commands/history.ts","metadata":{"preview":"/**\n * history.ts — View wave history and summaries.\n *\n * Usage:\n *   woco history                    List all past waves\n *   woco history <wave-id>          Show details of a specific wave\n *   woco history --output json      Output as JSON\n *\n * Wave history is stored in .wombo-combo/history/<wave-id>.json and survives\n * `woco cleanup`. Records are auto-exported when a wave completes.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport {\n  listHistory,\n  loadHistory,\n  type WaveHistoryRecord,\n} from \"../lib/history.js\";\nimport { output, outputError, type OutputFormat } from \"../lib/output.js\";\nimport { renderHistoryList, renderHistoryDetail } from \"../lib/toon.js\";","truncated":false,"loaded":[]},"time":{"start":1773439936534,"end":1773439936536}}}}
{"type":"tool_use","timestamp":1773439937177,"sessionID":"ses_316be8edcffeznA8v4atF4wsHM","part":{"id":"prt_ce941e817001ueXwYb4ZMVUPtV","sessionID":"ses_316be8edcffeznA8v4atF4wsHM","messageID":"msg_ce941d143001oUcw4bDMKBILAf","type":"tool","callID":"toolu_vrtx_0195i3f4wRuDXon2UsgvXny6","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/toon-output/src/commands/verify.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/toon-output/src/commands/verify.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * verify.ts — Run build verification on completed agents.\n3:  *\n4:  * Usage: woco verify [feature-id] [--browser] [--skip-tests] [--strict-tdd] [--output json]\n5:  *\n6:  * Runs the build command in each completed agent's worktree. If a specific\n7:  * feature-id is given, verifies only that agent. Otherwise verifies all\n8:  * agents with status \"completed\".\n9:  *\n10:  * When --browser is passed (or browser.enabled is true in config), also\n11:  * runs browser-based verification after the build passes.\n12:  *\n13:  * When TDD is enabled (tdd.enabled in config), also runs tests and checks\n14:  * for test coverage of new files. Use --skip-tests to skip or --strict-tdd\n15:  * to fail on missing tests.\n16:  */\n17: \n18: import type { WomboConfig } from \"../config.js\";\n19: import { loadFeatures, type Feature } from \"../lib/tasks.js\";\n20: import { loadState } from \"../lib/state.js\";\n21: import { printDashboard } from \"../lib/ui.js\";\n22: import { handleBuildVerification } from \"./launch.js\";\n23: import { output, outputMessage, type OutputFormat } from \"../lib/output.js\";\n24: import { renderVerifyResults } from \"../lib/toon.js\";\n25: \n26: // ---------------------------------------------------------------------------\n27: // Types\n28: // ---------------------------------------------------------------------------\n29: \n30: export interface VerifyCommandOptions {\n31:   projectRoot: string;\n32:   config: WomboConfig;\n33:   featureId?: string;\n34:   model?: string;\n35:   maxRetries?: number;\n36:   /** Enable browser verification (overrides config.browser.enabled) */\n37:   browserVerify?: boolean;\n38:   /** Skip running tests during TDD verification */\n39:   skipTests?: boolean;\n40:   /** Strict TDD mode: fail verification if new files are missing tests */\n41:   strictTdd?: boolean;\n42:   outputFmt?: OutputFormat;\n43: }\n44: \n45: // ---------------------------------------------------------------------------\n46: // Command\n47: // ---------------------------------------------------------------------------\n48: \n49: export async function cmdVerify(opts: VerifyCommandOptions): Promise<void> {\n50:   const { projectRoot, config } = opts;\n51:   const fmt = opts.outputFmt ?? \"text\";\n52: \n53:   // Apply browser verification override if --browser flag was passed\n54:   if (opts.browserVerify !== undefined) {\n55:     config.browser.enabled = opts.browserVerify;\n56:   }\n57: \n58:   // Apply TDD overrides from CLI flags\n59:   if (opts.strictTdd !== undefined) {\n60:     config.tdd.strictTdd = opts.strictTdd;\n61:   }\n62: \n63:   const state = loadState(projectRoot);\n64:   if (!state) {\n65:     outputMessage(fmt, \"No active wave.\", {\n66:       wave_id: null,\n67:       agents: [],\n68:       verified: 0,\n69:     });\n70:     return;\n71:   }\n72: \n73:   const toVerify = opts.featureId\n74:     ? state.agents.filter((a) => a.feature_id === opts.featureId)\n75:     : state.agents.filter((a) => a.status === \"completed\");\n76: \n77:   if (toVerify.length === 0) {\n78:     outputMessage(fmt, \"No agents to verify.\", {\n79:       wave_id: state.wave_id,\n80:       agents: [],\n81:       verified: 0,\n82:     });\n83:     return;\n84:   }\n85: \n86:   if (fmt === \"text\") {\n87:     console.log(`\\nVerifying ${toVerify.length} agent(s)...\\n`);\n88:   }\n89: \n90:   const data = loadFeatures(projectRoot, config);\n91: \n92:   for (const agent of toVerify) {\n93:     const feature = data.tasks.find((f: Feature) => f.id === agent.feature_id);\n94:     if (!feature) continue;\n95: \n96:     await handleBuildVerification(\n97:       projectRoot,\n98:       state,\n99:       agent,\n100:       feature,\n101:       config,\n102:       opts.model,\n103:       undefined, // monitor\n104:       { skipTests: opts.skipTests, strictTdd: opts.strictTdd }\n105:     );\n106:   }\n107: \n108:   // Collect results for JSON output\n109:   const results = toVerify.map((agent) => {\n110:     // Re-read agent state after verification (it was mutated in place)\n111:     const updatedAgent = state.agents.find((a) => a.feature_id === agent.feature_id);\n112:     return {\n113:       feature_id: agent.feature_id,\n114:       branch: agent.branch,\n115:       status: updatedAgent?.status ?? agent.status,\n116:       build_passed: updatedAgent?.build_passed ?? agent.build_passed,\n117:       error: updatedAgent?.error ?? agent.error,\n118:     };\n119:   });\n120: \n121:   output(fmt, {\n122:     wave_id: state.wave_id,\n123:     verified: results.filter((r) => r.status === \"verified\").length,\n124:     failed: results.filter((r) => r.status === \"failed\").length,\n125:     agents: results,\n126:   }, () => {\n127:     printDashboard(state);\n128:   }, () => {\n129:     console.log(renderVerifyResults({\n130:       wave_id: state.wave_id,\n131:       verified: results.filter((r) => r.status === \"verified\").length,\n132:       failed: results.filter((r) => r.status === \"failed\").length,\n133:       agents: results,\n134:     }));\n135:   });\n136: }\n\n(End of file - total 136 lines)\n</content>","title":"src/commands/verify.ts","metadata":{"preview":"/**\n * verify.ts — Run build verification on completed agents.\n *\n * Usage: woco verify [feature-id] [--browser] [--skip-tests] [--strict-tdd] [--output json]\n *\n * Runs the build command in each completed agent's worktree. If a specific\n * feature-id is given, verifies only that agent. Otherwise verifies all\n * agents with status \"completed\".\n *\n * When --browser is passed (or browser.enabled is true in config), also\n * runs browser-based verification after the build passes.\n *\n * When TDD is enabled (tdd.enabled in config), also runs tests and checks\n * for test coverage of new files. Use --skip-tests to skip or --strict-tdd\n * to fail on missing tests.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport { loadFeatures, type Feature } from \"../lib/tasks.js\";\nimport { loadState } from \"../lib/state.js\";","truncated":false,"loaded":[]},"time":{"start":1773439937174,"end":1773439937176}}}}
{"type":"tool_use","timestamp":1773439937751,"sessionID":"ses_316be8edcffeznA8v4atF4wsHM","part":{"id":"prt_ce941ea9700144ZXN6CiGPER75","sessionID":"ses_316be8edcffeznA8v4atF4wsHM","messageID":"msg_ce941d143001oUcw4bDMKBILAf","type":"tool","callID":"toolu_vrtx_01CGpgER3gBaPuk3WugjNaoh","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/toon-output/src/commands/merge.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/toon-output/src/commands/merge.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * merge.ts — Merge verified branches into the base branch.\n3:  *\n4:  * Usage: woco merge [feature-id] [--output json]\n5:  *\n6:  * Merges all verified agents (or a specific one) into the base branch.\n7:  * Uses the full merge pipeline including pre-flight conflict detection,\n8:  * automatic conflict resolution, and configurable retry attempts.\n9:  */\n10: \n11: import type { WomboConfig } from \"../config.js\";\n12: import {\n13:   loadState,\n14: } from \"../lib/state.js\";\n15: import { pushBaseBranch } from \"../lib/merger.js\";\n16: import type { Feature } from \"../lib/tasks.js\";\n17: import { loadFeatures } from \"../lib/tasks.js\";\n18: import { printDashboard, printAgentUpdate } from \"../lib/ui.js\";\n19: import { attemptMerge } from \"./launch.js\";\n20: import { output, outputMessage, type OutputFormat } from \"../lib/output.js\";\n21: import { renderMerge } from \"../lib/toon.js\";\n22: \n23: // ---------------------------------------------------------------------------\n24: // Types\n25: // ---------------------------------------------------------------------------\n26: \n27: export interface MergeCommandOptions {\n28:   projectRoot: string;\n29:   config: WomboConfig;\n30:   featureId?: string;\n31:   autoPush?: boolean;\n32:   dryRun?: boolean;\n33:   model?: string;\n34:   outputFmt?: OutputFormat;\n35: }\n36: \n37: // ---------------------------------------------------------------------------\n38: // Command\n39: // ---------------------------------------------------------------------------\n40: \n41: export async function cmdMerge(opts: MergeCommandOptions): Promise<void> {\n42:   const { projectRoot, config } = opts;\n43:   const fmt = opts.outputFmt ?? \"text\";\n44: \n45:   const state = loadState(projectRoot);\n46:   if (!state) {\n47:     outputMessage(fmt, \"No active wave.\", {\n48:       wave_id: null,\n49:       agents: [],\n50:       merged: 0,\n51:     });\n52:     return;\n53:   }\n54: \n55:   const toMerge = opts.featureId\n56:     ? state.agents.filter(\n57:         (a) => a.feature_id === opts.featureId && a.status === \"verified\"\n58:       )\n59:     : state.agents.filter((a) => a.status === \"verified\");\n60: \n61:   if (toMerge.length === 0) {\n62:     outputMessage(fmt, \"No verified agents to merge.\", {\n63:       wave_id: state.wave_id,\n64:       agents: [],\n65:       merged: 0,\n66:     });\n67:     return;\n68:   }\n69: \n70:   // Dry-run: show what would be merged without merging\n71:   if (opts.dryRun) {\n72:     const dryRunResult = {\n73:       dry_run: true,\n74:       wave_id: state.wave_id,\n75:       base_branch: state.base_branch,\n76:       count: toMerge.length,\n77:       agents: toMerge.map((a) => ({\n78:         feature_id: a.feature_id,\n79:         branch: a.branch,\n80:       })),\n81:       auto_push: !!opts.autoPush,\n82:     };\n83: \n84:     output(fmt, dryRunResult, () => {\n85:       console.log(`\\n[dry-run] Would merge ${toMerge.length} branch(es):\\n`);\n86:       for (const agent of toMerge) {\n87:         console.log(`  ${agent.feature_id} — branch: ${agent.branch}`);\n88:       }\n89:       if (opts.autoPush) {\n90:         console.log(`\\n  Would push ${state.base_branch} to remote after merge.`);\n91:       }\n92:     }, () => {\n93:       console.log(renderMerge(dryRunResult));\n94:     });\n95:     return;\n96:   }\n97: \n98:   // Load features for conflict resolution prompt generation.\n99:   // Build a flat map of all feature/subtask IDs so we can look up any agent.\n100:   const data = loadFeatures(projectRoot, config);\n101:   const featureMap = new Map<string, Feature>();\n102:   function indexFeatures(items: Feature[]) {\n103:     for (const f of items) {\n104:       featureMap.set(f.id, f);\n105:       if (f.subtasks) {\n106:         indexFeatures(f.subtasks as unknown as Feature[]);\n107:       }\n108:     }\n109:   }\n110:   indexFeatures(data.tasks);\n111:   indexFeatures(data.archive);\n112: \n113:   if (fmt === \"text\") {\n114:     console.log(`\\nMerging ${toMerge.length} branch(es)...\\n`);\n115:   }\n116: \n117:   for (const agent of toMerge) {\n118:     const feature = featureMap.get(agent.feature_id);\n119:     if (!feature) {\n120:       if (fmt === \"text\") {\n121:         printAgentUpdate(agent, `SKIP — feature \"${agent.feature_id}\" not found in features file`);\n122:       }\n123:       continue;\n124:     }\n125: \n126:     // Use the full merge pipeline (pre-flight, conflict resolution, retry)\n127:     await attemptMerge(projectRoot, state, agent, feature, config, opts.model);\n128:   }\n129: \n130:   // Auto-push if requested\n131:   if (opts.autoPush) {\n132:     const anyMerged = state.agents.some((a) => a.status === \"merged\");\n133:     if (anyMerged) {\n134:       await pushBaseBranch(projectRoot, state.base_branch, config);\n135:     }\n136:   }\n137: \n138:   // Collect results for JSON output\n139:   const results = toMerge.map((agent) => {\n140:     const updatedAgent = state.agents.find((a) => a.feature_id === agent.feature_id);\n141:     return {\n142:       feature_id: agent.feature_id,\n143:       branch: agent.branch,\n144:       status: updatedAgent?.status ?? agent.status,\n145:       error: updatedAgent?.error ?? agent.error,\n146:     };\n147:   });\n148: \n149:   output(fmt, {\n150:     wave_id: state.wave_id,\n151:     base_branch: state.base_branch,\n152:     merged: results.filter((r) => r.status === \"merged\").length,\n153:     failed: results.filter((r) => r.status === \"failed\").length,\n154:     agents: results,\n155:   }, () => {\n156:     printDashboard(state);\n157:   }, () => {\n158:     console.log(renderMerge({\n159:       wave_id: state.wave_id,\n160:       base_branch: state.base_branch,\n161:       merged: results.filter((r) => r.status === \"merged\").length,\n162:       failed: results.filter((r) => r.status === \"failed\").length,\n163:       agents: results,\n164:     }));\n165:   });\n166: }\n\n(End of file - total 166 lines)\n</content>","title":"src/commands/merge.ts","metadata":{"preview":"/**\n * merge.ts — Merge verified branches into the base branch.\n *\n * Usage: woco merge [feature-id] [--output json]\n *\n * Merges all verified agents (or a specific one) into the base branch.\n * Uses the full merge pipeline including pre-flight conflict detection,\n * automatic conflict resolution, and configurable retry attempts.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport {\n  loadState,\n} from \"../lib/state.js\";\nimport { pushBaseBranch } from \"../lib/merger.js\";\nimport type { Feature } from \"../lib/tasks.js\";\nimport { loadFeatures } from \"../lib/tasks.js\";\nimport { printDashboard, printAgentUpdate } from \"../lib/ui.js\";\nimport { attemptMerge } from \"./launch.js\";\nimport { output, outputMessage, type OutputFormat } from \"../lib/output.js\";","truncated":false,"loaded":[]},"time":{"start":1773439937748,"end":1773439937751}}}}
