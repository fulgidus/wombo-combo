omise<void> {\n41:   const { projectRoot, config } = opts;\n42:   const fmt = opts.outputFmt ?? \"text\";\n43: \n44:   if (!opts.featureId || !opts.newDifficulty) {\n45:     outputError(fmt, `Usage: woco tasks set-difficulty <task-id> <difficulty>\\nValid difficulties: ${VALID_DIFFICULTIES.join(\", \")}`);\n46:     return;\n47:   }\n48: \n49:   // Validate difficulty\n50:   if (!(VALID_DIFFICULTIES as readonly string[]).includes(opts.newDifficulty)) {\n51:     outputError(fmt, `Invalid difficulty: \"${opts.newDifficulty}\"\\nValid difficulties: ${VALID_DIFFICULTIES.join(\", \")}`);\n52:     return;\n53:   }\n54: \n55:   const data = loadFeatures(projectRoot, config);\n56:   const feature = findFeatureById(data, opts.featureId);\n57: \n58:   if (!feature) {\n59:     outputError(fmt, `Task \"${opts.featureId}\" not found.`);\n60:     return;\n61:   }\n62: \n63:   const oldDifficulty = feature.difficulty;\n64:   const newDifficulty = opts.newDifficulty as Difficulty;\n65: \n66:   if (oldDifficulty === newDifficulty) {\n67:     outputMessage(fmt, `Task \"${opts.featureId}\" already has difficulty \"${newDifficulty}\".`, {\n68:       id: opts.featureId,\n69:       difficulty: newDifficulty,\n70:       changed: false,\n71:     });\n72:     return;\n73:   }\n74: \n75:   // Dry-run: show what would change without writing\n76:   if (opts.dryRun) {\n77:     outputMessage(fmt, `[dry-run] Would change \"${opts.featureId}\" difficulty: ${oldDifficulty} → ${newDifficulty}`, {\n78:       dry_run: true,\n79:       id: opts.featureId,\n80:       old_difficulty: oldDifficulty,\n81:       new_difficulty: newDifficulty,\n82:       changed: false,\n83:     });\n84:     return;\n85:   }\n86: \n87:   // Apply difficulty change\n88:   feature.difficulty = newDifficulty;\n89: \n90:   saveFeatures(projectRoot, config, data);\n91: \n92:   outputMessage(fmt, `Task \"${opts.featureId}\" difficulty: ${oldDifficulty} → ${newDifficulty}`, {\n93:     id: opts.featureId,\n94:     old_difficulty: oldDifficulty,\n95:     new_difficulty: newDifficulty,\n96:     changed: true,\n97:   });\n98: }\n\n(End of file - total 98 lines)\n</content>","title":"src/commands/tasks/set-difficulty.ts","metadata":{"preview":"/**\n * tasks/set-difficulty.ts — Change a task's difficulty.\n *\n * Usage:\n *   woco tasks set-difficulty <task-id> <difficulty>\n *\n * Valid difficulties: trivial, easy, medium, hard, very_hard\n *\n * Supports --output json and --dry-run.\n * Works on both top-level tasks and subtasks.\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  saveFeatures,\n  findFeatureById,\n  type Difficulty,\n} from \"../../lib/tasks.js\";\nimport { VALID_DIFFICULTIES } from \"../../lib/task-schema.js\";","truncated":false,"loaded":[]},"time":{"start":1773439952809,"end":1773439952811}}}}
