{"type":"tool_use","timestamp":1773440696995,"sessionID":"ses_316b2af3bffeauPmrTvOGPlpJe","part":{"id":"prt_ce94d827b001Ec6ZpF4OiVIP4N","sessionID":"ses_316b2af3bffeauPmrTvOGPlpJe","messageID":"msg_ce94d742d001MT3nYiQv20zUh7","type":"tool","callID":"toolu_vrtx_01DY6AQC861htA1z2ChfWQWD","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/toon-output/src/lib/output.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/toon-output/src/lib/output.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * output.ts — Shared output helpers for agent-ready CLI.\n3:  *\n4:  * Provides a centralized way for commands to emit structured data that\n5:  * renders as human-readable text on TTY, as JSON when --output json\n6:  * is specified, or as compact TOON notation when --output toon is used.\n7:  *\n8:  * Usage in commands:\n9:  *   import { output, OutputFormat } from \"../lib/output.js\";\n10:  *\n11:  *   // At the end of a command:\n12:  *   output(format, data, textRenderer, toonRenderer);  // emits JSON, text, or TOON\n13:  *   outputError(format, message);                      // emits error in the right format\n14:  */\n15: \n16: import { renderGeneric } from \"./toon.js\";\n17: \n18: // ---------------------------------------------------------------------------\n19: // Types\n20: // ---------------------------------------------------------------------------\n21: \n22: export type OutputFormat = \"text\" | \"json\" | \"toon\";\n23: \n24: // ---------------------------------------------------------------------------\n25: // Helpers\n26: // ---------------------------------------------------------------------------\n27: \n28: /**\n29:  * Determine the output format. Priority:\n30:  *   1. Explicit --output flag value\n31:  *   2. WOMBO_OUTPUT env var (for agent pipelines)\n32:  *   3. Default to \"text\"\n33:  *\n34:  * Note: We intentionally do NOT auto-detect based on TTY. Many legitimate\n35:  * use cases (bun dev, piped to less/grep, CI) have non-TTY stdout but still\n36:  * want human output. Agents should explicitly pass --output json or set\n37:  * WOMBO_OUTPUT=json.\n38:  */\n39: export function resolveOutputFormat(explicit?: string): OutputFormat {\n40:   if (explicit === \"json\") return \"json\";\n41:   if (explicit === \"toon\") return \"toon\";\n42:   if (explicit === \"text\") return \"text\";\n43:   // Check env var for agent pipelines\n44:   const env = process.env.WOMBO_OUTPUT;\n45:   if (env === \"json\") return \"json\";\n46:   if (env === \"toon\") return \"toon\";\n47:   return \"text\";\n48: }\n49: \n50: /**\n51:  * Emit structured data.\n52:  *   - JSON mode: outputs a single JSON line to stdout\n53:  *   - TOON mode: calls toonRenderer if provided, otherwise uses generic TOON formatter\n54:  *   - Text mode: calls textRenderer\n55:  */\n56: export function output(\n57:   format: OutputFormat,\n58:   data: unknown,\n59:   textRenderer: () => void,\n60:   toonRenderer?: () => void\n61: ): void {\n62:   if (format === \"json\") {\n63:     console.log(JSON.stringify(data));\n64:   } else if (format === \"toon\") {\n65:     if (toonRenderer) {\n66:       toonRenderer();\n67:     } else {\n68:       // Generic fallback: convert structured data to TOON\n69:       console.log(renderGeneric(data));\n70:     }\n71:   } else {\n72:     textRenderer();\n73:   }\n74: }\n75: \n76: /**\n77:  * Emit an error. In JSON mode, outputs {\"error\": message} to stderr.\n78:  * In TOON mode, outputs \"#ERROR message\" to stderr.\n79:  * In text mode, outputs the message to stderr normally.\n80:  */\n81: export function outputError(format: OutputFormat, message: string, exitCode: number = 1): never {\n82:   if (format === \"json\") {\n83:     console.error(JSON.stringify({ error: message }));\n84:   } else if (format === \"toon\") {\n85:     console.error(`#ERROR ${message}`);\n86:   } else {\n87:     console.error(message);\n88:   }\n89:   process.exit(exitCode);\n90: }\n91: \n92: /**\n93:  * Emit a success/info message. In JSON mode, outputs {\"message\": msg, ...extra}.\n94:  * In TOON mode, outputs \"#MSG message\" to stdout.\n95:  * In text mode, outputs the message to stdout normally.\n96:  */\n97: export function outputMessage(\n98:   format: OutputFormat,\n99:   message: string,\n100:   extra?: Record<string, unknown>\n101: ): void {\n102:   if (format === \"json\") {\n103:     console.log(JSON.stringify({ message, ...extra }));\n104:   } else if (format === \"toon\") {\n105:     console.log(`#MSG ${message}`);\n106:   } else {\n107:     console.log(message);\n108:   }\n109: }\n110: \n111: // ---------------------------------------------------------------------------\n112: // Field filtering for compact output (--fields)\n113: // ---------------------------------------------------------------------------\n114: \n115: /**\n116:  * Filter an object to only include the specified fields.\n117:  * If fields is undefined/empty, returns the object unchanged.\n118:  */\n119: export function filterFields<T extends Record<string, unknown>>(\n120:   obj: T,\n121:   fields?: string[]\n122: ): Partial<T> {\n123:   if (!fields || fields.length === 0) return obj;\n124:   const result: Partial<T> = {};\n125:   for (const field of fields) {\n126:     if (field in obj) {\n127:       (result as any)[field] = (obj as any)[field];\n128:     }\n129:   }\n130:   return result;\n131: }\n132: \n133: /**\n134:  * Filter an array of objects to only include specified fields per object.\n135:  * If fields is undefined/empty, returns the array unchanged.\n136:  */\n137: export function filterFieldsArray<T extends Record<string, unknown>>(\n138:   arr: T[],\n139:   fields?: string[]\n140: ): Partial<T>[] {\n141:   if (!fields || fields.length === 0) return arr;\n142:   return arr.map((obj) => filterFields(obj, fields));\n143: }\n144: \n145: /**\n146:  * Render a compact text table from an array of objects with selected fields.\n147:  * Used for text-mode --fields output.\n148:  */\n149: export function renderCompactTable(\n150:   items: Record<string, unknown>[],\n151:   fields: string[]\n152: ): void {\n153:   if (items.length === 0) return;\n154: \n155:   // Calculate column widths\n156:   const widths: Record<string, number> = {};\n157:   for (const field of fields) {\n158:     widths[field] = field.length;\n159:     for (const item of items) {\n160:       const val = String(item[field] ?? \"\");\n161:       widths[field] = Math.max(widths[field], val.length);\n162:     }\n163:   }\n164: \n165:   // Header\n166:   const header = fields.map((f) => f.padEnd(widths[f])).join(\"  \");\n167:   console.log(header);\n168:   console.log(fields.map((f) => \"─\".repeat(widths[f])).join(\"  \"));\n169: \n170:   // Rows\n171:   for (const item of items) {\n172:     const row = fields.map((f) => String(item[f] ?? \"\").padEnd(widths[f])).join(\"  \");\n173:     console.log(row);\n174:   }\n175: }\n\n(End of file - total 175 lines)\n</content>","title":"src/lib/output.ts","metadata":{"preview":"/**\n * output.ts — Shared output helpers for agent-ready CLI.\n *\n * Provides a centralized way for commands to emit structured data that\n * renders as human-readable text on TTY, as JSON when --output json\n * is specified, or as compact TOON notation when --output toon is used.\n *\n * Usage in commands:\n *   import { output, OutputFormat } from \"../lib/output.js\";\n *\n *   // At the end of a command:\n *   output(format, data, textRenderer, toonRenderer);  // emits JSON, text, or TOON\n *   outputError(format, message);                      // emits error in the right format\n */\n\nimport { renderGeneric } from \"./toon.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------","truncated":false,"loaded":[]},"time":{"start":1773440696992,"end":1773440696994}}}}
{"type":"tool_use","timestamp":1773440697577,"sessionID":"ses_316b2af3bffeauPmrTvOGPlpJe","part":{"id":"prt_ce94d82a1001l4yCdbbxPJgrDm","sessionID":"ses_316b2af3bffeauPmrTvOGPlpJe","messageID":"msg_ce94d742d001MT3nYiQv20zUh7","type":"tool","callID":"toolu_vrtx_01J4N7c7afvddnfBBctRPudn","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/toon-output/src/lib/toon.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/toon-output/src/lib/toon.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * toon.ts -- Token-Optimized Output Notation (TOON) formatter module.\n3:  *\n4:  * Converts structured command results into compact, pipe-delimited TOON\n5:  * notation. Reduces token count by 60%+ vs JSON for equivalent data.\n6:  *\n7:  * Format:\n8:  *   - Delimiter: pipe (|)\n9:  *   - First line: #FIELDS header listing field names\n10:  *   - One record per line, positional fields\n11:  *   - Status codes: BL/PL/IP/BK/IR/DN/CN\n12:  *   - Priority codes: C/H/M/L/W\n13:  *   - Difficulty codes: T/E/M/H/V\n14:  *   - Duration: compact (30m, 2h, 1d4h)\n15:  *   - Boolean: 1/0\n16:  *   - Null/missing: empty field (||)\n17:  *   - Arrays: comma-separated within a field\n18:  */\n19: \n20: import type { Task, TaskStatus, Priority, Difficulty } from \"./tasks.js\";\n21: import type { AgentState, WaveState } from \"./state.js\";\n22: import type { AgentHistoryRecord, WaveHistoryRecord } from \"./history.js\";\n23: import {\n24:   TOON_STATUS_ENCODE,\n25:   TOON_PRIORITY_ENCODE,\n26:   TOON_DIFFICULTY_ENCODE,\n27:   encodeDuration,\n28:   encodeBool,\n29:   encodeNullable,\n30:   encodeArray,\n31: } from \"./toon-spec.js\";\n32: \n33: // ---------------------------------------------------------------------------\n34: // Generic Helpers\n35: // ---------------------------------------------------------------------------\n36: \n37: /**\n38:  * Join fields with pipe delimiter.\n39:  */\n40: function row(...fields: (string | number | null | undefined)[]): string {\n41:   return fields.map((f) => (f === null || f === undefined ? \"\" : String(f))).join(\"|\");\n42: }\n43: \n44: /**\n45:  * Emit a #FIELDS header line.\n46:  */\n47: function fieldsHeader(names: string[]): string {\n48:   return `#FIELDS ${names.join(\"|\")}`;\n49: }\n50: \n51: /**\n52:  * Encode a status code, falling back to raw value if unknown.\n53:  */\n54: function encodeStatus(status: TaskStatus | string): string {\n55:   return (TOON_STATUS_ENCODE as Record<string, string>)[status] ?? status;\n56: }\n57: \n58: /**\n59:  * Encode a priority code, falling back to raw value if unknown.\n60:  */\n61: function encodePriority(priority: Priority | string): string {\n62:   return (TOON_PRIORITY_ENCODE as Record<string, string>)[priority] ?? priority;\n63: }\n64: \n65: /**\n66:  * Encode a difficulty code, falling back to raw value if unknown.\n67:  */\n68: function encodeDifficulty(difficulty: Difficulty | string): string {\n69:   return (TOON_DIFFICULTY_ENCODE as Record<string, string>)[difficulty] ?? difficulty;\n70: }\n71: \n72: // ---------------------------------------------------------------------------\n73: // Tasks List Renderer\n74: // ---------------------------------------------------------------------------\n75: \n76: /**\n77:  * Render a task list in TOON format.\n78:  *\n79:  * Fields: id|status|priority|difficulty|effort|completion|deps_met|depends_on|title\n80:  *\n81:  * Example:\n82:  *   #FIELDS id|status|priority|difficulty|effort|completion|deps_met|depends_on|title\n83:  *   auth-flow|BL|H|E|2h|0|1||Add authentication flow\n84:  *   search-api|IP|C|M|4h|35|0|auth-flow|Implement search API\n85:  */\n86: export function renderTasksList(\n87:   tasks: Array<{\n88:     id: string;\n89:     title: string;\n90:     status: string;\n91:     priority: string;\n92:     difficulty: string;\n93:     effort: string;\n94:     completion: number;\n95:     depends_on: string[];\n96:   }>,\n97:   depsMetMap?: Map<string, boolean>\n98: ): string {\n99:   const header = fieldsHeader([\n100:     \"id\", \"status\", \"priority\", \"difficulty\", \"effort\",\n101:     \"completion\", \"deps_met\", \"depends_on\", \"title\",\n102:   ]);\n103: \n104:   const lines = [header];\n105: \n106:   for (const t of tasks) {\n107:     const depsMet = depsMetMap?.get(t.id) ?? true;\n108:     lines.push(row(\n109:       t.id,\n110:       encodeStatus(t.status),\n111:       encodePriority(t.priority),\n112:       encodeDifficulty(t.difficulty),\n113:       encodeDuration(t.effort),\n114:       t.completion,\n115:       encodeBool(depsMet),\n116:       encodeArray(t.depends_on),\n117:       t.title,\n118:     ));\n119:   }\n120: \n121:   return lines.join(\"\\n\");\n122: }\n123: \n124: // ---------------------------------------------------------------------------\n125: // Tasks Show Renderer\n126: // ---------------------------------------------------------------------------\n127: \n128: /**\n129:  * Render a single task detail in TOON key:value format.\n130:  *\n131:  * Uses abbreviated keys, one per line.\n132:  * Example:\n133:  *   id:auth-flow\n134:  *   st:BL\n135:  *   pr:H\n136:  *   df:E\n137:  *   ef:2h\n138:  *   cp:35\n139:  *   dm:1\n140:  *   dp:dep-a,dep-b\n141:  *   sa:2026-03-10T08:00:00Z\n142:  *   ea:\n143:  *   ti:Add authentication flow\n144:  *   ds:Description text here\n145:  *   cn:Must use TypeScript\n146:  *   fb:No external deps\n147:  *   rf:https://example.com\n148:  *   nt:Some note\n149:  *   sc:3\n150:  */\n151: export function renderTaskShow(\n152:   task: Task,\n153:   depsMet: boolean\n154: ): string {\n155:   const lines: string[] = [];\n156: \n157:   lines.push(`id:${task.id}`);\n158:   lines.push(`st:${encodeStatus(task.status)}`);\n159:   lines.push(`pr:${encodePriority(task.priority)}`);\n160:   lines.push(`df:${encodeDifficulty(task.difficulty)}`);\n161:   lines.push(`ef:${encodeDuration(task.effort)}`);\n162:   lines.push(`cp:${task.completion}`);\n163:   lines.push(`dm:${encodeBool(depsMet)}`);\n164:   lines.push(`dp:${encodeArray(task.depends_on)}`);\n165:   lines.push(`sa:${encodeNullable(task.started_at)}`);\n166:   lines.push(`ea:${encodeNullable(task.ended_at)}`);\n167:   lines.push(`ti:${task.title}`);\n168: \n169:   if (task.description) {\n170:     // Collapse multi-line descriptions to single line with \\n escape\n171:     lines.push(`ds:${task.description.replace(/\\n/g, \"\\\\n\")}`);\n172:   }\n173: \n174:   if (task.constraints.length > 0) {\n175:     lines.push(`cn:${encodeArray(task.constraints)}`);\n176:   }\n177: \n178:   if (task.forbidden.length > 0) {\n179:     lines.push(`fb:${encodeArray(task.forbidden)}`);\n180:   }\n181: \n182:   if (task.references.length > 0) {\n183:     lines.push(`rf:${encodeArray(task.references)}`);\n184:   }\n185: \n186:   if (task.notes.length > 0) {\n187:     lines.push(`nt:${encodeArray(task.notes)}`);\n188:   }\n189: \n190:   if (task.subtasks.length > 0) {\n191:     lines.push(`sc:${task.subtasks.length}`);\n192:     // Render subtasks as compact lines\n193:     for (const st of task.subtasks) {\n194:       lines.push(`  ${st.id}|${encodeStatus(st.status)}|${encodePriority(st.priority)}|${encodeDifficulty(st.difficulty)}|${encodeDuration(st.effort)}|${st.completion}|${st.title}`);\n195:     }\n196:   }\n197: \n198:   return lines.join(\"\\n\");\n199: }\n200: \n201: // ---------------------------------------------------------------------------\n202: // Status Renderer\n203: // ---------------------------------------------------------------------------\n204: \n205: /**\n206:  * Render wave status in TOON format.\n207:  *\n208:  * Fields: feature_id|agent_status|exit_code|retries|started_at\n209:  *\n210:  * Also emits a summary header line:\n211:  *   #WAVE wave_id|agent_count|active|completed|failed\n212:  */\n213: export function renderStatus(state: WaveState): string {\n214:   const lines: string[] = [];\n215: \n216:   // Summary line\n217:   const counts: Record<string, number> = {};\n218:   for (const a of state.agents) {\n219:     counts[a.status] = (counts[a.status] ?? 0) + 1;\n220:   }\n221: \n222:   const active = (counts[\"running\"] ?? 0) + (counts[\"installing\"] ?? 0) + (counts[\"resolving_conflict\"] ?? 0);\n223:   const completed = (counts[\"completed\"] ?? 0) + (counts[\"verified\"] ?? 0) + (counts[\"merged\"] ?? 0);\n224:   const failed = counts[\"failed\"] ?? 0;\n225: \n226:   lines.push(`#WAVE ${row(\n227:     state.wave_id,\n228:     state.agents.length,\n229:     active,\n230:     completed,\n231:     failed,\n232:   )}`);\n233: \n234:   // Agent detail lines\n235:   lines.push(fieldsHeader([\n236:     \"feature_id\", \"agent_status\", \"exit_code\", \"retries\", \"started_at\",\n237:   ]));\n238: \n239:   for (const a of state.agents) {\n240:     // Determine exit code: build_passed === true -> 0, false -> 1, null -> empty\n241:     const exitCode = a.build_passed === true ? \"0\" : a.build_passed === false ? \"1\" : \"\";\n242:     lines.push(row(\n243:       a.feature_id,\n244:       a.status,\n245:       exitCode,\n246:       a.retries,\n247:       encodeNullable(a.started_at),\n248:     ));\n249:   }\n250: \n251:   return lines.join(\"\\n\");\n252: }\n253: \n254: // ---------------------------------------------------------------------------\n255: // Verify Renderer\n256: // ---------------------------------------------------------------------------\n257: \n258: /**\n259:  * Render verification results in TOON format.\n260:  *\n261:  * Fields: feature_id|pass_fail|duration\n262:  */\n263: export function renderVerify(\n264:   results: Array<{ feature_id: string; passed: boolean; durationMs: number }>\n265: ): string {\n266:   const lines: string[] = [];\n267: \n268:   lines.push(fieldsHeader([\"feature_id\", \"pass_fail\", \"duration\"]));\n269: \n270:   for (const r of results) {\n271:     const durationSec = Math.round(r.durationMs / 1000);\n272:     const duration = durationSec >= 60\n273:       ? `${Math.floor(durationSec / 60)}m${durationSec % 60}s`\n274:       : `${durationSec}s`;\n275:     lines.push(row(\n276:       r.feature_id,\n277:       r.passed ? \"pass\" : \"fail\",\n278:       duration,\n279:     ));\n280:   }\n281: \n282:   return lines.join(\"\\n\");\n283: }\n284: \n285: // ---------------------------------------------------------------------------\n286: // History Renderer\n287: // ---------------------------------------------------------------------------\n288: \n289: /**\n290:  * Render history list in TOON format.\n291:  *\n292:  * Fields: wave_id|started_at|ended_at|total_agents|succeeded|failed\n293:  */\n294: export function renderHistoryList(records: WaveHistoryRecord[]): string {\n295:   const lines: string[] = [];\n296: \n297:   lines.push(fieldsHeader([\n298:     \"wave_id\", \"started_at\", \"ended_at\", \"total_agents\", \"succeeded\", \"failed\",\n299:   ]));\n300: \n301:   for (const rec of records) {\n302:     lines.push(row(\n303:       rec.wave_id,\n304:       rec.started_at,\n305:       rec.exported_at,\n306:       rec.summary.total,\n307:       rec.summary.succeeded,\n308:       rec.summary.failed,\n309:     ));\n310:   }\n311: \n312:   return lines.join(\"\\n\");\n313: }\n314: \n315: /**\n316:  * Render a single history record detail in TOON format.\n317:  *\n318:  * Emits a summary header then per-agent lines.\n319:  */\n320: export function renderHistoryDetail(rec: WaveHistoryRecord): string {\n321:   const lines: string[] = [];\n322: \n323:   // Summary\n324:   lines.push(`#WAVE ${row(\n325:     rec.wave_id,\n326:     rec.summary.total,\n327:     rec.summary.succeeded,\n328:     rec.summary.failed,\n329:     rec.summary.merged,\n330:   )}`);\n331: \n332:   // Agent details\n333:   lines.push(fieldsHeader([\n334:     \"feature_id\", \"status\", \"retries\", \"duration_ms\", \"build_passed\", \"error\",\n335:   ]));\n336: \n337:   for (const a of rec.agents) {\n338:     lines.push(row(\n339:       a.feature_id,\n340:       a.status,\n341:       a.retries,\n342:       a.duration_ms ?? \"\",\n343:       a.build_passed === null ? \"\" : encodeBool(a.build_passed),\n344:       encodeNullable(a.error?.split(\"\\n\")[0]?.slice(0, 60) ?? null),\n345:     ));\n346:   }\n347: \n348:   return lines.join(\"\\n\");\n349: }\n350: \n351: // ---------------------------------------------------------------------------\n352: // Tasks Check Renderer\n353: // ---------------------------------------------------------------------------\n354: \n355: /**\n356:  * Render task check results in TOON format.\n357:  *\n358:  * Fields: level|message\n359:  */\n360: export function renderTasksCheck(result: {\n361:   ok: boolean;\n362:   issues: Array<{ level: string; message: string }>;\n363:   items_checked: number;\n364: }): string {\n365:   const lines: string[] = [];\n366: \n367:   lines.push(`#CHECK ${row(\n368:     encodeBool(result.ok),\n369:     result.items_checked,\n370:     result.issues.length,\n371:   )}`);\n372: \n373:   if (result.issues.length > 0) {\n374:     lines.push(fieldsHeader([\"level\", \"message\"]));\n375:     for (const issue of result.issues) {\n376:       lines.push(row(\n377:         issue.level === \"error\" ? \"E\" : \"W\",\n378:         issue.message,\n379:       ));\n380:     }\n381:   }\n382: \n383:   return lines.join(\"\\n\");\n384: }\n385: \n386: // ---------------------------------------------------------------------------\n387: // Abort Renderer\n388: // ---------------------------------------------------------------------------\n389: \n390: /**\n391:  * Render abort result in TOON format.\n392:  *\n393:  * Uses key:value pairs for the single-record result.\n394:  */\n395: export function renderAbort(result: {\n396:   feature_id: string;\n397:   previous_status: string;\n398:   new_status: string;\n399:   mux_killed: boolean;\n400:   process_killed: boolean;\n401:   requeued: boolean;\n402: }): string {\n403:   const lines: string[] = [];\n404:   lines.push(`fid:${result.feature_id}`);\n405:   lines.push(`prev:${result.previous_status}`);\n406:   lines.push(`new:${result.new_status}`);\n407:   lines.push(`mux:${encodeBool(result.mux_killed)}`);\n408:   lines.push(`proc:${encodeBool(result.process_killed)}`);\n409:   lines.push(`rq:${encodeBool(result.requeued)}`);\n410:   return lines.join(\"\\n\");\n411: }\n412: \n413: // ---------------------------------------------------------------------------\n414: // Cleanup Renderer\n415: // ---------------------------------------------------------------------------\n416: \n417: /**\n418:  * Render cleanup result in TOON format.\n419:  *\n420:  * Uses key:value pairs for summary data.\n421:  */\n422: export function renderCleanup(result: {\n423:   mux_sessions_killed?: number;\n424:   worktrees_removed?: number;\n425:   state_removed?: boolean;\n426:   logs_removed?: boolean;\n427:   remaining_branches?: string[];\n428:   history_preserved?: boolean;\n429:   // dry-run fields\n430:   dry_run?: boolean;\n431:   mux_sessions?: string[];\n432:   mux_sessions_count?: number;\n433:   worktrees?: string[];\n434:   worktrees_count?: number;\n435:   files_to_remove?: string[];\n436: }): string {\n437:   const lines: string[] = [];\n438: \n439:   if (result.dry_run) {\n440:     lines.push(`dry:1`);\n441:     lines.push(`mux:${result.mux_sessions_count ?? 0}`);\n442:     lines.push(`wt:${result.worktrees_count ?? 0}`);\n443:     if (result.mux_sessions && result.mux_sessions.length > 0) {\n444:       lines.push(`mux_list:${encodeArray(result.mux_sessions)}`);\n445:     }\n446:     if (result.worktrees && result.worktrees.length > 0) {\n447:       lines.push(`wt_list:${encodeArray(result.worktrees)}`);\n448:     }\n449:     if (result.files_to_remove && result.files_to_remove.length > 0) {\n450:       lines.push(`files:${encodeArray(result.files_to_remove)}`);\n451:     }\n452:   } else {\n453:     lines.push(`mux:${result.mux_sessions_killed ?? 0}`);\n454:     lines.push(`wt:${result.worktrees_removed ?? 0}`);\n455:     lines.push(`st:${encodeBool(result.state_removed ?? false)}`);\n456:     lines.push(`logs:${encodeBool(result.logs_removed ?? false)}`);\n457:     if (result.remaining_branches && result.remaining_branches.length > 0) {\n458:       lines.push(`branches:${encodeArray(result.remaining_branches)}`);\n459:     }\n460:     lines.push(`hist:${encodeBool(result.history_preserved ?? false)}`);\n461:   }\n462: \n463:   return lines.join(\"\\n\");\n464: }\n465: \n466: // ---------------------------------------------------------------------------\n467: // Merge Renderer\n468: // ---------------------------------------------------------------------------\n469: \n470: /**\n471:  * Render merge results in TOON format.\n472:  *\n473:  * Fields: feature_id|branch|status|error\n474:  */\n475: export function renderMerge(result: {\n476:   wave_id: string;\n477:   base_branch: string;\n478:   merged?: number;\n479:   failed?: number;\n480:   agents: Array<{ feature_id: string; branch: string; status?: string; error?: string | null }>;\n481:   // dry-run fields\n482:   dry_run?: boolean;\n483:   count?: number;\n484:   auto_push?: boolean;\n485: }): string {\n486:   const lines: string[] = [];\n487: \n488:   if (result.dry_run) {\n489:     lines.push(`#DRY wave:${result.wave_id}|base:${result.base_branch}|count:${result.count ?? 0}|push:${encodeBool(result.auto_push ?? false)}`);\n490:     lines.push(fieldsHeader([\"feature_id\", \"branch\"]));\n491:     for (const a of result.agents) {\n492:       lines.push(row(a.feature_id, a.branch));\n493:     }\n494:   } else {\n495:     lines.push(`#MERGE wave:${result.wave_id}|base:${result.base_branch}|merged:${result.merged}|failed:${result.failed}`);\n496:     lines.push(fieldsHeader([\"feature_id\", \"branch\", \"status\", \"error\"]));\n497:     for (const a of result.agents) {\n498:       lines.push(row(a.feature_id, a.branch, a.status, encodeNullable(a.error)));\n499:     }\n500:   }\n501: \n502:   return lines.join(\"\\n\");\n503: }\n504: \n505: // ---------------------------------------------------------------------------\n506: // Retry Renderer\n507: // ---------------------------------------------------------------------------\n508: \n509: /**\n510:  * Render retry result in TOON format.\n511:  *\n512:  * Uses key:value pairs for the single-record result.\n513:  */\n514: export function renderRetry(result: {\n515:   feature_id: string;\n516:   mode?: string;\n517:   status?: string;\n518:   mux_session?: string;\n519:   pid?: number | null;\n520:   // dry-run fields\n521:   dry_run?: boolean;\n522:   current_status?: string;\n523:   retries_so_far?: number;\n524:   worktree?: string;\n525:   model?: string | null;\n526: }): string {\n527:   const lines: string[] = [];\n528: \n529:   if (result.dry_run) {\n530:     lines.push(`dry:1`);\n531:     lines.push(`fid:${result.feature_id}`);\n532:     lines.push(`st:${result.current_status ?? \"\"}`);\n533:     lines.push(`retries:${result.retries_so_far ?? 0}`);\n534:     lines.push(`wt:${result.worktree ?? \"\"}`);\n535:     lines.push(`mode:${result.mode ?? \"\"}`);\n536:     lines.push(`model:${encodeNullable(result.model ?? null)}`);\n537:   } else {\n538:     lines.push(`fid:${result.feature_id}`);\n539:     lines.push(`mode:${result.mode ?? \"\"}`);\n540:     lines.push(`st:${result.status ?? \"\"}`);\n541:     if (result.mux_session) {\n542:       lines.push(`mux:${result.mux_session}`);\n543:     }\n544:     if (result.pid !== undefined && result.pid !== null) {\n545:       lines.push(`pid:${result.pid}`);\n546:     }\n547:   }\n548: \n549:   return lines.join(\"\\n\");\n550: }\n551: \n552: // ---------------------------------------------------------------------------\n553: // Logs Renderer\n554: // ---------------------------------------------------------------------------\n555: \n556: /**\n557:  * Render logs in TOON format.\n558:  *\n559:  * Emits a header line then one line per log entry.\n560:  */\n561: export function renderLogs(result: {\n562:   feature_id: string;\n563:   log_file: string;\n564:   line_count: number;\n565:   first_line: number | null;\n566:   last_line: number | null;\n567:   lines: string[];\n568: }): string {\n569:   const output: string[] = [];\n570:   output.push(`#LOGS fid:${result.feature_id}|count:${result.line_count}|first:${result.first_line ?? \"\"}|last:${result.last_line ?? \"\"}`);\n571:   for (const line of result.lines) {\n572:     output.push(line);\n573:   }\n574:   return output.join(\"\\n\");\n575: }\n576: \n577: // ---------------------------------------------------------------------------\n578: // Launch Dry-Run Renderer\n579: // ---------------------------------------------------------------------------\n580: \n581: /**\n582:  * Render launch dry-run result in TOON format.\n583:  *\n584:  * Fields: id|priority|difficulty|effort\n585:  */\n586: export function renderLaunchDryRun(result: {\n587:   dry_run: boolean;\n588:   base_branch: string;\n589:   max_concurrent: number;\n590:   model: string | null;\n591:   interactive: boolean;\n592:   selected: Array<{ id: string; title: string; priority: string; difficulty: string; effort: string }>;\n593: }): string {\n594:   const lines: string[] = [];\n595: \n596:   lines.push(`#LAUNCH dry:1|base:${result.base_branch}|max:${result.max_concurrent}|model:${encodeNullable(result.model)}|interactive:${encodeBool(result.interactive)}`);\n597:   lines.push(fieldsHeader([\"id\", \"priority\", \"difficulty\", \"effort\", \"title\"]));\n598: \n599:   for (const f of result.selected) {\n600:     lines.push(row(\n601:       f.id,\n602:       encodePriority(f.priority),\n603:       encodeDifficulty(f.difficulty),\n604:       encodeDuration(f.effort),\n605:       f.title,\n606:     ));\n607:   }\n608: \n609:   return lines.join(\"\\n\");\n610: }\n611: \n612: // ---------------------------------------------------------------------------\n613: // Graph Renderer\n614: // ---------------------------------------------------------------------------\n615: \n616: /**\n617:  * Render tasks graph in TOON format.\n618:  *\n619:  * Emits mermaid source (if any), node/edge counts, and orphans.\n620:  */\n621: export function renderGraph(result: {\n622:   mermaid: string | null;\n623:   nodes: number;\n624:   edges: number;\n625:   orphan_count?: number;\n626:   orphans?: Array<{ id: string; title: string; status: string }>;\n627: }): string {\n628:   const lines: string[] = [];\n629: \n630:   lines.push(`#GRAPH nodes:${result.nodes}|edges:${result.edges}|orphans:${result.orphan_count ?? 0}`);\n631: \n632:   if (result.mermaid) {\n633:     lines.push(`#MERMAID`);\n634:     lines.push(result.mermaid);\n635:     lines.push(`#END`);\n636:   }\n637: \n638:   if (result.orphans && result.orphans.length > 0) {\n639:     lines.push(fieldsHeader([\"id\", \"status\", \"title\"]));\n640:     for (const o of result.orphans) {\n641:       lines.push(row(o.id, encodeStatus(o.status), o.title));\n642:     }\n643:   }\n644: \n645:   return lines.join(\"\\n\");\n646: }\n647: \n648: // ---------------------------------------------------------------------------\n649: // Verify Results Renderer (multi-agent)\n650: // ---------------------------------------------------------------------------\n651: \n652: /**\n653:  * Render verify command results in TOON format.\n654:  *\n655:  * Fields: feature_id|branch|status|build_passed|error\n656:  */\n657: export function renderVerifyResults(result: {\n658:   wave_id: string;\n659:   verified: number;\n660:   failed: number;\n661:   agents: Array<{ feature_id: string; branch: string; status: string; build_passed: boolean | null; error?: string | null }>;\n662: }): string {\n663:   const lines: string[] = [];\n664: \n665:   lines.push(`#VERIFY wave:${result.wave_id}|verified:${result.verified}|failed:${result.failed}`);\n666:   lines.push(fieldsHeader([\"feature_id\", \"branch\", \"status\", \"build_passed\", \"error\"]));\n667: \n668:   for (const a of result.agents) {\n669:     lines.push(row(\n670:       a.feature_id,\n671:       a.branch,\n672:       a.status,\n673:       a.build_passed === null ? \"\" : encodeBool(a.build_passed),\n674:       encodeNullable(a.error),\n675:     ));\n676:   }\n677: \n678:   return lines.join(\"\\n\");\n679: }\n680: \n681: // ---------------------------------------------------------------------------\n682: // Generic Fallback Renderer\n683: // ---------------------------------------------------------------------------\n684: \n685: /**\n686:  * Generic TOON renderer for data that doesn't have a specific formatter.\n687:  * Renders objects as key:value pairs, arrays as pipe-delimited rows.\n688:  */\n689: export function renderGeneric(data: unknown): string {\n690:   if (data === null || data === undefined) return \"\";\n691: \n692:   if (Array.isArray(data)) {\n693:     if (data.length === 0) return \"\";\n694:     // If array of objects, use first item's keys as fields\n695:     if (typeof data[0] === \"object\" && data[0] !== null) {\n696:       const keys = Object.keys(data[0] as Record<string, unknown>);\n697:       const lines = [fieldsHeader(keys)];\n698:       for (const item of data) {\n699:         const obj = item as Record<string, unknown>;\n700:         lines.push(row(...keys.map((k) => {\n701:           const v = obj[k];\n702:           if (Array.isArray(v)) return encodeArray(v.map(String));\n703:           if (typeof v === \"boolean\") return encodeBool(v);\n704:           if (v === null || v === undefined) return \"\";\n705:           return String(v);\n706:         })));\n707:       }\n708:       return lines.join(\"\\n\");\n709:     }\n710:     // Array of primitives\n711:     return data.map(String).join(\"\\n\");\n712:   }\n713: \n714:   if (typeof data === \"object\") {\n715:     const obj = data as Record<string, unknown>;\n716:     const lines: string[] = [];\n717:     for (const [key, val] of Object.entries(obj)) {\n718:       if (val === null || val === undefined) {\n719:         lines.push(`${key}:`);\n720:       } else if (Array.isArray(val)) {\n721:         lines.push(`${key}:${encodeArray(val.map(String))}`);\n722:       } else if (typeof val === \"boolean\") {\n723:         lines.push(`${key}:${encodeBool(val)}`);\n724:       } else if (typeof val === \"object\") {\n725:         // Nested object — flatten to key.subkey:value\n726:         for (const [sk, sv] of Object.entries(val as Record<string, unknown>)) {\n727:           lines.push(`${key}.${sk}:${sv === null || sv === undefined ? \"\" : String(sv)}`);\n728:         }\n729:       } else {\n730:         lines.push(`${key}:${String(val)}`);\n731:       }\n732:     }\n733:     return lines.join(\"\\n\");\n734:   }\n735: \n736:   return String(data);\n737: }\n\n(End of file - total 737 lines)\n</content>","title":"src/lib/toon.ts","metadata":{"preview":"/**\n * toon.ts -- Token-Optimized Output Notation (TOON) formatter module.\n *\n * Converts structured command results into compact, pipe-delimited TOON\n * notation. Reduces token count by 60%+ vs JSON for equivalent data.\n *\n * Format:\n *   - Delimiter: pipe (|)\n *   - First line: #FIELDS header listing field names\n *   - One record per line, positional fields\n *   - Status codes: BL/PL/IP/BK/IR/DN/CN\n *   - Priority codes: C/H/M/L/W\n *   - Difficulty codes: T/E/M/H/V\n *   - Duration: compact (30m, 2h, 1d4h)\n *   - Boolean: 1/0\n *   - Null/missing: empty field (||)\n *   - Arrays: comma-separated within a field\n */\n\nimport type { Task, TaskStatus, Priority, Difficulty } from \"./tasks.js\";","truncated":false,"loaded":[]},"time":{"start":1773440697572,"end":1773440697575}}}}
