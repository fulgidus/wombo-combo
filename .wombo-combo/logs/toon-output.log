if (!opts.featureId || !opts.newStatus) {\n42:     outputError(fmt, `Usage: woco tasks set-status <task-id> <new-status>\\nValid statuses: ${VALID_STATUSES.join(\", \")}`);\n43:     return;\n44:   }\n45: \n46:   // Validate status\n47:   if (!(VALID_STATUSES as readonly string[]).includes(opts.newStatus)) {\n48:     outputError(fmt, `Invalid status: \"${opts.newStatus}\"\\nValid statuses: ${VALID_STATUSES.join(\", \")}`);\n49:     return;\n50:   }\n51: \n52:   const data = loadFeatures(projectRoot, config);\n53:   const feature = findFeatureById(data, opts.featureId);\n54: \n55:   if (!feature) {\n56:     outputError(fmt, `Task \"${opts.featureId}\" not found.`);\n57:     return;\n58:   }\n59: \n60:   const oldStatus = feature.status;\n61:   const newStatus = opts.newStatus as FeatureStatus;\n62: \n63:   if (oldStatus === newStatus) {\n64:     outputMessage(fmt, `Task \"${opts.featureId}\" is already in status \"${newStatus}\".`, {\n65:       id: opts.featureId,\n66:       status: newStatus,\n67:       changed: false,\n68:     });\n69:     return;\n70:   }\n71: \n72:   // Dry-run: show what would change without writing\n73:   if (opts.dryRun) {\n74:     outputMessage(fmt, `[dry-run] Would change \"${opts.featureId}\": ${oldStatus} → ${newStatus}`, {\n75:       dry_run: true,\n76:       id: opts.featureId,\n77:       old_status: oldStatus,\n78:       new_status: newStatus,\n79:       changed: false,\n80:     });\n81:     return;\n82:   }\n83: \n84:   // Apply status change\n85:   feature.status = newStatus;\n86: \n87:   // Set timestamps\n88:   if (newStatus === \"in_progress\" && !feature.started_at) {\n89:     feature.started_at = new Date().toISOString();\n90:   }\n91:   if (newStatus === \"done\" || newStatus === \"cancelled\") {\n92:     feature.ended_at = new Date().toISOString();\n93:     if (newStatus === \"done\") {\n94:       feature.completion = 100;\n95:     }\n96:   }\n97: \n98:   saveFeatures(projectRoot, config, data);\n99: \n100:   outputMessage(fmt, `Task \"${opts.featureId}\": ${oldStatus} → ${newStatus}`, {\n101:     id: opts.featureId,\n102:     old_status: oldStatus,\n103:     new_status: newStatus,\n104:     changed: true,\n105:   });\n106: }\n\n(End of file - total 106 lines)\n</content>","title":"src/commands/tasks/set-status.ts","metadata":{"preview":"/**\n * tasks/set-status.ts — Change a task's status.\n *\n * Usage:\n *   woco tasks set-status <task-id> <new-status>\n *\n * Valid statuses: backlog, planned, in_progress, blocked, in_review, done, cancelled\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  saveFeatures,\n  findFeatureById,\n  type FeatureStatus,\n} from \"../../lib/tasks.js\";\nimport { VALID_STATUSES } from \"../../lib/task-schema.js\";\nimport { outputError, outputMessage, type OutputFormat } from \"../../lib/output.js\";\n\n// ---------------------------------------------------------------------------","truncated":false,"loaded":[]},"time":{"start":1773439944687,"end":1773439944690}}}}
{"type":"tool_use","timestamp":1773439945296,"sessionID":"ses_316be8edcffeznA8v4atF4wsHM","part":{"id":"prt_ce94207f0001kYZUQ6uvrpEnWl","sessionID":"ses_316be8edcffeznA8v4atF4wsHM","messageID":"msg_ce941f298001bP2q7eQsTQcrp9","type":"tool","callID":"toolu_vrtx_016q6nPwkAC1fVSbbSb8kCUL","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/toon-output/src/commands/tasks/archive.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/toon-output/src/commands/tasks/archive.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tasks/archive.ts — Move done/cancelled tasks to the archive section.\n3:  *\n4:  * Usage:\n5:  *   woco tasks archive              # archive all done + cancelled\n6:  *   woco tasks archive <task-id>    # archive a specific task\n7:  *   woco tasks archive --dry-run    # show what would be archived\n8:  */\n9: \n10: import type { WomboConfig } from \"../../config.js\";\n11: import {\n12:   loadFeatures,\n13:   saveFeatures,\n14:   type Feature,\n15: } from \"../../lib/tasks.js\";\n16: import { outputError, outputMessage, type OutputFormat } from \"../../lib/output.js\";\n17: \n18: // ---------------------------------------------------------------------------\n19: // Types\n20: // ---------------------------------------------------------------------------\n21: \n22: export interface TasksArchiveOptions {\n23:   projectRoot: string;\n24:   config: WomboConfig;\n25:   featureId?: string;\n26:   dryRun?: boolean;\n27:   outputFmt?: OutputFormat;\n28: }\n29: \n30: // ---------------------------------------------------------------------------\n31: // Command\n32: // ---------------------------------------------------------------------------\n33: \n34: export async function cmdTasksArchive(opts: TasksArchiveOptions): Promise<void> {\n35:   const fmt = opts.outputFmt ?? \"text\";\n36: \n37:   try {\n38:     const { projectRoot, config } = opts;\n39:     const data = loadFeatures(projectRoot, config);\n40: \n41:     // Ensure archive array exists\n42:     if (!data.archive) {\n43:       data.archive = [];\n44:     }\n45: \n46:     let toArchive: Feature[];\n47: \n48:     if (opts.featureId) {\n49:       // Archive a specific feature\n50:       const idx = data.tasks.findIndex((f: Feature) => f.id === opts.featureId);\n51:       if (idx === -1) {\n52:         // Check if already in archive\n53:         if (data.archive.find((f) => f.id === opts.featureId)) {\n54:           outputMessage(fmt, `Task \"${opts.featureId}\" is already in the archive.`, {\n55:             already_archived: true,\n56:             id: opts.featureId,\n57:           });\n58:           return;\n59:         }\n60:         outputError(fmt, `Task \"${opts.featureId}\" not found.`);\n61:         return;\n62:       }\n63:       toArchive = [data.tasks[idx]];\n64:     } else {\n65:       // Archive all done + cancelled features\n66:       toArchive = data.tasks.filter(\n67:         (f: Feature) => f.status === \"done\" || f.status === \"cancelled\"\n68:       );\n69:     }\n70: \n71:     if (toArchive.length === 0) {\n72:       outputMessage(fmt, \"No tasks to archive.\", { count: 0 });\n73:       return;\n74:     }\n75: \n76:     if (opts.dryRun) {\n77:       outputMessage(fmt, `Would archive ${toArchive.length} task(s)`, {\n78:         dry_run: true,\n79:         count: toArchive.length,\n80:         archived: toArchive.map((f) => ({ id: f.id, title: f.title, status: f.status })),\n81:       });\n82:       if (fmt === \"text\") {\n83:         console.log(\"\");\n84:         for (const f of toArchive) {\n85:           console.log(`  ${f.id} — ${f.title} (${f.status})`);\n86:         }\n87:       }\n88:       return;\n89:     }\n90: \n91:     // Move features from active to archive\n92:     const archiveIds = new Set(toArchive.map((f) => f.id));\n93:     data.tasks = data.tasks.filter((f: Feature) => !archiveIds.has(f.id));\n94:     data.archive.push(...toArchive);\n95: \n96:     saveFeatures(projectRoot, config, data);\n97: \n98:     outputMessage(fmt, `Archived ${toArchive.length} task(s)`, {\n99:       count: toArchive.length,\n100:       archived: toArchive.map((f) => ({ id: f.id, title: f.title, status: f.status })),\n101:     });\n102:     if (fmt === \"text\") {\n103:       for (const f of toArchive) {\n104:         console.log(`  ${f.id} — ${f.title} (${f.status})`);\n105:       }\n106:     }\n107:   } catch (err: unknown) {\n108:     const message = err instanceof Error ? err.message : String(err);\n109:     outputError(fmt, `Archive failed: ${message}`);\n110:   }\n111: }\n\n(End of file - total 111 lines)\n</content>","title":"src/commands/tasks/archive.ts","metadata":{"preview":"/**\n * tasks/archive.ts — Move done/cancelled tasks to the archive section.\n *\n * Usage:\n *   woco tasks archive              # archive all done + cancelled\n *   woco tasks archive <task-id>    # archive a specific task\n *   woco tasks archive --dry-run    # show what would be archived\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  saveFeatures,\n  type Feature,\n} from \"../../lib/tasks.js\";\nimport { outputError, outputMessage, type OutputFormat } from \"../../lib/output.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------","truncated":false,"loaded":[]},"time":{"start":1773439945293,"end":1773439945295}}}}
