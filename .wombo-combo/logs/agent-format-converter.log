   \"git_url\": \"https://api.github.com/repos/msitarzewski/agency-agents/git/trees/c6227e2cf925e9f437a04bc18c6d238efec451b8\",\n    \"download_url\": null,\n    \"type\": \"dir\",\n    \"_links\": {\n      \"self\": \"https://api.github.com/repos/msitarzewski/agency-agents/contents/integrations?ref=main\",\n      \"git\": \"https://api.github.com/repos/msitarzewski/agency-agents/git/trees/c6227e2cf925e9f437a04bc18c6d238efec451b8\",\n      \"html\": \"https://github.com/msitarzewski/agency-agents/tree/main/integrations\"\n    }\n  },\n  {\n    \"name\": \"marketing\",\n    \"path\": \"marketing\",\n    \"sha\": \"d579994392a8b1581663b60ad844398e4ca60388\",\n    \"size\": 0,\n    \"url\": \"https://api.github.com/repos/msitarzewski/agency-agents/contents/marketing?ref=main\",\n    \"html_url\": \"https://github.com/msitarzewski/agency-agents/tree/main/marketing\",\n    \"git_url\": \"https://api.github.com/repos/msitarzewski/agency-agents/git/trees/d579994392a8b1581663b60ad844398e4ca60388\",\n    \"download_url\": null,\n    \"type\": \"dir\",\n    \"_links\": {\n      \"self\": \"https://api.github.com/repos/msitarzewski/agency-agents/contents/marketing?ref=main\",\n      \"git\": \"https://api.github.com/repos/msitarzewski/agency-agents/git/trees/d579994392a8b1581663b60ad844398e4ca60388\",\n      \"html\": \"https://github.com/msitarzewski/agency-agents/tree/main/marketing\"\n    }\n  },\n  {\n    \"name\": \"paid-media\",\n    \"path\": \"paid-media\",\n    \"sha\": \"7c6635e2e60bf89d48c52905fe1b2487b341f5e4\",\n    \"size\": 0,\n    \"url\": \"https://api.github.com/repos/msitarzewski/agency-agents/contents/paid-media?ref=main\",\n    \"html_url\": \"https://github.com/msitarzewski/agency-agents/tree/main/paid-media\",\n    \"git_url\": \"https://api.github.com/repos/msitarzewski/agency-agents/git/trees/7c6635e2e60bf89d48c52905fe1b2487b341f5e4\",\n    \"download_url\": null,\n    \"type\": \"dir\",\n    \"_links\": {\n      \"self\": \"https://api.github.com/repos/msitarzewski/agency-agents/contents/paid-media?ref=main\",\n      \"git\": \"https://api.github.com/repos/msitarzewski/agency-agents/git/trees/7c6635e2e60bf89d48c52905fe1b2487b341f5e4\",\n      \"html\": \"https://github.com/msitarzewski/agency-agents/tree/main/paid-media\"\n    }\n  },\n  {\n    \"name\": \"product\",\n    \"path\": \"product\",\n    \"sha\": \"4b767ba71b07c63c83a2e33f27468e456d468cf2\",\n    \"size\": 0,\n    \"url\": \"https://api.github.com/repos/msitarzewski/agency-agents/contents/product?ref=main\",\n    \"html_url\": \"https://github.com/msitarzewski/agency-agents/tree/main/product\",\n    \"git_url\": \"https://api.github.com/repos/msitarzewski/agency-agents/git/trees/4b767ba71b07c63c83a2e33f27468e456d468cf2\",\n    \"download_url\": null,\n    \"type\": \"dir\",\n    \"_links\": {\n      \"self\": \"https://api.github.com/repos/msitarzewski/agency-agents/contents/product?ref=main\",\n      \"git\": \"https://api.github.com/repos/msitarzewski/agency-agents/git/trees/4b767ba71b07c63c83a2e33f27468e456d468cf2\",\n      \"html\": \"https://github.com/msitarzewski/agency-agents/tree/main/product\"\n    }\n  },\n  {\n    \"name\": \"project-management\",\n    \"path\": \"project-management\",\n    \"sha\": \"bcb704f30348cb5a9d6a7027d3708c014aacf411\",\n    \"size\": 0,\n    \"url\": \"https://api.github.com/repos/msitarzewski/agency-agents/contents/project-management?ref=main\",\n    \"html_url\": \"https://github.com/msitarzewski/agency-agents/tree/main/project-management\",\n    \"git_url\": \"https://api.github.com/repos/msitarzewski/agency-agents/git/trees/bcb704f30348cb5a9d6a7027d3708c014aacf411\",\n    \"download_url\": null,\n    \"type\": \"dir\",\n    \"_links\": {\n      \"self\": \"https://api.github.com/repos/msitarzewski/agency-agents/contents/project-management?ref=main\",\n      \"git\": \"https://api.github.com/repos/msitarzewski/agency-agents/git/trees/bcb704f30348cb5a9d6a7027d3708c014aacf411\",\n      \"html\": \"https://github.com/msitarzewski/agency-agents/tree/main/project-management\"\n    }\n  },\n  {\n    \"name\": \"sales\",\n    \"path\": \"sales\",\n    \"sha\": \"4f6e3c85a9c10f65700d1f916cfe1d9504ca52fa\",\n    \"size\": 0,\n    \"url\": \"https://api.github.com/repos/msitarzewski/agency-agents/contents/sales?ref=main\",\n    \"html_url\": \"https://github.com/msitarzewski/agency-agents/tree/main/sales\",\n    \"git_url\": \"https://api.github.com/repos/msitarzewski/agency-agents/git/trees/4f6e3c85a9c10f65700d1f916cfe1d9504ca52fa\",\n    \"download_url\": null,\n    \"type\": \"dir\",\n    \"_links\": {\n      \"self\": \"https://api.github.com/repos/msitarzewski/agency-agents/contents/sales?ref=main\",\n      \"git\": \"https://api.github.com/repos/msitarzewski/agency-agents/git/trees/4f6e3c85a9c10f65700d1f916cfe1d9504ca52fa\",\n      \"html\": \"https://github.com/msitarzewski/agency-agents/tree/main/sales\"\n    }\n  },\n  {\n    \"name\": \"scripts\",\n    \"path\": \"scripts\",\n    \"sha\": \"a21e79eaace2f53167e8c4f380e5eb2dc02d5fc8\",\n    \"size\": 0,\n    \"url\": \"https://api.github.com/repos/msitarzewski/agency-agents/contents/scripts?ref=main\",\n    \"html_url\": \"https://github.com/msitarzewski/agency-agents/tree/main/scripts\",\n    \"git_url\": \"https://api.github.com/repos/msitarzewski/agency-agents/git/trees/a21e79eaace2f53167e8c4f380e5eb2dc02d5fc8\",\n    \"download_url\": null,\n    \"type\": \"dir\",\n    \"_links\": {\n      \"self\": \"https://api.github.com/repos/msitarzewski/agency-agents/contents/scripts?ref=main\",\n      \"git\": \"https://api.github.com/repos/msitarzewski/agency-agents/git/trees/a21e79eaace2f53167e8c4f380e5eb2dc02d5fc8\",\n      \"html\": \"https://github.com/msitarzewski/agency-agents/tree/main/scripts\"\n    }\n  },\n  {\n    \"name\": \"spatial-computing\",\n    \"path\": \"spatial-computing\",\n    \"sha\": \"73784a071748e42b0fa68109eb6004750683f1b1\",\n    \"size\": 0,\n    \"url\": \"https://api.github.com/repos/msitarzewski