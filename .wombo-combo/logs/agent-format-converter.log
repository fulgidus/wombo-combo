{"type":"tool_use","timestamp":1773435866712,"sessionID":"ses_316fcb99fffew5IdSvpvZvnqV0","part":{"id":"prt_ce903cc94001GxfvcCYjUHoBAw","sessionID":"ses_316fcb99fffew5IdSvpvZvnqV0","messageID":"msg_ce903baa0001lWk4rSPg5GVcjs","type":"tool","callID":"toolu_vrtx_01HYak3tX6XesgA8VsnzZRCV","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-agent-format-converter/src/lib/launcher.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-agent-format-converter/src/lib/launcher.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * launcher.ts — Process spawning and terminal multiplexer session management.\n3:  *\n4:  * Responsibilities:\n5:  *   - Launch agent in headless mode (agent run --format json)\n6:  *   - Launch agent in interactive mode (dmux/tmux session with TUI)\n7:  *   - Resume sessions for auto-retry\n8:  *   - Manage multiplexer sessions (create, list, kill)\n9:  *\n10:  * Supports both dmux (preferred) and tmux (fallback) via the multiplexer\n11:  * abstraction layer. The active backend is determined by config.agent.multiplexer.\n12:  */\n13: \n14: import { spawn, execSync, type ChildProcess } from \"node:child_process\";\n15: import { writeFileSync, unlinkSync } from \"node:fs\";\n16: import type { WomboConfig } from \"../config.js\";\n17: import { resolveAgentBin } from \"../config.js\";\n18: import {\n19:   detectMultiplexer,\n20:   muxNewSession,\n21:   muxHasSession,\n22:   muxKillSession,\n23:   muxListSessions,\n24:   muxGetPanePid,\n25:   muxLoadBuffer,\n26:   muxPasteBuffer,\n27:   muxSendKeys,\n28:   muxDisplayName,\n29:   type MultiplexerInfo,\n30: } from \"./multiplexer.js\";\n31: import { portlessEnv } from \"./portless.js\";\n32: \n33: // ---------------------------------------------------------------------------\n34: // Types\n35: // ---------------------------------------------------------------------------\n36: \n37: export interface LaunchResult {\n38:   pid: number;\n39:   process: ChildProcess;\n40:   sessionId?: string;\n41: }\n42: \n43: export interface LaunchOptions {\n44:   worktreePath: string;\n45:   featureId: string;\n46:   prompt: string;\n47:   model?: string;\n48:   interactive?: boolean;\n49:   config: WomboConfig;\n50:   /** Override the agent name (for specialized agents from the registry) */\n51:   agentName?: string;\n52: }\n53: \n54: export interface RetryOptions {\n55:   worktreePath: string;\n56:   featureId: string;\n57:   sessionId: string;\n58:   buildErrors: string;\n59:   model?: string;\n60:   interactive?: boolean;\n61:   config: WomboConfig;\n62: }\n63: \n64: // ---------------------------------------------------------------------------\n65: // Helpers\n66: // ---------------------------------------------------------------------------\n67: \n68: function muxSessionName(featureId: string, config: WomboConfig): string {\n69:   return `${config.agent.tmuxPrefix}-${featureId}`;\n70: }\n71: \n72: /**\n73:  * Get the multiplexer info for this config.\n74:  * Caches detection per-process.\n75:  */\n76: function getMux(config: WomboConfig): MultiplexerInfo {\n77:   return detectMultiplexer(config.agent.multiplexer);\n78: }\n79: \n80: function runSilent(cmd: string): string {\n81:   try {\n82:     return execSync(cmd, { encoding: \"utf-8\", stdio: \"pipe\" }).trim();\n83:   } catch {\n84:     return \"\";\n85:   }\n86: }\n87: \n88: /**\n89:  * Build the environment for an agent process.\n90:  * Merges process.env with OPENCODE_DIR and portless env vars.\n91:  */\n92: function agentEnv(\n93:   worktreePath: string,\n94:   featureId: string,\n95:   config: WomboConfig\n96: ): Record<string, string | undefined> {\n97:   return {\n98:     ...process.env,\n99:     OPENCODE_DIR: worktreePath,\n100:     ...portlessEnv(featureId, config),\n101:   };\n102: }\n103: \n104: // ---------------------------------------------------------------------------\n105: // Headless Launch\n106: // ---------------------------------------------------------------------------\n107: \n108: /**\n109:  * Launch agent in headless mode with JSON output.\n110:  */\n111: export function launchHeadless(opts: LaunchOptions): LaunchResult {\n112:   const agentBin = resolveAgentBin(opts.config);\n113: \n114:   const args = [\n115:     \"run\",\n116:     \"--format\", \"json\",\n117:     \"--agent\", opts.agentName ?? opts.config.agent.name,\n118:     \"--dir\", opts.worktreePath,\n119:     \"--title\", `woco: ${opts.featureId}`,\n120:   ];\n121: \n122:   if (opts.model) {\n123:     args.push(\"--model\", opts.model);\n124:   }\n125: \n126:   args.push(opts.prompt);\n127: \n128:   const child = spawn(agentBin, args, {\n129:     stdio: [\"pipe\", \"pipe\", \"pipe\"],\n130:     detached: false,\n131:     env: agentEnv(opts.worktreePath, opts.featureId, opts.config),\n132:   });\n133: \n134:   // Close stdin so agent starts processing immediately\n135:   child.stdin?.end();\n136: \n137:   return {\n138:     pid: child.pid!,\n139:     process: child,\n140:   };\n141: }\n142: \n143: /**\n144:  * Resume a headless session with a retry message (build errors).\n145:  */\n146: export function retryHeadless(opts: RetryOptions): LaunchResult {\n147:   const agentBin = resolveAgentBin(opts.config);\n148: \n149:   const retryMessage = `The build failed. Please fix the following errors and run \\`${opts.config.build.command}\\` again:\\n\\n\\`\\`\\`\\n${opts.buildErrors}\\n\\`\\`\\`\\n\\nFix all errors, then verify the build passes.`;\n150: \n151:   const args = [\n152:     \"run\",\n153:     \"--format\", \"json\",\n154:     \"--session\", opts.sessionId,\n155:     \"--continue\",\n156:     \"--dir\", opts.worktreePath,\n157:   ];\n158: \n159:   if (opts.model) {\n160:     args.push(\"--model\", opts.model);\n161:   }\n162: \n163:   args.push(retryMessage);\n164: \n165:   const child = spawn(agentBin, args, {\n166:     stdio: [\"pipe\", \"pipe\", \"pipe\"],\n167:     detached: false,\n168:     env: agentEnv(opts.worktreePath, opts.featureId, opts.config),\n169:   });\n170: \n171:   child.stdin?.end();\n172: \n173:   return {\n174:     pid: child.pid!,\n175:     process: child,\n176:   };\n177: }\n178: \n179: // ---------------------------------------------------------------------------\n180: // Conflict Resolution Launch\n181: // ---------------------------------------------------------------------------\n182: \n183: export interface ConflictResolverOptions {\n184:   worktreePath: string;\n185:   featureId: string;\n186:   prompt: string;\n187:   model?: string;\n188:   config: WomboConfig;\n189: }\n190: \n191: /**\n192:  * Launch a headless agent to resolve merge conflicts.\n193:  *\n194:  * This is similar to `launchHeadless`, but the prompt is a conflict-resolution\n195:  * prompt generated by `generateConflictResolutionPrompt()`. The agent runs in\n196:  * the feature worktree where `git merge <baseBranch>` has already been run,\n197:  * leaving conflict markers in the working tree.\n198:  */\n199: export function launchConflictResolver(opts: ConflictResolverOptions): LaunchResult {\n200:   const agentBin = resolveAgentBin(opts.config);\n201: \n202:   const args = [\n203:     \"run\",\n204:     \"--format\", \"json\",\n205:     \"--agent\", opts.config.agent.name,\n206:     \"--dir\", opts.worktreePath,\n207:     \"--title\", `woco: conflict-resolve ${opts.featureId}`,\n208:   ];\n209: \n210:   if (opts.model) {\n211:     args.push(\"--model\", opts.model);\n212:   }\n213: \n214:   args.push(opts.prompt);\n215: \n216:   const child = spawn(agentBin, args, {\n217:     stdio: [\"pipe\", \"pipe\", \"pipe\"],\n218:     detached: false,\n219:     env: agentEnv(opts.worktreePath, opts.featureId, opts.config),\n220:   });\n221: \n222:   child.stdin?.end();\n223: \n224:   return {\n225:     pid: child.pid!,\n226:     process: child,\n227:   };\n228: }\n229: \n230: // ---------------------------------------------------------------------------\n231: // Interactive (multiplexer) Launch\n232: // ---------------------------------------------------------------------------\n233: \n234: /**\n235:  * Launch agent in a terminal multiplexer session (dmux or tmux) for interactive use.\n236:  */\n237: export function launchInteractive(opts: LaunchOptions): LaunchResult {\n238:   const agentBin = resolveAgentBin(opts.config);\n239:   const mux = getMux(opts.config);\n240:   const sessionName = muxSessionName(opts.featureId, opts.config);\n241: \n242:   // Kill existing session if any\n243:   killMuxSession(opts.featureId, opts.config);\n244: \n245:   // Build the agent command to run inside the multiplexer\n246:   // Include portless env vars so any server started in the session\n247:   // is routed through the portless proxy\n248:   const pEnv = portlessEnv(opts.featureId, opts.config);\n249:   const envPrefix = Object.entries(pEnv)\n250:     .map(([k, v]) => `${k}=${JSON.stringify(v)}`)\n251:     .join(\" \");\n252: \n253:   const ocArgs = [\n254:     agentBin,\n255:     \"--dir\", JSON.stringify(opts.worktreePath),\n256:   ];\n257: \n258:   if (opts.model) {\n259:     ocArgs.push(\"--model\", JSON.stringify(opts.model));\n260:   }\n261: \n262:   const muxCmd = envPrefix ? `${envPrefix} ${ocArgs.join(\" \")}` : ocArgs.join(\" \");\n263: \n264:   // Create a detached session running the agent\n265:   muxNewSession(mux, sessionName, opts.worktreePath, muxCmd);\n266: \n267:   // Send the prompt as initial message after a brief delay\n268:   setTimeout(() => {\n269:     try {\n270:       const tmpFile = `/tmp/woco-prompt-${opts.featureId}.txt`;\n271:       writeFileSync(tmpFile, opts.prompt);\n272:       muxLoadBuffer(mux, tmpFile);\n273:       muxPasteBuffer(mux, sessionName);\n274:       muxSendKeys(mux, sessionName, \"Enter\");\n275:       try { unlinkSync(tmpFile); } catch {}\n276:     } catch {\n277:       // If prompt sending fails, user can type manually\n278:     }\n279:   }, 3000);\n280: \n281:   // Get the PID of the pane process\n282:   const panePid = muxGetPanePid(mux, sessionName);\n283: \n284:   return {\n285:     pid: panePid,\n286:     process: null as any, // No direct process handle in multiplexer mode\n287:   };\n288: }\n289: \n290: /**\n291:  * Resume an interactive session with retry message.\n292:  */\n293: export function retryInteractive(opts: RetryOptions): LaunchResult {\n294:   const mux = getMux(opts.config);\n295:   const sessionName = muxSessionName(opts.featureId, opts.config);\n296: \n297:   const exists = muxSessionExists(opts.featureId, opts.config);\n298: \n299:   if (exists) {\n300:     const retryMsg = `The build failed. Fix these errors:\\n${opts.buildErrors}`;\n301:     const tmpFile = `/tmp/woco-retry-${opts.featureId}.txt`;\n302:     writeFileSync(tmpFile, retryMsg);\n303:     muxLoadBuffer(mux, tmpFile);\n304:     muxPasteBuffer(mux, sessionName);\n305:     muxSendKeys(mux, sessionName, \"Enter\");\n306:     try { unlinkSync(tmpFile); } catch {}\n307: \n308:     const panePid = muxGetPanePid(mux, sessionName);\n309: \n310:     return {\n311:       pid: panePid,\n312:       process: null as any,\n313:     };\n314:   }\n315: \n316:   // Session doesn't exist — launch a new interactive session\n317:   return launchInteractive({\n318:     worktreePath: opts.worktreePath,\n319:     featureId: opts.featureId,\n320:     prompt: `Continue from session ${opts.sessionId}. The build failed:\\n${opts.buildErrors}\\n\\nFix all errors and verify the build passes.`,\n321:     model: opts.model,\n322:     interactive: true,\n323:     config: opts.config,\n324:   });\n325: }\n326: \n327: // ---------------------------------------------------------------------------\n328: // Multiplexer Session Management\n329: // ---------------------------------------------------------------------------\n330: \n331: /**\n332:  * Check if a multiplexer session exists for a feature.\n333:  */\n334: export function muxSessionExists(\n335:   featureId: string,\n336:   config: WomboConfig\n337: ): boolean {\n338:   const mux = getMux(config);\n339:   const sessionName = muxSessionName(featureId, config);\n340:   return muxHasSession(mux, sessionName);\n341: }\n342: \n343: /**\n344:  * Kill a multiplexer session for a feature.\n345:  */\n346: export function killMuxSession(\n347:   featureId: string,\n348:   config: WomboConfig\n349: ): void {\n350:   const mux = getMux(config);\n351:   const sessionName = muxSessionName(featureId, config);\n352:   muxKillSession(mux, sessionName);\n353: }\n354: \n355: /**\n356:  * List all woco-related multiplexer sessions.\n357:  */\n358: export function listMuxSessions(config: WomboConfig): string[] {\n359:   const mux = getMux(config);\n360:   const sessions = muxListSessions(mux);\n361:   return sessions.filter((s) => s.startsWith(config.agent.tmuxPrefix + \"-\"));\n362: }\n363: \n364: /**\n365:  * Kill all woco-related multiplexer sessions.\n366:  */\n367: export function killAllMuxSessions(config: WomboConfig): number {\n368:   const mux = getMux(config);\n369:   const sessions = listMuxSessions(config);\n370:   for (const s of sessions) {\n371:     muxKillSession(mux, s);\n372:   }\n373:   return sessions.length;\n374: }\n375: \n376: /**\n377:  * Get the display name of the active multiplexer backend.\n378:  */\n379: export function getMultiplexerName(config: WomboConfig): string {\n380:   try {\n381:     const mux = getMux(config);\n382:     return muxDisplayName(mux);\n383:   } catch {\n384:     return \"tmux/dmux\";\n385:   }\n386: }\n387: \n388: // ---------------------------------------------------------------------------\n389: // Backward Compatibility Aliases\n390: // ---------------------------------------------------------------------------\n391: \n392: /** @deprecated Use muxSessionExists instead */\n393: export const tmuxSessionExists = muxSessionExists;\n394: /** @deprecated Use killMuxSession instead */\n395: export const killTmuxSession = killMuxSession;\n396: /** @deprecated Use listMuxSessions instead */\n397: export const listTmuxSessions = listMuxSessions;\n398: /** @deprecated Use killAllMuxSessions instead */\n399: export const killAllTmuxSessions = killAllMuxSessions;\n400: \n401: /**\n402:  * Check if a process is still running by PID.\n403:  */\n404: export function isProcessRunning(pid: number): boolean {\n405:   if (!pid || pid <= 0) return false;\n406:   try {\n407:     process.kill(pid, 0);\n408:     return true;\n409:   } catch {\n410:     return false;\n411:   }\n412: }\n\n(End of file - total 412 lines)\n</content>","title":"src/lib/launcher.ts","metadata":{"preview":"/**\n * launcher.ts — Process spawning and terminal multiplexer session management.\n *\n * Responsibilities:\n *   - Launch agent in headless mode (agent run --format json)\n *   - Launch agent in interactive mode (dmux/tmux session with TUI)\n *   - Resume sessions for auto-retry\n *   - Manage multiplexer sessions (create, list, kill)\n *\n * Supports both dmux (preferred) and tmux (fallback) via the multiplexer\n * abstraction layer. The active backend is determined by config.agent.multiplexer.\n */\n\nimport { spawn, execSync, type ChildProcess } from \"node:child_process\";\nimport { writeFileSync, unlinkSync } from \"node:fs\";\nimport type { WomboConfig } from \"../config.js\";\nimport { resolveAgentBin } from \"../config.js\";\nimport {\n  detectMultiplexer,\n  muxNewSession,","truncated":false,"loaded":[]},"time":{"start":1773435866707,"end":1773435866711}}}}
