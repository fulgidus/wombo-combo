{"type":"tool_use","timestamp":1773435849586,"sessionID":"ses_316fcb99fffew5IdSvpvZvnqV0","part":{"id":"prt_ce9038b5c001DR2mNhVtd4Kl2j","sessionID":"ses_316fcb99fffew5IdSvpvZvnqV0","messageID":"msg_ce9037d5f0018IIuUSPT54mKsm","type":"tool","callID":"toolu_vrtx_01Krs4i34C8m7efiscXoxMeJ","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-agent-format-converter/src/lib/agent-registry.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-agent-format-converter/src/lib/agent-registry.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * agent-registry.ts — Fetch, cache, and resolve specialized agent definitions\n3:  * from an external registry (e.g. github.com/msitarzewski/agency-agents).\n4:  *\n5:  * Flow:\n6:  *   1. Task has `agent_type: \"engineering/engineering-frontend-developer\"`\n7:  *   2. resolveAgentForTask() checks cache, fetches if missing, returns raw md\n8:  *   3. At launch time, raw md is patched via patchImportedAgent() and written\n9:  *      into the worktree's .opencode/agents/ directory\n10:  *\n11:  * Cache layout:\n12:  *   .wombo-combo/agents-cache/engineering/engineering-frontend-developer.md\n13:  *\n14:  * Raw downloads are cached. Patching is done at launch time (not cached)\n15:  * because patches depend on runtime config (portless, placeholders, etc.).\n16:  */\n17: \n18: import { resolve, dirname, relative } from \"node:path\";\n19: import {\n20:   existsSync,\n21:   readFileSync,\n22:   writeFileSync,\n23:   mkdirSync,\n24:   readdirSync,\n25:   statSync,\n26: } from \"node:fs\";\n27: import { WOMBO_DIR, type WomboConfig, type AgentRegistryMode } from \"../config.js\";\n28: import type { Task } from \"./tasks.js\";\n29: \n30: // ---------------------------------------------------------------------------\n31: // Types\n32: // ---------------------------------------------------------------------------\n33: \n34: /** Result of resolving an agent for a task */\n35: export interface ResolvedAgent {\n36:   /** Task ID this agent is resolved for */\n37:   taskId: string;\n38:   /**\n39:    * Agent name (last path segment of agent_type).\n40:    * e.g. \"engineering-frontend-developer\" from \"engineering/engineering-frontend-developer\"\n41:    */\n42:   name: string;\n43:   /** Raw markdown content from the registry (before patching) */\n44:   rawContent: string;\n45:   /** Whether this was loaded from cache (true) or freshly fetched (false) */\n46:   fromCache: boolean;\n47:   /** The agent_type string from the task */\n48:   agentType: string;\n49: }\n50: \n51: /** Generalist fallback — no specialized agent, use default */\n52: export interface GeneralistFallback {\n53:   taskId: string;\n54:   name: null;\n55:   rawContent: null;\n56:   fromCache: false;\n57:   agentType: null;\n58: }\n59: \n60: export type AgentResolution = ResolvedAgent | GeneralistFallback;\n61: \n62: /** Summary info for a registry agent (used by listRegistryAgents / getCachedAgents) */\n63: export interface RegistryAgentInfo {\n64:   /** Agent type path, e.g. \"engineering/engineering-frontend-developer\" */\n65:   agentType: string;\n66:   /** Short name derived from the path, e.g. \"engineering-frontend-developer\" */\n67:   name: string;\n68:   /** Category (first path segment), e.g. \"engineering\" */\n69:   category: string;\n70:   /** Human-readable description extracted from frontmatter, or null if unavailable */\n71:   description: string | null;\n72: }\n73: \n74: /** Entry returned by the GitHub Contents API */\n75: interface GitHubContentEntry {\n76:   name: string;\n77:   path: string;\n78:   type: \"file\" | \"dir\" | \"symlink\" | \"submodule\";\n79:   size?: number;\n80:   download_url?: string | null;\n81: }\n82: \n83: // ---------------------------------------------------------------------------\n84: // Agent Name Derivation\n85: // ---------------------------------------------------------------------------\n86: \n87: /**\n88:  * Derive the agent name from an agent_type string.\n89:  * \"engineering/engineering-frontend-developer\" → \"engineering-frontend-developer\"\n90:  */\n91: export function agentNameFromType(agentType: string): string {\n92:   const segments = agentType.split(\"/\");\n93:   return segments[segments.length - 1];\n94: }\n95: \n96: // ---------------------------------------------------------------------------\n97: // Frontmatter Parsing\n98: // ---------------------------------------------------------------------------\n99: \n100: /**\n101:  * Extract description from YAML frontmatter in a markdown string.\n102:  * Expects `---` delimiters at the top of the file.\n103:  * Returns null if no frontmatter or no description field found.\n104:  */\n105: function extractDescription(markdownContent: string): string | null {\n106:   const trimmed = markdownContent.trimStart();\n107:   if (!trimmed.startsWith(\"---\")) return null;\n108: \n109:   const endIndex = trimmed.indexOf(\"---\", 3);\n110:   if (endIndex === -1) return null;\n111: \n112:   const frontmatter = trimmed.slice(3, endIndex);\n113:   // Simple regex extraction — avoids pulling in a YAML parser for a single field\n114:   const match = frontmatter.match(/^description:\\s*(.+)$/m);\n115:   if (!match) return null;\n116: \n117:   // Strip surrounding quotes if present\n118:   let desc = match[1].trim();\n119:   if ((desc.startsWith('\"') && desc.endsWith('\"')) || (desc.startsWith(\"'\") && desc.endsWith(\"'\"))) {\n120:     desc = desc.slice(1, -1);\n121:   }\n122:   return desc || null;\n123: }\n124: \n125: // ---------------------------------------------------------------------------\n126: // Cache Operations\n127: // ---------------------------------------------------------------------------\n128: \n129: /**\n130:  * Resolve the cache directory root for agents.\n131:  */\n132: function cacheDir(projectRoot: string, config: WomboConfig): string {\n133:   return resolve(projectRoot, WOMBO_DIR, config.agentRegistry.cacheDir);\n134: }\n135: \n136: /**\n137:  * Resolve the cache file path for an agent type.\n138:  * e.g. \"engineering/engineering-frontend-developer\"\n139:  *   → \".wombo-combo/agents-cache/engineering/engineering-frontend-developer.md\"\n140:  */\n141: function cachePath(projectRoot: string, config: WomboConfig, agentType: string): string {\n142:   return resolve(cacheDir(projectRoot, config), `${agentType}.md`);\n143: }\n144: \n145: /**\n146:  * Check whether a cached agent file is still valid (within TTL).\n147:  * Returns true if the file exists and its mtime is within cacheTTL ms of now.\n148:  */\n149: function isCacheValid(\n150:   projectRoot: string,\n151:   config: WomboConfig,\n152:   agentType: string\n153: ): boolean {\n154:   const path = cachePath(projectRoot, config, agentType);\n155:   if (!existsSync(path)) return false;\n156:   try {\n157:     const stat = statSync(path);\n158:     const age = Date.now() - stat.mtimeMs;\n159:     return age < config.agentRegistry.cacheTTL;\n160:   } catch {\n161:     return false;\n162:   }\n163: }\n164: \n165: /**\n166:  * Read a cached agent definition. Returns null if not cached.\n167:  * Does NOT check TTL — callers should use isCacheValid() for freshness checks.\n168:  */\n169: export function getCachedAgent(\n170:   projectRoot: string,\n171:   config: WomboConfig,\n172:   agentType: string\n173: ): string | null {\n174:   const path = cachePath(projectRoot, config, agentType);\n175:   if (!existsSync(path)) return null;\n176:   try {\n177:     return readFileSync(path, \"utf-8\");\n178:   } catch {\n179:     return null;\n180:   }\n181: }\n182: \n183: /**\n184:  * Write an agent definition to the cache.\n185:  */\n186: export function cacheAgent(\n187:   projectRoot: string,\n188:   config: WomboConfig,\n189:   agentType: string,\n190:   content: string\n191: ): void {\n192:   const path = cachePath(projectRoot, config, agentType);\n193:   mkdirSync(dirname(path), { recursive: true });\n194:   writeFileSync(path, content, \"utf-8\");\n195: }\n196: \n197: /**\n198:  * List all locally cached agents from .wombo-combo/agents-cache/.\n199:  * Recursively scans the cache directory for .md files and extracts\n200:  * metadata from their frontmatter.\n201:  */\n202: export function getCachedAgents(\n203:   projectRoot: string,\n204:   config: WomboConfig\n205: ): RegistryAgentInfo[] {\n206:   const root = cacheDir(projectRoot, config);\n207:   if (!existsSync(root)) return [];\n208: \n209:   const results: RegistryAgentInfo[] = [];\n210: \n211:   function walk(dir: string): void {\n212:     let entries: string[];\n213:     try {\n214:       entries = readdirSync(dir);\n215:     } catch {\n216:       return;\n217:     }\n218:     for (const entry of entries) {\n219:       const fullPath = resolve(dir, entry);\n220:       let stat;\n221:       try {\n222:         stat = statSync(fullPath);\n223:       } catch {\n224:         continue;\n225:       }\n226:       if (stat.isDirectory()) {\n227:         walk(fullPath);\n228:       } else if (stat.isFile() && entry.endsWith(\".md\")) {\n229:         // Derive agentType from relative path minus .md extension\n230:         const rel = relative(root, fullPath);\n231:         const agentType = rel.replace(/\\.md$/, \"\").replace(/\\\\/g, \"/\");\n232:         const name = agentNameFromType(agentType);\n233:         const segments = agentType.split(\"/\");\n234:         const category = segments.length > 1 ? segments[0] : \"\";\n235: \n236:         let description: string | null = null;\n237:         try {\n238:           const content = readFileSync(fullPath, \"utf-8\");\n239:           description = extractDescription(content);\n240:         } catch {\n241:           // ignore read errors — description stays null\n242:         }\n243: \n244:         results.push({ agentType, name, category, description });\n245:       }\n246:     }\n247:   }\n248: \n249:   walk(root);\n250:   return results;\n251: }\n252: \n253: // ---------------------------------------------------------------------------\n254: // Fetch from Registry\n255: // ---------------------------------------------------------------------------\n256: \n257: /**\n258:  * Build the raw GitHub URL for an agent definition.\n259:  * Source: \"msitarzewski/agency-agents\"\n260:  * Agent type: \"engineering/engineering-frontend-developer\"\n261:  * → \"https://raw.githubusercontent.com/msitarzewski/agency-agents/main/engineering/engineering-frontend-developer.md\"\n262:  */\n263: function rawUrl(source: string, agentType: string): string {\n264:   return `https://raw.githubusercontent.com/${source}/main/${agentType}.md`;\n265: }\n266: \n267: /**\n268:  * Build the GitHub API URL for listing directory contents.\n269:  * Source: \"msitarzewski/agency-agents\"\n270:  * Path: \"engineering\" (or \"\" for root)\n271:  * → \"https://api.github.com/repos/msitarzewski/agency-agents/contents/engineering\"\n272:  */\n273: function contentsApiUrl(source: string, path?: string): string {\n274:   const base = `https://api.github.com/repos/${source}/contents`;\n275:   return path ? `${base}/${path}` : base;\n276: }\n277: \n278: /**\n279:  * Fetch an agent definition from the registry by agent type.\n280:  * Returns the raw markdown content or throws on failure.\n281:  *\n282:  * @param agentType — e.g. \"engineering/engineering-frontend-developer\"\n283:  * @param source    — GitHub repo in \"owner/repo\" format\n284:  */\n285: export async function fetchAgent(\n286:   agentType: string,\n287:   source: string\n288: ): Promise<string> {\n289:   const url = rawUrl(source, agentType);\n290:   const response = await fetch(url);\n291: \n292:   if (!response.ok) {\n293:     if (response.status === 404) {\n294:       throw new Error(\n295:         `Agent \"${agentType}\" not found in registry \"${source}\". ` +\n296:         `Looked at: ${url}`\n297:       );\n298:     }\n299:     throw new Error(\n300:       `Failed to fetch agent \"${agentType}\" from registry: ` +\n301:       `HTTP ${response.status} ${response.statusText}`\n302:     );\n303:   }\n304: \n305:   return await response.text();\n306: }\n307: \n308: /**\n309:  * Fetch the list of available agents from the registry.\n310:  *\n311:  * Uses the GitHub Contents API to recursively walk the repo and find all .md\n312:  * agent definitions. For each found agent, fetches the raw content to extract\n313:  * the description from the YAML frontmatter.\n314:  *\n315:  * Categories excluded from listing: files in the repo root, and directories\n316:  * that are not agent categories (e.g. \"scripts\", \"examples\", \".github\").\n317:  *\n318:  * @param source — GitHub repo in \"owner/repo\" format (e.g. \"msitarzewski/agency-agents\")\n319:  * @returns Array of agent info objects with name, category, and description\n320:  */\n321: export async function listRegistryAgents(\n322:   source: string\n323: ): Promise<RegistryAgentInfo[]> {\n324:   // Directories that are NOT agent categories — skip them\n325:   const EXCLUDED_DIRS = new Set([\n326:     \".github\",\n327:     \"scripts\",\n328:     \"examples\",\n329:   ]);\n330: \n331:   // Step 1: Fetch root listing to discover categories\n332:   const rootUrl = contentsApiUrl(source);\n333:   const rootResponse = await fetch(rootUrl, {\n334:     headers: { Accept: \"application/vnd.github.v3+json\" },\n335:   });\n336: \n337:   if (!rootResponse.ok) {\n338:     throw new Error(\n339:       `Failed to list registry \"${source}\": HTTP ${rootResponse.status} ${rootResponse.statusText}`\n340:     );\n341:   }\n342: \n343:   const rootEntries = (await rootResponse.json()) as GitHubContentEntry[];\n344:   const categoryDirs = rootEntries.filter(\n345:     (e) => e.type === \"dir\" && !e.name.startsWith(\".\") && !EXCLUDED_DIRS.has(e.name)\n346:   );\n347: \n348:   // Step 2: Fetch each category directory in parallel\n349:   const categoryResults = await Promise.allSettled(\n350:     categoryDirs.map(async (catEntry) => {\n351:       const catUrl = contentsApiUrl(source, catEntry.path);\n352:       const catResponse = await fetch(catUrl, {\n353:         headers: { Accept: \"application/vnd.github.v3+json\" },\n354:       });\n355: \n356:       if (!catResponse.ok) {\n357:         throw new Error(\n358:           `Failed to list category \"${catEntry.path}\": HTTP ${catResponse.status}`\n359:         );\n360:       }\n361: \n362:       const files = (await catResponse.json()) as GitHubContentEntry[];\n363:       return { category: catEntry.name, files };\n364:     })\n365:   );\n366: \n367:   // Step 3: For each .md file, extract agent info.\n368:   // We fetch the raw content in parallel (batched per category) to get descriptions.\n369:   const agents: RegistryAgentInfo[] = [];\n370: \n371:   for (const result of categoryResults) {\n372:     if (result.status !== \"fulfilled\") continue;\n373:     const { category, files } = result.value;\n374: \n375:     const mdFiles = files.filter(\n376:       (f) => f.type === \"file\" && f.name.endsWith(\".md\")\n377:     );\n378: \n379:     // Fetch raw contents in parallel to extract descriptions\n380:     const fileResults = await Promise.allSettled(\n381:       mdFiles.map(async (mdFile) => {\n382:         const agentType = mdFile.path.replace(/\\.md$/, \"\");\n383:         const name = agentNameFromType(agentType);\n384: \n385:         let description: string | null = null;\n386:         if (mdFile.download_url) {\n387:           try {\n388:             const raw = await fetch(mdFile.download_url);\n389:             if (raw.ok) {\n390:               const content = await raw.text();\n391:               description = extractDescription(content);\n392:             }\n393:           } catch {\n394:             // Couldn't fetch content — description stays null\n395:           }\n396:         }\n397: \n398:         return { agentType, name, category, description } as RegistryAgentInfo;\n399:       })\n400:     );\n401: \n402:     for (const fileResult of fileResults) {\n403:       if (fileResult.status === \"fulfilled\") {\n404:         agents.push(fileResult.value);\n405:       }\n406:     }\n407:   }\n408: \n409:   return agents;\n410: }\n411: \n412: // ---------------------------------------------------------------------------\n413: // Resolution (with TTL + offline fallback)\n414: // ---------------------------------------------------------------------------\n415: \n416: /**\n417:  * Resolve the agent definition for a single task.\n418:  *\n419:  * If the task has no agent_type or registry mode is disabled, returns a\n420:  * generalist fallback. Otherwise checks cache (with TTL) then fetches\n421:  * from the registry. If the fetch fails, falls back to stale cache\n422:  * silently with a warning (offline support).\n423:  */\n424: export async function resolveAgentForTask(\n425:   task: Task,\n426:   config: WomboConfig,\n427:   projectRoot: string\n428: ): Promise<AgentResolution> {\n429:   // No agent_type specified or registry disabled → generalist\n430:   if (!task.agent_type || config.agentRegistry.mode === \"disabled\") {\n431:     return {\n432:       taskId: task.id,\n433:       name: null,\n434:       rawContent: null,\n435:       fromCache: false,\n436:       agentType: null,\n437:     };\n438:   }\n439: \n440:   const agentType = task.agent_type;\n441:   const name = agentNameFromType(agentType);\n442: \n443:   // Check cache first — only use if within TTL\n444:   if (isCacheValid(projectRoot, config, agentType)) {\n445:     const cached = getCachedAgent(projectRoot, config, agentType);\n446:     if (cached !== null) {\n447:       return {\n448:         taskId: task.id,\n449:         name,\n450:         rawContent: cached,\n451:         fromCache: true,\n452:         agentType,\n453:       };\n454:     }\n455:   }\n456: \n457:   // Attempt to fetch from registry\n458:   try {\n459:     const rawContent = await fetchAgent(agentType, config.agentRegistry.source);\n460: \n461:     // Cache the raw download\n462:     cacheAgent(projectRoot, config, agentType, rawContent);\n463: \n464:     return {\n465:       taskId: task.id,\n466:       name,\n467:       rawContent,\n468:       fromCache: false,\n469:       agentType,\n470:     };\n471:   } catch (fetchError: any) {\n472:     // Offline fallback: try stale cache (ignore TTL)\n473:     const staleCache = getCachedAgent(projectRoot, config, agentType);\n474:     if (staleCache !== null) {\n475:       console.warn(\n476:         `\\x1b[33m[WARNING]\\x1b[0m Failed to fetch agent \"${agentType}\" from registry: ${fetchError?.message ?? fetchError}`\n477:       );\n478:       console.warn(\n479:         `  Using stale cached version (offline fallback).\\n`\n480:       );\n481:       return {\n482:         taskId: task.id,\n483:         name,\n484:         rawContent: staleCache,\n485:         fromCache: true,\n486:         agentType,\n487:       };\n488:     }\n489: \n490:     // No cache available — re-throw the original error\n491:     throw fetchError;\n492:   }\n493: }\n494: \n495: /**\n496:  * Resolve agent definitions for all tasks in a launch wave.\n497:  *\n498:  * Returns a Map from task ID to agent resolution. Fetches are parallelized.\n499:  * Individual fetch failures are caught and logged — the task falls back to\n500:  * the generalist agent rather than blocking the entire wave.\n501:  */\n502: export async function prepareAgentDefinitions(\n503:   tasks: Task[],\n504:   config: WomboConfig,\n505:   projectRoot: string\n506: ): Promise<Map<string, AgentResolution>> {\n507:   const results = new Map<string, AgentResolution>();\n508: \n509:   // Resolve all tasks in parallel\n510:   const resolutions = await Promise.allSettled(\n511:     tasks.map(async (task) => {\n512:       const resolution = await resolveAgentForTask(task, config, projectRoot);\n513:       return { taskId: task.id, resolution };\n514:     })\n515:   );\n516: \n517:   for (const result of resolutions) {\n518:     if (result.status === \"fulfilled\") {\n519:       results.set(result.value.taskId, result.value.resolution);\n520:     } else {\n521:       // Extract task ID from the error context — find the task that failed\n522:       // by checking which tasks don't have results yet\n523:       const resolvedIds = new Set(results.keys());\n524:       const failedTask = tasks.find((t) => !resolvedIds.has(t.id));\n525:       if (failedTask) {\n526:         console.warn(\n527:           `\\x1b[33m[WARNING]\\x1b[0m Failed to resolve agent for task \"${failedTask.id}\": ${result.reason?.message ?? result.reason}`\n528:         );\n529:         console.warn(`  Falling back to generalist agent.\\n`);\n530:         results.set(failedTask.id, {\n531:           taskId: failedTask.id,\n532:           name: null,\n533:           rawContent: null,\n534:           fromCache: false,\n535:           agentType: null,\n536:         });\n537:       }\n538:     }\n539:   }\n540: \n541:   return results;\n542: }\n543: \n544: /**\n545:  * Write a patched agent definition into a worktree's agent/ directory.\n546:  *\n547:  * @param worktreePath — absolute path to the worktree root\n548:  * @param agentName    — derived name (e.g. \"engineering-frontend-developer\")\n549:  * @param patchedContent — fully patched markdown content\n550:  */\n551: export function writeAgentToWorktree(\n552:   worktreePath: string,\n553:   agentName: string,\n554:   patchedContent: string\n555: ): void {\n556:   const agentDir = resolve(worktreePath, \".opencode\", \"agents\");\n557:   mkdirSync(agentDir, { recursive: true });\n558:   const agentPath = resolve(agentDir, `${agentName}.md`);\n559:   writeFileSync(agentPath, patchedContent, \"utf-8\");\n560: }\n561: \n562: /**\n563:  * Check if a resolution is a specialized agent (not generalist fallback).\n564:  */\n565: export function isSpecializedAgent(resolution: AgentResolution): resolution is ResolvedAgent {\n566:   return resolution.name !== null && resolution.rawContent !== null;\n567: }\n\n(End of file - total 567 lines)\n</content>","title":"src/lib/agent-registry.ts","metadata":{"preview":"/**\n * agent-registry.ts — Fetch, cache, and resolve specialized agent definitions\n * from an external registry (e.g. github.com/msitarzewski/agency-agents).\n *\n * Flow:\n *   1. Task has `agent_type: \"engineering/engineering-frontend-developer\"`\n *   2. resolveAgentForTask() checks cache, fetches if missing, returns raw md\n *   3. At launch time, raw md is patched via patchImportedAgent() and written\n *      into the worktree's .opencode/agents/ directory\n *\n * Cache layout:\n *   .wombo-combo/agents-cache/engineering/engineering-frontend-developer.md\n *\n * Raw downloads are cached. Patching is done at launch time (not cached)\n * because patches depend on runtime config (portless, placeholders, etc.).\n */\n\nimport { resolve, dirname, relative } from \"node:path\";\nimport {\n  existsSync,","truncated":false,"loaded":[]},"time":{"start":1773435849572,"end":1773435849580}}}}
{"type":"tool_use","timestamp":1773435850062,"sessionID":"ses_316fcb99fffew5IdSvpvZvnqV0","part":{"id":"prt_ce9038b660017RLCndBq90Zth2","sessionID":"ses_316fcb99fffew5IdSvpvZvnqV0","messageID":"msg_ce9037d5f0018IIuUSPT54mKsm","type":"tool","callID":"toolu_vrtx_016HtqJDHu8jnWPiCBvC7Zdt","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-agent-format-converter/src/config.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-agent-format-converter/src/config.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * config.ts — Load .wombo-combo/config.json, merge with defaults, validate, expose typed config.\n3:  *\n4:  * The config file lives at .wombo-combo/config.json inside the target project root.\n5:  * All values have sensible defaults so minimal config works out of the box.\n6:  */\n7: \n8: import { readFileSync, existsSync } from \"node:fs\";\n9: import { resolve } from \"node:path\";\n10: import type { MultiplexerPreference } from \"./lib/multiplexer.js\";\n11: \n12: // ---------------------------------------------------------------------------\n13: // .wombo-combo directory constant\n14: // ---------------------------------------------------------------------------\n15: \n16: /** Name of the directory that holds all wombo-combo files */\n17: export const WOMBO_DIR = \".wombo-combo\";\n18: \n19: // ---------------------------------------------------------------------------\n20: // Types\n21: // ---------------------------------------------------------------------------\n22: \n23: /** Agent registry download mode */\n24: export type AgentRegistryMode = \"auto\" | \"monitored\" | \"disabled\";\n25: \n26: export interface WomboConfig {\n27:   /** Directory name for task files relative to .wombo-combo/ (folder-based storage) */\n28:   tasksDir: string;\n29:   /** Directory name for archived task files relative to .wombo-combo/ */\n30:   archiveDir: string;\n31:   /** @deprecated Use tasksDir. Legacy single-file path relative to .wombo-combo/ */\n32:   tasksFile?: string;\n33:   /** @deprecated Use archiveDir. Legacy single-file path relative to .wombo-combo/ */\n34:   archiveFile?: string;\n35:   /** Base branch to create feature branches from */\n36:   baseBranch: string;\n37:   /** Build configuration */\n38:   build: {\n39:     /** Build command to run in worktrees */\n40:     command: string;\n41:     /** Build timeout in milliseconds */\n42:     timeout: number;\n43:     /** Build artifact directory (for quick \"did it build?\" checks) */\n44:     artifactDir: string;\n45:   };\n46:   /** Install configuration */\n47:   install: {\n48:     /** Install command to run in worktrees */\n49:     command: string;\n50:     /** Install timeout in milliseconds */\n51:     timeout: number;\n52:   };\n53:   /** Git configuration */\n54:   git: {\n55:     /** Branch name prefix for feature branches */\n56:     branchPrefix: string;\n57:     /** Worktree directory name prefix */\n58:     worktreePrefix: string;\n59:     /** Git remote name */\n60:     remote: string;\n61:     /** Merge strategy flag */\n62:     mergeStrategy: string;\n63:   };\n64:   /** Agent configuration */\n65:   agent: {\n66:     /** Path to agent binary (null = auto-detect) */\n67:     bin: string | null;\n68:     /** Agent name to pass via --agent flag */\n69:     name: string;\n70:     /** Config files/dirs to copy into worktrees */\n71:     configFiles: string[];\n72:     /** Session name prefix for terminal multiplexer */\n73:     tmuxPrefix: string;\n74:     /** Terminal multiplexer preference: \"auto\" (prefer dmux), \"dmux\", or \"tmux\" */\n75:     multiplexer: MultiplexerPreference;\n76:   };\n77:   /** Portless integration for localhost server testing */\n78:   portless: {\n79:     /** Whether portless is enabled for agent worktrees */\n80:     enabled: boolean;\n81:     /** Path to portless binary (null = auto-detect via PATH) */\n82:     bin: string | null;\n83:     /** Proxy port (portless default is 1355) */\n84:     proxyPort: number;\n85:     /** Whether to use HTTPS mode */\n86:     https: boolean;\n87:   };\n88:   /** Backup configuration for tasks file */\n89:   backup: {\n90:     /** Maximum number of timestamped backups to keep */\n91:     maxBackups: number;\n92:   };\n93:   /** Default runtime values */\n94:   defaults: {\n95:     /** Max concurrent agents */\n96:     maxConcurrent: number;\n97:     /** Max retries per agent */\n98:     maxRetries: number;\n99:   };\n100:   /** Browser testing configuration */\n101:   browser: BrowserConfig;\n102:   /** Agent registry configuration for specialized agent downloads */\n103:   agentRegistry: AgentRegistryConfig;\n104:   /** Test-Driven Development configuration */\n105:   tdd: TddConfig;\n106: }\n107: \n108: /** Configuration for browser-based verification and testing */\n109: export interface BrowserConfig {\n110:   /** Enable browser testing in the verify pipeline */\n111:   enabled: boolean;\n112:   /** Path to browser binary (null = auto-detect) */\n113:   bin: string | null;\n114:   /** Run browser in headless mode (required for CI) */\n115:   headless: boolean;\n116:   /** Custom test command to run browser tests (overrides script discovery) */\n117:   testCommand: string | null;\n118:   /** Timeout for launching a browser instance (ms) */\n119:   launchTimeout: number;\n120:   /** Timeout for each browser test script (ms) */\n121:   testTimeout: number;\n122:   /** Default viewport size */\n123:   defaultViewport: {\n124:     width: number;\n125:     height: number;\n126:   };\n127: }\n128: \n129: /** Configuration for the external agent registry (e.g. agency-agents) */\n130: export interface AgentRegistryConfig {\n131:   /**\n132:    * Download mode:\n133:    * - \"auto\"      — download agents without asking (default)\n134:    * - \"monitored\" — user reviews/edits/rejects each agent before launch\n135:    * - \"disabled\"  — always use the generalist agent\n136:    */\n137:   mode: AgentRegistryMode;\n138:   /** GitHub repo in \"owner/repo\" format to pull agent definitions from */\n139:   source: string;\n140:   /** Cache directory name (relative to .wombo-combo/) */\n141:   cacheDir: string;\n142:   /** Cache TTL in milliseconds. Cached agents older than this are re-fetched. Default 24h. */\n143:   cacheTTL: number;\n144: }\n145: \n146: /** Configuration for Test-Driven Development workflow */\n147: export interface TddConfig {\n148:   /** Enable TDD red-green-refactor instructions in agent prompts */\n149:   enabled: boolean;\n150:   /** Test command to run (default: \"bun test\") */\n151:   testCommand: string;\n152: }\n153: \n154: // ---------------------------------------------------------------------------\n155: // Defaults\n156: // ---------------------------------------------------------------------------\n157: \n158: export const DEFAULT_CONFIG: WomboConfig = {\n159:   tasksDir: \"tasks\",\n160:   archiveDir: \"archive\",\n161:   baseBranch: \"develop\",\n162:   build: {\n163:     command: \"bun run build\",\n164:     timeout: 300_000,\n165:     artifactDir: \"dist\",\n166:   },\n167:   install: {\n168:     command: \"bun install\",\n169:     timeout: 120_000,\n170:   },\n171:   git: {\n172:     branchPrefix: \"feature/\",\n173:     worktreePrefix: \"wombo-\",\n174:     remote: \"origin\",\n175:     mergeStrategy: \"--no-ff\",\n176:   },\n177:   agent: {\n178:     bin: null,\n179:     name: \"generalist-agent\",\n180:     configFiles: [\".opencode/\", \"opencode.json\", \"AGENTS.md\"],\n181:     tmuxPrefix: \"wombo\",\n182:     multiplexer: \"auto\",\n183:   },\n184:   portless: {\n185:     enabled: true,\n186:     bin: null,\n187:     proxyPort: 1355,\n188:     https: false,\n189:   },\n190:   backup: {\n191:     maxBackups: 5,\n192:   },\n193:   defaults: {\n194:     maxConcurrent: 6,\n195:     maxRetries: 2,\n196:   },\n197:   browser: {\n198:     enabled: false,\n199:     bin: null,\n200:     headless: true,\n201:     testCommand: null,\n202:     launchTimeout: 30_000,\n203:     testTimeout: 60_000,\n204:     defaultViewport: {\n205:       width: 1280,\n206:       height: 720,\n207:     },\n208:   },\n209:   agentRegistry: {\n210:     mode: \"auto\",\n211:     source: \"msitarzewski/agency-agents\",\n212:     cacheDir: \"agents-cache\",\n213:     cacheTTL: 24 * 60 * 60 * 1000, // 24 hours\n214:   },\n215:   tdd: {\n216:     enabled: false,\n217:     testCommand: \"bun test\",\n218:   },\n219: };\n220: \n221: // ---------------------------------------------------------------------------\n222: // Config File Name\n223: // ---------------------------------------------------------------------------\n224: \n225: export const CONFIG_FILE = `${WOMBO_DIR}/config.json`;\n226: \n227: // ---------------------------------------------------------------------------\n228: // Loader\n229: // ---------------------------------------------------------------------------\n230: \n231: /**\n232:  * Deep-merge source into target. Only merges plain objects, not arrays.\n233:  */\n234: function deepMerge<T extends Record<string, any>>(target: T, source: Partial<T>): T {\n235:   const result = { ...target };\n236:   for (const key of Object.keys(source) as (keyof T)[]) {\n237:     const srcVal = source[key];\n238:     const tgtVal = target[key];\n239:     if (\n240:       srcVal !== undefined &&\n241:       srcVal !== null &&\n242:       typeof srcVal === \"object\" &&\n243:       !Array.isArray(srcVal) &&\n244:       typeof tgtVal === \"object\" &&\n245:       !Array.isArray(tgtVal) &&\n246:       tgtVal !== null\n247:     ) {\n248:       result[key] = deepMerge(tgtVal as any, srcVal as any);\n249:     } else if (srcVal !== undefined) {\n250:       result[key] = srcVal as T[keyof T];\n251:     }\n252:   }\n253:   return result;\n254: }\n255: \n256: /**\n257:  * Load .wombo-combo/config.json from the given project root and merge with defaults.\n258:  * Returns the full config. If no config file exists, returns defaults.\n259:  */\n260: export function loadConfig(projectRoot: string): WomboConfig {\n261:   const configPath = resolve(projectRoot, CONFIG_FILE);\n262: \n263:   if (!existsSync(configPath)) {\n264:     return { ...DEFAULT_CONFIG };\n265:   }\n266: \n267:   try {\n268:     const raw = readFileSync(configPath, \"utf-8\");\n269:     const partial = JSON.parse(raw) as Partial<WomboConfig>;\n270: \n271:     // Migrate legacy single-file config keys to folder-based\n272:     if ((partial as any).tasksFile && !partial.tasksDir) {\n273:       // Legacy \"tasks.yml\" → strip extension for dir name, or use as-is\n274:       const legacy = (partial as any).tasksFile as string;\n275:       partial.tasksDir = legacy.replace(/\\.ya?ml$/i, \"\") || \"tasks\";\n276:       delete (partial as any).tasksFile;\n277:     }\n278:     if ((partial as any).archiveFile && !partial.archiveDir) {\n279:       const legacy = (partial as any).archiveFile as string;\n280:       partial.archiveDir = legacy.replace(/\\.ya?ml$/i, \"\") || \"archive\";\n281:       delete (partial as any).archiveFile;\n282:     }\n283: \n284:     return deepMerge(DEFAULT_CONFIG, partial);\n285:   } catch (err: any) {\n286:     throw new Error(`Failed to load ${CONFIG_FILE}: ${err.message}`);\n287:   }\n288: }\n289: \n290: /**\n291:  * Resolve the agent binary path. Priority:\n292:  *   1. config.agent.bin (explicit)\n293:  *   2. OPENCODE_BIN env var\n294:  *   3. ~/.opencode/bin/opencode (default install location)\n295:  */\n296: export function resolveAgentBin(config: WomboConfig): string {\n297:   if (config.agent.bin) return config.agent.bin;\n298:   if (process.env.OPENCODE_BIN) return process.env.OPENCODE_BIN;\n299:   return resolve(process.env.HOME || \"~\", \".opencode/bin/opencode\");\n300: }\n301: \n302: /**\n303:  * Validate the config for obvious issues. Throws on error.\n304:  */\n305: export function validateConfig(config: WomboConfig): void {\n306:   if (!config.tasksDir) {\n307:     throw new Error(\"config.tasksDir must be a non-empty string\");\n308:   }\n309:   if (!config.archiveDir) {\n310:     throw new Error(\"config.archiveDir must be a non-empty string\");\n311:   }\n312:   if (!config.baseBranch) {\n313:     throw new Error(\"config.baseBranch must be a non-empty string\");\n314:   }\n315:   if (!config.build.command) {\n316:     throw new Error(\"config.build.command must be a non-empty string\");\n317:   }\n318:   if (!config.install.command) {\n319:     throw new Error(\"config.install.command must be a non-empty string\");\n320:   }\n321:   if (!config.git.branchPrefix) {\n322:     throw new Error(\"config.git.branchPrefix must be a non-empty string\");\n323:   }\n324:   if (!config.git.worktreePrefix) {\n325:     throw new Error(\"config.git.worktreePrefix must be a non-empty string\");\n326:   }\n327:   if (config.defaults.maxConcurrent < 1) {\n328:     throw new Error(\"config.defaults.maxConcurrent must be >= 1\");\n329:   }\n330:   if (config.defaults.maxRetries < 0) {\n331:     throw new Error(\"config.defaults.maxRetries must be >= 0\");\n332:   }\n333:   if (config.backup.maxBackups < 0) {\n334:     throw new Error(\"config.backup.maxBackups must be >= 0\");\n335:   }\n336:   const validModes: AgentRegistryMode[] = [\"auto\", \"monitored\", \"disabled\"];\n337:   if (!validModes.includes(config.agentRegistry.mode)) {\n338:     throw new Error(`config.agentRegistry.mode must be one of: ${validModes.join(\", \")}`);\n339:   }\n340:   if (!config.agentRegistry.source) {\n341:     throw new Error(\"config.agentRegistry.source must be a non-empty string\");\n342:   }\n343:   if (!config.agentRegistry.cacheDir) {\n344:     throw new Error(\"config.agentRegistry.cacheDir must be a non-empty string\");\n345:   }\n346:   if (config.tdd.enabled && !config.tdd.testCommand) {\n347:     throw new Error(\"config.tdd.testCommand must be a non-empty string when TDD is enabled\");\n348:   }\n349: }\n350: \n351: /**\n352:  * Generate the default .wombo-combo/config.json content string (for `woco init`).\n353:  */\n354: export function generateDefaultConfig(): string {\n355:   return JSON.stringify(DEFAULT_CONFIG, null, 2) + \"\\n\";\n356: }\n\n(End of file - total 356 lines)\n</content>","title":"src/config.ts","metadata":{"preview":"/**\n * config.ts — Load .wombo-combo/config.json, merge with defaults, validate, expose typed config.\n *\n * The config file lives at .wombo-combo/config.json inside the target project root.\n * All values have sensible defaults so minimal config works out of the box.\n */\n\nimport { readFileSync, existsSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\nimport type { MultiplexerPreference } from \"./lib/multiplexer.js\";\n\n// ---------------------------------------------------------------------------\n// .wombo-combo directory constant\n// ---------------------------------------------------------------------------\n\n/** Name of the directory that holds all wombo-combo files */\nexport const WOMBO_DIR = \".wombo-combo\";\n\n// ---------------------------------------------------------------------------\n// Types","truncated":false,"loaded":[]},"time":{"start":1773435850030,"end":1773435850059}}}}
