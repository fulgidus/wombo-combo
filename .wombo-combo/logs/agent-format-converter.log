{"type":"tool_use","timestamp":1773435844382,"sessionID":"ses_316fcb99fffew5IdSvpvZvnqV0","part":{"id":"prt_ce90376c4002IiFQYI4Ahg4nvp","sessionID":"ses_316fcb99fffew5IdSvpvZvnqV0","messageID":"msg_ce9036cd1001XXwjk3pQYNwD9I","type":"tool","callID":"toolu_vrtx_01HSgwjkQmNsAt13K9wSY7nr","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-agent-format-converter/src/lib/templates.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-agent-format-converter/src/lib/templates.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * templates.ts — Resolve paths to bundled template files, render agent\n3:  * definitions, and compose patched agent definitions from imported agents.\n4:  *\n5:  * Template architecture:\n6:  *\n7:  *   generalist-agent.md          — standalone agent definition (no imported base)\n8:  *   wc-patch.description.end.md  — appended to imported agent's frontmatter description\n9:  *   wc-patch.body.start.md       — prepended to imported agent's body\n10:  *   wc-patch.body.end.md         — appended to imported agent's body\n11:  *\n12:  * Conditional blocks (portless, browser testing) are injected programmatically\n13:  * by the render/patch functions based on config — never left as \"if enabled\"\n14:  * prose for the LLM to interpret.\n15:  */\n16: \n17: import { join, dirname, resolve } from \"node:path\";\n18: import { existsSync, readFileSync, writeFileSync, mkdirSync } from \"node:fs\";\n19: import YAML from \"yaml\";\n20: import type { WomboConfig } from \"../config.js\";\n21: import { isPortlessAvailable } from \"./portless.js\";\n22: \n23: // ---------------------------------------------------------------------------\n24: // Template Directory & Paths\n25: // ---------------------------------------------------------------------------\n26: \n27: const TEMPLATES_DIR = join(dirname(import.meta.dir), \"templates\");\n28: \n29: /** Standalone generalist agent template. */\n30: export const GENERALIST_TEMPLATE_PATH = join(TEMPLATES_DIR, \"generalist-agent.md\");\n31: \n32: /** Patch: text appended to an imported agent's frontmatter `description` field. */\n33: export const PATCH_DESCRIPTION_END_PATH = join(TEMPLATES_DIR, \"wc-patch.description.end.md\");\n34: \n35: /** Patch: markdown prepended to an imported agent's body. */\n36: export const PATCH_BODY_START_PATH = join(TEMPLATES_DIR, \"wc-patch.body.start.md\");\n37: \n38: /** Patch: markdown appended to an imported agent's body. */\n39: export const PATCH_BODY_END_PATH = join(TEMPLATES_DIR, \"wc-patch.body.end.md\");\n40: \n41: /**\n42:  * Backward-compatible alias. Code that referenced `AGENT_TEMPLATE_PATH`\n43:  * continues to work — it now points to the generalist template.\n44:  */\n45: export const AGENT_TEMPLATE_PATH = GENERALIST_TEMPLATE_PATH;\n46: \n47: // ---------------------------------------------------------------------------\n48: // Deterministic Conditional Blocks\n49: // ---------------------------------------------------------------------------\n50: \n51: /**\n52:  * Portless server-testing block. Injected by render/patch functions ONLY when\n53:  * `config.portless.enabled` is true. The agent never sees \"if portless is\n54:  * enabled\" — it either gets these instructions or it doesn't.\n55:  */\n56: const PORTLESS_BLOCK = `\n57: ## Server Testing (portless)\n58: \n59: Your environment is preconfigured with **portless** for collision-free localhost servers:\n60: \n61: - **\\`PORTLESS_ENABLED=1\\`** is set in your environment.\n62: - **Do NOT hardcode port numbers.** Use \\`process.env.PORT\\` or let your framework pick a port automatically.\n63: - **Use \\`portless run <cmd>\\`** to start dev servers (e.g., \\`portless run bun start\\`). This auto-assigns a port and gives you a stable \\`.localhost\\` URL via \\`PORTLESS_URL\\`.\n64: - **Check \\`PORTLESS_URL\\`** in your environment for the stable URL assigned to your worktree's server.\n65: - Multiple agents can run dev servers simultaneously without port conflicts — portless handles routing through its proxy.\n66: - **Never hardcode port numbers.** Always use the portless-assigned port.\n67: `;\n68: \n69: /**\n70:  * TDD red-green-refactor block. Injected by render/patch functions ONLY when\n71:  * `config.tdd.enabled` is true. The agent never sees \"if TDD is enabled\" —\n72:  * it either gets these instructions or it doesn't.\n73:  *\n74:  * The `{{testCommand}}` placeholder is replaced at render time.\n75:  */\n76: const TDD_BLOCK = `\n77: ## Test-Driven Development (TDD)\n78: \n79: You MUST follow the **red-green-refactor** TDD cycle for all implementation work:\n80: \n81: ### The TDD Cycle\n82: \n83: 1. **🔴 Red — Write a failing test first**\n84:    - Before writing any implementation code, write a test that describes the desired behavior.\n85:    - Use Bun's built-in test runner. Create test files alongside source files using the \\`.test.ts\\` naming convention.\n86:    - The test MUST fail initially — this proves the test is actually testing something.\n87: \n88: 2. **🔴 Verify the test fails**\n89:    - Run \\`{{testCommand}}\\` and confirm the new test fails with the expected error.\n90:    - If the test passes without implementation, the test is not testing the right thing — rewrite it.\n91: \n92: 3. **🟢 Green — Write minimal code to pass**\n93:    - Implement just enough production code to make the failing test pass.\n94:    - Do NOT write more code than necessary to satisfy the test.\n95:    - Do NOT add features or handle edge cases not covered by a test yet.\n96: \n97: 4. **🟢 Verify the test passes**\n98:    - Run \\`{{testCommand}}\\` and confirm ALL tests pass (both new and existing).\n99:    - If any test fails, fix the implementation — do NOT modify the test to make it pass (unless the test itself is wrong).\n100: \n101: 5. **🔵 Refactor**\n102:    - Clean up the implementation while keeping all tests green.\n103:    - Extract helpers, rename variables, simplify logic — but run \\`{{testCommand}}\\` after each change.\n104:    - If a refactor breaks a test, undo the refactor and try a different approach.\n105: \n106: ### TDD Rules\n107: \n108: - **Never skip the red step.** Every new behavior starts with a failing test.\n109: - **One behavior per cycle.** Each red-green-refactor iteration should cover exactly one small behavior or edge case.\n110: - **Tests are first-class code.** Keep them readable, well-named, and focused.\n111: - **Run tests frequently.** Run \\`{{testCommand}}\\` after every meaningful change — not just at the end.\n112: - **Commit at green.** Each commit should have all tests passing. Use the cycle boundaries as natural commit points.\n113: \n114: ### Test File Conventions\n115: \n116: - Place test files next to the source: \\`src/foo.ts\\` → \\`src/foo.test.ts\\` (or \\`tests/foo.test.ts\\`)\n117: - Use descriptive test names: \\`test(\"returns empty array when input is null\", ...)\\`\n118: - Import from \\`bun:test\\`: \\`import { describe, test, expect } from \"bun:test\";\\`\n119: `;\n120: \n121: /**\n122:  * Build the TDD block with the configured test command substituted in.\n123:  */\n124: function buildTddBlock(config: WomboConfig): string {\n125:   return TDD_BLOCK.replace(/\\{\\{testCommand\\}\\}/g, config.tdd.testCommand);\n126: }\n127: \n128: // ---------------------------------------------------------------------------\n129: // Placeholder Substitution\n130: // ---------------------------------------------------------------------------\n131: \n132: /**\n133:  * Default runtime description used when no project-specific value is available.\n134:  */\n135: const DEFAULT_RUNTIME = \"Bun (not Node). TypeScript, strict mode, ESM only.\";\n136: \n137: /**\n138:  * Replace {{placeholders}} in template content with config-derived values.\n139:  *\n140:  * Supported placeholders:\n141:  *   - {{tasksFile}}      — tasks YAML filename (e.g. \"tasks.yml\")\n142:  *   - {{branchPrefix}}   — git branch prefix (e.g. \"feature/\")\n143:  *   - {{buildCommand}}   — build command (e.g. \"bun run build\")\n144:  *   - {{runtime}}        — project runtime description\n145:  *   - {{project}}        — project directory name\n146:  */\n147: function applyPlaceholders(\n148:   content: string,\n149:   config: WomboConfig,\n150:   projectRoot: string\n151: ): string {\n152:   const projectName = projectRoot.split(\"/\").pop() ?? \"project\";\n153:   return content\n154:     .replace(/\\{\\{tasksDir\\}\\}/g, config.tasksDir)\n155:     .replace(/\\{\\{branchPrefix\\}\\}/g, config.git.branchPrefix)\n156:     .replace(/\\{\\{buildCommand\\}\\}/g, config.build.command)\n157:     .replace(/\\{\\{runtime\\}\\}/g, DEFAULT_RUNTIME)\n158:     .replace(/\\{\\{project\\}\\}/g, projectName);\n159: }\n160: \n161: // ---------------------------------------------------------------------------\n162: // Frontmatter Parsing\n163: // ---------------------------------------------------------------------------\n164: \n165: /**\n166:  * Split a markdown file with YAML frontmatter into its two parts.\n167:  * Returns the raw YAML string (without delimiters) and the body.\n168:  */\n169: function splitFrontmatter(md: string): { yaml: string; body: string } {\n170:   const match = md.match(/^---\\r?\\n([\\s\\S]*?)\\r?\\n---\\r?\\n?([\\s\\S]*)$/);\n171:   if (!match) {\n172:     return { yaml: \"\", body: md };\n173:   }\n174:   return { yaml: match[1], body: match[2] };\n175: }\n176: \n177: /**\n178:  * Reassemble frontmatter YAML and body into a markdown string.\n179:  */\n180: function joinFrontmatter(yaml: string, body: string): string {\n181:   if (!yaml.trim()) return body;\n182:   return `---\\n${yaml.trimEnd()}\\n---\\n${body}`;\n183: }\n184: \n185: // ---------------------------------------------------------------------------\n186: // Generalist Agent Rendering\n187: // ---------------------------------------------------------------------------\n188: \n189: /**\n190:  * Render the standalone generalist agent template.\n191:  *\n192:  * This is the default agent definition for projects that don't import a\n193:  * specialized agent from an external registry. Portless instructions are\n194:  * injected deterministically based on config.\n195:  */\n196: export function renderGeneralistAgent(\n197:   config: WomboConfig,\n198:   projectRoot: string\n199: ): string {\n200:   let raw = readFileSync(GENERALIST_TEMPLATE_PATH, \"utf-8\");\n201: \n202:   // Deterministic portless injection\n203:   if (config.portless.enabled && isPortlessAvailable(config)) {\n204:     // Insert portless block before \"## What You Must Never Do\" (or at end)\n205:     const neverDoMarker = \"## What You Must Never Do\";\n206:     const idx = raw.indexOf(neverDoMarker);\n207:     if (idx !== -1) {\n208:       raw = raw.slice(0, idx) + PORTLESS_BLOCK + \"\\n\" + raw.slice(idx);\n209:     } else {\n210:       raw += \"\\n\" + PORTLESS_BLOCK;\n211:     }\n212:   }\n213: \n214:   // Deterministic TDD injection\n215:   if (config.tdd.enabled) {\n216:     const tddContent = buildTddBlock(config);\n217:     const neverDoMarker = \"## What You Must Never Do\";\n218:     const idx = raw.indexOf(neverDoMarker);\n219:     if (idx !== -1) {\n220:       raw = raw.slice(0, idx) + tddContent + \"\\n\" + raw.slice(idx);\n221:     } else {\n222:       raw += \"\\n\" + tddContent;\n223:     }\n224:   }\n225: \n226:   return applyPlaceholders(raw, config, projectRoot);\n227: }\n228: \n229: // ---------------------------------------------------------------------------\n230: // Imported Agent Patching\n231: // ---------------------------------------------------------------------------\n232: \n233: /**\n234:  * Patch an imported agent definition (e.g. from agency-agents) with\n235:  * wombo-combo operational context.\n236:  *\n237:  * Composition order:\n238:  *   1. Parse the imported agent's frontmatter and body\n239:  *   2. Append wc-patch.description.end to the `description` frontmatter field\n240:  *   3. Prepend wc-patch.body.start to the body\n241:  *   4. Append wc-patch.body.end to the body\n242:  *   5. Conditionally inject portless block (deterministic, based on config)\n243:  *   6. Apply {{placeholder}} substitution to the entire result\n244:  *\n245:  * @param rawAgentMd  — raw markdown content of the imported agent file\n246:  * @param config      — wombo-combo project config\n247:  * @param projectRoot — absolute path to the project root\n248:  */\n249: export function patchImportedAgent(\n250:   rawAgentMd: string,\n251:   config: WomboConfig,\n252:   projectRoot: string\n253: ): string {\n254:   const { yaml: rawYaml, body: rawBody } = splitFrontmatter(rawAgentMd);\n255: \n256:   // --- Patch frontmatter description ---\n257:   let patchedYaml = rawYaml;\n258:   if (rawYaml) {\n259:     try {\n260:       const descPatchRaw = readFileSync(PATCH_DESCRIPTION_END_PATH, \"utf-8\").trim();\n261:       if (descPatchRaw) {\n262:         const doc = YAML.parseDocument(rawYaml);\n263:         const currentDesc = doc.get(\"description\");\n264:         if (typeof currentDesc === \"string\") {\n265:           doc.set(\"description\", currentDesc.trimEnd() + \"\\n\\n\" + descPatchRaw);\n266:         } else {\n267:           // No description field — add one\n268:           doc.set(\"description\", descPatchRaw);\n269:         }\n270:         // Ensure mode is set for wombo-combo compatibility\n271:         if (!doc.has(\"mode\")) {\n272:           doc.set(\"mode\", \"primary\");\n273:         }\n274:         patchedYaml = YAML.stringify(doc, { lineWidth: 0 }).trimEnd();\n275:       }\n276:     } catch {\n277:       // Patch file missing or YAML parse error — proceed without patching\n278:     }\n279:   }\n280: \n281:   // --- Patch body ---\n282:   let patchedBody = rawBody;\n283: \n284:   // Prepend body.start\n285:   try {\n286:     const bodyStart = readFileSync(PATCH_BODY_START_PATH, \"utf-8\");\n287:     if (bodyStart.trim()) {\n288:       patchedBody = bodyStart + patchedBody;\n289:     }\n290:   } catch {\n291:     // Patch file missing — skip\n292:   }\n293: \n294:   // Append body.end\n295:   try {\n296:     const bodyEnd = readFileSync(PATCH_BODY_END_PATH, \"utf-8\");\n297:     if (bodyEnd.trim()) {\n298:       patchedBody = patchedBody.trimEnd() + \"\\n\" + bodyEnd;\n299:     }\n300:   } catch {\n301:     // Patch file missing — skip\n302:   }\n303: \n304:   // Deterministic portless injection (appended after body.end)\n305:   if (config.portless.enabled && isPortlessAvailable(config)) {\n306:     patchedBody = patchedBody.trimEnd() + \"\\n\" + PORTLESS_BLOCK;\n307:   }\n308: \n309:   // Deterministic TDD injection (appended after portless or body.end)\n310:   if (config.tdd.enabled) {\n311:     patchedBody = patchedBody.trimEnd() + \"\\n\" + buildTddBlock(config);\n312:   }\n313: \n314:   // --- Reassemble & substitute placeholders ---\n315:   const composed = joinFrontmatter(patchedYaml, patchedBody);\n316:   return applyPlaceholders(composed, config, projectRoot);\n317: }\n318: \n319: // ---------------------------------------------------------------------------\n320: // Backward Compatibility\n321: // ---------------------------------------------------------------------------\n322: \n323: /**\n324:  * Render the agent template. Backward-compatible wrapper around\n325:  * `renderGeneralistAgent` — existing code that calls this function\n326:  * continues to work unchanged.\n327:  */\n328: export function renderAgentTemplate(\n329:   config: WomboConfig,\n330:   projectRoot: string\n331: ): string {\n332:   return renderGeneralistAgent(config, projectRoot);\n333: }\n334: \n335: // ---------------------------------------------------------------------------\n336: // Agent Definition Guard\n337: // ---------------------------------------------------------------------------\n338: \n339: /**\n340:  * Ensure the agent definition file exists at the expected path.\n341:  * If missing, reinstall from the bundled generalist template and warn.\n342:  *\n343:  * Called at the start of `woco launch` to prevent the failure mode where\n344:  * agents spawn without their agent definition file.\n345:  *\n346:  * @returns true if the file was reinstalled, false if it already existed.\n347:  */\n348: export function ensureAgentDefinition(\n349:   projectRoot: string,\n350:   config: WomboConfig\n351: ): boolean {\n352:   const agentDir = resolve(projectRoot, \".opencode\", \"agents\");\n353:   const agentDefPath = resolve(agentDir, `${config.agent.name}.md`);\n354: \n355:   if (existsSync(agentDefPath)) {\n356:     return false;\n357:   }\n358: \n359:   // Agent definition missing — reinstall from bundled template\n360:   console.warn(\n361:     `\\x1b[33m[WARNING]\\x1b[0m Agent definition not found: .opencode/agents/${config.agent.name}.md`\n362:   );\n363:   console.warn(`  Reinstalling from bundled generalist template...`);\n364: \n365:   try {\n366:     mkdirSync(agentDir, { recursive: true });\n367:     const content = renderGeneralistAgent(config, projectRoot);\n368:     writeFileSync(agentDefPath, content, \"utf-8\");\n369:     console.warn(`  Restored .opencode/agents/${config.agent.name}.md\\n`);\n370:     return true;\n371:   } catch (err: any) {\n372:     console.error(\n373:       `  Failed to restore agent definition: ${err.message}`\n374:     );\n375:     console.error(\n376:       `  Agents may launch without their definition file.\\n`\n377:     );\n378:     return false;\n379:   }\n380: }\n\n(End of file - total 380 lines)\n</content>","title":"src/lib/templates.ts","metadata":{"preview":"/**\n * templates.ts — Resolve paths to bundled template files, render agent\n * definitions, and compose patched agent definitions from imported agents.\n *\n * Template architecture:\n *\n *   generalist-agent.md          — standalone agent definition (no imported base)\n *   wc-patch.description.end.md  — appended to imported agent's frontmatter description\n *   wc-patch.body.start.md       — prepended to imported agent's body\n *   wc-patch.body.end.md         — appended to imported agent's body\n *\n * Conditional blocks (portless, browser testing) are injected programmatically\n * by the render/patch functions based on config — never left as \"if enabled\"\n * prose for the LLM to interpret.\n */\n\nimport { join, dirname, resolve } from \"node:path\";\nimport { existsSync, readFileSync, writeFileSync, mkdirSync } from \"node:fs\";\nimport YAML from \"yaml\";\nimport type { WomboConfig } from \"../config.js\";","truncated":false,"loaded":[]},"time":{"start":1773435844378,"end":1773435844381}}}}
{"type":"tool_use","timestamp":1773435844801,"sessionID":"ses_316fcb99fffew5IdSvpvZvnqV0","part":{"id":"prt_ce903771b001h7N9hACdD6ORzK","sessionID":"ses_316fcb99fffew5IdSvpvZvnqV0","messageID":"msg_ce9036cd1001XXwjk3pQYNwD9I","type":"tool","callID":"toolu_vrtx_01S5nd3nM3kQAoghjcHQ1nMc","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-agent-format-converter/src/templates/generalist-agent.md"},"output":"<path>/home/fulgidus/Documents/wt-wombo-agent-format-converter/src/templates/generalist-agent.md</path>\n<type>file</type>\n<content>1: ---\n2: description: >-\n3:   Autonomous generalist coding agent launched by wombo-combo into isolated git\n4:   worktrees to implement tasks from {{tasksFile}}. Operates headlessly with\n5:   zero human interaction. Each task is a node in a recursive tree of identical\n6:   atomic jobs — the agent receives one task with its full subtree and implements\n7:   all subtasks depth-first.\n8: \n9:   Examples:\n10: \n11:   - user: \"Implement task cli-bugs from the backlog\"\n12:     assistant: \"I'll read the task spec from {{tasksFile}} and implement all subtasks.\"\n13: \n14:   - user: \"Fix the build errors from the last run\"\n15:     assistant: \"I'll read the build output, identify the failures, and fix them.\"\n16: mode: primary\n17: ---\n18: You are an autonomous coding agent launched by wombo-combo into an isolated git worktree.\n19: You implement tasks defined in `{{tasksFile}}` with zero human interaction.\n20: \n21: ## Task Structure\n22: \n23: Tasks form a **recursive tree**. Every node — whether a top-level task or a deeply\n24: nested subtask — has the identical schema: id, title, description, status, subtasks,\n25: constraints, forbidden, references, notes, effort, difficulty, priority, and\n26: dependencies. You receive one task with its full subtree and implement all nodes\n27: depth-first.\n28: \n29: ## Your Environment\n30: \n31: - You are in a **git worktree**, not the main repository. Your branch is `{{branchPrefix}}<task-id>`.\n32: - The task you must implement was passed to you as a prompt. It includes the full spec: description, subtasks, constraints, forbidden items, references, and build command.\n33: - Config files from the main repo (AGENTS.md, opencode config, this agent definition) have been copied into your worktree.\n34: - **Runtime:** {{runtime}}\n35: \n36: ## Operational Rules\n37: \n38: **You run headlessly. You MUST:**\n39: - NEVER ask questions or request clarification. Make reasonable decisions from context and code conventions.\n40: - NEVER enter plan mode or propose plans for approval. Execute directly.\n41: - NEVER wait for confirmation. Act decisively.\n42: - If ambiguity exists, examine the codebase for patterns and follow them.\n43: - If you encounter an error, debug and fix it yourself (up to 3 attempts per issue).\n44: \n45: ## Workflow\n46: \n47: 1. **Read the prompt** — it contains the full task spec from `{{tasksFile}}` including subtasks, constraints, and forbidden items.\n48: 2. **Read AGENTS.md** if present — it contains project-specific hard constraints and conventions.\n49: 3. **Explore the codebase** — understand the architecture before writing code. Read key files, follow imports, understand patterns.\n50: 4. **Plan with TodoWrite** — break the work into concrete steps.\n51: 5. **Implement subtasks in order** — commit after each logical unit of work.\n52: 6. **Typecheck** — run `bun run typecheck` (or the project's equivalent).\n53: 7. **Build** — run the build command from the prompt to verify everything compiles.\n54: 8. **Fix any failures** — if typecheck or build fails, fix and re-run until it passes.\n55: \n56: ## Commit Guidelines\n57: \n58: - Use conventional commits: `feat(scope):`, `fix(scope):`, `refactor(scope):`\n59: - Scope should be the task ID or a relevant module name\n60: - Commit after each logical unit of work (roughly per subtask)\n61: - Do NOT squash everything into one commit\n62: - Do NOT push to remote — the orchestrator handles that\n63: - Do NOT modify `{{tasksFile}}` — the orchestrator handles status updates\n64: \n65: ## Constraints\n66: \n67: - **Stay in scope.** Only implement the task you were assigned. Do not modify unrelated code.\n68: - **Respect the task's constraints and forbidden lists.** These are non-negotiable.\n69: - **Build must pass.** The orchestrator will verify your build. If it fails, you'll be retried with the error output.\n70: - **No new dependencies** unless the task spec explicitly requires them.\n71: - **Follow existing code style** — indentation, naming, patterns, module structure.\n72: \n73: ## Error Recovery\n74: \n75: If something fails:\n76: 1. Read error messages carefully and diagnose the root cause.\n77: 2. Check if the error is in your new code or pre-existing.\n78: 3. Attempt up to 3 fix-and-retry iterations per issue.\n79: 4. If truly blocked by an external factor, document the blocker in a commit message, implement what you can, and move on.\n80: 5. Never leave the worktree in a broken state — if you cannot complete a task, revert partial changes and document why.\n81: \n82: ## What You Must Never Do\n83: \n84: - Never ask for human input or confirmation\n85: - Never enter plan mode\n86: - Never modify files outside the scope of the current task\n87: - Never commit code that breaks the build\n88: - Never ignore errors without investigation\n89: - Never push to remote\n\n(End of file - total 89 lines)\n</content>","title":"src/templates/generalist-agent.md","metadata":{"preview":"---\ndescription: >-\n  Autonomous generalist coding agent launched by wombo-combo into isolated git\n  worktrees to implement tasks from {{tasksFile}}. Operates headlessly with\n  zero human interaction. Each task is a node in a recursive tree of identical\n  atomic jobs — the agent receives one task with its full subtree and implements\n  all subtasks depth-first.\n\n  Examples:\n\n  - user: \"Implement task cli-bugs from the backlog\"\n    assistant: \"I'll read the task spec from {{tasksFile}} and implement all subtasks.\"\n\n  - user: \"Fix the build errors from the last run\"\n    assistant: \"I'll read the build output, identify the failures, and fix them.\"\nmode: primary\n---\nYou are an autonomous coding agent launched by wombo-combo into an isolated git worktree.\nYou implement tasks defined in `{{tasksFile}}` with zero human interaction.\n","truncated":false,"loaded":[]},"time":{"start":1773435844787,"end":1773435844799}}}}
{"type":"tool_use","timestamp":1773435845408,"sessionID":"ses_316fcb99fffew5IdSvpvZvnqV0","part":{"id":"prt_ce90378b5001PqapaE72Frq6fW","sessionID":"ses_316fcb99fffew5IdSvpvZvnqV0","messageID":"msg_ce9036cd1001XXwjk3pQYNwD9I","type":"tool","callID":"toolu_vrtx_01TxDhPqbFXbsUnGHrubinNG","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-agent-format-converter/src/templates/_meta.yml"},"output":"<path>/home/fulgidus/Documents/wt-wombo-agent-format-converter/src/templates/_meta.yml</path>\n<type>file</type>\n<content>1: # =============================================================================\n2: # WOMBO COMBO! — Task Store Metadata (_meta.yml)\n3: # =============================================================================\n4: #\n5: # This file lives at: .wombo-combo/<tasks|archive>/_meta.yml\n6: # Sibling files: one <task-id>.yml per task (see TASK SCHEMA below).\n7: #\n8: # REQUIRED FIELDS:\n9: #   version    : string — Schema version (currently \"1.0\").\n10: #   meta       : object — Metadata about this task store.\n11: #     created_at  : string — ISO 8601 datetime when the store was created.\n12: #     updated_at  : string — ISO 8601 datetime, auto-updated on every write.\n13: #     project     : string — Project name.\n14: #     generator   : string — Tool that created this file (always \"wombo-combo\").\n15: #     maintainer  : string — Primary maintainer handle or email.\n16: #\n17: # TASK FILE SCHEMA (<task-id>.yml):\n18: #   Each task file is a plain YAML mapping with these fields:\n19: #\n20: #   id          : string        — Unique kebab-case identifier (1-128 chars).\n21: #   title       : string        — Human-readable short name.\n22: #   description : string        — Detailed explanation of the task's goal.\n23: #   status      : enum          — backlog | planned | in_progress | blocked |\n24: #                                  in_review | done | cancelled\n25: #   completion  : integer       — Percentage 0-100.\n26: #   difficulty  : enum          — trivial | easy | medium | hard | very_hard\n27: #   priority    : enum          — critical | high | medium | low | wishlist\n28: #   depends_on  : list[string]  — IDs of tasks that must complete first.\n29: #   effort      : string        — ISO 8601 duration (e.g. \"PT2H\", \"P1D\").\n30: #   started_at  : string|null   — ISO 8601 datetime or null.\n31: #   ended_at    : string|null   — ISO 8601 datetime or null.\n32: #   constraints : list[string]  — Technical or process constraints.\n33: #   forbidden   : list[string]  — Explicitly forbidden approaches.\n34: #   references  : list[string]  — URLs or file paths for relevant docs.\n35: #   notes       : list[string]  — Free-form updates (newest first).\n36: #   subtasks    : list[task]    — Always [] in folder-based storage (legacy).\n37: #   agent_type  : string|null   — Optional agent type from registry.\n38: #\n39: # =============================================================================\n40: \n41: version: \"1.0\"\n42: \n43: meta:\n44:   created_at: \"{{created_at}}\"\n45:   updated_at: \"{{updated_at}}\"\n46:   project: \"{{project}}\"\n47:   generator: \"wombo-combo\"\n48:   maintainer: \"{{maintainer}}\"\n\n(End of file - total 48 lines)\n</content>","title":"src/templates/_meta.yml","metadata":{"preview":"# =============================================================================\n# WOMBO COMBO! — Task Store Metadata (_meta.yml)\n# =============================================================================\n#\n# This file lives at: .wombo-combo/<tasks|archive>/_meta.yml\n# Sibling files: one <task-id>.yml per task (see TASK SCHEMA below).\n#\n# REQUIRED FIELDS:\n#   version    : string — Schema version (currently \"1.0\").\n#   meta       : object — Metadata about this task store.\n#     created_at  : string — ISO 8601 datetime when the store was created.\n#     updated_at  : string — ISO 8601 datetime, auto-updated on every write.\n#     project     : string — Project name.\n#     generator   : string — Tool that created this file (always \"wombo-combo\").\n#     maintainer  : string — Primary maintainer handle or email.\n#\n# TASK FILE SCHEMA (<task-id>.yml):\n#   Each task file is a plain YAML mapping with these fields:\n#\n#   id          : string        — Unique kebab-case identifier (1-128 chars).","truncated":false,"loaded":[]},"time":{"start":1773435845258,"end":1773435845375}}}}
