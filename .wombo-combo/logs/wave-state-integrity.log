{"type":"tool_use","timestamp":1773482772745,"sessionID":"ses_314328d09ffeHamS8Go5GE0ezF","part":{"id":"prt_cebcf87b5001vSWQSic0l61GIA","sessionID":"ses_314328d09ffeHamS8Go5GE0ezF","messageID":"msg_cebcf7b610017scM4jvy4Q1vPH","type":"tool","callID":"toolu_vrtx_01LUy6bT9K77YNhydpUm9BMk","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/wave-state-integrity/src/commands/launch.ts","offset":1407},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/wave-state-integrity/src/commands/launch.ts</path>\n<type>file</type>\n<content>1407:   }\n1408: }\n1409: \n1410: // ---------------------------------------------------------------------------\n1411: // Interactive Wave Launch\n1412: // ---------------------------------------------------------------------------\n1413: \n1414: async function launchWaveInteractive(\n1415:   projectRoot: string,\n1416:   state: WaveState,\n1417:   features: Feature[],\n1418:   opts: LaunchCommandOptions,\n1419:   agentResolutions?: Map<string, AgentResolution>,\n1420:   questContext?: QuestPromptContext,\n1421:   hitlMode?: string\n1422: ): Promise<void> {\n1423:   const { config, model } = opts;\n1424:   const fmt = opts.outputFmt ?? \"text\";\n1425:   const featureMap = new Map(features.map((f) => [f.id, f]));\n1426: \n1427:   // Show dashboard immediately\n1428:   if (fmt === \"text\") printDashboard(state);\n1429: \n1430:   // Launch initial batch — parallelize setup\n1431:   const tolaunch = queuedAgents(state).slice(0, opts.maxConcurrent);\n1432:   if (fmt === \"text\") console.log(`Setting up ${tolaunch.length} agent(s) in parallel...\\n`);\n1433: \n1434:   await Promise.all(\n1435:     tolaunch.map(async (agent) => {\n1436:       updateAgent(state, agent.feature_id, {\n1437:         status: \"installing\",\n1438:         started_at: new Date().toISOString(),\n1439:         activity: \"setting up worktree...\",\n1440:       });\n1441:       saveState(projectRoot, state);\n1442: \n1443:       try {\n1444:         if (worktreeReady(agent.worktree)) {\n1445:           wtLog(agent.feature_id, \"worktree already exists, skipping setup\");\n1446:         } else {\n1447:           await createWorktree(projectRoot, agent.feature_id, state.base_branch, config);\n1448:           updateAgent(state, agent.feature_id, { activity: \"installing deps...\" });\n1449:           await installDeps(agent.worktree, agent.feature_id, config);\n1450:         }\n1451: \n1452:         const prompt = generatePrompt(\n1453:           featureMap.get(agent.feature_id)!,\n1454:           state.base_branch,\n1455:           config,\n1456:           questContext,\n1457:           hitlMode as QuestHitlMode | undefined\n1458:         );\n1459: \n1460:         // Write specialized agent to worktree if applicable\n1461:         const resolution = agentResolutions?.get(agent.feature_id);\n1462:         const agentName = agent.agent_name ?? undefined;\n1463:         if (resolution && isSpecializedAgent(resolution)) {\n1464:           try {\n1465:             const patchedContent = patchImportedAgent(resolution.rawContent, config, projectRoot);\n1466:             writeAgentToWorktree(agent.worktree, resolution.name, patchedContent);\n1467:             wtLog(agent.feature_id, `wrote specialized agent: ${resolution.name}`);\n1468:           } catch (err: any) {\n1469:             wtLog(agent.feature_id, `WARN: failed to write specialized agent, using generalist: ${err.message}`);\n1470:           }\n1471:         }\n1472: \n1473:         wtLog(agent.feature_id, \"launching interactive session...\");\n1474:         const result = launchInteractive({\n1475:           worktreePath: agent.worktree,\n1476:           featureId: agent.feature_id,\n1477:           prompt,\n1478:           model,\n1479:           interactive: true,\n1480:           config,\n1481:           agentName,\n1482:         });\n1483: \n1484:         const muxName = getMultiplexerName(config);\n1485:         updateAgent(state, agent.feature_id, {\n1486:           status: \"running\",\n1487:           pid: result.pid,\n1488:           activity: `${muxName} session active`,\n1489:         });\n1490:         saveState(projectRoot, state);\n1491:         wtLog(agent.feature_id, `${muxName} session: ${config.agent.tmuxPrefix}-${agent.feature_id}`);\n1492:       } catch (err: any) {\n1493:         updateAgent(state, agent.feature_id, {\n1494:           status: \"failed\",\n1495:           error: err.message,\n1496:           activity: null,\n1497:           completed_at: new Date().toISOString(),\n1498:         });\n1499:         saveState(projectRoot, state);\n1500:         wtLog(agent.feature_id, `SETUP FAILED: ${err.message.split(\"\\n\")[0]}`);\n1501:       }\n1502:     })\n1503:   );\n1504: \n1505:   const mux = detectMultiplexer(config.agent.multiplexer);\n1506:   const muxName = getMultiplexerName(config);\n1507:   if (fmt === \"text\") {\n1508:     console.log(\"\\nInteractive sessions launched. Use these commands:\");\n1509:     console.log(`  ${muxAttachCommand(mux, `${config.agent.tmuxPrefix}-<feature-id>`)}   # attach to a session`);\n1510:     console.log(`  ${muxListCommand(mux)}${\" \".repeat(Math.max(1, 54 - muxListCommand(mux).length))}# list sessions`);\n1511:     console.log(\"  woco status                                             # check status\");\n1512:     console.log(\"  woco verify                                             # verify builds\");\n1513:     console.log(\"  woco merge                                              # merge verified\");\n1514:     console.log(\"  woco cleanup                                            # remove worktrees\");\n1515: \n1516:     printDashboard(state);\n1517:   }\n1518: }\n1519: \n1520: // ---------------------------------------------------------------------------\n1521: // Main Command\n1522: // ---------------------------------------------------------------------------\n1523: \n1524: export async function cmdLaunch(opts: LaunchCommandOptions): Promise<void> {\n1525:   const { projectRoot } = opts;\n1526:   let { config } = opts;\n1527:   const fmt = opts.outputFmt ?? \"text\";\n1528: \n1529:   if (fmt === \"text\") console.log(\"\\n--- wombo-combo: Launch ---\\n\");\n1530: \n1531:   // Ensure agent definition exists — reinstall from template if missing\n1532:   ensureAgentDefinition(projectRoot, config, opts.agent);\n1533: \n1534:   // -------------------------------------------------------------------------\n1535:   // Quest resolution — if --quest was specified, scope the wave to that quest\n1536:   // -------------------------------------------------------------------------\n1537:   let questContext: QuestPromptContext | undefined;\n1538:   let questId: string | null = opts.questId ?? null;\n1539: \n1540:   if (questId) {\n1541:     const quest = loadQuest(projectRoot, questId);\n1542:     if (!quest) {\n1543:       outputError(fmt, `Quest \"${questId}\" not found. Use 'woco quest list' to see available quests.`);\n1544:       return; // unreachable\n1545:     }\n1546: \n1547:     if (quest.status !== \"active\") {\n1548:       outputError(fmt, `Quest \"${questId}\" is in status \"${quest.status}\" — only active quests can be launched. Use 'woco quest activate ${questId}' first.`);\n1549:       return; // unreachable\n1550:     }\n1551: \n1552:     // Ensure the quest branch exists (create from baseBranch if needed)\n1553:     if (!questBranchExists(projectRoot, questId)) {\n1554:       if (fmt === \"text\") console.log(`Creating quest branch \"${quest.branch}\" from \"${quest.baseBranch}\"...`);\n1555:       createQuestBranch(projectRoot, questId, quest.baseBranch);\n1556:     }\n1557: \n1558:     // Override baseBranch — task branches will fork from the quest branch\n1559:     opts.baseBranch = quest.branch;\n1560:     if (fmt === \"text\") {\n1561:       console.log(`Quest: ${quest.title} (${questId})`);\n1562:       console.log(`  Base branch overridden to: ${quest.branch}`);\n1563:     }\n1564: \n1565:     // Apply quest config overrides (layered on top of project config)\n1566:     config = resolveQuestConfig(config, quest);\n1567: \n1568:     // Build quest prompt context for agent prompts\n1569:     const knowledge = loadQuestKnowledge(projectRoot, questId);\n1570:     questContext = {\n1571:       questId: quest.id,\n1572:       goal: quest.goal,\n1573:       addedConstraints: quest.constraints.add ?? [],\n1574:       addedForbidden: quest.constraints.ban ?? [],\n1575:       knowledge,\n1576:     };\n1577: \n1578:     if (fmt === \"text\") {\n1579:       const constraintCount = questContext.addedConstraints.length + questContext.addedForbidden.length;\n1580:       if (constraintCount > 0) {\n1581:         console.log(`  Quest constraints: ${questContext.addedConstraints.length} added, ${questContext.addedForbidden.length} banned`);\n1582:       }\n1583:       if (knowledge) {\n1584:         console.log(`  Quest knowledge: loaded (${knowledge.length} bytes)`);\n1585:       }\n1586:       console.log(\"\");\n1587:     }\n1588:   }\n1589: \n1590:   // Extract HITL mode from quest (defaults to undefined / yolo for non-quest waves)\n1591:   const hitlMode = questId ? loadQuest(projectRoot, questId)?.hitlMode : undefined;\n1592: \n1593:   // Ensure portless proxy is running (if enabled) to prevent port collisions\n1594:   if (config.portless.enabled) {\n1595:     if (isPortlessAvailable(config)) {\n1596:       const proxyOk = ensureProxyRunning(config);\n1597:       if (!proxyOk && fmt === \"text\") {\n1598:         console.warn(\n1599:           \"\\x1b[33m[portless]\\x1b[0m proxy could not be started — agents may encounter port collisions\"\n1600:         );\n1601:       }\n1602:     } else if (fmt === \"text\") {\n1603:       console.warn(\n1604:         \"\\x1b[33m[portless]\\x1b[0m enabled but not installed. Install with: npm install -g portless\"\n1605:       );\n1606:       console.warn(\n1607:         \"  Agents will run without portless — concurrent dev servers may have port collisions.\\n\"\n1608:       );\n1609:     }\n1610:   }\n1611: \n1612:   // -------------------------------------------------------------------------\n1613:   // Validate that the configured baseBranch exists as a local branch\n1614:   // -------------------------------------------------------------------------\n1615:   if (!branchExists(projectRoot, opts.baseBranch)) {\n1616:     const msg = `Base branch \"${opts.baseBranch}\" does not exist as a local branch. ` +\n1617:       `Create it first (e.g. \"git checkout -b ${opts.baseBranch}\") or specify ` +\n1618:       `a different branch with --base-branch.`;\n1619:     outputError(fmt, msg);\n1620:   }\n1621: \n1622:   // -------------------------------------------------------------------------\n1623:   // Check for existing wave state — don't overwrite work in progress\n1624:   // -------------------------------------------------------------------------\n1625:   const existingState = loadState(projectRoot);\n1626:   if (existingState) {\n1627:     const merged = existingState.agents.filter((a) => a.status === \"merged\");\n1628:     const verified = existingState.agents.filter((a) => a.status === \"verified\");\n1629:     const completed = existingState.agents.filter((a) => a.status === \"completed\");\n1630:     const running = existingState.agents.filter((a) => a.status === \"running\");\n1631:     const queued = existingState.agents.filter((a) => a.status === \"queued\");\n1632:     const failed = existingState.agents.filter((a) => a.status === \"failed\");\n1633: \n1634:     const hasWork = merged.length > 0 || verified.length > 0 || completed.length > 0 || running.length > 0;\n1635: \n1636:     if (hasWork) {\n1637:       if (fmt === \"text\") {\n1638:         console.log(`Existing wave found: ${existingState.wave_id}`);\n1639:         console.log(`  ${merged.length} merged, ${verified.length} verified, ${completed.length} completed, ${running.length} running, ${queued.length} queued, ${failed.length} failed`);\n1640:       }\n1641: \n1642:       // Finalize any merged agents by marking their features as done\n1643:       const finalizedIds: string[] = [];\n1644:       if (merged.length > 0) {\n1645:         if (fmt === \"text\") console.log(\"\\nFinalizing merged tasks in tasks file...\");\n1646:         for (const agent of merged) {\n1647:           markFeatureDone(projectRoot, agent.feature_id, config, existingState.base_branch, fmt);\n1648:           finalizedIds.push(agent.feature_id);\n1649:           // Clean up worktree and branch (already merged, safe to delete)\n1650:           try {\n1651:             removeWorktree(projectRoot, agent.worktree, true);\n1652:             if (fmt === \"text\") console.log(`  ${agent.feature_id}: marked done, worktree removed`);\n1653:           } catch {\n1654:             if (fmt === \"text\") console.log(`  ${agent.feature_id}: marked done (worktree already cleaned)`);\n1655:           }\n1656:         }\n1657:       }\n1658: \n1659:       // Strip finalized task IDs from explicit selection so we don't\n1660:       // try to re-launch tasks that were just marked done\n1661:       if (finalizedIds.length > 0 && opts.features?.length) {\n1662:         const finalizedSet = new Set(finalizedIds);\n1663:         opts.features = opts.features.filter((id) => !finalizedSet.has(id));\n1664:       }\n1665: \n1666:       // Verified agents: build passed but NOT merged — do NOT mark done.\n1667:       // Leave them for 'woco resume' to attempt the merge.\n1668:       if (verified.length > 0) {\n1669:         for (const agent of verified) {\n1670:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: verified (not yet merged) — use 'woco resume' to merge`);\n1671:         }\n1672:       }\n1673: \n1674:       const activeCount = running.length + completed.length + queued.length;\n1675:       if (activeCount > 0) {\n1676:         outputError(fmt, `Wave ${existingState.wave_id} has ${activeCount} unfinished agent(s). Use 'woco resume' to continue the existing wave, or 'woco cleanup' to clear it before starting a new one.`);\n1677:       }\n1678: \n1679:       // All agents are in terminal states (merged/verified/failed) — safe to start fresh\n1680:       if (fmt === \"text\") console.log(\"\\nAll agents in previous wave are finished. Starting fresh wave.\\n\");\n1681:     }\n1682:   }\n1683: \n1684:   // Load features\n1685:   const data = loadFeatures(projectRoot, config);\n1686: \n1687:   // Build selection options\n1688:   const selOpts: SelectionOptions = {};\n1689:   if (opts.topPriority) selOpts.topPriority = opts.topPriority;\n1690:   if (opts.quickestWins) selOpts.quickestWins = opts.quickestWins;\n1691:   if (opts.priority) selOpts.priority = opts.priority;\n1692:   if (opts.difficulty) selOpts.difficulty = opts.difficulty;\n1693:   if (opts.features) selOpts.taskIds = opts.features;\n1694:   if (opts.allReady) selOpts.allReady = true;\n1695: \n1696:   // Select features\n1697:   let selected = selectFeatures(data, selOpts);\n1698: \n1699:   if (selected.length === 0) {\n1700:     // Build a context-aware message based on which flags were passed\n1701:     const activeFilters: string[] = [];\n1702:     if (opts.allReady) activeFilters.push(\"--all-ready\");\n1703:     if (opts.topPriority) activeFilters.push(`--top-priority ${opts.topPriority}`);\n1704:     if (opts.quickestWins) activeFilters.push(`--quickest-wins ${opts.quickestWins}`);\n1705:     if (opts.priority) activeFilters.push(`--priority ${opts.priority}`);\n1706:     if (opts.difficulty) activeFilters.push(`--difficulty ${opts.difficulty}`);\n1707:     if (opts.features?.length) activeFilters.push(`--tasks ${opts.features.join(\",\")}`);\n1708: \n1709:     let msg: string;\n1710:     if (opts.allReady && activeFilters.length === 1) {\n1711:       msg = \"No launchable tasks found (all tasks are done, cancelled, or have unmet dependencies).\";\n1712:     } else if (activeFilters.length > 0) {\n1713:       msg = `No tasks matched the current filters: ${activeFilters.join(\", \")}.`;\n1714:     } else {\n1715:       msg = \"No launchable tasks found.\";\n1716:     }\n1717: \n1718:     // Throw instead of outputError so TUI callers can catch gracefully.\n1719:     // CLI callers catch this in the command handler (index.ts).\n1720:     throw new Error(msg);\n1721:   }\n1722: \n1723:   // Apply quest constraints to selected tasks (add/ban layered on each task)\n1724:   if (questId && questContext) {\n1725:     const quest = loadQuest(projectRoot, questId)!;\n1726:     selected = selected.map((f) => applyQuestConstraintsToTask(f, quest));\n1727:   }\n1728: \n1729:   // Show selection\n1730:   if (fmt === \"text\") {\n1731:     printFeatureSelection(\n1732:       selected.map((f) => ({\n1733:         id: f.id,\n1734:         title: f.title,\n1735:         priority: f.priority,\n1736:         difficulty: f.difficulty,\n1737:         effort: f.effort,\n1738:       }))\n1739:     );\n1740:   }\n1741: \n1742:   // Check per-task agent definitions exist\n1743:   if (!opts.agent) {\n1744:     const taskAgents = new Set(\n1745:       selected.map((f) => f.agent).filter((a): a is string => !!a)\n1746:     );\n1747:     for (const agentName of taskAgents) {\n1748:       ensureAgentDefinition(projectRoot, config, agentName);\n1749:     }\n1750:   }\n1751: \n1752:   // ---------------------------------------------------------------------------\n1753:   // Dependency graph analysis\n1754:   // ---------------------------------------------------------------------------\n1755:   const depGraph = buildDepGraph(selected, data.tasks);\n1756:   let schedulePlan: SchedulePlan | null = null;\n1757: \n1758:   // Check if any features actually have dependencies within the selected set\n1759:   const hasDeps = selected.some(\n1760:     (f) => f.depends_on.some((d) => selected.find((s) => s.id === d))\n1761:   );\n1762: \n1763:   if (hasDeps) {\n1764:     // Validate graph — throws on cycles or dangling deps\n1765:     try {\n1766:       validateDepGraph(depGraph);\n1767:     } catch (err: any) {\n1768:       outputError(fmt, `${err.message}\\nFix dependency issues before launching.`);\n1769:     }\n1770: \n1771:     // Build scheduling plan\n1772:     schedulePlan = buildSchedulePlan(depGraph);\n1773:     if (fmt === \"text\") console.log(`\\n${formatSchedulePlan(schedulePlan)}\\n`);\n1774:   }\n1775: \n1776:   if (opts.dryRun) {\n1777:     const dryRunResult = {\n1778:       dry_run: true,\n1779:       base_branch: opts.baseBranch,\n1780:       max_concurrent: opts.maxConcurrent,\n1781:       model: opts.model ?? null,\n1782:       interactive: opts.interactive,\n1783:       selected: selected.map((f) => ({\n1784:         id: f.id,\n1785:         title: f.title,\n1786:         priority: f.priority,\n1787:         difficulty: f.difficulty,\n1788:         effort: f.effort,\n1789:       })),\n1790:       schedule_plan: schedulePlan ? {\n1791:         streams: schedulePlan.streams.map((s) => s.featureIds),\n1792:         merge_gates: schedulePlan.mergeGates.map((g) => ({\n1793:           feature_id: g.featureId,\n1794:           wait_for: g.waitFor,\n1795:         })),\n1796:         topological_order: schedulePlan.topologicalOrder,\n1797:       } : null,\n1798:     };\n1799: \n1800:     output(fmt, dryRunResult, () => {\n1801:       console.log(\"Dry run — not launching agents.\");\n1802:     }, () => {\n1803:       console.log(renderLaunchDryRun(dryRunResult));\n1804:     });\n1805:     return;\n1806:   }\n1807: \n1808:   // ---------------------------------------------------------------------------\n1809:   // Agent registry: resolve specialized agents for tasks with agent_type\n1810:   // ---------------------------------------------------------------------------\n1811:   let agentResolutions: Map<string, AgentResolution> | undefined;\n1812: \n1813:   if (config.agentRegistry.mode !== \"disabled\") {\n1814:     const tasksWithAgentType = selected.filter((t) => t.agent_type);\n1815:     if (tasksWithAgentType.length > 0) {\n1816:       if (fmt === \"text\") console.log(`\\nResolving ${tasksWithAgentType.length} specialized agent(s) from registry...`);\n1817:       agentResolutions = await prepareAgentDefinitions(selected, config, projectRoot);\n1818: \n1819:       const specialized = [...agentResolutions.values()].filter(isSpecializedAgent);\n1820:       const cached = specialized.filter((r) => r.fromCache);\n1821:       if (fmt === \"text\") {\n1822:         console.log(\n1823:           `  ${specialized.length} specialized (${cached.length} cached, ${specialized.length - cached.length} fetched), ` +\n1824:           `${selected.length - specialized.length} generalist`\n1825:         );\n1826:       }\n1827:     }\n1828:   }\n1829: \n1830:   // ---------------------------------------------------------------------------\n1831:   // Preflight confirmation\n1832:   // ---------------------------------------------------------------------------\n1833:   if (agentResolutions && agentResolutions.size > 0) {\n1834:     const isTTY = process.stdout.isTTY && process.stdin.isTTY;\n1835:     const preflight = isTTY && !opts.noTui\n1836:       ? await tuiPreflightConfirm(selected, agentResolutions, config)\n1837:       : await consolePreflightConfirm(selected, agentResolutions, config);\n1838: \n1839:     if (!preflight.proceed) {\n1840:       outputMessage(fmt, \"Launch cancelled.\");\n1841:       return;\n1842:     }\n1843: \n1844:     // Apply user's changes (rejected agents, mode changes)\n1845:     agentResolutions = preflight.agents;\n1846:   }\n1847: \n1848:   // Create wave state\n1849:   const state = createWaveState({\n1850:     baseBranch: opts.baseBranch,\n1851:     maxConcurrent: opts.maxConcurrent,\n1852:     model: opts.model ?? null,\n1853:     interactive: opts.interactive,\n1854:     questId,\n1855:   });\n1856: \n1857:   // Store serialized schedule plan in wave state\n1858:   if (schedulePlan) {\n1859:     state.schedule_plan = {\n1860:       streams: schedulePlan.streams.map((s) => s.featureIds),\n1861:       merge_gates: schedulePlan.mergeGates.map((g) => ({\n1862:         feature_id: g.featureId,\n1863:         wait_for: g.waitFor,\n1864:       })),\n1865:       topological_order: schedulePlan.topologicalOrder,\n1866:     };\n1867:   }\n1868: \n1869:   // Create agent entries for all selected features\n1870:   const selectedIds = new Set(selected.map((f) => f.id));\n1871: \n1872:   // Build a map from feature ID → shared worktree path for chain reuse.\n1873:   // All features in the same chain share the worktree of the chain's first feature.\n1874:   const chainWorktreeMap = new Map<string, string>();\n1875:   if (schedulePlan) {\n1876:     for (const stream of schedulePlan.streams) {\n1877:       if (stream.featureIds.length > 1) {\n1878:         // All features in this chain share the first feature's worktree\n1879:         const sharedWtPath = worktreePath(projectRoot, stream.featureIds[0], config);\n1880:         for (const featureId of stream.featureIds) {\n1881:           chainWorktreeMap.set(featureId, sharedWtPath);\n1882:         }\n1883:       }\n1884:     }\n1885:   }\n1886: \n1887:   for (const feature of selected) {\n1888:     const branch = featureBranchName(feature.id, config);\n1889:     // Use shared worktree path for chain members, or individual path otherwise\n1890:     const wtPath = chainWorktreeMap.get(feature.id) ?? worktreePath(projectRoot, feature.id, config);\n1891:     const agent = createAgentState(feature.id, branch, wtPath, opts.maxRetries);\n1892: \n1893:     // Set effort estimate from feature spec\n1894:     const effortMinutes = parseDurationMinutes(feature.effort);\n1895:     agent.effort_estimate_ms = effortMinutes === Infinity ? null : effortMinutes * 60 * 1000;\n1896: \n1897:     // Populate dependency fields from the graph\n1898:     const graphNode = depGraph.nodes.get(feature.id);\n1899:     if (graphNode) {\n1900:       // Only track internal deps (within the selected set)\n1901:       agent.depends_on = graphNode.dependsOn.filter((d) => selectedIds.has(d));\n1902:       agent.depended_on_by = graphNode.dependedOnBy.filter((d) => selectedIds.has(d));\n1903:     }\n1904: \n1905:     // Set stream index\n1906:     if (schedulePlan) {\n1907:       agent.stream_index = getStreamForFeature(schedulePlan, feature.id);\n1908:     }\n1909: \n1910:     // Set specialized agent info from resolution\n1911:     const resolution = agentResolutions?.get(feature.id);\n1912:     if (resolution && isSpecializedAgent(resolution)) {\n1913:       agent.agent_name = resolution.name;\n1914:       agent.agent_type = resolution.agentType;\n1915:     }\n1916: \n1917:     // Per-task local agent override: CLI --agent flag takes precedence,\n1918:     // then task-level `agent` field, then registry resolution (above).\n1919:     // This is for local agent definitions in .opencode/agents/<name>.md.\n1920:     const localAgent = opts.agent ?? feature.agent;\n1921:     if (localAgent && !agent.agent_name) {\n1922:       // Only set if not already resolved from the external registry\n1923:       agent.agent_name = localAgent;\n1924:     } else if (opts.agent) {\n1925:       // CLI --agent flag overrides even registry agents\n1926:       agent.agent_name = opts.agent;\n1927:     }\n1928: \n1929:     state.agents.push(agent);\n1930:   }\n1931: \n1932:   saveState(projectRoot, state);\n1933:   if (fmt === \"text\") console.log(`Wave ${state.wave_id} created with ${selected.length} agents.`);\n1934: \n1935:   // Launch agents up to max_concurrent\n1936:   if (opts.interactive) {\n1937:     await launchWaveInteractive(projectRoot, state, selected, opts, agentResolutions, questContext, hitlMode);\n1938:   } else {\n1939:     await launchWaveHeadless(projectRoot, state, selected, opts, agentResolutions, questContext, hitlMode);\n1940:   }\n1941: }\n\n(End of file - total 1941 lines)\n</content>","title":"src/commands/launch.ts","metadata":{"preview":"  }\n}\n\n// ---------------------------------------------------------------------------\n// Interactive Wave Launch\n// ---------------------------------------------------------------------------\n\nasync function launchWaveInteractive(\n  projectRoot: string,\n  state: WaveState,\n  features: Feature[],\n  opts: LaunchCommandOptions,\n  agentResolutions?: Map<string, AgentResolution>,\n  questContext?: QuestPromptContext,\n  hitlMode?: string\n): Promise<void> {\n  const { config, model } = opts;\n  const fmt = opts.outputFmt ?? \"text\";\n  const featureMap = new Map(features.map((f) => [f.id, f]));\n","truncated":false,"loaded":[]},"time":{"start":1773482772737,"end":1773482772743}}}}
