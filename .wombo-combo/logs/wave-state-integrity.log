{"type":"tool_use","timestamp":1773482644035,"sessionID":"ses_314328d09ffeHamS8Go5GE0ezF","part":{"id":"prt_cebcd919c001RBuMKyREgUt7S0","sessionID":"ses_314328d09ffeHamS8Go5GE0ezF","messageID":"msg_cebcd888f0017LC1oxP6eHTgo1","type":"tool","callID":"toolu_vrtx_01GC6MwZ49VTF4G5cLYcPCsv","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/wave-state-integrity/src/lib/state.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/wave-state-integrity/src/lib/state.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * state.ts — Persistent wave state management.\n3:  *\n4:  * Responsibilities:\n5:  *   - Define the shape of .wombo-combo/state.json\n6:  *   - Read/write state atomically\n7:  *   - Generate wave IDs\n8:  *   - Update individual agent state within a wave\n9:  */\n10: \n11: import { readFileSync, writeFileSync, existsSync, renameSync, mkdirSync } from \"node:fs\";\n12: import { resolve } from \"node:path\";\n13: import { WOMBO_DIR } from \"../config.js\";\n14: \n15: // ---------------------------------------------------------------------------\n16: // Types\n17: // ---------------------------------------------------------------------------\n18: \n19: export type AgentStatus =\n20:   | \"queued\"\n21:   | \"installing\"\n22:   | \"running\"\n23:   | \"completed\"\n24:   | \"verified\"\n25:   | \"failed\"\n26:   | \"merged\"\n27:   | \"retry\"\n28:   | \"resolving_conflict\";\n29: \n30: export interface AgentState {\n31:   feature_id: string;\n32:   branch: string;\n33:   worktree: string;\n34:   session_id: string | null;\n35:   pid: number | null;\n36:   status: AgentStatus;\n37:   activity: string | null;\n38:   activity_updated_at: string | null;\n39:   retries: number;\n40:   max_retries: number;\n41:   started_at: string | null;\n42:   completed_at: string | null;\n43:   build_passed: boolean | null;\n44:   build_output: string | null;\n45:   error: string | null;\n46:   /** Estimated effort in milliseconds (from feature's ISO 8601 duration) */\n47:   effort_estimate_ms: number | null;\n48:   /** Stream index this agent belongs to (for dependency-aware scheduling) */\n49:   stream_index: number | null;\n50:   /** IDs of features this agent depends on (within the current wave) */\n51:   depends_on: string[];\n52:   /** IDs of features that depend on this agent (within the current wave) */\n53:   depended_on_by: string[];\n54:   /**\n55:    * Override agent name for this specific agent (from registry).\n56:    * When set, uses this agent definition instead of the default generalist.\n57:    * e.g. \"engineering-frontend-developer\"\n58:    */\n59:   agent_name: string | null;\n60:   /**\n61:    * The agent_type from the task (e.g. \"engineering/engineering-frontend-developer\").\n62:    * Stored for informational purposes and to support resume with re-fetch.\n63:    */\n64:   agent_type: string | null;\n65: }\n66: \n67: export interface WaveState {\n68:   wave_id: string;\n69:   base_branch: string;\n70:   started_at: string;\n71:   updated_at: string;\n72:   max_concurrent: number;\n73:   model: string | null;\n74:   interactive: boolean;\n75:   agents: AgentState[];\n76:   /** Dependency-aware scheduling plan (null if no dependencies exist) */\n77:   schedule_plan: SerializedSchedulePlan | null;\n78:   /** Quest ID this wave belongs to (null if not quest-scoped) */\n79:   quest_id: string | null;\n80: }\n81: \n82: /**\n83:  * Serialized schedule plan stored in wave state JSON.\n84:  * Uses plain arrays instead of the rich SchedulePlan type for JSON compatibility.\n85:  */\n86: export interface SerializedSchedulePlan {\n87:   /** Streams: each is a list of feature IDs to execute sequentially */\n88:   streams: string[][];\n89:   /** Merge gates: features that must wait for multiple deps from different streams */\n90:   merge_gates: Array<{ feature_id: string; wait_for: string[] }>;\n91:   /** Topological order of all features */\n92:   topological_order: string[];\n93: }\n94: \n95: // ---------------------------------------------------------------------------\n96: // Constants\n97: // ---------------------------------------------------------------------------\n98: \n99: const STATE_FILE = \".wombo-combo/state.json\";\n100: \n101: // ---------------------------------------------------------------------------\n102: // Wave ID Generation\n103: // ---------------------------------------------------------------------------\n104: \n105: /**\n106:  * Generate a unique wave ID based on current timestamp.\n107:  * Format: wave-YYYY-MM-DD-NNN\n108:  */\n109: export function generateWaveId(): string {\n110:   const now = new Date();\n111:   const date = now.toISOString().slice(0, 10);\n112:   const seq = String(now.getHours() * 60 + now.getMinutes()).padStart(3, \"0\");\n113:   return `wave-${date}-${seq}`;\n114: }\n115: \n116: // ---------------------------------------------------------------------------\n117: // State Path\n118: // ---------------------------------------------------------------------------\n119: \n120: function statePath(projectRoot: string): string {\n121:   return resolve(projectRoot, STATE_FILE);\n122: }\n123: \n124: // ---------------------------------------------------------------------------\n125: // Read State\n126: // ---------------------------------------------------------------------------\n127: \n128: /**\n129:  * Load the current wave state from disk. Returns null if no state file exists.\n130:  */\n131: export function loadState(projectRoot: string): WaveState | null {\n132:   const p = statePath(projectRoot);\n133:   if (!existsSync(p)) return null;\n134:   try {\n135:     const raw = readFileSync(p, \"utf-8\");\n136:     return JSON.parse(raw) as WaveState;\n137:   } catch {\n138:     return null;\n139:   }\n140: }\n141: \n142: // ---------------------------------------------------------------------------\n143: // Write State\n144: // ---------------------------------------------------------------------------\n145: \n146: /**\n147:  * Save wave state to disk atomically (write to tmp then rename).\n148:  */\n149: export function saveState(projectRoot: string, state: WaveState): void {\n150:   const dir = resolve(projectRoot, WOMBO_DIR);\n151:   if (!existsSync(dir)) mkdirSync(dir, { recursive: true });\n152:   state.updated_at = new Date().toISOString();\n153:   const p = statePath(projectRoot);\n154:   const tmp = p + \".tmp\";\n155:   writeFileSync(tmp, JSON.stringify(state, null, 2) + \"\\n\", \"utf-8\");\n156:   renameSync(tmp, p);\n157: }\n158: \n159: // ---------------------------------------------------------------------------\n160: // State Mutations\n161: // ---------------------------------------------------------------------------\n162: \n163: /**\n164:  * Create a fresh wave state.\n165:  */\n166: export function createWaveState(opts: {\n167:   baseBranch: string;\n168:   maxConcurrent: number;\n169:   model: string | null;\n170:   interactive: boolean;\n171:   questId?: string | null;\n172: }): WaveState {\n173:   return {\n174:     wave_id: generateWaveId(),\n175:     base_branch: opts.baseBranch,\n176:     started_at: new Date().toISOString(),\n177:     updated_at: new Date().toISOString(),\n178:     max_concurrent: opts.maxConcurrent,\n179:     model: opts.model,\n180:     interactive: opts.interactive,\n181:     agents: [],\n182:     schedule_plan: null,\n183:     quest_id: opts.questId ?? null,\n184:   };\n185: }\n186: \n187: /**\n188:  * Create an initial agent state for a feature.\n189:  */\n190: export function createAgentState(\n191:   featureId: string,\n192:   branch: string,\n193:   worktreePath: string,\n194:   maxRetries: number = 2\n195: ): AgentState {\n196:   return {\n197:     feature_id: featureId,\n198:     branch,\n199:     worktree: worktreePath,\n200:     session_id: null,\n201:     pid: null,\n202:     status: \"queued\",\n203:     activity: null,\n204:     activity_updated_at: null,\n205:     retries: 0,\n206:     max_retries: maxRetries,\n207:     started_at: null,\n208:     completed_at: null,\n209:     build_passed: null,\n210:     build_output: null,\n211:     error: null,\n212:     effort_estimate_ms: null,\n213:     stream_index: null,\n214:     depends_on: [],\n215:     depended_on_by: [],\n216:     agent_name: null,\n217:     agent_type: null,\n218:   };\n219: }\n220: \n221: /**\n222:  * Find an agent state by feature ID.\n223:  */\n224: export function getAgent(\n225:   state: WaveState,\n226:   featureId: string\n227: ): AgentState | undefined {\n228:   return state.agents.find((a) => a.feature_id === featureId);\n229: }\n230: \n231: /**\n232:  * Update an agent's state fields.\n233:  */\n234: export function updateAgent(\n235:   state: WaveState,\n236:   featureId: string,\n237:   updates: Partial<AgentState>\n238: ): void {\n239:   const agent = state.agents.find((a) => a.feature_id === featureId);\n240:   if (!agent) throw new Error(`Agent not found for feature: ${featureId}`);\n241:   Object.assign(agent, updates);\n242: }\n243: \n244: /**\n245:  * Get counts of agents by status.\n246:  */\n247: export function agentCounts(state: WaveState): Record<AgentStatus, number> {\n248:   const counts: Record<AgentStatus, number> = {\n249:     queued: 0,\n250:     installing: 0,\n251:     running: 0,\n252:     completed: 0,\n253:     verified: 0,\n254:     failed: 0,\n255:     merged: 0,\n256:     retry: 0,\n257:     resolving_conflict: 0,\n258:   };\n259:   for (const a of state.agents) {\n260:     counts[a.status]++;\n261:   }\n262:   return counts;\n263: }\n264: \n265: /**\n266:  * Get agents that are currently running or installing.\n267:  */\n268: export function activeAgents(state: WaveState): AgentState[] {\n269:   return state.agents.filter(\n270:     (a) => a.status === \"running\" || a.status === \"installing\" || a.status === \"resolving_conflict\"\n271:   );\n272: }\n273: \n274: /**\n275:  * Get agents that are queued and ready to be launched.\n276:  */\n277: export function queuedAgents(state: WaveState): AgentState[] {\n278:   return state.agents.filter((a) => a.status === \"queued\");\n279: }\n280: \n281: /**\n282:  * Check if the wave is fully complete (no queued, installing, running, or retry agents).\n283:  */\n284: export function isWaveComplete(state: WaveState): boolean {\n285:   return state.agents.every(\n286:     (a) =>\n287:       a.status === \"completed\" ||\n288:       a.status === \"verified\" ||\n289:       a.status === \"failed\" ||\n290:       a.status === \"merged\"\n291:   );\n292: }\n293: \n294: // ---------------------------------------------------------------------------\n295: // Dependency-Aware Helpers\n296: // ---------------------------------------------------------------------------\n297: \n298: /**\n299:  * Terminal statuses that count as \"dependency satisfied\" for downstream features.\n300:  * A dependency is satisfied when it has been verified or merged.\n301:  */\n302: const DEP_SATISFIED_STATUSES: Set<AgentStatus> = new Set([\"verified\", \"merged\"]);\n303: \n304: /**\n305:  * Check if an agent's dependencies within the wave are all satisfied.\n306:  * Dependencies are satisfied when their agents reach \"verified\" or \"merged\" status.\n307:  *\n308:  * If the agent has no depends_on entries, it's always ready.\n309:  */\n310: export function areAgentDepsReady(\n311:   state: WaveState,\n312:   agent: AgentState\n313: ): boolean {\n314:   if (agent.depends_on.length === 0) return true;\n315: \n316:   for (const depId of agent.depends_on) {\n317:     const depAgent = state.agents.find((a) => a.feature_id === depId);\n318:     if (depAgent && !DEP_SATISFIED_STATUSES.has(depAgent.status)) {\n319:       return false;\n320:     }\n321:     // If depAgent doesn't exist in this wave, the dep is external — assumed satisfied\n322:   }\n323:   return true;\n324: }\n325: \n326: /**\n327:  * Get queued agents whose dependencies are all satisfied.\n328:  * This is the dependency-aware replacement for plain queuedAgents().\n329:  */\n330: export function readyToLaunchAgents(state: WaveState): AgentState[] {\n331:   return state.agents.filter(\n332:     (a) => a.status === \"queued\" && areAgentDepsReady(state, a)\n333:   );\n334: }\n335: \n336: /**\n337:  * Get all agents that are downstream (depend on) a given feature, directly or transitively.\n338:  * Used for failure cascading — when a feature fails, cancel all downstream.\n339:  */\n340: export function getDownstreamAgents(\n341:   state: WaveState,\n342:   featureId: string\n343: ): AgentState[] {\n344:   const visited = new Set<string>();\n345:   const result: AgentState[] = [];\n346: \n347:   function collect(id: string): void {\n348:     const agent = state.agents.find((a) => a.feature_id === id);\n349:     if (!agent) return;\n350: \n351:     for (const downstreamId of agent.depended_on_by) {\n352:       if (visited.has(downstreamId)) continue;\n353:       visited.add(downstreamId);\n354: \n355:       const downstream = state.agents.find((a) => a.feature_id === downstreamId);\n356:       if (downstream) {\n357:         result.push(downstream);\n358:         collect(downstreamId);\n359:       }\n360:     }\n361:   }\n362: \n363:   collect(featureId);\n364:   return result;\n365: }\n366: \n367: /**\n368:  * Cancel all downstream agents when an upstream dependency fails.\n369:  * Sets status to \"failed\" with an error explaining the dependency failure.\n370:  * Returns the list of cancelled agent IDs.\n371:  */\n372: export function cancelDownstream(\n373:   state: WaveState,\n374:   failedFeatureId: string\n375: ): string[] {\n376:   const downstream = getDownstreamAgents(state, failedFeatureId);\n377:   const cancelled: string[] = [];\n378: \n379:   for (const agent of downstream) {\n380:     // Only cancel agents that haven't already reached a terminal state\n381:     if (\n382:       agent.status === \"queued\" ||\n383:       agent.status === \"installing\" ||\n384:       agent.status === \"running\" ||\n385:       agent.status === \"retry\"\n386:     ) {\n387:       updateAgent(state, agent.feature_id, {\n388:         status: \"failed\",\n389:         error: `Dependency \"${failedFeatureId}\" failed — downstream cancelled`,\n390:         activity: null,\n391:         completed_at: new Date().toISOString(),\n392:       });\n393:       cancelled.push(agent.feature_id);\n394:     }\n395:   }\n396: \n397:   return cancelled;\n398: }\n\n(End of file - total 398 lines)\n</content>","title":"src/lib/state.ts","metadata":{"preview":"/**\n * state.ts — Persistent wave state management.\n *\n * Responsibilities:\n *   - Define the shape of .wombo-combo/state.json\n *   - Read/write state atomically\n *   - Generate wave IDs\n *   - Update individual agent state within a wave\n */\n\nimport { readFileSync, writeFileSync, existsSync, renameSync, mkdirSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\nimport { WOMBO_DIR } from \"../config.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type AgentStatus =\n  | \"queued\"","truncated":false,"loaded":[]},"time":{"start":1773482644030,"end":1773482644034}}}}
{"type":"tool_use","timestamp":1773482644832,"sessionID":"ses_314328d09ffeHamS8Go5GE0ezF","part":{"id":"prt_cebcd923f00124ZxMRko7xuicP","sessionID":"ses_314328d09ffeHamS8Go5GE0ezF","messageID":"msg_cebcd888f0017LC1oxP6eHTgo1","type":"tool","callID":"toolu_vrtx_01DG14dG67WjTvhYn9a45zD8","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/wave-state-integrity/src/lib/monitor.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/wave-state-integrity/src/lib/monitor.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * monitor.ts — Parse JSON events from agent and detect completion/failure.\n3:  *\n4:  * Responsibilities:\n5:  *   - Parse newline-delimited JSON events from agent stdout\n6:  *   - Detect session completion (agent finished)\n7:  *   - Detect session ID from events\n8:  *   - Detect errors and failures\n9:  *   - Write per-agent raw log files for diagnostics\n10:  *   - Maintain per-agent parsed activity log for TUI preview\n11:  *\n12:  * ## Process Lifecycle (audit: wave-detach-audit)\n13:  *\n14:  * ProcessMonitor manages the lifecycle of headless agent child processes:\n15:  *\n16:  * **Normal flow**: Agent stdout → JSON event parsing → callbacks → completion\n17:  *   1. `addProcess()` registers a ChildProcess and attaches stdout/stderr listeners\n18:  *   2. Stdout data is parsed line-by-line as JSON events\n19:  *   3. Callbacks fire: `onSessionId`, `onActivity`, `onComplete`, `onError`\n20:  *   4. On process exit (code 0 or sawFinalStop), `onComplete` is called\n21:  *   5. On process exit (non-zero, no final stop), `onError` is called\n22:  *\n23:  * **Teardown flow**: Parent quit → `killAll()` → SIGTERM to each child\n24:  *   1. TUI `onQuit` or SIGINT handler calls `monitor.killAll()`\n25:  *   2. `killAll()` iterates all processes and calls `remove(featureId)`\n26:  *   3. `remove()` sends SIGTERM to the child process (if still running)\n27:  *   4. The process map entry is deleted — no further events are tracked\n28:  *\n29:  * **Key behavior**: `remove()` and `killAll()` intentionally kill child\n30:  * processes. This is correct because headless agents are spawned with\n31:  * `detached: false` — they are tied to the parent and would die anyway\n32:  * when the parent exits. Explicitly killing them ensures a clean shutdown\n33:  * with proper state saving before the parent terminates.\n34:  *\n35:  * **Edge case**: If the parent is killed with SIGKILL (not catchable),\n36:  * child processes die with no cleanup. `woco resume` handles this by\n37:  * detecting orphaned worktrees with commits and re-verifying/re-launching.\n38:  */\n39: \n40: import type { ChildProcess } from \"node:child_process\";\n41: import { isProcessRunning } from \"./launcher.js\";\n42: import { mkdirSync, appendFileSync, existsSync } from \"node:fs\";\n43: import { resolve } from \"node:path\";\n44: import { TokenCollector, type UsageRecord } from \"./token-collector.js\";\n45: \n46: // ---------------------------------------------------------------------------\n47: // Log directory name (configurable would be overkill here)\n48: // ---------------------------------------------------------------------------\n49: \n50: const LOG_DIR_NAME = \".wombo-combo/logs\";\n51: \n52: // ---------------------------------------------------------------------------\n53: // Types — OpenCode JSON Events\n54: // ---------------------------------------------------------------------------\n55: \n56: export interface OpenCodeEvent {\n57:   type: string;\n58:   sessionID?: string;\n59:   timestamp?: number;\n60:   part?: {\n61:     type?: string;\n62:     tool?: string;\n63:     callID?: string;\n64:     text?: string;\n65:     reason?: string;\n66:     cost?: number;\n67:     tokens?: {\n68:       total: number;\n69:       input: number;\n70:       output: number;\n71:       reasoning: number;\n72:       cache?: {\n73:         read: number;\n74:         write: number;\n75:       };\n76:     };\n77:     state?: {\n78:       status?: string;\n79:       input?: Record<string, any>;\n80:       output?: string;\n81:       error?: string;\n82:     };\n83:   };\n84:   [key: string]: any;\n85: }\n86: \n87: // ---------------------------------------------------------------------------\n88: // Event Parser\n89: // ---------------------------------------------------------------------------\n90: \n91: export interface ParsedOutput {\n92:   sessionId: string | null;\n93:   completed: boolean;\n94:   errored: boolean;\n95:   lastError: string | null;\n96:   events: OpenCodeEvent[];\n97: }\n98: \n99: export function parseEvents(rawOutput: string): ParsedOutput {\n100:   const result: ParsedOutput = {\n101:     sessionId: null,\n102:     completed: false,\n103:     errored: false,\n104:     lastError: null,\n105:     events: [],\n106:   };\n107: \n108:   const lines = rawOutput.split(\"\\n\").filter((l) => l.trim());\n109: \n110:   for (const line of lines) {\n111:     try {\n112:       const event = JSON.parse(line) as OpenCodeEvent;\n113:       result.events.push(event);\n114: \n115:       if (event.sessionID && !result.sessionId) {\n116:         result.sessionId = event.sessionID;\n117:       }\n118: \n119:       if (\n120:         event.type === \"step_finish\" &&\n121:         event.part?.reason === \"stop\"\n122:       ) {\n123:         result.completed = true;\n124:       }\n125: \n126:       if (\n127:         event.type === \"tool_use\" &&\n128:         event.part?.state?.status === \"error\"\n129:       ) {\n130:         result.errored = true;\n131:         result.lastError = event.part.state.error ?? \"unknown tool error\";\n132:       }\n133:     } catch {\n134:       // Not valid JSON — skip\n135:     }\n136:   }\n137: \n138:   return result;\n139: }\n140: \n141: // ---------------------------------------------------------------------------\n142: // Activity Extraction\n143: // ---------------------------------------------------------------------------\n144: \n145: function shortPath(fullPath: string | undefined, maxLen: number = 30): string {\n146:   if (!fullPath) return \"\";\n147:   const parts = fullPath.replace(/^\\/+/, \"\").split(\"/\");\n148:   const short =\n149:     parts.length > 1\n150:       ? parts.slice(-2).join(\"/\")\n151:       : parts[parts.length - 1];\n152:   if (short.length <= maxLen) return short;\n153:   const fname = parts[parts.length - 1];\n154:   return fname.length <= maxLen ? fname : fname.slice(0, maxLen - 1) + \"\\u2026\";\n155: }\n156: \n157: function shortCmd(cmd: string | undefined, maxLen: number = 30): string {\n158:   if (!cmd) return \"\";\n159:   const first = cmd.split(\"\\n\")[0].trim();\n160:   if (first.length <= maxLen) return first;\n161:   return first.slice(0, maxLen - 1) + \"\\u2026\";\n162: }\n163: \n164: /**\n165:  * Map an event to a human-readable activity string.\n166:  */\n167: export function extractActivity(event: OpenCodeEvent): string | null {\n168:   switch (event.type) {\n169:     case \"step_start\":\n170:       return \"thinking\\u2026\";\n171: \n172:     case \"tool_use\": {\n173:       const toolName = (event.part?.tool ?? \"\").toLowerCase();\n174:       const input = event.part?.state?.input ?? {};\n175:       const status = event.part?.state?.status ?? \"\";\n176: \n177:       if (status === \"error\") {\n178:         return `${toolName}: error`;\n179:       }\n180: \n181:       switch (toolName) {\n182:         case \"read\":\n183:           return `reading ${shortPath(input.filePath ?? input.path)}`;\n184:         case \"write\":\n185:           return `writing ${shortPath(input.filePath ?? input.path)}`;\n186:         case \"edit\":\n187:           return `editing ${shortPath(input.filePath ?? input.path)}`;\n188:         case \"bash\":\n189:         case \"command\":\n190:         case \"terminal\": {\n191:           const cmd = input.command ?? input.cmd ?? \"\";\n192:           // Detect HITL ask script invocation\n193:           if (cmd.includes(\"hitl-ask\")) {\n194:             return \"waiting for human…\";\n195:           }\n196:           return `$ ${shortCmd(cmd)}`;\n197:         }\n198:         case \"glob\":\n199:           return `finding: ${shortPath(input.pattern)}`;\n200:         case \"grep\":\n201:         case \"search\":\n202:           return `searching: ${(input.pattern ?? \"\").slice(0, 25)}`;\n203:         case \"task\":\n204:           return \"delegating task\\u2026\";\n205:         case \"webfetch\":\n206:         case \"web_fetch\":\n207:           return \"fetching URL\\u2026\";\n208:         case \"todowrite\":\n209:         case \"todo_write\":\n210:           return \"planning\\u2026\";\n211:         case \"question\":\n212:           return \"asking question\\u2026\";\n213:         case \"jcodemunch_index_folder\":\n214:         case \"jcodemunch_index_repo\":\n215:           return \"indexing code\\u2026\";\n216:         case \"jcodemunch_search_symbols\":\n217:         case \"jcodemunch_search_text\":\n218:           return \"searching symbols\\u2026\";\n219:         case \"jcodemunch_get_file_outline\":\n220:           return `outlining ${shortPath(input.file_path)}`;\n221:         case \"jcodemunch_get_symbol\":\n222:         case \"jcodemunch_get_symbols\":\n223:           return \"reading symbol\\u2026\";\n224:         default:\n225:           return `tool: ${toolName}`;\n226:       }\n227:     }\n228: \n229:     case \"text\":\n230:       return \"responding\\u2026\";\n231: \n232:     case \"step_finish\":\n233:       if (event.part?.reason === \"stop\") return \"done\";\n234:       if (event.part?.reason === \"tool-calls\") return null;\n235:       return null;\n236: \n237:     default:\n238:       return null;\n239:   }\n240: }\n241: \n242: /**\n243:  * Format an event into a human-readable log line for the activity stream.\n244:  */\n245: export function formatEventForLog(event: OpenCodeEvent): string | null {\n246:   switch (event.type) {\n247:     case \"step_start\":\n248:       return \"-- step started\";\n249: \n250:     case \"tool_use\": {\n251:       const toolName = event.part?.tool ?? \"unknown\";\n252:       const input = event.part?.state?.input ?? {};\n253:       const status = event.part?.state?.status ?? \"\";\n254:       const output = event.part?.state?.output ?? \"\";\n255:       const error = event.part?.state?.error ?? \"\";\n256: \n257:       let line = `>> ${toolName}`;\n258:       switch (toolName.toLowerCase()) {\n259:         case \"read\":\n260:           line = `>> read ${shortPath(input.filePath ?? input.path, 50)}`;\n261:           break;\n262:         case \"write\":\n263:           line = `>> write ${shortPath(input.filePath ?? input.path, 50)}`;\n264:           break;\n265:         case \"edit\":\n266:           line = `>> edit ${shortPath(input.filePath ?? input.path, 50)}`;\n267:           break;\n268:         case \"bash\":\n269:         case \"command\":\n270:           line = `>> $ ${shortCmd(input.command ?? input.cmd, 60)}`;\n271:           break;\n272:         case \"glob\":\n273:           line = `>> glob ${input.pattern ?? \"\"}`;\n274:           break;\n275:         case \"grep\":\n276:           line = `>> grep \"${(input.pattern ?? \"\").slice(0, 30)}\"`;\n277:           break;\n278:         case \"task\":\n279:           line = `>> task: ${(input.description ?? input.prompt ?? \"\").slice(0, 50)}`;\n280:           break;\n281:       }\n282: \n283:       if (status === \"completed\" && output) {\n284:         const preview = output.split(\"\\n\")[0].slice(0, 80);\n285:         return `${line}\\n   ${preview}${output.length > 80 ? \"\\u2026\" : \"\"}`;\n286:       }\n287:       if (status === \"error\" && error) {\n288:         return `${line}\\n!! ${error.slice(0, 100)}`;\n289:       }\n290:       return line;\n291:     }\n292: \n293:     case \"text\": {\n294:       const text = event.part?.text ?? \"\";\n295:       if (!text.trim()) return null;\n296:       const firstLine = text.split(\"\\n\").find((l: string) => l.trim())?.trim() ?? \"\";\n297:       if (firstLine.length === 0) return null;\n298:       return `   ${firstLine.slice(0, 120)}${firstLine.length > 120 ? \"\\u2026\" : \"\"}`;\n299:     }\n300: \n301:     case \"step_finish\": {\n302:       const reason = event.part?.reason ?? \"\";\n303:       const tokens = event.part?.tokens;\n304:       if (reason === \"stop\") {\n305:         let tokStr = \"\";\n306:         if (tokens) {\n307:           const parts = [`${tokens.input}in`, `${tokens.output}out`];\n308:           if (tokens.cache?.read) parts.push(`${tokens.cache.read}cache`);\n309:           tokStr = ` (${parts.join(\"/\")})`;\n310:         }\n311:         return `-- done${tokStr}`;\n312:       }\n313:       return null;\n314:     }\n315: \n316:     default:\n317:       return null;\n318:   }\n319: }\n320: \n321: // ---------------------------------------------------------------------------\n322: // Per-agent Activity Log (in-memory ring buffer for TUI)\n323: // ---------------------------------------------------------------------------\n324: \n325: export interface ActivityEntry {\n326:   timestamp: string;\n327:   text: string;\n328: }\n329: \n330: const MAX_ACTIVITY_LINES = 500;\n331: \n332: // ---------------------------------------------------------------------------\n333: // Process Monitor\n334: // ---------------------------------------------------------------------------\n335: \n336: export interface MonitorCallbacks {\n337:   onSessionId?: (featureId: string, sessionId: string) => void;\n338:   onComplete?: (featureId: string) => void;\n339:   onError?: (featureId: string, error: string) => void;\n340:   onOutput?: (featureId: string, data: string) => void;\n341:   onActivity?: (featureId: string, activity: string) => void;\n342:   /** Called when an agent asks a human question via HITL */\n343:   onQuestion?: (featureId: string, questionText: string) => void;\n344:   /** Called when token usage data is parsed from a step_finish event */\n345:   onUsage?: (featureId: string, record: UsageRecord) => void;\n346: }\n347: \n348: interface MonitoredProcess {\n349:   featureId: string;\n350:   process: ChildProcess;\n351:   stdout: string;\n352:   stderr: string;\n353:   sessionId: string | null;\n354:   done: boolean;\n355:   lineBuffer: string;\n356:   sawFinalStop: boolean;\n357: }\n358: \n359: /**\n360:  * Monitor a set of headless agent processes.\n361:  * Collects stdout, parses events, and calls callbacks on state changes.\n362:  */\n363: export class ProcessMonitor {\n364:   private processes: Map<string, MonitoredProcess> = new Map();\n365:   private callbacks: MonitorCallbacks;\n366:   private logDir: string;\n367:   /** Per-agent activity log for TUI preview pane */\n368:   public activityLogs: Map<string, ActivityEntry[]> = new Map();\n369:   /** Token usage collector — parses and accumulates usage from step_finish events */\n370:   public tokenCollector: TokenCollector;\n371: \n372:   constructor(projectRoot: string, callbacks: MonitorCallbacks = {}) {\n373:     this.callbacks = callbacks;\n374:     this.logDir = resolve(projectRoot, LOG_DIR_NAME);\n375:     if (!existsSync(this.logDir)) {\n376:       mkdirSync(this.logDir, { recursive: true });\n377:     }\n378:     this.tokenCollector = new TokenCollector((record) => {\n379:       this.callbacks.onUsage?.(record.task_id, record);\n380:     });\n381:   }\n382: \n383:   private pushActivity(featureId: string, text: string): void {\n384:     if (!this.activityLogs.has(featureId)) {\n385:       this.activityLogs.set(featureId, []);\n386:     }\n387:     const log = this.activityLogs.get(featureId)!;\n388:     for (const line of text.split(\"\\n\")) {\n389:       log.push({ timestamp: new Date().toISOString().slice(11, 19), text: line });\n390:     }\n391:     if (log.length > MAX_ACTIVITY_LINES) {\n392:       log.splice(0, log.length - MAX_ACTIVITY_LINES);\n393:     }\n394:   }\n395: \n396:   private writeLog(featureId: string, data: string): void {\n397:     try {\n398:       const logFile = resolve(this.logDir, `${featureId}.log`);\n399:       appendFileSync(logFile, data);\n400:     } catch {\n401:       // Non-critical\n402:     }\n403:   }\n404: \n405:   getActivityLog(featureId: string): ActivityEntry[] {\n406:     return this.activityLogs.get(featureId) ?? [];\n407:   }\n408: \n409:   addProcess(featureId: string, child: ChildProcess): void {\n410:     const monitored: MonitoredProcess = {\n411:       featureId,\n412:       process: child,\n413:       stdout: \"\",\n414:       stderr: \"\",\n415:       sessionId: null,\n416:       done: false,\n417:       lineBuffer: \"\",\n418:       sawFinalStop: false,\n419:     };\n420: \n421:     this.pushActivity(featureId, \"-- agent process started\");\n422:     this.writeLog(featureId, `[wombo] Process started at ${new Date().toISOString()}\\n`);\n423: \n424:     child.stdout?.on(\"data\", (data: Buffer) => {\n425:       const chunk = data.toString();\n426:       monitored.stdout += chunk;\n427:       this.callbacks.onOutput?.(featureId, chunk);\n428:       this.writeLog(featureId, chunk);\n429: \n430:       monitored.lineBuffer += chunk;\n431:       const lines = monitored.lineBuffer.split(\"\\n\");\n432:       monitored.lineBuffer = lines.pop() ?? \"\";\n433: \n434:       for (const line of lines) {\n435:         const trimmed = line.trim();\n436:         if (!trimmed) continue;\n437:         try {\n438:           const event = JSON.parse(trimmed) as OpenCodeEvent;\n439: \n440:           if (!monitored.sessionId && event.sessionID) {\n441:             monitored.sessionId = event.sessionID;\n442:             this.callbacks.onSessionId?.(featureId, event.sessionID);\n443:             this.pushActivity(featureId, `-- session: ${event.sessionID}`);\n444:           }\n445: \n446:           const activity = extractActivity(event);\n447:           if (activity) {\n448:             this.callbacks.onActivity?.(featureId, activity);\n449:           }\n450: \n451:           const logLine = formatEventForLog(event);\n452:           if (logLine) {\n453:             this.pushActivity(featureId, logLine);\n454:           }\n455: \n456:           // Extract token usage from step_finish events\n457:           this.tokenCollector.ingestEvent(featureId, event);\n458: \n459:           if (\n460:             event.type === \"step_finish\" &&\n461:             event.part?.reason === \"stop\"\n462:           ) {\n463:             monitored.sawFinalStop = true;\n464:           }\n465:         } catch {\n466:           if (trimmed.length > 0 && trimmed.length < 500) {\n467:             this.pushActivity(featureId, `[raw] ${trimmed.slice(0, 120)}`);\n468:           }\n469:         }\n470:       }\n471:     });\n472: \n473:     child.stderr?.on(\"data\", (data: Buffer) => {\n474:       const chunk = data.toString();\n475:       monitored.stderr += chunk;\n476:       this.writeLog(featureId, `[stderr] ${chunk}`);\n477:       const lines = chunk.split(\"\\n\").filter((l) => l.trim());\n478:       for (const line of lines) {\n479:         this.pushActivity(featureId, `[stderr] ${line.trim().slice(0, 120)}`);\n480:       }\n481:     });\n482: \n483:     child.on(\"exit\", (code) => {\n484:       monitored.done = true;\n485:       this.pushActivity(featureId, `-- process exited (code ${code})`);\n486:       this.writeLog(featureId, `\\n[wombo] Process exited with code ${code} at ${new Date().toISOString()}\\n`);\n487: \n488:       if (code === 0 || monitored.sawFinalStop) {\n489:         this.callbacks.onComplete?.(featureId);\n490:       } else {\n491:         const error =\n492:           monitored.stderr.slice(-2000) ||\n493:           `Process exited with code ${code}`;\n494:         this.callbacks.onError?.(featureId, error);\n495:       }\n496:     });\n497: \n498:     child.on(\"error\", (err) => {\n499:       monitored.done = true;\n500:       this.pushActivity(featureId, `!! process error: ${err.message}`);\n501:       this.writeLog(featureId, `\\n[wombo] Process error: ${err.message}\\n`);\n502:       this.callbacks.onError?.(featureId, err.message);\n503:     });\n504: \n505:     this.processes.set(featureId, monitored);\n506:   }\n507: \n508:   getSessionId(featureId: string): string | null {\n509:     return this.processes.get(featureId)?.sessionId ?? null;\n510:   }\n511: \n512:   getOutput(featureId: string): string {\n513:     return this.processes.get(featureId)?.stdout ?? \"\";\n514:   }\n515: \n516:   isRunning(featureId: string): boolean {\n517:     const m = this.processes.get(featureId);\n518:     if (!m) return false;\n519:     if (m.done) return false;\n520:     return isProcessRunning(m.process.pid!);\n521:   }\n522: \n523:   allDone(): boolean {\n524:     for (const m of this.processes.values()) {\n525:       if (!m.done) return false;\n526:     }\n527:     return true;\n528:   }\n529: \n530:   activeCount(): number {\n531:     let count = 0;\n532:     for (const m of this.processes.values()) {\n533:       if (!m.done) count++;\n534:     }\n535:     return count;\n536:   }\n537: \n538:   /**\n539:    * Remove a process from monitoring and kill it if still running.\n540:    *\n541:    * Sends SIGTERM (not SIGKILL) to allow the agent to handle shutdown\n542:    * gracefully (e.g., save partial work, close files). The process map\n543:    * entry is deleted immediately — any subsequent events from the dying\n544:    * process are ignored.\n545:    */\n546:   remove(featureId: string): void {\n547:     const m = this.processes.get(featureId);\n548:     if (m && !m.done) {\n549:       try {\n550:         m.process.kill(\"SIGTERM\");\n551:       } catch {}\n552:     }\n553:     this.processes.delete(featureId);\n554:   }\n555: \n556:   /**\n557:    * Kill all monitored processes. Called during graceful shutdown\n558:    * (SIGINT, TUI quit) to ensure no orphaned agent processes remain.\n559:    *\n560:    * This is the primary teardown path. After killAll(), the parent\n561:    * process saves wave state and exits. Agents can be re-launched\n562:    * later via `woco resume`.\n563:    */\n564:   killAll(): void {\n565:     for (const id of this.processes.keys()) {\n566:       this.remove(id);\n567:     }\n568:   }\n569: \n570:   waitAll(pollIntervalMs: number = 1000): Promise<void> {\n571:     return new Promise((resolve) => {\n572:       const check = () => {\n573:         if (this.allDone()) {\n574:           resolve();\n575:         } else {\n576:           setTimeout(check, pollIntervalMs);\n577:         }\n578:       };\n579:       check();\n580:     });\n581:   }\n582: }\n583: \n584: // ---------------------------------------------------------------------------\n585: // Re-exports from token-collector for convenience\n586: // ---------------------------------------------------------------------------\n587: \n588: export { TokenCollector, type UsageRecord } from \"./token-collector.js\";\n589: export type { UsageSummary, UsageCallback } from \"./token-collector.js\";\n\n(End of file - total 589 lines)\n</content>","title":"src/lib/monitor.ts","metadata":{"preview":"/**\n * monitor.ts — Parse JSON events from agent and detect completion/failure.\n *\n * Responsibilities:\n *   - Parse newline-delimited JSON events from agent stdout\n *   - Detect session completion (agent finished)\n *   - Detect session ID from events\n *   - Detect errors and failures\n *   - Write per-agent raw log files for diagnostics\n *   - Maintain per-agent parsed activity log for TUI preview\n *\n * ## Process Lifecycle (audit: wave-detach-audit)\n *\n * ProcessMonitor manages the lifecycle of headless agent child processes:\n *\n * **Normal flow**: Agent stdout → JSON event parsing → callbacks → completion\n *   1. `addProcess()` registers a ChildProcess and attaches stdout/stderr listeners\n *   2. Stdout data is parsed line-by-line as JSON events\n *   3. Callbacks fire: `onSessionId`, `onActivity`, `onComplete`, `onError`\n *   4. On process exit (code 0 or sawFinalStop), `onComplete` is called","truncated":false,"loaded":[]},"time":{"start":1773482644807,"end":1773482644828}}}}
{"type":"tool_use","timestamp":1773482645224,"sessionID":"ses_314328d09ffeHamS8Go5GE0ezF","part":{"id":"prt_cebcd9549001RGfHiO0EYbBlLm","sessionID":"ses_314328d09ffeHamS8Go5GE0ezF","messageID":"msg_cebcd888f0017LC1oxP6eHTgo1","type":"tool","callID":"toolu_vrtx_01SoZNA33zzdDbZXUgwkgn7i","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/wave-state-integrity/src/lib/tui.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/wave-state-integrity/src/lib/tui.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tui.ts — Blessed-based TUI dashboard for wombo-combo.\n3:  *\n4:  * Layout:\n5:  *   ┌─────────────────────────────────────────────┐\n6:  *   │ Header: Wave ID, base branch, mode, model   │\n7:  *   ├──────────────────────────┬──────────────────┤\n8:  *   │ Agent Table              │ Preview Pane     │\n9:  *   │ (selectable rows with    │ (parsed activity │\n10:  *   │  status, activity,       │  stream for the  │\n11:  *   │  progress bars, elapsed) │  selected agent) │\n12:  *   ├──────────────────────────┴──────────────────┤\n13:  *   │ Status bar: keybinds + summary counts       │\n14:  *   └─────────────────────────────────────────────┘\n15:  *\n16:  * Keybinds:\n17:  *   Up/Down   — navigate agent list\n18:  *   Enter     — attach to selected agent's multiplexer session (interactive mode)\n19:  *   r         — retry a failed/stuck agent\n20:  *   b         — show build log for selected agent\n21:  *   p         — toggle auto-scroll (pause/resume)\n22:  *   q / C-c   — quit\n23:  */\n24: \n25: import blessed from \"neo-blessed\";\n26: import type { Widgets } from \"neo-blessed\";\n27: import type { WaveState, AgentState, AgentStatus } from \"./state.js\";\n28: import { agentCounts } from \"./state.js\";\n29: import type { ProcessMonitor, ActivityEntry } from \"./monitor.js\";\n30: import { execSync } from \"node:child_process\";\n31: import { readFileSync } from \"node:fs\";\n32: import { resolve } from \"node:path\";\n33: import type { WomboConfig } from \"../config.js\";\n34: import {\n35:   detectMultiplexer,\n36:   muxHasSession,\n37:   muxAttach,\n38:   muxDisplayName,\n39: } from \"./multiplexer.js\";\n40: import { QuestionPopup } from \"./tui-question-popup.js\";\n41: import type { HitlQuestion } from \"./hitl-channel.js\";\n42: \n43: // ---------------------------------------------------------------------------\n44: // Types\n45: // ---------------------------------------------------------------------------\n46: \n47: export interface TUIOptions {\n48:   state: WaveState;\n49:   monitor: ProcessMonitor;\n50:   onQuit: () => void;\n51:   /** Whether the wave is running in interactive (multiplexer) mode. */\n52:   interactive?: boolean;\n53:   /** Project root path (for locating log files). */\n54:   projectRoot: string;\n55:   /** Config (for multiplexer session prefix, log dir, etc.) */\n56:   config: WomboConfig;\n57:   /** Callback to retry a failed/stuck agent from the TUI. */\n58:   onRetry?: (featureId: string) => void;\n59:   /** Callback when the user answers an HITL question. */\n60:   onAnswer?: (agentId: string, questionId: string, answerText: string) => void;\n61: }\n62: \n63: // ---------------------------------------------------------------------------\n64: // Color Map\n65: // ---------------------------------------------------------------------------\n66: \n67: const STATUS_COLORS: Record<AgentStatus, string> = {\n68:   queued: \"gray\",\n69:   installing: \"cyan\",\n70:   running: \"blue\",\n71:   completed: \"yellow\",\n72:   verified: \"green\",\n73:   failed: \"red\",\n74:   merged: \"magenta\",\n75:   retry: \"yellow\",\n76:   resolving_conflict: \"cyan\",\n77: };\n78: \n79: const STATUS_ICONS: Record<AgentStatus, string> = {\n80:   queued: \"·\",\n81:   installing: \"⟳\",\n82:   running: \"●\",\n83:   completed: \"○\",\n84:   verified: \"✓\",\n85:   failed: \"✗\",\n86:   merged: \"◆\",\n87:   retry: \"↻\",\n88:   resolving_conflict: \"⚡\",\n89: };\n90: \n91: // ---------------------------------------------------------------------------\n92: // Helpers\n93: // ---------------------------------------------------------------------------\n94: \n95: /**\n96:  * Escape curly braces so blessed doesn't interpret them as formatting tags.\n97:  * Blessed uses {color-fg}...{/color-fg} syntax; unmatched or malformed braces\n98:  * in user-provided text (JSON, Python dicts, shell commands, etc.) crash the\n99:  * renderer. We replace { and } with the Unicode fullwidth equivalents which\n100:  * render visually similar but are not parsed by blessed.\n101:  */\n102: function escapeBlessedTags(text: string): string {\n103:   return text.replace(/\\{/g, \"｛\").replace(/\\}/g, \"｝\");\n104: }\n105: \n106: function elapsed(startedAt: string | null): string {\n107:   if (!startedAt) return \"-\";\n108:   const start = new Date(startedAt).getTime();\n109:   const diffMs = Date.now() - start;\n110:   const secs = Math.floor(diffMs / 1000);\n111:   if (secs < 60) return `${secs}s`;\n112:   const mins = Math.floor(secs / 60);\n113:   if (mins < 60) return `${mins}m`;\n114:   const hours = Math.floor(mins / 60);\n115:   return `${hours}h${mins % 60}m`;\n116: }\n117: \n118: function progressBar(\n119:   elapsedMs: number,\n120:   estimateMs: number,\n121:   width: number = 10\n122: ): string {\n123:   if (estimateMs <= 0) return \"░\".repeat(width);\n124:   const ratio = Math.min(elapsedMs / estimateMs, 1);\n125:   const filled = Math.round(ratio * width);\n126:   return \"█\".repeat(filled) + \"░\".repeat(width - filled);\n127: }\n128: \n129: // ---------------------------------------------------------------------------\n130: // TUI Dashboard Class\n131: // ---------------------------------------------------------------------------\n132: \n133: export class WomboTUI {\n134:   private screen: Widgets.Screen;\n135:   private headerBox: Widgets.BoxElement;\n136:   private agentList: Widgets.ListElement;\n137:   private previewBox: Widgets.Log;\n138:   private statusBar: Widgets.BoxElement;\n139:   private buildLogBox: Widgets.Log;\n140: \n141:   private state: WaveState;\n142:   private monitor: ProcessMonitor;\n143:   private onQuit: () => void;\n144:   private onRetry?: (featureId: string) => void;\n145:   private onAnswer?: (agentId: string, questionId: string, answerText: string) => void;\n146:   private interactive: boolean;\n147:   private projectRoot: string;\n148:   private config: WomboConfig;\n149: \n150:   private selectedIndex: number = 0;\n151:   private autoScroll: boolean = true;\n152:   private showingBuildLog: boolean = false;\n153:   private showingLogFile: boolean = false;\n154:   private logFileBox: Widgets.Log | null = null;\n155:   private refreshTimer: ReturnType<typeof setInterval> | null = null;\n156:   private waveComplete: boolean = false;\n157:   private waveCompleteResolve: (() => void) | null = null;\n158: \n159:   /** Pending HITL questions from agents */\n160:   private pendingQuestions: HitlQuestion[] = [];\n161:   /** Active question popup (null when closed) */\n162:   private questionPopup: QuestionPopup | null = null;\n163: \n164:   /** Saved originals for console interception */\n165:   private origConsoleLog: typeof console.log = console.log;\n166:   private origConsoleError: typeof console.error = console.error;\n167:   private origConsoleWarn: typeof console.warn = console.warn;\n168:   /** System messages captured while TUI is active */\n169:   private systemMessages: ActivityEntry[] = [];\n170: \n171:   constructor(opts: TUIOptions) {\n172:     this.state = opts.state;\n173:     this.monitor = opts.monitor;\n174:     this.onQuit = opts.onQuit;\n175:     this.onRetry = opts.onRetry;\n176:     this.onAnswer = opts.onAnswer;\n177:     this.interactive = opts.interactive ?? false;\n178:     this.projectRoot = opts.projectRoot;\n179:     this.config = opts.config;\n180: \n181:     // Create screen\n182:     this.screen = blessed.screen({\n183:       smartCSR: true,\n184:       title: `wombo-combo — ${opts.state.wave_id}`,\n185:       fullUnicode: true,\n186:     });\n187: \n188:     // Header\n189:     this.headerBox = blessed.box({\n190:       top: 0,\n191:       left: 0,\n192:       width: \"100%\",\n193:       height: 3,\n194:       tags: true,\n195:       style: {\n196:         fg: \"white\",\n197:         bg: \"black\",\n198:       },\n199:     });\n200: \n201:     // Agent list (left pane)\n202:     this.agentList = blessed.list({\n203:       top: 3,\n204:       left: 0,\n205:       width: \"55%\",\n206:       height: \"100%-6\",\n207:       tags: true,\n208:       scrollable: true,\n209:       mouse: true,\n210:       keys: true,\n211:       vi: true,\n212:       border: {\n213:         type: \"line\",\n214:       },\n215:       style: {\n216:         border: { fg: \"gray\" },\n217:         selected: {\n218:           bg: \"blue\",\n219:           fg: \"white\",\n220:           bold: true,\n221:         },\n222:         item: {\n223:           fg: \"white\",\n224:         },\n225:       },\n226:       label: \" Agents \",\n227:     });\n228: \n229:     // Preview pane (right pane)\n230:     this.previewBox = blessed.log({\n231:       top: 3,\n232:       left: \"55%\",\n233:       width: \"45%\",\n234:       height: \"100%-6\",\n235:       tags: true,\n236:       scrollable: true,\n237:       mouse: true,\n238:       keys: false,\n239:       scrollbar: {\n240:         ch: \"│\",\n241:         style: { fg: \"cyan\" },\n242:       },\n243:       border: {\n244:         type: \"line\",\n245:       },\n246:       style: {\n247:         border: { fg: \"gray\" },\n248:         fg: \"white\",\n249:       },\n250:       label: \" Activity \",\n251:     });\n252: \n253:     // Build log overlay (hidden by default)\n254:     this.buildLogBox = blessed.log({\n255:       top: 3,\n256:       left: \"10%\",\n257:       width: \"80%\",\n258:       height: \"100%-6\",\n259:       tags: true,\n260:       scrollable: true,\n261:       mouse: true,\n262:       keys: true,\n263:       scrollbar: {\n264:         ch: \"│\",\n265:         style: { fg: \"yellow\" },\n266:       },\n267:       border: {\n268:         type: \"line\",\n269:       },\n270:       style: {\n271:         border: { fg: \"yellow\" },\n272:         fg: \"white\",\n273:       },\n274:       label: \" Build Log \",\n275:       hidden: true,\n276:     });\n277: \n278:     // Status bar\n279:     this.statusBar = blessed.box({\n280:       bottom: 0,\n281:       left: 0,\n282:       width: \"100%\",\n283:       height: 3,\n284:       tags: true,\n285:       style: {\n286:         fg: \"white\",\n287:         bg: \"black\",\n288:       },\n289:     });\n290: \n291:     // Assemble\n292:     this.screen.append(this.headerBox);\n293:     this.screen.append(this.agentList);\n294:     this.screen.append(this.previewBox);\n295:     this.screen.append(this.buildLogBox);\n296:     this.screen.append(this.statusBar);\n297: \n298:     // Focus the agent list\n299:     this.agentList.focus();\n300: \n301:     // Bind keys\n302:     this.bindKeys();\n303:   }\n304: \n305:   // -------------------------------------------------------------------------\n306:   // Key Bindings\n307:   // -------------------------------------------------------------------------\n308: \n309:   private bindKeys(): void {\n310:     // Quit\n311:     this.screen.key([\"q\", \"C-c\"], () => {\n312:       this.stop();\n313:       if (this.waveComplete && this.waveCompleteResolve) {\n314:         // Wave is done — just close TUI and resolve the wait promise\n315:         this.waveCompleteResolve();\n316:       } else {\n317:         // Wave still running — trigger the abort/interrupt handler\n318:         this.onQuit();\n319:       }\n320:     });\n321: \n322:     // Navigate agent list\n323:     this.agentList.on(\"select item\", (_item: any, index: number) => {\n324:       this.selectedIndex = index;\n325:       this.refreshPreview();\n326:     });\n327: \n328:     // Enter — multiplexer attach\n329:     this.screen.key([\"enter\"], () => {\n330:       this.muxAttach();\n331:     });\n332: \n333:     // b — toggle build log\n334:     this.screen.key([\"b\"], () => {\n335:       this.toggleBuildLog();\n336:     });\n337: \n338:     // p — toggle auto-scroll\n339:     this.screen.key([\"p\"], () => {\n340:       this.autoScroll = !this.autoScroll;\n341:       this.refreshStatusBar();\n342:     });\n343: \n344:     // r — retry failed/stuck agent\n345:     this.screen.key([\"r\"], () => {\n346:       this.retrySelected();\n347:     });\n348: \n349:     // h — open HITL question popup\n350:     this.screen.key([\"h\"], () => {\n351:       this.openQuestionPopup();\n352:     });\n353: \n354:     // Escape — close build log, log file overlay, or question popup\n355:     this.screen.key([\"escape\"], () => {\n356:       if (this.questionPopup && !this.questionPopup.isDestroyed()) {\n357:         this.questionPopup.close();\n358:         this.questionPopup = null;\n359:         this.agentList.focus();\n360:         this.screen.render();\n361:       } else if (this.showingBuildLog) {\n362:         this.showingBuildLog = false;\n363:         this.buildLogBox.hide();\n364:         this.agentList.focus();\n365:         this.screen.render();\n366:       } else if (this.showingLogFile && this.logFileBox) {\n367:         this.showingLogFile = false;\n368:         this.logFileBox.destroy();\n369:         this.logFileBox = null;\n370:         this.agentList.focus();\n371:         this.screen.render();\n372:       }\n373:     });\n374:   }\n375: \n376:   // -------------------------------------------------------------------------\n377:   // Start / Stop\n378:   //\n379:   // ## TUI Lifecycle and Agent Processes (audit: wave-detach-audit)\n380:   //\n381:   // `stop()` only tears down the TUI — it clears the refresh timer and\n382:   // destroys the blessed screen. It does NOT kill agent processes.\n383:   //\n384:   // Agent process termination is handled by the `onQuit` callback, which\n385:   // is set by launch.ts/resume.ts to call `monitor.killAll()` + state save.\n386:   //\n387:   // The separation is intentional:\n388:   //   - `stop()` is also called before mux attach (muxAttach method) where\n389:   //     the TUI is temporarily destroyed and recreated after detach.\n390:   //   - `onQuit()` is only called when the user intends to exit the entire\n391:   //     wave, triggering agent cleanup and process exit.\n392:   //\n393:   // `screen.destroy()` does NOT affect child processes because agents are\n394:   // spawned by the ProcessMonitor (in the launch command), not by the TUI.\n395:   // The TUI only reads from the monitor — it never owns agent processes.\n396:   // -------------------------------------------------------------------------\n397: \n398:   start(): void {\n399:     this.interceptConsole();\n400:     this.refresh();\n401:     this.screen.render();\n402: \n403:     // Auto-refresh every 2 seconds\n404:     this.refreshTimer = setInterval(() => {\n405:       this.refresh();\n406:     }, 2000);\n407:   }\n408: \n409:   stop(): void {\n410:     this.restoreConsole();\n411:     if (this.refreshTimer) {\n412:       clearInterval(this.refreshTimer);\n413:       this.refreshTimer = null;\n414:     }\n415:     this.screen.destroy();\n416:   }\n417: \n418:   /**\n419:    * Intercept console.log/error/warn so they don't corrupt the TUI.\n420:    * Messages are captured into systemMessages and shown in the preview\n421:    * when no specific agent is producing activity.\n422:    */\n423:   private interceptConsole(): void {\n424:     this.origConsoleLog = console.log;\n425:     this.origConsoleError = console.error;\n426:     this.origConsoleWarn = console.warn;\n427: \n428:     const capture = (...args: any[]) => {\n429:       const text = args\n430:         .map((a) => (typeof a === \"string\" ? a : JSON.stringify(a)))\n431:         .join(\" \");\n432:       // Strip ANSI codes for clean TUI display\n433:       const clean = text.replace(/\\x1b\\[[0-9;]*m/g, \"\");\n434:       if (!clean.trim()) return;\n435:       this.systemMessages.push({\n436:         timestamp: new Date().toISOString().slice(11, 19),\n437:         text: clean,\n438:       });\n439:       // Keep bounded\n440:       if (this.systemMessages.length > 200) {\n441:         this.systemMessages.splice(0, this.systemMessages.length - 200);\n442:       }\n443:     };\n444: \n445:     console.log = capture;\n446:     console.error = capture;\n447:     console.warn = capture;\n448:   }\n449: \n450:   /**\n451:    * Restore original console methods.\n452:    */\n453:   private restoreConsole(): void {\n454:     console.log = this.origConsoleLog;\n455:     console.error = this.origConsoleError;\n456:     console.warn = this.origConsoleWarn;\n457:   }\n458: \n459:   /**\n460:    * Update the state reference (called from the monitoring loop).\n461:    */\n462:   updateState(state: WaveState): void {\n463:     this.state = state;\n464:   }\n465: \n466:   /**\n467:    * Mark the wave as complete. The TUI stays open so the user can browse\n468:    * agent logs, build output, etc. The header shows a WAVE COMPLETE banner\n469:    * and the status bar tells the user to press q to exit.\n470:    */\n471:   markWaveComplete(): void {\n472:     this.waveComplete = true;\n473:     this.refresh();\n474:   }\n475: \n476:   /**\n477:    * Returns a Promise that resolves when the user presses q to quit.\n478:    * Used after wave completion so the TUI stays open for post-mortem browsing.\n479:    */\n480:   waitForQuit(): Promise<void> {\n481:     return new Promise<void>((resolve) => {\n482:       this.waveCompleteResolve = resolve;\n483:     });\n484:   }\n485: \n486:   /**\n487:    * Update pending HITL questions. Called from the monitoring loop.\n488:    * If the question popup is open, it gets live-updated too.\n489:    */\n490:   setPendingQuestions(questions: HitlQuestion[]): void {\n491:     this.pendingQuestions = questions;\n492:     if (this.questionPopup && !this.questionPopup.isDestroyed()) {\n493:       this.questionPopup.updateQuestions(questions);\n494:     }\n495:     // Status bar will pick up the badge on next refresh cycle\n496:   }\n497: \n498:   /**\n499:    * Open the HITL question popup modal.\n500:    */\n501:   private openQuestionPopup(): void {\n502:     // Don't open if already open\n503:     if (this.questionPopup && !this.questionPopup.isDestroyed()) return;\n504: \n505:     // Don't open if there are no pending questions\n506:     if (this.pendingQuestions.length === 0) {\n507:       // Flash a message in the preview\n508:       const agent = this.state.agents[this.selectedIndex];\n509:       if (agent) {\n510:         const logs = this.monitor.activityLogs.get(agent.feature_id);\n511:         if (logs) {\n512:           logs.push({\n513:             timestamp: new Date().toISOString().slice(11, 19),\n514:             text: `-- No pending HITL questions`,\n515:           });\n516:         }\n517:         this.refreshPreview();\n518:         this.screen.render();\n519:       }\n520:       return;\n521:     }\n522: \n523:     this.questionPopup = new QuestionPopup(\n524:       this.screen,\n525:       [...this.pendingQuestions], // copy so popup can mutate internally\n526:       {\n527:         onAnswer: (agentId, questionId, answerText) => {\n528:           // Forward to the external callback (which calls submitAnswer)\n529:           if (this.onAnswer) {\n530:             this.onAnswer(agentId, questionId, answerText);\n531:           }\n532:           // Remove from our pending list\n533:           this.pendingQuestions = this.pendingQuestions.filter(\n534:             (q) => !(q.agentId === agentId && q.id === questionId)\n535:           );\n536:         },\n537:         onClose: () => {\n538:           this.questionPopup = null;\n539:           this.agentList.focus();\n540:           this.refreshStatusBar();\n541:           this.screen.render();\n542:         },\n543:       }\n544:     );\n545:   }\n546: \n547:   // -------------------------------------------------------------------------\n548:   // Refresh Logic\n549:   // -------------------------------------------------------------------------\n550: \n551:   private refresh(): void {\n552:     this.refreshHeader();\n553:     this.refreshAgentList();\n554:     this.refreshPreview();\n555:     this.refreshStatusBar();\n556:     this.screen.render();\n557:   }\n558: \n559:   private refreshHeader(): void {\n560:     const s = this.state;\n561:     const counts = agentCounts(s);\n562:     const total = s.agents.length;\n563:     const done = counts.verified + counts.merged;\n564: \n565:     let line1 = ` {bold}wombo-combo{/bold} {gray-fg}${s.wave_id}{/gray-fg}`;\n566:     if (this.waveComplete) {\n567:       line1 += `  {gray-fg}│{/gray-fg}  {bold}{green-fg}WAVE COMPLETE{/green-fg}{/bold}`;\n568:     }\n569:     line1 += `  {gray-fg}│{/gray-fg}  Base: {cyan-fg}${s.base_branch}{/cyan-fg}`;\n570:     line1 += `  {gray-fg}│{/gray-fg}  Mode: ${s.interactive ? \"{green-fg}interactive{/green-fg}\" : \"{blue-fg}headless{/blue-fg}\"}`;\n571:     if (s.model) {\n572:       line1 += `  {gray-fg}│{/gray-fg}  Model: {yellow-fg}${s.model}{/yellow-fg}`;\n573:     }\n574: \n575:     let line2 = ` Progress: {green-fg}${done}{/green-fg}/{white-fg}${total}{/white-fg}`;\n576:     if (counts.running > 0)\n577:       line2 += `  {blue-fg}${counts.running} running{/blue-fg}`;\n578:     if (counts.failed > 0)\n579:       line2 += `  {red-fg}${counts.failed} failed{/red-fg}`;\n580:     if (counts.queued > 0)\n581:       line2 += `  {gray-fg}${counts.queued} queued{/gray-fg}`;\n582:     if (counts.retry > 0)\n583:       line2 += `  {yellow-fg}${counts.retry} retrying{/yellow-fg}`;\n584:     if (counts.resolving_conflict > 0)\n585:       line2 += `  {cyan-fg}${counts.resolving_conflict} resolving{/cyan-fg}`;\n586: \n587:     this.headerBox.setContent(`${line1}\\n${line2}`);\n588:   }\n589: \n590:   private refreshAgentList(): void {\n591:     const items: string[] = [];\n592: \n593:     for (let i = 0; i < this.state.agents.length; i++) {\n594:       const a = this.state.agents[i];\n595:       const color = STATUS_COLORS[a.status];\n596:       const icon = STATUS_ICONS[a.status];\n597: \n598:       // Feature ID (padded)\n599:       const fid =\n600:         a.feature_id.length > 24\n601:           ? a.feature_id.slice(0, 23) + \"…\"\n602:           : a.feature_id.padEnd(24);\n603: \n604:       // Status\n605:       const st = `{${color}-fg}${icon} ${a.status.padEnd(10)}{/${color}-fg}`;\n606: \n607:       // Progress bar\n608:       let pbar = \"\";\n609:       if ((a.status === \"running\" || a.status === \"resolving_conflict\") && a.started_at) {\n610:         const elapsedMs = Date.now() - new Date(a.started_at).getTime();\n611:         // Use actual effort estimate from feature data, fallback to 1h\n612:         const estimateMs = a.effort_estimate_ms ?? 60 * 60 * 1000;\n613:         pbar = ` {cyan-fg}${progressBar(elapsedMs, estimateMs, 8)}{/cyan-fg}`;\n614:       } else if (a.status === \"verified\" || a.status === \"merged\") {\n615:         pbar = ` {green-fg}${\"█\".repeat(8)}{/green-fg}`;\n616:       } else if (a.status === \"failed\") {\n617:         pbar = ` {red-fg}${\"█\".repeat(8)}{/red-fg}`;\n618:       }\n619: \n620:       // Activity (for running/resolving agents)\n621:       let act = \"\";\n622:       if ((a.status === \"running\" || a.status === \"resolving_conflict\") && a.activity) {\n623:         const rawAct =\n624:           a.activity.length > 25 ? a.activity.slice(0, 24) + \"…\" : a.activity;\n625:         const actText = escapeBlessedTags(rawAct);\n626:         act = ` {cyan-fg}${actText}{/cyan-fg}`;\n627:       } else if (a.status === \"installing\") {\n628:         act = \" {cyan-fg}setting up…{/cyan-fg}\";\n629:       }\n630: \n631:       // Elapsed\n632:       const el = elapsed(a.started_at);\n633: \n634:       // Retries\n635:       const retries =\n636:         a.retries > 0 ? ` {yellow-fg}↻${a.retries}{/yellow-fg}` : \"\";\n637: \n638:       items.push(\n639:         ` ${fid} ${st}${pbar}${act}${retries} {gray-fg}${el}{/gray-fg}`\n640:       );\n641:     }\n642: \n643:     // Preserve selection\n644:     const prevSelected = this.selectedIndex;\n645:     this.agentList.setItems(items as any);\n646:     if (prevSelected < items.length) {\n647:       this.agentList.select(prevSelected);\n648:     }\n649:   }\n650: \n651:   private refreshPreview(): void {\n652:     const agent = this.state.agents[this.selectedIndex];\n653:     if (!agent) {\n654:       this.previewBox.setContent(\"{gray-fg}No agent selected{/gray-fg}\");\n655:       return;\n656:     }\n657: \n658:     // Update label\n659:     this.previewBox.setLabel(` ${agent.feature_id} — Activity `);\n660: \n661:     // Get activity log from monitor\n662:     const log = this.monitor.getActivityLog(agent.feature_id);\n663: \n664:     // Also include system messages (build verification, etc.)\n665:     // that mention this agent's feature_id\n666:     const relevantSys = this.systemMessages.filter((m) =>\n667:       m.text.includes(agent.feature_id)\n668:     );\n669: \n670:     if (log.length === 0 && relevantSys.length === 0) {\n671:       this.previewBox.setContent(\n672:         \"{gray-fg}No activity yet. Waiting for agent output…{/gray-fg}\"\n673:       );\n674:       return;\n675:     }\n676: \n677:     // Format log entries\n678:     const lines: string[] = [];\n679:     for (const entry of log) {\n680:       lines.push(this.formatActivityLine(entry));\n681:     }\n682: \n683:     // Append relevant system messages\n684:     if (relevantSys.length > 0) {\n685:       lines.push(\"\");\n686:       lines.push(\"{yellow-fg}-- system --{/yellow-fg}\");\n687:       for (const entry of relevantSys) {\n688:         const ts = `{gray-fg}${entry.timestamp}{/gray-fg}`;\n689:         lines.push(`${ts} {yellow-fg}${escapeBlessedTags(entry.text)}{/yellow-fg}`);\n690:       }\n691:     }\n692: \n693:     this.previewBox.setContent(lines.join(\"\\n\"));\n694: \n695:     // Auto-scroll to bottom\n696:     if (this.autoScroll) {\n697:       this.previewBox.setScrollPerc(100);\n698:     }\n699:   }\n700: \n701:   private formatActivityLine(entry: ActivityEntry): string {\n702:     const ts = `{gray-fg}${entry.timestamp}{/gray-fg}`;\n703:     let text = escapeBlessedTags(entry.text);\n704: \n705:     // Color-code different line types\n706:     if (text.startsWith(\">>\")) {\n707:       text = `{cyan-fg}${text}{/cyan-fg}`;\n708:     } else if (text.startsWith(\"!!\")) {\n709:       text = `{red-fg}${text}{/red-fg}`;\n710:     } else if (text.startsWith(\"--\")) {\n711:       text = `{green-fg}${text}{/green-fg}`;\n712:     } else if (text.startsWith(\"[stderr]\")) {\n713:       text = `{red-fg}${text}{/red-fg}`;\n714:     } else if (text.startsWith(\"[raw]\")) {\n715:       text = `{gray-fg}${text}{/gray-fg}`;\n716:     } else if (text.startsWith(\"   \")) {\n717:       text = `{white-fg}${text}{/white-fg}`;\n718:     }\n719: \n720:     return `${ts} ${text}`;\n721:   }\n722: \n723:   private refreshStatusBar(): void {\n724:     const scrollStatus = this.autoScroll\n725:       ? \"{green-fg}auto-scroll{/green-fg}\"\n726:       : \"{yellow-fg}paused{/yellow-fg}\";\n727: \n728:     const agent = this.state.agents[this.selectedIndex];\n729:     const agentInfo = agent\n730:       ? `{gray-fg}Selected: {white-fg}${agent.feature_id}{/white-fg}{/gray-fg}`\n731:       : \"\";\n732: \n733:     const enterHint = this.interactive\n734:       ? \"{gray-fg}Enter{/gray-fg} attach session\"\n735:       : \"{gray-fg}Enter{/gray-fg} view log\";\n736: \n737:     // HITL badge — show only when there are pending questions\n738:     const hitlBadge =\n739:       this.pendingQuestions.length > 0\n740:         ? `  {bold}{yellow-fg}? ${this.pendingQuestions.length} pending{/yellow-fg}{/bold}  {gray-fg}H{/gray-fg} answer`\n741:         : \"\";\n742: \n743:     let line1: string;\n744:     if (this.waveComplete) {\n745:       line1 = ` {bold}{green-fg}Wave complete.{/green-fg}{/bold}  ${enterHint}  {gray-fg}R{/gray-fg} retry  {gray-fg}B{/gray-fg} build log  {gray-fg}P{/gray-fg} ${scrollStatus}${hitlBadge}  {bold}{yellow-fg}Q{/yellow-fg} exit{/bold}`;\n746:     } else {\n747:       line1 = ` {bold}Keys:{/bold} {gray-fg}\\u2191\\u2193{/gray-fg} navigate  ${enterHint}  {gray-fg}R{/gray-fg} retry  {gray-fg}B{/gray-fg} build log  {gray-fg}P{/gray-fg} ${scrollStatus}${hitlBadge}  {gray-fg}Q{/gray-fg} quit`;\n748:     }\n749:     const line2 = ` ${agentInfo}`;\n750: \n751:     this.statusBar.setContent(`${line1}\\n${line2}`);\n752:   }\n753: \n754:   // -------------------------------------------------------------------------\n755:   // Actions\n756:   // -------------------------------------------------------------------------\n757: \n758:   private muxAttach(): void {\n759:     const agent = this.state.agents[this.selectedIndex];\n760:     if (!agent) return;\n761: \n762:     if (!this.interactive) {\n763:       // Headless mode — show the raw log file in an overlay\n764:       this.showLogFile(agent);\n765:       return;\n766:     }\n767: \n768:     const mux = detectMultiplexer(this.config.agent.multiplexer);\n769:     const sessionName = `${this.config.agent.tmuxPrefix}-${agent.feature_id}`;\n770: \n771:     // Check if multiplexer session exists\n772:     if (!muxHasSession(mux, sessionName)) {\n773:       // No session — show message in preview\n774:       this.monitor.activityLogs.get(agent.feature_id)?.push({\n775:         timestamp: new Date().toISOString().slice(11, 19),\n776:         text: `!! No ${muxDisplayName(mux)} session '${sessionName}' found`,\n777:       });\n778:       this.refreshPreview();\n779:       this.screen.render();\n780:       return;\n781:     }\n782: \n783:     // Detach from blessed, attach to multiplexer session\n784:     this.restoreConsole();\n785:     this.screen.destroy();\n786:     try {\n787:       muxAttach(mux, sessionName);\n788:     } catch {\n789:       // User detached from session — resume TUI\n790:     }\n791: \n792:     // Re-create screen after returning from multiplexer\n793:     this.recreateScreen();\n794:   }\n795: \n796:   /**\n797:    * Retry the selected agent (only if failed or stuck in retry).\n798:    * Resets it to \"queued\" so the polling loop picks it up for a fresh launch.\n799:    */\n800:   private retrySelected(): void {\n801:     const agent = this.state.agents[this.selectedIndex];\n802:     if (!agent) return;\n803: \n804:     const retryableStatuses: AgentStatus[] = [\"failed\", \"retry\"];\n805:     if (!retryableStatuses.includes(agent.status)) {\n806:       // Flash a message in the preview — agent isn't in a retryable state\n807:       const logs = this.monitor.activityLogs.get(agent.feature_id);\n808:       if (logs) {\n809:         logs.push({\n810:           timestamp: new Date().toISOString().slice(11, 19),\n811:           text: `!! Cannot retry — agent status is \"${agent.status}\" (must be failed or retry)`,\n812:         });\n813:       }\n814:       this.refreshPreview();\n815:       this.screen.render();\n816:       return;\n817:     }\n818: \n819:     if (this.onRetry) {\n820:       this.onRetry(agent.feature_id);\n821: \n822:       // Show feedback in preview\n823:       const logs = this.monitor.activityLogs.get(agent.feature_id);\n824:       if (logs) {\n825:         logs.push({\n826:           timestamp: new Date().toISOString().slice(11, 19),\n827:           text: `>> Retry requested — agent will be relaunched`,\n828:         });\n829:       }\n830:       this.refresh();\n831:       this.screen.render();\n832:     }\n833:   }\n834: \n835:   /**\n836:    * Show the raw log file for an agent in an overlay (headless mode).\n837:    */\n838:   private showLogFile(agent: AgentState): void {\n839:     if (this.showingLogFile) {\n840:       // Toggle off\n841:       this.showingLogFile = false;\n842:       if (this.logFileBox) {\n843:         this.logFileBox.destroy();\n844:         this.logFileBox = null;\n845:       }\n846:       this.agentList.focus();\n847:       this.screen.render();\n848:       return;\n849:     }\n850: \n851:     const logPath = resolve(\n852:       this.projectRoot,\n853:       \".wombo-combo\",\n854:       \"logs\",\n855:       `${agent.feature_id}.log`\n856:     );\n857:     let content: string;\n858:     try {\n859:       content = readFileSync(logPath, \"utf-8\");\n860:       if (!content.trim()) {\n861:         content =\n862:           \"{gray-fg}Log file is empty. Agent may not have started producing output yet.{/gray-fg}\";\n863:       }\n864:     } catch {\n865:       content = \"{gray-fg}No log file found at \" + logPath + \"{/gray-fg}\";\n866:     }\n867: \n868:     // Create overlay\n869:     this.logFileBox = blessed.log({\n870:       top: 3,\n871:       left: \"5%\",\n872:       width: \"90%\",\n873:       height: \"100%-6\",\n874:       tags: true,\n875:       scrollable: true,\n876:       mouse: true,\n877:       keys: true,\n878:       scrollbar: {\n879:         ch: \"│\",\n880:         style: { fg: \"cyan\" },\n881:       },\n882:       border: {\n883:         type: \"line\",\n884:       },\n885:       style: {\n886:         border: { fg: \"cyan\" },\n887:         fg: \"white\",\n888:       },\n889:       label: ` Log — ${agent.feature_id} (Esc to close) `,\n890:     });\n891: \n892:     this.screen.append(this.logFileBox);\n893: \n894:     // Truncate to last 200 lines to keep TUI responsive\n895:     const lines = content.split(\"\\n\");\n896:     const truncated =\n897:       lines.length > 200 ? lines.slice(-200).join(\"\\n\") : content;\n898:     this.logFileBox.setContent(escapeBlessedTags(truncated));\n899:     this.logFileBox.setScrollPerc(100);\n900:     this.logFileBox.focus();\n901:     this.showingLogFile = true;\n902:     this.screen.render();\n903:   }\n904: \n905:   private toggleBuildLog(): void {\n906:     const agent = this.state.agents[this.selectedIndex];\n907:     if (!agent) return;\n908: \n909:     if (this.showingBuildLog) {\n910:       this.showingBuildLog = false;\n911:       this.buildLogBox.hide();\n912:       this.agentList.focus();\n913:     } else {\n914:       this.showingBuildLog = true;\n915:       this.buildLogBox.setLabel(` Build Log — ${agent.feature_id} `);\n916: \n917:       if (agent.build_output) {\n918:         this.buildLogBox.setContent(escapeBlessedTags(agent.build_output));\n919:       } else if (agent.build_passed === true) {\n920:         this.buildLogBox.setContent(\n921:           \"{green-fg}Build passed — no errors.{/green-fg}\"\n922:         );\n923:       } else if (agent.build_passed === false) {\n924:         this.buildLogBox.setContent(\n925:           \"{red-fg}Build failed — no output captured.{/red-fg}\"\n926:         );\n927:       } else {\n928:         this.buildLogBox.setContent(\n929:           \"{gray-fg}No build has been run yet.{/gray-fg}\"\n930:         );\n931:       }\n932: \n933:       this.buildLogBox.show();\n934:       this.buildLogBox.focus();\n935:     }\n936:     this.screen.render();\n937:   }\n938: \n939:   /**\n940:    * Re-create the screen after returning from multiplexer attach.\n941:    * Blessed can't resume after destroy, so we rebuild everything.\n942:    */\n943:   private recreateScreen(): void {\n944:     // Re-create screen\n945:     this.screen = blessed.screen({\n946:       smartCSR: true,\n947:       title: `wombo-combo — ${this.state.wave_id}`,\n948:       fullUnicode: true,\n949:     });\n950: \n951:     // Re-create all widgets\n952:     this.headerBox = blessed.box({\n953:       top: 0,\n954:       left: 0,\n955:       width: \"100%\",\n956:       height: 3,\n957:       tags: true,\n958:       style: { fg: \"white\", bg: \"black\" },\n959:     });\n960: \n961:     this.agentList = blessed.list({\n962:       top: 3,\n963:       left: 0,\n964:       width: \"55%\",\n965:       height: \"100%-6\",\n966:       tags: true,\n967:       scrollable: true,\n968:       mouse: true,\n969:       keys: true,\n970:       vi: true,\n971:       border: { type: \"line\" },\n972:       style: {\n973:         border: { fg: \"gray\" },\n974:         selected: { bg: \"blue\", fg: \"white\", bold: true },\n975:         item: { fg: \"white\" },\n976:       },\n977:       label: \" Agents \",\n978:     });\n979: \n980:     this.previewBox = blessed.log({\n981:       top: 3,\n982:       left: \"55%\",\n983:       width: \"45%\",\n984:       height: \"100%-6\",\n985:       tags: true,\n986:       scrollable: true,\n987:       mouse: true,\n988:       keys: false,\n989:       scrollbar: { ch: \"│\", style: { fg: \"cyan\" } },\n990:       border: { type: \"line\" },\n991:       style: { border: { fg: \"gray\" }, fg: \"white\" },\n992:       label: \" Activity \",\n993:     });\n994: \n995:     this.buildLogBox = blessed.log({\n996:       top: 3,\n997:       left: \"10%\",\n998:       width: \"80%\",\n999:       height: \"100%-6\",\n1000:       tags: true,\n1001:       scrollable: true,\n1002:       mouse: true,\n1003:       keys: true,\n1004:       scrollbar: { ch: \"│\", style: { fg: \"yellow\" } },\n1005:       border: { type: \"line\" },\n1006:       style: { border: { fg: \"yellow\" }, fg: \"white\" },\n1007:       label: \" Build Log \",\n1008:       hidden: true,\n1009:     });\n1010: \n1011:     this.statusBar = blessed.box({\n1012:       bottom: 0,\n1013:       left: 0,\n1014:       width: \"100%\",\n1015:       height: 3,\n1016:       tags: true,\n1017:       style: { fg: \"white\", bg: \"black\" },\n1018:     });\n1019: \n1020:     this.screen.append(this.headerBox);\n1021:     this.screen.append(this.agentList);\n1022:     this.screen.append(this.previewBox);\n1023:     this.screen.append(this.buildLogBox);\n1024:     this.screen.append(this.statusBar);\n1025: \n1026:     this.agentList.focus();\n1027:     this.showingBuildLog = false;\n1028:     this.showingLogFile = false;\n1029:     this.logFileBox = null;\n1030:     this.questionPopup = null;\n1031:     this.interceptConsole();\n1032:     this.bindKeys();\n1033:     this.refresh();\n1034:   }\n1035: }\n\n(End of file - total 1035 lines)\n</content>","title":"src/lib/tui.ts","metadata":{"preview":"/**\n * tui.ts — Blessed-based TUI dashboard for wombo-combo.\n *\n * Layout:\n *   ┌─────────────────────────────────────────────┐\n *   │ Header: Wave ID, base branch, mode, model   │\n *   ├──────────────────────────┬──────────────────┤\n *   │ Agent Table              │ Preview Pane     │\n *   │ (selectable rows with    │ (parsed activity │\n *   │  status, activity,       │  stream for the  │\n *   │  progress bars, elapsed) │  selected agent) │\n *   ├──────────────────────────┴──────────────────┤\n *   │ Status bar: keybinds + summary counts       │\n *   └─────────────────────────────────────────────┘\n *\n * Keybinds:\n *   Up/Down   — navigate agent list\n *   Enter     — attach to selected agent's multiplexer session (interactive mode)\n *   r         — retry a failed/stuck agent\n *   b         — show build log for selected agent","truncated":false,"loaded":[]},"time":{"start":1773482645212,"end":1773482645221}}}}
{"type":"tool_use","timestamp":1773482645617,"sessionID":"ses_314328d09ffeHamS8Go5GE0ezF","part":{"id":"prt_cebcd96de001ML1yYwyHWp2z0l","sessionID":"ses_314328d09ffeHamS8Go5GE0ezF","messageID":"msg_cebcd888f0017LC1oxP6eHTgo1","type":"tool","callID":"toolu_vrtx_017bcFJA6BuwL2Uqtm6yZs9Y","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/wave-state-integrity/src/lib/ui.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/wave-state-integrity/src/lib/ui.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * ui.ts — Terminal dashboard for wave status display.\n3:  *\n4:  * Responsibilities:\n5:  *   - Render a live status table of all agents in a wave\n6:  *   - Show progress indicators, timing, retry counts\n7:  *   - Color-coded status output\n8:  *   - Summary statistics\n9:  */\n10: \n11: import type { WaveState, AgentState, AgentStatus } from \"./state.js\";\n12: import { agentCounts, areAgentDepsReady } from \"./state.js\";\n13: import { formatDuration, parseDurationMinutes } from \"./tasks.js\";\n14: \n15: // ---------------------------------------------------------------------------\n16: // ANSI Color Helpers\n17: // ---------------------------------------------------------------------------\n18: \n19: const RESET = \"\\x1b[0m\";\n20: const BOLD = \"\\x1b[1m\";\n21: const DIM = \"\\x1b[2m\";\n22: \n23: const FG = {\n24:   red: \"\\x1b[31m\",\n25:   green: \"\\x1b[32m\",\n26:   yellow: \"\\x1b[33m\",\n27:   blue: \"\\x1b[34m\",\n28:   magenta: \"\\x1b[35m\",\n29:   cyan: \"\\x1b[36m\",\n30:   white: \"\\x1b[37m\",\n31:   gray: \"\\x1b[90m\",\n32: };\n33: \n34: // ---------------------------------------------------------------------------\n35: // Status Colors\n36: // ---------------------------------------------------------------------------\n37: \n38: const STATUS_COLORS: Record<AgentStatus, string> = {\n39:   queued: FG.gray,\n40:   installing: FG.cyan,\n41:   running: FG.blue,\n42:   completed: FG.yellow,\n43:   verified: FG.green,\n44:   failed: FG.red,\n45:   merged: FG.magenta,\n46:   retry: FG.yellow,\n47:   resolving_conflict: FG.cyan,\n48: };\n49: \n50: const STATUS_ICONS: Record<AgentStatus, string> = {\n51:   queued: \".\",\n52:   installing: \">\",\n53:   running: \"*\",\n54:   completed: \"~\",\n55:   verified: \"+\",\n56:   failed: \"!\",\n57:   merged: \"#\",\n58:   retry: \"?\",\n59:   resolving_conflict: \"!\",\n60: };\n61: \n62: // ---------------------------------------------------------------------------\n63: // Formatting Helpers\n64: // ---------------------------------------------------------------------------\n65: \n66: function colorize(text: string, color: string): string {\n67:   return `${color}${text}${RESET}`;\n68: }\n69: \n70: function pad(text: string, width: number): string {\n71:   if (text.length >= width) return text.slice(0, width);\n72:   return text + \" \".repeat(width - text.length);\n73: }\n74: \n75: function padLeft(text: string, width: number): string {\n76:   if (text.length >= width) return text.slice(0, width);\n77:   return \" \".repeat(width - text.length) + text;\n78: }\n79: \n80: function elapsed(startedAt: string | null): string {\n81:   if (!startedAt) return \"-\";\n82:   const start = new Date(startedAt).getTime();\n83:   const now = Date.now();\n84:   const diffMs = now - start;\n85:   const mins = Math.floor(diffMs / 60000);\n86:   if (mins < 60) return `${mins}m`;\n87:   const hours = Math.floor(mins / 60);\n88:   const remMins = mins % 60;\n89:   return `${hours}h${remMins}m`;\n90: }\n91: \n92: // ---------------------------------------------------------------------------\n93: // Table Rendering\n94: // ---------------------------------------------------------------------------\n95: \n96: /**\n97:  * Render the full wave status dashboard to stdout.\n98:  */\n99: export function renderDashboard(state: WaveState): string {\n100:   const lines: string[] = [];\n101: \n102:   // Header\n103:   lines.push(\"\");\n104:   lines.push(\n105:     `${BOLD}wombo-combo${RESET} ${DIM}${state.wave_id}${RESET}`\n106:   );\n107:   lines.push(\n108:     `${DIM}Base: ${state.base_branch} | Concurrency: ${state.max_concurrent} | Mode: ${state.interactive ? \"interactive\" : \"headless\"}${RESET}`\n109:   );\n110:   if (state.model) {\n111:     lines.push(`${DIM}Model: ${state.model}${RESET}`);\n112:   }\n113:   if (state.schedule_plan) {\n114:     const { streams, merge_gates } = state.schedule_plan;\n115:     const chainCount = streams.filter((s) => s.length > 1).length;\n116:     lines.push(\n117:       `${DIM}Scheduling: ${streams.length} stream(s)` +\n118:       (chainCount > 0 ? `, ${chainCount} chain(s)` : \"\") +\n119:       (merge_gates.length > 0 ? `, ${merge_gates.length} merge gate(s)` : \"\") +\n120:       `${RESET}`\n121:     );\n122:   }\n123:   lines.push(\"\");\n124: \n125:   // Table header\n126:   const header = [\n127:     pad(\"\", 3),\n128:     pad(\"Feature\", 30),\n129:     pad(\"Status\", 12),\n130:     pad(\"Activity\", 30),\n131:     padLeft(\"Retries\", 8),\n132:     padLeft(\"Elapsed\", 8),\n133:   ].join(\" \");\n134:   lines.push(`${BOLD}${header}${RESET}`);\n135:   lines.push(\"-\".repeat(95));\n136: \n137:   // Agent rows\n138:   for (const agent of state.agents) {\n139:     const statusColor = STATUS_COLORS[agent.status];\n140:     const icon = STATUS_ICONS[agent.status];\n141: \n142:     let activityText = \"-\";\n143:     if ((agent.status === \"running\" || agent.status === \"resolving_conflict\") && agent.activity) {\n144:       activityText = agent.activity;\n145:     } else if (agent.status === \"installing\") {\n146:       activityText = \"setting up worktree...\";\n147:     } else if (agent.status === \"retry\") {\n148:       activityText = \"retrying with errors...\";\n149:     } else if (agent.status === \"failed\" && agent.error) {\n150:       activityText = agent.error.split(\"\\n\")[0].slice(0, 28);\n151:     } else if (agent.status === \"verified\") {\n152:       activityText = \"build passed\";\n153:     } else if (agent.status === \"merged\") {\n154:       activityText = agent.branch;\n155:     } else if (agent.status === \"queued\" && agent.depends_on.length > 0) {\n156:       // Show what this queued agent is waiting for\n157:       const unsatisfied = agent.depends_on.filter((depId) => {\n158:         const dep = state.agents.find((a) => a.feature_id === depId);\n159:         return dep && dep.status !== \"verified\" && dep.status !== \"merged\";\n160:       });\n161:       if (unsatisfied.length > 0) {\n162:         activityText = `waiting: ${unsatisfied.join(\", \")}`.slice(0, 28);\n163:       } else {\n164:         activityText = \"deps ready, queued\";\n165:       }\n166:     }\n167: \n168:     const row = [\n169:       colorize(pad(`[${icon}]`, 3), statusColor),\n170:       pad(agent.feature_id, 30),\n171:       colorize(pad(agent.status, 12), statusColor),\n172:       (agent.status === \"running\" ? FG.cyan : DIM) + pad(activityText, 30) + RESET,\n173:       padLeft(\n174:         agent.retries > 0 ? `${agent.retries}/${agent.max_retries}` : \"-\",\n175:         8\n176:       ),\n177:       padLeft(elapsed(agent.started_at), 8),\n178:     ].join(\" \");\n179: \n180:     lines.push(row);\n181:   }\n182: \n183:   // Summary\n184:   lines.push(\"-\".repeat(95));\n185:   const counts = agentCounts(state);\n186:   const summaryParts: string[] = [];\n187: \n188:   if (counts.queued > 0)\n189:     summaryParts.push(colorize(`${counts.queued} queued`, FG.gray));\n190:   if (counts.installing > 0)\n191:     summaryParts.push(colorize(`${counts.installing} installing`, FG.cyan));\n192:   if (counts.running > 0)\n193:     summaryParts.push(colorize(`${counts.running} running`, FG.blue));\n194:   if (counts.completed > 0)\n195:     summaryParts.push(colorize(`${counts.completed} completed`, FG.yellow));\n196:   if (counts.verified > 0)\n197:     summaryParts.push(colorize(`${counts.verified} verified`, FG.green));\n198:   if (counts.failed > 0)\n199:     summaryParts.push(colorize(`${counts.failed} failed`, FG.red));\n200:   if (counts.merged > 0)\n201:     summaryParts.push(colorize(`${counts.merged} merged`, FG.magenta));\n202:   if (counts.retry > 0)\n203:     summaryParts.push(colorize(`${counts.retry} retrying`, FG.yellow));\n204:   if (counts.resolving_conflict > 0)\n205:     summaryParts.push(colorize(`${counts.resolving_conflict} resolving`, FG.cyan));\n206: \n207:   lines.push(summaryParts.join(\" | \"));\n208: \n209:   // Show merge gate status if applicable\n210:   if (state.schedule_plan && state.schedule_plan.merge_gates.length > 0) {\n211:     const gateParts: string[] = [];\n212:     for (const gate of state.schedule_plan.merge_gates) {\n213:       const gateAgent = state.agents.find((a) => a.feature_id === gate.feature_id);\n214:       if (!gateAgent) continue;\n215: \n216:       if (gateAgent.status === \"queued\") {\n217:         const waitingOn = gate.wait_for.filter((depId) => {\n218:           const dep = state.agents.find((a) => a.feature_id === depId);\n219:           return dep && dep.status !== \"verified\" && dep.status !== \"merged\";\n220:         });\n221:         if (waitingOn.length > 0) {\n222:           gateParts.push(\n223:             `${DIM}⊘ ${gate.feature_id} gate: waiting for ${waitingOn.join(\", \")}${RESET}`\n224:           );\n225:         } else {\n226:           gateParts.push(\n227:             colorize(`⊙ ${gate.feature_id} gate: ready`, FG.green)\n228:           );\n229:         }\n230:       } else {\n231:         gateParts.push(\n232:           colorize(`⊙ ${gate.feature_id} gate: ${gateAgent.status}`, STATUS_COLORS[gateAgent.status])\n233:         );\n234:       }\n235:     }\n236:     if (gateParts.length > 0) {\n237:       lines.push(`${DIM}Merge Gates:${RESET} ${gateParts.join(\" | \")}`);\n238:     }\n239:   }\n240: \n241:   lines.push(\"\");\n242: \n243:   return lines.join(\"\\n\");\n244: }\n245: \n246: /**\n247:  * Print the dashboard to stdout.\n248:  */\n249: export function printDashboard(state: WaveState): void {\n250:   console.log(renderDashboard(state));\n251: }\n252: \n253: /**\n254:  * Print a single-line status update for a feature.\n255:  */\n256: export function printAgentUpdate(\n257:   agent: AgentState,\n258:   message: string\n259: ): void {\n260:   const statusColor = STATUS_COLORS[agent.status];\n261:   const icon = STATUS_ICONS[agent.status];\n262:   console.log(\n263:     `${colorize(`[${icon}]`, statusColor)} ${pad(agent.feature_id, 28)} ${message}`\n264:   );\n265: }\n266: \n267: /**\n268:  * Print a compact summary.\n269:  */\n270: export function printSummary(state: WaveState): void {\n271:   const counts = agentCounts(state);\n272:   const total = state.agents.length;\n273:   const done = counts.verified + counts.merged;\n274:   console.log(\n275:     `\\n${BOLD}Wave ${state.wave_id}${RESET}: ${done}/${total} done, ${counts.running} running, ${counts.failed} failed, ${counts.queued} queued`\n276:   );\n277: }\n278: \n279: /**\n280:  * Clear the terminal screen.\n281:  */\n282: export function clearScreen(): void {\n283:   process.stdout.write(\"\\x1b[2J\\x1b[H\");\n284: }\n285: \n286: /**\n287:  * Print a feature selection table (for launch preview).\n288:  */\n289: export function printFeatureSelection(\n290:   features: Array<{\n291:     id: string;\n292:     title: string;\n293:     priority: string;\n294:     difficulty: string;\n295:     effort: string;\n296:   }>\n297: ): void {\n298:   console.log(\"\");\n299:   console.log(`${BOLD}Selected Tasks (${features.length}):${RESET}`);\n300:   console.log(\"\");\n301: \n302:   const header = [\n303:     pad(\"#\", 4),\n304:     pad(\"Feature ID\", 30),\n305:     pad(\"Priority\", 10),\n306:     pad(\"Difficulty\", 12),\n307:     padLeft(\"Effort\", 8),\n308:     pad(\"Title\", 40),\n309:   ].join(\" \");\n310:   console.log(`${BOLD}${header}${RESET}`);\n311:   console.log(\"-\".repeat(108));\n312: \n313:   for (let i = 0; i < features.length; i++) {\n314:     const f = features[i];\n315:     const effortMin = parseDurationMinutes(f.effort);\n316:     const row = [\n317:       pad(`${i + 1}.`, 4),\n318:       pad(f.id, 30),\n319:       pad(f.priority, 10),\n320:       pad(f.difficulty, 12),\n321:       padLeft(formatDuration(effortMin), 8),\n322:       pad(f.title, 40),\n323:     ].join(\" \");\n324:     console.log(row);\n325:   }\n326: \n327:   console.log(\"\");\n328: }\n\n(End of file - total 328 lines)\n</content>","title":"src/lib/ui.ts","metadata":{"preview":"/**\n * ui.ts — Terminal dashboard for wave status display.\n *\n * Responsibilities:\n *   - Render a live status table of all agents in a wave\n *   - Show progress indicators, timing, retry counts\n *   - Color-coded status output\n *   - Summary statistics\n */\n\nimport type { WaveState, AgentState, AgentStatus } from \"./state.js\";\nimport { agentCounts, areAgentDepsReady } from \"./state.js\";\nimport { formatDuration, parseDurationMinutes } from \"./tasks.js\";\n\n// ---------------------------------------------------------------------------\n// ANSI Color Helpers\n// ---------------------------------------------------------------------------\n\nconst RESET = \"\\x1b[0m\";\nconst BOLD = \"\\x1b[1m\";","truncated":false,"loaded":[]},"time":{"start":1773482645613,"end":1773482645616}}}}
