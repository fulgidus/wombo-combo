{"type":"tool_use","timestamp":1773482818245,"sessionID":"ses_314328d09ffeHamS8Go5GE0ezF","part":{"id":"prt_cebd038d80018uB5047nh3Eatk","sessionID":"ses_314328d09ffeHamS8Go5GE0ezF","messageID":"msg_cebd026cf001rn4lwgN0UoM1dT","type":"tool","callID":"toolu_vrtx_016TWdtyPDfvHuSJESoeRQ37","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/wave-state-integrity/src/commands/launch.ts","offset":1168,"limit":30},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/wave-state-integrity/src/commands/launch.ts</path>\n<type>file</type>\n<content>1168:   // Handle graceful shutdown\n1169:   //\n1170:   // Audit (wave-detach-audit): This is the critical shutdown path for headless\n1171:   // agents. Because agents are spawned with `detached: false` (see launcher.ts),\n1172:   // they would be killed by the OS when the parent exits anyway. However, calling\n1173:   // `monitor.killAll()` explicitly before `process.exit(0)` ensures:\n1174:   //   1. Each agent gets SIGTERM (not SIGKILL), allowing graceful shutdown\n1175:   //   2. Wave state is saved BEFORE agents die, preserving progress\n1176:   //   3. The TUI is cleanly destroyed before terminal restoration\n1177:   //\n1178:   // If the parent is killed with SIGKILL (uncatchable), agents die immediately\n1179:   // with no state save. `woco resume` recovers from this by detecting orphaned\n1180:   // worktrees with commits and re-verifying or re-launching as appropriate.\n1181:   process.on(\"SIGINT\", () => {\n1182:     if (tuiRef.current) tuiRef.current.stop();\n1183:     for (const agent of state.agents) {\n1184:       if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n1185:         updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n1186:       }\n1187:     }\n1188:     monitor.killAll();\n1189:     flushState(projectRoot, state);\n1190:     if (fmt === \"text\") console.log(\"\\nState saved. Use 'woco resume' to continue.\");\n1191:     process.exit(0);\n1192:   });\n1193: \n1194:   // Launch initial batch — only agents whose dependencies are already satisfied\n1195:   // Stagger launches to avoid SQLite race conditions in agent processes:\n1196:   // each agent spawns its own DB, and simultaneous CREATE TABLE calls collide.\n1197:   const ready = readyToLaunchAgents(state);\n\n(Showing lines 1168-1197 of 1941. Use offset=1198 to continue.)\n</content>","title":"src/commands/launch.ts","metadata":{"preview":"  // Handle graceful shutdown\n  //\n  // Audit (wave-detach-audit): This is the critical shutdown path for headless\n  // agents. Because agents are spawned with `detached: false` (see launcher.ts),\n  // they would be killed by the OS when the parent exits anyway. However, calling\n  // `monitor.killAll()` explicitly before `process.exit(0)` ensures:\n  //   1. Each agent gets SIGTERM (not SIGKILL), allowing graceful shutdown\n  //   2. Wave state is saved BEFORE agents die, preserving progress\n  //   3. The TUI is cleanly destroyed before terminal restoration\n  //\n  // If the parent is killed with SIGKILL (uncatchable), agents die immediately\n  // with no state save. `woco resume` recovers from this by detecting orphaned\n  // worktrees with commits and re-verifying or re-launching as appropriate.\n  process.on(\"SIGINT\", () => {\n    if (tuiRef.current) tuiRef.current.stop();\n    for (const agent of state.agents) {\n      if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n        updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n      }\n    }","truncated":true,"loaded":[]},"time":{"start":1773482818240,"end":1773482818244}}}}
