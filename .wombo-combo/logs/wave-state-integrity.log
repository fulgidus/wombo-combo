{"type":"tool_use","timestamp":1773482650637,"sessionID":"ses_314328d09ffeHamS8Go5GE0ezF","part":{"id":"prt_cebcdaa55001dP3PebPWVoaWb2","sessionID":"ses_314328d09ffeHamS8Go5GE0ezF","messageID":"msg_cebcd9922001Sirb5xyqiMB8Pd","type":"tool","callID":"toolu_vrtx_0132JiTZZi5nREAgXGWKdY6x","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/wave-state-integrity/src/commands/resume.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/wave-state-integrity/src/commands/resume.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * resume.ts — Resume a previously stopped wave.\n3:  *\n4:  * Usage: woco resume [options] [--output json]\n5:  *\n6:  * Restores from .wombo-combo/state.json:\n7:  *   - Agents in \"running\"/\"installing\" whose PID is dead → re-check or re-launch\n8:  *   - Agents in \"queued\" → launch them\n9:  *   - Agents in terminal states (verified/failed/merged) → leave alone\n10:  *\n11:  * ## Agent Recovery (audit: wave-detach-audit)\n12:  *\n13:  * This is the primary recovery mechanism for agents that died when the parent\n14:  * process was terminated (gracefully via SIGINT, or ungracefully via SIGKILL/crash).\n15:  *\n16:  * Recovery triage for each agent:\n17:  *   - PID still alive → leave it running (another wombo instance may still be active)\n18:  *   - PID dead + worktree has commits → run build verification on existing work\n19:  *   - PID dead + no commits → reset to \"queued\" for a fresh re-launch\n20:  *   - \"completed\" → verify build\n21:  *   - \"verified\" → attempt merge\n22:  *   - \"failed\" with retries remaining + worktree has commits → re-verify\n23:  *   - \"failed\" with retries remaining + no commits → re-launch\n24:  *   - \"failed\" with retries exhausted → leave alone (user can `woco retry`)\n25:  *\n26:  * This design means no agent work is permanently lost unless the worktree\n27:  * itself is destroyed (e.g., by `woco cleanup`).\n28:  */\n29: \n30: import type { WomboConfig } from \"../config.js\";\n31: import type { Feature } from \"../lib/tasks.js\";\n32: import { loadFeatures } from \"../lib/tasks.js\";\n33: import {\n34:   loadState,\n35:   saveState,\n36:   updateAgent,\n37:   queuedAgents,\n38:   readyToLaunchAgents,\n39:   cancelDownstream,\n40:   isWaveComplete,\n41:   type WaveState,\n42:   type AgentState,\n43: } from \"../lib/state.js\";\n44: import {\n45:   createWorktree,\n46:   installDeps,\n47:   worktreeReady,\n48:   worktreeExists,\n49:   branchHasChanges,\n50:   removeWorktree,\n51:   log as wtLog,\n52: } from \"../lib/worktree.js\";\n53: import { generatePrompt, type QuestPromptContext } from \"../lib/prompt.js\";\n54: import {\n55:   launchInteractive,\n56:   isProcessRunning,\n57:   getMultiplexerName,\n58: } from \"../lib/launcher.js\";\n59: import { ProcessMonitor } from \"../lib/monitor.js\";\n60: import { pushBaseBranch } from \"../lib/merger.js\";\n61: import { runBuild } from \"../lib/verifier.js\";\n62: import { printDashboard, printAgentUpdate } from \"../lib/ui.js\";\n63: import { WomboTUI } from \"../lib/tui.js\";\n64: import {\n65:   launchSingleHeadless,\n66:   handleBuildVerification,\n67:   handleRetry,\n68:   launchNextQueued,\n69:   launchAllReady,\n70:   markFeatureDone,\n71:   attemptMerge,\n72:   dumpFailedAgentLogs,\n73: } from \"./launch.js\";\n74: import {\n75:   detectMultiplexer,\n76:   muxAttachCommand,\n77: } from \"../lib/multiplexer.js\";\n78: import { exportWaveHistory } from \"../lib/history.js\";\n79: import { outputError, outputMessage, type OutputFormat } from \"../lib/output.js\";\n80: import {\n81:   prepareAgentDefinitions,\n82:   isSpecializedAgent,\n83:   type AgentResolution,\n84: } from \"../lib/agent-registry.js\";\n85: import { patchImportedAgent } from \"../lib/templates.js\";\n86: import { writeAgentToWorktree } from \"../lib/agent-registry.js\";\n87: import { loadQuest, loadQuestKnowledge } from \"../lib/quest-store.js\";\n88: import { resolveQuestConfig, type QuestHitlMode } from \"../lib/quest.js\";\n89: import { getPendingQuestions, cleanupAll as cleanupHitl, submitAnswer, type HitlQuestion } from \"../lib/hitl-channel.js\";\n90: \n91: // ---------------------------------------------------------------------------\n92: // Types\n93: // ---------------------------------------------------------------------------\n94: \n95: export interface ResumeCommandOptions {\n96:   projectRoot: string;\n97:   config: WomboConfig;\n98:   maxConcurrent?: number;\n99:   model?: string;\n100:   interactive: boolean;\n101:   noTui: boolean;\n102:   autoPush: boolean;\n103:   baseBranch?: string;\n104:   maxRetries?: number;\n105:   outputFmt?: OutputFormat;\n106: }\n107: \n108: // ---------------------------------------------------------------------------\n109: // Command\n110: // ---------------------------------------------------------------------------\n111: \n112: export async function cmdResume(opts: ResumeCommandOptions): Promise<void> {\n113:   const { projectRoot } = opts;\n114:   let { config } = opts;\n115:   const fmt = opts.outputFmt ?? \"text\";\n116: \n117:   const state = loadState(projectRoot);\n118:   if (!state) {\n119:     outputError(fmt, \"No wave state found. Use 'woco launch' to start a new wave.\");\n120:     return; // unreachable — outputError calls process.exit\n121:   }\n122: \n123:   if (fmt === \"text\") {\n124:     console.log(`\\n--- wombo-combo: Resume ${state.wave_id} ---\\n`);\n125:   }\n126: \n127:   // Reconstruct quest context from wave state (if quest-scoped)\n128:   let questContext: QuestPromptContext | undefined;\n129:   let hitlMode: string | undefined;\n130:   if (state.quest_id) {\n131:     const quest = loadQuest(projectRoot, state.quest_id);\n132:     if (quest) {\n133:       config = resolveQuestConfig(config, quest);\n134:       hitlMode = quest.hitlMode;\n135:       const knowledge = loadQuestKnowledge(projectRoot, state.quest_id);\n136:       questContext = {\n137:         questId: quest.id,\n138:         goal: quest.goal,\n139:         addedConstraints: quest.constraints.add ?? [],\n140:         addedForbidden: quest.constraints.ban ?? [],\n141:         knowledge,\n142:       };\n143:       if (fmt === \"text\") {\n144:         console.log(`Quest: ${quest.title} (${quest.id})\\n`);\n145:       }\n146:     } else if (fmt === \"text\") {\n147:       console.warn(`Warning: wave references quest \"${state.quest_id}\" but it was not found.\\n`);\n148:     }\n149:   }\n150: \n151:   // Load feature data for prompt generation\n152:   const data = loadFeatures(projectRoot, config);\n153:   const featureMap = new Map(data.tasks.map((f: Feature) => [f.id, f]));\n154: \n155:   // Triage agents by current state\n156:   let toRelaunch: AgentState[] = [];\n157:   let toVerify: AgentState[] = [];\n158: \n159:   for (const agent of state.agents) {\n160:     switch (agent.status) {\n161:       case \"running\":\n162:       case \"installing\":\n163:       case \"retry\":\n164:       case \"resolving_conflict\":\n165:         // Was in-flight when we stopped — check if PID is still alive\n166:         if (agent.pid && isProcessRunning(agent.pid)) {\n167:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: still running (PID ${agent.pid}), leaving alone`);\n168:         } else {\n169:           // Process is dead — check if worktree exists with meaningful changes.\n170:           // Use worktreeExists (not worktreeReady) because node_modules may be\n171:           // missing — the worktree still has code that should be verified.\n172:           if (worktreeExists(agent.worktree) && branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n173:             // Worktree exists AND branch has commits — try build verification\n174:             if (fmt === \"text\") console.log(`  ${agent.feature_id}: process dead, worktree has changes — will verify build`);\n175:             toVerify.push(agent);\n176:           } else {\n177:             // No worktree, or worktree exists but branch has no commits (agent did nothing)\n178:             const reason = worktreeExists(agent.worktree)\n179:               ? \"worktree exists but no code changes\"\n180:               : \"no worktree\";\n181:             if (fmt === \"text\") console.log(`  ${agent.feature_id}: process dead, ${reason} — will re-launch`);\n182:             updateAgent(state, agent.feature_id, {\n183:               status: \"queued\",\n184:               pid: null,\n185:               activity: null,\n186:               session_id: null,\n187:             });\n188:             toRelaunch.push(agent);\n189:           }\n190:         }\n191:         break;\n192: \n193:       case \"queued\":\n194:         if (fmt === \"text\") console.log(`  ${agent.feature_id}: queued — will launch`);\n195:         toRelaunch.push(agent);\n196:         break;\n197: \n198:       case \"completed\":\n199:         // Completed but not verified — verify\n200:         if (fmt === \"text\") console.log(`  ${agent.feature_id}: completed — will verify build`);\n201:         toVerify.push(agent);\n202:         break;\n203: \n204:       case \"verified\":\n205:         // Build passed but NOT yet merged — need to attempt merge (+ conflict resolution)\n206:         if (fmt === \"text\") console.log(`  ${agent.feature_id}: verified — will attempt merge`);\n207:         toVerify.push(agent);\n208:         break;\n209: \n210:       case \"merged\":\n211:         if (fmt === \"text\") console.log(`  ${agent.feature_id}: merged — marking feature as done`);\n212:         markFeatureDone(projectRoot, agent.feature_id, config, state.base_branch, fmt);\n213:         try {\n214:           removeWorktree(projectRoot, agent.worktree, true);\n215:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: worktree and branch removed`);\n216:         } catch {\n217:           // Already cleaned — not critical\n218:         }\n219:         break;\n220: \n221:       case \"failed\":\n222:         // If the worktree exists with code changes and retries remain,\n223:         // attempt build verification rather than discarding the work.\n224:         if (agent.retries < agent.max_retries &&\n225:             worktreeExists(agent.worktree) &&\n226:             branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n227:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: failed but has work (retry ${agent.retries}/${agent.max_retries}) — will verify build`);\n228:           // Clear stale error and mark as completed so handleBuildVerification\n229:           // processes it correctly (it expects a non-failed agent)\n230:           updateAgent(state, agent.feature_id, {\n231:             status: \"completed\",\n232:             error: null,\n233:             build_passed: null,\n234:             build_output: null,\n235:             completed_at: new Date().toISOString(),\n236:           });\n237:           toVerify.push(agent);\n238:         } else if (agent.retries < agent.max_retries) {\n239:           // No worktree or no changes — re-launch from scratch\n240:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: failed, no salvageable work (retry ${agent.retries}/${agent.max_retries}) — will re-launch`);\n241:           updateAgent(state, agent.feature_id, {\n242:             status: \"queued\",\n243:             pid: null,\n244:             error: null,\n245:             build_passed: null,\n246:             build_output: null,\n247:             activity: null,\n248:             session_id: null,\n249:             completed_at: null,\n250:           });\n251:           toRelaunch.push(agent);\n252:         } else {\n253:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: failed — max retries reached (use 'woco retry' to reset)`);\n254:         }\n255:         break;\n256:     }\n257:   }\n258: \n259:   saveState(projectRoot, state);\n260: \n261:   // ---------------------------------------------------------------------------\n262:   // Phase 1: Parallel build verification\n263:   // Each agent's worktree is independent, so dep install + build can run\n264:   // concurrently. Merges must remain sequential (they mutate the project root).\n265:   // ---------------------------------------------------------------------------\n266:   if (toVerify.length > 0) {\n267:     if (fmt === \"text\") console.log(`\\nVerifying ${toVerify.length} agent(s) in parallel...\\n`);\n268: \n269:     const verifyResults = await Promise.all(\n270:       toVerify.map(async (agent): Promise<{ agent: AgentState; needsMerge: boolean }> => {\n271:         const feature = featureMap.get(agent.feature_id);\n272:         if (!feature) return { agent, needsMerge: false };\n273: \n274:         // Already verified — skip build, go straight to merge\n275:         if (agent.status === \"verified\") {\n276:           printAgentUpdate(agent, \"already verified — queued for merge\");\n277:           return { agent, needsMerge: true };\n278:         }\n279: \n280:         printAgentUpdate(agent, \"verifying build...\");\n281: \n282:         // Ensure deps are installed — worktree may exist without node_modules\n283:         // (e.g., failed agents whose setup was interrupted)\n284:         if (!worktreeReady(agent.worktree) && worktreeExists(agent.worktree)) {\n285:           try {\n286:             printAgentUpdate(agent, \"installing deps...\");\n287:             await installDeps(agent.worktree, agent.feature_id, config);\n288:           } catch (depErr: any) {\n289:             printAgentUpdate(agent, `dep install failed: ${depErr.message}`);\n290:             updateAgent(state, agent.feature_id, {\n291:               status: \"failed\",\n292:               error: `Dependency install failed: ${depErr.message}`,\n293:               retries: agent.retries + 1,\n294:               completed_at: new Date().toISOString(),\n295:             });\n296:             saveState(projectRoot, state);\n297:             return { agent, needsMerge: false };\n298:           }\n299:         }\n300: \n301:         try {\n302:           const buildResult = await runBuild(agent.worktree, config);\n303:           if (buildResult.passed) {\n304:             updateAgent(state, agent.feature_id, {\n305:               status: \"verified\",\n306:               build_passed: true,\n307:               build_output: null,\n308:             });\n309:             saveState(projectRoot, state);\n310:             printAgentUpdate(agent, `BUILD PASSED (${Math.round(buildResult.durationMs / 1000)}s)`);\n311:             return { agent, needsMerge: true };\n312:           } else {\n313:             // Build failed\n314:             if (agent.retries < agent.max_retries) {\n315:               updateAgent(state, agent.feature_id, {\n316:                 status: \"retry\",\n317:                 retries: agent.retries + 1,\n318:                 build_passed: false,\n319:                 build_output: buildResult.errorSummary,\n320:               });\n321:               saveState(projectRoot, state);\n322:               printAgentUpdate(agent, `BUILD FAILED — will retry (${agent.retries + 1}/${agent.max_retries})`);\n323:             } else {\n324:               updateAgent(state, agent.feature_id, {\n325:                 status: \"failed\",\n326:                 build_passed: false,\n327:                 build_output: buildResult.errorSummary,\n328:                 error: `Build failed after ${agent.max_retries} retries`,\n329:                 completed_at: new Date().toISOString(),\n330:               });\n331:               saveState(projectRoot, state);\n332:               printAgentUpdate(agent, \"BUILD FAILED — max retries reached\");\n333:             }\n334:             return { agent, needsMerge: false };\n335:           }\n336:         } catch (err: any) {\n337:           printAgentUpdate(agent, `verify error: ${err.message}`);\n338:           updateAgent(state, agent.feature_id, {\n339:             status: \"failed\",\n340:             error: `Build verification error: ${err.message}`,\n341:             completed_at: new Date().toISOString(),\n342:           });\n343:           saveState(projectRoot, state);\n344:           return { agent, needsMerge: false };\n345:         }\n346:       })\n347:     );\n348: \n349:     saveState(projectRoot, state);\n350: \n351:     // -------------------------------------------------------------------------\n352:     // Phase 2: Sequential merge for verified agents\n353:     // Merges must be sequential because they operate on the project root.\n354:     // -------------------------------------------------------------------------\n355:     const toMerge = verifyResults.filter((r) => r.needsMerge);\n356:     if (toMerge.length > 0) {\n357:       if (fmt === \"text\") console.log(`\\nMerging ${toMerge.length} verified agent(s)...\\n`);\n358:       for (const { agent } of toMerge) {\n359:         const feature = featureMap.get(agent.feature_id);\n360:         if (!feature) continue;\n361:         try {\n362:           await attemptMerge(projectRoot, state, agent, feature, config, opts.model);\n363:         } catch (err: any) {\n364:           printAgentUpdate(agent, `merge error: ${err.message}`);\n365:         }\n366:       }\n367:     }\n368: \n369:     // Collect agents that need re-launching from verify results\n370:     for (const { agent } of verifyResults) {\n371:       if (agent.status === \"retry\" || agent.status === \"running\") {\n372:         toRelaunch.push(agent);\n373:       }\n374:     }\n375:   }\n376: \n377:   // Re-launch agents\n378:   const maxConcurrent = opts.maxConcurrent ?? state.max_concurrent;\n379:   const toLaunchNow = toRelaunch.slice(0, maxConcurrent);\n380:   if (toLaunchNow.length === 0) {\n381:     outputMessage(fmt, \"No agents need (re)launching.\", {\n382:       wave_id: state.wave_id,\n383:       triage: {\n384:         to_verify: toVerify.length,\n385:         to_relaunch: 0,\n386:       },\n387:       agents: state.agents.map((a) => ({\n388:         feature_id: a.feature_id,\n389:         status: a.status,\n390:         build_passed: a.build_passed,\n391:         error: a.error,\n392:       })),\n393:     });\n394:     if (fmt === \"text\") printDashboard(state);\n395:     return;\n396:   }\n397: \n398:   // ---------------------------------------------------------------------------\n399:   // Re-resolve specialized agents for relaunched tasks that have agent_type\n400:   // ---------------------------------------------------------------------------\n401:   let agentResolutions: Map<string, AgentResolution> | undefined;\n402: \n403:   if (config.agentRegistry.mode !== \"disabled\") {\n404:     const agentsWithType = toLaunchNow.filter((a) => a.agent_type);\n405:     if (agentsWithType.length > 0) {\n406:       // Build feature list for tasks being relaunched\n407:       const featuresToResolve = agentsWithType\n408:         .map((a) => featureMap.get(a.feature_id))\n409:         .filter((f): f is Feature => !!f);\n410:       if (featuresToResolve.length > 0) {\n411:         if (fmt === \"text\") console.log(`\\nRe-resolving ${featuresToResolve.length} specialized agent(s) from registry...`);\n412:         try {\n413:           agentResolutions = await prepareAgentDefinitions(featuresToResolve, config, projectRoot);\n414:         } catch (err: any) {\n415:           if (fmt === \"text\") console.log(`  WARN: agent resolution failed, using cached agent names: ${err.message}`);\n416:         }\n417:       }\n418:     }\n419:   }\n420: \n421:   if (fmt === \"text\") {\n422:     console.log(`\\nRe-launching ${toLaunchNow.length} agent(s)...\\n`);\n423:     printDashboard(state);\n424:   }\n425:   const model = opts.model ?? state.model ?? undefined;\n426: \n427:   if (opts.interactive) {\n428:     // Interactive resume\n429:     await Promise.all(\n430:       toLaunchNow.map(async (agent) => {\n431:         const feature = featureMap.get(agent.feature_id);\n432:         if (!feature) return;\n433: \n434:         updateAgent(state, agent.feature_id, {\n435:           status: \"installing\",\n436:           started_at: new Date().toISOString(),\n437:           activity: \"resuming...\",\n438:         });\n439:         saveState(projectRoot, state);\n440: \n441:         try {\n442:           if (!worktreeReady(agent.worktree)) {\n443:             await createWorktree(projectRoot, agent.feature_id, state.base_branch, config);\n444:             await installDeps(agent.worktree, agent.feature_id, config);\n445:           }\n446: \n447:           // Write specialized agent to worktree if applicable\n448:           const resolution = agentResolutions?.get(agent.feature_id);\n449:           const agentName = agent.agent_name ?? undefined;\n450:           if (resolution && isSpecializedAgent(resolution)) {\n451:             try {\n452:               const patchedContent = patchImportedAgent(resolution.rawContent, config, projectRoot);\n453:               writeAgentToWorktree(agent.worktree, resolution.name, patchedContent);\n454:               wtLog(agent.feature_id, `wrote specialized agent: ${resolution.name}`);\n455:             } catch (err: any) {\n456:               wtLog(agent.feature_id, `WARN: failed to write specialized agent: ${err.message}`);\n457:             }\n458:           }\n459: \n460:           const prompt = generatePrompt(feature, state.base_branch, config, questContext, hitlMode as QuestHitlMode | undefined);\n461:           const result = launchInteractive({\n462:             worktreePath: agent.worktree,\n463:             featureId: feature.id,\n464:             prompt,\n465:             model,\n466:             interactive: true,\n467:             config,\n468:             agentName,\n469:           });\n470: \n471:           const muxName = getMultiplexerName(config);\n472:           updateAgent(state, agent.feature_id, {\n473:             status: \"running\",\n474:             pid: result.pid,\n475:             activity: `${muxName} session active`,\n476:           });\n477:           saveState(projectRoot, state);\n478:         } catch (err: any) {\n479:           updateAgent(state, agent.feature_id, {\n480:             status: \"failed\",\n481:             error: err.message,\n482:             activity: null,\n483:             completed_at: new Date().toISOString(),\n484:           });\n485:           saveState(projectRoot, state);\n486:         }\n487:       })\n488:     );\n489: \n490:     if (fmt === \"text\") {\n491:       printDashboard(state);\n492:       const mux = detectMultiplexer(config.agent.multiplexer);\n493:       console.log(`\\nResume complete. Use '${muxAttachCommand(mux, `${config.agent.tmuxPrefix}-<id>`)}' to check sessions.`);\n494:     }\n495:   } else {\n496:     // Headless resume — re-enter monitoring loop\n497:     const monitor = new ProcessMonitor(projectRoot, {\n498:       onSessionId: (featureId, sessionId) => {\n499:         updateAgent(state, featureId, { session_id: sessionId });\n500:         saveState(projectRoot, state);\n501:       },\n502:       onComplete: (featureId) => {\n503:         updateAgent(state, featureId, {\n504:           status: \"completed\",\n505:           completed_at: new Date().toISOString(),\n506:           activity: \"done\",\n507:         });\n508:         saveState(projectRoot, state);\n509:         wtLog(featureId, \"agent completed — verifying build...\");\n510: \n511:         const agent = state.agents.find((a) => a.feature_id === featureId)!;\n512:         const feature = featureMap.get(featureId)!;\n513:         handleBuildVerification(projectRoot, state, agent, feature, config, model, monitor, undefined, hitlMode)\n514:           .then(() => launchAllReady(projectRoot, state, featureMap, monitor, config, model, undefined, questContext, hitlMode))\n515:           .catch((err) => {\n516:             wtLog(featureId, `BUILD VERIFICATION UNHANDLED ERROR: ${err.message}`);\n517:             launchAllReady(projectRoot, state, featureMap, monitor, config, model, undefined, questContext, hitlMode);\n518:           });\n519:       },\n520:       onError: (featureId, error) => {\n521:         const agent = state.agents.find((a) => a.feature_id === featureId)!;\n522:         if (agent.retries < agent.max_retries) {\n523:           updateAgent(state, featureId, {\n524:             status: \"retry\",\n525:             retries: agent.retries + 1,\n526:             error,\n527:             activity: \"retrying...\",\n528:           });\n529:           saveState(projectRoot, state);\n530:           handleRetry(projectRoot, state, agent, monitor, config, model, hitlMode);\n531:         } else {\n532:           updateAgent(state, featureId, {\n533:             status: \"failed\",\n534:             error,\n535:             activity: null,\n536:             completed_at: new Date().toISOString(),\n537:           });\n538:           saveState(projectRoot, state);\n539: \n540:           // Cascade failure to downstream agents\n541:           const cancelled = cancelDownstream(state, featureId);\n542:           if (cancelled.length > 0) {\n543:             wtLog(featureId, `downstream cancelled: ${cancelled.join(\", \")}`);\n544:             saveState(projectRoot, state);\n545:           }\n546:         }\n547:         launchAllReady(projectRoot, state, featureMap, monitor, config, model, undefined, questContext, hitlMode);\n548:       },\n549:       onActivity: (featureId, activity) => {\n550:         updateAgent(state, featureId, {\n551:           activity,\n552:           activity_updated_at: new Date().toISOString(),\n553:         });\n554:       },\n555:     });\n556: \n557:     // Handle graceful shutdown\n558:     // Audit (wave-detach-audit): Same pattern as launch.ts — see launch.ts\n559:     // SIGINT handler for detailed lifecycle documentation. Agents are\n560:     // non-detached children; killAll() gives them SIGTERM before exit.\n561:     const tuiRef = { current: null as WomboTUI | null };\n562:     process.on(\"SIGINT\", () => {\n563:       if (tuiRef.current) tuiRef.current.stop();\n564:       for (const agent of state.agents) {\n565:         if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n566:           updateAgent(state, agent.feature_id, {\n567:             activity: \"interrupted\",\n568:           });\n569:         }\n570:       }\n571:       monitor.killAll();\n572:       saveState(projectRoot, state);\n573:       if (fmt === \"text\") console.log(\"\\nState saved. Use 'woco resume' to continue.\");\n574:       process.exit(0);\n575:     });\n576: \n577:     await Promise.all(\n578:       toLaunchNow.map((agent) => {\n579:         const feature = featureMap.get(agent.feature_id);\n580:         if (!feature) return Promise.resolve();\n581:         return launchSingleHeadless(projectRoot, state, agent, feature, monitor, config, model, agentResolutions, questContext, hitlMode);\n582:       })\n583:     );\n584: \n585:     // Start TUI dashboard (or skip if --no-tui)\n586:     if (!opts.noTui) {\n587:       tuiRef.current = new WomboTUI({\n588:         state,\n589:         monitor,\n590:         projectRoot,\n591:         interactive: false,\n592:         config,\n593:         onQuit: () => {\n594:           // Audit (wave-detach-audit): Same killAll() + saveState pattern as\n595:           // launch.ts onQuit. See launch.ts for full lifecycle documentation.\n596:           for (const agent of state.agents) {\n597:             if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n598:               updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n599:             }\n600:           }\n601:           monitor.killAll();\n602:           saveState(projectRoot, state);\n603:           if (fmt === \"text\") console.log(\"State saved. Use 'woco resume' to continue.\");\n604:           process.exit(0);\n605:         },\n606:         onRetry: (featureId: string) => {\n607:           const agent = state.agents.find((a) => a.feature_id === featureId);\n608:           if (!agent) return;\n609:           if (agent.status !== \"failed\" && agent.status !== \"retry\") return;\n610: \n611:           // Reset retries if exhausted, give it one more shot\n612:           if (agent.retries >= agent.max_retries) {\n613:             updateAgent(state, featureId, { max_retries: agent.retries + 1 });\n614:           }\n615: \n616:           wtLog(featureId, `manual retry requested from TUI — resetting to queued`);\n617:           updateAgent(state, featureId, {\n618:             status: \"queued\",\n619:             error: null,\n620:             activity: \"waiting for relaunch (manual retry)...\",\n621:           });\n622:           saveState(projectRoot, state);\n623:         },\n624:         onAnswer: (agentId: string, questionId: string, answerText: string) => {\n625:           try {\n626:             submitAnswer(projectRoot, agentId, questionId, answerText);\n627:             wtLog(agentId, `HITL answer submitted: \"${answerText.slice(0, 80)}${answerText.length > 80 ? \"...\" : \"\"}\"`);\n628:           } catch (err: any) {\n629:             wtLog(agentId, `HITL answer error: ${err.message}`);\n630:           }\n631:         },\n632:       });\n633:       tuiRef.current.start();\n634:     } else {\n635:       if (fmt === \"text\") console.log(\"(--no-tui mode, dashboard prints every 15s)\\n\");\n636:       printDashboard(state);\n637:     }\n638: \n639:     // Monitoring loop\n640:     const POLL_INTERVAL = 5000;\n641:     let dashboardCounter = 0;\n642:     while (!isWaveComplete(state)) {\n643:       await new Promise((r) => setTimeout(r, POLL_INTERVAL));\n644: \n645:       for (const agent of state.agents) {\n646:         if (\n647:           (agent.status === \"running\" || agent.status === \"resolving_conflict\") &&\n648:           agent.pid &&\n649:           !isProcessRunning(agent.pid) &&\n650:           !monitor.isRunning(agent.feature_id)\n651:         ) {\n652:           if (agent.status === \"resolving_conflict\") {\n653:             // Conflict resolver died unexpectedly — mark as failed\n654:             updateAgent(state, agent.feature_id, {\n655:               status: \"failed\",\n656:               error: \"Conflict resolver process died unexpectedly\",\n657:               activity: null,\n658:               completed_at: new Date().toISOString(),\n659:             });\n660:             saveState(projectRoot, state);\n661:             wtLog(agent.feature_id, \"conflict resolver died — marked failed\");\n662: \n663:             // Cascade failure to downstream agents\n664:             const cancelled = cancelDownstream(state, agent.feature_id);\n665:             if (cancelled.length > 0) {\n666:               wtLog(agent.feature_id, `downstream cancelled: ${cancelled.join(\", \")}`);\n667:               saveState(projectRoot, state);\n668:             }\n669: \n670:             launchAllReady(projectRoot, state, featureMap, monitor, config, model, undefined, questContext, hitlMode);\n671:             continue;\n672:           }\n673:           // Check if the agent actually made any commits\n674:           if (!branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n675:             // Agent died without producing any code — mark as failed\n676:             updateAgent(state, agent.feature_id, {\n677:               status: \"failed\",\n678:               error: \"Agent process exited without making any commits\",\n679:               activity: null,\n680:               completed_at: new Date().toISOString(),\n681:             });\n682:             saveState(projectRoot, state);\n683:             wtLog(agent.feature_id, \"process died with no code changes — marked failed\");\n684: \n685:             // Cascade failure to downstream agents\n686:             const cancelled = cancelDownstream(state, agent.feature_id);\n687:             if (cancelled.length > 0) {\n688:               wtLog(agent.feature_id, `downstream cancelled: ${cancelled.join(\", \")}`);\n689:               saveState(projectRoot, state);\n690:             }\n691:           } else {\n692:             updateAgent(state, agent.feature_id, {\n693:               status: \"completed\",\n694:               completed_at: new Date().toISOString(),\n695:               activity: \"done\",\n696:             });\n697:             saveState(projectRoot, state);\n698:             const feature = featureMap.get(agent.feature_id)!;\n699:             try {\n700:               await handleBuildVerification(projectRoot, state, agent, feature, config, model, monitor, undefined, hitlMode);\n701:             } catch (err: any) {\n702:               wtLog(agent.feature_id, `POLL VERIFY ERROR: ${err.message}`);\n703:             }\n704:           }\n705:           launchAllReady(projectRoot, state, featureMap, monitor, config, model, undefined, questContext, hitlMode);\n706:         }\n707:       }\n708: \n709:       saveState(projectRoot, state);\n710: \n711:       // Poll for HITL questions from agents and forward to TUI\n712:       if (hitlMode && hitlMode !== \"yolo\") {\n713:         try {\n714:           const pendingQuestions = getPendingQuestions(projectRoot);\n715:           if (tuiRef.current && pendingQuestions.length > 0) {\n716:             tuiRef.current.setPendingQuestions(pendingQuestions);\n717:           }\n718:         } catch {\n719:           // Non-fatal — HITL dir may not exist yet\n720:         }\n721:       }\n722: \n723:       if (tuiRef.current) {\n724:         tuiRef.current.updateState(state);\n725:       } else if (opts.noTui) {\n726:         dashboardCounter++;\n727:         if (dashboardCounter % 3 === 0) {\n728:           printDashboard(state);\n729:         }\n730:       }\n731:     }\n732: \n733:     // Wave complete — keep TUI open for post-mortem browsing\n734:     if (tuiRef.current) {\n735:       tuiRef.current.updateState(state);\n736:       tuiRef.current.markWaveComplete();\n737:       await tuiRef.current.waitForQuit();\n738:     }\n739: \n740:     if (fmt === \"text\") {\n741:       printDashboard(state);\n742: \n743:       // Dump full logs for failed agents (post-mortem)\n744:       dumpFailedAgentLogs(projectRoot, state, fmt);\n745:     }\n746: \n747:     // Clean up HITL files\n748:     try {\n749:       cleanupHitl(projectRoot);\n750:     } catch {\n751:       // Non-fatal\n752:     }\n753: \n754:     // Auto-export wave history\n755:     try {\n756:       const historyPath = exportWaveHistory(projectRoot, state);\n757:       if (fmt === \"text\") console.log(`Wave history exported to ${historyPath}`);\n758:     } catch (err: any) {\n759:       if (fmt === \"text\") console.error(`Warning: failed to export wave history: ${err.message}`);\n760:     }\n761: \n762:     // Auto-push base branch if requested\n763:     if (opts.autoPush) {\n764:       await pushBaseBranch(projectRoot, state.base_branch, config);\n765:     }\n766: \n767:     if (fmt === \"text\") console.log(\"Wave complete.\");\n768:   }\n769: }\n\n(End of file - total 769 lines)\n</content>","title":"src/commands/resume.ts","metadata":{"preview":"/**\n * resume.ts — Resume a previously stopped wave.\n *\n * Usage: woco resume [options] [--output json]\n *\n * Restores from .wombo-combo/state.json:\n *   - Agents in \"running\"/\"installing\" whose PID is dead → re-check or re-launch\n *   - Agents in \"queued\" → launch them\n *   - Agents in terminal states (verified/failed/merged) → leave alone\n *\n * ## Agent Recovery (audit: wave-detach-audit)\n *\n * This is the primary recovery mechanism for agents that died when the parent\n * process was terminated (gracefully via SIGINT, or ungracefully via SIGKILL/crash).\n *\n * Recovery triage for each agent:\n *   - PID still alive → leave it running (another wombo instance may still be active)\n *   - PID dead + worktree has commits → run build verification on existing work\n *   - PID dead + no commits → reset to \"queued\" for a fresh re-launch\n *   - \"completed\" → verify build","truncated":false,"loaded":[]},"time":{"start":1773482650631,"end":1773482650635}}}}
