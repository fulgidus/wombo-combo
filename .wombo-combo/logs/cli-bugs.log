{"type":"tool_use","timestamp":1773435865230,"sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","part":{"id":"prt_ce903c446001rKLZePa2K8dY0m","sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","messageID":"msg_ce903bbd20016vFIFsRcYODS8J","type":"tool","callID":"toolu_vrtx_019JexQQQEUxFgQdSHvxntQ5","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-cli-bugs/src/commands/resume.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-cli-bugs/src/commands/resume.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * resume.ts — Resume a previously stopped wave.\n3:  *\n4:  * Usage: woco resume [options]\n5:  *\n6:  * Restores from .wombo-combo/state.json:\n7:  *   - Agents in \"running\"/\"installing\" whose PID is dead → re-check or re-launch\n8:  *   - Agents in \"queued\" → launch them\n9:  *   - Agents in terminal states (verified/failed/merged) → leave alone\n10:  */\n11: \n12: import type { WomboConfig } from \"../config.js\";\n13: import type { Feature } from \"../lib/tasks.js\";\n14: import { loadFeatures } from \"../lib/tasks.js\";\n15: import {\n16:   loadState,\n17:   saveState,\n18:   updateAgent,\n19:   queuedAgents,\n20:   readyToLaunchAgents,\n21:   cancelDownstream,\n22:   isWaveComplete,\n23:   type WaveState,\n24:   type AgentState,\n25: } from \"../lib/state.js\";\n26: import {\n27:   createWorktree,\n28:   installDeps,\n29:   worktreeReady,\n30:   worktreeExists,\n31:   branchHasChanges,\n32:   removeWorktree,\n33:   log as wtLog,\n34: } from \"../lib/worktree.js\";\n35: import { generatePrompt } from \"../lib/prompt.js\";\n36: import {\n37:   launchInteractive,\n38:   isProcessRunning,\n39:   getMultiplexerName,\n40: } from \"../lib/launcher.js\";\n41: import { ProcessMonitor } from \"../lib/monitor.js\";\n42: import { pushBaseBranch } from \"../lib/merger.js\";\n43: import { runBuild } from \"../lib/verifier.js\";\n44: import { printDashboard, printAgentUpdate } from \"../lib/ui.js\";\n45: import { WomboTUI } from \"../lib/tui.js\";\n46: import {\n47:   launchSingleHeadless,\n48:   handleBuildVerification,\n49:   handleRetry,\n50:   launchNextQueued,\n51:   launchAllReady,\n52:   markFeatureDone,\n53:   attemptMerge,\n54:   dumpFailedAgentLogs,\n55: } from \"./launch.js\";\n56: import {\n57:   detectMultiplexer,\n58:   muxAttachCommand,\n59: } from \"../lib/multiplexer.js\";\n60: import { exportWaveHistory } from \"../lib/history.js\";\n61: \n62: // ---------------------------------------------------------------------------\n63: // Types\n64: // ---------------------------------------------------------------------------\n65: \n66: export interface ResumeCommandOptions {\n67:   projectRoot: string;\n68:   config: WomboConfig;\n69:   maxConcurrent?: number;\n70:   model?: string;\n71:   interactive: boolean;\n72:   noTui: boolean;\n73:   autoPush: boolean;\n74:   baseBranch?: string;\n75:   maxRetries?: number;\n76: }\n77: \n78: // ---------------------------------------------------------------------------\n79: // Command\n80: // ---------------------------------------------------------------------------\n81: \n82: export async function cmdResume(opts: ResumeCommandOptions): Promise<void> {\n83:   const { projectRoot, config } = opts;\n84: \n85:   const state = loadState(projectRoot);\n86:   if (!state) {\n87:     console.error(\"No wave state found. Use 'woco launch' to start a new wave.\");\n88:     process.exit(1);\n89:     return; // unreachable — helps TypeScript narrow\n90:   }\n91: \n92:   console.log(`\\n--- wombo-combo: Resume ${state.wave_id} ---\\n`);\n93: \n94:   // Load feature data for prompt generation\n95:   const data = loadFeatures(projectRoot, config);\n96:   const featureMap = new Map(data.tasks.map((f: Feature) => [f.id, f]));\n97: \n98:   // Triage agents by current state\n99:   let toRelaunch: AgentState[] = [];\n100:   let toVerify: AgentState[] = [];\n101: \n102:   for (const agent of state.agents) {\n103:     switch (agent.status) {\n104:       case \"running\":\n105:       case \"installing\":\n106:       case \"retry\":\n107:       case \"resolving_conflict\":\n108:         // Was in-flight when we stopped — check if PID is still alive\n109:         if (agent.pid && isProcessRunning(agent.pid)) {\n110:           console.log(`  ${agent.feature_id}: still running (PID ${agent.pid}), leaving alone`);\n111:         } else {\n112:           // Process is dead — check if worktree exists with meaningful changes.\n113:           // Use worktreeExists (not worktreeReady) because node_modules may be\n114:           // missing — the worktree still has code that should be verified.\n115:           if (worktreeExists(agent.worktree) && branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n116:             // Worktree exists AND branch has commits — try build verification\n117:             console.log(`  ${agent.feature_id}: process dead, worktree has changes — will verify build`);\n118:             toVerify.push(agent);\n119:           } else {\n120:             // No worktree, or worktree exists but branch has no commits (agent did nothing)\n121:             const reason = worktreeExists(agent.worktree)\n122:               ? \"worktree exists but no code changes\"\n123:               : \"no worktree\";\n124:             console.log(`  ${agent.feature_id}: process dead, ${reason} — will re-launch`);\n125:             updateAgent(state, agent.feature_id, {\n126:               status: \"queued\",\n127:               pid: null,\n128:               activity: null,\n129:               session_id: null,\n130:             });\n131:             toRelaunch.push(agent);\n132:           }\n133:         }\n134:         break;\n135: \n136:       case \"queued\":\n137:         console.log(`  ${agent.feature_id}: queued — will launch`);\n138:         toRelaunch.push(agent);\n139:         break;\n140: \n141:       case \"completed\":\n142:         // Completed but not verified — verify\n143:         console.log(`  ${agent.feature_id}: completed — will verify build`);\n144:         toVerify.push(agent);\n145:         break;\n146: \n147:       case \"verified\":\n148:         // Build passed but NOT yet merged — need to attempt merge (+ conflict resolution)\n149:         console.log(`  ${agent.feature_id}: verified — will attempt merge`);\n150:         toVerify.push(agent);\n151:         break;\n152: \n153:       case \"merged\":\n154:         console.log(`  ${agent.feature_id}: merged — marking feature as done`);\n155:         markFeatureDone(projectRoot, agent.feature_id, config, state.base_branch);\n156:         try {\n157:           removeWorktree(projectRoot, agent.worktree, true);\n158:           console.log(`  ${agent.feature_id}: worktree and branch removed`);\n159:         } catch {\n160:           // Already cleaned — not critical\n161:         }\n162:         break;\n163: \n164:       case \"failed\":\n165:         // If the worktree exists with code changes and retries remain,\n166:         // attempt build verification rather than discarding the work.\n167:         if (agent.retries < agent.max_retries &&\n168:             worktreeExists(agent.worktree) &&\n169:             branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n170:           console.log(`  ${agent.feature_id}: failed but has work (retry ${agent.retries}/${agent.max_retries}) — will verify build`);\n171:           // Clear stale error and mark as completed so handleBuildVerification\n172:           // processes it correctly (it expects a non-failed agent)\n173:           updateAgent(state, agent.feature_id, {\n174:             status: \"completed\",\n175:             error: null,\n176:             build_passed: null,\n177:             build_output: null,\n178:             completed_at: new Date().toISOString(),\n179:           });\n180:           toVerify.push(agent);\n181:         } else if (agent.retries < agent.max_retries) {\n182:           // No worktree or no changes — re-launch from scratch\n183:           console.log(`  ${agent.feature_id}: failed, no salvageable work (retry ${agent.retries}/${agent.max_retries}) — will re-launch`);\n184:           updateAgent(state, agent.feature_id, {\n185:             status: \"queued\",\n186:             pid: null,\n187:             error: null,\n188:             build_passed: null,\n189:             build_output: null,\n190:             activity: null,\n191:             session_id: null,\n192:             completed_at: null,\n193:           });\n194:           toRelaunch.push(agent);\n195:         } else {\n196:           console.log(`  ${agent.feature_id}: failed — max retries reached (use 'woco retry' to reset)`);\n197:         }\n198:         break;\n199:     }\n200:   }\n201: \n202:   saveState(projectRoot, state);\n203: \n204:   // ---------------------------------------------------------------------------\n205:   // Phase 1: Parallel build verification\n206:   // Each agent's worktree is independent, so dep install + build can run\n207:   // concurrently. Merges must remain sequential (they mutate the project root).\n208:   // ---------------------------------------------------------------------------\n209:   if (toVerify.length > 0) {\n210:     console.log(`\\nVerifying ${toVerify.length} agent(s) in parallel...\\n`);\n211: \n212:     const verifyResults = await Promise.all(\n213:       toVerify.map(async (agent): Promise<{ agent: AgentState; needsMerge: boolean }> => {\n214:         const feature = featureMap.get(agent.feature_id);\n215:         if (!feature) return { agent, needsMerge: false };\n216: \n217:         // Already verified — skip build, go straight to merge\n218:         if (agent.status === \"verified\") {\n219:           printAgentUpdate(agent, \"already verified — queued for merge\");\n220:           return { agent, needsMerge: true };\n221:         }\n222: \n223:         printAgentUpdate(agent, \"verifying build...\");\n224: \n225:         // Ensure deps are installed — worktree may exist without node_modules\n226:         // (e.g., failed agents whose setup was interrupted)\n227:         if (!worktreeReady(agent.worktree) && worktreeExists(agent.worktree)) {\n228:           try {\n229:             printAgentUpdate(agent, \"installing deps...\");\n230:             await installDeps(agent.worktree, agent.feature_id, config);\n231:           } catch (depErr: any) {\n232:             printAgentUpdate(agent, `dep install failed: ${depErr.message}`);\n233:             updateAgent(state, agent.feature_id, {\n234:               status: \"failed\",\n235:               error: `Dependency install failed: ${depErr.message}`,\n236:               retries: agent.retries + 1,\n237:               completed_at: new Date().toISOString(),\n238:             });\n239:             saveState(projectRoot, state);\n240:             return { agent, needsMerge: false };\n241:           }\n242:         }\n243: \n244:         try {\n245:           const buildResult = await runBuild(agent.worktree, config);\n246:           if (buildResult.passed) {\n247:             updateAgent(state, agent.feature_id, {\n248:               status: \"verified\",\n249:               build_passed: true,\n250:               build_output: null,\n251:             });\n252:             saveState(projectRoot, state);\n253:             printAgentUpdate(agent, `BUILD PASSED (${Math.round(buildResult.durationMs / 1000)}s)`);\n254:             return { agent, needsMerge: true };\n255:           } else {\n256:             // Build failed\n257:             if (agent.retries < agent.max_retries) {\n258:               updateAgent(state, agent.feature_id, {\n259:                 status: \"retry\",\n260:                 retries: agent.retries + 1,\n261:                 build_passed: false,\n262:                 build_output: buildResult.errorSummary,\n263:               });\n264:               saveState(projectRoot, state);\n265:               printAgentUpdate(agent, `BUILD FAILED — will retry (${agent.retries + 1}/${agent.max_retries})`);\n266:             } else {\n267:               updateAgent(state, agent.feature_id, {\n268:                 status: \"failed\",\n269:                 build_passed: false,\n270:                 build_output: buildResult.errorSummary,\n271:                 error: `Build failed after ${agent.max_retries} retries`,\n272:                 completed_at: new Date().toISOString(),\n273:               });\n274:               saveState(projectRoot, state);\n275:               printAgentUpdate(agent, \"BUILD FAILED — max retries reached\");\n276:             }\n277:             return { agent, needsMerge: false };\n278:           }\n279:         } catch (err: any) {\n280:           printAgentUpdate(agent, `verify error: ${err.message}`);\n281:           updateAgent(state, agent.feature_id, {\n282:             status: \"failed\",\n283:             error: `Build verification error: ${err.message}`,\n284:             completed_at: new Date().toISOString(),\n285:           });\n286:           saveState(projectRoot, state);\n287:           return { agent, needsMerge: false };\n288:         }\n289:       })\n290:     );\n291: \n292:     saveState(projectRoot, state);\n293: \n294:     // -------------------------------------------------------------------------\n295:     // Phase 2: Sequential merge for verified agents\n296:     // Merges must be sequential because they operate on the project root.\n297:     // -------------------------------------------------------------------------\n298:     const toMerge = verifyResults.filter((r) => r.needsMerge);\n299:     if (toMerge.length > 0) {\n300:       console.log(`\\nMerging ${toMerge.length} verified agent(s)...\\n`);\n301:       for (const { agent } of toMerge) {\n302:         const feature = featureMap.get(agent.feature_id);\n303:         if (!feature) continue;\n304:         try {\n305:           await attemptMerge(projectRoot, state, agent, feature, config, opts.model);\n306:         } catch (err: any) {\n307:           printAgentUpdate(agent, `merge error: ${err.message}`);\n308:         }\n309:       }\n310:     }\n311: \n312:     // Collect agents that need re-launching from verify results\n313:     for (const { agent } of verifyResults) {\n314:       if (agent.status === \"retry\" || agent.status === \"running\") {\n315:         toRelaunch.push(agent);\n316:       }\n317:     }\n318:   }\n319: \n320:   // Re-launch agents\n321:   const maxConcurrent = opts.maxConcurrent ?? state.max_concurrent;\n322:   const toLaunchNow = toRelaunch.slice(0, maxConcurrent);\n323:   if (toLaunchNow.length === 0) {\n324:     console.log(\"\\nNo agents need (re)launching.\");\n325:     printDashboard(state);\n326:     return;\n327:   }\n328: \n329:   console.log(`\\nRe-launching ${toLaunchNow.length} agent(s)...\\n`);\n330:   printDashboard(state);\n331: \n332:   const model = opts.model ?? state.model ?? undefined;\n333: \n334:   if (opts.interactive) {\n335:     // Interactive resume\n336:     await Promise.all(\n337:       toLaunchNow.map(async (agent) => {\n338:         const feature = featureMap.get(agent.feature_id);\n339:         if (!feature) return;\n340: \n341:         updateAgent(state, agent.feature_id, {\n342:           status: \"installing\",\n343:           started_at: new Date().toISOString(),\n344:           activity: \"resuming...\",\n345:         });\n346:         saveState(projectRoot, state);\n347: \n348:         try {\n349:           if (!worktreeReady(agent.worktree)) {\n350:             await createWorktree(projectRoot, agent.feature_id, state.base_branch, config);\n351:             await installDeps(agent.worktree, agent.feature_id, config);\n352:           }\n353: \n354:           const prompt = generatePrompt(feature, state.base_branch, config);\n355:           const result = launchInteractive({\n356:             worktreePath: agent.worktree,\n357:             featureId: feature.id,\n358:             prompt,\n359:             model,\n360:             interactive: true,\n361:             config,\n362:           });\n363: \n364:           const muxName = getMultiplexerName(config);\n365:           updateAgent(state, agent.feature_id, {\n366:             status: \"running\",\n367:             pid: result.pid,\n368:             activity: `${muxName} session active`,\n369:           });\n370:           saveState(projectRoot, state);\n371:         } catch (err: any) {\n372:           updateAgent(state, agent.feature_id, {\n373:             status: \"failed\",\n374:             error: err.message,\n375:             activity: null,\n376:             completed_at: new Date().toISOString(),\n377:           });\n378:           saveState(projectRoot, state);\n379:         }\n380:       })\n381:     );\n382: \n383:     printDashboard(state);\n384:     const mux = detectMultiplexer(config.agent.multiplexer);\n385:     console.log(`\\nResume complete. Use '${muxAttachCommand(mux, `${config.agent.tmuxPrefix}-<id>`)}' to check sessions.`);\n386:   } else {\n387:     // Headless resume — re-enter monitoring loop\n388:     const monitor = new ProcessMonitor(projectRoot, {\n389:       onSessionId: (featureId, sessionId) => {\n390:         updateAgent(state, featureId, { session_id: sessionId });\n391:         saveState(projectRoot, state);\n392:       },\n393:       onComplete: (featureId) => {\n394:         updateAgent(state, featureId, {\n395:           status: \"completed\",\n396:           completed_at: new Date().toISOString(),\n397:           activity: \"done\",\n398:         });\n399:         saveState(projectRoot, state);\n400:         wtLog(featureId, \"agent completed — verifying build...\");\n401: \n402:         const agent = state.agents.find((a) => a.feature_id === featureId)!;\n403:         const feature = featureMap.get(featureId)!;\n404:         handleBuildVerification(projectRoot, state, agent, feature, config, model, monitor)\n405:           .then(() => launchAllReady(projectRoot, state, featureMap, monitor, config, model))\n406:           .catch((err) => {\n407:             wtLog(featureId, `BUILD VERIFICATION UNHANDLED ERROR: ${err.message}`);\n408:             launchAllReady(projectRoot, state, featureMap, monitor, config, model);\n409:           });\n410:       },\n411:       onError: (featureId, error) => {\n412:         const agent = state.agents.find((a) => a.feature_id === featureId)!;\n413:         if (agent.retries < agent.max_retries) {\n414:           updateAgent(state, featureId, {\n415:             status: \"retry\",\n416:             retries: agent.retries + 1,\n417:             error,\n418:             activity: \"retrying...\",\n419:           });\n420:           saveState(projectRoot, state);\n421:           handleRetry(projectRoot, state, agent, monitor, config, model);\n422:         } else {\n423:           updateAgent(state, featureId, {\n424:             status: \"failed\",\n425:             error,\n426:             activity: null,\n427:             completed_at: new Date().toISOString(),\n428:           });\n429:           saveState(projectRoot, state);\n430: \n431:           // Cascade failure to downstream agents\n432:           const cancelled = cancelDownstream(state, featureId);\n433:           if (cancelled.length > 0) {\n434:             wtLog(featureId, `downstream cancelled: ${cancelled.join(\", \")}`);\n435:             saveState(projectRoot, state);\n436:           }\n437:         }\n438:         launchAllReady(projectRoot, state, featureMap, monitor, config, model);\n439:       },\n440:       onActivity: (featureId, activity) => {\n441:         updateAgent(state, featureId, {\n442:           activity,\n443:           activity_updated_at: new Date().toISOString(),\n444:         });\n445:       },\n446:     });\n447: \n448:     // Handle graceful shutdown\n449:     const tuiRef = { current: null as WomboTUI | null };\n450:     process.on(\"SIGINT\", () => {\n451:       if (tuiRef.current) tuiRef.current.stop();\n452:       for (const agent of state.agents) {\n453:         if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n454:           updateAgent(state, agent.feature_id, {\n455:             activity: \"interrupted\",\n456:           });\n457:         }\n458:       }\n459:       monitor.killAll();\n460:       saveState(projectRoot, state);\n461:       console.log(\"\\nState saved. Use 'woco resume' to continue.\");\n462:       process.exit(0);\n463:     });\n464: \n465:     await Promise.all(\n466:       toLaunchNow.map((agent) => {\n467:         const feature = featureMap.get(agent.feature_id);\n468:         if (!feature) return Promise.resolve();\n469:         return launchSingleHeadless(projectRoot, state, agent, feature, monitor, config, model);\n470:       })\n471:     );\n472: \n473:     // Start TUI dashboard (or skip if --no-tui)\n474:     if (!opts.noTui) {\n475:       tuiRef.current = new WomboTUI({\n476:         state,\n477:         monitor,\n478:         projectRoot,\n479:         interactive: false,\n480:         config,\n481:         onQuit: () => {\n482:           for (const agent of state.agents) {\n483:             if (agent.status === \"running\") {\n484:               updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n485:             }\n486:           }\n487:           monitor.killAll();\n488:           saveState(projectRoot, state);\n489:           console.log(\"State saved. Use 'woco resume' to continue.\");\n490:           process.exit(0);\n491:         },\n492:       });\n493:       tuiRef.current.start();\n494:     } else {\n495:       console.log(\"(--no-tui mode, dashboard prints every 15s)\\n\");\n496:       printDashboard(state);\n497:     }\n498: \n499:     // Monitoring loop\n500:     const POLL_INTERVAL = 5000;\n501:     let dashboardCounter = 0;\n502:     while (!isWaveComplete(state)) {\n503:       await new Promise((r) => setTimeout(r, POLL_INTERVAL));\n504: \n505:       for (const agent of state.agents) {\n506:         if (\n507:           (agent.status === \"running\" || agent.status === \"resolving_conflict\") &&\n508:           agent.pid &&\n509:           !isProcessRunning(agent.pid) &&\n510:           !monitor.isRunning(agent.feature_id)\n511:         ) {\n512:           if (agent.status === \"resolving_conflict\") {\n513:             // Conflict resolver died unexpectedly — mark as failed\n514:             updateAgent(state, agent.feature_id, {\n515:               status: \"failed\",\n516:               error: \"Conflict resolver process died unexpectedly\",\n517:               activity: null,\n518:               completed_at: new Date().toISOString(),\n519:             });\n520:             saveState(projectRoot, state);\n521:             wtLog(agent.feature_id, \"conflict resolver died — marked failed\");\n522: \n523:             // Cascade failure to downstream agents\n524:             const cancelled = cancelDownstream(state, agent.feature_id);\n525:             if (cancelled.length > 0) {\n526:               wtLog(agent.feature_id, `downstream cancelled: ${cancelled.join(\", \")}`);\n527:               saveState(projectRoot, state);\n528:             }\n529: \n530:             launchAllReady(projectRoot, state, featureMap, monitor, config, model);\n531:             continue;\n532:           }\n533:           // Check if the agent actually made any commits\n534:           if (!branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n535:             // Agent died without producing any code — mark as failed\n536:             updateAgent(state, agent.feature_id, {\n537:               status: \"failed\",\n538:               error: \"Agent process exited without making any commits\",\n539:               activity: null,\n540:               completed_at: new Date().toISOString(),\n541:             });\n542:             saveState(projectRoot, state);\n543:             wtLog(agent.feature_id, \"process died with no code changes — marked failed\");\n544: \n545:             // Cascade failure to downstream agents\n546:             const cancelled = cancelDownstream(state, agent.feature_id);\n547:             if (cancelled.length > 0) {\n548:               wtLog(agent.feature_id, `downstream cancelled: ${cancelled.join(\", \")}`);\n549:               saveState(projectRoot, state);\n550:             }\n551:           } else {\n552:             updateAgent(state, agent.feature_id, {\n553:               status: \"completed\",\n554:               completed_at: new Date().toISOString(),\n555:               activity: \"done\",\n556:             });\n557:             saveState(projectRoot, state);\n558:             const feature = featureMap.get(agent.feature_id)!;\n559:             try {\n560:               await handleBuildVerification(projectRoot, state, agent, feature, config, model, monitor);\n561:             } catch (err: any) {\n562:               wtLog(agent.feature_id, `POLL VERIFY ERROR: ${err.message}`);\n563:             }\n564:           }\n565:           launchAllReady(projectRoot, state, featureMap, monitor, config, model);\n566:         }\n567:       }\n568: \n569:       saveState(projectRoot, state);\n570:       if (tuiRef.current) {\n571:         tuiRef.current.updateState(state);\n572:       } else if (opts.noTui) {\n573:         dashboardCounter++;\n574:         if (dashboardCounter % 3 === 0) {\n575:           printDashboard(state);\n576:         }\n577:       }\n578:     }\n579: \n580:     // Wave complete — keep TUI open for post-mortem browsing\n581:     if (tuiRef.current) {\n582:       tuiRef.current.updateState(state);\n583:       tuiRef.current.markWaveComplete();\n584:       await tuiRef.current.waitForQuit();\n585:     }\n586: \n587:     printDashboard(state);\n588: \n589:     // Dump full logs for failed agents (post-mortem)\n590:     dumpFailedAgentLogs(projectRoot, state);\n591: \n592:     // Auto-export wave history\n593:     try {\n594:       const historyPath = exportWaveHistory(projectRoot, state);\n595:       console.log(`Wave history exported to ${historyPath}`);\n596:     } catch (err: any) {\n597:       console.error(`Warning: failed to export wave history: ${err.message}`);\n598:     }\n599: \n600:     // Auto-push base branch if requested\n601:     if (opts.autoPush) {\n602:       await pushBaseBranch(projectRoot, state.base_branch, config);\n603:     }\n604: \n605:     console.log(\"Wave complete.\");\n606:   }\n607: }\n\n(End of file - total 607 lines)\n</content>","title":"src/commands/resume.ts","metadata":{"preview":"/**\n * resume.ts — Resume a previously stopped wave.\n *\n * Usage: woco resume [options]\n *\n * Restores from .wombo-combo/state.json:\n *   - Agents in \"running\"/\"installing\" whose PID is dead → re-check or re-launch\n *   - Agents in \"queued\" → launch them\n *   - Agents in terminal states (verified/failed/merged) → leave alone\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport type { Feature } from \"../lib/tasks.js\";\nimport { loadFeatures } from \"../lib/tasks.js\";\nimport {\n  loadState,\n  saveState,\n  updateAgent,\n  queuedAgents,\n  readyToLaunchAgents,","truncated":false,"loaded":[]},"time":{"start":1773435865227,"end":1773435865229}}}}
{"type":"tool_use","timestamp":1773435865724,"sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","part":{"id":"prt_ce903c8f4001MfRI9MUTg017JW","sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","messageID":"msg_ce903bbd20016vFIFsRcYODS8J","type":"tool","callID":"toolu_vrtx_01HUnDLXJJRrVuRmmoYhcy8P","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-cli-bugs/src/commands/retry.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-cli-bugs/src/commands/retry.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * retry.ts — Retry a specific failed agent.\n3:  *\n4:  * Usage: woco retry <feature-id> [--interactive] [--model <model>]\n5:  *\n6:  * Resets the agent's retry count and re-launches it. Can launch in either\n7:  * headless mode (default) or interactive (dmux/tmux) mode.\n8:  */\n9: \n10: import type { WomboConfig } from \"../config.js\";\n11: import { loadFeatures, type Feature } from \"../lib/tasks.js\";\n12: import {\n13:   loadState,\n14:   saveState,\n15:   updateAgent,\n16: } from \"../lib/state.js\";\n17: import { worktreeReady } from \"../lib/worktree.js\";\n18: import { generatePrompt } from \"../lib/prompt.js\";\n19: import { launchInteractive, getMultiplexerName } from \"../lib/launcher.js\";\n20: import { ProcessMonitor } from \"../lib/monitor.js\";\n21: import { launchSingleHeadless } from \"./launch.js\";\n22: \n23: // ---------------------------------------------------------------------------\n24: // Types\n25: // ---------------------------------------------------------------------------\n26: \n27: export interface RetryCommandOptions {\n28:   projectRoot: string;\n29:   config: WomboConfig;\n30:   featureId: string;\n31:   model?: string;\n32:   interactive: boolean;\n33:   dryRun?: boolean;\n34: }\n35: \n36: // ---------------------------------------------------------------------------\n37: // Command\n38: // ---------------------------------------------------------------------------\n39: \n40: export async function cmdRetry(opts: RetryCommandOptions): Promise<void> {\n41:   const { projectRoot, config } = opts;\n42: \n43:   if (!opts.featureId) {\n44:     console.error(\"Usage: woco retry <feature-id>\");\n45:     process.exit(1);\n46:     return; // unreachable — helps TypeScript narrow\n47:   }\n48: \n49:   const state = loadState(projectRoot);\n50:   if (!state) {\n51:     console.log(\"No active wave.\");\n52:     return;\n53:   }\n54: \n55:   const agent = state.agents.find((a) => a.feature_id === opts.featureId);\n56:   if (!agent) {\n57:     console.error(`Agent not found for feature: ${opts.featureId}`);\n58:     process.exit(1);\n59:     return; // unreachable — helps TypeScript narrow\n60:   }\n61: \n62:   if (agent.status !== \"failed\") {\n63:     console.error(\n64:       `Agent ${opts.featureId} is not in failed state (current: ${agent.status})`\n65:     );\n66:     process.exit(1);\n67:     return; // unreachable — helps TypeScript narrow\n68:   }\n69: \n70:   // Dry-run: show what would be retried without doing it\n71:   if (opts.dryRun) {\n72:     console.log(`\\n[dry-run] Would retry agent: ${opts.featureId}`);\n73:     console.log(`  Current status: ${agent.status}`);\n74:     console.log(`  Retries so far: ${agent.retries}`);\n75:     console.log(`  Worktree: ${agent.worktree}`);\n76:     console.log(`  Mode: ${opts.interactive ? \"interactive (multiplexer)\" : \"headless\"}`);\n77:     if (opts.model) console.log(`  Model: ${opts.model}`);\n78:     return;\n79:   }\n80: \n81:   // Reset retry count and re-run\n82:   updateAgent(state, agent.feature_id, {\n83:     status: \"queued\",\n84:     retries: 0,\n85:     error: null,\n86:     build_passed: null,\n87:     build_output: null,\n88:     completed_at: null,\n89:   });\n90:   saveState(projectRoot, state);\n91: \n92:   const data = loadFeatures(projectRoot, config);\n93:   const feature = data.tasks.find((f: Feature) => f.id === opts.featureId);\n94:   if (!feature) {\n95:     console.error(`Feature ${opts.featureId} not found in ${config.tasksFile}`);\n96:     process.exit(1);\n97:     return; // unreachable — helps TypeScript narrow\n98:   }\n99: \n100:   if (opts.interactive) {\n101:     const prompt = generatePrompt(feature, state.base_branch, config);\n102:     launchInteractive({\n103:       worktreePath: agent.worktree,\n104:       featureId: feature.id,\n105:       prompt,\n106:       model: opts.model,\n107:       interactive: true,\n108:       config,\n109:     });\n110: \n111:     updateAgent(state, agent.feature_id, {\n112:       status: \"running\",\n113:       started_at: new Date().toISOString(),\n114:     });\n115:     saveState(projectRoot, state);\n116:     const muxName = getMultiplexerName(config);\n117:     console.log(`Retrying ${opts.featureId} in ${muxName} session ${config.agent.tmuxPrefix}-${opts.featureId}`);\n118:   } else {\n119:     const monitor = new ProcessMonitor(projectRoot);\n120:     await launchSingleHeadless(projectRoot, state, agent, feature, monitor, config, opts.model);\n121:     console.log(`Retrying ${opts.featureId} in headless mode`);\n122:   }\n123: }\n\n(End of file - total 123 lines)\n</content>","title":"src/commands/retry.ts","metadata":{"preview":"/**\n * retry.ts — Retry a specific failed agent.\n *\n * Usage: woco retry <feature-id> [--interactive] [--model <model>]\n *\n * Resets the agent's retry count and re-launches it. Can launch in either\n * headless mode (default) or interactive (dmux/tmux) mode.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport { loadFeatures, type Feature } from \"../lib/tasks.js\";\nimport {\n  loadState,\n  saveState,\n  updateAgent,\n} from \"../lib/state.js\";\nimport { worktreeReady } from \"../lib/worktree.js\";\nimport { generatePrompt } from \"../lib/prompt.js\";\nimport { launchInteractive, getMultiplexerName } from \"../lib/launcher.js\";\nimport { ProcessMonitor } from \"../lib/monitor.js\";","truncated":false,"loaded":[]},"time":{"start":1773435865722,"end":1773435865724}}}}
{"type":"tool_use","timestamp":1773435866170,"sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","part":{"id":"prt_ce903cae3001DBlamIEdl3EnA4","sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","messageID":"msg_ce903bbd20016vFIFsRcYODS8J","type":"tool","callID":"toolu_vrtx_01Jsg6QPoc6AjymH7DsuEEng","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-cli-bugs/src/commands/verify.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-cli-bugs/src/commands/verify.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * verify.ts — Run build verification on completed agents.\n3:  *\n4:  * Usage: woco verify [feature-id] [--browser]\n5:  *\n6:  * Runs the build command in each completed agent's worktree. If a specific\n7:  * feature-id is given, verifies only that agent. Otherwise verifies all\n8:  * agents with status \"completed\".\n9:  *\n10:  * When --browser is passed (or browser.enabled is true in config), also\n11:  * runs browser-based verification after the build passes.\n12:  */\n13: \n14: import type { WomboConfig } from \"../config.js\";\n15: import { loadFeatures, type Feature } from \"../lib/tasks.js\";\n16: import { loadState, saveState } from \"../lib/state.js\";\n17: import { printDashboard } from \"../lib/ui.js\";\n18: import { handleBuildVerification } from \"./launch.js\";\n19: \n20: // ---------------------------------------------------------------------------\n21: // Types\n22: // ---------------------------------------------------------------------------\n23: \n24: export interface VerifyCommandOptions {\n25:   projectRoot: string;\n26:   config: WomboConfig;\n27:   featureId?: string;\n28:   model?: string;\n29:   maxRetries?: number;\n30:   /** Enable browser verification (overrides config.browser.enabled) */\n31:   browserVerify?: boolean;\n32: }\n33: \n34: // ---------------------------------------------------------------------------\n35: // Command\n36: // ---------------------------------------------------------------------------\n37: \n38: export async function cmdVerify(opts: VerifyCommandOptions): Promise<void> {\n39:   const { projectRoot, config } = opts;\n40: \n41:   // Apply browser verification override if --browser flag was passed\n42:   if (opts.browserVerify !== undefined) {\n43:     config.browser.enabled = opts.browserVerify;\n44:   }\n45: \n46:   const state = loadState(projectRoot);\n47:   if (!state) {\n48:     console.log(\"No active wave.\");\n49:     return;\n50:   }\n51: \n52:   const toVerify = opts.featureId\n53:     ? state.agents.filter((a) => a.feature_id === opts.featureId)\n54:     : state.agents.filter((a) => a.status === \"completed\");\n55: \n56:   if (toVerify.length === 0) {\n57:     console.log(\"No agents to verify.\");\n58:     return;\n59:   }\n60: \n61:   console.log(`\\nVerifying ${toVerify.length} agent(s)...\\n`);\n62: \n63:   const data = loadFeatures(projectRoot, config);\n64: \n65:   for (const agent of toVerify) {\n66:     const feature = data.tasks.find((f: Feature) => f.id === agent.feature_id);\n67:     if (!feature) continue;\n68: \n69:     await handleBuildVerification(projectRoot, state, agent, feature, config, opts.model);\n70:   }\n71: \n72:   printDashboard(state);\n73: }\n\n(End of file - total 73 lines)\n</content>","title":"src/commands/verify.ts","metadata":{"preview":"/**\n * verify.ts — Run build verification on completed agents.\n *\n * Usage: woco verify [feature-id] [--browser]\n *\n * Runs the build command in each completed agent's worktree. If a specific\n * feature-id is given, verifies only that agent. Otherwise verifies all\n * agents with status \"completed\".\n *\n * When --browser is passed (or browser.enabled is true in config), also\n * runs browser-based verification after the build passes.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport { loadFeatures, type Feature } from \"../lib/tasks.js\";\nimport { loadState, saveState } from \"../lib/state.js\";\nimport { printDashboard } from \"../lib/ui.js\";\nimport { handleBuildVerification } from \"./launch.js\";\n\n// ---------------------------------------------------------------------------","truncated":false,"loaded":[]},"time":{"start":1773435866166,"end":1773435866169}}}}
{"type":"tool_use","timestamp":1773435866621,"sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","part":{"id":"prt_ce903cc9f001IAkmUU5ij0SbRZ","sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","messageID":"msg_ce903bbd20016vFIFsRcYODS8J","type":"tool","callID":"toolu_vrtx_01PXQBmETq1G5H9edXNJyBYN","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-cli-bugs/src/commands/merge.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-cli-bugs/src/commands/merge.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * merge.ts — Merge verified branches into the base branch.\n3:  *\n4:  * Usage: woco merge [feature-id]\n5:  *\n6:  * Merges all verified agents (or a specific one) into the base branch.\n7:  * Uses the full merge pipeline including pre-flight conflict detection,\n8:  * automatic conflict resolution, and configurable retry attempts.\n9:  */\n10: \n11: import type { WomboConfig } from \"../config.js\";\n12: import {\n13:   loadState,\n14: } from \"../lib/state.js\";\n15: import { pushBaseBranch } from \"../lib/merger.js\";\n16: import type { Feature } from \"../lib/tasks.js\";\n17: import { loadFeatures } from \"../lib/tasks.js\";\n18: import { printDashboard, printAgentUpdate } from \"../lib/ui.js\";\n19: import { attemptMerge } from \"./launch.js\";\n20: \n21: // ---------------------------------------------------------------------------\n22: // Types\n23: // ---------------------------------------------------------------------------\n24: \n25: export interface MergeCommandOptions {\n26:   projectRoot: string;\n27:   config: WomboConfig;\n28:   featureId?: string;\n29:   autoPush?: boolean;\n30:   dryRun?: boolean;\n31:   model?: string;\n32: }\n33: \n34: // ---------------------------------------------------------------------------\n35: // Command\n36: // ---------------------------------------------------------------------------\n37: \n38: export async function cmdMerge(opts: MergeCommandOptions): Promise<void> {\n39:   const { projectRoot, config } = opts;\n40: \n41:   const state = loadState(projectRoot);\n42:   if (!state) {\n43:     console.log(\"No active wave.\");\n44:     return;\n45:   }\n46: \n47:   const toMerge = opts.featureId\n48:     ? state.agents.filter(\n49:         (a) => a.feature_id === opts.featureId && a.status === \"verified\"\n50:       )\n51:     : state.agents.filter((a) => a.status === \"verified\");\n52: \n53:   if (toMerge.length === 0) {\n54:     console.log(\"No verified agents to merge.\");\n55:     return;\n56:   }\n57: \n58:   // Dry-run: show what would be merged without merging\n59:   if (opts.dryRun) {\n60:     console.log(`\\n[dry-run] Would merge ${toMerge.length} branch(es):\\n`);\n61:     for (const agent of toMerge) {\n62:       console.log(`  ${agent.feature_id} — branch: ${agent.branch}`);\n63:     }\n64:     if (opts.autoPush) {\n65:       console.log(`\\n  Would push ${state.base_branch} to remote after merge.`);\n66:     }\n67:     return;\n68:   }\n69: \n70:   // Load features for conflict resolution prompt generation.\n71:   // Build a flat map of all feature/subtask IDs so we can look up any agent.\n72:   const data = loadFeatures(projectRoot, config);\n73:   const featureMap = new Map<string, Feature>();\n74:   function indexFeatures(items: Feature[]) {\n75:     for (const f of items) {\n76:       featureMap.set(f.id, f);\n77:       if (f.subtasks) {\n78:         indexFeatures(f.subtasks as unknown as Feature[]);\n79:       }\n80:     }\n81:   }\n82:   indexFeatures(data.tasks);\n83:   indexFeatures(data.archive);\n84: \n85:   console.log(`\\nMerging ${toMerge.length} branch(es)...\\n`);\n86: \n87:   for (const agent of toMerge) {\n88:     const feature = featureMap.get(agent.feature_id);\n89:     if (!feature) {\n90:       printAgentUpdate(agent, `SKIP — feature \"${agent.feature_id}\" not found in features file`);\n91:       continue;\n92:     }\n93: \n94:     // Use the full merge pipeline (pre-flight, conflict resolution, retry)\n95:     await attemptMerge(projectRoot, state, agent, feature, config, opts.model);\n96:   }\n97: \n98:   // Auto-push if requested\n99:   if (opts.autoPush) {\n100:     const anyMerged = state.agents.some((a) => a.status === \"merged\");\n101:     if (anyMerged) {\n102:       await pushBaseBranch(projectRoot, state.base_branch, config);\n103:     }\n104:   }\n105: \n106:   printDashboard(state);\n107: }\n\n(End of file - total 107 lines)\n</content>","title":"src/commands/merge.ts","metadata":{"preview":"/**\n * merge.ts — Merge verified branches into the base branch.\n *\n * Usage: woco merge [feature-id]\n *\n * Merges all verified agents (or a specific one) into the base branch.\n * Uses the full merge pipeline including pre-flight conflict detection,\n * automatic conflict resolution, and configurable retry attempts.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport {\n  loadState,\n} from \"../lib/state.js\";\nimport { pushBaseBranch } from \"../lib/merger.js\";\nimport type { Feature } from \"../lib/tasks.js\";\nimport { loadFeatures } from \"../lib/tasks.js\";\nimport { printDashboard, printAgentUpdate } from \"../lib/ui.js\";\nimport { attemptMerge } from \"./launch.js\";\n","truncated":false,"loaded":[]},"time":{"start":1773435866618,"end":1773435866620}}}}
{"type":"tool_use","timestamp":1773435867166,"sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","part":{"id":"prt_ce903cdfb001bcripOpi4QBrK9","sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","messageID":"msg_ce903bbd20016vFIFsRcYODS8J","type":"tool","callID":"toolu_vrtx_01KiaZ7VskLsL7kzfK44mkD2","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-cli-bugs/src/commands/cleanup.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-cli-bugs/src/commands/cleanup.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * cleanup.ts — Remove all wave-related resources.\n3:  *\n4:  * Usage: woco cleanup\n5:  *\n6:  * Kills multiplexer sessions (dmux/tmux), removes worktrees, removes state and log files.\n7:  *\n8:  * NOTE: .wombo-combo/history/ is intentionally NOT removed by cleanup.\n9:  * Wave history records are meant to survive cleanup for retrospective\n10:  * analysis. See src/lib/history.ts.\n11:  */\n12: \n13: import { existsSync, unlinkSync, rmSync } from \"node:fs\";\n14: import { execSync } from \"node:child_process\";\n15: import { resolve } from \"node:path\";\n16: import type { WomboConfig } from \"../config.js\";\n17: import { WOMBO_DIR } from \"../config.js\";\n18: import { killAllMuxSessions, getMultiplexerName } from \"../lib/launcher.js\";\n19: import { cleanupAllWorktrees, listWomboWorktrees } from \"../lib/worktree.js\";\n20: import {\n21:   detectMultiplexer,\n22:   muxListSessions,\n23: } from \"../lib/multiplexer.js\";\n24: \n25: export interface CleanupOptions {\n26:   projectRoot: string;\n27:   config: WomboConfig;\n28:   dryRun?: boolean;\n29: }\n30: \n31: export async function cmdCleanup(opts: CleanupOptions): Promise<void> {\n32:   const { projectRoot, config } = opts;\n33: \n34:   // Dry-run: show what would be cleaned up without doing it\n35:   if (opts.dryRun) {\n36:     console.log(\"\\n[dry-run] Would perform the following cleanup:\\n\");\n37: \n38:     // List multiplexer sessions that would be killed\n39:     const muxName = getMultiplexerName(config);\n40:     try {\n41:       const mux = detectMultiplexer(config.agent.multiplexer);\n42:       const sessions = muxListSessions(mux);\n43:       const prefix = config.agent.tmuxPrefix;\n44:       const matching = sessions.filter((s) => s.startsWith(prefix));\n45:       console.log(`  ${muxName} sessions to kill: ${matching.length}`);\n46:       for (const s of matching) {\n47:         console.log(`    ${s}`);\n48:       }\n49:     } catch {\n50:       console.log(`  ${muxName} sessions to kill: 0 (no ${muxName} server running)`);\n51:     }\n52: \n53:     // List worktrees that would be removed (using safe filtering)\n54:     try {\n55:       const matching = listWomboWorktrees(projectRoot, config);\n56:       console.log(`  worktrees to remove: ${matching.length}`);\n57:       for (const wt of matching) {\n58:         console.log(`    ${wt.path}`);\n59:       }\n60:     } catch {\n61:       console.log(\"  worktrees to remove: 0\");\n62:     }\n63: \n64:     const statePath = resolve(projectRoot, WOMBO_DIR, \"state.json\");\n65:     const logDir = resolve(projectRoot, WOMBO_DIR, \"logs\");\n66:     if (existsSync(statePath)) console.log(\"  Would remove: .wombo-combo/state.json\");\n67:     if (existsSync(logDir)) console.log(\"  Would remove: .wombo-combo/logs/\");\n68: \n69:     return;\n70:   }\n71: \n72:   console.log(\"\\n--- wombo-combo: Cleanup ---\\n\");\n73: \n74:   // Kill multiplexer sessions\n75:   const muxName = getMultiplexerName(config);\n76:   const killed = killAllMuxSessions(config);\n77:   console.log(`Killed ${killed} ${muxName} session(s)`);\n78: \n79:   // Remove worktrees\n80:   const removed = cleanupAllWorktrees(projectRoot, config);\n81:   console.log(`Removed ${removed} worktree(s)`);\n82: \n83:   // List remaining feature branches\n84:   try {\n85:     const branchPattern = `\"${config.git.branchPrefix}*\"`;\n86:     const branches = execSync(`git branch --list ${branchPattern}`, {\n87:       cwd: projectRoot,\n88:       encoding: \"utf-8\",\n89:     }).trim();\n90:     if (branches) {\n91:       console.log(`\\nRemaining feature branches:\\n${branches}`);\n92:       console.log('Use \"git branch -D <branch>\" to remove manually.');\n93:     }\n94:   } catch {}\n95: \n96:   // Remove state file\n97:   const statePath = resolve(projectRoot, WOMBO_DIR, \"state.json\");\n98:   if (existsSync(statePath)) {\n99:     unlinkSync(statePath);\n100:     console.log(\"Removed .wombo-combo/state.json\");\n101:   }\n102: \n103:   // Remove log directory\n104:   const logDir = resolve(projectRoot, WOMBO_DIR, \"logs\");\n105:   if (existsSync(logDir)) {\n106:     rmSync(logDir, { recursive: true, force: true });\n107:     console.log(\"Removed .wombo-combo/logs/\");\n108:   }\n109: \n110:   console.log(\"\\nCleanup complete.\");\n111: \n112:   // Inform the user that history is preserved\n113:   const historyDir = resolve(projectRoot, WOMBO_DIR, \"history\");\n114:   if (existsSync(historyDir)) {\n115:     console.log(\"Note: .wombo-combo/history/ is preserved. Use 'woco history' to view past waves.\");\n116:   }\n117: }\n\n(End of file - total 117 lines)\n</content>","title":"src/commands/cleanup.ts","metadata":{"preview":"/**\n * cleanup.ts — Remove all wave-related resources.\n *\n * Usage: woco cleanup\n *\n * Kills multiplexer sessions (dmux/tmux), removes worktrees, removes state and log files.\n *\n * NOTE: .wombo-combo/history/ is intentionally NOT removed by cleanup.\n * Wave history records are meant to survive cleanup for retrospective\n * analysis. See src/lib/history.ts.\n */\n\nimport { existsSync, unlinkSync, rmSync } from \"node:fs\";\nimport { execSync } from \"node:child_process\";\nimport { resolve } from \"node:path\";\nimport type { WomboConfig } from \"../config.js\";\nimport { WOMBO_DIR } from \"../config.js\";\nimport { killAllMuxSessions, getMultiplexerName } from \"../lib/launcher.js\";\nimport { cleanupAllWorktrees, listWomboWorktrees } from \"../lib/worktree.js\";\nimport {","truncated":false,"loaded":[]},"time":{"start":1773435867164,"end":1773435867166}}}}
{"type":"tool_use","timestamp":1773435867547,"sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","part":{"id":"prt_ce903d01d001YdPp7bqnsKFwCR","sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","messageID":"msg_ce903bbd20016vFIFsRcYODS8J","type":"tool","callID":"toolu_vrtx_01GjxUYkmBbPQMsfyz3jK7jz","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-cli-bugs/src/commands/upgrade.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-cli-bugs/src/commands/upgrade.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * upgrade.ts — Self-upgrade wombo-combo from GitHub.\n3:  *\n4:  * Usage:\n5:  *   woco upgrade              # Check for updates and prompt to install\n6:  *   woco upgrade --force      # Skip confirmation prompt\n7:  *   woco upgrade --tag v0.1.0 # Install a specific version\n8:  *   woco upgrade --check      # Only check, don't install\n9:  */\n10: \n11: import { readFileSync } from \"node:fs\";\n12: import { resolve } from \"node:path\";\n13: import { createInterface } from \"node:readline\";\n14: \n15: // ---------------------------------------------------------------------------\n16: // Types\n17: // ---------------------------------------------------------------------------\n18: \n19: export interface UpgradeOptions {\n20:   force: boolean;\n21:   tag?: string;\n22:   checkOnly: boolean;\n23: }\n24: \n25: // ---------------------------------------------------------------------------\n26: // Helpers\n27: // ---------------------------------------------------------------------------\n28: \n29: const REPO = \"fulgidus/wombo-combo\";\n30: \n31: /**\n32:  * Get the locally installed version from package.json.\n33:  * Uses import.meta to find the package.json relative to this source file,\n34:  * which works whether running from local source or global install.\n35:  */\n36: function getLocalVersion(): string {\n37:   const pkgPath = resolve(import.meta.dir, \"../../package.json\");\n38:   const raw = readFileSync(pkgPath, \"utf-8\");\n39:   return JSON.parse(raw).version as string;\n40: }\n41: \n42: /**\n43:  * Fetch all v* tags from the remote GitHub repo using git ls-remote.\n44:  * Returns tags sorted by semver descending (latest first).\n45:  */\n46: async function fetchRemoteTags(): Promise<string[]> {\n47:   const proc = Bun.spawn([\"git\", \"ls-remote\", \"--tags\", `https://github.com/${REPO}.git`], {\n48:     stdout: \"pipe\",\n49:     stderr: \"pipe\",\n50:   });\n51: \n52:   const stdout = await new Response(proc.stdout).text();\n53:   const exitCode = await proc.exited;\n54: \n55:   if (exitCode !== 0) {\n56:     const stderr = await new Response(proc.stderr).text();\n57:     throw new Error(`Failed to fetch remote tags: ${stderr.trim()}`);\n58:   }\n59: \n60:   // Parse lines like: \"abc123\\trefs/tags/v0.0.1\"\n61:   const tags: string[] = [];\n62:   for (const line of stdout.split(\"\\n\")) {\n63:     const match = line.match(/refs\\/tags\\/(v\\d+\\.\\d+\\.\\d+)$/);\n64:     if (match) {\n65:       tags.push(match[1]);\n66:     }\n67:   }\n68: \n69:   // Sort descending by semver\n70:   tags.sort((a, b) => {\n71:     const pa = a.slice(1).split(\".\").map(Number);\n72:     const pb = b.slice(1).split(\".\").map(Number);\n73:     for (let i = 0; i < 3; i++) {\n74:       if (pa[i] !== pb[i]) return pb[i] - pa[i];\n75:     }\n76:     return 0;\n77:   });\n78: \n79:   return tags;\n80: }\n81: \n82: /**\n83:  * Compare two semver strings. Returns:\n84:  *   -1 if a < b\n85:  *    0 if a === b\n86:  *    1 if a > b\n87:  */\n88: function compareSemver(a: string, b: string): number {\n89:   const pa = a.replace(/^v/, \"\").split(\".\").map(Number);\n90:   const pb = b.replace(/^v/, \"\").split(\".\").map(Number);\n91:   for (let i = 0; i < 3; i++) {\n92:     if (pa[i] < pb[i]) return -1;\n93:     if (pa[i] > pb[i]) return 1;\n94:   }\n95:   return 0;\n96: }\n97: \n98: /**\n99:  * Prompt the user for yes/no confirmation.\n100:  */\n101: async function confirm(message: string): Promise<boolean> {\n102:   if (!process.stdin.isTTY) return false;\n103: \n104:   const rl = createInterface({ input: process.stdin, output: process.stdout });\n105:   return new Promise<boolean>((resolve) => {\n106:     rl.question(`${message} [y/N] `, (answer) => {\n107:       rl.close();\n108:       resolve(answer.trim().toLowerCase() === \"y\");\n109:     });\n110:   });\n111: }\n112: \n113: // ---------------------------------------------------------------------------\n114: // Command\n115: // ---------------------------------------------------------------------------\n116: \n117: export async function cmdUpgrade(opts: UpgradeOptions): Promise<void> {\n118:   const localVersion = getLocalVersion();\n119:   console.log(`Current version: v${localVersion}`);\n120: \n121:   // If a specific version is requested, skip the check\n122:   if (opts.tag) {\n123:     const targetTag = opts.tag.startsWith(\"v\") ? opts.tag : `v${opts.tag}`;\n124:     console.log(`Requested version: ${targetTag}`);\n125: \n126:     if (compareSemver(localVersion, targetTag) === 0) {\n127:       console.log(\"Already at the requested version.\");\n128:       return;\n129:     }\n130: \n131:     if (!opts.force) {\n132:       const ok = await confirm(`Install ${targetTag}?`);\n133:       if (!ok) {\n134:         console.log(\"Upgrade cancelled.\");\n135:         return;\n136:       }\n137:     }\n138: \n139:     await installVersion(targetTag);\n140:     return;\n141:   }\n142: \n143:   // Fetch latest from GitHub\n144:   console.log(`Checking for updates from github.com/${REPO}...`);\n145: \n146:   let tags: string[];\n147:   try {\n148:     tags = await fetchRemoteTags();\n149:   } catch (err: any) {\n150:     console.error(`Failed to check for updates: ${err.message}`);\n151:     process.exit(1);\n152:     return;\n153:   }\n154: \n155:   if (tags.length === 0) {\n156:     console.error(\"No release tags found on the remote repository.\");\n157:     process.exit(1);\n158:     return;\n159:   }\n160: \n161:   const latestTag = tags[0];\n162:   const latestVersion = latestTag.slice(1); // strip 'v'\n163:   console.log(`Latest version:  ${latestTag}`);\n164: \n165:   const cmp = compareSemver(localVersion, latestVersion);\n166:   if (cmp >= 0) {\n167:     console.log(\"You are already up to date.\");\n168:     return;\n169:   }\n170: \n171:   if (opts.checkOnly) {\n172:     console.log(`\\nUpdate available: v${localVersion} → ${latestTag}`);\n173:     console.log(`Run 'woco upgrade' to install.`);\n174:     return;\n175:   }\n176: \n177:   console.log(`\\nUpdate available: v${localVersion} → ${latestTag}`);\n178: \n179:   if (!opts.force) {\n180:     const ok = await confirm(`Upgrade to ${latestTag}?`);\n181:     if (!ok) {\n182:       console.log(\"Upgrade cancelled.\");\n183:       return;\n184:     }\n185:   }\n186: \n187:   await installVersion(latestTag);\n188: }\n189: \n190: async function installVersion(tag: string): Promise<void> {\n191:   console.log(`\\nInstalling wombo-combo@${tag}...`);\n192: \n193:   const proc = Bun.spawn(\n194:     [\"bun\", \"install\", \"-g\", `github:${REPO}#${tag}`],\n195:     {\n196:       stdout: \"inherit\",\n197:       stderr: \"inherit\",\n198:     }\n199:   );\n200: \n201:   const exitCode = await proc.exited;\n202: \n203:   if (exitCode !== 0) {\n204:     console.error(`\\nInstallation failed (exit code ${exitCode}).`);\n205:     process.exit(1);\n206:     return;\n207:   }\n208: \n209:   console.log(`\\nSuccessfully upgraded to ${tag}.`);\n210: }\n\n(End of file - total 210 lines)\n</content>","title":"src/commands/upgrade.ts","metadata":{"preview":"/**\n * upgrade.ts — Self-upgrade wombo-combo from GitHub.\n *\n * Usage:\n *   woco upgrade              # Check for updates and prompt to install\n *   woco upgrade --force      # Skip confirmation prompt\n *   woco upgrade --tag v0.1.0 # Install a specific version\n *   woco upgrade --check      # Only check, don't install\n */\n\nimport { readFileSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\nimport { createInterface } from \"node:readline\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface UpgradeOptions {\n  force: boolean;","truncated":false,"loaded":[]},"time":{"start":1773435867545,"end":1773435867547}}}}
