{"type":"tool_use","timestamp":1773435871547,"sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","part":{"id":"prt_ce903ddb4001oh6UaB11Xh1vDb","sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","messageID":"msg_ce903d1ca001mxB6I3YCD0BKUf","type":"tool","callID":"toolu_vrtx_01DKjDB47X5CcqdwAsMWtj1u","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-cli-bugs/src/lib/task-schema.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-cli-bugs/src/lib/task-schema.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * task-schema.ts — Single source of truth for task field enums, ordering,\n3:  * required fields, and validation.\n4:  *\n5:  * Every command that needs to validate or enumerate task field values should\n6:  * import from here. No more duplicated VALID_* arrays.\n7:  */\n8: \n9: import type { TaskStatus, Priority, Difficulty, Task } from \"./tasks.js\";\n10: import { parseDurationMinutes } from \"./tasks.js\";\n11: import { validateId, type ValidationResult } from \"./validate.js\";\n12: \n13: // ---------------------------------------------------------------------------\n14: // Canonical enum arrays (order matters: used for display and sorting)\n15: // ---------------------------------------------------------------------------\n16: \n17: export const VALID_STATUSES: readonly TaskStatus[] = [\n18:   \"backlog\",\n19:   \"planned\",\n20:   \"in_progress\",\n21:   \"blocked\",\n22:   \"in_review\",\n23:   \"done\",\n24:   \"cancelled\",\n25: ] as const;\n26: \n27: export const VALID_PRIORITIES: readonly Priority[] = [\n28:   \"critical\",\n29:   \"high\",\n30:   \"medium\",\n31:   \"low\",\n32:   \"wishlist\",\n33: ] as const;\n34: \n35: export const VALID_DIFFICULTIES: readonly Difficulty[] = [\n36:   \"trivial\",\n37:   \"easy\",\n38:   \"medium\",\n39:   \"hard\",\n40:   \"very_hard\",\n41: ] as const;\n42: \n43: // ---------------------------------------------------------------------------\n44: // Ordering maps (lower = more important / easier)\n45: // ---------------------------------------------------------------------------\n46: \n47: export const PRIORITY_ORDER: Readonly<Record<Priority, number>> = {\n48:   critical: 0,\n49:   high: 1,\n50:   medium: 2,\n51:   low: 3,\n52:   wishlist: 4,\n53: };\n54: \n55: export const DIFFICULTY_ORDER: Readonly<Record<Difficulty, number>> = {\n56:   trivial: 0,\n57:   easy: 1,\n58:   medium: 2,\n59:   hard: 3,\n60:   very_hard: 4,\n61: };\n62: \n63: // ---------------------------------------------------------------------------\n64: // _meta.yml schema\n65: // ---------------------------------------------------------------------------\n66: \n67: export interface MetaSchema {\n68:   version: string;\n69:   meta: {\n70:     created_at: string;\n71:     updated_at: string;\n72:     project: string;\n73:     generator: string;\n74:     maintainer: string;\n75:   };\n76: }\n77: \n78: export const META_REQUIRED_FIELDS = [\"version\", \"meta\"] as const;\n79: export const META_INNER_REQUIRED_FIELDS = [\n80:   \"created_at\",\n81:   \"updated_at\",\n82:   \"project\",\n83:   \"generator\",\n84:   \"maintainer\",\n85: ] as const;\n86: \n87: // ---------------------------------------------------------------------------\n88: // Task schema — required fields and array-defaulted fields\n89: // ---------------------------------------------------------------------------\n90: \n91: export const TASK_REQUIRED_FIELDS = [\"id\", \"title\", \"status\"] as const;\n92: \n93: /** Fields that must be arrays; YAML may parse absent values as null */\n94: export const TASK_ARRAY_FIELDS = [\n95:   \"depends_on\",\n96:   \"constraints\",\n97:   \"forbidden\",\n98:   \"references\",\n99:   \"notes\",\n100:   \"subtasks\",\n101: ] as const;\n102: \n103: // ---------------------------------------------------------------------------\n104: // Validation result\n105: // ---------------------------------------------------------------------------\n106: \n107: export interface SchemaIssue {\n108:   level: \"error\" | \"warning\";\n109:   taskId: string;\n110:   message: string;\n111: }\n112: \n113: // ---------------------------------------------------------------------------\n114: // Validate a single task object\n115: // ---------------------------------------------------------------------------\n116: \n117: /**\n118:  * Validate a task against the schema. Returns a list of issues (errors and\n119:  * warnings). Does NOT throw — callers decide how to handle issues.\n120:  *\n121:  * Checks:\n122:  *   - Required fields: id, title, status\n123:  *   - id format (kebab-case via validateId)\n124:  *   - status is a valid enum\n125:  *   - priority is a valid enum (if present)\n126:  *   - difficulty is a valid enum (if present)\n127:  *   - effort is a parseable ISO 8601 duration (warning if not)\n128:  *   - completion is 0-100 (warning if out of range)\n129:  *   - depends_on entries are strings (structural check only; cross-ref is\n130:  *     done by check.ts which has access to the full task set)\n131:  */\n132: export function validateTask(task: unknown): SchemaIssue[] {\n133:   const issues: SchemaIssue[] = [];\n134:   const t = task as Record<string, unknown>;\n135:   const id = typeof t?.id === \"string\" ? t.id : \"<unknown>\";\n136: \n137:   // Required fields\n138:   for (const field of TASK_REQUIRED_FIELDS) {\n139:     if (!t?.[field]) {\n140:       issues.push({ level: \"error\", taskId: id, message: `Missing required field: ${field}` });\n141:     }\n142:   }\n143: \n144:   // id format\n145:   if (typeof t?.id === \"string\") {\n146:     const idResult: ValidationResult = validateId(t.id, \"Task ID\");\n147:     if (!idResult.valid) {\n148:       issues.push({ level: \"error\", taskId: id, message: idResult.error! });\n149:     }\n150:   }\n151: \n152:   // status enum\n153:   if (t?.status && !(VALID_STATUSES as readonly string[]).includes(t.status as string)) {\n154:     issues.push({ level: \"error\", taskId: id, message: `Invalid status: \"${t.status}\"` });\n155:   }\n156: \n157:   // priority enum\n158:   if (t?.priority && !(VALID_PRIORITIES as readonly string[]).includes(t.priority as string)) {\n159:     issues.push({ level: \"error\", taskId: id, message: `Invalid priority: \"${t.priority}\"` });\n160:   }\n161: \n162:   // difficulty enum\n163:   if (t?.difficulty && !(VALID_DIFFICULTIES as readonly string[]).includes(t.difficulty as string)) {\n164:     issues.push({ level: \"error\", taskId: id, message: `Invalid difficulty: \"${t.difficulty}\"` });\n165:   }\n166: \n167:   // effort duration\n168:   if (typeof t?.effort === \"string\" && t.effort.length > 0) {\n169:     const minutes = parseDurationMinutes(t.effort);\n170:     if (minutes === Infinity) {\n171:       issues.push({ level: \"warning\", taskId: id, message: `Unparseable effort duration: \"${t.effort}\"` });\n172:     }\n173:   } else if (!t?.effort || t.effort === \"PT0S\") {\n174:     issues.push({ level: \"warning\", taskId: id, message: \"No effort estimate\" });\n175:   }\n176: \n177:   // completion range\n178:   if (typeof t?.completion === \"number\" && (t.completion < 0 || t.completion > 100)) {\n179:     issues.push({ level: \"warning\", taskId: id, message: `Completion ${t.completion} is out of range 0-100` });\n180:   }\n181: \n182:   // depends_on structural check\n183:   if (t?.depends_on != null && !Array.isArray(t.depends_on)) {\n184:     issues.push({ level: \"error\", taskId: id, message: \"depends_on must be an array\" });\n185:   }\n186: \n187:   return issues;\n188: }\n189: \n190: // ---------------------------------------------------------------------------\n191: // Validate _meta.yml\n192: // ---------------------------------------------------------------------------\n193: \n194: /**\n195:  * Validate a parsed _meta.yml object. Returns issues.\n196:  */\n197: export function validateMeta(meta: unknown): SchemaIssue[] {\n198:   const issues: SchemaIssue[] = [];\n199:   const m = meta as Record<string, unknown>;\n200:   const id = \"_meta.yml\";\n201: \n202:   if (!m?.version) {\n203:     issues.push({ level: \"error\", taskId: id, message: \"Missing required field: version\" });\n204:   }\n205: \n206:   if (!m?.meta || typeof m.meta !== \"object\") {\n207:     issues.push({ level: \"error\", taskId: id, message: \"Missing required field: meta\" });\n208:     return issues; // Can't check inner fields\n209:   }\n210: \n211:   const inner = m.meta as Record<string, unknown>;\n212:   for (const field of META_INNER_REQUIRED_FIELDS) {\n213:     if (!inner[field]) {\n214:       issues.push({ level: \"warning\", taskId: id, message: `Missing meta field: ${field}` });\n215:     }\n216:   }\n217: \n218:   return issues;\n219: }\n\n(End of file - total 219 lines)\n</content>","title":"src/lib/task-schema.ts","metadata":{"preview":"/**\n * task-schema.ts — Single source of truth for task field enums, ordering,\n * required fields, and validation.\n *\n * Every command that needs to validate or enumerate task field values should\n * import from here. No more duplicated VALID_* arrays.\n */\n\nimport type { TaskStatus, Priority, Difficulty, Task } from \"./tasks.js\";\nimport { parseDurationMinutes } from \"./tasks.js\";\nimport { validateId, type ValidationResult } from \"./validate.js\";\n\n// ---------------------------------------------------------------------------\n// Canonical enum arrays (order matters: used for display and sorting)\n// ---------------------------------------------------------------------------\n\nexport const VALID_STATUSES: readonly TaskStatus[] = [\n  \"backlog\",\n  \"planned\",\n  \"in_progress\",","truncated":false,"loaded":[]},"time":{"start":1773435871544,"end":1773435871546}}}}
{"type":"tool_use","timestamp":1773435872397,"sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","part":{"id":"prt_ce903e139001CiMv39zbvA3snp","sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","messageID":"msg_ce903d1ca001mxB6I3YCD0BKUf","type":"tool","callID":"toolu_vrtx_01Fd9XpjbM6zFjN4ax3KB2P5","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-cli-bugs/src/commands/tasks/list.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-cli-bugs/src/commands/tasks/list.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tasks/list.ts — List and filter tasks from the tasks file.\n3:  *\n4:  * Usage:\n5:  *   woco tasks list                     # list all tasks\n6:  *   woco tasks list --status backlog    # filter by status\n7:  *   woco tasks list --priority high     # filter by priority\n8:  *   woco tasks list --ready             # show only ready tasks\n9:  *   woco tasks list --archive           # include archived tasks\n10:  */\n11: \n12: import type { WomboConfig } from \"../../config.js\";\n13: import {\n14:   loadFeatures,\n15:   getReadyFeatures,\n16:   featureSummary,\n17:   formatDuration,\n18:   parseDurationMinutes,\n19:   type Feature,\n20:   type FeatureStatus,\n21:   type Priority,\n22:   type Difficulty,\n23:   type FeaturesFile,\n24: } from \"../../lib/tasks.js\";\n25: import { output, filterFieldsArray, renderCompactTable, type OutputFormat } from \"../../lib/output.js\";\n26: \n27: // ---------------------------------------------------------------------------\n28: // Types\n29: // ---------------------------------------------------------------------------\n30: \n31: export interface TasksListOptions {\n32:   projectRoot: string;\n33:   config: WomboConfig;\n34:   status?: FeatureStatus;\n35:   priority?: Priority;\n36:   difficulty?: Difficulty;\n37:   ready?: boolean;\n38:   includeArchive?: boolean;\n39:   outputFmt?: OutputFormat;\n40:   fields?: string[];\n41: }\n42: \n43: // ---------------------------------------------------------------------------\n44: // ANSI Helpers\n45: // ---------------------------------------------------------------------------\n46: \n47: const RESET = \"\\x1b[0m\";\n48: const BOLD = \"\\x1b[1m\";\n49: const DIM = \"\\x1b[2m\";\n50: \n51: const STATUS_COLOR: Record<FeatureStatus, string> = {\n52:   backlog: \"\\x1b[37m\",     // white\n53:   planned: \"\\x1b[36m\",     // cyan\n54:   in_progress: \"\\x1b[34m\", // blue\n55:   blocked: \"\\x1b[31m\",     // red\n56:   in_review: \"\\x1b[33m\",   // yellow\n57:   done: \"\\x1b[32m\",        // green\n58:   cancelled: \"\\x1b[90m\",   // gray\n59: };\n60: \n61: // ---------------------------------------------------------------------------\n62: // Command\n63: // ---------------------------------------------------------------------------\n64: \n65: export async function cmdTasksList(opts: TasksListOptions): Promise<void> {\n66:   const { projectRoot, config } = opts;\n67:   const data = loadFeatures(projectRoot, config);\n68: \n69:   let features: Feature[] = [...data.tasks];\n70: \n71:   // Include archive if requested\n72:   if (opts.includeArchive && data.archive?.length) {\n73:     features = [...features, ...data.archive];\n74:   }\n75: \n76:   // Filter by status\n77:   if (opts.status) {\n78:     features = features.filter((f) => f.status === opts.status);\n79:   }\n80: \n81:   // Filter by priority\n82:   if (opts.priority) {\n83:     features = features.filter((f) => f.priority === opts.priority);\n84:   }\n85: \n86:   // Filter by difficulty\n87:   if (opts.difficulty) {\n88:     features = features.filter((f) => f.difficulty === opts.difficulty);\n89:   }\n90: \n91:   // Filter to ready-only\n92:   if (opts.ready) {\n93:     const readyFeatures = getReadyFeatures(data);\n94:     const readyIds = new Set(readyFeatures.map((f) => f.id));\n95:     features = features.filter((f) => readyIds.has(f.id));\n96:   }\n97: \n98:   if (features.length === 0) {\n99:     output(opts.outputFmt ?? \"text\", { features: [], total: 0, effort: \"0m\" }, () => {\n100:       console.log(\"No tasks match the given filters.\");\n101:     });\n102:     return;\n103:   }\n104: \n105:   // Group by status for display\n106:   const byStatus = new Map<FeatureStatus, Feature[]>();\n107:   for (const f of features) {\n108:     const list = byStatus.get(f.status) ?? [];\n109:     list.push(f);\n110:     byStatus.set(f.status, list);\n111:   }\n112: \n113:   // Display\n114:   const totalEffort = features.reduce(\n115:     (sum, f) => sum + parseDurationMinutes(f.effort),\n116:     0\n117:   );\n118: \n119:   const fmt = opts.outputFmt ?? \"text\";\n120: \n121:   // Build the structured data for each feature\n122:   const featureData = features.map((f) => ({\n123:     id: f.id,\n124:     title: f.title,\n125:     status: f.status,\n126:     priority: f.priority,\n127:     difficulty: f.difficulty,\n128:     effort: f.effort,\n129:     completion: f.completion,\n130:     depends_on: f.depends_on,\n131:   }));\n132: \n133:   // If --fields is specified, use compact output mode\n134:   if (opts.fields?.length) {\n135:     const filtered = filterFieldsArray(featureData, opts.fields);\n136:     output(\n137:       fmt,\n138:       { features: filtered, total: features.length, effort: formatDuration(totalEffort) },\n139:       () => {\n140:         renderCompactTable(\n141:           featureData as Record<string, unknown>[],\n142:           opts.fields!\n143:         );\n144:       }\n145:     );\n146:     return;\n147:   }\n148: \n149:   output(\n150:     fmt,\n151:     {\n152:       features: featureData,\n153:       total: features.length,\n154:       effort: formatDuration(totalEffort),\n155:     },\n156:     () => {\n157:       console.log(`\\n${BOLD}Tasks (${features.length} total, ~${formatDuration(totalEffort)} effort)${RESET}\\n`);\n158: \n159:       const statusOrder: FeatureStatus[] = [\n160:         \"in_progress\",\n161:         \"planned\",\n162:         \"backlog\",\n163:         \"blocked\",\n164:         \"in_review\",\n165:         \"done\",\n166:         \"cancelled\",\n167:       ];\n168: \n169:       for (const status of statusOrder) {\n170:         const group = byStatus.get(status);\n171:         if (!group?.length) continue;\n172: \n173:         const color = STATUS_COLOR[status] ?? \"\";\n174:         console.log(`  ${color}${BOLD}${status.toUpperCase()}${RESET} (${group.length})`);\n175: \n176:         for (const f of group) {\n177:           const effort = formatDuration(parseDurationMinutes(f.effort));\n178:           const deps = f.depends_on.length > 0 ? ` ${DIM}deps: ${f.depends_on.join(\", \")}${RESET}` : \"\";\n179:           const completion = f.completion > 0 ? ` ${DIM}${f.completion}%${RESET}` : \"\";\n180:           console.log(\n181:             `    ${color}${f.id}${RESET} — ${f.title} [${f.priority}/${f.difficulty}] (${effort})${completion}${deps}`\n182:           );\n183:         }\n184:         console.log(\"\");\n185:       }\n186:     }\n187:   );\n188: }\n\n(End of file - total 188 lines)\n</content>","title":"src/commands/tasks/list.ts","metadata":{"preview":"/**\n * tasks/list.ts — List and filter tasks from the tasks file.\n *\n * Usage:\n *   woco tasks list                     # list all tasks\n *   woco tasks list --status backlog    # filter by status\n *   woco tasks list --priority high     # filter by priority\n *   woco tasks list --ready             # show only ready tasks\n *   woco tasks list --archive           # include archived tasks\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  getReadyFeatures,\n  featureSummary,\n  formatDuration,\n  parseDurationMinutes,\n  type Feature,\n  type FeatureStatus,","truncated":false,"loaded":[]},"time":{"start":1773435872394,"end":1773435872396}}}}
{"type":"tool_use","timestamp":1773435872651,"sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","part":{"id":"prt_ce903e48b001z7kEgNu5P0oxAv","sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","messageID":"msg_ce903d1ca001mxB6I3YCD0BKUf","type":"tool","callID":"toolu_vrtx_01NN72oggN6sh3m7KNy4VRwf","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-cli-bugs/src/commands/tasks/check.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-cli-bugs/src/commands/tasks/check.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tasks/check.ts — Validate the tasks file for schema issues, broken deps, and orphans.\n3:  *\n4:  * Usage:\n5:  *   woco tasks check\n6:  *\n7:  * Checks:\n8:  *   - Required fields present on every task\n9:  *   - No duplicate IDs\n10:  *   - All depends_on references point to existing tasks\n11:  *   - No circular dependencies\n12:  *   - No orphaned subtasks (subtask IDs unique)\n13:  *   - Priority/difficulty values are valid enums\n14:  *   - Effort strings are parseable ISO 8601 durations\n15:  */\n16: \n17: import type { WomboConfig } from \"../../config.js\";\n18: import {\n19:   loadFeatures,\n20:   allFeatureIds,\n21:   parseDurationMinutes,\n22:   type Feature,\n23:   type Subtask,\n24:   type FeaturesFile,\n25: } from \"../../lib/tasks.js\";\n26: import {\n27:   VALID_STATUSES,\n28:   VALID_PRIORITIES,\n29:   VALID_DIFFICULTIES,\n30: } from \"../../lib/task-schema.js\";\n31: import { output, type OutputFormat } from \"../../lib/output.js\";\n32: \n33: // ---------------------------------------------------------------------------\n34: // Types\n35: // ---------------------------------------------------------------------------\n36: \n37: export interface TasksCheckOptions {\n38:   projectRoot: string;\n39:   config: WomboConfig;\n40:   outputFmt?: OutputFormat;\n41: }\n42: \n43: interface CheckResult {\n44:   errors: string[];\n45:   warnings: string[];\n46: }\n47: \n48: // ---------------------------------------------------------------------------\n49: // Validation (enums imported from task-schema.ts — single source of truth)\n50: // ---------------------------------------------------------------------------\n51: \n52: function collectAllItems(data: FeaturesFile): (Feature | Subtask)[] {\n53:   const items: (Feature | Subtask)[] = [];\n54:   const collect = (list: (Feature | Subtask)[]) => {\n55:     for (const item of list) {\n56:       items.push(item);\n57:       if (item.subtasks?.length) collect(item.subtasks);\n58:     }\n59:   };\n60:   collect(data.tasks ?? []);\n61:   collect(data.archive ?? []);\n62:   return items;\n63: }\n64: \n65: function checkTasks(data: FeaturesFile): CheckResult {\n66:   const errors: string[] = [];\n67:   const warnings: string[] = [];\n68:   const allItems = collectAllItems(data);\n69:   const allIds = allItems.map((i) => i.id);\n70:   const idSet = new Set<string>();\n71: \n72:   // Check for duplicates\n73:   for (const id of allIds) {\n74:     if (idSet.has(id)) {\n75:       errors.push(`Duplicate ID: \"${id}\"`);\n76:     }\n77:     idSet.add(id);\n78:   }\n79: \n80:   // Check each item\n81:   for (const item of allItems) {\n82:     const prefix = `[${item.id}]`;\n83: \n84:     // Required fields\n85:     if (!item.id) errors.push(`${prefix} Missing required field: id`);\n86:     if (!item.title) errors.push(`${prefix} Missing required field: title`);\n87:     if (!item.status) errors.push(`${prefix} Missing required field: status`);\n88: \n89:     // Validate enum values\n90:     if (item.status && !(VALID_STATUSES as readonly string[]).includes(item.status)) {\n91:       errors.push(`${prefix} Invalid status: \"${item.status}\"`);\n92:     }\n93:     if (item.priority && !(VALID_PRIORITIES as readonly string[]).includes(item.priority)) {\n94:       errors.push(`${prefix} Invalid priority: \"${item.priority}\"`);\n95:     }\n96:     if (item.difficulty && !(VALID_DIFFICULTIES as readonly string[]).includes(item.difficulty)) {\n97:       errors.push(`${prefix} Invalid difficulty: \"${item.difficulty}\"`);\n98:     }\n99: \n100:     // Validate effort\n101:     if (item.effort) {\n102:       const minutes = parseDurationMinutes(item.effort);\n103:       if (minutes === Infinity) {\n104:         warnings.push(`${prefix} Unparseable effort duration: \"${item.effort}\"`);\n105:       }\n106:     }\n107: \n108:     // Check depends_on references\n109:     if (item.depends_on?.length) {\n110:       for (const dep of item.depends_on) {\n111:         if (!idSet.has(dep)) {\n112:           errors.push(`${prefix} Broken dependency: \"${dep}\" does not exist`);\n113:         }\n114:       }\n115:     }\n116:   }\n117: \n118:   // Check for circular dependencies (simple DFS)\n119:   const visited = new Set<string>();\n120:   const visiting = new Set<string>();\n121:   const depMap = new Map<string, string[]>();\n122:   for (const item of allItems) {\n123:     depMap.set(item.id, item.depends_on ?? []);\n124:   }\n125: \n126:   function hasCycle(id: string): boolean {\n127:     if (visiting.has(id)) return true;\n128:     if (visited.has(id)) return false;\n129:     visiting.add(id);\n130:     for (const dep of depMap.get(id) ?? []) {\n131:       if (hasCycle(dep)) {\n132:         errors.push(`Circular dependency detected involving: \"${id}\" → \"${dep}\"`);\n133:         return true;\n134:       }\n135:     }\n136:     visiting.delete(id);\n137:     visited.add(id);\n138:     return false;\n139:   }\n140: \n141:   for (const id of idSet) {\n142:     hasCycle(id);\n143:   }\n144: \n145:   // Warn about features with no effort estimate\n146:   for (const item of allItems) {\n147:     if (!item.effort || item.effort === \"PT0S\") {\n148:       warnings.push(`[${item.id}] No effort estimate`);\n149:     }\n150:   }\n151: \n152:   return { errors, warnings };\n153: }\n154: \n155: // ---------------------------------------------------------------------------\n156: // Command\n157: // ---------------------------------------------------------------------------\n158: \n159: export async function cmdTasksCheck(opts: TasksCheckOptions): Promise<void> {\n160:   const { projectRoot, config } = opts;\n161:   const fmt = opts.outputFmt ?? \"text\";\n162: \n163:   const data = loadFeatures(projectRoot, config);\n164:   const result = checkTasks(data);\n165: \n166:   const allItems = collectAllItems(data);\n167:   const issues = [\n168:     ...result.errors.map((msg) => ({ level: \"error\" as const, message: msg })),\n169:     ...result.warnings.map((msg) => ({ level: \"warning\" as const, message: msg })),\n170:   ];\n171:   const ok = result.errors.length === 0;\n172: \n173:   output(\n174:     fmt,\n175:     {\n176:       ok,\n177:       issues,\n178:       items_checked: allItems.length,\n179:     },\n180:     () => {\n181:       console.log(`\\nChecking ${config.tasksDir}/ (${allItems.length} items)...\\n`);\n182: \n183:       if (result.errors.length === 0 && result.warnings.length === 0) {\n184:         console.log(\"  All checks passed. No issues found.\");\n185:         return;\n186:       }\n187: \n188:       if (result.errors.length > 0) {\n189:         console.log(`  ERRORS (${result.errors.length}):`);\n190:         for (const e of result.errors) {\n191:           console.log(`    \\x1b[31m✗\\x1b[0m ${e}`);\n192:         }\n193:         console.log(\"\");\n194:       }\n195: \n196:       if (result.warnings.length > 0) {\n197:         console.log(`  WARNINGS (${result.warnings.length}):`);\n198:         for (const w of result.warnings) {\n199:           console.log(`    \\x1b[33m⚠\\x1b[0m ${w}`);\n200:         }\n201:         console.log(\"\");\n202:       }\n203:     }\n204:   );\n205: \n206:   if (result.errors.length > 0) {\n207:     process.exit(1);\n208:   }\n209: }\n\n(End of file - total 209 lines)\n</content>","title":"src/commands/tasks/check.ts","metadata":{"preview":"/**\n * tasks/check.ts — Validate the tasks file for schema issues, broken deps, and orphans.\n *\n * Usage:\n *   woco tasks check\n *\n * Checks:\n *   - Required fields present on every task\n *   - No duplicate IDs\n *   - All depends_on references point to existing tasks\n *   - No circular dependencies\n *   - No orphaned subtasks (subtask IDs unique)\n *   - Priority/difficulty values are valid enums\n *   - Effort strings are parseable ISO 8601 durations\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  allFeatureIds,","truncated":false,"loaded":[]},"time":{"start":1773435872637,"end":1773435872649}}}}
