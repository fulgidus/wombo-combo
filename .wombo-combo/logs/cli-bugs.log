{"type":"tool_use","timestamp":1773435859582,"sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","part":{"id":"prt_ce903af340016wC40kcAHkWBPv","sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","messageID":"msg_ce903a4b40016u9VM5CAKp8cNM","type":"tool","callID":"toolu_vrtx_017nAwXMo3tpjTLtFJvdoLik","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-cli-bugs/src/commands/tasks/add.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-cli-bugs/src/commands/tasks/add.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tasks/add.ts — Add a new task to the tasks file.\n3:  *\n4:  * Usage:\n5:  *   woco tasks add <id> --title \"Task Title\" [--description \"...\"]\n6:  *                   [--priority medium] [--difficulty easy] [--effort PT2H]\n7:  *                   [--depends-on \"task1,task2\"]\n8:  */\n9: \n10: import type { WomboConfig } from \"../../config.js\";\n11: import {\n12:   loadFeatures,\n13:   saveFeatures,\n14:   createBlankFeature,\n15:   allFeatureIds,\n16:   type Priority,\n17:   type Difficulty,\n18: } from \"../../lib/tasks.js\";\n19: import {\n20:   VALID_PRIORITIES,\n21:   VALID_DIFFICULTIES,\n22: } from \"../../lib/task-schema.js\";\n23: import { outputError, outputMessage, type OutputFormat } from \"../../lib/output.js\";\n24: import { validateEnum } from \"../../lib/validate.js\";\n25: \n26: // ---------------------------------------------------------------------------\n27: // Types\n28: // ---------------------------------------------------------------------------\n29: \n30: export interface TasksAddOptions {\n31:   projectRoot: string;\n32:   config: WomboConfig;\n33:   id: string;\n34:   title: string;\n35:   description?: string;\n36:   priority?: Priority;\n37:   difficulty?: Difficulty;\n38:   effort?: string;\n39:   dependsOn?: string[];\n40:   outputFmt?: OutputFormat;\n41:   dryRun?: boolean;\n42: }\n43: \n44: // ---------------------------------------------------------------------------\n45: // Command\n46: // ---------------------------------------------------------------------------\n47: \n48: export async function cmdTasksAdd(opts: TasksAddOptions): Promise<void> {\n49:   const { projectRoot, config } = opts;\n50:   const fmt = opts.outputFmt ?? \"text\";\n51: \n52:   if (!opts.id) {\n53:     outputError(fmt, \"Usage: woco tasks add <id> --title \\\"Task Title\\\"\");\n54:     return;\n55:   }\n56: \n57:   if (!opts.title) {\n58:     outputError(fmt, \"--title is required when adding a task.\");\n59:     return;\n60:   }\n61: \n62:   // Validate priority and difficulty enums (imported from task-schema.ts)\n63:   if (opts.priority) {\n64:     const pResult = validateEnum(opts.priority, VALID_PRIORITIES, \"--priority\");\n65:     if (!pResult.valid) {\n66:       outputError(fmt, pResult.error!);\n67:       return;\n68:     }\n69:   }\n70: \n71:   if (opts.difficulty) {\n72:     const dResult = validateEnum(opts.difficulty, VALID_DIFFICULTIES, \"--difficulty\");\n73:     if (!dResult.valid) {\n74:       outputError(fmt, dResult.error!);\n75:       return;\n76:     }\n77:   }\n78: \n79:   const data = loadFeatures(projectRoot, config);\n80: \n81:   // Check for duplicate ID\n82:   const existingIds = allFeatureIds(data);\n83:   if (existingIds.includes(opts.id)) {\n84:     outputError(fmt, `Task ID \"${opts.id}\" already exists.`);\n85:     return;\n86:   }\n87: \n88:   // Validate depends_on references\n89:   if (opts.dependsOn?.length) {\n90:     for (const dep of opts.dependsOn) {\n91:       if (!existingIds.includes(dep)) {\n92:         outputError(fmt, `Dependency \"${dep}\" does not exist in the tasks file.`);\n93:         return;\n94:       }\n95:     }\n96:   }\n97: \n98:   // Create the feature\n99:   const feature = createBlankFeature(opts.id, opts.title, opts.description ?? \"\", {\n100:     priority: opts.priority,\n101:     difficulty: opts.difficulty,\n102:     effort: opts.effort,\n103:   });\n104: \n105:   // Set dependencies\n106:   if (opts.dependsOn?.length) {\n107:     feature.depends_on = opts.dependsOn;\n108:   }\n109: \n110:   // Dry-run: show what would be added without writing\n111:   if (opts.dryRun) {\n112:     outputMessage(fmt, `[dry-run] Would add task: ${opts.id} — ${opts.title}`, {\n113:       dry_run: true,\n114:       id: feature.id,\n115:       title: feature.title,\n116:       priority: feature.priority,\n117:       difficulty: feature.difficulty,\n118:       effort: feature.effort,\n119:       depends_on: feature.depends_on,\n120:     });\n121:     return;\n122:   }\n123: \n124:   // Append to features list\n125:   data.tasks.push(feature);\n126:   saveFeatures(projectRoot, config, data);\n127: \n128:   outputMessage(fmt, `Added task: ${opts.id} — ${opts.title}`, {\n129:     id: feature.id,\n130:     title: feature.title,\n131:     priority: feature.priority,\n132:     difficulty: feature.difficulty,\n133:     effort: feature.effort,\n134:     depends_on: feature.depends_on,\n135:   });\n136: \n137:   if (fmt === \"text\") {\n138:     console.log(`  priority: ${feature.priority}, difficulty: ${feature.difficulty}, effort: ${feature.effort}`);\n139:     if (feature.depends_on.length > 0) {\n140:       console.log(`  depends on: ${feature.depends_on.join(\", \")}`);\n141:     }\n142:   }\n143: }\n\n(End of file - total 143 lines)\n</content>","title":"src/commands/tasks/add.ts","metadata":{"preview":"/**\n * tasks/add.ts — Add a new task to the tasks file.\n *\n * Usage:\n *   woco tasks add <id> --title \"Task Title\" [--description \"...\"]\n *                   [--priority medium] [--difficulty easy] [--effort PT2H]\n *                   [--depends-on \"task1,task2\"]\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  saveFeatures,\n  createBlankFeature,\n  allFeatureIds,\n  type Priority,\n  type Difficulty,\n} from \"../../lib/tasks.js\";\nimport {\n  VALID_PRIORITIES,","truncated":false,"loaded":[]},"time":{"start":1773435859565,"end":1773435859581}}}}
{"type":"tool_use","timestamp":1773435860131,"sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","part":{"id":"prt_ce903b27a001boZ54b7RC5fFeA","sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","messageID":"msg_ce903a4b40016u9VM5CAKp8cNM","type":"tool","callID":"toolu_vrtx_0184daK8eSoKajjvVLfrnxWb","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-cli-bugs/src/commands/tasks/set-status.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-cli-bugs/src/commands/tasks/set-status.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tasks/set-status.ts — Change a task's status.\n3:  *\n4:  * Usage:\n5:  *   woco tasks set-status <task-id> <new-status>\n6:  *\n7:  * Valid statuses: backlog, planned, in_progress, blocked, in_review, done, cancelled\n8:  */\n9: \n10: import type { WomboConfig } from \"../../config.js\";\n11: import {\n12:   loadFeatures,\n13:   saveFeatures,\n14:   findFeatureById,\n15:   type FeatureStatus,\n16: } from \"../../lib/tasks.js\";\n17: import { VALID_STATUSES } from \"../../lib/task-schema.js\";\n18: import { outputError, outputMessage, type OutputFormat } from \"../../lib/output.js\";\n19: \n20: // ---------------------------------------------------------------------------\n21: // Types\n22: // ---------------------------------------------------------------------------\n23: \n24: export interface TasksSetStatusOptions {\n25:   projectRoot: string;\n26:   config: WomboConfig;\n27:   featureId: string;\n28:   newStatus: string;\n29:   outputFmt?: OutputFormat;\n30:   dryRun?: boolean;\n31: }\n32: \n33: // ---------------------------------------------------------------------------\n34: // Command\n35: // ---------------------------------------------------------------------------\n36: \n37: export async function cmdTasksSetStatus(opts: TasksSetStatusOptions): Promise<void> {\n38:   const { projectRoot, config } = opts;\n39:   const fmt = opts.outputFmt ?? \"text\";\n40: \n41:   if (!opts.featureId || !opts.newStatus) {\n42:     outputError(fmt, `Usage: woco tasks set-status <task-id> <new-status>\\nValid statuses: ${VALID_STATUSES.join(\", \")}`);\n43:     return;\n44:   }\n45: \n46:   // Validate status\n47:   if (!(VALID_STATUSES as readonly string[]).includes(opts.newStatus)) {\n48:     outputError(fmt, `Invalid status: \"${opts.newStatus}\"\\nValid statuses: ${VALID_STATUSES.join(\", \")}`);\n49:     return;\n50:   }\n51: \n52:   const data = loadFeatures(projectRoot, config);\n53:   const feature = findFeatureById(data, opts.featureId);\n54: \n55:   if (!feature) {\n56:     outputError(fmt, `Task \"${opts.featureId}\" not found.`);\n57:     return;\n58:   }\n59: \n60:   const oldStatus = feature.status;\n61:   const newStatus = opts.newStatus as FeatureStatus;\n62: \n63:   if (oldStatus === newStatus) {\n64:     outputMessage(fmt, `Task \"${opts.featureId}\" is already in status \"${newStatus}\".`, {\n65:       id: opts.featureId,\n66:       status: newStatus,\n67:       changed: false,\n68:     });\n69:     return;\n70:   }\n71: \n72:   // Dry-run: show what would change without writing\n73:   if (opts.dryRun) {\n74:     outputMessage(fmt, `[dry-run] Would change \"${opts.featureId}\": ${oldStatus} → ${newStatus}`, {\n75:       dry_run: true,\n76:       id: opts.featureId,\n77:       old_status: oldStatus,\n78:       new_status: newStatus,\n79:       changed: false,\n80:     });\n81:     return;\n82:   }\n83: \n84:   // Apply status change\n85:   feature.status = newStatus;\n86: \n87:   // Set timestamps\n88:   if (newStatus === \"in_progress\" && !feature.started_at) {\n89:     feature.started_at = new Date().toISOString();\n90:   }\n91:   if (newStatus === \"done\" || newStatus === \"cancelled\") {\n92:     feature.ended_at = new Date().toISOString();\n93:     if (newStatus === \"done\") {\n94:       feature.completion = 100;\n95:     }\n96:   }\n97: \n98:   saveFeatures(projectRoot, config, data);\n99: \n100:   outputMessage(fmt, `Task \"${opts.featureId}\": ${oldStatus} → ${newStatus}`, {\n101:     id: opts.featureId,\n102:     old_status: oldStatus,\n103:     new_status: newStatus,\n104:     changed: true,\n105:   });\n106: }\n\n(End of file - total 106 lines)\n</content>","title":"src/commands/tasks/set-status.ts","metadata":{"preview":"/**\n * tasks/set-status.ts — Change a task's status.\n *\n * Usage:\n *   woco tasks set-status <task-id> <new-status>\n *\n * Valid statuses: backlog, planned, in_progress, blocked, in_review, done, cancelled\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  saveFeatures,\n  findFeatureById,\n  type FeatureStatus,\n} from \"../../lib/tasks.js\";\nimport { VALID_STATUSES } from \"../../lib/task-schema.js\";\nimport { outputError, outputMessage, type OutputFormat } from \"../../lib/output.js\";\n\n// ---------------------------------------------------------------------------","truncated":false,"loaded":[]},"time":{"start":1773435860128,"end":1773435860131}}}}
{"type":"tool_use","timestamp":1773435860528,"sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","part":{"id":"prt_ce903b4a1001gaocllyZz1V295","sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","messageID":"msg_ce903a4b40016u9VM5CAKp8cNM","type":"tool","callID":"toolu_vrtx_01P4ve1jm3H7zxLeCyUhFKWq","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-cli-bugs/src/commands/tasks/set-priority.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-cli-bugs/src/commands/tasks/set-priority.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tasks/set-priority.ts — Change a task's priority.\n3:  *\n4:  * Usage:\n5:  *   woco tasks set-priority <task-id> <priority>\n6:  *\n7:  * Valid priorities: critical, high, medium, low, wishlist\n8:  *\n9:  * Supports --output json and --dry-run.\n10:  * Works on both top-level tasks and subtasks.\n11:  */\n12: \n13: import type { WomboConfig } from \"../../config.js\";\n14: import {\n15:   loadFeatures,\n16:   saveFeatures,\n17:   findFeatureById,\n18:   type Priority,\n19: } from \"../../lib/tasks.js\";\n20: import { VALID_PRIORITIES } from \"../../lib/task-schema.js\";\n21: import { outputError, outputMessage, type OutputFormat } from \"../../lib/output.js\";\n22: \n23: // ---------------------------------------------------------------------------\n24: // Types\n25: // ---------------------------------------------------------------------------\n26: \n27: export interface TasksSetPriorityOptions {\n28:   projectRoot: string;\n29:   config: WomboConfig;\n30:   featureId: string;\n31:   newPriority: string;\n32:   outputFmt?: OutputFormat;\n33:   dryRun?: boolean;\n34: }\n35: \n36: // ---------------------------------------------------------------------------\n37: // Command\n38: // ---------------------------------------------------------------------------\n39: \n40: export async function cmdTasksSetPriority(opts: TasksSetPriorityOptions): Promise<void> {\n41:   const { projectRoot, config } = opts;\n42:   const fmt = opts.outputFmt ?? \"text\";\n43: \n44:   if (!opts.featureId || !opts.newPriority) {\n45:     outputError(fmt, `Usage: woco tasks set-priority <task-id> <priority>\\nValid priorities: ${VALID_PRIORITIES.join(\", \")}`);\n46:     return;\n47:   }\n48: \n49:   // Validate priority\n50:   if (!(VALID_PRIORITIES as readonly string[]).includes(opts.newPriority)) {\n51:     outputError(fmt, `Invalid priority: \"${opts.newPriority}\"\\nValid priorities: ${VALID_PRIORITIES.join(\", \")}`);\n52:     return;\n53:   }\n54: \n55:   const data = loadFeatures(projectRoot, config);\n56:   const feature = findFeatureById(data, opts.featureId);\n57: \n58:   if (!feature) {\n59:     outputError(fmt, `Task \"${opts.featureId}\" not found.`);\n60:     return;\n61:   }\n62: \n63:   const oldPriority = feature.priority;\n64:   const newPriority = opts.newPriority as Priority;\n65: \n66:   if (oldPriority === newPriority) {\n67:     outputMessage(fmt, `Task \"${opts.featureId}\" already has priority \"${newPriority}\".`, {\n68:       id: opts.featureId,\n69:       priority: newPriority,\n70:       changed: false,\n71:     });\n72:     return;\n73:   }\n74: \n75:   // Dry-run: show what would change without writing\n76:   if (opts.dryRun) {\n77:     outputMessage(fmt, `[dry-run] Would change \"${opts.featureId}\" priority: ${oldPriority} → ${newPriority}`, {\n78:       dry_run: true,\n79:       id: opts.featureId,\n80:       old_priority: oldPriority,\n81:       new_priority: newPriority,\n82:       changed: false,\n83:     });\n84:     return;\n85:   }\n86: \n87:   // Apply priority change\n88:   feature.priority = newPriority;\n89: \n90:   saveFeatures(projectRoot, config, data);\n91: \n92:   outputMessage(fmt, `Task \"${opts.featureId}\" priority: ${oldPriority} → ${newPriority}`, {\n93:     id: opts.featureId,\n94:     old_priority: oldPriority,\n95:     new_priority: newPriority,\n96:     changed: true,\n97:   });\n98: }\n\n(End of file - total 98 lines)\n</content>","title":"src/commands/tasks/set-priority.ts","metadata":{"preview":"/**\n * tasks/set-priority.ts — Change a task's priority.\n *\n * Usage:\n *   woco tasks set-priority <task-id> <priority>\n *\n * Valid priorities: critical, high, medium, low, wishlist\n *\n * Supports --output json and --dry-run.\n * Works on both top-level tasks and subtasks.\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  saveFeatures,\n  findFeatureById,\n  type Priority,\n} from \"../../lib/tasks.js\";\nimport { VALID_PRIORITIES } from \"../../lib/task-schema.js\";","truncated":false,"loaded":[]},"time":{"start":1773435860522,"end":1773435860527}}}}
{"type":"tool_use","timestamp":1773435861090,"sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","part":{"id":"prt_ce903b62b0018xEgFkeuM4tEDA","sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","messageID":"msg_ce903a4b40016u9VM5CAKp8cNM","type":"tool","callID":"toolu_vrtx_012MZUCCfH3uBEDFczzvnurs","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-cli-bugs/src/commands/tasks/set-difficulty.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-cli-bugs/src/commands/tasks/set-difficulty.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tasks/set-difficulty.ts — Change a task's difficulty.\n3:  *\n4:  * Usage:\n5:  *   woco tasks set-difficulty <task-id> <difficulty>\n6:  *\n7:  * Valid difficulties: trivial, easy, medium, hard, very_hard\n8:  *\n9:  * Supports --output json and --dry-run.\n10:  * Works on both top-level tasks and subtasks.\n11:  */\n12: \n13: import type { WomboConfig } from \"../../config.js\";\n14: import {\n15:   loadFeatures,\n16:   saveFeatures,\n17:   findFeatureById,\n18:   type Difficulty,\n19: } from \"../../lib/tasks.js\";\n20: import { VALID_DIFFICULTIES } from \"../../lib/task-schema.js\";\n21: import { outputError, outputMessage, type OutputFormat } from \"../../lib/output.js\";\n22: \n23: // ---------------------------------------------------------------------------\n24: // Types\n25: // ---------------------------------------------------------------------------\n26: \n27: export interface TasksSetDifficultyOptions {\n28:   projectRoot: string;\n29:   config: WomboConfig;\n30:   featureId: string;\n31:   newDifficulty: string;\n32:   outputFmt?: OutputFormat;\n33:   dryRun?: boolean;\n34: }\n35: \n36: // ---------------------------------------------------------------------------\n37: // Command\n38: // ---------------------------------------------------------------------------\n39: \n40: export async function cmdTasksSetDifficulty(opts: TasksSetDifficultyOptions): Promise<void> {\n41:   const { projectRoot, config } = opts;\n42:   const fmt = opts.outputFmt ?? \"text\";\n43: \n44:   if (!opts.featureId || !opts.newDifficulty) {\n45:     outputError(fmt, `Usage: woco tasks set-difficulty <task-id> <difficulty>\\nValid difficulties: ${VALID_DIFFICULTIES.join(\", \")}`);\n46:     return;\n47:   }\n48: \n49:   // Validate difficulty\n50:   if (!(VALID_DIFFICULTIES as readonly string[]).includes(opts.newDifficulty)) {\n51:     outputError(fmt, `Invalid difficulty: \"${opts.newDifficulty}\"\\nValid difficulties: ${VALID_DIFFICULTIES.join(\", \")}`);\n52:     return;\n53:   }\n54: \n55:   const data = loadFeatures(projectRoot, config);\n56:   const feature = findFeatureById(data, opts.featureId);\n57: \n58:   if (!feature) {\n59:     outputError(fmt, `Task \"${opts.featureId}\" not found.`);\n60:     return;\n61:   }\n62: \n63:   const oldDifficulty = feature.difficulty;\n64:   const newDifficulty = opts.newDifficulty as Difficulty;\n65: \n66:   if (oldDifficulty === newDifficulty) {\n67:     outputMessage(fmt, `Task \"${opts.featureId}\" already has difficulty \"${newDifficulty}\".`, {\n68:       id: opts.featureId,\n69:       difficulty: newDifficulty,\n70:       changed: false,\n71:     });\n72:     return;\n73:   }\n74: \n75:   // Dry-run: show what would change without writing\n76:   if (opts.dryRun) {\n77:     outputMessage(fmt, `[dry-run] Would change \"${opts.featureId}\" difficulty: ${oldDifficulty} → ${newDifficulty}`, {\n78:       dry_run: true,\n79:       id: opts.featureId,\n80:       old_difficulty: oldDifficulty,\n81:       new_difficulty: newDifficulty,\n82:       changed: false,\n83:     });\n84:     return;\n85:   }\n86: \n87:   // Apply difficulty change\n88:   feature.difficulty = newDifficulty;\n89: \n90:   saveFeatures(projectRoot, config, data);\n91: \n92:   outputMessage(fmt, `Task \"${opts.featureId}\" difficulty: ${oldDifficulty} → ${newDifficulty}`, {\n93:     id: opts.featureId,\n94:     old_difficulty: oldDifficulty,\n95:     new_difficulty: newDifficulty,\n96:     changed: true,\n97:   });\n98: }\n\n(End of file - total 98 lines)\n</content>","title":"src/commands/tasks/set-difficulty.ts","metadata":{"preview":"/**\n * tasks/set-difficulty.ts — Change a task's difficulty.\n *\n * Usage:\n *   woco tasks set-difficulty <task-id> <difficulty>\n *\n * Valid difficulties: trivial, easy, medium, hard, very_hard\n *\n * Supports --output json and --dry-run.\n * Works on both top-level tasks and subtasks.\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  saveFeatures,\n  findFeatureById,\n  type Difficulty,\n} from \"../../lib/tasks.js\";\nimport { VALID_DIFFICULTIES } from \"../../lib/task-schema.js\";","truncated":false,"loaded":[]},"time":{"start":1773435861087,"end":1773435861089}}}}
{"type":"tool_use","timestamp":1773435861527,"sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","part":{"id":"prt_ce903b8600011mdApkqZfPbBEd","sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","messageID":"msg_ce903a4b40016u9VM5CAKp8cNM","type":"tool","callID":"toolu_vrtx_01SDf4BH6F18GvoqHXSz2M2N","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-cli-bugs/src/commands/tasks/show.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-cli-bugs/src/commands/tasks/show.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tasks/show.ts — Show detailed information about a specific task.\n3:  *\n4:  * Usage:\n5:  *   woco tasks show <task-id>\n6:  */\n7: \n8: import type { WomboConfig } from \"../../config.js\";\n9: import {\n10:   loadFeatures,\n11:   findFeatureById,\n12:   formatDuration,\n13:   parseDurationMinutes,\n14:   areDependenciesMet,\n15:   getDoneFeatureIds,\n16:   type Feature,\n17:   type Subtask,\n18: } from \"../../lib/tasks.js\";\n19: import { output, outputError, filterFields, type OutputFormat } from \"../../lib/output.js\";\n20: \n21: // ---------------------------------------------------------------------------\n22: // Types\n23: // ---------------------------------------------------------------------------\n24: \n25: export interface TasksShowOptions {\n26:   projectRoot: string;\n27:   config: WomboConfig;\n28:   featureId: string;\n29:   outputFmt?: OutputFormat;\n30:   fields?: string[];\n31: }\n32: \n33: // ---------------------------------------------------------------------------\n34: // ANSI Helpers\n35: // ---------------------------------------------------------------------------\n36: \n37: const RESET = \"\\x1b[0m\";\n38: const BOLD = \"\\x1b[1m\";\n39: const DIM = \"\\x1b[2m\";\n40: const GREEN = \"\\x1b[32m\";\n41: const RED = \"\\x1b[31m\";\n42: const YELLOW = \"\\x1b[33m\";\n43: const CYAN = \"\\x1b[36m\";\n44: \n45: // ---------------------------------------------------------------------------\n46: // Display Helpers\n47: // ---------------------------------------------------------------------------\n48: \n49: function statusColor(status: string): string {\n50:   switch (status) {\n51:     case \"done\": return GREEN;\n52:     case \"in_progress\": return CYAN;\n53:     case \"blocked\":\n54:     case \"failed\": return RED;\n55:     case \"cancelled\": return DIM;\n56:     default: return \"\";\n57:   }\n58: }\n59: \n60: function renderSubtask(st: Subtask, indent: number): void {\n61:   const pad = \"  \".repeat(indent);\n62:   const color = statusColor(st.status);\n63:   const effort = formatDuration(parseDurationMinutes(st.effort));\n64:   const completionStr = st.completion > 0 ? ` (${st.completion}%)` : \"\";\n65:   console.log(\n66:     `${pad}${color}[${st.status}]${RESET} ${st.id} — ${st.title} [${st.priority}/${st.difficulty}] (${effort})${completionStr}`\n67:   );\n68:   if (st.subtasks?.length) {\n69:     for (const sub of st.subtasks) {\n70:       renderSubtask(sub, indent + 1);\n71:     }\n72:   }\n73: }\n74: \n75: // ---------------------------------------------------------------------------\n76: // Command\n77: // ---------------------------------------------------------------------------\n78: \n79: export async function cmdTasksShow(opts: TasksShowOptions): Promise<void> {\n80:   const { projectRoot, config } = opts;\n81:   const fmt = opts.outputFmt ?? \"text\";\n82: \n83:   if (!opts.featureId) {\n84:     outputError(fmt, \"Usage: woco tasks show <task-id>\");\n85:     return;\n86:   }\n87: \n88:   const data = loadFeatures(projectRoot, config);\n89:   const feature = findFeatureById(data, opts.featureId);\n90: \n91:   if (!feature) {\n92:     outputError(fmt, `Task \"${opts.featureId}\" not found.`);\n93:     return;\n94:   }\n95: \n96:   const doneIds = getDoneFeatureIds(data);\n97:   const depsMet = areDependenciesMet(feature, doneIds);\n98:   const effort = formatDuration(parseDurationMinutes(feature.effort));\n99: \n100:   const fullData = {\n101:     ...feature,\n102:     deps_met: depsMet,\n103:     effort_formatted: effort,\n104:   };\n105: \n106:   // If --fields is specified, emit only those fields\n107:   if (opts.fields?.length) {\n108:     const filtered = filterFields(fullData as Record<string, unknown>, opts.fields);\n109:     output(fmt, filtered, () => {\n110:       for (const [key, val] of Object.entries(filtered)) {\n111:         const display = Array.isArray(val) ? val.join(\", \") : String(val ?? \"\");\n112:         console.log(`${key}: ${display}`);\n113:       }\n114:     });\n115:     return;\n116:   }\n117: \n118:   output(\n119:     fmt,\n120:     fullData,\n121:     () => {\n122:       console.log(`\\n${BOLD}Task: ${feature.title}${RESET}`);\n123:       console.log(`  ID:          ${feature.id}`);\n124:       console.log(`  Status:      ${statusColor(feature.status)}${feature.status}${RESET}`);\n125:       console.log(`  Priority:    ${feature.priority}`);\n126:       console.log(`  Difficulty:  ${feature.difficulty}`);\n127:       console.log(`  Effort:      ${effort}`);\n128:       console.log(`  Completion:  ${feature.completion}%`);\n129:       console.log(`  Deps met:    ${depsMet ? `${GREEN}yes${RESET}` : `${RED}no${RESET}`}`);\n130: \n131:       if (feature.started_at) {\n132:         console.log(`  Started:     ${feature.started_at}`);\n133:       }\n134:       if (feature.ended_at) {\n135:         console.log(`  Ended:       ${feature.ended_at}`);\n136:       }\n137: \n138:       if (feature.description) {\n139:         console.log(`\\n  ${BOLD}Description:${RESET}`);\n140:         for (const line of feature.description.split(\"\\n\")) {\n141:           console.log(`    ${line}`);\n142:         }\n143:       }\n144: \n145:       if (feature.depends_on.length > 0) {\n146:         console.log(`\\n  ${BOLD}Dependencies:${RESET}`);\n147:         for (const dep of feature.depends_on) {\n148:           const met = doneIds.has(dep);\n149:           const icon = met ? `${GREEN}✓${RESET}` : `${RED}✗${RESET}`;\n150:           console.log(`    ${icon} ${dep}`);\n151:         }\n152:       }\n153: \n154:       if (feature.constraints.length > 0) {\n155:         console.log(`\\n  ${BOLD}Constraints:${RESET}`);\n156:         for (const c of feature.constraints) {\n157:           console.log(`    - ${c}`);\n158:         }\n159:       }\n160: \n161:       if (feature.forbidden.length > 0) {\n162:         console.log(`\\n  ${BOLD}Forbidden:${RESET}`);\n163:         for (const f of feature.forbidden) {\n164:           console.log(`    - ${RED}${f}${RESET}`);\n165:         }\n166:       }\n167: \n168:       if (feature.references.length > 0) {\n169:         console.log(`\\n  ${BOLD}References:${RESET}`);\n170:         for (const r of feature.references) {\n171:           console.log(`    - ${DIM}${r}${RESET}`);\n172:         }\n173:       }\n174: \n175:       if (feature.notes.length > 0) {\n176:         console.log(`\\n  ${BOLD}Notes:${RESET}`);\n177:         for (const n of feature.notes) {\n178:           console.log(`    - ${n}`);\n179:         }\n180:       }\n181: \n182:       if (feature.subtasks.length > 0) {\n183:         console.log(`\\n  ${BOLD}Subtasks (${feature.subtasks.length}):${RESET}`);\n184:         for (const st of feature.subtasks) {\n185:           renderSubtask(st, 2);\n186:         }\n187:       }\n188: \n189:       console.log(\"\");\n190:     }\n191:   );\n192: }\n\n(End of file - total 192 lines)\n</content>","title":"src/commands/tasks/show.ts","metadata":{"preview":"/**\n * tasks/show.ts — Show detailed information about a specific task.\n *\n * Usage:\n *   woco tasks show <task-id>\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  findFeatureById,\n  formatDuration,\n  parseDurationMinutes,\n  areDependenciesMet,\n  getDoneFeatureIds,\n  type Feature,\n  type Subtask,\n} from \"../../lib/tasks.js\";\nimport { output, outputError, filterFields, type OutputFormat } from \"../../lib/output.js\";\n","truncated":false,"loaded":[]},"time":{"start":1773435861523,"end":1773435861526}}}}
