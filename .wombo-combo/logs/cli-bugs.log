{"type":"tool_use","timestamp":1773435927511,"sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","part":{"id":"prt_ce904b8f7001MTVguYhC2Aalkv","sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","messageID":"msg_ce904b05e001OJDyB53zp0C682","type":"tool","callID":"toolu_vrtx_016xxam4n4Dxt8W9ky2LhZEu","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-cli-bugs/src/commands/abort.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-cli-bugs/src/commands/abort.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * abort.ts — Kill a single running agent without nuking the entire wave.\n3:  *\n4:  * Usage: woco abort <feature-id> [--requeue] [--output json]\n5:  *\n6:  * Kills the multiplexer session (if any) and the agent process, then updates\n7:  * wave state to mark the agent as \"failed\" (default) or \"queued\"\n8:  * (if --requeue is passed, returning it to the queue for retry).\n9:  */\n10: \n11: import type { WomboConfig } from \"../config.js\";\n12: import {\n13:   loadState,\n14:   saveState,\n15:   updateAgent,\n16:   type AgentState,\n17: } from \"../lib/state.js\";\n18: import {\n19:   killMuxSession,\n20:   getMultiplexerName,\n21:   isProcessRunning,\n22: } from \"../lib/launcher.js\";\n23: import { output, outputError, type OutputFormat } from \"../lib/output.js\";\n24: \n25: // ---------------------------------------------------------------------------\n26: // Types\n27: // ---------------------------------------------------------------------------\n28: \n29: export interface AbortCommandOptions {\n30:   projectRoot: string;\n31:   config: WomboConfig;\n32:   featureId: string;\n33:   /** Return the feature to \"queued\" instead of marking it \"failed\" */\n34:   requeue?: boolean;\n35:   outputFmt: OutputFormat;\n36: }\n37: \n38: // ---------------------------------------------------------------------------\n39: // Command\n40: // ---------------------------------------------------------------------------\n41: \n42: export async function cmdAbort(opts: AbortCommandOptions): Promise<void> {\n43:   const { projectRoot, config, featureId, outputFmt } = opts;\n44: \n45:   // Load wave state\n46:   const state = loadState(projectRoot);\n47:   if (!state) {\n48:     outputError(outputFmt, \"No active wave. Nothing to abort.\");\n49:   }\n50: \n51:   // Find the agent\n52:   const agent = state.agents.find((a: AgentState) => a.feature_id === featureId);\n53:   if (!agent) {\n54:     outputError(\n55:       outputFmt,\n56:       `Agent not found for feature: ${featureId}. Use 'woco status' to see active agents.`\n57:     );\n58:   }\n59: \n60:   // Only abort agents that are actually active (running, installing, queued, resolving_conflict)\n61:   const abortable = new Set([\"running\", \"installing\", \"queued\", \"resolving_conflict\"]);\n62:   if (!abortable.has(agent.status)) {\n63:     outputError(\n64:       outputFmt,\n65:       `Agent ${featureId} is not in an abortable state (current: ${agent.status}). ` +\n66:         `Only running, installing, queued, or resolving_conflict agents can be aborted.`\n67:     );\n68:   }\n69: \n70:   // 1. Kill the multiplexer session (if any)\n71:   let muxKilled = false;\n72:   try {\n73:     killMuxSession(featureId, config);\n74:     muxKilled = true;\n75:   } catch {\n76:     // Session may not exist — that's fine\n77:   }\n78: \n79:   // 2. Kill the process by PID (if any and still running)\n80:   let processKilled = false;\n81:   if (agent.pid && isProcessRunning(agent.pid)) {\n82:     try {\n83:       process.kill(agent.pid, \"SIGTERM\");\n84:       processKilled = true;\n85:     } catch {\n86:       // Process may have already exited\n87:     }\n88:   }\n89: \n90:   // 3. Update wave state\n91:   const newStatus = opts.requeue ? \"queued\" : \"failed\";\n92:   const updates: Partial<AgentState> = {\n93:     status: newStatus as AgentState[\"status\"],\n94:     error: opts.requeue ? null : \"Aborted by user\",\n95:     completed_at: opts.requeue ? null : new Date().toISOString(),\n96:   };\n97: \n98:   // If requeuing, reset retry-related fields so the agent gets a fresh start\n99:   if (opts.requeue) {\n100:     updates.retries = 0;\n101:     updates.build_passed = null;\n102:     updates.build_output = null;\n103:     updates.started_at = null;\n104:     updates.completed_at = null;\n105:     updates.activity = null;\n106:     updates.activity_updated_at = null;\n107:   }\n108: \n109:   updateAgent(state, featureId, updates);\n110:   saveState(projectRoot, state);\n111: \n112:   // 4. Output result\n113:   const muxName = getMultiplexerName(config);\n114:   const result = {\n115:     feature_id: featureId,\n116:     previous_status: agent.status,\n117:     new_status: newStatus,\n118:     mux_killed: muxKilled,\n119:     process_killed: processKilled,\n120:     requeued: !!opts.requeue,\n121:   };\n122: \n123:   output(outputFmt, result, () => {\n124:     console.log(`\\nAborted agent: ${featureId}`);\n125:     console.log(`  Previous status: ${agent.status}`);\n126:     console.log(`  New status: ${newStatus}`);\n127:     if (muxKilled) console.log(`  Killed ${muxName} session: ${config.agent.tmuxPrefix}-${featureId}`);\n128:     if (processKilled) console.log(`  Killed process: PID ${agent.pid}`);\n129:     if (opts.requeue) {\n130:       console.log(`  Feature returned to queue for retry.`);\n131:     } else {\n132:       console.log(`  Feature marked as failed.`);\n133:     }\n134:   });\n135: }\n\n(End of file - total 135 lines)\n</content>","title":"src/commands/abort.ts","metadata":{"preview":"/**\n * abort.ts — Kill a single running agent without nuking the entire wave.\n *\n * Usage: woco abort <feature-id> [--requeue] [--output json]\n *\n * Kills the multiplexer session (if any) and the agent process, then updates\n * wave state to mark the agent as \"failed\" (default) or \"queued\"\n * (if --requeue is passed, returning it to the queue for retry).\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport {\n  loadState,\n  saveState,\n  updateAgent,\n  type AgentState,\n} from \"../lib/state.js\";\nimport {\n  killMuxSession,\n  getMultiplexerName,","truncated":false,"loaded":[]},"time":{"start":1773435927505,"end":1773435927510}}}}
