": \"file\",\n              \"language\": \"typescript\",\n              \"symbol_count\": 12\n            },\n            {\n              \"path\": \"src/lib/tui.ts\",\n              \"type\": \"file\",\n              \"language\": \"typescript\",\n              \"symbol_count\": 25\n            },\n            {\n              \"path\": \"src/lib/ui.ts\",\n              \"type\": \"file\",\n              \"language\": \"typescript\",\n              \"symbol_count\": 10\n            },\n            {\n              \"path\": \"src/lib/validate.ts\",\n              \"type\": \"file\",\n              \"language\": \"typescript\",\n              \"symbol_count\": 9\n            },\n            {\n              \"path\": \"src/lib/verifier.ts\",\n              \"type\": \"file\",\n              \"language\": \"typescript\",\n              \"symbol_count\": 7\n            },\n            {\n              \"path\": \"src/lib/worktree.ts\",\n              \"type\": \"file\",\n              \"language\": \"typescript\",\n              \"symbol_count\": 20\n            }\n          ]\n        },\n        {\n          \"path\": \"src/neo-blessed.d.ts\",\n          \"type\": \"file\",\n          \"language\": \"typescript\",\n          \"symbol_count\": 0\n        }\n      ]\n    },\n    {\n      \"path\": \"tests/\",\n      \"type\": \"dir\",\n      \"children\": [\n        {\n          \"path\": \"tests/arg-parsing.test.ts\",\n          \"type\": \"file\",\n          \"language\": \"typescript\",\n          \"symbol_count\": 2\n        },\n        {\n          \"path\": \"tests/features.test.ts\",\n          \"type\": \"file\",\n          \"language\": \"typescript\",\n          \"symbol_count\": 5\n        },\n        {\n          \"path\": \"tests/state.test.ts\",\n          \"type\": \"file\",\n          \"language\": \"typescript\",\n          \"symbol_count\": 2\n        },\n        {\n          \"path\": \"tests/worktree-filtering.test.ts\",\n          \"type\": \"fi