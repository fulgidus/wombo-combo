{"type":"tool_use","timestamp":1773435930274,"sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","part":{"id":"prt_ce904c3ea001L46scz8M5wXfUh","sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","messageID":"msg_ce904bbfe001tACfx67yFIMauL","type":"tool","callID":"toolu_vrtx_01UuHCbPu5i996aMALwT3h9H","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-cli-bugs/src/commands/retry.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-cli-bugs/src/commands/retry.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * retry.ts — Retry a specific failed agent.\n3:  *\n4:  * Usage: woco retry <feature-id> [--interactive] [--model <model>]\n5:  *\n6:  * Resets the agent's retry count and re-launches it. Can launch in either\n7:  * headless mode (default) or interactive (dmux/tmux) mode.\n8:  */\n9: \n10: import type { WomboConfig } from \"../config.js\";\n11: import { loadFeatures, type Feature } from \"../lib/tasks.js\";\n12: import {\n13:   loadState,\n14:   saveState,\n15:   updateAgent,\n16: } from \"../lib/state.js\";\n17: import { worktreeReady } from \"../lib/worktree.js\";\n18: import { generatePrompt } from \"../lib/prompt.js\";\n19: import { launchInteractive, getMultiplexerName } from \"../lib/launcher.js\";\n20: import { ProcessMonitor } from \"../lib/monitor.js\";\n21: import { launchSingleHeadless } from \"./launch.js\";\n22: \n23: // ---------------------------------------------------------------------------\n24: // Types\n25: // ---------------------------------------------------------------------------\n26: \n27: export interface RetryCommandOptions {\n28:   projectRoot: string;\n29:   config: WomboConfig;\n30:   featureId: string;\n31:   model?: string;\n32:   interactive: boolean;\n33:   dryRun?: boolean;\n34: }\n35: \n36: // ---------------------------------------------------------------------------\n37: // Command\n38: // ---------------------------------------------------------------------------\n39: \n40: export async function cmdRetry(opts: RetryCommandOptions): Promise<void> {\n41:   const { projectRoot, config } = opts;\n42: \n43:   if (!opts.featureId) {\n44:     console.error(\"Usage: woco retry <feature-id>\");\n45:     process.exit(1);\n46:     return; // unreachable — helps TypeScript narrow\n47:   }\n48: \n49:   const state = loadState(projectRoot);\n50:   if (!state) {\n51:     console.log(\"No active wave.\");\n52:     return;\n53:   }\n54: \n55:   const agent = state.agents.find((a) => a.feature_id === opts.featureId);\n56:   if (!agent) {\n57:     console.error(`Agent not found for feature: ${opts.featureId}`);\n58:     process.exit(1);\n59:     return; // unreachable — helps TypeScript narrow\n60:   }\n61: \n62:   if (agent.status !== \"failed\") {\n63:     console.error(\n64:       `Agent ${opts.featureId} is not in failed state (current: ${agent.status})`\n65:     );\n66:     process.exit(1);\n67:     return; // unreachable — helps TypeScript narrow\n68:   }\n69: \n70:   // Dry-run: show what would be retried without doing it\n71:   if (opts.dryRun) {\n72:     console.log(`\\n[dry-run] Would retry agent: ${opts.featureId}`);\n73:     console.log(`  Current status: ${agent.status}`);\n74:     console.log(`  Retries so far: ${agent.retries}`);\n75:     console.log(`  Worktree: ${agent.worktree}`);\n76:     console.log(`  Mode: ${opts.interactive ? \"interactive (multiplexer)\" : \"headless\"}`);\n77:     if (opts.model) console.log(`  Model: ${opts.model}`);\n78:     return;\n79:   }\n80: \n81:   // Reset retry count and re-run\n82:   updateAgent(state, agent.feature_id, {\n83:     status: \"queued\",\n84:     retries: 0,\n85:     error: null,\n86:     build_passed: null,\n87:     build_output: null,\n88:     completed_at: null,\n89:   });\n90:   saveState(projectRoot, state);\n91: \n92:   const data = loadFeatures(projectRoot, config);\n93:   const feature = data.tasks.find((f: Feature) => f.id === opts.featureId);\n94:   if (!feature) {\n95:     console.error(`Feature ${opts.featureId} not found in ${config.tasksFile}`);\n96:     process.exit(1);\n97:     return; // unreachable — helps TypeScript narrow\n98:   }\n99: \n100:   if (opts.interactive) {\n101:     const prompt = generatePrompt(feature, state.base_branch, config);\n102:     launchInteractive({\n103:       worktreePath: agent.worktree,\n104:       featureId: feature.id,\n105:       prompt,\n106:       model: opts.model,\n107:       interactive: true,\n108:       config,\n109:     });\n110: \n111:     updateAgent(state, agent.feature_id, {\n112:       status: \"running\",\n113:       started_at: new Date().toISOString(),\n114:     });\n115:     saveState(projectRoot, state);\n116:     const muxName = getMultiplexerName(config);\n117:     console.log(`Retrying ${opts.featureId} in ${muxName} session ${config.agent.tmuxPrefix}-${opts.featureId}`);\n118:   } else {\n119:     const monitor = new ProcessMonitor(projectRoot);\n120:     await launchSingleHeadless(projectRoot, state, agent, feature, monitor, config, opts.model);\n121:     console.log(`Retrying ${opts.featureId} in headless mode`);\n122:   }\n123: }\n\n(End of file - total 123 lines)\n</content>","title":"src/commands/retry.ts","metadata":{"preview":"/**\n * retry.ts — Retry a specific failed agent.\n *\n * Usage: woco retry <feature-id> [--interactive] [--model <model>]\n *\n * Resets the agent's retry count and re-launches it. Can launch in either\n * headless mode (default) or interactive (dmux/tmux) mode.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport { loadFeatures, type Feature } from \"../lib/tasks.js\";\nimport {\n  loadState,\n  saveState,\n  updateAgent,\n} from \"../lib/state.js\";\nimport { worktreeReady } from \"../lib/worktree.js\";\nimport { generatePrompt } from \"../lib/prompt.js\";\nimport { launchInteractive, getMultiplexerName } from \"../lib/launcher.js\";\nimport { ProcessMonitor } from \"../lib/monitor.js\";","truncated":false,"loaded":[]},"time":{"start":1773435930271,"end":1773435930273}}}}
