{"type":"tool_use","timestamp":1773435932956,"sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","part":{"id":"prt_ce904ce8a002JS3bXfRxkbhDjZ","sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","messageID":"msg_ce904c6c7001MHlpZCNdDhPdrK","type":"tool","callID":"toolu_vrtx_01A5eHVfu1TRYwUA3cGQQWVp","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-cli-bugs/src/commands/history.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-cli-bugs/src/commands/history.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * history.ts — View wave history and summaries.\n3:  *\n4:  * Usage:\n5:  *   woco history                    List all past waves\n6:  *   woco history <wave-id>          Show details of a specific wave\n7:  *   woco history --output json      Output as JSON\n8:  *\n9:  * Wave history is stored in .wombo-combo/history/<wave-id>.json and survives\n10:  * `woco cleanup`. Records are auto-exported when a wave completes.\n11:  */\n12: \n13: import type { WomboConfig } from \"../config.js\";\n14: import {\n15:   listHistory,\n16:   loadHistory,\n17:   type WaveHistoryRecord,\n18: } from \"../lib/history.js\";\n19: import { output, outputError, type OutputFormat } from \"../lib/output.js\";\n20: \n21: // ---------------------------------------------------------------------------\n22: // Types\n23: // ---------------------------------------------------------------------------\n24: \n25: export interface HistoryCommandOptions {\n26:   projectRoot: string;\n27:   config: WomboConfig;\n28:   /** Specific wave ID to show details for */\n29:   waveId?: string;\n30:   /** Output format */\n31:   outputFmt: OutputFormat;\n32: }\n33: \n34: // ---------------------------------------------------------------------------\n35: // Formatting Helpers\n36: // ---------------------------------------------------------------------------\n37: \n38: const RESET = \"\\x1b[0m\";\n39: const BOLD = \"\\x1b[1m\";\n40: const DIM = \"\\x1b[2m\";\n41: const FG = {\n42:   red: \"\\x1b[31m\",\n43:   green: \"\\x1b[32m\",\n44:   yellow: \"\\x1b[33m\",\n45:   blue: \"\\x1b[34m\",\n46:   magenta: \"\\x1b[35m\",\n47:   cyan: \"\\x1b[36m\",\n48:   gray: \"\\x1b[90m\",\n49: };\n50: \n51: function pad(text: string, width: number): string {\n52:   if (text.length >= width) return text.slice(0, width);\n53:   return text + \" \".repeat(width - text.length);\n54: }\n55: \n56: function padLeft(text: string, width: number): string {\n57:   if (text.length >= width) return text.slice(0, width);\n58:   return \" \".repeat(width - text.length) + text;\n59: }\n60: \n61: function formatDurationMs(ms: number | null): string {\n62:   if (ms === null || ms === 0) return \"-\";\n63:   const seconds = Math.floor(ms / 1000);\n64:   if (seconds < 60) return `${seconds}s`;\n65:   const minutes = Math.floor(seconds / 60);\n66:   if (minutes < 60) return `${minutes}m ${seconds % 60}s`;\n67:   const hours = Math.floor(minutes / 60);\n68:   return `${hours}h ${minutes % 60}m`;\n69: }\n70: \n71: function formatDate(iso: string): string {\n72:   try {\n73:     const d = new Date(iso);\n74:     return d.toLocaleDateString(\"en-US\", {\n75:       year: \"numeric\",\n76:       month: \"short\",\n77:       day: \"numeric\",\n78:       hour: \"2-digit\",\n79:       minute: \"2-digit\",\n80:     });\n81:   } catch {\n82:     return iso;\n83:   }\n84: }\n85: \n86: function statusColor(status: string): string {\n87:   switch (status) {\n88:     case \"merged\":\n89:       return FG.magenta;\n90:     case \"verified\":\n91:       return FG.green;\n92:     case \"failed\":\n93:       return FG.red;\n94:     case \"completed\":\n95:       return FG.yellow;\n96:     default:\n97:       return FG.gray;\n98:   }\n99: }\n100: \n101: // ---------------------------------------------------------------------------\n102: // List All Waves\n103: // ---------------------------------------------------------------------------\n104: \n105: function renderWaveList(records: WaveHistoryRecord[]): void {\n106:   if (records.length === 0) {\n107:     console.log(\"\\nNo wave history found.\");\n108:     console.log(\"History is auto-exported when a wave completes.\\n\");\n109:     return;\n110:   }\n111: \n112:   console.log(\"\");\n113:   console.log(`${BOLD}Wave History (${records.length} wave(s)):${RESET}`);\n114:   console.log(\"\");\n115: \n116:   const header = [\n117:     pad(\"Wave ID\", 24),\n118:     pad(\"Date\", 22),\n119:     padLeft(\"Total\", 6),\n120:     padLeft(\"OK\", 4),\n121:     padLeft(\"Fail\", 5),\n122:     padLeft(\"Merged\", 7),\n123:     padLeft(\"Retries\", 8),\n124:     padLeft(\"Duration\", 10),\n125:   ].join(\" \");\n126: \n127:   console.log(`${BOLD}${header}${RESET}`);\n128:   console.log(\"-\".repeat(90));\n129: \n130:   for (const rec of records) {\n131:     const s = rec.summary;\n132:     const okColor = s.succeeded === s.total ? FG.green : FG.yellow;\n133:     const failColor = s.failed > 0 ? FG.red : FG.gray;\n134: \n135:     const row = [\n136:       pad(rec.wave_id, 24),\n137:       pad(formatDate(rec.started_at), 22),\n138:       padLeft(String(s.total), 6),\n139:       `${okColor}${padLeft(String(s.succeeded), 4)}${RESET}`,\n140:       `${failColor}${padLeft(String(s.failed), 5)}${RESET}`,\n141:       padLeft(String(s.merged), 7),\n142:       padLeft(String(s.total_retries), 8),\n143:       padLeft(formatDurationMs(s.total_duration_ms), 10),\n144:     ].join(\" \");\n145: \n146:     console.log(row);\n147:   }\n148: \n149:   console.log(\"\");\n150:   console.log(`${DIM}Use 'woco history <wave-id>' for details.${RESET}`);\n151:   console.log(\"\");\n152: }\n153: \n154: // ---------------------------------------------------------------------------\n155: // Show Single Wave Details\n156: // ---------------------------------------------------------------------------\n157: \n158: function renderWaveDetails(rec: WaveHistoryRecord): void {\n159:   console.log(\"\");\n160:   console.log(`${BOLD}Wave: ${rec.wave_id}${RESET}`);\n161:   console.log(`${DIM}Base: ${rec.base_branch} | Concurrency: ${rec.max_concurrent} | Mode: ${rec.interactive ? \"interactive\" : \"headless\"}${RESET}`);\n162:   if (rec.model) {\n163:     console.log(`${DIM}Model: ${rec.model}${RESET}`);\n164:   }\n165:   console.log(`${DIM}Started: ${formatDate(rec.started_at)} | Exported: ${formatDate(rec.exported_at)}${RESET}`);\n166:   console.log(\"\");\n167: \n168:   // Summary\n169:   const s = rec.summary;\n170:   console.log(`${BOLD}Summary:${RESET}`);\n171:   console.log(`  Total agents:    ${s.total}`);\n172:   console.log(`  Succeeded:       ${FG.green}${s.succeeded}${RESET}`);\n173:   console.log(`  Failed:          ${s.failed > 0 ? FG.red : FG.gray}${s.failed}${RESET}`);\n174:   console.log(`  Merged:          ${FG.magenta}${s.merged}${RESET}`);\n175:   console.log(`  Verified:        ${FG.green}${s.verified}${RESET}`);\n176:   console.log(`  Total retries:   ${s.total_retries}`);\n177:   console.log(`  Total duration:  ${formatDurationMs(s.total_duration_ms)}`);\n178:   console.log(\"\");\n179: \n180:   // Agent table\n181:   console.log(`${BOLD}Agents:${RESET}`);\n182:   console.log(\"\");\n183: \n184:   const header = [\n185:     pad(\"Feature\", 30),\n186:     pad(\"Status\", 12),\n187:     padLeft(\"Retries\", 8),\n188:     padLeft(\"Duration\", 10),\n189:     pad(\"Build\", 6),\n190:     pad(\"Conflict\", 9),\n191:     pad(\"Error\", 30),\n192:   ].join(\" \");\n193: \n194:   console.log(`${BOLD}${header}${RESET}`);\n195:   console.log(\"-\".repeat(109));\n196: \n197:   for (const agent of rec.agents) {\n198:     const color = statusColor(agent.status);\n199:     const buildStr = agent.build_passed === true\n200:       ? `${FG.green}pass${RESET}`\n201:       : agent.build_passed === false\n202:         ? `${FG.red}fail${RESET}`\n203:         : `${FG.gray}-${RESET}`;\n204:     const conflictStr = agent.had_merge_conflict\n205:       ? `${FG.yellow}yes${RESET}`\n206:       : `${FG.gray}no${RESET}`;\n207:     const errorStr = agent.error\n208:       ? agent.error.split(\"\\n\")[0].slice(0, 28)\n209:       : \"-\";\n210: \n211:     const row = [\n212:       pad(agent.feature_id, 30),\n213:       `${color}${pad(agent.status, 12)}${RESET}`,\n214:       padLeft(\n215:         agent.retries > 0 ? `${agent.retries}/${agent.max_retries}` : \"-\",\n216:         8\n217:       ),\n218:       padLeft(formatDurationMs(agent.duration_ms), 10),\n219:       pad(buildStr, 6),\n220:       pad(conflictStr, 9),\n221:       pad(errorStr, 30),\n222:     ].join(\" \");\n223: \n224:     console.log(row);\n225:   }\n226: \n227:   console.log(\"\");\n228: }\n229: \n230: // ---------------------------------------------------------------------------\n231: // Command\n232: // ---------------------------------------------------------------------------\n233: \n234: export async function cmdHistory(opts: HistoryCommandOptions): Promise<void> {\n235:   const { projectRoot, outputFmt } = opts;\n236: \n237:   if (opts.waveId) {\n238:     // Show details for a specific wave\n239:     const record = loadHistory(projectRoot, opts.waveId);\n240:     if (!record) {\n241:       outputError(\n242:         outputFmt,\n243:         `Wave history not found: ${opts.waveId}. Use 'woco history' to list available waves.`\n244:       );\n245:     }\n246: \n247:     output(outputFmt, record, () => {\n248:       renderWaveDetails(record!);\n249:     });\n250:   } else {\n251:     // List all waves\n252:     const records = listHistory(projectRoot);\n253: \n254:     output(outputFmt, records, () => {\n255:       renderWaveList(records);\n256:     });\n257:   }\n258: }\n\n(End of file - total 258 lines)\n</content>","title":"src/commands/history.ts","metadata":{"preview":"/**\n * history.ts — View wave history and summaries.\n *\n * Usage:\n *   woco history                    List all past waves\n *   woco history <wave-id>          Show details of a specific wave\n *   woco history --output json      Output as JSON\n *\n * Wave history is stored in .wombo-combo/history/<wave-id>.json and survives\n * `woco cleanup`. Records are auto-exported when a wave completes.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport {\n  listHistory,\n  loadHistory,\n  type WaveHistoryRecord,\n} from \"../lib/history.js\";\nimport { output, outputError, type OutputFormat } from \"../lib/output.js\";\n","truncated":false,"loaded":[]},"time":{"start":1773435932953,"end":1773435932955}}}}
