{"type":"tool_use","timestamp":1773435939911,"sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","part":{"id":"prt_ce904e8f8001zBILqKstGdAHOu","sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","messageID":"msg_ce904dc10001CH9bJHfzvFNaDN","type":"tool","callID":"toolu_vrtx_01SiASKxuNrzGXBhivZ4nMCC","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-cli-bugs/src/commands/tasks/add.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-cli-bugs/src/commands/tasks/add.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tasks/add.ts — Add a new task to the tasks file.\n3:  *\n4:  * Usage:\n5:  *   woco tasks add <id> --title \"Task Title\" [--description \"...\"]\n6:  *                   [--priority medium] [--difficulty easy] [--effort PT2H]\n7:  *                   [--depends-on \"task1,task2\"]\n8:  */\n9: \n10: import type { WomboConfig } from \"../../config.js\";\n11: import {\n12:   loadFeatures,\n13:   saveFeatures,\n14:   createBlankFeature,\n15:   allFeatureIds,\n16:   type Priority,\n17:   type Difficulty,\n18: } from \"../../lib/tasks.js\";\n19: import {\n20:   VALID_PRIORITIES,\n21:   VALID_DIFFICULTIES,\n22: } from \"../../lib/task-schema.js\";\n23: import { outputError, outputMessage, type OutputFormat } from \"../../lib/output.js\";\n24: import { validateEnum } from \"../../lib/validate.js\";\n25: \n26: // ---------------------------------------------------------------------------\n27: // Types\n28: // ---------------------------------------------------------------------------\n29: \n30: export interface TasksAddOptions {\n31:   projectRoot: string;\n32:   config: WomboConfig;\n33:   id: string;\n34:   title: string;\n35:   description?: string;\n36:   priority?: Priority;\n37:   difficulty?: Difficulty;\n38:   effort?: string;\n39:   dependsOn?: string[];\n40:   outputFmt?: OutputFormat;\n41:   dryRun?: boolean;\n42: }\n43: \n44: // ---------------------------------------------------------------------------\n45: // Command\n46: // ---------------------------------------------------------------------------\n47: \n48: export async function cmdTasksAdd(opts: TasksAddOptions): Promise<void> {\n49:   const { projectRoot, config } = opts;\n50:   const fmt = opts.outputFmt ?? \"text\";\n51: \n52:   if (!opts.id) {\n53:     outputError(fmt, \"Usage: woco tasks add <id> --title \\\"Task Title\\\"\");\n54:     return;\n55:   }\n56: \n57:   if (!opts.title) {\n58:     outputError(fmt, \"--title is required when adding a task.\");\n59:     return;\n60:   }\n61: \n62:   // Validate priority and difficulty enums (imported from task-schema.ts)\n63:   if (opts.priority) {\n64:     const pResult = validateEnum(opts.priority, VALID_PRIORITIES, \"--priority\");\n65:     if (!pResult.valid) {\n66:       outputError(fmt, pResult.error!);\n67:       return;\n68:     }\n69:   }\n70: \n71:   if (opts.difficulty) {\n72:     const dResult = validateEnum(opts.difficulty, VALID_DIFFICULTIES, \"--difficulty\");\n73:     if (!dResult.valid) {\n74:       outputError(fmt, dResult.error!);\n75:       return;\n76:     }\n77:   }\n78: \n79:   const data = loadFeatures(projectRoot, config);\n80: \n81:   // Check for duplicate ID\n82:   const existingIds = allFeatureIds(data);\n83:   if (existingIds.includes(opts.id)) {\n84:     outputError(fmt, `Task ID \"${opts.id}\" already exists.`);\n85:     return;\n86:   }\n87: \n88:   // Validate depends_on references\n89:   if (opts.dependsOn?.length) {\n90:     for (const dep of opts.dependsOn) {\n91:       if (!existingIds.includes(dep)) {\n92:         outputError(fmt, `Dependency \"${dep}\" does not exist in the tasks file.`);\n93:         return;\n94:       }\n95:     }\n96:   }\n97: \n98:   // Create the feature\n99:   const feature = createBlankFeature(opts.id, opts.title, opts.description ?? \"\", {\n100:     priority: opts.priority,\n101:     difficulty: opts.difficulty,\n102:     effort: opts.effort,\n103:   });\n104: \n105:   // Set dependencies\n106:   if (opts.dependsOn?.length) {\n107:     feature.depends_on = opts.dependsOn;\n108:   }\n109: \n110:   // Dry-run: show what would be added without writing\n111:   if (opts.dryRun) {\n112:     outputMessage(fmt, `[dry-run] Would add task: ${opts.id} — ${opts.title}`, {\n113:       dry_run: true,\n114:       id: feature.id,\n115:       title: feature.title,\n116:       priority: feature.priority,\n117:       difficulty: feature.difficulty,\n118:       effort: feature.effort,\n119:       depends_on: feature.depends_on,\n120:     });\n121:     return;\n122:   }\n123: \n124:   // Append to features list\n125:   data.tasks.push(feature);\n126:   saveFeatures(projectRoot, config, data);\n127: \n128:   outputMessage(fmt, `Added task: ${opts.id} — ${opts.title}`, {\n129:     id: feature.id,\n130:     title: feature.title,\n131:     priority: feature.priority,\n132:     difficulty: feature.difficulty,\n133:     effort: feature.effort,\n134:     depends_on: feature.depends_on,\n135:   });\n136: \n137:   if (fmt === \"text\") {\n138:     console.log(`  priority: ${feature.priority}, difficulty: ${feature.difficulty}, effort: ${feature.effort}`);\n139:     if (feature.depends_on.length > 0) {\n140:       console.log(`  depends on: ${feature.depends_on.join(\", \")}`);\n141:     }\n142:   }\n143: }\n\n(End of file - total 143 lines)\n</content>","title":"src/commands/tasks/add.ts","metadata":{"preview":"/**\n * tasks/add.ts — Add a new task to the tasks file.\n *\n * Usage:\n *   woco tasks add <id> --title \"Task Title\" [--description \"...\"]\n *                   [--priority medium] [--difficulty easy] [--effort PT2H]\n *                   [--depends-on \"task1,task2\"]\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  saveFeatures,\n  createBlankFeature,\n  allFeatureIds,\n  type Priority,\n  type Difficulty,\n} from \"../../lib/tasks.js\";\nimport {\n  VALID_PRIORITIES,","truncated":false,"loaded":[]},"time":{"start":1773435939909,"end":1773435939911}}}}
