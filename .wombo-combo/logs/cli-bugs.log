{"type":"tool_use","timestamp":1773435849590,"sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","part":{"id":"prt_ce903892a001RhdHW7iA8169U2","sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","messageID":"msg_ce9037b8c001aIYQXD4xpyC3ZR","type":"tool","callID":"toolu_vrtx_01D8vWMcZQqaYpSdmhE3qt9v","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-cli-bugs/src/lib/validate.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-cli-bugs/src/lib/validate.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * validate.ts — Input validation / hardening for agent-ready CLI.\n3:  *\n4:  * All user/agent-supplied inputs pass through these validators at the CLI\n5:  * boundary. This prevents hallucinated inputs from corrupting state.\n6:  *\n7:  * Rules:\n8:  *   - Feature IDs: kebab-case only, no path traversals, no query params\n9:  *   - Branch names: no control chars, no \"..\", no spaces\n10:  *   - Free-text (titles, descriptions): no control chars except \\n \\t\n11:  *   - Effort strings: ISO 8601 duration pattern only\n12:  */\n13: \n14: // ---------------------------------------------------------------------------\n15: // Patterns\n16: // ---------------------------------------------------------------------------\n17: \n18: /** Valid feature/subtask ID: lowercase alphanumeric + hyphens, 1-128 chars */\n19: const ID_PATTERN = /^[a-z0-9][a-z0-9-]{0,127}$/;\n20: \n21: /** Control characters below space, excluding \\t (0x09) and \\n (0x0a) */\n22: const CONTROL_CHARS = /[\\x00-\\x08\\x0b\\x0c\\x0e-\\x1f\\x7f]/;\n23: \n24: /** Path traversal sequences */\n25: const PATH_TRAVERSAL = /\\.\\.\\//;\n26: \n27: /** Embedded query params or fragments */\n28: const QUERY_FRAGMENT = /[?#]/;\n29: \n30: /** Percent-encoded sequences (indicates double-encoding risk) */\n31: const PERCENT_ENCODED = /%[0-9a-fA-F]{2}/;\n32: \n33: /** ISO 8601 duration: P[nY][nM][nD][T[nH][nM][nS]] */\n34: const DURATION_PATTERN = /^P(?:\\d+Y)?(?:\\d+M)?(?:\\d+D)?(?:T(?:\\d+H)?(?:\\d+M)?(?:\\d+S)?)?$/;\n35: \n36: // ---------------------------------------------------------------------------\n37: // Result type\n38: // ---------------------------------------------------------------------------\n39: \n40: export interface ValidationResult {\n41:   valid: boolean;\n42:   error?: string;\n43: }\n44: \n45: function ok(): ValidationResult {\n46:   return { valid: true };\n47: }\n48: \n49: function fail(error: string): ValidationResult {\n50:   return { valid: false, error };\n51: }\n52: \n53: // ---------------------------------------------------------------------------\n54: // Validators\n55: // ---------------------------------------------------------------------------\n56: \n57: /**\n58:  * Validate a feature or subtask ID.\n59:  * Must be kebab-case, no traversals, no query params, no encoded chars.\n60:  */\n61: export function validateId(value: string, label: string = \"ID\"): ValidationResult {\n62:   if (!value || value.length === 0) {\n63:     return fail(`${label} must not be empty.`);\n64:   }\n65: \n66:   if (CONTROL_CHARS.test(value)) {\n67:     return fail(`${label} contains control characters.`);\n68:   }\n69: \n70:   if (PATH_TRAVERSAL.test(value)) {\n71:     return fail(`${label} contains path traversal sequence \"../\".`);\n72:   }\n73: \n74:   if (QUERY_FRAGMENT.test(value)) {\n75:     return fail(`${label} contains query/fragment characters (? or #).`);\n76:   }\n77: \n78:   if (PERCENT_ENCODED.test(value)) {\n79:     return fail(`${label} contains percent-encoded characters — possible double-encoding.`);\n80:   }\n81: \n82:   if (!ID_PATTERN.test(value)) {\n83:     return fail(\n84:       `${label} \"${value}\" is invalid. IDs must be kebab-case ` +\n85:       `(lowercase letters, digits, hyphens), 1–128 characters, starting with a letter or digit.`\n86:     );\n87:   }\n88: \n89:   return ok();\n90: }\n91: \n92: /**\n93:  * Validate free-text input (titles, descriptions, notes).\n94:  * Rejects control chars except \\t and \\n.\n95:  */\n96: export function validateText(value: string, label: string = \"text\"): ValidationResult {\n97:   if (CONTROL_CHARS.test(value)) {\n98:     return fail(`${label} contains control characters (non-printable bytes).`);\n99:   }\n100:   return ok();\n101: }\n102: \n103: /**\n104:  * Validate a branch name.\n105:  * No control chars, no \"..\", no spaces, no ~, ^, :, \\, ?, *, [\n106:  */\n107: export function validateBranchName(value: string, label: string = \"branch name\"): ValidationResult {\n108:   if (!value || value.length === 0) {\n109:     return fail(`${label} must not be empty.`);\n110:   }\n111: \n112:   if (CONTROL_CHARS.test(value)) {\n113:     return fail(`${label} contains control characters.`);\n114:   }\n115: \n116:   if (/\\.\\./.test(value)) {\n117:     return fail(`${label} contains \"..\" which is not allowed in git branch names.`);\n118:   }\n119: \n120:   if (/[ ~^:\\\\?*\\[]/.test(value)) {\n121:     return fail(`${label} contains characters not allowed in git branch names.`);\n122:   }\n123: \n124:   return ok();\n125: }\n126: \n127: /**\n128:  * Validate an ISO 8601 duration string.\n129:  */\n130: export function validateDuration(value: string, label: string = \"effort\"): ValidationResult {\n131:   if (!value || value.length === 0) {\n132:     return fail(`${label} must not be empty.`);\n133:   }\n134: \n135:   if (!DURATION_PATTERN.test(value)) {\n136:     return fail(\n137:       `${label} \"${value}\" is not a valid ISO 8601 duration. ` +\n138:       `Expected format: P[nY][nM][nD][T[nH][nM][nS]] (e.g., \"PT2H\", \"P1D\", \"P1DT4H30M\").`\n139:     );\n140:   }\n141: \n142:   return ok();\n143: }\n144: \n145: /**\n146:  * Validate a status value against the allowed set.\n147:  */\n148: export function validateEnum(\n149:   value: string,\n150:   allowed: readonly string[],\n151:   label: string = \"value\"\n152: ): ValidationResult {\n153:   if (!allowed.includes(value)) {\n154:     return fail(`${label} \"${value}\" is not valid. Allowed values: ${allowed.join(\", \")}`);\n155:   }\n156:   return ok();\n157: }\n158: \n159: // ---------------------------------------------------------------------------\n160: // Convenience: validate and exit on failure\n161: // ---------------------------------------------------------------------------\n162: \n163: /**\n164:  * Run a validation and exit with error message if invalid.\n165:  * For use at the CLI boundary.\n166:  */\n167: export function assertValid(result: ValidationResult): void {\n168:   if (!result.valid) {\n169:     console.error(`Validation error: ${result.error}`);\n170:     process.exit(1);\n171:   }\n172: }\n\n(End of file - total 172 lines)\n</content>","title":"src/lib/validate.ts","metadata":{"preview":"/**\n * validate.ts — Input validation / hardening for agent-ready CLI.\n *\n * All user/agent-supplied inputs pass through these validators at the CLI\n * boundary. This prevents hallucinated inputs from corrupting state.\n *\n * Rules:\n *   - Feature IDs: kebab-case only, no path traversals, no query params\n *   - Branch names: no control chars, no \"..\", no spaces\n *   - Free-text (titles, descriptions): no control chars except \\n \\t\n *   - Effort strings: ISO 8601 duration pattern only\n */\n\n// ---------------------------------------------------------------------------\n// Patterns\n// ---------------------------------------------------------------------------\n\n/** Valid feature/subtask ID: lowercase alphanumeric + hyphens, 1-128 chars */\nconst ID_PATTERN = /^[a-z0-9][a-z0-9-]{0,127}$/;\n","truncated":false,"loaded":[]},"time":{"start":1773435849573,"end":1773435849584}}}}
{"type":"tool_use","timestamp":1773435850094,"sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","part":{"id":"prt_ce9038b68001GmVw03aqLX0BZw","sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","messageID":"msg_ce9037b8c001aIYQXD4xpyC3ZR","type":"tool","callID":"toolu_vrtx_01PgrCg1znjX8frTMSUeJCzF","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-cli-bugs/src/lib/tasks.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-cli-bugs/src/lib/tasks.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tasks.ts -- Parse tasks YAML and provide task selection/filtering.\n3:  *\n4:  * Responsibilities:\n5:  *   - Load and parse the tasks file with full type safety\n6:  *   - Load and parse the archive file separately\n7:  *   - Parse ISO 8601 durations into comparable minutes\n8:  *   - Filter tasks by status, priority, difficulty, dependency readiness\n9:  *   - Select tasks by various strategies (top-priority, quickest-wins, etc.)\n10:  *   - Resolve dependency graphs to determine which tasks are ready to start\n11:  *   - Write-back capability for task management commands\n12:  */\n13: \n14: import { existsSync, mkdirSync } from \"node:fs\";\n15: import { resolve, dirname, join } from \"node:path\";\n16: import { createInterface } from \"node:readline\";\n17: import type { WomboConfig } from \"../config.js\";\n18: import { WOMBO_DIR } from \"../config.js\";\n19: import {\n20:   loadTasksFromStore,\n21:   loadArchiveFromStore,\n22:   saveAllTasksToStore,\n23:   saveAllArchiveToStore,\n24:   saveTaskToStore,\n25:   saveTaskToArchive,\n26:   removeTaskFromStore,\n27:   tasksStoreExists,\n28:   saveTasksMetaToStore,\n29:   saveArchiveMetaToStore,\n30:   getTasksDir,\n31:   getArchiveDir,\n32:   saveTaskFile,\n33:   deleteTaskFile,\n34: } from \"./task-store.js\";\n35: \n36: // ---------------------------------------------------------------------------\n37: // Template path (resolved relative to this source file)\n38: // ---------------------------------------------------------------------------\n39: \n40: export const META_TEMPLATE_PATH = join(dirname(import.meta.dir), \"templates\", \"_meta.yml\");\n41: /** @deprecated Use META_TEMPLATE_PATH — the old monolithic template no longer exists. */\n42: export const TASKS_TEMPLATE_PATH = META_TEMPLATE_PATH;\n43: \n44: // ---------------------------------------------------------------------------\n45: // Types\n46: // ---------------------------------------------------------------------------\n47: \n48: export type TaskStatus =\n49:   | \"backlog\"\n50:   | \"planned\"\n51:   | \"in_progress\"\n52:   | \"blocked\"\n53:   | \"in_review\"\n54:   | \"done\"\n55:   | \"cancelled\";\n56: \n57: export type Priority = \"critical\" | \"high\" | \"medium\" | \"low\" | \"wishlist\";\n58: \n59: export type Difficulty = \"trivial\" | \"easy\" | \"medium\" | \"hard\" | \"very_hard\";\n60: \n61: /**\n62:  * Unified task type. Previously split into Feature and Subtask, but the shapes\n63:  * are identical so there is no reason to maintain two names.\n64:  */\n65: export interface Task {\n66:   id: string;\n67:   title: string;\n68:   description: string;\n69:   status: TaskStatus;\n70:   completion: number;\n71:   difficulty: Difficulty;\n72:   priority: Priority;\n73:   depends_on: string[];\n74:   effort: string;\n75:   started_at: string | null;\n76:   ended_at: string | null;\n77:   constraints: string[];\n78:   forbidden: string[];\n79:   references: string[];\n80:   notes: string[];\n81:   subtasks: Task[];\n82:   /**\n83:    * Optional agent type from an external registry (e.g. agency-agents).\n84:    * Format: \"category/agent-name\" (e.g. \"engineering/engineering-frontend-developer\").\n85:    * When set, wombo downloads and patches the specified agent definition\n86:    * instead of using the default generalist agent.\n87:    */\n88:   agent_type?: string;\n89: }\n90: \n91: /**\n92:  * Shape of tasks.yml (active tasks).\n93:  */\n94: export interface TasksFile {\n95:   version: string;\n96:   meta: {\n97:     created_at: string;\n98:     updated_at: string;\n99:     project: string;\n100:     generator: string;\n101:     maintainer: string;\n102:   };\n103:   tasks: Task[];\n104: }\n105: \n106: /**\n107:  * Shape of archive.yml (archived tasks). Same structure as TasksFile.\n108:  */\n109: export type ArchiveFile = TasksFile;\n110: \n111: // Backward-compat aliases (ease migration in consuming code)\n112: export type Feature = Task;\n113: export type Subtask = Task;\n114: export type FeatureStatus = TaskStatus;\n115: export type FeaturesFile = TasksFile & { archive: Task[] };\n116: \n117: // Re-export ordering maps from the canonical source (task-schema.ts)\n118: import { PRIORITY_ORDER, DIFFICULTY_ORDER } from \"./task-schema.js\";\n119: export { PRIORITY_ORDER, DIFFICULTY_ORDER };\n120: \n121: // ---------------------------------------------------------------------------\n122: // ISO 8601 Duration Parser\n123: // ---------------------------------------------------------------------------\n124: \n125: /**\n126:  * Parse an ISO 8601 duration string into total minutes.\n127:  * Supports: P[nY][nM][nD][T[nH][nM][nS]]\n128:  * Examples: PT1H -> 60, PT30M -> 30, P1D -> 1440, P2DT4H -> 3360, PT1H30M -> 90\n129:  *           P1Y -> 525600, P2M -> 86400\n130:  * Year/month approximations: 1Y = 365D, 1M = 30D\n131:  */\n132: export function parseDurationMinutes(iso: string): number {\n133:   const match = iso.match(\n134:     /^P(?:(\\d+)Y)?(?:(\\d+)M)?(?:(\\d+)D)?(?:T(?:(\\d+)H)?(?:(\\d+)M)?(?:(\\d+)S)?)?$/\n135:   );\n136:   if (!match) return Infinity; // unparseable -> sort to end\n137:   const years = parseInt(match[1] || \"0\", 10);\n138:   const months = parseInt(match[2] || \"0\", 10);\n139:   const days = parseInt(match[3] || \"0\", 10);\n140:   const hours = parseInt(match[4] || \"0\", 10);\n141:   const minutes = parseInt(match[5] || \"0\", 10);\n142:   const seconds = parseInt(match[6] || \"0\", 10);\n143:   const totalDays = years * 365 + months * 30 + days;\n144:   return totalDays * 24 * 60 + hours * 60 + minutes + Math.ceil(seconds / 60);\n145: }\n146: \n147: /**\n148:  * Format minutes into a human-readable string.\n149:  */\n150: export function formatDuration(minutes: number): string {\n151:   if (minutes === Infinity) return \"unknown\";\n152:   if (minutes < 60) return `${minutes}m`;\n153:   const h = Math.floor(minutes / 60);\n154:   const m = minutes % 60;\n155:   if (h >= 24) {\n156:     const d = Math.floor(h / 24);\n157:     const rh = h % 24;\n158:     if (rh === 0 && m === 0) return `${d}d`;\n159:     if (m === 0) return `${d}d ${rh}h`;\n160:     return `${d}d ${rh}h ${m}m`;\n161:   }\n162:   return m === 0 ? `${h}h` : `${h}h ${m}m`;\n163: }\n164: \n165: // ---------------------------------------------------------------------------\n166: // .wombo-combo directory helpers\n167: // ---------------------------------------------------------------------------\n168: \n169: /**\n170:  * Ensure the .wombo-combo directory exists.\n171:  */\n172: export function ensureWomboDir(projectRoot: string): string {\n173:   const dir = resolve(projectRoot, WOMBO_DIR);\n174:   if (!existsSync(dir)) {\n175:     mkdirSync(dir, { recursive: true });\n176:   }\n177:   return dir;\n178: }\n179: \n180: /**\n181:  * Resolve a file path within the .wombo-combo directory.\n182:  */\n183: function womboPath(projectRoot: string, filename: string): string {\n184:   return resolve(projectRoot, WOMBO_DIR, filename);\n185: }\n186: \n187: // ---------------------------------------------------------------------------\n188: // Tasks File Existence Guard\n189: // ---------------------------------------------------------------------------\n190: \n191: /**\n192:  * Prompt the user with a yes/no question via stdin.\n193:  */\n194: function promptYesNo(question: string): Promise<boolean> {\n195:   const rl = createInterface({ input: process.stdin, output: process.stdout });\n196:   return new Promise((resolve) => {\n197:     rl.question(question, (answer) => {\n198:       rl.close();\n199:       resolve(answer.trim().toLowerCase().startsWith(\"y\"));\n200:     });\n201:   });\n202: }\n203: \n204: /**\n205:  * Ensure the tasks store exists before any command that needs it.\n206:  * If the folder is missing, prompt the user to generate one from scratch\n207:  * or auto-migrate from a legacy single-file tasks.yml.\n208:  */\n209: export async function ensureTasksFile(\n210:   projectRoot: string,\n211:   config: WomboConfig\n212: ): Promise<void> {\n213:   if (tasksStoreExists(projectRoot, config)) return;\n214: \n215:   // Try loading — this triggers auto-migration from legacy files\n216:   const data = loadTasksFromStore(projectRoot, config);\n217:   if (data.tasks.length > 0 || tasksStoreExists(projectRoot, config)) return;\n218: \n219:   console.log(`\\nTasks store not found: ${WOMBO_DIR}/${config.tasksDir}/`);\n220: \n221:   const generate = await promptYesNo(\n222:     \"Generate a new tasks store from template? (y/N): \"\n223:   );\n224: \n225:   if (!generate) {\n226:     console.error(\n227:       `Cannot proceed without a tasks store. Create one manually or run again and accept the prompt.`\n228:     );\n229:     process.exit(1);\n230:   }\n231: \n232:   // Ensure .wombo-combo/ directory exists\n233:   ensureWomboDir(projectRoot);\n234: \n235:   const now = new Date().toISOString();\n236:   saveTasksMetaToStore(projectRoot, config, {\n237:     version: \"1.0\",\n238:     meta: {\n239:       created_at: now,\n240:       updated_at: now,\n241:       project: \"unknown\",\n242:       generator: \"wombo-combo\",\n243:       maintainer: \"unknown\",\n244:     },\n245:   });\n246:   console.log(`Created ${WOMBO_DIR}/${config.tasksDir}/ with empty task store.\\n`);\n247: \n248:   // Also create empty archive store\n249:   saveArchiveMetaToStore(projectRoot, config, {\n250:     version: \"1.0\",\n251:     meta: {\n252:       created_at: now,\n253:       updated_at: now,\n254:       project: \"unknown\",\n255:       generator: \"wombo-combo\",\n256:       maintainer: \"unknown\",\n257:     },\n258:   });\n259:   console.log(`Created ${WOMBO_DIR}/${config.archiveDir}/.\\n`);\n260: }\n261: \n262: // Backward-compat alias\n263: export const ensureFeaturesFile = ensureTasksFile;\n264: \n265: // ---------------------------------------------------------------------------\n266: // Loader\n267: // ---------------------------------------------------------------------------\n268: \n269: /**\n270:  * Load and parse tasks from the folder-based store.\n271:  */\n272: export function loadTasks(\n273:   projectRoot: string,\n274:   config: WomboConfig\n275: ): TasksFile {\n276:   return loadTasksFromStore(projectRoot, config);\n277: }\n278: \n279: /**\n280:  * Load archived tasks from the folder-based store.\n281:  * Returns an empty ArchiveFile if the store doesn't exist.\n282:  */\n283: export function loadArchive(\n284:   projectRoot: string,\n285:   config: WomboConfig\n286: ): ArchiveFile {\n287:   return loadArchiveFromStore(projectRoot, config);\n288: }\n289: \n290: /**\n291:  * Backward-compat: load tasks + archive merged into a single FeaturesFile shape.\n292:  * This eases migration — callers that used loadFeatures() keep working.\n293:  */\n294: export function loadFeatures(\n295:   projectRoot: string,\n296:   config: WomboConfig\n297: ): FeaturesFile {\n298:   const tasksData = loadTasks(projectRoot, config);\n299:   const archiveData = loadArchive(projectRoot, config);\n300:   return {\n301:     ...tasksData,\n302:     // Map \"tasks\" to \"features\" for backward compat (FeaturesFile has .features)\n303:     // Actually FeaturesFile extends TasksFile which has .tasks, but add .archive\n304:     archive: archiveData.tasks,\n305:   };\n306: }\n307: \n308: // ---------------------------------------------------------------------------\n309: // Writer\n310: // ---------------------------------------------------------------------------\n311: \n312: /**\n313:  * Save all tasks to the folder-based store.\n314:  * Writes _meta.yml + one file per task.\n315:  */\n316: export function saveTasks(\n317:   projectRoot: string,\n318:   config: WomboConfig,\n319:   data: TasksFile\n320: ): void {\n321:   saveAllTasksToStore(projectRoot, config, data);\n322: }\n323: \n324: /**\n325:  * Save all archived tasks to the folder-based store.\n326:  */\n327: export function saveArchive(\n328:   projectRoot: string,\n329:   config: WomboConfig,\n330:   data: ArchiveFile\n331: ): void {\n332:   saveAllArchiveToStore(projectRoot, config, data);\n333: }\n334: \n335: /**\n336:  * Backward-compat: save a FeaturesFile (tasks + archive in one object).\n337:  * Splits and writes to both tasks.yml and archive.yml.\n338:  */\n339: export function saveFeatures(\n340:   projectRoot: string,\n341:   config: WomboConfig,\n342:   data: FeaturesFile\n343: ): void {\n344:   const tasksData: TasksFile = {\n345:     version: data.version,\n346:     meta: { ...data.meta },\n347:     tasks: data.tasks,\n348:   };\n349:   saveTasks(projectRoot, config, tasksData);\n350: \n351:   if (data.archive && data.archive.length > 0) {\n352:     const archiveData: ArchiveFile = {\n353:       version: data.version,\n354:       meta: { ...data.meta },\n355:       tasks: data.archive,\n356:     };\n357:     saveArchive(projectRoot, config, archiveData);\n358:   }\n359: }\n360: \n361: \n362: // ---------------------------------------------------------------------------\n363: // Dependency Resolution\n364: // ---------------------------------------------------------------------------\n365: \n366: /**\n367:  * Get all task IDs that are done (status === \"done\" or completion === 100).\n368:  */\n369: function getDoneIds(tasks: Task[], archive: Task[]): Set<string> {\n370:   const done = new Set<string>();\n371:   const collectDone = (items: Task[]) => {\n372:     for (const item of items) {\n373:       if (item.status === \"done\" || item.completion === 100) {\n374:         done.add(item.id);\n375:       }\n376:       if (item.subtasks?.length) {\n377:         collectDone(item.subtasks);\n378:       }\n379:     }\n380:   };\n381:   collectDone(tasks);\n382:   collectDone(archive);\n383:   return done;\n384: }\n385: \n386: /**\n387:  * Check if a task's dependencies are all satisfied.\n388:  */\n389: export function areDependenciesMet(\n390:   task: Task,\n391:   doneIds: Set<string>\n392: ): boolean {\n393:   return task.depends_on.every((dep) => doneIds.has(dep));\n394: }\n395: \n396: /**\n397:  * Get all tasks that are ready to start (backlog + deps met).\n398:  */\n399: export function getReadyTasks(data: TasksFile, archive?: Task[]): Task[] {\n400:   const doneIds = getDoneIds(data.tasks, archive ?? []);\n401:   return data.tasks.filter(\n402:     (t) =>\n403:       t.status === \"backlog\" &&\n404:       t.completion === 0 &&\n405:       areDependenciesMet(t, doneIds)\n406:   );\n407: }\n408: \n409: /**\n410:  * Get done IDs (exported for use in selection error messages).\n411:  */\n412: export function getDoneTaskIds(data: TasksFile, archive?: Task[]): Set<string> {\n413:   return getDoneIds(data.tasks, archive ?? []);\n414: }\n415: \n416: // Backward-compat aliases\n417: export function getReadyFeatures(data: FeaturesFile): Task[] {\n418:   return getReadyTasks(data, data.archive);\n419: }\n420: \n421: export function getDoneFeatureIds(data: FeaturesFile): Set<string> {\n422:   return getDoneTaskIds(data, data.archive);\n423: }\n424: \n425: // ---------------------------------------------------------------------------\n426: // Selection Strategies\n427: // ---------------------------------------------------------------------------\n428: \n429: export interface SelectionOptions {\n430:   /** Select top N by priority (highest priority first, then lowest effort) */\n431:   topPriority?: number;\n432:   /** Select N quickest wins (lowest effort first) */\n433:   quickestWins?: number;\n434:   /** Select all tasks matching this priority level */\n435:   priority?: Priority;\n436:   /** Select all tasks matching this difficulty level */\n437:   difficulty?: Difficulty;\n438:   /** Select specific task IDs (comma-separated) */\n439:   taskIds?: string[];\n440:   /** Select all ready tasks */\n441:   allReady?: boolean;\n442: }\n443: \n444: /**\n445:  * Select tasks based on the given strategy.\n446:  * Always filters to only ready tasks (backlog + deps met) first.\n447:  */\n448: export function selectTasks(\n449:   data: TasksFile,\n450:   options: SelectionOptions,\n451:   archive?: Task[]\n452: ): Task[] {\n453:   const ready = getReadyTasks(data, archive);\n454: \n455:   if (options.allReady) {\n456:     return sortByPriorityThenEffort(ready);\n457:   }\n458: \n459:   if (options.taskIds?.length) {\n460:     const idSet = new Set(options.taskIds);\n461:     const selected = ready.filter((t) => idSet.has(t.id));\n462:     const missing = options.taskIds.filter(\n463:       (id) => !selected.find((t) => t.id === id)\n464:     );\n465:     if (missing.length) {\n466:       const allIds = data.tasks.map((t) => t.id);\n467:       const doneIds = getDoneIds(data.tasks, archive ?? []);\n468:       for (const m of missing) {\n469:         if (!allIds.includes(m)) {\n470:           console.error(`  Task \"${m}\" does not exist in the tasks file`);\n471:         } else {\n472:           const task = data.tasks.find((t) => t.id === m)!;\n473:           console.error(\n474:             `  Task \"${m}\" is not ready (status: ${task.status}, deps met: ${areDependenciesMet(task, doneIds)})`\n475:           );\n476:         }\n477:       }\n478:     }\n479:     return sortByPriorityThenEffort(selected);\n480:   }\n481: \n482:   if (options.priority) {\n483:     return sortByPriorityThenEffort(\n484:       ready.filter((t) => t.priority === options.priority)\n485:     );\n486:   }\n487: \n488:   if (options.difficulty) {\n489:     return sortByEffort(ready.filter((t) => t.difficulty === options.difficulty));\n490:   }\n491: \n492:   if (options.topPriority) {\n493:     return sortByPriorityThenEffort(ready).slice(0, options.topPriority);\n494:   }\n495: \n496:   if (options.quickestWins) {\n497:     return sortByEffort(ready).slice(0, options.quickestWins);\n498:   }\n499: \n500:   // Default: return all ready, sorted by priority\n501:   return sortByPriorityThenEffort(ready);\n502: }\n503: \n504: // Backward-compat alias\n505: export function selectFeatures(\n506:   data: FeaturesFile,\n507:   options: SelectionOptions & { featureIds?: string[] }\n508: ): Task[] {\n509:   // Map featureIds -> taskIds for backward compat\n510:   const opts: SelectionOptions = {\n511:     ...options,\n512:     taskIds: options.taskIds ?? options.featureIds,\n513:   };\n514:   return selectTasks(data, opts, data.archive);\n515: }\n516: \n517: // ---------------------------------------------------------------------------\n518: // Sorting Helpers\n519: // ---------------------------------------------------------------------------\n520: \n521: function sortByPriorityThenEffort(tasks: Task[]): Task[] {\n522:   return [...tasks].sort((a, b) => {\n523:     const pDiff = PRIORITY_ORDER[a.priority] - PRIORITY_ORDER[b.priority];\n524:     if (pDiff !== 0) return pDiff;\n525:     return parseDurationMinutes(a.effort) - parseDurationMinutes(b.effort);\n526:   });\n527: }\n528: \n529: function sortByEffort(tasks: Task[]): Task[] {\n530:   return [...tasks].sort(\n531:     (a, b) => parseDurationMinutes(a.effort) - parseDurationMinutes(b.effort)\n532:   );\n533: }\n534: \n535: // ---------------------------------------------------------------------------\n536: // Utility Exports\n537: // ---------------------------------------------------------------------------\n538: \n539: /**\n540:  * Get a compact summary of a task for display.\n541:  */\n542: export function taskSummary(t: Task): string {\n543:   const effort = formatDuration(parseDurationMinutes(t.effort));\n544:   return `[${t.priority}/${t.difficulty}] ${t.id} -- ${t.title} (${effort})`;\n545: }\n546: \n547: // Backward-compat alias\n548: export const featureSummary = taskSummary;\n549: \n550: /**\n551:  * Recursively search a list of tasks (and their subtasks) for a matching ID.\n552:  */\n553: function findInList(tasks: Task[], id: string): Task | undefined {\n554:   for (const t of tasks) {\n555:     if (t.id === id) return t;\n556:     if (t.subtasks?.length) {\n557:       const found = findInList(t.subtasks, id);\n558:       if (found) return found;\n559:     }\n560:   }\n561:   return undefined;\n562: }\n563: \n564: /**\n565:  * Find a task by ID across active tasks, their subtasks\n566:  * (recursively), and the archive list.\n567:  */\n568: export function findTaskById(\n569:   data: TasksFile,\n570:   id: string,\n571:   archive?: Task[]\n572: ): Task | undefined {\n573:   return (\n574:     findInList(data.tasks, id) ??\n575:     (archive ? findInList(archive, id) : undefined)\n576:   );\n577: }\n578: \n579: // Backward-compat alias\n580: export function findFeatureById(\n581:   data: FeaturesFile,\n582:   id: string\n583: ): Task | undefined {\n584:   return findTaskById(data, id, data.archive);\n585: }\n586: \n587: /**\n588:  * Create a blank task with all required fields initialized.\n589:  */\n590: export function createBlankTask(\n591:   id: string,\n592:   title: string,\n593:   description: string = \"\",\n594:   opts?: {\n595:     priority?: Priority;\n596:     difficulty?: Difficulty;\n597:     effort?: string;\n598:   }\n599: ): Task {\n600:   return {\n601:     id,\n602:     title,\n603:     description,\n604:     status: \"backlog\",\n605:     completion: 0,\n606:     difficulty: opts?.difficulty ?? \"medium\",\n607:     priority: opts?.priority ?? \"medium\",\n608:     depends_on: [],\n609:     effort: opts?.effort ?? \"PT1H\",\n610:     started_at: null,\n611:     ended_at: null,\n612:     constraints: [],\n613:     forbidden: [],\n614:     references: [],\n615:     notes: [],\n616:     subtasks: [],\n617:   };\n618: }\n619: \n620: // Backward-compat alias\n621: export const createBlankFeature = createBlankTask;\n622: \n623: /**\n624:  * Get all task IDs (active + archive), useful for validation.\n625:  */\n626: export function allTaskIds(data: TasksFile, archive?: Task[]): string[] {\n627:   const ids: string[] = [];\n628:   const collect = (items: Task[]) => {\n629:     for (const item of items) {\n630:       ids.push(item.id);\n631:       if (item.subtasks?.length) collect(item.subtasks);\n632:     }\n633:   };\n634:   collect(data.tasks);\n635:   collect(archive ?? []);\n636:   return ids;\n637: }\n638: \n639: // Backward-compat alias\n640: export function allFeatureIds(data: FeaturesFile): string[] {\n641:   return allTaskIds(data, data.archive);\n642: }\n643: \n644: // Re-export the old template path name for migration\n645: export const FEATURES_TEMPLATE_PATH = TASKS_TEMPLATE_PATH;\n646: \n647: // Re-export store functions for single-task operations\n648: export {\n649:   saveTaskToStore,\n650:   saveTaskToArchive,\n651:   removeTaskFromStore,\n652:   getTasksDir,\n653:   getArchiveDir,\n654: } from \"./task-store.js\";\n\n(End of file - total 654 lines)\n</content>","title":"src/lib/tasks.ts","metadata":{"preview":"/**\n * tasks.ts -- Parse tasks YAML and provide task selection/filtering.\n *\n * Responsibilities:\n *   - Load and parse the tasks file with full type safety\n *   - Load and parse the archive file separately\n *   - Parse ISO 8601 durations into comparable minutes\n *   - Filter tasks by status, priority, difficulty, dependency readiness\n *   - Select tasks by various strategies (top-priority, quickest-wins, etc.)\n *   - Resolve dependency graphs to determine which tasks are ready to start\n *   - Write-back capability for task management commands\n */\n\nimport { existsSync, mkdirSync } from \"node:fs\";\nimport { resolve, dirname, join } from \"node:path\";\nimport { createInterface } from \"node:readline\";\nimport type { WomboConfig } from \"../config.js\";\nimport { WOMBO_DIR } from \"../config.js\";\nimport {\n  loadTasksFromStore,","truncated":false,"loaded":[]},"time":{"start":1773435850055,"end":1773435850092}}}}
{"type":"tool_use","timestamp":1773435850651,"sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","part":{"id":"prt_ce9038daa0018BA7LHGVmgPjvH","sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","messageID":"msg_ce9037b8c001aIYQXD4xpyC3ZR","type":"tool","callID":"toolu_vrtx_01UAoftwVT6MKBK2UcswsLuV","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-cli-bugs/src/lib/output.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-cli-bugs/src/lib/output.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * output.ts — Shared output helpers for agent-ready CLI.\n3:  *\n4:  * Provides a centralized way for commands to emit structured data that\n5:  * renders as human-readable text on TTY or as JSON when --output json\n6:  * is specified (or when stdout is not a TTY).\n7:  *\n8:  * Usage in commands:\n9:  *   import { output, OutputFormat } from \"../lib/output.js\";\n10:  *\n11:  *   // At the end of a command:\n12:  *   output(format, data);           // emits JSON or human text\n13:  *   outputError(format, message);   // emits error in the right format\n14:  */\n15: \n16: // ---------------------------------------------------------------------------\n17: // Types\n18: // ---------------------------------------------------------------------------\n19: \n20: export type OutputFormat = \"text\" | \"json\" | \"toon\";\n21: \n22: // ---------------------------------------------------------------------------\n23: // Helpers\n24: // ---------------------------------------------------------------------------\n25: \n26: /**\n27:  * Determine the output format. Priority:\n28:  *   1. Explicit --output flag value\n29:  *   2. WOMBO_OUTPUT env var (for agent pipelines)\n30:  *   3. Default to \"text\"\n31:  *\n32:  * Note: We intentionally do NOT auto-detect based on TTY. Many legitimate\n33:  * use cases (bun dev, piped to less/grep, CI) have non-TTY stdout but still\n34:  * want human output. Agents should explicitly pass --output json or set\n35:  * WOMBO_OUTPUT=json.\n36:  */\n37: export function resolveOutputFormat(explicit?: string): OutputFormat {\n38:   if (explicit === \"json\") return \"json\";\n39:   if (explicit === \"toon\") return \"toon\";\n40:   if (explicit === \"text\") return \"text\";\n41:   // Check env var for agent pipelines\n42:   const env = process.env.WOMBO_OUTPUT;\n43:   if (env === \"json\") return \"json\";\n44:   if (env === \"toon\") return \"toon\";\n45:   return \"text\";\n46: }\n47: \n48: /**\n49:  * Emit structured data. In JSON mode, outputs a single JSON line to stdout.\n50:  * In text mode, calls the provided textRenderer callback.\n51:  */\n52: export function output(\n53:   format: OutputFormat,\n54:   data: unknown,\n55:   textRenderer: () => void\n56: ): void {\n57:   if (format === \"json\") {\n58:     console.log(JSON.stringify(data));\n59:   } else {\n60:     textRenderer();\n61:   }\n62: }\n63: \n64: /**\n65:  * Emit an error. In JSON mode, outputs {\"error\": message} to stderr.\n66:  * In text mode, outputs the message to stderr normally.\n67:  */\n68: export function outputError(format: OutputFormat, message: string, exitCode: number = 1): never {\n69:   if (format === \"json\") {\n70:     console.error(JSON.stringify({ error: message }));\n71:   } else {\n72:     console.error(message);\n73:   }\n74:   process.exit(exitCode);\n75: }\n76: \n77: /**\n78:  * Emit a success/info message. In JSON mode, outputs {\"message\": msg, ...extra}.\n79:  * In text mode, outputs the message to stdout normally.\n80:  */\n81: export function outputMessage(\n82:   format: OutputFormat,\n83:   message: string,\n84:   extra?: Record<string, unknown>\n85: ): void {\n86:   if (format === \"json\") {\n87:     console.log(JSON.stringify({ message, ...extra }));\n88:   } else {\n89:     console.log(message);\n90:   }\n91: }\n92: \n93: // ---------------------------------------------------------------------------\n94: // Field filtering for compact output (--fields)\n95: // ---------------------------------------------------------------------------\n96: \n97: /**\n98:  * Filter an object to only include the specified fields.\n99:  * If fields is undefined/empty, returns the object unchanged.\n100:  */\n101: export function filterFields<T extends Record<string, unknown>>(\n102:   obj: T,\n103:   fields?: string[]\n104: ): Partial<T> {\n105:   if (!fields || fields.length === 0) return obj;\n106:   const result: Partial<T> = {};\n107:   for (const field of fields) {\n108:     if (field in obj) {\n109:       (result as any)[field] = (obj as any)[field];\n110:     }\n111:   }\n112:   return result;\n113: }\n114: \n115: /**\n116:  * Filter an array of objects to only include specified fields per object.\n117:  * If fields is undefined/empty, returns the array unchanged.\n118:  */\n119: export function filterFieldsArray<T extends Record<string, unknown>>(\n120:   arr: T[],\n121:   fields?: string[]\n122: ): Partial<T>[] {\n123:   if (!fields || fields.length === 0) return arr;\n124:   return arr.map((obj) => filterFields(obj, fields));\n125: }\n126: \n127: /**\n128:  * Render a compact text table from an array of objects with selected fields.\n129:  * Used for text-mode --fields output.\n130:  */\n131: export function renderCompactTable(\n132:   items: Record<string, unknown>[],\n133:   fields: string[]\n134: ): void {\n135:   if (items.length === 0) return;\n136: \n137:   // Calculate column widths\n138:   const widths: Record<string, number> = {};\n139:   for (const field of fields) {\n140:     widths[field] = field.length;\n141:     for (const item of items) {\n142:       const val = String(item[field] ?? \"\");\n143:       widths[field] = Math.max(widths[field], val.length);\n144:     }\n145:   }\n146: \n147:   // Header\n148:   const header = fields.map((f) => f.padEnd(widths[f])).join(\"  \");\n149:   console.log(header);\n150:   console.log(fields.map((f) => \"─\".repeat(widths[f])).join(\"  \"));\n151: \n152:   // Rows\n153:   for (const item of items) {\n154:     const row = fields.map((f) => String(item[f] ?? \"\").padEnd(widths[f])).join(\"  \");\n155:     console.log(row);\n156:   }\n157: }\n\n(End of file - total 157 lines)\n</content>","title":"src/lib/output.ts","metadata":{"preview":"/**\n * output.ts — Shared output helpers for agent-ready CLI.\n *\n * Provides a centralized way for commands to emit structured data that\n * renders as human-readable text on TTY or as JSON when --output json\n * is specified (or when stdout is not a TTY).\n *\n * Usage in commands:\n *   import { output, OutputFormat } from \"../lib/output.js\";\n *\n *   // At the end of a command:\n *   output(format, data);           // emits JSON or human text\n *   outputError(format, message);   // emits error in the right format\n */\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type OutputFormat = \"text\" | \"json\" | \"toon\";","truncated":false,"loaded":[]},"time":{"start":1773435850645,"end":1773435850650}}}}
{"type":"text","timestamp":1773435851034,"sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","part":{"id":"prt_ce90386a1001EFMck639V9pQYY","sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","messageID":"msg_ce9037b8c001aIYQXD4xpyC3ZR","type":"text","text":"Now let me do a systematic exploration of all the command files and key library files to find bugs. Let me read the critical files in parallel:","time":{"start":1773435851033,"end":1773435851033}}}
{"type":"tool_use","timestamp":1773435851044,"sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","part":{"id":"prt_ce9038f97001hbSokzTzIJ1SbK","sessionID":"ses_316fcbe54ffegvIvV0T61c4er2","messageID":"msg_ce9037b8c001aIYQXD4xpyC3ZR","type":"tool","callID":"toolu_vrtx_011p9KcnSH5PwXzYMLHQCjzo","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-cli-bugs/src/lib/state.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-cli-bugs/src/lib/state.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * state.ts — Persistent wave state management.\n3:  *\n4:  * Responsibilities:\n5:  *   - Define the shape of .wombo-combo/state.json\n6:  *   - Read/write state atomically\n7:  *   - Generate wave IDs\n8:  *   - Update individual agent state within a wave\n9:  */\n10: \n11: import { readFileSync, writeFileSync, existsSync, renameSync, mkdirSync } from \"node:fs\";\n12: import { resolve } from \"node:path\";\n13: import { WOMBO_DIR } from \"../config.js\";\n14: \n15: // ---------------------------------------------------------------------------\n16: // Types\n17: // ---------------------------------------------------------------------------\n18: \n19: export type AgentStatus =\n20:   | \"queued\"\n21:   | \"installing\"\n22:   | \"running\"\n23:   | \"completed\"\n24:   | \"verified\"\n25:   | \"failed\"\n26:   | \"merged\"\n27:   | \"retry\"\n28:   | \"resolving_conflict\";\n29: \n30: export interface AgentState {\n31:   feature_id: string;\n32:   branch: string;\n33:   worktree: string;\n34:   session_id: string | null;\n35:   pid: number | null;\n36:   status: AgentStatus;\n37:   activity: string | null;\n38:   activity_updated_at: string | null;\n39:   retries: number;\n40:   max_retries: number;\n41:   started_at: string | null;\n42:   completed_at: string | null;\n43:   build_passed: boolean | null;\n44:   build_output: string | null;\n45:   error: string | null;\n46:   /** Estimated effort in milliseconds (from feature's ISO 8601 duration) */\n47:   effort_estimate_ms: number | null;\n48:   /** Stream index this agent belongs to (for dependency-aware scheduling) */\n49:   stream_index: number | null;\n50:   /** IDs of features this agent depends on (within the current wave) */\n51:   depends_on: string[];\n52:   /** IDs of features that depend on this agent (within the current wave) */\n53:   depended_on_by: string[];\n54:   /**\n55:    * Override agent name for this specific agent (from registry).\n56:    * When set, uses this agent definition instead of the default generalist.\n57:    * e.g. \"engineering-frontend-developer\"\n58:    */\n59:   agent_name: string | null;\n60:   /**\n61:    * The agent_type from the task (e.g. \"engineering/engineering-frontend-developer\").\n62:    * Stored for informational purposes and to support resume with re-fetch.\n63:    */\n64:   agent_type: string | null;\n65: }\n66: \n67: export interface WaveState {\n68:   wave_id: string;\n69:   base_branch: string;\n70:   started_at: string;\n71:   updated_at: string;\n72:   max_concurrent: number;\n73:   model: string | null;\n74:   interactive: boolean;\n75:   agents: AgentState[];\n76:   /** Dependency-aware scheduling plan (null if no dependencies exist) */\n77:   schedule_plan: SerializedSchedulePlan | null;\n78: }\n79: \n80: /**\n81:  * Serialized schedule plan stored in wave state JSON.\n82:  * Uses plain arrays instead of the rich SchedulePlan type for JSON compatibility.\n83:  */\n84: export interface SerializedSchedulePlan {\n85:   /** Streams: each is a list of feature IDs to execute sequentially */\n86:   streams: string[][];\n87:   /** Merge gates: features that must wait for multiple deps from different streams */\n88:   merge_gates: Array<{ feature_id: string; wait_for: string[] }>;\n89:   /** Topological order of all features */\n90:   topological_order: string[];\n91: }\n92: \n93: // ---------------------------------------------------------------------------\n94: // Constants\n95: // ---------------------------------------------------------------------------\n96: \n97: const STATE_FILE = \".wombo-combo/state.json\";\n98: \n99: // ---------------------------------------------------------------------------\n100: // Wave ID Generation\n101: // ---------------------------------------------------------------------------\n102: \n103: /**\n104:  * Generate a unique wave ID based on current timestamp.\n105:  * Format: wave-YYYY-MM-DD-NNN\n106:  */\n107: export function generateWaveId(): string {\n108:   const now = new Date();\n109:   const date = now.toISOString().slice(0, 10);\n110:   const seq = String(now.getHours() * 60 + now.getMinutes()).padStart(3, \"0\");\n111:   return `wave-${date}-${seq}`;\n112: }\n113: \n114: // ---------------------------------------------------------------------------\n115: // State Path\n116: // ---------------------------------------------------------------------------\n117: \n118: function statePath(projectRoot: string): string {\n119:   return resolve(projectRoot, STATE_FILE);\n120: }\n121: \n122: // ---------------------------------------------------------------------------\n123: // Read State\n124: // ---------------------------------------------------------------------------\n125: \n126: /**\n127:  * Load the current wave state from disk. Returns null if no state file exists.\n128:  */\n129: export function loadState(projectRoot: string): WaveState | null {\n130:   const p = statePath(projectRoot);\n131:   if (!existsSync(p)) return null;\n132:   try {\n133:     const raw = readFileSync(p, \"utf-8\");\n134:     return JSON.parse(raw) as WaveState;\n135:   } catch {\n136:     return null;\n137:   }\n138: }\n139: \n140: // ---------------------------------------------------------------------------\n141: // Write State\n142: // ---------------------------------------------------------------------------\n143: \n144: /**\n145:  * Save wave state to disk atomically (write to tmp then rename).\n146:  */\n147: export function saveState(projectRoot: string, state: WaveState): void {\n148:   const dir = resolve(projectRoot, WOMBO_DIR);\n149:   if (!existsSync(dir)) mkdirSync(dir, { recursive: true });\n150:   state.updated_at = new Date().toISOString();\n151:   const p = statePath(projectRoot);\n152:   const tmp = p + \".tmp\";\n153:   writeFileSync(tmp, JSON.stringify(state, null, 2) + \"\\n\", \"utf-8\");\n154:   renameSync(tmp, p);\n155: }\n156: \n157: // ---------------------------------------------------------------------------\n158: // State Mutations\n159: // ---------------------------------------------------------------------------\n160: \n161: /**\n162:  * Create a fresh wave state.\n163:  */\n164: export function createWaveState(opts: {\n165:   baseBranch: string;\n166:   maxConcurrent: number;\n167:   model: string | null;\n168:   interactive: boolean;\n169: }): WaveState {\n170:   return {\n171:     wave_id: generateWaveId(),\n172:     base_branch: opts.baseBranch,\n173:     started_at: new Date().toISOString(),\n174:     updated_at: new Date().toISOString(),\n175:     max_concurrent: opts.maxConcurrent,\n176:     model: opts.model,\n177:     interactive: opts.interactive,\n178:     agents: [],\n179:     schedule_plan: null,\n180:   };\n181: }\n182: \n183: /**\n184:  * Create an initial agent state for a feature.\n185:  */\n186: export function createAgentState(\n187:   featureId: string,\n188:   branch: string,\n189:   worktreePath: string,\n190:   maxRetries: number = 2\n191: ): AgentState {\n192:   return {\n193:     feature_id: featureId,\n194:     branch,\n195:     worktree: worktreePath,\n196:     session_id: null,\n197:     pid: null,\n198:     status: \"queued\",\n199:     activity: null,\n200:     activity_updated_at: null,\n201:     retries: 0,\n202:     max_retries: maxRetries,\n203:     started_at: null,\n204:     completed_at: null,\n205:     build_passed: null,\n206:     build_output: null,\n207:     error: null,\n208:     effort_estimate_ms: null,\n209:     stream_index: null,\n210:     depends_on: [],\n211:     depended_on_by: [],\n212:     agent_name: null,\n213:     agent_type: null,\n214:   };\n215: }\n216: \n217: /**\n218:  * Find an agent state by feature ID.\n219:  */\n220: export function getAgent(\n221:   state: WaveState,\n222:   featureId: string\n223: ): AgentState | undefined {\n224:   return state.agents.find((a) => a.feature_id === featureId);\n225: }\n226: \n227: /**\n228:  * Update an agent's state fields.\n229:  */\n230: export function updateAgent(\n231:   state: WaveState,\n232:   featureId: string,\n233:   updates: Partial<AgentState>\n234: ): void {\n235:   const agent = state.agents.find((a) => a.feature_id === featureId);\n236:   if (!agent) throw new Error(`Agent not found for feature: ${featureId}`);\n237:   Object.assign(agent, updates);\n238: }\n239: \n240: /**\n241:  * Get counts of agents by status.\n242:  */\n243: export function agentCounts(state: WaveState): Record<AgentStatus, number> {\n244:   const counts: Record<AgentStatus, number> = {\n245:     queued: 0,\n246:     installing: 0,\n247:     running: 0,\n248:     completed: 0,\n249:     verified: 0,\n250:     failed: 0,\n251:     merged: 0,\n252:     retry: 0,\n253:     resolving_conflict: 0,\n254:   };\n255:   for (const a of state.agents) {\n256:     counts[a.status]++;\n257:   }\n258:   return counts;\n259: }\n260: \n261: /**\n262:  * Get agents that are currently running or installing.\n263:  */\n264: export function activeAgents(state: WaveState): AgentState[] {\n265:   return state.agents.filter(\n266:     (a) => a.status === \"running\" || a.status === \"installing\" || a.status === \"resolving_conflict\"\n267:   );\n268: }\n269: \n270: /**\n271:  * Get agents that are queued and ready to be launched.\n272:  */\n273: export function queuedAgents(state: WaveState): AgentState[] {\n274:   return state.agents.filter((a) => a.status === \"queued\");\n275: }\n276: \n277: /**\n278:  * Check if the wave is fully complete (no queued, installing, running, or retry agents).\n279:  */\n280: export function isWaveComplete(state: WaveState): boolean {\n281:   return state.agents.every(\n282:     (a) =>\n283:       a.status === \"completed\" ||\n284:       a.status === \"verified\" ||\n285:       a.status === \"failed\" ||\n286:       a.status === \"merged\"\n287:   );\n288: }\n289: \n290: // ---------------------------------------------------------------------------\n291: // Dependency-Aware Helpers\n292: // ---------------------------------------------------------------------------\n293: \n294: /**\n295:  * Terminal statuses that count as \"dependency satisfied\" for downstream features.\n296:  * A dependency is satisfied when it has been verified or merged.\n297:  */\n298: const DEP_SATISFIED_STATUSES: Set<AgentStatus> = new Set([\"verified\", \"merged\"]);\n299: \n300: /**\n301:  * Check if an agent's dependencies within the wave are all satisfied.\n302:  * Dependencies are satisfied when their agents reach \"verified\" or \"merged\" status.\n303:  *\n304:  * If the agent has no depends_on entries, it's always ready.\n305:  */\n306: export function areAgentDepsReady(\n307:   state: WaveState,\n308:   agent: AgentState\n309: ): boolean {\n310:   if (agent.depends_on.length === 0) return true;\n311: \n312:   for (const depId of agent.depends_on) {\n313:     const depAgent = state.agents.find((a) => a.feature_id === depId);\n314:     if (depAgent && !DEP_SATISFIED_STATUSES.has(depAgent.status)) {\n315:       return false;\n316:     }\n317:     // If depAgent doesn't exist in this wave, the dep is external — assumed satisfied\n318:   }\n319:   return true;\n320: }\n321: \n322: /**\n323:  * Get queued agents whose dependencies are all satisfied.\n324:  * This is the dependency-aware replacement for plain queuedAgents().\n325:  */\n326: export function readyToLaunchAgents(state: WaveState): AgentState[] {\n327:   return state.agents.filter(\n328:     (a) => a.status === \"queued\" && areAgentDepsReady(state, a)\n329:   );\n330: }\n331: \n332: /**\n333:  * Get all agents that are downstream (depend on) a given feature, directly or transitively.\n334:  * Used for failure cascading — when a feature fails, cancel all downstream.\n335:  */\n336: export function getDownstreamAgents(\n337:   state: WaveState,\n338:   featureId: string\n339: ): AgentState[] {\n340:   const visited = new Set<string>();\n341:   const result: AgentState[] = [];\n342: \n343:   function collect(id: string): void {\n344:     const agent = state.agents.find((a) => a.feature_id === id);\n345:     if (!agent) return;\n346: \n347:     for (const downstreamId of agent.depended_on_by) {\n348:       if (visited.has(downstreamId)) continue;\n349:       visited.add(downstreamId);\n350: \n351:       const downstream = state.agents.find((a) => a.feature_id === downstreamId);\n352:       if (downstream) {\n353:         result.push(downstream);\n354:         collect(downstreamId);\n355:       }\n356:     }\n357:   }\n358: \n359:   collect(featureId);\n360:   return result;\n361: }\n362: \n363: /**\n364:  * Cancel all downstream agents when an upstream dependency fails.\n365:  * Sets status to \"failed\" with an error explaining the dependency failure.\n366:  * Returns the list of cancelled agent IDs.\n367:  */\n368: export function cancelDownstream(\n369:   state: WaveState,\n370:   failedFeatureId: string\n371: ): string[] {\n372:   const downstream = getDownstreamAgents(state, failedFeatureId);\n373:   const cancelled: string[] = [];\n374: \n375:   for (const agent of downstream) {\n376:     // Only cancel agents that haven't already reached a terminal state\n377:     if (\n378:       agent.status === \"queued\" ||\n379:       agent.status === \"installing\" ||\n380:       agent.status === \"running\" ||\n381:       agent.status === \"retry\"\n382:     ) {\n383:       updateAgent(state, agent.feature_id, {\n384:         status: \"failed\",\n385:         error: `Dependency \"${failedFeatureId}\" failed — downstream cancelled`,\n386:         activity: null,\n387:         completed_at: new Date().toISOString(),\n388:       });\n389:       cancelled.push(agent.feature_id);\n390:     }\n391:   }\n392: \n393:   return cancelled;\n394: }\n\n(End of file - total 394 lines)\n</content>","title":"src/lib/state.ts","metadata":{"preview":"/**\n * state.ts — Persistent wave state management.\n *\n * Responsibilities:\n *   - Define the shape of .wombo-combo/state.json\n *   - Read/write state atomically\n *   - Generate wave IDs\n *   - Update individual agent state within a wave\n */\n\nimport { readFileSync, writeFileSync, existsSync, renameSync, mkdirSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\nimport { WOMBO_DIR } from \"../config.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type AgentStatus =\n  | \"queued\"","truncated":false,"loaded":[]},"time":{"start":1773435851027,"end":1773435851040}}}}
