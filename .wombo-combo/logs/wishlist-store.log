{"type":"tool_use","timestamp":1773483373145,"sessionID":"ses_314277a64ffetLdnasYv2hEYs1","part":{"id":"prt_cebd8b091001BU0Tej1Ci5vU6Z","sessionID":"ses_314277a64ffetLdnasYv2hEYs1","messageID":"msg_cebd8a43f0019N754kJ3WCCsLV","type":"tool","callID":"toolu_vrtx_01VKT8b1THFj63BgzqRZeBHb","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/wishlist-store/src/lib/tasks.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/wishlist-store/src/lib/tasks.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tasks.ts -- Parse tasks YAML and provide task selection/filtering.\n3:  *\n4:  * Responsibilities:\n5:  *   - Load and parse the tasks file with full type safety\n6:  *   - Load and parse the archive file separately\n7:  *   - Parse ISO 8601 durations into comparable minutes\n8:  *   - Filter tasks by status, priority, difficulty, dependency readiness\n9:  *   - Select tasks by various strategies (top-priority, quickest-wins, etc.)\n10:  *   - Resolve dependency graphs to determine which tasks are ready to start\n11:  *   - Write-back capability for task management commands\n12:  */\n13: \n14: import { existsSync, mkdirSync } from \"node:fs\";\n15: import { resolve, dirname, join } from \"node:path\";\n16: import { createInterface } from \"node:readline\";\n17: import type { WomboConfig } from \"../config.js\";\n18: import { WOMBO_DIR } from \"../config.js\";\n19: import {\n20:   loadTasksFromStore,\n21:   loadArchiveFromStore,\n22:   saveAllTasksToStore,\n23:   saveAllArchiveToStore,\n24:   saveTaskToStore,\n25:   saveTaskToArchive,\n26:   removeTaskFromStore,\n27:   tasksStoreExists,\n28:   saveTasksMetaToStore,\n29:   saveArchiveMetaToStore,\n30:   getTasksDir,\n31:   getArchiveDir,\n32:   saveTaskFile,\n33:   deleteTaskFile,\n34: } from \"./task-store.js\";\n35: \n36: // ---------------------------------------------------------------------------\n37: // Template path (resolved relative to this source file)\n38: // ---------------------------------------------------------------------------\n39: \n40: export const META_TEMPLATE_PATH = join(dirname(import.meta.dir), \"templates\", \"_meta.yml\");\n41: /** @deprecated Use META_TEMPLATE_PATH — the old monolithic template no longer exists. */\n42: export const TASKS_TEMPLATE_PATH = META_TEMPLATE_PATH;\n43: \n44: // ---------------------------------------------------------------------------\n45: // Types\n46: // ---------------------------------------------------------------------------\n47: \n48: export type TaskStatus =\n49:   | \"backlog\"\n50:   | \"planned\"\n51:   | \"in_progress\"\n52:   | \"blocked\"\n53:   | \"in_review\"\n54:   | \"done\"\n55:   | \"cancelled\";\n56: \n57: export type Priority = \"critical\" | \"high\" | \"medium\" | \"low\" | \"wishlist\";\n58: \n59: export type Difficulty = \"trivial\" | \"easy\" | \"medium\" | \"hard\" | \"very_hard\";\n60: \n61: /**\n62:  * Unified task type. Previously split into Feature and Subtask, but the shapes\n63:  * are identical so there is no reason to maintain two names.\n64:  */\n65: export interface Task {\n66:   id: string;\n67:   title: string;\n68:   description: string;\n69:   status: TaskStatus;\n70:   completion: number;\n71:   difficulty: Difficulty;\n72:   priority: Priority;\n73:   depends_on: string[];\n74:   effort: string;\n75:   started_at: string | null;\n76:   ended_at: string | null;\n77:   constraints: string[];\n78:   forbidden: string[];\n79:   references: string[];\n80:   notes: string[];\n81:   subtasks: Task[];\n82:   /**\n83:    * Optional agent type from an external registry (e.g. agency-agents).\n84:    * Format: \"category/agent-name\" (e.g. \"engineering/engineering-frontend-developer\").\n85:    * When set, wombo downloads and patches the specified agent definition\n86:    * instead of using the default generalist agent.\n87:    */\n88:   agent_type?: string;\n89:   /**\n90:    * Optional local agent definition file name (without extension).\n91:    * References a file in `.opencode/agents/<agent>.md`.\n92:    * When omitted, defaults to the config's `agent.name` (typically \"generalist-agent\").\n93:    * This is independent of `agent_type` which references external registry agents.\n94:    */\n95:   agent?: string;\n96: }\n97: \n98: /**\n99:  * Shape of tasks.yml (active tasks).\n100:  */\n101: export interface TasksFile {\n102:   version: string;\n103:   meta: {\n104:     created_at: string;\n105:     updated_at: string;\n106:     project: string;\n107:     generator: string;\n108:     maintainer: string;\n109:   };\n110:   tasks: Task[];\n111: }\n112: \n113: /**\n114:  * Shape of archive.yml (archived tasks). Same structure as TasksFile.\n115:  */\n116: export type ArchiveFile = TasksFile;\n117: \n118: // Backward-compat aliases (ease migration in consuming code)\n119: export type Feature = Task;\n120: export type Subtask = Task;\n121: export type FeatureStatus = TaskStatus;\n122: export type FeaturesFile = TasksFile & { archive: Task[] };\n123: \n124: // Re-export ordering maps from the canonical source (task-schema.ts)\n125: import { PRIORITY_ORDER, DIFFICULTY_ORDER } from \"./task-schema.js\";\n126: export { PRIORITY_ORDER, DIFFICULTY_ORDER };\n127: \n128: // ---------------------------------------------------------------------------\n129: // ISO 8601 Duration Parser\n130: // ---------------------------------------------------------------------------\n131: \n132: /**\n133:  * Parse an ISO 8601 duration string into total minutes.\n134:  * Supports: P[nY][nM][nD][T[nH][nM][nS]]\n135:  * Examples: PT1H -> 60, PT30M -> 30, P1D -> 1440, P2DT4H -> 3360, PT1H30M -> 90\n136:  *           P1Y -> 525600, P2M -> 86400\n137:  * Year/month approximations: 1Y = 365D, 1M = 30D\n138:  */\n139: export function parseDurationMinutes(iso: string): number {\n140:   const match = iso.match(\n141:     /^P(?:(\\d+)Y)?(?:(\\d+)M)?(?:(\\d+)D)?(?:T(?:(\\d+)H)?(?:(\\d+)M)?(?:(\\d+)S)?)?$/\n142:   );\n143:   if (!match) return Infinity; // unparseable -> sort to end\n144:   const years = parseInt(match[1] || \"0\", 10);\n145:   const months = parseInt(match[2] || \"0\", 10);\n146:   const days = parseInt(match[3] || \"0\", 10);\n147:   const hours = parseInt(match[4] || \"0\", 10);\n148:   const minutes = parseInt(match[5] || \"0\", 10);\n149:   const seconds = parseInt(match[6] || \"0\", 10);\n150:   const totalDays = years * 365 + months * 30 + days;\n151:   return totalDays * 24 * 60 + hours * 60 + minutes + Math.ceil(seconds / 60);\n152: }\n153: \n154: /**\n155:  * Format minutes into a human-readable string.\n156:  */\n157: export function formatDuration(minutes: number): string {\n158:   if (minutes === Infinity) return \"unknown\";\n159:   if (minutes < 60) return `${minutes}m`;\n160:   const h = Math.floor(minutes / 60);\n161:   const m = minutes % 60;\n162:   if (h >= 24) {\n163:     const d = Math.floor(h / 24);\n164:     const rh = h % 24;\n165:     if (rh === 0 && m === 0) return `${d}d`;\n166:     if (m === 0) return `${d}d ${rh}h`;\n167:     return `${d}d ${rh}h ${m}m`;\n168:   }\n169:   return m === 0 ? `${h}h` : `${h}h ${m}m`;\n170: }\n171: \n172: // ---------------------------------------------------------------------------\n173: // .wombo-combo directory helpers\n174: // ---------------------------------------------------------------------------\n175: \n176: /**\n177:  * Ensure the .wombo-combo directory exists.\n178:  */\n179: export function ensureWomboDir(projectRoot: string): string {\n180:   const dir = resolve(projectRoot, WOMBO_DIR);\n181:   if (!existsSync(dir)) {\n182:     mkdirSync(dir, { recursive: true });\n183:   }\n184:   return dir;\n185: }\n186: \n187: /**\n188:  * Resolve a file path within the .wombo-combo directory.\n189:  */\n190: function womboPath(projectRoot: string, filename: string): string {\n191:   return resolve(projectRoot, WOMBO_DIR, filename);\n192: }\n193: \n194: // ---------------------------------------------------------------------------\n195: // Tasks File Existence Guard\n196: // ---------------------------------------------------------------------------\n197: \n198: /**\n199:  * Prompt the user with a yes/no question via stdin.\n200:  */\n201: function promptYesNo(question: string): Promise<boolean> {\n202:   const rl = createInterface({ input: process.stdin, output: process.stdout });\n203:   return new Promise((resolve) => {\n204:     rl.question(question, (answer) => {\n205:       rl.close();\n206:       resolve(answer.trim().toLowerCase().startsWith(\"y\"));\n207:     });\n208:   });\n209: }\n210: \n211: /**\n212:  * Ensure the tasks store exists before any command that needs it.\n213:  * If the folder is missing, prompt the user to generate one from scratch\n214:  * or auto-migrate from a legacy single-file tasks.yml.\n215:  */\n216: export async function ensureTasksFile(\n217:   projectRoot: string,\n218:   config: WomboConfig\n219: ): Promise<void> {\n220:   if (tasksStoreExists(projectRoot, config)) return;\n221: \n222:   // Try loading — this triggers auto-migration from legacy files\n223:   const data = loadTasksFromStore(projectRoot, config);\n224:   if (data.tasks.length > 0 || tasksStoreExists(projectRoot, config)) return;\n225: \n226:   console.log(`\\nTasks store not found: ${WOMBO_DIR}/${config.tasksDir}/`);\n227: \n228:   const generate = await promptYesNo(\n229:     \"Generate a new tasks store from template? (y/N): \"\n230:   );\n231: \n232:   if (!generate) {\n233:     console.error(\n234:       `Cannot proceed without a tasks store. Create one manually or run again and accept the prompt.`\n235:     );\n236:     process.exit(1);\n237:   }\n238: \n239:   // Ensure .wombo-combo/ directory exists\n240:   ensureWomboDir(projectRoot);\n241: \n242:   const now = new Date().toISOString();\n243:   saveTasksMetaToStore(projectRoot, config, {\n244:     version: \"1.0\",\n245:     meta: {\n246:       created_at: now,\n247:       updated_at: now,\n248:       project: \"unknown\",\n249:       generator: \"wombo-combo\",\n250:       maintainer: \"unknown\",\n251:     },\n252:   });\n253:   console.log(`Created ${WOMBO_DIR}/${config.tasksDir}/ with empty task store.\\n`);\n254: \n255:   // Also create empty archive store\n256:   saveArchiveMetaToStore(projectRoot, config, {\n257:     version: \"1.0\",\n258:     meta: {\n259:       created_at: now,\n260:       updated_at: now,\n261:       project: \"unknown\",\n262:       generator: \"wombo-combo\",\n263:       maintainer: \"unknown\",\n264:     },\n265:   });\n266:   console.log(`Created ${WOMBO_DIR}/${config.archiveDir}/.\\n`);\n267: }\n268: \n269: // Backward-compat alias\n270: export const ensureFeaturesFile = ensureTasksFile;\n271: \n272: // ---------------------------------------------------------------------------\n273: // Loader\n274: // ---------------------------------------------------------------------------\n275: \n276: /**\n277:  * Load and parse tasks from the folder-based store.\n278:  */\n279: export function loadTasks(\n280:   projectRoot: string,\n281:   config: WomboConfig\n282: ): TasksFile {\n283:   return loadTasksFromStore(projectRoot, config);\n284: }\n285: \n286: /**\n287:  * Load archived tasks from the folder-based store.\n288:  * Returns an empty ArchiveFile if the store doesn't exist.\n289:  */\n290: export function loadArchive(\n291:   projectRoot: string,\n292:   config: WomboConfig\n293: ): ArchiveFile {\n294:   return loadArchiveFromStore(projectRoot, config);\n295: }\n296: \n297: /**\n298:  * Backward-compat: load tasks + archive merged into a single FeaturesFile shape.\n299:  * This eases migration — callers that used loadFeatures() keep working.\n300:  */\n301: export function loadFeatures(\n302:   projectRoot: string,\n303:   config: WomboConfig\n304: ): FeaturesFile {\n305:   const tasksData = loadTasks(projectRoot, config);\n306:   const archiveData = loadArchive(projectRoot, config);\n307:   return {\n308:     ...tasksData,\n309:     // Map \"tasks\" to \"features\" for backward compat (FeaturesFile has .features)\n310:     // Actually FeaturesFile extends TasksFile which has .tasks, but add .archive\n311:     archive: archiveData.tasks,\n312:   };\n313: }\n314: \n315: // ---------------------------------------------------------------------------\n316: // Writer\n317: // ---------------------------------------------------------------------------\n318: \n319: /**\n320:  * Save all tasks to the folder-based store.\n321:  * Writes _meta.yml + one file per task.\n322:  */\n323: export function saveTasks(\n324:   projectRoot: string,\n325:   config: WomboConfig,\n326:   data: TasksFile\n327: ): void {\n328:   saveAllTasksToStore(projectRoot, config, data);\n329: }\n330: \n331: /**\n332:  * Save all archived tasks to the folder-based store.\n333:  */\n334: export function saveArchive(\n335:   projectRoot: string,\n336:   config: WomboConfig,\n337:   data: ArchiveFile\n338: ): void {\n339:   saveAllArchiveToStore(projectRoot, config, data);\n340: }\n341: \n342: /**\n343:  * Backward-compat: save a FeaturesFile (tasks + archive in one object).\n344:  * Splits and writes to both tasks.yml and archive.yml.\n345:  */\n346: export function saveFeatures(\n347:   projectRoot: string,\n348:   config: WomboConfig,\n349:   data: FeaturesFile\n350: ): void {\n351:   const tasksData: TasksFile = {\n352:     version: data.version,\n353:     meta: { ...data.meta },\n354:     tasks: data.tasks,\n355:   };\n356:   saveTasks(projectRoot, config, tasksData);\n357: \n358:   if (data.archive && data.archive.length > 0) {\n359:     const archiveData: ArchiveFile = {\n360:       version: data.version,\n361:       meta: { ...data.meta },\n362:       tasks: data.archive,\n363:     };\n364:     saveArchive(projectRoot, config, archiveData);\n365:   }\n366: }\n367: \n368: \n369: // ---------------------------------------------------------------------------\n370: // Dependency Resolution\n371: // ---------------------------------------------------------------------------\n372: \n373: /**\n374:  * Get all task IDs that are done (status === \"done\" or completion === 100).\n375:  */\n376: function getDoneIds(tasks: Task[], archive: Task[]): Set<string> {\n377:   const done = new Set<string>();\n378:   const collectDone = (items: Task[]) => {\n379:     for (const item of items) {\n380:       if (item.status === \"done\" || item.completion === 100) {\n381:         done.add(item.id);\n382:       }\n383:       if (item.subtasks?.length) {\n384:         collectDone(item.subtasks);\n385:       }\n386:     }\n387:   };\n388:   collectDone(tasks);\n389:   collectDone(archive);\n390:   return done;\n391: }\n392: \n393: /**\n394:  * Check if a task's dependencies are all satisfied.\n395:  */\n396: export function areDependenciesMet(\n397:   task: Task,\n398:   doneIds: Set<string>\n399: ): boolean {\n400:   return task.depends_on.every((dep) => doneIds.has(dep));\n401: }\n402: \n403: /**\n404:  * Get all tasks that are ready to start (backlog + deps met).\n405:  */\n406: export function getReadyTasks(data: TasksFile, archive?: Task[]): Task[] {\n407:   const doneIds = getDoneIds(data.tasks, archive ?? []);\n408:   return data.tasks.filter(\n409:     (t) =>\n410:       t.status === \"backlog\" &&\n411:       areDependenciesMet(t, doneIds)\n412:   );\n413: }\n414: \n415: /**\n416:  * Get done IDs (exported for use in selection error messages).\n417:  */\n418: export function getDoneTaskIds(data: TasksFile, archive?: Task[]): Set<string> {\n419:   return getDoneIds(data.tasks, archive ?? []);\n420: }\n421: \n422: // Backward-compat aliases\n423: export function getReadyFeatures(data: FeaturesFile): Task[] {\n424:   return getReadyTasks(data, data.archive);\n425: }\n426: \n427: export function getDoneFeatureIds(data: FeaturesFile): Set<string> {\n428:   return getDoneTaskIds(data, data.archive);\n429: }\n430: \n431: // ---------------------------------------------------------------------------\n432: // Selection Strategies\n433: // ---------------------------------------------------------------------------\n434: \n435: export interface SelectionOptions {\n436:   /** Select top N by priority (highest priority first, then lowest effort) */\n437:   topPriority?: number;\n438:   /** Select N quickest wins (lowest effort first) */\n439:   quickestWins?: number;\n440:   /** Select all tasks matching this priority level */\n441:   priority?: Priority;\n442:   /** Select all tasks matching this difficulty level */\n443:   difficulty?: Difficulty;\n444:   /** Select specific task IDs (comma-separated) */\n445:   taskIds?: string[];\n446:   /** Select all ready tasks */\n447:   allReady?: boolean;\n448: }\n449: \n450: /**\n451:  * Select tasks based on the given strategy.\n452:  * Always filters to only ready tasks (backlog + deps met) first.\n453:  */\n454: export function selectTasks(\n455:   data: TasksFile,\n456:   options: SelectionOptions,\n457:   archive?: Task[]\n458: ): Task[] {\n459:   const ready = getReadyTasks(data, archive);\n460: \n461:   if (options.allReady) {\n462:     return sortByPriorityThenEffort(ready);\n463:   }\n464: \n465:   if (options.taskIds?.length) {\n466:     const idSet = new Set(options.taskIds);\n467:     const selected = ready.filter((t) => idSet.has(t.id));\n468:     const missing = options.taskIds.filter(\n469:       (id) => !selected.find((t) => t.id === id)\n470:     );\n471:     if (missing.length) {\n472:       const allIds = data.tasks.map((t) => t.id);\n473:       const doneIds = getDoneIds(data.tasks, archive ?? []);\n474:       for (const m of missing) {\n475:         if (!allIds.includes(m)) {\n476:           console.error(`  Task \"${m}\" does not exist in the tasks file`);\n477:         } else {\n478:           const task = data.tasks.find((t) => t.id === m)!;\n479:           console.error(\n480:             `  Task \"${m}\" is not ready (status: ${task.status}, deps met: ${areDependenciesMet(task, doneIds)})`\n481:           );\n482:         }\n483:       }\n484:     }\n485:     return sortByPriorityThenEffort(selected);\n486:   }\n487: \n488:   if (options.priority) {\n489:     return sortByPriorityThenEffort(\n490:       ready.filter((t) => t.priority === options.priority)\n491:     );\n492:   }\n493: \n494:   if (options.difficulty) {\n495:     return sortByEffort(ready.filter((t) => t.difficulty === options.difficulty));\n496:   }\n497: \n498:   if (options.topPriority) {\n499:     return sortByPriorityThenEffort(ready).slice(0, options.topPriority);\n500:   }\n501: \n502:   if (options.quickestWins) {\n503:     return sortByEffort(ready).slice(0, options.quickestWins);\n504:   }\n505: \n506:   // Default: return all ready, sorted by priority\n507:   return sortByPriorityThenEffort(ready);\n508: }\n509: \n510: // Backward-compat alias\n511: export function selectFeatures(\n512:   data: FeaturesFile,\n513:   options: SelectionOptions & { featureIds?: string[] }\n514: ): Task[] {\n515:   // Map featureIds -> taskIds for backward compat\n516:   const opts: SelectionOptions = {\n517:     ...options,\n518:     taskIds: options.taskIds ?? options.featureIds,\n519:   };\n520:   return selectTasks(data, opts, data.archive);\n521: }\n522: \n523: // ---------------------------------------------------------------------------\n524: // Sorting Helpers\n525: // ---------------------------------------------------------------------------\n526: \n527: function sortByPriorityThenEffort(tasks: Task[]): Task[] {\n528:   return [...tasks].sort((a, b) => {\n529:     const pDiff = PRIORITY_ORDER[a.priority] - PRIORITY_ORDER[b.priority];\n530:     if (pDiff !== 0) return pDiff;\n531:     return parseDurationMinutes(a.effort) - parseDurationMinutes(b.effort);\n532:   });\n533: }\n534: \n535: function sortByEffort(tasks: Task[]): Task[] {\n536:   return [...tasks].sort(\n537:     (a, b) => parseDurationMinutes(a.effort) - parseDurationMinutes(b.effort)\n538:   );\n539: }\n540: \n541: // ---------------------------------------------------------------------------\n542: // Utility Exports\n543: // ---------------------------------------------------------------------------\n544: \n545: /**\n546:  * Get a compact summary of a task for display.\n547:  */\n548: export function taskSummary(t: Task): string {\n549:   const effort = formatDuration(parseDurationMinutes(t.effort));\n550:   return `[${t.priority}/${t.difficulty}] ${t.id} -- ${t.title} (${effort})`;\n551: }\n552: \n553: // Backward-compat alias\n554: export const featureSummary = taskSummary;\n555: \n556: /**\n557:  * Recursively search a list of tasks (and their subtasks) for a matching ID.\n558:  */\n559: function findInList(tasks: Task[], id: string): Task | undefined {\n560:   for (const t of tasks) {\n561:     if (t.id === id) return t;\n562:     if (t.subtasks?.length) {\n563:       const found = findInList(t.subtasks, id);\n564:       if (found) return found;\n565:     }\n566:   }\n567:   return undefined;\n568: }\n569: \n570: /**\n571:  * Find a task by ID across active tasks, their subtasks\n572:  * (recursively), and the archive list.\n573:  */\n574: export function findTaskById(\n575:   data: TasksFile,\n576:   id: string,\n577:   archive?: Task[]\n578: ): Task | undefined {\n579:   return (\n580:     findInList(data.tasks, id) ??\n581:     (archive ? findInList(archive, id) : undefined)\n582:   );\n583: }\n584: \n585: // Backward-compat alias\n586: export function findFeatureById(\n587:   data: FeaturesFile,\n588:   id: string\n589: ): Task | undefined {\n590:   return findTaskById(data, id, data.archive);\n591: }\n592: \n593: /**\n594:  * Create a blank task with all required fields initialized.\n595:  */\n596: export function createBlankTask(\n597:   id: string,\n598:   title: string,\n599:   description: string = \"\",\n600:   opts?: {\n601:     priority?: Priority;\n602:     difficulty?: Difficulty;\n603:     effort?: string;\n604:   }\n605: ): Task {\n606:   return {\n607:     id,\n608:     title,\n609:     description,\n610:     status: \"backlog\",\n611:     completion: 0,\n612:     difficulty: opts?.difficulty ?? \"medium\",\n613:     priority: opts?.priority ?? \"medium\",\n614:     depends_on: [],\n615:     effort: opts?.effort ?? \"PT1H\",\n616:     started_at: null,\n617:     ended_at: null,\n618:     constraints: [],\n619:     forbidden: [],\n620:     references: [],\n621:     notes: [],\n622:     subtasks: [],\n623:   };\n624: }\n625: \n626: // Backward-compat alias\n627: export const createBlankFeature = createBlankTask;\n628: \n629: /**\n630:  * Get all task IDs (active + archive), useful for validation.\n631:  */\n632: export function allTaskIds(data: TasksFile, archive?: Task[]): string[] {\n633:   const ids: string[] = [];\n634:   const collect = (items: Task[]) => {\n635:     for (const item of items) {\n636:       ids.push(item.id);\n637:       if (item.subtasks?.length) collect(item.subtasks);\n638:     }\n639:   };\n640:   collect(data.tasks);\n641:   collect(archive ?? []);\n642:   return ids;\n643: }\n644: \n645: // Backward-compat alias\n646: export function allFeatureIds(data: FeaturesFile): string[] {\n647:   return allTaskIds(data, data.archive);\n648: }\n649: \n650: // Re-export the old template path name for migration\n651: export const FEATURES_TEMPLATE_PATH = TASKS_TEMPLATE_PATH;\n652: \n653: // Re-export store functions for single-task operations\n654: export {\n655:   saveTaskToStore,\n656:   saveTaskToArchive,\n657:   removeTaskFromStore,\n658:   getTasksDir,\n659:   getArchiveDir,\n660: } from \"./task-store.js\";\n\n(End of file - total 660 lines)\n</content>","title":"src/lib/tasks.ts","metadata":{"preview":"/**\n * tasks.ts -- Parse tasks YAML and provide task selection/filtering.\n *\n * Responsibilities:\n *   - Load and parse the tasks file with full type safety\n *   - Load and parse the archive file separately\n *   - Parse ISO 8601 durations into comparable minutes\n *   - Filter tasks by status, priority, difficulty, dependency readiness\n *   - Select tasks by various strategies (top-priority, quickest-wins, etc.)\n *   - Resolve dependency graphs to determine which tasks are ready to start\n *   - Write-back capability for task management commands\n */\n\nimport { existsSync, mkdirSync } from \"node:fs\";\nimport { resolve, dirname, join } from \"node:path\";\nimport { createInterface } from \"node:readline\";\nimport type { WomboConfig } from \"../config.js\";\nimport { WOMBO_DIR } from \"../config.js\";\nimport {\n  loadTasksFromStore,","truncated":false,"loaded":[]},"time":{"start":1773483373132,"end":1773483373143}}}}
