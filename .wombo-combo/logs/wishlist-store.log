{"type":"tool_use","timestamp":1773481778002,"sessionID":"ses_314408b3affedlAR2t7y2tf3to","part":{"id":"prt_cebbfe8b0001ZNnNSRbidJBb65","sessionID":"ses_314408b3affedlAR2t7y2tf3to","messageID":"msg_cebbfd9fe001bvtpiSmik3D7th","type":"tool","callID":"toolu_vrtx_0172pGkzmgorGxmNe3FEReUu","tool":"write","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/wishlist-store/src/lib/wishlist-store.ts","content":"/**\n * wishlist-store.ts — Flat YAML-based wishlist storage.\n *\n * Storage: .wombo-combo/wishlist.yml\n * Format: A flat YAML array of WishlistItem objects.\n *\n * Provides simple CRUD operations:\n *   - loadWishlist()  — Load all items from the YAML file\n *   - addItem()       — Add a new item with auto-generated ID\n *   - deleteItem()    — Remove an item by ID\n *   - listItems()     — Return all items (alias for loadWishlist)\n */\n\nimport {\n  readFileSync,\n  writeFileSync,\n  existsSync,\n  mkdirSync,\n  renameSync,\n} from \"node:fs\";\nimport { resolve, dirname } from \"node:path\";\nimport { parse as parseYaml, stringify as stringifyYaml } from \"yaml\";\nimport { WOMBO_DIR } from \"../config.js\";\nimport { randomUUID } from \"node:crypto\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\n/**\n * A single wishlist item.\n */\nexport interface WishlistItem {\n  /** Unique identifier (UUID v4) */\n  id: string;\n  /** Description of the wishlist item */\n  text: string;\n  /** ISO 8601 timestamp of when the item was created */\n  created_at: string;\n  /** Optional tags for categorization */\n  tags: string[];\n}\n\n// ---------------------------------------------------------------------------\n// Constants\n// ---------------------------------------------------------------------------\n\n/** Filename for the wishlist store inside .wombo-combo/ */\nconst WISHLIST_FILE = \"wishlist.yml\";\n\nconst YAML_OPTS = {\n  lineWidth: 120,\n  defaultKeyType: \"PLAIN\" as const,\n  defaultStringType: \"PLAIN\" as const,\n};\n\n// ---------------------------------------------------------------------------\n// Path helpers\n// ---------------------------------------------------------------------------\n\n/**\n * Resolve the full path to the wishlist YAML file.\n */\nfunction wishlistPath(projectRoot: string): string {\n  return resolve(projectRoot, WOMBO_DIR, WISHLIST_FILE);\n}\n\n// ---------------------------------------------------------------------------\n// Internal helpers\n// ---------------------------------------------------------------------------\n\nfunction ensureDir(dir: string): void {\n  if (!existsSync(dir)) {\n    mkdirSync(dir, { recursive: true });\n  }\n}\n\nfunction atomicWrite(filePath: string, content: string): void {\n  const tmp = filePath + \".tmp\";\n  writeFileSync(tmp, content, \"utf-8\");\n  renameSync(tmp, filePath);\n}\n\n/**\n * Normalize a parsed item to ensure all fields are present.\n */\nfunction normalizeItem(item: Partial<WishlistItem>): WishlistItem {\n  return {\n    id: item.id ?? randomUUID(),\n    text: item.text ?? \"\",\n    created_at: item.created_at ?? new Date().toISOString(),\n    tags: item.tags ?? [],\n  };\n}\n\n// ---------------------------------------------------------------------------\n// Public API — Load\n// ---------------------------------------------------------------------------\n\n/**\n * Load all wishlist items from .wombo-combo/wishlist.yml.\n * Returns an empty array if the file does not exist or is empty.\n */\nexport function loadWishlist(projectRoot: string): WishlistItem[] {\n  const filePath = wishlistPath(projectRoot);\n  if (!existsSync(filePath)) return [];\n\n  try {\n    const raw = readFileSync(filePath, \"utf-8\");\n    const parsed = parseYaml(raw);\n\n    // YAML parses empty files / `null` as null\n    if (!parsed) return [];\n    if (!Array.isArray(parsed)) {\n      console.error(`wishlist.yml: expected a YAML array, got ${typeof parsed}`);\n      return [];\n    }\n\n    return parsed.map((item: unknown) => normalizeItem(item as Partial<WishlistItem>));\n  } catch (err: unknown) {\n    const reason = err instanceof Error ? err.message : String(err);\n    console.error(`Failed to parse ${WISHLIST_FILE}: ${reason}`);\n    return [];\n  }\n}\n\n// ---------------------------------------------------------------------------\n// Public API — Save (internal, used by mutating operations)\n// ---------------------------------------------------------------------------\n\n/**\n * Save the full wishlist array to .wombo-combo/wishlist.yml.\n */\nfunction saveWishlist(projectRoot: string, items: WishlistItem[]): void {\n  const filePath = wishlistPath(projectRoot);\n  ensureDir(dirname(filePath));\n\n  const yaml = stringifyYaml(items, YAML_OPTS);\n  atomicWrite(filePath, yaml);\n}\n\n// ---------------------------------------------------------------------------\n// Public API — CRUD\n// ---------------------------------------------------------------------------\n\n/**\n * Add a new item to the wishlist.\n *\n * @param projectRoot — The project root directory.\n * @param text — Description of the wishlist item.\n * @param tags — Optional tags for categorization.\n * @returns The newly created WishlistItem.\n */\nexport function addItem(\n  projectRoot: string,\n  text: string,\n  tags: string[] = []\n): WishlistItem {\n  const items = loadWishlist(projectRoot);\n\n  const newItem: WishlistItem = {\n    id: randomUUID(),\n    text,\n    created_at: new Date().toISOString(),\n    tags,\n  };\n\n  items.push(newItem);\n  saveWishlist(projectRoot, items);\n  return newItem;\n}\n\n/**\n * Delete an item from the wishlist by ID.\n *\n * @param projectRoot — The project root directory.\n * @param id — The UUID of the item to delete.\n * @returns true if the item was found and removed, false otherwise.\n */\nexport function deleteItem(projectRoot: string, id: string): boolean {\n  const items = loadWishlist(projectRoot);\n  const index = items.findIndex((item) => item.id === id);\n\n  if (index === -1) return false;\n\n  items.splice(index, 1);\n  saveWishlist(projectRoot, items);\n  return true;\n}\n\n/**\n * List all items in the wishlist.\n * This is a convenience alias for loadWishlist().\n *\n * @param projectRoot — The project root directory.\n * @returns Array of all WishlistItem objects.\n */\nexport function listItems(projectRoot: string): WishlistItem[] {\n  return loadWishlist(projectRoot);\n}\n"},"output":"Wrote file successfully.","title":"src/lib/wishlist-store.ts","metadata":{"diagnostics":{"/home/fulgidus/Documents/wombo-combo-worktrees/wishlist-store/src/lib/quest-store.ts":[{"range":{"start":{"line":27,"character":24},"end":{"line":27,"character":32}},"message":"'basename' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"}],"/home/fulgidus/Documents/wombo-combo-worktrees/wishlist-store/src/lib/task-store.ts":[{"range":{"start":{"line":442,"character":9},"end":{"line":442,"character":21}},"message":"'createBackup' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"}],"/home/fulgidus/Documents/wombo-combo-worktrees/wishlist-store/src/lib/tasks.ts":[{"range":{"start":{"line":23,"character":2},"end":{"line":23,"character":17}},"message":"'saveTaskToStore' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"},{"range":{"start":{"line":24,"character":2},"end":{"line":24,"character":19}},"message":"'saveTaskToArchive' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"},{"range":{"start":{"line":25,"character":2},"end":{"line":25,"character":21}},"message":"'removeTaskFromStore' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"},{"range":{"start":{"line":29,"character":2},"end":{"line":29,"character":13}},"message":"'getTasksDir' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"},{"range":{"start":{"line":30,"character":2},"end":{"line":30,"character":15}},"message":"'getArchiveDir' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"},{"range":{"start":{"line":31,"character":2},"end":{"line":31,"character":14}},"message":"'saveTaskFile' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"},{"range":{"start":{"line":32,"character":2},"end":{"line":32,"character":16}},"message":"'deleteTaskFile' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"},{"range":{"start":{"line":189,"character":9},"end":{"line":189,"character":18}},"message":"'womboPath' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"},{"range":{"start":{"line":650,"character":38},"end":{"line":650,"character":57}},"message":"'TASKS_TEMPLATE_PATH' is deprecated.","severity":4,"code":6385,"source":"typescript","relatedInformation":[{"location":{"uri":"file:///home/fulgidus/Documents/wombo-combo-worktrees/wishlist-store/src/lib/tasks.ts","range":{"start":{"line":40,"character":4},"end":{"line":40,"character":87}}},"message":"The declaration was marked as deprecated here."}]}],"/home/fulgidus/Documents/wombo-combo-worktrees/wishlist-store/src/config.ts":[],"/home/fulgidus/Documents/wombo-combo-worktrees/wishlist-store/src/lib/wishlist-store.ts":[]},"filepath":"/home/fulgidus/Documents/wombo-combo-worktrees/wishlist-store/src/lib/wishlist-store.ts","exists":false,"truncated":false},"time":{"start":1773481774992,"end":1773481778001}}}}
