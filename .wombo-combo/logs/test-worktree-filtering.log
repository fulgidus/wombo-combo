{"type":"tool_use","timestamp":1773433289519,"sessionID":"ses_31723c227ffes6YQhTzXCb8Yyr","part":{"id":"prt_ce8dc7a4c0018h1BqslI2xzCN9","sessionID":"ses_31723c227ffes6YQhTzXCb8Yyr","messageID":"msg_ce8dc70ba0013nOB125zIh2fdR","type":"tool","callID":"toolu_vrtx_01QkHBMi2qnRUhSd8fzXuutY","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-test-worktree-filtering/tests/worktree.test.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-test-worktree-filtering/tests/worktree.test.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * worktree.test.ts — Unit tests for worktree listing, filtering, and safety guards.\n3:  *\n4:  * Critical coverage:\n5:  *   - listWomboWorktrees must use basename matching, NOT full-path .includes()\n6:  *   - removeWorktree must refuse to remove the project root\n7:  *   - cleanupAllWorktrees must never touch the project root\n8:  *   - The \"wombo-combo\" prefix collision bug (project dir name contains worktree prefix)\n9:  */\n10: \n11: import { describe, test, expect, mock, beforeEach, afterEach } from \"bun:test\";\n12: import { resolve, basename } from \"node:path\";\n13: import type { WomboConfig } from \"../src/config.js\";\n14: import type { WorktreeInfo } from \"../src/lib/worktree.js\";\n15: \n16: // ---------------------------------------------------------------------------\n17: // Helpers: minimal WomboConfig for testing\n18: // ---------------------------------------------------------------------------\n19: \n20: function makeConfig(overrides?: Partial<WomboConfig[\"git\"]>): WomboConfig {\n21:   return {\n22:     tasksDir: \"tasks\",\n23:     archiveDir: \"archive\",\n24:     baseBranch: \"main\",\n25:     build: { command: \"bun run build\", timeout: 300_000, artifactDir: \"dist\" },\n26:     install: { command: \"bun install\", timeout: 120_000 },\n27:     git: {\n28:       branchPrefix: \"feature/\",\n29:       worktreePrefix: \"wombo-\",\n30:       remote: \"origin\",\n31:       mergeStrategy: \"--no-ff\",\n32:       ...overrides,\n33:     },\n34:     agent: {\n35:       bin: null,\n36:       name: \"generalist-agent\",\n37:       configFiles: [],\n38:       tmuxPrefix: \"wombo\",\n39:       multiplexer: \"auto\",\n40:     },\n41:     portless: {\n42:       enabled: true,\n43:       bin: null,\n44:       proxyPort: 1355,\n45:       https: false,\n46:     },\n47:     backup: { maxBackups: 5 },\n48:     defaults: { maxConcurrent: 6, maxRetries: 2 },\n49:     browser: {\n50:       enabled: false,\n51:       bin: null,\n52:       headless: true,\n53:       testCommand: null,\n54:       launchTimeout: 30_000,\n55:       testTimeout: 60_000,\n56:       defaultViewport: { width: 1280, height: 720 },\n57:     },\n58:     agentRegistry: {\n59:       mode: \"auto\",\n60:       source: \"msitarzewski/agency-agents\",\n61:       cacheDir: \"agents-cache\",\n62:     },\n63:   };\n64: }\n65: \n66: // ---------------------------------------------------------------------------\n67: // Tests for worktreePath and featureBranchName (pure functions, no git needed)\n68: // ---------------------------------------------------------------------------\n69: \n70: import { worktreePath, featureBranchName } from \"../src/lib/worktree.js\";\n71: \n72: describe(\"featureBranchName\", () => {\n73:   test(\"generates correct branch name with default prefix\", () => {\n74:     const config = makeConfig();\n75:     expect(featureBranchName(\"my-feature\", config)).toBe(\"feature/my-feature\");\n76:   });\n77: \n78:   test(\"generates correct branch name with custom prefix\", () => {\n79:     const config = makeConfig({ branchPrefix: \"feat-\" });\n80:     expect(featureBranchName(\"auth-flow\", config)).toBe(\"feat-auth-flow\");\n81:   });\n82: \n83:   test(\"handles empty feature ID\", () => {\n84:     const config = makeConfig();\n85:     expect(featureBranchName(\"\", config)).toBe(\"feature/\");\n86:   });\n87: });\n88: \n89: describe(\"worktreePath\", () => {\n90:   test(\"generates sibling directory path with prefix\", () => {\n91:     const config = makeConfig();\n92:     const result = worktreePath(\"/home/user/projects/my-app\", \"auth\", config);\n93:     expect(result).toBe(resolve(\"/home/user/projects\", \"wombo-auth\"));\n94:   });\n95: \n96:   test(\"uses custom worktree prefix\", () => {\n97:     const config = makeConfig({ worktreePrefix: \"wt-\" });\n98:     const result = worktreePath(\"/home/user/projects/my-app\", \"auth\", config);\n99:     expect(result).toBe(resolve(\"/home/user/projects\", \"wt-auth\"));\n100:   });\n101: \n102:   test(\"works with deeply nested project root\", () => {\n103:     const config = makeConfig();\n104:     const result = worktreePath(\"/a/b/c/d/project\", \"feat1\", config);\n105:     expect(result).toBe(resolve(\"/a/b/c/d\", \"wombo-feat1\"));\n106:   });\n107: });\n108: \n109: // ---------------------------------------------------------------------------\n110: // Tests for listWomboWorktrees filtering logic\n111: // ---------------------------------------------------------------------------\n112: \n113: describe(\"listWomboWorktrees — basename filtering\", () => {\n114:   // We test the filtering logic by mocking the module. The critical test is\n115:   // that a project directory named \"wombo-combo\" (whose name starts with\n116:   // \"wombo-\") does NOT get included in the filtered list when it is the\n117:   // project root itself.\n118: \n119:   /**\n120:    * Simulate the filtering logic from listWomboWorktrees.\n121:    * This mirrors the implementation exactly so we can test edge cases.\n122:    */\n123:   function filterWomboWorktrees(\n124:     worktrees: WorktreeInfo[],\n125:     projectRoot: string,\n126:     config: WomboConfig\n127:   ): WorktreeInfo[] {\n128:     const resolvedRoot = resolve(projectRoot);\n129:     return worktrees.filter((wt) => {\n130:       // Never include the main project root\n131:       if (resolve(wt.path) === resolvedRoot) return false;\n132:       // Match only worktrees whose directory name starts with the prefix\n133:       return basename(wt.path).startsWith(config.git.worktreePrefix);\n134:     });\n135:   }\n136: \n137:   /**\n138:    * A BUGGY version of the filter that used .includes() on full path.\n139:    * This is what caused the rm -rf bug. We test that it WOULD match\n140:    * the project root, proving the fix is necessary.\n141:    */\n142:   function buggyFilter(\n143:     worktrees: WorktreeInfo[],\n144:     projectRoot: string,\n145:     config: WomboConfig\n146:   ): WorktreeInfo[] {\n147:     return worktrees.filter((wt) => {\n148:       return wt.path.includes(config.git.worktreePrefix);\n149:     });\n150:   }\n151: \n152:   const projectRoot = \"/home/user/projects/wombo-combo\";\n153:   const config = makeConfig();\n154: \n155:   const worktrees: WorktreeInfo[] = [\n156:     {\n157:       path: \"/home/user/projects/wombo-combo\",\n158:       branch: \"main\",\n159:       head: \"abc123\",\n160:       bare: false,\n161:     },\n162:     {\n163:       path: \"/home/user/projects/wombo-auth-flow\",\n164:       branch: \"feature/auth-flow\",\n165:       head: \"def456\",\n166:       bare: false,\n167:     },\n168:     {\n169:       path: \"/home/user/projects/wombo-search-api\",\n170:       branch: \"feature/search-api\",\n171:       head: \"ghi789\",\n172:       bare: false,\n173:     },\n174:   ];\n175: \n176:   test(\"excludes project root even when its name starts with worktree prefix\", () => {\n177:     const result = filterWomboWorktrees(worktrees, projectRoot, config);\n178:     expect(result.map((w) => w.path)).not.toContain(projectRoot);\n179:     expect(result).toHaveLength(2);\n180:   });\n181: \n182:   test(\"includes legitimate worktrees\", () => {\n183:     const result = filterWomboWorktrees(worktrees, projectRoot, config);\n184:     expect(result.map((w) => w.path)).toContain(\n185:       \"/home/user/projects/wombo-auth-flow\"\n186:     );\n187:     expect(result.map((w) => w.path)).toContain(\n188:       \"/home/user/projects/wombo-search-api\"\n189:     );\n190:   });\n191: \n192:   test(\"buggy .includes() filter WOULD match project root (proving fix is needed)\", () => {\n193:     const buggyResult = buggyFilter(worktrees, projectRoot, config);\n194:     // The buggy filter includes the project root because \"wombo-combo\"\n195:     // contains \"wombo-\" as a substring\n196:     expect(buggyResult.map((w) => w.path)).toContain(projectRoot);\n197:     expect(buggyResult).toHaveLength(3); // all three match!\n198:   });\n199: \n200:   test(\"handles project root without prefix in name\", () => {\n201:     const root = \"/home/user/projects/my-app\";\n202:     const result = filterWomboWorktrees(worktrees, root, config);\n203:     // Project root \"/my-app\" is not in worktrees list and has no prefix match.\n204:     // \"wombo-combo\" basename starts with \"wombo-\" and is NOT the project root,\n205:     // so all three worktrees with \"wombo-\" prefix in basename are included.\n206:     expect(result).toHaveLength(3);\n207:   });\n208: \n209:   test(\"handles empty worktree list\", () => {\n210:     const result = filterWomboWorktrees([], projectRoot, config);\n211:     expect(result).toHaveLength(0);\n212:   });\n213: \n214:   test(\"handles worktrees with no matching prefix\", () => {\n215:     const unrelatedWorktrees: WorktreeInfo[] = [\n216:       {\n217:         path: \"/home/user/projects/wombo-combo\",\n218:         branch: \"main\",\n219:         head: \"abc123\",\n220:         bare: false,\n221:       },\n222:       {\n223:         path: \"/home/user/projects/other-project\",\n224:         branch: \"feature/other\",\n225:         head: \"xyz000\",\n226:         bare: false,\n227:       },\n228:     ];\n229:     const result = filterWomboWorktrees(\n230:       unrelatedWorktrees,\n231:       projectRoot,\n232:       config\n233:     );\n234:     expect(result).toHaveLength(0);\n235:   });\n236: \n237:   test(\"matches with custom worktree prefix\", () => {\n238:     const customConfig = makeConfig({ worktreePrefix: \"wt-\" });\n239:     const customWorktrees: WorktreeInfo[] = [\n240:       {\n241:         path: \"/home/user/projects/my-app\",\n242:         branch: \"main\",\n243:         head: \"abc123\",\n244:         bare: false,\n245:       },\n246:       {\n247:         path: \"/home/user/projects/wt-auth\",\n248:         branch: \"feature/auth\",\n249:         head: \"def456\",\n250:         bare: false,\n251:       },\n252:       {\n253:         path: \"/home/user/projects/wombo-stale\",\n254:         branch: \"feature/stale\",\n255:         head: \"ghi789\",\n256:         bare: false,\n257:       },\n258:     ];\n259:     const result = filterWomboWorktrees(\n260:       customWorktrees,\n261:       \"/home/user/projects/my-app\",\n262:       customConfig\n263:     );\n264:     expect(result).toHaveLength(1);\n265:     expect(result[0].path).toBe(\"/home/user/projects/wt-auth\");\n266:   });\n267: \n268:   test(\"bare worktrees are not special-cased\", () => {\n269:     const bareWorktrees: WorktreeInfo[] = [\n270:       {\n271:         path: \"/home/user/projects/wombo-combo\",\n272:         branch: \"main\",\n273:         head: \"abc123\",\n274:         bare: true,\n275:       },\n276:       {\n277:         path: \"/home/user/projects/wombo-feat\",\n278:         branch: \"feature/feat\",\n279:         head: \"def456\",\n280:         bare: false,\n281:       },\n282:     ];\n283:     const result = filterWomboWorktrees(bareWorktrees, projectRoot, config);\n284:     expect(result).toHaveLength(1);\n285:     expect(result[0].path).toBe(\"/home/user/projects/wombo-feat\");\n286:   });\n287: \n288:   test(\"resolves symlinks/relative paths in project root comparison\", () => {\n289:     // Test with trailing slash and relative components\n290:     const messyRoot = \"/home/user/projects/./wombo-combo/\";\n291:     const result = filterWomboWorktrees(\n292:       [\n293:         {\n294:           path: \"/home/user/projects/wombo-combo\",\n295:           branch: \"main\",\n296:           head: \"abc123\",\n297:           bare: false,\n298:         },\n299:         {\n300:           path: \"/home/user/projects/wombo-feat\",\n301:           branch: \"feature/feat\",\n302:           head: \"def456\",\n303:           bare: false,\n304:         },\n305:       ],\n306:       messyRoot,\n307:       config\n308:     );\n309:     // The resolve() call should normalize the path, excluding the project root\n310:     expect(result).toHaveLength(1);\n311:     expect(result[0].path).toBe(\"/home/user/projects/wombo-feat\");\n312:   });\n313: });\n314: \n315: // ---------------------------------------------------------------------------\n316: // Tests for removeWorktree safety guard\n317: // ---------------------------------------------------------------------------\n318: \n319: describe(\"removeWorktree — safety guard\", () => {\n320:   // We can import the function and test the safety check directly.\n321:   // The actual git operations will fail in test, but the safety check\n322:   // happens before any git calls.\n323: \n324:   test(\"throws when asked to remove project root (exact match)\", async () => {\n325:     const { removeWorktree } = await import(\"../src/lib/worktree.js\");\n326:     const root = \"/home/user/projects/my-app\";\n327:     expect(() => removeWorktree(root, root)).toThrow(\n328:       \"SAFETY: refusing to remove project root\"\n329:     );\n330:   });\n331: \n332:   test(\"throws when asked to remove project root (resolved paths)\", async () => {\n333:     const { removeWorktree } = await import(\"../src/lib/worktree.js\");\n334:     const root = \"/home/user/projects/my-app\";\n335:     const messyPath = \"/home/user/projects/./my-app\";\n336:     expect(() => removeWorktree(root, messyPath)).toThrow(\n337:       \"SAFETY: refusing to remove project root\"\n338:     );\n339:   });\n340: \n341:   test(\"throws when asked to remove project root with trailing slash\", async () => {\n342:     const { removeWorktree } = await import(\"../src/lib/worktree.js\");\n343:     const root = \"/home/user/projects/my-app\";\n344:     const trailingSlash = \"/home/user/projects/my-app/\";\n345:     // resolve() strips trailing slashes\n346:     expect(() => removeWorktree(root, trailingSlash)).toThrow(\n347:       \"SAFETY: refusing to remove project root\"\n348:     );\n349:   });\n350: });\n351: \n352: // ---------------------------------------------------------------------------\n353: // Tests for listWorktrees parsing (porcelain output format)\n354: // ---------------------------------------------------------------------------\n355: \n356: describe(\"listWorktrees — porcelain output parsing\", () => {\n357:   // The listWorktrees function parses `git worktree list --porcelain` output.\n358:   // We can test the parsing logic by examining the function's behavior with\n359:   // known git output. Since we can't easily mock the exec call without\n360:   // restructuring, we test the parsing logic pattern instead.\n361: \n362:   test(\"parses standard porcelain output correctly\", () => {\n363:     // Simulate what listWorktrees does internally\n364:     const output = [\n365:       \"worktree /home/user/projects/my-app\",\n366:       \"HEAD abc123def456\",\n367:       \"branch refs/heads/main\",\n368:       \"\",\n369:       \"worktree /home/user/projects/wombo-auth\",\n370:       \"HEAD def456789012\",\n371:       \"branch refs/heads/feature/auth\",\n372:       \"\",\n373:     ].join(\"\\n\");\n374: \n375:     // Re-implement the parsing logic to test it\n376:     const worktrees: WorktreeInfo[] = [];\n377:     let current: Partial<WorktreeInfo> = {};\n378: \n379:     for (const line of output.split(\"\\n\")) {\n380:       if (line.startsWith(\"worktree \")) {\n381:         if (current.path) worktrees.push(current as WorktreeInfo);\n382:         current = { path: line.slice(9), bare: false };\n383:       } else if (line.startsWith(\"HEAD \")) {\n384:         current.head = line.slice(5);\n385:       } else if (line.startsWith(\"branch \")) {\n386:         current.branch = line.slice(7).replace(\"refs/heads/\", \"\");\n387:       } else if (line === \"bare\") {\n388:         current.bare = true;\n389:       } else if (line === \"\" && current.path) {\n390:         worktrees.push(current as WorktreeInfo);\n391:         current = {};\n392:       }\n393:     }\n394:     if (current.path) worktrees.push(current as WorktreeInfo);\n395: \n396:     expect(worktrees).toHaveLength(2);\n397:     expect(worktrees[0]).toEqual({\n398:       path: \"/home/user/projects/my-app\",\n399:       head: \"abc123def456\",\n400:       branch: \"main\",\n401:       bare: false,\n402:     });\n403:     expect(worktrees[1]).toEqual({\n404:       path: \"/home/user/projects/wombo-auth\",\n405:       head: \"def456789012\",\n406:       branch: \"feature/auth\",\n407:       bare: false,\n408:     });\n409:   });\n410: \n411:   test(\"parses bare worktree correctly\", () => {\n412:     const output = [\n413:       \"worktree /home/user/repos/my-app.git\",\n414:       \"HEAD abc123\",\n415:       \"bare\",\n416:       \"\",\n417:     ].join(\"\\n\");\n418: \n419:     const worktrees: WorktreeInfo[] = [];\n420:     let current: Partial<WorktreeInfo> = {};\n421: \n422:     for (const line of output.split(\"\\n\")) {\n423:       if (line.startsWith(\"worktree \")) {\n424:         if (current.path) worktrees.push(current as WorktreeInfo);\n425:         current = { path: line.slice(9), bare: false };\n426:       } else if (line.startsWith(\"HEAD \")) {\n427:         current.head = line.slice(5);\n428:       } else if (line.startsWith(\"branch \")) {\n429:         current.branch = line.slice(7).replace(\"refs/heads/\", \"\");\n430:       } else if (line === \"bare\") {\n431:         current.bare = true;\n432:       } else if (line === \"\" && current.path) {\n433:         worktrees.push(current as WorktreeInfo);\n434:         current = {};\n435:       }\n436:     }\n437:     if (current.path) worktrees.push(current as WorktreeInfo);\n438: \n439:     expect(worktrees).toHaveLength(1);\n440:     expect(worktrees[0].bare).toBe(true);\n441:     expect(worktrees[0].branch).toBeUndefined();\n442:   });\n443: \n444:   test(\"handles empty output\", () => {\n445:     const output = \"\";\n446:     const worktrees: WorktreeInfo[] = [];\n447:     if (!output) {\n448:       // matches the guard in listWorktrees\n449:       expect(worktrees).toHaveLength(0);\n450:     }\n451:   });\n452: \n453:   test(\"handles output without trailing empty line\", () => {\n454:     const output = [\n455:       \"worktree /home/user/projects/my-app\",\n456:       \"HEAD abc123\",\n457:       \"branch refs/heads/main\",\n458:     ].join(\"\\n\");\n459: \n460:     const worktrees: WorktreeInfo[] = [];\n461:     let current: Partial<WorktreeInfo> = {};\n462: \n463:     for (const line of output.split(\"\\n\")) {\n464:       if (line.startsWith(\"worktree \")) {\n465:         if (current.path) worktrees.push(current as WorktreeInfo);\n466:         current = { path: line.slice(9), bare: false };\n467:       } else if (line.startsWith(\"HEAD \")) {\n468:         current.head = line.slice(5);\n469:       } else if (line.startsWith(\"branch \")) {\n470:         current.branch = line.slice(7).replace(\"refs/heads/\", \"\");\n471:       } else if (line === \"bare\") {\n472:         current.bare = true;\n473:       } else if (line === \"\" && current.path) {\n474:         worktrees.push(current as WorktreeInfo);\n475:         current = {};\n476:       }\n477:     }\n478:     if (current.path) worktrees.push(current as WorktreeInfo);\n479: \n480:     // The final entry should still be captured\n481:     expect(worktrees).toHaveLength(1);\n482:     expect(worktrees[0].path).toBe(\"/home/user/projects/my-app\");\n483:   });\n484: });\n\n(End of file - total 484 lines)\n</content>","title":"tests/worktree.test.ts","metadata":{"preview":"/**\n * worktree.test.ts — Unit tests for worktree listing, filtering, and safety guards.\n *\n * Critical coverage:\n *   - listWomboWorktrees must use basename matching, NOT full-path .includes()\n *   - removeWorktree must refuse to remove the project root\n *   - cleanupAllWorktrees must never touch the project root\n *   - The \"wombo-combo\" prefix collision bug (project dir name contains worktree prefix)\n */\n\nimport { describe, test, expect, mock, beforeEach, afterEach } from \"bun:test\";\nimport { resolve, basename } from \"node:path\";\nimport type { WomboConfig } from \"../src/config.js\";\nimport type { WorktreeInfo } from \"../src/lib/worktree.js\";\n\n// ---------------------------------------------------------------------------\n// Helpers: minimal WomboConfig for testing\n// ---------------------------------------------------------------------------\n\nfunction makeConfig(overrides?: Partial<WomboConfig[\"git\"]>): WomboConfig {","truncated":false,"loaded":[]},"time":{"start":1773433289490,"end":1773433289512}}}}
