{"type":"tool_use","timestamp":1773433290188,"sessionID":"ses_31723c227ffes6YQhTzXCb8Yyr","part":{"id":"prt_ce8dc7b8c001Utahq27MTVpdd6","sessionID":"ses_31723c227ffes6YQhTzXCb8Yyr","messageID":"msg_ce8dc70ba0013nOB125zIh2fdR","type":"tool","callID":"toolu_vrtx_017fNLaXGZFacB3ENj6gNc5J","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-test-worktree-filtering/tests/state.test.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-test-worktree-filtering/tests/state.test.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * state.test.ts — Unit tests for wave state persistence and mutations.\n3:  *\n4:  * Coverage:\n5:  *   - saveState / loadState round-trip\n6:  *   - Atomic write (write to .tmp then rename)\n7:  *   - State file corruption recovery (returns null)\n8:  *   - createWaveState / createAgentState\n9:  *   - updateAgent with valid/invalid feature IDs\n10:  *   - agentCounts\n11:  *   - activeAgents / queuedAgents\n12:  *   - isWaveComplete\n13:  *   - generateWaveId format\n14:  *   - Concurrent mutation patterns\n15:  */\n16: \n17: import { describe, test, expect, beforeEach, afterEach } from \"bun:test\";\n18: import { mkdtempSync, mkdirSync, writeFileSync, readFileSync, rmSync, existsSync } from \"node:fs\";\n19: import { join } from \"node:path\";\n20: import { tmpdir } from \"node:os\";\n21: import {\n22:   loadState,\n23:   saveState,\n24:   createWaveState,\n25:   createAgentState,\n26:   getAgent,\n27:   updateAgent,\n28:   agentCounts,\n29:   activeAgents,\n30:   queuedAgents,\n31:   isWaveComplete,\n32:   generateWaveId,\n33: } from \"../src/lib/state.js\";\n34: import type { WaveState, AgentState, AgentStatus } from \"../src/lib/state.js\";\n35: \n36: // ---------------------------------------------------------------------------\n37: // Helpers\n38: // ---------------------------------------------------------------------------\n39: \n40: let tmpDir: string;\n41: \n42: beforeEach(() => {\n43:   tmpDir = mkdtempSync(join(tmpdir(), \"wombo-test-state-\"));\n44: });\n45: \n46: afterEach(() => {\n47:   rmSync(tmpDir, { recursive: true, force: true });\n48: });\n49: \n50: function makeWaveState(overrides?: Partial<WaveState>): WaveState {\n51:   return {\n52:     wave_id: \"wave-2025-01-01-000\",\n53:     base_branch: \"main\",\n54:     started_at: \"2025-01-01T00:00:00Z\",\n55:     updated_at: \"2025-01-01T00:00:00Z\",\n56:     max_concurrent: 4,\n57:     model: null,\n58:     interactive: false,\n59:     agents: [],\n60:     ...overrides,\n61:   };\n62: }\n63: \n64: function makeAgentState(overrides?: Partial<AgentState>): AgentState {\n65:   return {\n66:     feature_id: \"test-feature\",\n67:     branch: \"feature/test-feature\",\n68:     worktree: \"/tmp/wombo-test-feature\",\n69:     session_id: null,\n70:     pid: null,\n71:     status: \"queued\",\n72:     activity: null,\n73:     activity_updated_at: null,\n74:     retries: 0,\n75:     max_retries: 2,\n76:     started_at: null,\n77:     completed_at: null,\n78:     build_passed: null,\n79:     build_output: null,\n80:     error: null,\n81:     effort_estimate_ms: null,\n82:     ...overrides,\n83:   };\n84: }\n85: \n86: // ---------------------------------------------------------------------------\n87: // generateWaveId\n88: // ---------------------------------------------------------------------------\n89: \n90: describe(\"generateWaveId\", () => {\n91:   test(\"produces wave ID in expected format\", () => {\n92:     const id = generateWaveId();\n93:     // The sequence part is hours*60+minutes, padStart(3, \"0\"), so can be 3-4 digits\n94:     expect(id).toMatch(/^wave-\\d{4}-\\d{2}-\\d{2}-\\d{3,4}$/);\n95:   });\n96: \n97:   test(\"includes current date\", () => {\n98:     const id = generateWaveId();\n99:     const today = new Date().toISOString().slice(0, 10);\n100:     expect(id).toContain(today);\n101:   });\n102: \n103:   test(\"produces consistent format on repeated calls\", () => {\n104:     const id1 = generateWaveId();\n105:     const id2 = generateWaveId();\n106:     // Both should match the format (though values may differ slightly)\n107:     expect(id1).toMatch(/^wave-\\d{4}-\\d{2}-\\d{2}-\\d{3,4}$/);\n108:     expect(id2).toMatch(/^wave-\\d{4}-\\d{2}-\\d{2}-\\d{3,4}$/);\n109:   });\n110: });\n111: \n112: // ---------------------------------------------------------------------------\n113: // createWaveState\n114: // ---------------------------------------------------------------------------\n115: \n116: describe(\"createWaveState\", () => {\n117:   test(\"creates state with provided options\", () => {\n118:     const state = createWaveState({\n119:       baseBranch: \"develop\",\n120:       maxConcurrent: 3,\n121:       model: \"gpt-4\",\n122:       interactive: true,\n123:     });\n124:     expect(state.base_branch).toBe(\"develop\");\n125:     expect(state.max_concurrent).toBe(3);\n126:     expect(state.model).toBe(\"gpt-4\");\n127:     expect(state.interactive).toBe(true);\n128:     expect(state.agents).toEqual([]);\n129:     expect(state.wave_id).toMatch(/^wave-/);\n130:   });\n131: \n132:   test(\"creates state with null model\", () => {\n133:     const state = createWaveState({\n134:       baseBranch: \"main\",\n135:       maxConcurrent: 6,\n136:       model: null,\n137:       interactive: false,\n138:     });\n139:     expect(state.model).toBeNull();\n140:   });\n141: \n142:   test(\"sets started_at and updated_at timestamps\", () => {\n143:     const before = new Date().toISOString();\n144:     const state = createWaveState({\n145:       baseBranch: \"main\",\n146:       maxConcurrent: 1,\n147:       model: null,\n148:       interactive: false,\n149:     });\n150:     const after = new Date().toISOString();\n151:     expect(state.started_at >= before).toBe(true);\n152:     expect(state.started_at <= after).toBe(true);\n153:   });\n154: });\n155: \n156: // ---------------------------------------------------------------------------\n157: // createAgentState\n158: // ---------------------------------------------------------------------------\n159: \n160: describe(\"createAgentState\", () => {\n161:   test(\"creates agent with default max retries\", () => {\n162:     const agent = createAgentState(\"my-feat\", \"feature/my-feat\", \"/tmp/wt\");\n163:     expect(agent.feature_id).toBe(\"my-feat\");\n164:     expect(agent.branch).toBe(\"feature/my-feat\");\n165:     expect(agent.worktree).toBe(\"/tmp/wt\");\n166:     expect(agent.status).toBe(\"queued\");\n167:     expect(agent.max_retries).toBe(2);\n168:     expect(agent.retries).toBe(0);\n169:     expect(agent.pid).toBeNull();\n170:     expect(agent.session_id).toBeNull();\n171:     expect(agent.build_passed).toBeNull();\n172:   });\n173: \n174:   test(\"creates agent with custom max retries\", () => {\n175:     const agent = createAgentState(\"my-feat\", \"feature/my-feat\", \"/tmp/wt\", 5);\n176:     expect(agent.max_retries).toBe(5);\n177:   });\n178: });\n179: \n180: // ---------------------------------------------------------------------------\n181: // saveState / loadState round-trip\n182: // ---------------------------------------------------------------------------\n183: \n184: describe(\"saveState / loadState\", () => {\n185:   test(\"round-trips state through file system\", () => {\n186:     const state = makeWaveState({\n187:       agents: [makeAgentState({ feature_id: \"feat-a\" })],\n188:     });\n189:     saveState(tmpDir, state);\n190:     const loaded = loadState(tmpDir);\n191:     expect(loaded).not.toBeNull();\n192:     expect(loaded!.wave_id).toBe(state.wave_id);\n193:     expect(loaded!.agents).toHaveLength(1);\n194:     expect(loaded!.agents[0].feature_id).toBe(\"feat-a\");\n195:   });\n196: \n197:   test(\"updates updated_at timestamp on save\", () => {\n198:     const state = makeWaveState();\n199:     const oldTimestamp = state.updated_at;\n200:     // Wait a tiny bit to ensure timestamp differs\n201:     saveState(tmpDir, state);\n202:     const loaded = loadState(tmpDir);\n203:     expect(loaded).not.toBeNull();\n204:     // The saved state should have a newer (or equal) timestamp\n205:     expect(loaded!.updated_at >= oldTimestamp).toBe(true);\n206:   });\n207: \n208:   test(\"writes valid JSON\", () => {\n209:     const state = makeWaveState({\n210:       agents: [\n211:         makeAgentState({ feature_id: \"feat-a\", status: \"running\" }),\n212:         makeAgentState({ feature_id: \"feat-b\", status: \"completed\" }),\n213:       ],\n214:     });\n215:     saveState(tmpDir, state);\n216:     const raw = readFileSync(join(tmpDir, \".wombo-combo\", \"state.json\"), \"utf-8\");\n217:     const parsed = JSON.parse(raw);\n218:     expect(parsed.wave_id).toBe(state.wave_id);\n219:     expect(parsed.agents).toHaveLength(2);\n220:   });\n221: \n222:   test(\"atomic write: tmp file is cleaned up after rename\", () => {\n223:     const state = makeWaveState();\n224:     saveState(tmpDir, state);\n225:     // The .tmp file should not exist after a successful save\n226:     expect(existsSync(join(tmpDir, \".wombo-combo\", \"state.json.tmp\"))).toBe(false);\n227:     // The actual file should exist\n228:     expect(existsSync(join(tmpDir, \".wombo-combo\", \"state.json\"))).toBe(true);\n229:   });\n230: \n231:   test(\"returns null when no state file exists\", () => {\n232:     const loaded = loadState(tmpDir);\n233:     expect(loaded).toBeNull();\n234:   });\n235: \n236:   test(\"returns null on corrupted JSON\", () => {\n237:     mkdirSync(join(tmpDir, \".wombo-combo\"), { recursive: true });\n238:     writeFileSync(\n239:       join(tmpDir, \".wombo-combo\", \"state.json\"),\n240:       \"{{not valid json!!!\",\n241:       \"utf-8\"\n242:     );\n243:     const loaded = loadState(tmpDir);\n244:     expect(loaded).toBeNull();\n245:   });\n246: \n247:   test(\"returns null on empty file\", () => {\n248:     mkdirSync(join(tmpDir, \".wombo-combo\"), { recursive: true });\n249:     writeFileSync(join(tmpDir, \".wombo-combo\", \"state.json\"), \"\", \"utf-8\");\n250:     const loaded = loadState(tmpDir);\n251:     expect(loaded).toBeNull();\n252:   });\n253: \n254:   test(\"handles state with many agents\", () => {\n255:     const agents: AgentState[] = [];\n256:     for (let i = 0; i < 50; i++) {\n257:       agents.push(\n258:         makeAgentState({\n259:           feature_id: `feat-${i}`,\n260:           branch: `feature/feat-${i}`,\n261:         })\n262:       );\n263:     }\n264:     const state = makeWaveState({ agents });\n265:     saveState(tmpDir, state);\n266:     const loaded = loadState(tmpDir);\n267:     expect(loaded!.agents).toHaveLength(50);\n268:   });\n269: \n270:   test(\"preserves all agent fields through round-trip\", () => {\n271:     const agent = makeAgentState({\n272:       feature_id: \"full-agent\",\n273:       branch: \"feature/full\",\n274:       worktree: \"/tmp/wt-full\",\n275:       session_id: \"tmux-session-123\",\n276:       pid: 12345,\n277:       status: \"running\",\n278:       activity: \"Building project\",\n279:       activity_updated_at: \"2025-01-01T12:00:00Z\",\n280:       retries: 1,\n281:       max_retries: 3,\n282:       started_at: \"2025-01-01T10:00:00Z\",\n283:       completed_at: null,\n284:       build_passed: null,\n285:       build_output: null,\n286:       error: null,\n287:       effort_estimate_ms: 3600000,\n288:     });\n289:     const state = makeWaveState({ agents: [agent] });\n290:     saveState(tmpDir, state);\n291:     const loaded = loadState(tmpDir);\n292:     const loadedAgent = loaded!.agents[0];\n293:     expect(loadedAgent.feature_id).toBe(\"full-agent\");\n294:     expect(loadedAgent.session_id).toBe(\"tmux-session-123\");\n295:     expect(loadedAgent.pid).toBe(12345);\n296:     expect(loadedAgent.status).toBe(\"running\");\n297:     expect(loadedAgent.activity).toBe(\"Building project\");\n298:     expect(loadedAgent.retries).toBe(1);\n299:     expect(loadedAgent.max_retries).toBe(3);\n300:     expect(loadedAgent.effort_estimate_ms).toBe(3600000);\n301:   });\n302: });\n303: \n304: // ---------------------------------------------------------------------------\n305: // getAgent\n306: // ---------------------------------------------------------------------------\n307: \n308: describe(\"getAgent\", () => {\n309:   test(\"finds agent by feature ID\", () => {\n310:     const state = makeWaveState({\n311:       agents: [\n312:         makeAgentState({ feature_id: \"feat-a\" }),\n313:         makeAgentState({ feature_id: \"feat-b\" }),\n314:       ],\n315:     });\n316:     const agent = getAgent(state, \"feat-b\");\n317:     expect(agent).toBeDefined();\n318:     expect(agent!.feature_id).toBe(\"feat-b\");\n319:   });\n320: \n321:   test(\"returns undefined for nonexistent feature ID\", () => {\n322:     const state = makeWaveState({\n323:       agents: [makeAgentState({ feature_id: \"feat-a\" })],\n324:     });\n325:     const agent = getAgent(state, \"nonexistent\");\n326:     expect(agent).toBeUndefined();\n327:   });\n328: \n329:   test(\"returns undefined when agents list is empty\", () => {\n330:     const state = makeWaveState({ agents: [] });\n331:     const agent = getAgent(state, \"any\");\n332:     expect(agent).toBeUndefined();\n333:   });\n334: });\n335: \n336: // ---------------------------------------------------------------------------\n337: // updateAgent\n338: // ---------------------------------------------------------------------------\n339: \n340: describe(\"updateAgent\", () => {\n341:   test(\"updates agent status\", () => {\n342:     const state = makeWaveState({\n343:       agents: [makeAgentState({ feature_id: \"feat-a\", status: \"queued\" })],\n344:     });\n345:     updateAgent(state, \"feat-a\", { status: \"running\" });\n346:     expect(state.agents[0].status).toBe(\"running\");\n347:   });\n348: \n349:   test(\"updates multiple fields at once\", () => {\n350:     const state = makeWaveState({\n351:       agents: [makeAgentState({ feature_id: \"feat-a\" })],\n352:     });\n353:     updateAgent(state, \"feat-a\", {\n354:       status: \"running\",\n355:       pid: 12345,\n356:       started_at: \"2025-01-01T00:00:00Z\",\n357:       activity: \"Installing dependencies\",\n358:     });\n359:     expect(state.agents[0].status).toBe(\"running\");\n360:     expect(state.agents[0].pid).toBe(12345);\n361:     expect(state.agents[0].started_at).toBe(\"2025-01-01T00:00:00Z\");\n362:     expect(state.agents[0].activity).toBe(\"Installing dependencies\");\n363:   });\n364: \n365:   test(\"throws for nonexistent feature ID\", () => {\n366:     const state = makeWaveState({\n367:       agents: [makeAgentState({ feature_id: \"feat-a\" })],\n368:     });\n369:     expect(() => updateAgent(state, \"nonexistent\", { status: \"running\" })).toThrow(\n370:       \"Agent not found for feature: nonexistent\"\n371:     );\n372:   });\n373: \n374:   test(\"throws when agents list is empty\", () => {\n375:     const state = makeWaveState({ agents: [] });\n376:     expect(() => updateAgent(state, \"any\", { status: \"running\" })).toThrow(\n377:       \"Agent not found for feature: any\"\n378:     );\n379:   });\n380: \n381:   test(\"only updates the targeted agent\", () => {\n382:     const state = makeWaveState({\n383:       agents: [\n384:         makeAgentState({ feature_id: \"feat-a\", status: \"queued\" }),\n385:         makeAgentState({ feature_id: \"feat-b\", status: \"queued\" }),\n386:       ],\n387:     });\n388:     updateAgent(state, \"feat-a\", { status: \"running\" });\n389:     expect(state.agents[0].status).toBe(\"running\");\n390:     expect(state.agents[1].status).toBe(\"queued\");\n391:   });\n392: \n393:   test(\"sequential updates accumulate correctly\", () => {\n394:     const state = makeWaveState({\n395:       agents: [makeAgentState({ feature_id: \"feat-a\" })],\n396:     });\n397:     updateAgent(state, \"feat-a\", { status: \"installing\" });\n398:     updateAgent(state, \"feat-a\", { status: \"running\", pid: 1234 });\n399:     updateAgent(state, \"feat-a\", {\n400:       status: \"completed\",\n401:       completed_at: \"2025-01-01T01:00:00Z\",\n402:       build_passed: true,\n403:     });\n404:     const agent = state.agents[0];\n405:     expect(agent.status).toBe(\"completed\");\n406:     expect(agent.pid).toBe(1234);\n407:     expect(agent.build_passed).toBe(true);\n408:     expect(agent.completed_at).toBe(\"2025-01-01T01:00:00Z\");\n409:   });\n410: });\n411: \n412: // ---------------------------------------------------------------------------\n413: // agentCounts\n414: // ---------------------------------------------------------------------------\n415: \n416: describe(\"agentCounts\", () => {\n417:   test(\"counts agents by status\", () => {\n418:     const state = makeWaveState({\n419:       agents: [\n420:         makeAgentState({ feature_id: \"a\", status: \"queued\" }),\n421:         makeAgentState({ feature_id: \"b\", status: \"queued\" }),\n422:         makeAgentState({ feature_id: \"c\", status: \"running\" }),\n423:         makeAgentState({ feature_id: \"d\", status: \"completed\" }),\n424:         makeAgentState({ feature_id: \"e\", status: \"failed\" }),\n425:       ],\n426:     });\n427:     const counts = agentCounts(state);\n428:     expect(counts.queued).toBe(2);\n429:     expect(counts.running).toBe(1);\n430:     expect(counts.completed).toBe(1);\n431:     expect(counts.failed).toBe(1);\n432:     expect(counts.installing).toBe(0);\n433:     expect(counts.verified).toBe(0);\n434:     expect(counts.merged).toBe(0);\n435:     expect(counts.retry).toBe(0);\n436:     expect(counts.resolving_conflict).toBe(0);\n437:   });\n438: \n439:   test(\"returns all zeros for empty agents list\", () => {\n440:     const state = makeWaveState({ agents: [] });\n441:     const counts = agentCounts(state);\n442:     expect(counts.queued).toBe(0);\n443:     expect(counts.running).toBe(0);\n444:     expect(counts.completed).toBe(0);\n445:   });\n446: });\n447: \n448: // ---------------------------------------------------------------------------\n449: // activeAgents\n450: // ---------------------------------------------------------------------------\n451: \n452: describe(\"activeAgents\", () => {\n453:   test(\"returns running, installing, and resolving_conflict agents\", () => {\n454:     const state = makeWaveState({\n455:       agents: [\n456:         makeAgentState({ feature_id: \"a\", status: \"running\" }),\n457:         makeAgentState({ feature_id: \"b\", status: \"installing\" }),\n458:         makeAgentState({ feature_id: \"c\", status: \"resolving_conflict\" }),\n459:         makeAgentState({ feature_id: \"d\", status: \"queued\" }),\n460:         makeAgentState({ feature_id: \"e\", status: \"completed\" }),\n461:       ],\n462:     });\n463:     const active = activeAgents(state);\n464:     expect(active).toHaveLength(3);\n465:     const ids = active.map((a) => a.feature_id);\n466:     expect(ids).toContain(\"a\");\n467:     expect(ids).toContain(\"b\");\n468:     expect(ids).toContain(\"c\");\n469:   });\n470: \n471:   test(\"returns empty array when no agents are active\", () => {\n472:     const state = makeWaveState({\n473:       agents: [\n474:         makeAgentState({ feature_id: \"a\", status: \"queued\" }),\n475:         makeAgentState({ feature_id: \"b\", status: \"completed\" }),\n476:       ],\n477:     });\n478:     expect(activeAgents(state)).toHaveLength(0);\n479:   });\n480: });\n481: \n482: // ---------------------------------------------------------------------------\n483: // queuedAgents\n484: // ---------------------------------------------------------------------------\n485: \n486: describe(\"queuedAgents\", () => {\n487:   test(\"returns only queued agents\", () => {\n488:     const state = makeWaveState({\n489:       agents: [\n490:         makeAgentState({ feature_id: \"a\", status: \"queued\" }),\n491:         makeAgentState({ feature_id: \"b\", status: \"running\" }),\n492:         makeAgentState({ feature_id: \"c\", status: \"queued\" }),\n493:       ],\n494:     });\n495:     const queued = queuedAgents(state);\n496:     expect(queued).toHaveLength(2);\n497:     expect(queued[0].feature_id).toBe(\"a\");\n498:     expect(queued[1].feature_id).toBe(\"c\");\n499:   });\n500: });\n501: \n502: // ---------------------------------------------------------------------------\n503: // isWaveComplete\n504: // ---------------------------------------------------------------------------\n505: \n506: describe(\"isWaveComplete\", () => {\n507:   test(\"returns true when all agents are in terminal states\", () => {\n508:     const state = makeWaveState({\n509:       agents: [\n510:         makeAgentState({ feature_id: \"a\", status: \"completed\" }),\n511:         makeAgentState({ feature_id: \"b\", status: \"verified\" }),\n512:         makeAgentState({ feature_id: \"c\", status: \"failed\" }),\n513:         makeAgentState({ feature_id: \"d\", status: \"merged\" }),\n514:       ],\n515:     });\n516:     expect(isWaveComplete(state)).toBe(true);\n517:   });\n518: \n519:   test(\"returns false when some agents are still queued\", () => {\n520:     const state = makeWaveState({\n521:       agents: [\n522:         makeAgentState({ feature_id: \"a\", status: \"completed\" }),\n523:         makeAgentState({ feature_id: \"b\", status: \"queued\" }),\n524:       ],\n525:     });\n526:     expect(isWaveComplete(state)).toBe(false);\n527:   });\n528: \n529:   test(\"returns false when some agents are still running\", () => {\n530:     const state = makeWaveState({\n531:       agents: [\n532:         makeAgentState({ feature_id: \"a\", status: \"completed\" }),\n533:         makeAgentState({ feature_id: \"b\", status: \"running\" }),\n534:       ],\n535:     });\n536:     expect(isWaveComplete(state)).toBe(false);\n537:   });\n538: \n539:   test(\"returns false when some agents are installing\", () => {\n540:     const state = makeWaveState({\n541:       agents: [\n542:         makeAgentState({ feature_id: \"a\", status: \"installing\" }),\n543:       ],\n544:     });\n545:     expect(isWaveComplete(state)).toBe(false);\n546:   });\n547: \n548:   test(\"returns false when some agents are in retry\", () => {\n549:     const state = makeWaveState({\n550:       agents: [\n551:         makeAgentState({ feature_id: \"a\", status: \"retry\" }),\n552:       ],\n553:     });\n554:     expect(isWaveComplete(state)).toBe(false);\n555:   });\n556: \n557:   test(\"returns true for empty agents list\", () => {\n558:     const state = makeWaveState({ agents: [] });\n559:     expect(isWaveComplete(state)).toBe(true);\n560:   });\n561: });\n562: \n563: // ---------------------------------------------------------------------------\n564: // Concurrent mutation patterns (save-load-modify-save cycles)\n565: // ---------------------------------------------------------------------------\n566: \n567: describe(\"concurrent mutation patterns\", () => {\n568:   test(\"multiple save-load cycles preserve data integrity\", () => {\n569:     const state = makeWaveState({\n570:       agents: [\n571:         makeAgentState({ feature_id: \"feat-a\", status: \"queued\" }),\n572:         makeAgentState({ feature_id: \"feat-b\", status: \"queued\" }),\n573:       ],\n574:     });\n575: \n576:     // Save initial state\n577:     saveState(tmpDir, state);\n578: \n579:     // Simulate agent A starting: load, modify, save\n580:     const s1 = loadState(tmpDir)!;\n581:     updateAgent(s1, \"feat-a\", { status: \"running\", pid: 1001 });\n582:     saveState(tmpDir, s1);\n583: \n584:     // Simulate agent B starting: load, modify, save\n585:     const s2 = loadState(tmpDir)!;\n586:     expect(s2.agents[0].status).toBe(\"running\"); // A's change persisted\n587:     updateAgent(s2, \"feat-b\", { status: \"running\", pid: 1002 });\n588:     saveState(tmpDir, s2);\n589: \n590:     // Final verification\n591:     const final = loadState(tmpDir)!;\n592:     expect(final.agents[0].status).toBe(\"running\");\n593:     expect(final.agents[0].pid).toBe(1001);\n594:     expect(final.agents[1].status).toBe(\"running\");\n595:     expect(final.agents[1].pid).toBe(1002);\n596:   });\n597: \n598:   test(\"rapid sequential updates don't corrupt state\", () => {\n599:     const state = makeWaveState({\n600:       agents: [makeAgentState({ feature_id: \"feat-a\", status: \"queued\" })],\n601:     });\n602: \n603:     // Rapid fire updates\n604:     const statuses: AgentStatus[] = [\n605:       \"queued\",\n606:       \"installing\",\n607:       \"running\",\n608:       \"completed\",\n609:     ];\n610:     for (const status of statuses) {\n611:       updateAgent(state, \"feat-a\", { status });\n612:       saveState(tmpDir, state);\n613:     }\n614: \n615:     const loaded = loadState(tmpDir)!;\n616:     expect(loaded.agents[0].status).toBe(\"completed\");\n617:   });\n618: \n619:   test(\"save and load with all possible agent statuses\", () => {\n620:     const allStatuses: AgentStatus[] = [\n621:       \"queued\",\n622:       \"installing\",\n623:       \"running\",\n624:       \"completed\",\n625:       \"verified\",\n626:       \"failed\",\n627:       \"merged\",\n628:       \"retry\",\n629:       \"resolving_conflict\",\n630:     ];\n631: \n632:     const agents = allStatuses.map((status, i) =>\n633:       makeAgentState({ feature_id: `feat-${i}`, status })\n634:     );\n635:     const state = makeWaveState({ agents });\n636:     saveState(tmpDir, state);\n637: \n638:     const loaded = loadState(tmpDir)!;\n639:     for (let i = 0; i < allStatuses.length; i++) {\n640:       expect(loaded.agents[i].status).toBe(allStatuses[i]);\n641:     }\n642:   });\n643: });\n\n(End of file - total 643 lines)\n</content>","title":"tests/state.test.ts","metadata":{"preview":"/**\n * state.test.ts — Unit tests for wave state persistence and mutations.\n *\n * Coverage:\n *   - saveState / loadState round-trip\n *   - Atomic write (write to .tmp then rename)\n *   - State file corruption recovery (returns null)\n *   - createWaveState / createAgentState\n *   - updateAgent with valid/invalid feature IDs\n *   - agentCounts\n *   - activeAgents / queuedAgents\n *   - isWaveComplete\n *   - generateWaveId format\n *   - Concurrent mutation patterns\n */\n\nimport { describe, test, expect, beforeEach, afterEach } from \"bun:test\";\nimport { mkdtempSync, mkdirSync, writeFileSync, readFileSync, rmSync, existsSync } from \"node:fs\";\nimport { join } from \"node:path\";\nimport { tmpdir } from \"node:os\";","truncated":false,"loaded":[]},"time":{"start":1773433289992,"end":1773433290168}}}}
