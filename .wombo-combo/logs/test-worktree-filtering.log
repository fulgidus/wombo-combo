{"type":"tool_use","timestamp":1773433281698,"sessionID":"ses_31723c227ffes6YQhTzXCb8Yyr","part":{"id":"prt_ce8dc5a5b001PPCpQ1dICa6Cyv","sessionID":"ses_31723c227ffes6YQhTzXCb8Yyr","messageID":"msg_ce8dc3fa900109YXU5eqZiQZaK","type":"tool","callID":"toolu_vrtx_01KGCw2RNKJpKYiNHrEWAF1h","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-test-worktree-filtering/tsconfig.json"},"output":"<path>/home/fulgidus/Documents/wt-wombo-test-worktree-filtering/tsconfig.json</path>\n<type>file</type>\n<content>1: {\n2:   \"compilerOptions\": {\n3:     \"target\": \"ES2022\",\n4:     \"module\": \"ESNext\",\n5:     \"moduleResolution\": \"bundler\",\n6:     \"esModuleInterop\": true,\n7:     \"strict\": true,\n8:     \"skipLibCheck\": true,\n9:     \"outDir\": \"dist\",\n10:     \"rootDir\": \"src\",\n11:     \"declaration\": true,\n12:     \"resolveJsonModule\": true,\n13:     \"forceConsistentCasingInFileNames\": true,\n14:     \"noUnusedLocals\": false,\n15:     \"noUnusedParameters\": false,\n16:     \"types\": [\"bun\"]\n17:   },\n18:   \"include\": [\"src/**/*.ts\"],\n19:   \"exclude\": [\"node_modules\", \"dist\"]\n20: }\n\n(End of file - total 20 lines)\n</content>","title":"tsconfig.json","metadata":{"preview":"{\n  \"compilerOptions\": {\n    \"target\": \"ES2022\",\n    \"module\": \"ESNext\",\n    \"moduleResolution\": \"bundler\",\n    \"esModuleInterop\": true,\n    \"strict\": true,\n    \"skipLibCheck\": true,\n    \"outDir\": \"dist\",\n    \"rootDir\": \"src\",\n    \"declaration\": true,\n    \"resolveJsonModule\": true,\n    \"forceConsistentCasingInFileNames\": true,\n    \"noUnusedLocals\": false,\n    \"noUnusedParameters\": false,\n    \"types\": [\"bun\"]\n  },\n  \"include\": [\"src/**/*.ts\"],\n  \"exclude\": [\"node_modules\", \"dist\"]\n}","truncated":false,"loaded":[]},"time":{"start":1773433281537,"end":1773433281685}}}}
