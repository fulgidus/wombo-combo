{"type":"tool_use","timestamp":1773481728344,"sessionID":"ses_3144090b0ffeCEU4EeqeWovYRR","part":{"id":"prt_cebbf98ee001je7TFGZ3mhs83q","sessionID":"ses_3144090b0ffeCEU4EeqeWovYRR","messageID":"msg_cebbf9012001idFr9N9BXH2pAj","type":"tool","callID":"toolu_vrtx_01VQ5eJocDx5dN4EwTAr86dx","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/tui-sort-keybind/src/lib/tui-browser.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/tui-sort-keybind/src/lib/tui-browser.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tui-browser.ts — Task browser view for the wombo-combo TUI.\n3:  *\n4:  * Shows all tasks organized by dependency streams with checkboxes for\n5:  * selection. Users can evaluate tasks, order them, select/deselect\n6:  * entire streams, and launch a wave with the selected tasks.\n7:  *\n8:  * Layout:\n9:  *   ┌───────────────────────────────────────────────────────┐\n10:  *   │ WOMBO-COMBO Task Browser  │ 42 tasks │ 5 selected    │\n11:  *   ├──────────────────────────────┬────────────────────────┤\n12:  *   │ ☑ json-features-check  done │ Title: ...             │\n13:  *   │ ☑ json-features-arch   done │ Status: backlog        │\n14:  *   │   ☐ json-ops-commands  back │ Priority: high         │\n15:  *   │ ── stream 2 ──              │ Effort: PT6H           │\n16:  *   │ ☐ tdd-test-detection   done │ Depends on:            │\n17:  *   │ ...                         │   - json-ops-commands  │\n18:  *   ├──────────────────────────────┴────────────────────────┤\n19:  *   │ Space:toggle  S:stream  L:launch  Tab:sort  Q:quit   │\n20:  *   └───────────────────────────────────────────────────────┘\n21:  *\n22:  * Keybinds:\n23:  *   Space     — toggle selection of current task\n24:  *   S         — toggle entire stream (select/deselect all tasks in the group)\n25:  *   A         — select all / deselect all (toggle)\n26:  *   L         — launch selected tasks as a new wave\n27:  *   Tab       — cycle sort field (priority → status → name → effort → stream)\n28:  *   +/-       — change priority of selected task\n29:  *   Enter     — expand/collapse task detail inline\n30:  *   D         — toggle show done tasks (filter)\n31:  *   C         — cycle concurrency level\n32:  *   Q / C-c   — quit (saves session)\n33:  */\n34: \n35: import blessed from \"neo-blessed\";\n36: import type { Widgets } from \"neo-blessed\";\n37: import type { Task, TasksFile, Priority } from \"./tasks.js\";\n38: import { loadTasks, loadArchive, parseDurationMinutes, formatDuration, areDependenciesMet, getDoneTaskIds } from \"./tasks.js\";\n39: import { saveTaskToStore, saveTaskToArchive, removeTaskFromStore } from \"./task-store.js\";\n40: import { PRIORITY_ORDER, DIFFICULTY_ORDER } from \"./task-schema.js\";\n41: import type { TUISession, SortField } from \"./tui-session.js\";\n42: import { saveTUISession } from \"./tui-session.js\";\n43: import type { WomboConfig } from \"../config.js\";\n44: \n45: // ---------------------------------------------------------------------------\n46: // Types\n47: // ---------------------------------------------------------------------------\n48: \n49: export interface TaskBrowserOptions {\n50:   projectRoot: string;\n51:   config: WomboConfig;\n52:   session: TUISession;\n53:   /** Called when user presses L to launch selected tasks */\n54:   onLaunch: (selectedIds: string[]) => void;\n55:   /** Called when user presses q to quit */\n56:   onQuit: () => void;\n57:   /** Called when user presses Escape to go back to quest picker */\n58:   onBack?: () => void;\n59:   /** Called when user presses Tab to switch to wave monitor (if a wave is running) */\n60:   onSwitchToMonitor?: () => void;\n61:   /** Called when user presses E to create an errand (quest-less assisted task) */\n62:   onErrand?: () => void;\n63:   /** If set, filter to only tasks belonging to this quest */\n64:   questId?: string | null;\n65:   /** Human-readable quest title for header display */\n66:   questTitle?: string;\n67:   /** Task IDs belonging to the selected quest (used for filtering) */\n68:   questTaskIds?: string[];\n69: }\n70: \n71: /**\n72:  * A task node in the display tree with computed metadata.\n73:  */\n74: interface TaskNode {\n75:   task: Task;\n76:   /** Depth in the dependency chain (0 = leaf/no deps, higher = depends on more) */\n77:   depth: number;\n78:   /** ID of the stream (connected component) this task belongs to */\n79:   streamId: string;\n80:   /** Task IDs that depend on this task */\n81:   dependedOnBy: string[];\n82: }\n83: \n84: /**\n85:  * A stream is a group of related tasks connected by dependencies.\n86:  */\n87: interface Stream {\n88:   id: string;\n89:   nodes: TaskNode[];\n90: }\n91: \n92: // ---------------------------------------------------------------------------\n93: // Status / Priority display helpers\n94: // ---------------------------------------------------------------------------\n95: \n96: const STATUS_ABBREV: Record<string, string> = {\n97:   backlog: \"BACK\",\n98:   planned: \"PLAN\",\n99:   in_progress: \"PROG\",\n100:   blocked: \"BLKD\",\n101:   in_review: \"REVW\",\n102:   done: \"DONE\",\n103:   cancelled: \"CANC\",\n104: };\n105: \n106: const STATUS_COLORS: Record<string, string> = {\n107:   backlog: \"gray\",\n108:   planned: \"blue\",\n109:   in_progress: \"cyan\",\n110:   blocked: \"red\",\n111:   in_review: \"yellow\",\n112:   done: \"green\",\n113:   cancelled: \"gray\",\n114: };\n115: \n116: const PRIORITY_ABBREV: Record<string, string> = {\n117:   critical: \"CRIT\",\n118:   high: \"HIGH\",\n119:   medium: \"MED \",\n120:   low: \"LOW \",\n121:   wishlist: \"WISH\",\n122: };\n123: \n124: const PRIORITY_COLORS: Record<string, string> = {\n125:   critical: \"red\",\n126:   high: \"yellow\",\n127:   medium: \"white\",\n128:   low: \"gray\",\n129:   wishlist: \"gray\",\n130: };\n131: \n132: // ---------------------------------------------------------------------------\n133: // Helpers\n134: // ---------------------------------------------------------------------------\n135: \n136: function escapeBlessedTags(text: string): string {\n137:   return text.replace(/\\{/g, \"\\uFF5B\").replace(/\\}/g, \"\\uFF5D\");\n138: }\n139: \n140: const SORT_FIELDS: SortField[] = [\"priority\", \"status\", \"name\", \"effort\", \"stream\"];\n141: \n142: // ---------------------------------------------------------------------------\n143: // Task Graph Builder\n144: // ---------------------------------------------------------------------------\n145: \n146: /**\n147:  * Build a dependency graph from all tasks and organize them into streams\n148:  * (connected components). Within each stream, tasks are topologically sorted.\n149:  */\n150: function buildTaskGraph(tasks: Task[]): Stream[] {\n151:   const taskMap = new Map<string, Task>();\n152:   for (const t of tasks) taskMap.set(t.id, t);\n153: \n154:   // Build reverse dependency map (who depends on me?)\n155:   const dependedOnBy = new Map<string, string[]>();\n156:   for (const t of tasks) {\n157:     for (const dep of t.depends_on) {\n158:       if (!dependedOnBy.has(dep)) dependedOnBy.set(dep, []);\n159:       dependedOnBy.get(dep)!.push(t.id);\n160:     }\n161:   }\n162: \n163:   // Find connected components using undirected graph traversal\n164:   const visited = new Set<string>();\n165:   const components: string[][] = [];\n166: \n167:   function dfs(id: string, component: string[]): void {\n168:     if (visited.has(id)) return;\n169:     if (!taskMap.has(id)) return; // dep references a task not in our list\n170:     visited.add(id);\n171:     component.push(id);\n172:     // Follow forward deps\n173:     const task = taskMap.get(id)!;\n174:     for (const dep of task.depends_on) dfs(dep, component);\n175:     // Follow reverse deps\n176:     for (const rev of (dependedOnBy.get(id) ?? [])) dfs(rev, component);\n177:   }\n178: \n179:   for (const t of tasks) {\n180:     if (!visited.has(t.id)) {\n181:       const comp: string[] = [];\n182:       dfs(t.id, comp);\n183:       components.push(comp);\n184:     }\n185:   }\n186: \n187:   // For each component, compute depths and sort topologically\n188:   const streams: Stream[] = [];\n189:   for (const comp of components) {\n190:     // Compute depth: longest path from any leaf (task with no deps in this component)\n191:     const depthMap = new Map<string, number>();\n192:     const compSet = new Set(comp);\n193: \n194:     function computeDepth(id: string, visiting: Set<string>): number {\n195:       if (depthMap.has(id)) return depthMap.get(id)!;\n196:       if (visiting.has(id)) return 0; // cycle protection\n197:       visiting.add(id);\n198:       const task = taskMap.get(id);\n199:       if (!task) return 0;\n200:       let maxDepth = 0;\n201:       for (const dep of task.depends_on) {\n202:         if (compSet.has(dep)) {\n203:           maxDepth = Math.max(maxDepth, 1 + computeDepth(dep, visiting));\n204:         }\n205:       }\n206:       visiting.delete(id);\n207:       depthMap.set(id, maxDepth);\n208:       return maxDepth;\n209:     }\n210: \n211:     for (const id of comp) computeDepth(id, new Set());\n212: \n213:     // Sort: by depth ascending (leaves first), then by priority\n214:     const sorted = [...comp].sort((a, b) => {\n215:       const dA = depthMap.get(a) ?? 0;\n216:       const dB = depthMap.get(b) ?? 0;\n217:       if (dA !== dB) return dA - dB;\n218:       const tA = taskMap.get(a)!;\n219:       const tB = taskMap.get(b)!;\n220:       return PRIORITY_ORDER[tA.priority] - PRIORITY_ORDER[tB.priority];\n221:     });\n222: \n223:     // Use the deepest task's ID as the stream ID (it's the \"root\" task)\n224:     const maxDepthId = sorted[sorted.length - 1];\n225:     const streamId = maxDepthId;\n226: \n227:     const nodes: TaskNode[] = sorted.map((id) => ({\n228:       task: taskMap.get(id)!,\n229:       depth: depthMap.get(id) ?? 0,\n230:       streamId,\n231:       dependedOnBy: (dependedOnBy.get(id) ?? []).filter((d) => compSet.has(d)),\n232:     }));\n233: \n234:     streams.push({ id: streamId, nodes });\n235:   }\n236: \n237:   // Sort streams by highest-priority task in each\n238:   streams.sort((a, b) => {\n239:     const bestA = Math.min(...a.nodes.map((n) => PRIORITY_ORDER[n.task.priority]));\n240:     const bestB = Math.min(...b.nodes.map((n) => PRIORITY_ORDER[n.task.priority]));\n241:     return bestA - bestB;\n242:   });\n243: \n244:   return streams;\n245: }\n246: \n247: // ---------------------------------------------------------------------------\n248: // Task Browser Class\n249: // ---------------------------------------------------------------------------\n250: \n251: export class TaskBrowser {\n252:   private screen: Widgets.Screen;\n253:   private headerBox: Widgets.BoxElement;\n254:   private taskList: Widgets.ListElement;\n255:   private detailBox: Widgets.BoxElement;\n256:   private statusBar: Widgets.BoxElement;\n257: \n258:   private projectRoot: string;\n259:   private config: WomboConfig;\n260:   private session: TUISession;\n261:   private onLaunch: (selectedIds: string[]) => void;\n262:   private onQuit: () => void;\n263:   private onBack?: () => void;\n264:   private onSwitchToMonitor?: () => void;\n265:   private onErrand?: () => void;\n266: \n267:   /** Quest filtering */\n268:   private questId: string | null = null;\n269:   private questTitle: string | null = null;\n270:   private questTaskIds: Set<string> | null = null;\n271: \n272:   private allTasks: Task[] = [];\n273:   private archiveTasks: Task[] = [];\n274:   private doneIds: Set<string> = new Set();\n275:   private streams: Stream[] = [];\n276:   /** Flat ordered list of task nodes as displayed */\n277:   private displayNodes: TaskNode[] = [];\n278:   private selectedIndex: number = 0;\n279:   private selected: Set<string>;\n280:   private collapsed: Set<string>;\n281:   private hideDone: boolean = false;\n282:   private refreshTimer: ReturnType<typeof setInterval> | null = null;\n283:   private hasRunningWave: boolean = false;\n284: \n285:   constructor(opts: TaskBrowserOptions) {\n286:     this.projectRoot = opts.projectRoot;\n287:     this.config = opts.config;\n288:     this.session = opts.session;\n289:     this.onLaunch = opts.onLaunch;\n290:     this.onQuit = opts.onQuit;\n291:     this.onBack = opts.onBack;\n292:     this.onSwitchToMonitor = opts.onSwitchToMonitor;\n293:     this.onErrand = opts.onErrand;\n294:     this.selected = new Set(opts.session.selected);\n295:     this.collapsed = new Set(opts.session.collapsed);\n296: \n297:     // Quest filtering\n298:     this.questId = opts.questId ?? null;\n299:     this.questTitle = opts.questTitle ?? null;\n300:     this.questTaskIds = opts.questTaskIds ? new Set(opts.questTaskIds) : null;\n301: \n302:     // Load tasks\n303:     this.reloadTasks();\n304: \n305:     // Create screen\n306:     this.screen = blessed.screen({\n307:       smartCSR: true,\n308:       title: this.questTitle\n309:         ? `wombo-combo -- ${this.questTitle}`\n310:         : \"wombo-combo -- Task Browser\",\n311:       fullUnicode: true,\n312:     });\n313: \n314:     // Header\n315:     this.headerBox = blessed.box({\n316:       top: 0,\n317:       left: 0,\n318:       width: \"100%\",\n319:       height: 3,\n320:       tags: true,\n321:       style: { fg: \"white\", bg: \"black\" },\n322:     });\n323: \n324:     // Task list (left pane)\n325:     this.taskList = blessed.list({\n326:       top: 3,\n327:       left: 0,\n328:       width: \"60%\",\n329:       height: \"100%-6\",\n330:       tags: true,\n331:       scrollable: true,\n332:       mouse: true,\n333:       keys: true,\n334:       vi: true,\n335:       border: { type: \"line\" },\n336:       style: {\n337:         border: { fg: \"gray\" },\n338:         selected: { bg: \"blue\", fg: \"white\", bold: true },\n339:         item: { fg: \"white\" },\n340:       },\n341:       label: \" Tasks \",\n342:     });\n343: \n344:     // Detail pane (right pane)\n345:     this.detailBox = blessed.box({\n346:       top: 3,\n347:       left: \"60%\",\n348:       width: \"40%\",\n349:       height: \"100%-6\",\n350:       tags: true,\n351:       scrollable: true,\n352:       mouse: true,\n353:       border: { type: \"line\" },\n354:       style: {\n355:         border: { fg: \"gray\" },\n356:         fg: \"white\",\n357:       },\n358:       label: \" Details \",\n359:     });\n360: \n361:     // Status bar\n362:     this.statusBar = blessed.box({\n363:       bottom: 0,\n364:       left: 0,\n365:       width: \"100%\",\n366:       height: 3,\n367:       tags: true,\n368:       style: { fg: \"white\", bg: \"black\" },\n369:     });\n370: \n371:     // Assemble\n372:     this.screen.append(this.headerBox);\n373:     this.screen.append(this.taskList);\n374:     this.screen.append(this.detailBox);\n375:     this.screen.append(this.statusBar);\n376:     this.taskList.focus();\n377: \n378:     this.bindKeys();\n379:   }\n380: \n381:   // -------------------------------------------------------------------------\n382:   // Public API\n383:   // -------------------------------------------------------------------------\n384: \n385:   start(): void {\n386:     this.buildDisplay();\n387:     this.refresh();\n388:     this.screen.render();\n389:   }\n390: \n391:   stop(): void {\n392:     this.saveSession();\n393:     if (this.refreshTimer) {\n394:       clearInterval(this.refreshTimer);\n395:       this.refreshTimer = null;\n396:     }\n397:     this.screen.destroy();\n398:   }\n399: \n400:   /**\n401:    * Destroy the browser screen without saving session (caller already saved).\n402:    * Used by the TUI orchestrator after receiving onLaunch — the transition\n403:    * message is already displayed, so we just tear down the blessed screen\n404:    * and clear the terminal for the next view.\n405:    */\n406:   destroy(): void {\n407:     if (this.refreshTimer) {\n408:       clearInterval(this.refreshTimer);\n409:       this.refreshTimer = null;\n410:     }\n411:     this.screen.destroy();\n412:     // Clear terminal so the next view starts fresh\n413:     process.stdout.write(\"\\x1B[2J\\x1B[H\");\n414:   }\n415: \n416:   /** Let the orchestrator tell us a wave is running (enables Tab to switch) */\n417:   setHasRunningWave(running: boolean): void {\n418:     this.hasRunningWave = running;\n419:     this.refreshStatusBar();\n420:     this.screen.render();\n421:   }\n422: \n423:   // -------------------------------------------------------------------------\n424:   // Task Loading\n425:   // -------------------------------------------------------------------------\n426: \n427:   private reloadTasks(): void {\n428:     const tasksData = loadTasks(this.projectRoot, this.config);\n429:     const archiveData = loadArchive(this.projectRoot, this.config);\n430: \n431:     // Filter tasks by quest if a quest is selected\n432:     if (this.questTaskIds) {\n433:       this.allTasks = tasksData.tasks.filter((t) => this.questTaskIds!.has(t.id));\n434:     } else {\n435:       this.allTasks = tasksData.tasks;\n436:     }\n437: \n438:     this.archiveTasks = archiveData.tasks;\n439:     this.doneIds = getDoneTaskIds(tasksData, this.archiveTasks);\n440:     this.streams = buildTaskGraph(this.allTasks);\n441: \n442:     // Prune selected IDs that no longer exist\n443:     const validIds = new Set(this.allTasks.map((t) => t.id));\n444:     for (const id of this.selected) {\n445:       if (!validIds.has(id)) this.selected.delete(id);\n446:     }\n447:   }\n448: \n449:   // -------------------------------------------------------------------------\n450:   // Display Building\n451:   // -------------------------------------------------------------------------\n452: \n453:   private buildDisplay(): void {\n454:     this.displayNodes = [];\n455:     const sortedStreams = this.sortStreams(this.streams);\n456: \n457:     for (const stream of sortedStreams) {\n458:       const sortedNodes = this.sortNodesInStream(stream.nodes);\n459:       for (const node of sortedNodes) {\n460:         if (this.hideDone && node.task.status === \"done\") continue;\n461:         this.displayNodes.push(node);\n462:       }\n463:     }\n464:   }\n465: \n466:   private sortStreams(streams: Stream[]): Stream[] {\n467:     const field = this.session.sortBy;\n468:     const order = this.session.sortOrder === \"asc\" ? 1 : -1;\n469: \n470:     if (field === \"stream\") return streams; // natural grouping\n471: \n472:     return [...streams].sort((a, b) => {\n473:       const bestA = this.streamSortKey(a, field);\n474:       const bestB = this.streamSortKey(b, field);\n475:       return (bestA - bestB) * order;\n476:     });\n477:   }\n478: \n479:   private streamSortKey(stream: Stream, field: SortField): number {\n480:     switch (field) {\n481:       case \"priority\":\n482:         return Math.min(...stream.nodes.map((n) => PRIORITY_ORDER[n.task.priority]));\n483:       case \"effort\":\n484:         return Math.min(...stream.nodes.map((n) => parseDurationMinutes(n.task.effort)));\n485:       case \"status\": {\n486:         const STATUS_SORT: Record<string, number> = {\n487:           in_progress: 0, backlog: 1, planned: 2, blocked: 3,\n488:           in_review: 4, done: 5, cancelled: 6,\n489:         };\n490:         return Math.min(...stream.nodes.map((n) => STATUS_SORT[n.task.status] ?? 99));\n491:       }\n492:       case \"name\":\n493:         return 0; // alpha sort handled differently\n494:       default:\n495:         return 0;\n496:     }\n497:   }\n498: \n499:   private sortNodesInStream(nodes: TaskNode[]): TaskNode[] {\n500:     // Always sort by depth within a stream (topological order)\n501:     return [...nodes].sort((a, b) => a.depth - b.depth);\n502:   }\n503: \n504:   // -------------------------------------------------------------------------\n505:   // Key Bindings\n506:   // -------------------------------------------------------------------------\n507: \n508:   private bindKeys(): void {\n509:     // Quit (or go back to quest picker if in quest mode)\n510:     this.screen.key([\"q\", \"C-c\"], () => {\n511:       if (this.onBack && this.questId) {\n512:         // In quest-filtered mode: Q goes back to quest picker\n513:         this.saveSession();\n514:         this.destroy();\n515:         this.onBack();\n516:       } else {\n517:         this.stop();\n518:         this.onQuit();\n519:       }\n520:     });\n521: \n522:     // Escape -- go back to quest picker (always, if available)\n523:     this.screen.key([\"escape\"], () => {\n524:       if (this.onBack) {\n525:         this.saveSession();\n526:         this.destroy();\n527:         this.onBack();\n528:       }\n529:     });\n530: \n531:     // Navigate\n532:     this.taskList.on(\"select item\", (_item: any, index: number) => {\n533:       this.selectedIndex = index;\n534:       this.refreshDetail();\n535:       this.screen.render();\n536:     });\n537: \n538:     // Space — toggle selection\n539:     this.screen.key([\"space\"], () => {\n540:       this.toggleCurrent();\n541:     });\n542: \n543:     // s — toggle stream\n544:     this.screen.key([\"s\"], () => {\n545:       this.toggleStream();\n546:     });\n547: \n548:     // a — select all / deselect all\n549:     this.screen.key([\"a\"], () => {\n550:       this.toggleAll();\n551:     });\n552: \n553:     // l — launch selected\n554:     this.screen.key([\"l\"], () => {\n555:       this.launchSelected();\n556:     });\n557: \n558:     // Tab — cycle sort / switch to monitor\n559:     this.screen.key([\"tab\"], () => {\n560:       if (this.hasRunningWave && this.onSwitchToMonitor) {\n561:         this.saveSession();\n562:         this.stop();\n563:         this.onSwitchToMonitor();\n564:       } else {\n565:         this.cycleSort();\n566:       }\n567:     });\n568: \n569:     // F5 — cycle sort (alternative when Tab is used for view switch)\n570:     this.screen.key([\"f5\"], () => {\n571:       this.cycleSort();\n572:     });\n573: \n574:     // +/- — change priority\n575:     this.screen.key([\"+\", \"=\"], () => {\n576:       this.changePriority(-1); // higher priority (lower number)\n577:     });\n578:     this.screen.key([\"-\"], () => {\n579:       this.changePriority(1); // lower priority (higher number)\n580:     });\n581: \n582:     // d — toggle hide done\n583:     this.screen.key([\"d\"], () => {\n584:       this.hideDone = !this.hideDone;\n585:       this.buildDisplay();\n586:       this.refreshTaskList();\n587:       this.refreshHeader();\n588:       this.refreshStatusBar();\n589:       this.screen.render();\n590:     });\n591: \n592:     // x — archive done/cancelled tasks\n593:     this.screen.key([\"x\"], () => {\n594:       this.archiveDone();\n595:     });\n596: \n597:     // c — change concurrency\n598:     this.screen.key([\"c\"], () => {\n599:       this.cycleConcurrency();\n600:     });\n601: \n602:     // e — errand (quest-less assisted task generation)\n603:     this.screen.key([\"e\"], () => {\n604:       if (!this.onErrand) return;\n605:       this.saveSession();\n606:       this.destroy();\n607:       this.onErrand();\n608:     });\n609:   }\n610: \n611:   // -------------------------------------------------------------------------\n612:   // Actions\n613:   // -------------------------------------------------------------------------\n614: \n615:   private toggleCurrent(): void {\n616:     const node = this.displayNodes[this.selectedIndex];\n617:     if (!node) return;\n618:     if (this.selected.has(node.task.id)) {\n619:       this.selected.delete(node.task.id);\n620:     } else {\n621:       this.selected.add(node.task.id);\n622:     }\n623:     this.refreshTaskList();\n624:     this.refreshHeader();\n625:     this.refreshDetail();\n626:     this.refreshStatusBar();\n627:     this.screen.render();\n628:   }\n629: \n630:   private toggleStream(): void {\n631:     const node = this.displayNodes[this.selectedIndex];\n632:     if (!node) return;\n633:     const streamId = node.streamId;\n634:     const streamNodes = this.displayNodes.filter((n) => n.streamId === streamId);\n635: \n636:     // If all in stream are selected, deselect all; otherwise select all\n637:     const allSelected = streamNodes.every((n) => this.selected.has(n.task.id));\n638:     for (const n of streamNodes) {\n639:       if (allSelected) {\n640:         this.selected.delete(n.task.id);\n641:       } else {\n642:         this.selected.add(n.task.id);\n643:       }\n644:     }\n645: \n646:     this.refreshTaskList();\n647:     this.refreshHeader();\n648:     this.refreshDetail();\n649:     this.refreshStatusBar();\n650:     this.screen.render();\n651:   }\n652: \n653:   private toggleAll(): void {\n654:     const allSelected = this.displayNodes.every((n) => this.selected.has(n.task.id));\n655:     for (const n of this.displayNodes) {\n656:       if (allSelected) {\n657:         this.selected.delete(n.task.id);\n658:       } else {\n659:         this.selected.add(n.task.id);\n660:       }\n661:     }\n662:     this.refreshTaskList();\n663:     this.refreshHeader();\n664:     this.refreshStatusBar();\n665:     this.screen.render();\n666:   }\n667: \n668:   private launchSelected(): void {\n669:     if (this.selected.size === 0) return;\n670:     this.saveSession();\n671:     const ids = [...this.selected];\n672: \n673:     // Show a transition message on the existing screen before the caller\n674:     // destroys it — avoids jarring flash of raw console output.\n675:     try {\n676:       this.taskList.setContent(\"\");\n677:       this.detailBox.setContent(\"\");\n678:       this.statusBar.setContent(\"\");\n679:       this.headerBox.setContent(\n680:         ` {bold}{cyan-fg}Launching ${ids.length} task(s)...{/cyan-fg}{/bold}`\n681:       );\n682:       this.screen.render();\n683:     } catch {\n684:       // Screen may already be in a bad state — proceed regardless\n685:     }\n686: \n687:     this.onLaunch(ids);\n688:   }\n689: \n690:   private cycleSort(): void {\n691:     const idx = SORT_FIELDS.indexOf(this.session.sortBy);\n692:     this.session.sortBy = SORT_FIELDS[(idx + 1) % SORT_FIELDS.length];\n693:     this.buildDisplay();\n694:     this.selectedIndex = Math.min(this.selectedIndex, this.displayNodes.length - 1);\n695:     this.refreshTaskList();\n696:     this.refreshHeader();\n697:     this.refreshStatusBar();\n698:     this.screen.render();\n699:   }\n700: \n701:   private changePriority(delta: number): void {\n702:     const node = this.displayNodes[this.selectedIndex];\n703:     if (!node) return;\n704:     const priorities: Priority[] = [\"critical\", \"high\", \"medium\", \"low\", \"wishlist\"];\n705:     const currentIdx = priorities.indexOf(node.task.priority);\n706:     const newIdx = Math.max(0, Math.min(priorities.length - 1, currentIdx + delta));\n707:     if (newIdx === currentIdx) return;\n708: \n709:     node.task.priority = priorities[newIdx];\n710:     // Persist the change\n711:     saveTaskToStore(this.projectRoot, this.config, node.task);\n712:     this.refreshTaskList();\n713:     this.refreshDetail();\n714:     this.screen.render();\n715:   }\n716: \n717:   private cycleConcurrency(): void {\n718:     const levels = [1, 2, 3, 5, 8, 10, 15, 20];\n719:     const idx = levels.indexOf(this.session.maxConcurrent);\n720:     this.session.maxConcurrent = levels[(idx + 1) % levels.length];\n721:     this.refreshStatusBar();\n722:     this.screen.render();\n723:   }\n724: \n725:   /**\n726:    * Archive all done/cancelled tasks. If tasks are selected, only archive\n727:    * those that are done/cancelled. Otherwise archive ALL done/cancelled.\n728:    */\n729:   private archiveDone(): void {\n730:     const candidates =\n731:       this.selected.size > 0\n732:         ? this.allTasks.filter(\n733:             (t) => this.selected.has(t.id) && (t.status === \"done\" || t.status === \"cancelled\")\n734:           )\n735:         : this.allTasks.filter(\n736:             (t) => t.status === \"done\" || t.status === \"cancelled\"\n737:           );\n738: \n739:     if (candidates.length === 0) return;\n740: \n741:     for (const task of candidates) {\n742:       saveTaskToArchive(this.projectRoot, this.config, task);\n743:       removeTaskFromStore(this.projectRoot, this.config, task.id);\n744:       this.selected.delete(task.id);\n745:     }\n746: \n747:     // Reload from disk and rebuild the display\n748:     this.reloadTasks();\n749:     this.buildDisplay();\n750:     this.selectedIndex = Math.min(this.selectedIndex, Math.max(0, this.displayNodes.length - 1));\n751:     this.refresh();\n752:   }\n753: \n754:   // -------------------------------------------------------------------------\n755:   // Session Persistence\n756:   // -------------------------------------------------------------------------\n757: \n758:   private saveSession(): void {\n759:     this.session.selected = [...this.selected];\n760:     this.session.collapsed = [...this.collapsed];\n761:     saveTUISession(this.projectRoot, this.session);\n762:   }\n763: \n764:   // -------------------------------------------------------------------------\n765:   // Refresh Logic\n766:   // -------------------------------------------------------------------------\n767: \n768:   private refresh(): void {\n769:     this.refreshHeader();\n770:     this.refreshTaskList();\n771:     this.refreshDetail();\n772:     this.refreshStatusBar();\n773:     this.screen.render();\n774:   }\n775: \n776:   private refreshHeader(): void {\n777:     const total = this.allTasks.length;\n778:     const displayed = this.displayNodes.length;\n779:     const selectedCount = this.selected.size;\n780:     const doneCount = this.allTasks.filter((t) => t.status === \"done\").length;\n781:     const readyCount = this.allTasks.filter(\n782:       (t) => t.status === \"backlog\" && areDependenciesMet(t, this.doneIds)\n783:     ).length;\n784: \n785:     let line1 = ` {bold}wombo-combo{/bold}`;\n786:     if (this.questTitle) {\n787:       line1 += ` {magenta-fg}\\u25B6 ${escapeBlessedTags(this.questTitle)}{/magenta-fg}`;\n788:     } else {\n789:       line1 += ` {cyan-fg}Task Browser{/cyan-fg}`;\n790:     }\n791:     line1 += `  {gray-fg}|{/gray-fg}  {white-fg}${total}{/white-fg} tasks`;\n792:     if (this.hideDone) line1 += ` ({white-fg}${displayed}{/white-fg} shown)`;\n793:     line1 += `  {gray-fg}|{/gray-fg}  {green-fg}${selectedCount}{/green-fg} selected`;\n794: \n795:     let line2 = ` {green-fg}${doneCount}{/green-fg} done`;\n796:     line2 += `  {cyan-fg}${readyCount}{/cyan-fg} ready`;\n797:     line2 += `  {gray-fg}|{/gray-fg}  Sort: {yellow-fg}${this.session.sortBy}{/yellow-fg}`;\n798:     line2 += `  {gray-fg}|{/gray-fg}  Concurrency: {yellow-fg}${this.session.maxConcurrent}{/yellow-fg}`;\n799: \n800:     this.headerBox.setContent(`${line1}\\n${line2}`);\n801:   }\n802: \n803:   private refreshTaskList(): void {\n804:     const items: string[] = [];\n805:     let lastStreamId = \"\";\n806: \n807:     for (let i = 0; i < this.displayNodes.length; i++) {\n808:       const node = this.displayNodes[i];\n809:       const t = node.task;\n810: \n811:       // Stream separator\n812:       if (node.streamId !== lastStreamId && lastStreamId !== \"\") {\n813:         // We use a visual separator row — but it's not selectable in blessed list,\n814:         // so we just change the color/style\n815:       }\n816:       lastStreamId = node.streamId;\n817: \n818:       // Checkbox\n819:       const isSelected = this.selected.has(t.id);\n820:       const checkbox = isSelected\n821:         ? \"{green-fg}\\u2611{/green-fg}\" // ☑\n822:         : \"{gray-fg}\\u2610{/gray-fg}\";  // ☐\n823: \n824:       // Indent based on depth\n825:       const indent = \"  \".repeat(node.depth);\n826: \n827:       // Dependency readiness indicator\n828:       const depsReady = areDependenciesMet(t, this.doneIds);\n829:       const readyIcon = t.status === \"done\"\n830:         ? \"{green-fg}\\u2713{/green-fg}\"   // ✓\n831:         : depsReady\n832:           ? \"{cyan-fg}\\u25CF{/cyan-fg}\"   // ● ready\n833:           : \"{red-fg}\\u25CB{/red-fg}\";     // ○ blocked\n834: \n835:       // Task ID (truncated)\n836:       const maxIdLen = 26 - node.depth * 2;\n837:       const fid = t.id.length > maxIdLen\n838:         ? t.id.slice(0, maxIdLen - 1) + \"\\u2026\"\n839:         : t.id.padEnd(maxIdLen);\n840: \n841:       // Priority\n842:       const pColor = PRIORITY_COLORS[t.priority] ?? \"white\";\n843:       const pAbbr = PRIORITY_ABBREV[t.priority] ?? t.priority.slice(0, 4).toUpperCase();\n844:       const priority = `{${pColor}-fg}${pAbbr}{/${pColor}-fg}`;\n845: \n846:       // Status\n847:       const sColor = STATUS_COLORS[t.status] ?? \"white\";\n848:       const sAbbr = STATUS_ABBREV[t.status] ?? t.status.slice(0, 4).toUpperCase();\n849:       const status = `{${sColor}-fg}${sAbbr}{/${sColor}-fg}`;\n850: \n851:       // Effort\n852:       const effort = formatDuration(parseDurationMinutes(t.effort));\n853: \n854:       items.push(\n855:         ` ${checkbox} ${indent}${readyIcon} ${fid} ${priority} ${status} {gray-fg}${effort}{/gray-fg}`\n856:       );\n857:     }\n858: \n859:     if (items.length === 0) {\n860:       items.push(\" {gray-fg}No tasks found{/gray-fg}\");\n861:     }\n862: \n863:     const prevSelected = this.selectedIndex;\n864:     this.taskList.setItems(items as any);\n865:     if (prevSelected < items.length) {\n866:       this.taskList.select(prevSelected);\n867:     }\n868:   }\n869: \n870:   private refreshDetail(): void {\n871:     const node = this.displayNodes[this.selectedIndex];\n872:     if (!node) {\n873:       this.detailBox.setContent(\"{gray-fg}No task selected{/gray-fg}\");\n874:       return;\n875:     }\n876: \n877:     const t = node.task;\n878:     const lines: string[] = [];\n879: \n880:     // Title\n881:     lines.push(`{bold}{white-fg}${escapeBlessedTags(t.title)}{/white-fg}{/bold}`);\n882:     lines.push(\"\");\n883: \n884:     // Status & Priority\n885:     const sColor = STATUS_COLORS[t.status] ?? \"white\";\n886:     lines.push(`  Status:     {${sColor}-fg}${t.status}{/${sColor}-fg}`);\n887:     const pColor = PRIORITY_COLORS[t.priority] ?? \"white\";\n888:     lines.push(`  Priority:   {${pColor}-fg}${t.priority}{/${pColor}-fg}  {gray-fg}(+/- to change){/gray-fg}`);\n889:     lines.push(`  Difficulty:  ${t.difficulty}`);\n890:     lines.push(`  Effort:      ${formatDuration(parseDurationMinutes(t.effort))}`);\n891:     lines.push(`  Completion:  ${t.completion}%`);\n892: \n893:     // Selection state\n894:     const isSelected = this.selected.has(t.id);\n895:     lines.push(`  Selected:   ${isSelected ? \"{green-fg}yes{/green-fg}\" : \"{gray-fg}no{/gray-fg}\"}`);\n896: \n897:     // Dependency readiness\n898:     const depsReady = areDependenciesMet(t, this.doneIds);\n899:     lines.push(`  Deps ready: ${depsReady ? \"{green-fg}yes{/green-fg}\" : \"{red-fg}no{/red-fg}\"}`);\n900: \n901:     // Stream info\n902:     lines.push(`  Stream:      ${node.streamId}`);\n903:     lines.push(`  Depth:       ${node.depth}`);\n904:     lines.push(\"\");\n905: \n906:     // Dependencies\n907:     if (t.depends_on.length > 0) {\n908:       lines.push(\"{bold}Dependencies:{/bold}\");\n909:       for (const dep of t.depends_on) {\n910:         const isDone = this.doneIds.has(dep);\n911:         const icon = isDone ? \"{green-fg}\\u2713{/green-fg}\" : \"{red-fg}\\u2717{/red-fg}\";\n912:         lines.push(`  ${icon} ${dep}`);\n913:       }\n914:       lines.push(\"\");\n915:     }\n916: \n917:     // Depended on by\n918:     if (node.dependedOnBy.length > 0) {\n919:       lines.push(\"{bold}Depended on by:{/bold}\");\n920:       for (const id of node.dependedOnBy) {\n921:         lines.push(`  \\u2192 ${id}`);\n922:       }\n923:       lines.push(\"\");\n924:     }\n925: \n926:     // Description\n927:     if (t.description) {\n928:       lines.push(\"{bold}Description:{/bold}\");\n929:       const desc = escapeBlessedTags(t.description.trim());\n930:       // Word-wrap to roughly 38 chars\n931:       const words = desc.split(/\\s+/);\n932:       let line = \" \";\n933:       for (const w of words) {\n934:         if (line.length + w.length > 36) {\n935:           lines.push(line);\n936:           line = \" \" + w;\n937:         } else {\n938:           line += \" \" + w;\n939:         }\n940:       }\n941:       if (line.trim()) lines.push(line);\n942:       lines.push(\"\");\n943:     }\n944: \n945:     // Agent type\n946:     if (t.agent_type) {\n947:       lines.push(`{bold}Agent:{/bold} ${escapeBlessedTags(t.agent_type)}`);\n948:     }\n949: \n950:     // Constraints\n951:     if (t.constraints.length > 0) {\n952:       lines.push(\"{bold}Constraints:{/bold}\");\n953:       for (const c of t.constraints) {\n954:         lines.push(`  \\u2022 ${escapeBlessedTags(c)}`);\n955:       }\n956:     }\n957: \n958:     this.detailBox.setContent(lines.join(\"\\n\"));\n959:     this.detailBox.setLabel(` ${t.id} `);\n960:   }\n961: \n962:   private refreshStatusBar(): void {\n963:     const selCount = this.selected.size;\n964:     const readyInSelection = [...this.selected].filter((id) => {\n965:       const t = this.allTasks.find((tt) => tt.id === id);\n966:       return t && (t.status === \"backlog\" || t.status === \"planned\") && areDependenciesMet(t, this.doneIds);\n967:     }).length;\n968: \n969:     let line1 = ` {bold}Keys:{/bold}`;\n970:     line1 += `  {gray-fg}Space{/gray-fg} toggle`;\n971:     line1 += `  {gray-fg}S{/gray-fg} stream`;\n972:     line1 += `  {gray-fg}A{/gray-fg} all`;\n973:     line1 += `  {gray-fg}+/-{/gray-fg} priority`;\n974:     line1 += `  {gray-fg}D{/gray-fg} ${this.hideDone ? \"show\" : \"hide\"} done`;\n975:     line1 += `  {gray-fg}X{/gray-fg} archive done`;\n976:     line1 += `  {gray-fg}C{/gray-fg} concurrency`;\n977:     if (this.onErrand) {\n978:       line1 += `  {gray-fg}E{/gray-fg} errand`;\n979:     }\n980:     line1 += `  {gray-fg}F5{/gray-fg} sort`;\n981: \n982:     if (selCount > 0) {\n983:       line1 += `  {bold}{green-fg}L{/green-fg} LAUNCH (${selCount}){/bold}`;\n984:     }\n985:     if (this.hasRunningWave) {\n986:       line1 += `  {gray-fg}Tab{/gray-fg} monitor`;\n987:     }\n988:     if (this.onBack) {\n989:       line1 += `  {gray-fg}Esc{/gray-fg} back`;\n990:     }\n991:     if (this.questId) {\n992:       line1 += `  {gray-fg}Q{/gray-fg} back`;\n993:     } else {\n994:       line1 += `  {gray-fg}Q{/gray-fg} quit`;\n995:     }\n996: \n997:     let line2 = ` `;\n998:     if (selCount > 0) {\n999:       line2 += `{green-fg}${selCount}{/green-fg} selected`;\n1000:       line2 += `  {cyan-fg}${readyInSelection}{/cyan-fg} launchable now`;\n1001:       const doneInSel = [...this.selected].filter((id) => {\n1002:         const t = this.allTasks.find((tt) => tt.id === id);\n1003:         return t?.status === \"done\";\n1004:       }).length;\n1005:       if (doneInSel > 0) {\n1006:         line2 += `  {yellow-fg}${doneInSel} already done (will be skipped){/yellow-fg}`;\n1007:       }\n1008:     } else {\n1009:       line2 += `{gray-fg}Select tasks with Space, then press L to launch{/gray-fg}`;  \n1010:     }\n1011: \n1012:     this.statusBar.setContent(`${line1}\\n${line2}`);\n1013:   }\n1014: }\n\n(End of file - total 1014 lines)\n</content>","title":"src/lib/tui-browser.ts","metadata":{"preview":"/**\n * tui-browser.ts — Task browser view for the wombo-combo TUI.\n *\n * Shows all tasks organized by dependency streams with checkboxes for\n * selection. Users can evaluate tasks, order them, select/deselect\n * entire streams, and launch a wave with the selected tasks.\n *\n * Layout:\n *   ┌───────────────────────────────────────────────────────┐\n *   │ WOMBO-COMBO Task Browser  │ 42 tasks │ 5 selected    │\n *   ├──────────────────────────────┬────────────────────────┤\n *   │ ☑ json-features-check  done │ Title: ...             │\n *   │ ☑ json-features-arch   done │ Status: backlog        │\n *   │   ☐ json-ops-commands  back │ Priority: high         │\n *   │ ── stream 2 ──              │ Effort: PT6H           │\n *   │ ☐ tdd-test-detection   done │ Depends on:            │\n *   │ ...                         │   - json-ops-commands  │\n *   ├──────────────────────────────┴────────────────────────┤\n *   │ Space:toggle  S:stream  L:launch  Tab:sort  Q:quit   │\n *   └───────────────────────────────────────────────────────┘","truncated":false,"loaded":[]},"time":{"start":1773481728328,"end":1773481728342}}}}
