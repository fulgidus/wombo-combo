{"type":"tool_use","timestamp":1773436222913,"sessionID":"ses_316fcb4c5ffehqcHU7q5TvsiXt","part":{"id":"prt_ce90939a0001cQkCJBNTnPsaag","sessionID":"ses_316fcb4c5ffehqcHU7q5TvsiXt","messageID":"msg_ce9093055001QeWdFgG9ez9JdO","type":"tool","callID":"toolu_vrtx_01UScx3wLZWVrvvURJW5Hb8P","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-json-operational-commands/src/commands/launch.ts","offset":1452},"output":"<path>/home/fulgidus/Documents/wt-wombo-json-operational-commands/src/commands/launch.ts</path>\n<type>file</type>\n<content>1452:     const preflight = isTTY && !opts.noTui\n1453:       ? await tuiPreflightConfirm(selected, agentResolutions, config)\n1454:       : await consolePreflightConfirm(selected, agentResolutions, config);\n1455: \n1456:     if (!preflight.proceed) {\n1457:       console.log(\"Launch cancelled.\\n\");\n1458:       return;\n1459:     }\n1460: \n1461:     // Apply user's changes (rejected agents, mode changes)\n1462:     agentResolutions = preflight.agents;\n1463:   }\n1464: \n1465:   // Create wave state\n1466:   const state = createWaveState({\n1467:     baseBranch: opts.baseBranch,\n1468:     maxConcurrent: opts.maxConcurrent,\n1469:     model: opts.model ?? null,\n1470:     interactive: opts.interactive,\n1471:   });\n1472: \n1473:   // Store serialized schedule plan in wave state\n1474:   if (schedulePlan) {\n1475:     state.schedule_plan = {\n1476:       streams: schedulePlan.streams.map((s) => s.featureIds),\n1477:       merge_gates: schedulePlan.mergeGates.map((g) => ({\n1478:         feature_id: g.featureId,\n1479:         wait_for: g.waitFor,\n1480:       })),\n1481:       topological_order: schedulePlan.topologicalOrder,\n1482:     };\n1483:   }\n1484: \n1485:   // Create agent entries for all selected features\n1486:   const selectedIds = new Set(selected.map((f) => f.id));\n1487: \n1488:   // Build a map from feature ID → shared worktree path for chain reuse.\n1489:   // All features in the same chain share the worktree of the chain's first feature.\n1490:   const chainWorktreeMap = new Map<string, string>();\n1491:   if (schedulePlan) {\n1492:     for (const stream of schedulePlan.streams) {\n1493:       if (stream.featureIds.length > 1) {\n1494:         // All features in this chain share the first feature's worktree\n1495:         const sharedWtPath = worktreePath(projectRoot, stream.featureIds[0], config);\n1496:         for (const featureId of stream.featureIds) {\n1497:           chainWorktreeMap.set(featureId, sharedWtPath);\n1498:         }\n1499:       }\n1500:     }\n1501:   }\n1502: \n1503:   for (const feature of selected) {\n1504:     const branch = featureBranchName(feature.id, config);\n1505:     // Use shared worktree path for chain members, or individual path otherwise\n1506:     const wtPath = chainWorktreeMap.get(feature.id) ?? worktreePath(projectRoot, feature.id, config);\n1507:     const agent = createAgentState(feature.id, branch, wtPath, opts.maxRetries);\n1508: \n1509:     // Set effort estimate from feature spec\n1510:     const effortMinutes = parseDurationMinutes(feature.effort);\n1511:     agent.effort_estimate_ms = effortMinutes === Infinity ? null : effortMinutes * 60 * 1000;\n1512: \n1513:     // Populate dependency fields from the graph\n1514:     const graphNode = depGraph.nodes.get(feature.id);\n1515:     if (graphNode) {\n1516:       // Only track internal deps (within the selected set)\n1517:       agent.depends_on = graphNode.dependsOn.filter((d) => selectedIds.has(d));\n1518:       agent.depended_on_by = graphNode.dependedOnBy.filter((d) => selectedIds.has(d));\n1519:     }\n1520: \n1521:     // Set stream index\n1522:     if (schedulePlan) {\n1523:       agent.stream_index = getStreamForFeature(schedulePlan, feature.id);\n1524:     }\n1525: \n1526:     // Set specialized agent info from resolution\n1527:     const resolution = agentResolutions?.get(feature.id);\n1528:     if (resolution && isSpecializedAgent(resolution)) {\n1529:       agent.agent_name = resolution.name;\n1530:       agent.agent_type = resolution.agentType;\n1531:     }\n1532: \n1533:     state.agents.push(agent);\n1534:   }\n1535: \n1536:   saveState(projectRoot, state);\n1537:   console.log(`Wave ${state.wave_id} created with ${selected.length} agents.`);\n1538: \n1539:   // Launch agents up to max_concurrent\n1540:   if (opts.interactive) {\n1541:     await launchWaveInteractive(projectRoot, state, selected, opts, agentResolutions);\n1542:   } else {\n1543:     await launchWaveHeadless(projectRoot, state, selected, opts, agentResolutions);\n1544:   }\n1545: }\n\n(End of file - total 1545 lines)\n</content>","title":"src/commands/launch.ts","metadata":{"preview":"    const preflight = isTTY && !opts.noTui\n      ? await tuiPreflightConfirm(selected, agentResolutions, config)\n      : await consolePreflightConfirm(selected, agentResolutions, config);\n\n    if (!preflight.proceed) {\n      console.log(\"Launch cancelled.\\n\");\n      return;\n    }\n\n    // Apply user's changes (rejected agents, mode changes)\n    agentResolutions = preflight.agents;\n  }\n\n  // Create wave state\n  const state = createWaveState({\n    baseBranch: opts.baseBranch,\n    maxConcurrent: opts.maxConcurrent,\n    model: opts.model ?? null,\n    interactive: opts.interactive,\n  });","truncated":false,"loaded":[]},"time":{"start":1773436222908,"end":1773436222912}}}}
