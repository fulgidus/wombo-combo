ty":4,"code":6133,"source":"typescript"},{"range":{"start":{"line":22,"character":7},"end":{"line":22,"character":16}},"message":"'WaveState' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"},{"range":{"start":{"line":49,"character":2},"end":{"line":49,"character":18}},"message":"'launchNextQueued' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"},{"range":{"start":{"line":90,"character":4},"end":{"line":90,"character":10}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"}],"/home/fulgidus/Documents/wt-wombo-json-operational-commands/src/commands/retry.ts":[{"range":{"start":{"line":16,"character":0},"end":{"line":16,"character":51}},"message":"'worktreeReady' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"},{"range":{"start":{"line":47,"character":4},"end":{"line":47,"character":10}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":59,"character":4},"end":{"line":59,"character":10}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":67,"character":4},"end":{"line":67,"character":10}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":107,"character":70},"end":{"line":107,"character":79}},"message":"'tasksFile' is deprecated.","severity":4,"code":6385,"source":"typescript","relatedInformation":[{"location":{"uri":"file:///home/fulgidus/Documents/wt-wombo-json-operational-commands/src/config.ts","range":{"start":{"line":30,"character":6},"end":{"line":30,"character":82}}},"message":"The declaration was marked as deprecated here."}]},{"range":{"start":{"line":108,"character":4},"end":{"line":108,"character":10}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"}],"/home/fulgidus/Documents/wt-w