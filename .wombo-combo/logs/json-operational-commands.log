{"type":"tool_use","timestamp":1773436219435,"sessionID":"ses_316fcb4c5ffehqcHU7q5TvsiXt","part":{"id":"prt_ce9092c99001rcJkL7a47yRvVO","sessionID":"ses_316fcb4c5ffehqcHU7q5TvsiXt","messageID":"msg_ce9092005001NkqmRH94jg3ttf","type":"tool","callID":"toolu_vrtx_016TzE5wFMBvQaXU32PE5rmS","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-json-operational-commands/src/commands/launch.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-json-operational-commands/src/commands/launch.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * launch.ts — Launch a wave of agents.\n3:  *\n4:  * Usage: woco launch [selection options] [launch options]\n5:  *\n6:  * This is the primary entry point for starting a new wave. It selects features\n7:  * from the features file, creates a wave state, sets up worktrees, and launches\n8:  * agent processes (either headless or interactive via dmux/tmux).\n9:  *\n10:  * IMPORTANT: This file also exports shared helper functions that are reused\n11:  * by resume.ts and other commands:\n12:  *   - launchSingleHeadless\n13:  *   - handleBuildVerification\n14:  *   - handleRetry\n15:  *   - launchNextQueued\n16:  */\n17: \n18: import { execSync } from \"node:child_process\";\n19: import { existsSync, readFileSync } from \"node:fs\";\n20: import { resolve } from \"node:path\";\n21: import type { WomboConfig } from \"../config.js\";\n22: import type { Feature, SelectionOptions, Priority, Difficulty } from \"../lib/tasks.js\";\n23: import { loadFeatures, selectFeatures, parseDurationMinutes, saveFeatures } from \"../lib/tasks.js\";\n24: import {\n25:   loadState,\n26:   saveState,\n27:   createWaveState,\n28:   createAgentState,\n29:   updateAgent,\n30:   activeAgents,\n31:   queuedAgents,\n32:   readyToLaunchAgents,\n33:   areAgentDepsReady,\n34:   cancelDownstream,\n35:   isWaveComplete,\n36:   type WaveState,\n37:   type AgentState,\n38:   type SerializedSchedulePlan,\n39: } from \"../lib/state.js\";\n40: import {\n41:   createWorktree,\n42:   installDeps,\n43:   featureBranchName,\n44:   worktreePath,\n45:   worktreeReady,\n46:   branchHasChanges,\n47:   branchExists,\n48:   removeWorktree,\n49:   log as wtLog,\n50: } from \"../lib/worktree.js\";\n51: import { generatePrompt, generateConflictResolutionPrompt } from \"../lib/prompt.js\";\n52: import {\n53:   launchHeadless,\n54:   retryHeadless,\n55:   launchInteractive,\n56:   retryInteractive,\n57:   launchConflictResolver,\n58:   isProcessRunning,\n59:   getMultiplexerName,\n60: } from \"../lib/launcher.js\";\n61: import { ProcessMonitor } from \"../lib/monitor.js\";\n62: import { runBuild, runFullVerification } from \"../lib/verifier.js\";\n63: import { mergeBranch, mergeBaseIntoFeature, pushBaseBranch, canMerge, enqueueMerge } from \"../lib/merger.js\";\n64: import {\n65:   printDashboard,\n66:   printFeatureSelection,\n67:   printAgentUpdate,\n68: } from \"../lib/ui.js\";\n69: import { WomboTUI } from \"../lib/tui.js\";\n70: import { ensureAgentDefinition } from \"../lib/templates.js\";\n71: import {\n72:   buildDepGraph,\n73:   validateDepGraph,\n74:   buildSchedulePlan,\n75:   formatSchedulePlan,\n76:   getStreamForFeature,\n77:   type DepGraph,\n78:   type SchedulePlan,\n79: } from \"../lib/dependency-graph.js\";\n80: import { ensureProxyRunning, isPortlessAvailable, portlessUrl } from \"../lib/portless.js\";\n81: import { output, outputError, outputMessage, type OutputFormat } from \"../lib/output.js\";\n82: import {\n83:   detectMultiplexer,\n84:   muxAttachCommand,\n85:   muxListCommand,\n86: } from \"../lib/multiplexer.js\";\n87: import { exportWaveHistory } from \"../lib/history.js\";\n88: import {\n89:   prepareAgentDefinitions,\n90:   isSpecializedAgent,\n91:   writeAgentToWorktree,\n92:   type AgentResolution,\n93: } from \"../lib/agent-registry.js\";\n94: import { patchImportedAgent } from \"../lib/templates.js\";\n95: import {\n96:   tuiPreflightConfirm,\n97:   consolePreflightConfirm,\n98: } from \"../lib/preflight.js\";\n99: \n100: // ---------------------------------------------------------------------------\n101: // Types\n102: // ---------------------------------------------------------------------------\n103: \n104: export interface LaunchCommandOptions {\n105:   projectRoot: string;\n106:   config: WomboConfig;\n107:   // Selection\n108:   topPriority?: number;\n109:   quickestWins?: number;\n110:   priority?: Priority;\n111:   difficulty?: Difficulty;\n112:   features?: string[];\n113:   allReady?: boolean;\n114:   // Launch\n115:   maxConcurrent: number;\n116:   model?: string;\n117:   interactive: boolean;\n118:   dryRun: boolean;\n119:   baseBranch: string;\n120:   maxRetries: number;\n121:   noTui: boolean;\n122:   autoPush: boolean;\n123:   // Output\n124:   outputFmt?: OutputFormat;\n125: }\n126: \n127: // ---------------------------------------------------------------------------\n128: // Shared Helpers (exported for resume.ts and others)\n129: // ---------------------------------------------------------------------------\n130: \n131: /**\n132:  * Mark a feature as done in the features file after a successful merge.\n133:  * Updates status to \"done\", completion to 100, and sets ended_at.\n134:  *\n135:  * GUARD: Verifies that the feature branch has actually been merged into\n136:  * baseBranch before allowing the status change. This prevents callers\n137:  * from accidentally marking verified-but-unmerged features as done.\n138:  */\n139: export function markFeatureDone(\n140:   projectRoot: string,\n141:   featureId: string,\n142:   config: WomboConfig,\n143:   baseBranch: string\n144: ): void {\n145:   try {\n146:     // Verify the feature branch was actually merged into base\n147:     const branch = featureBranchName(featureId, config);\n148:     try {\n149:       execSync(`git merge-base --is-ancestor \"${branch}\" \"${baseBranch}\"`, {\n150:         cwd: projectRoot,\n151:         stdio: \"pipe\",\n152:       });\n153:     } catch {\n154:       // git merge-base --is-ancestor exits non-zero if NOT an ancestor\n155:       console.error(\n156:         `Warning: ${featureId} branch \"${branch}\" is not merged into \"${baseBranch}\" — refusing to mark as done`\n157:       );\n158:       return;\n159:     }\n160: \n161:     const data = loadFeatures(projectRoot, config);\n162:     const feature = data.tasks.find((f: Feature) => f.id === featureId);\n163:     if (feature && feature.status !== \"done\") {\n164:       feature.status = \"done\";\n165:       feature.completion = 100;\n166:       feature.ended_at = new Date().toISOString();\n167:       saveFeatures(projectRoot, config, data);\n168:     }\n169:   } catch (err: any) {\n170:     // Non-fatal — log but don't crash the wave\n171:     console.error(`Warning: failed to update feature status for ${featureId}: ${err.message}`);\n172:   }\n173: }\n174: \n175: /**\n176:  * Launch a single agent in headless mode.\n177:  * Sets up worktree, installs deps, generates prompt, launches agent process.\n178:  * If agentResolutions is provided and contains a specialized agent for this\n179:  * feature, the patched agent definition is written into the worktree.\n180:  */\n181: export async function launchSingleHeadless(\n182:   projectRoot: string,\n183:   state: WaveState,\n184:   agent: AgentState,\n185:   feature: Feature,\n186:   monitor: ProcessMonitor,\n187:   config: WomboConfig,\n188:   model?: string,\n189:   agentResolutions?: Map<string, AgentResolution>\n190: ): Promise<void> {\n191:   updateAgent(state, agent.feature_id, {\n192:     status: \"installing\",\n193:     started_at: new Date().toISOString(),\n194:     activity: \"setting up worktree...\",\n195:   });\n196:   saveState(projectRoot, state);\n197: \n198:   try {\n199:     // Check if this agent is reusing a chain predecessor's worktree\n200:     const isChainReuse = agent.depends_on.some((depId) => {\n201:       const depAgent = state.agents.find((a) => a.feature_id === depId);\n202:       return depAgent && depAgent.worktree === agent.worktree;\n203:     });\n204: \n205:     if (isChainReuse && worktreeReady(agent.worktree)) {\n206:       // Chain worktree reuse: the worktree already exists from a predecessor.\n207:       // Create a new branch for this feature and switch the worktree to it.\n208:       wtLog(agent.feature_id, \"reusing chain worktree — switching branch...\");\n209:       updateAgent(state, agent.feature_id, { activity: \"switching branch (chain reuse)...\" });\n210: \n211:       try {\n212:         // Create the new feature branch from base (in the worktree)\n213:         execSync(`git checkout -B \"${agent.branch}\" \"${state.base_branch}\"`, {\n214:           cwd: agent.worktree,\n215:           stdio: \"pipe\",\n216:         });\n217:         wtLog(agent.feature_id, `switched to branch ${agent.branch}`);\n218:       } catch (branchErr: any) {\n219:         wtLog(agent.feature_id, `branch switch failed: ${branchErr.message}`);\n220:         // Fall through to normal worktree creation\n221:         await createWorktree(projectRoot, feature.id, state.base_branch, config);\n222:       }\n223:     } else if (worktreeReady(agent.worktree)) {\n224:       // Skip worktree setup if already ready (resume case)\n225:       wtLog(agent.feature_id, \"worktree already exists, skipping setup\");\n226:     } else {\n227:       // Create worktree (async — doesn't block other agents)\n228:       await createWorktree(projectRoot, feature.id, state.base_branch, config);\n229: \n230:       // Install dependencies (async)\n231:       updateAgent(state, agent.feature_id, { activity: \"installing deps...\" });\n232:       await installDeps(agent.worktree, feature.id, config);\n233:     }\n234: \n235:     // Generate prompt\n236:     const prompt = generatePrompt(feature, state.base_branch, config);\n237: \n238:     // Write specialized agent to worktree if applicable\n239:     const resolution = agentResolutions?.get(feature.id);\n240:     const agentName = agent.agent_name ?? undefined;\n241:     if (resolution && isSpecializedAgent(resolution)) {\n242:       try {\n243:         const patchedContent = patchImportedAgent(resolution.rawContent, config, projectRoot);\n244:         writeAgentToWorktree(agent.worktree, resolution.name, patchedContent);\n245:         wtLog(agent.feature_id, `wrote specialized agent: ${resolution.name}`);\n246:       } catch (err: any) {\n247:         wtLog(agent.feature_id, `WARN: failed to write specialized agent, using generalist: ${err.message}`);\n248:       }\n249:     }\n250: \n251:     // Launch agent\n252:     wtLog(agent.feature_id, \"launching agent...\");\n253:     const result = launchHeadless({\n254:       worktreePath: agent.worktree,\n255:       featureId: feature.id,\n256:       prompt,\n257:       model,\n258:       config,\n259:       agentName,\n260:     });\n261: \n262:     updateAgent(state, agent.feature_id, {\n263:       status: \"running\",\n264:       pid: result.pid,\n265:       activity: \"starting...\",\n266:     });\n267:     saveState(projectRoot, state);\n268: \n269:     monitor.addProcess(feature.id, result.process);\n270:     wtLog(agent.feature_id, `running (PID: ${result.pid})`);\n271:   } catch (err: any) {\n272:     updateAgent(state, agent.feature_id, {\n273:       status: \"failed\",\n274:       error: err.message,\n275:       activity: null,\n276:       completed_at: new Date().toISOString(),\n277:     });\n278:     saveState(projectRoot, state);\n279:     wtLog(agent.feature_id, `SETUP FAILED: ${err.message.split(\"\\n\")[0]}`);\n280:   }\n281: }\n282: \n283: /**\n284:  * Handle build verification after agent completion.\n285:  * Runs build, auto-merges on pass, retries on failure if retries remain.\n286:  *\n287:  * ASYNC — runs build and merge without blocking the event loop.\n288:  */\n289: export async function handleBuildVerification(\n290:   projectRoot: string,\n291:   state: WaveState,\n292:   agent: AgentState,\n293:   feature: Feature,\n294:   config: WomboConfig,\n295:   model?: string,\n296:   monitor?: ProcessMonitor\n297: ): Promise<void> {\n298:   try {\n299:     printAgentUpdate(agent, \"verifying build...\");\n300: \n301:     // Use full verification pipeline (build + optional browser tests)\n302:     const fullResult = await runFullVerification(agent.worktree, agent.feature_id, config);\n303:     const buildResult = fullResult.build;\n304: \n305:     // Report browser test status if they ran\n306:     if (fullResult.browser.ran && fullResult.browser.browserResult) {\n307:       const br = fullResult.browser.browserResult;\n308:       printAgentUpdate(\n309:         agent,\n310:         `BROWSER: ${br.summary} (${Math.round(br.totalDurationMs / 1000)}s)`\n311:       );\n312:     } else if (fullResult.browser.skipReason && config.browser.enabled) {\n313:       printAgentUpdate(agent, `BROWSER: skipped — ${fullResult.browser.skipReason}`);\n314:     }\n315: \n316:     if (fullResult.overallPassed) {\n317:       updateAgent(state, agent.feature_id, {\n318:         status: \"verified\",\n319:         build_passed: true,\n320:         build_output: null,\n321:       });\n322:       saveState(projectRoot, state);\n323:       printAgentUpdate(agent, `BUILD PASSED (${Math.round(buildResult.durationMs / 1000)}s)`);\n324: \n325:       // Auto-merge: attempt merge + conflict resolution\n326:       await attemptMerge(projectRoot, state, agent, feature, config, model);\n327:     } else {\n328:       const errorSummary = fullResult.combinedErrorSummary;\n329: \n330:       if (agent.retries < agent.max_retries) {\n331:         updateAgent(state, agent.feature_id, {\n332:           status: \"retry\",\n333:           retries: agent.retries + 1,\n334:           build_passed: false,\n335:           build_output: errorSummary,\n336:         });\n337:         saveState(projectRoot, state);\n338:         printAgentUpdate(\n339:           agent,\n340:           `VERIFICATION FAILED — retrying (${agent.retries}/${agent.max_retries})`\n341:         );\n342: \n343:         // Retry with error details\n344:         if (agent.session_id) {\n345:           const retryResult = retryHeadless({\n346:             worktreePath: agent.worktree,\n347:             featureId: agent.feature_id,\n348:             sessionId: agent.session_id,\n349:             buildErrors: errorSummary,\n350:             model,\n351:             config,\n352:           });\n353: \n354:           updateAgent(state, agent.feature_id, {\n355:             status: \"running\",\n356:             pid: retryResult.pid,\n357:           });\n358:           saveState(projectRoot, state);\n359: \n360:           // Add retry process to monitor so events are tracked\n361:           if (monitor) {\n362:             monitor.addProcess(agent.feature_id, retryResult.process);\n363:           }\n364:         }\n365:       } else {\n366:         updateAgent(state, agent.feature_id, {\n367:           status: \"failed\",\n368:           build_passed: false,\n369:           build_output: errorSummary,\n370:           error: `Verification failed after ${agent.max_retries} retries`,\n371:           completed_at: new Date().toISOString(),\n372:         });\n373:         saveState(projectRoot, state);\n374:         printAgentUpdate(agent, \"VERIFICATION FAILED — max retries reached\");\n375: \n376:         // Cascade failure to downstream agents\n377:         const cancelled = cancelDownstream(state, agent.feature_id);\n378:         if (cancelled.length > 0) {\n379:           printAgentUpdate(agent, `downstream cancelled: ${cancelled.join(\", \")}`);\n380:           saveState(projectRoot, state);\n381:         }\n382:       }\n383:     }\n384:   } catch (err: any) {\n385:     // Catch-all — never let build verification crash the process\n386:     printAgentUpdate(agent, `VERIFY ERROR: ${err.message?.slice(0, 100)}`);\n387:     updateAgent(state, agent.feature_id, {\n388:       status: \"failed\",\n389:       error: `Build verification error: ${err.message}`,\n390:       completed_at: new Date().toISOString(),\n391:     });\n392:     saveState(projectRoot, state);\n393:   }\n394: }\n395: \n396: /**\n397:  * Attempt to merge a verified agent's branch into the base branch.\n398:  *\n399:  * Handles conflict detection, base-into-feature merge, and resolver agent\n400:  * launch. Extracted from handleBuildVerification so it can be called\n401:  * independently (e.g., from resume's sequential merge phase).\n402:  *\n403:  * All merge operations are serialized via enqueueMerge() to prevent\n404:  * concurrent checkout races on the project root.\n405:  */\n406: export async function attemptMerge(\n407:   projectRoot: string,\n408:   state: WaveState,\n409:   agent: AgentState,\n410:   feature: Feature,\n411:   config: WomboConfig,\n412:   model?: string,\n413: ): Promise<void> {\n414:   return enqueueMerge(async () => {\n415:     printAgentUpdate(agent, \"auto-merging...\");\n416:     try {\n417:       // Pre-flight check: detect conflicts before attempting the real merge.\n418:       // This avoids the expensive merge-then-abort dance for known conflicts.\n419:       const preCheck = await canMerge(projectRoot, agent.branch, state.base_branch);\n420:       if (!preCheck.canMerge) {\n421:         printAgentUpdate(agent, `conflict detected (pre-flight) — attempting resolution...`);\n422:         await handleMergeConflict(\n423:           projectRoot, state, agent, feature, config, model,\n424:           preCheck.reason\n425:         );\n426:         return;\n427:       }\n428: \n429:       const mergeResult = await mergeBranch(projectRoot, agent.branch, state.base_branch, config);\n430: \n431:       if (mergeResult.success) {\n432:         handleMergeSuccess(projectRoot, state, agent, config, mergeResult.commitHash);\n433:         return;\n434:       }\n435: \n436:       // Merge failed despite clean pre-flight — race with another merge or\n437:       // a git state issue. Fall through to conflict resolution.\n438:       printAgentUpdate(agent, `MERGE CONFLICT — attempting resolution...`);\n439:       await handleMergeConflict(\n440:         projectRoot, state, agent, feature, config, model,\n441:         mergeResult.error ?? \"Unknown merge error\"\n442:       );\n443:     } catch (mergeErr: any) {\n444:       // Unexpected exception — stay in \"verified\" (retryable) but record the\n445:       // error so the user can see what went wrong instead of silent stalling.\n446:       printAgentUpdate(agent, `AUTO-MERGE ERROR: ${mergeErr.message?.slice(0, 100)}`);\n447:       updateAgent(state, agent.feature_id, {\n448:         error: `Auto-merge error: ${mergeErr.message}`,\n449:       });\n450:       saveState(projectRoot, state);\n451:     }\n452:   });\n453: }\n454: \n455: /**\n456:  * Handle a successful merge: update state, mark feature done, clean up.\n457:  */\n458: function handleMergeSuccess(\n459:   projectRoot: string,\n460:   state: WaveState,\n461:   agent: AgentState,\n462:   config: WomboConfig,\n463:   commitHash: string | null,\n464:   label = \"MERGED\",\n465: ): void {\n466:   updateAgent(state, agent.feature_id, {\n467:     status: \"merged\",\n468:     completed_at: new Date().toISOString(),\n469:   });\n470:   saveState(projectRoot, state);\n471:   printAgentUpdate(agent, `${label} (${commitHash?.slice(0, 7)})`);\n472: \n473:   markFeatureDone(projectRoot, agent.feature_id, config, state.base_branch);\n474: \n475:   // Clean up worktree — but preserve it if downstream agents in the same\n476:   // chain share this worktree.\n477:   const hasChainSuccessor = agent.depended_on_by.some((depId) => {\n478:     const depAgent = state.agents.find((a) => a.feature_id === depId);\n479:     return depAgent && depAgent.worktree === agent.worktree;\n480:   });\n481: \n482:   if (hasChainSuccessor) {\n483:     printAgentUpdate(agent, \"worktree preserved for chain successor\");\n484:   } else {\n485:     try {\n486:       removeWorktree(projectRoot, agent.worktree, true);\n487:       printAgentUpdate(agent, \"worktree and branch removed\");\n488:     } catch {\n489:       // Not critical — worktree cleanup is best-effort\n490:     }\n491:   }\n492: }\n493: \n494: /**\n495:  * Handle a merge conflict: merge base into feature, then either retry the\n496:  * direct merge (if base merged cleanly) or launch a resolver agent.\n497:  *\n498:  * All failure paths record the error on the agent (which stays \"verified\")\n499:  * so the merge can be retried without silently stalling.\n500:  */\n501: async function handleMergeConflict(\n502:   projectRoot: string,\n503:   state: WaveState,\n504:   agent: AgentState,\n505:   feature: Feature,\n506:   config: WomboConfig,\n507:   model: string | undefined,\n508:   mergeError: string,\n509: ): Promise<void> {\n510:   try {\n511:     // Merge base INTO the feature worktree to create conflict markers\n512:     const conflictResult = await mergeBaseIntoFeature(\n513:       agent.worktree,\n514:       state.base_branch,\n515:       config\n516:     );\n517: \n518:     if (conflictResult.error && !conflictResult.conflicting) {\n519:       // Setup itself failed — stay as \"verified\" (retryable) with error\n520:       printAgentUpdate(agent, `CONFLICT SETUP FAILED: ${conflictResult.error.slice(0, 100)}`);\n521:       updateAgent(state, agent.feature_id, {\n522:         error: `Conflict setup failed: ${conflictResult.error}`,\n523:       });\n524:       saveState(projectRoot, state);\n525:       return;\n526:     }\n527: \n528:     if (!conflictResult.conflicting) {\n529:       // Base merged cleanly into feature — retry merge into base.\n530:       printAgentUpdate(agent, \"base merged cleanly into feature — retrying merge...\");\n531:       const retryMerge = await mergeBranch(projectRoot, agent.branch, state.base_branch, config);\n532:       if (retryMerge.success) {\n533:         handleMergeSuccess(projectRoot, state, agent, config, retryMerge.commitHash, \"MERGED after rebase\");\n534:         return;\n535:       }\n536: \n537:       // Retry still failed — need conflict resolution.\n538:       // Merge base into feature again to get conflict files for the resolver.\n539:       printAgentUpdate(agent, `retry merge still failed — launching resolver agent...`);\n540:       const secondConflict = await mergeBaseIntoFeature(\n541:         agent.worktree,\n542:         state.base_branch,\n543:         config\n544:       );\n545: \n546:       const conflictFiles = secondConflict.conflicting\n547:         ? secondConflict.files\n548:         : [\"(unknown — merge direction mismatch)\"];\n549: \n550:       await launchResolverAndRetryMerge(\n551:         projectRoot, state, agent, feature, config, model,\n552:         retryMerge.error ?? mergeError, conflictFiles\n553:       );\n554:       return;\n555:     }\n556: \n557:     // There are real conflicts — launch a resolver agent\n558:     printAgentUpdate(\n559:       agent,\n560:       `${conflictResult.files.length} conflicting file(s): ${conflictResult.files.join(\", \")}`\n561:     );\n562: \n563:     await launchResolverAndRetryMerge(\n564:       projectRoot, state, agent, feature, config, model,\n565:       mergeError, conflictResult.files\n566:     );\n567:   } catch (conflictErr: any) {\n568:     // Unexpected error during conflict handling — stay \"verified\" with error\n569:     printAgentUpdate(agent, `CONFLICT RESOLUTION ERROR: ${conflictErr.message?.slice(0, 100)}`);\n570:     updateAgent(state, agent.feature_id, {\n571:       error: `Conflict resolution error: ${conflictErr.message}`,\n572:     });\n573:     saveState(projectRoot, state);\n574:   }\n575: }\n576: \n577: /**\n578:  * Launch a conflict resolver agent, wait for it to finish, re-verify build,\n579:  * and retry the merge. Supports configurable retry attempts (defaults to 1,\n580:  * up to config.defaults.maxRetries + 1).\n581:  *\n582:  * The resolver is re-launched with updated conflict state on each attempt,\n583:  * so it sees the current conflict markers, not stale ones.\n584:  */\n585: async function launchResolverAndRetryMerge(\n586:   projectRoot: string,\n587:   state: WaveState,\n588:   agent: AgentState,\n589:   feature: Feature,\n590:   config: WomboConfig,\n591:   model: string | undefined,\n592:   mergeError: string,\n593:   conflictFiles: string[]\n594: ): Promise<void> {\n595:   const maxResolverAttempts = Math.max(1, (config.defaults.maxRetries ?? 0) + 1);\n596: \n597:   for (let attempt = 1; attempt <= maxResolverAttempts; attempt++) {\n598:     const conflictPrompt = generateConflictResolutionPrompt(\n599:       feature,\n600:       state.base_branch,\n601:       mergeError,\n602:       config\n603:     );\n604: \n605:     const attemptLabel = maxResolverAttempts > 1\n606:       ? ` (attempt ${attempt}/${maxResolverAttempts})`\n607:       : \"\";\n608: \n609:     updateAgent(state, agent.feature_id, {\n610:       status: \"resolving_conflict\",\n611:       activity: `resolving ${conflictFiles.length} conflict(s)${attemptLabel}...`,\n612:     });\n613:     saveState(projectRoot, state);\n614: \n615:     const resolverResult = launchConflictResolver({\n616:       worktreePath: agent.worktree,\n617:       featureId: agent.feature_id,\n618:       prompt: conflictPrompt,\n619:       model,\n620:       config,\n621:     });\n622: \n623:     updateAgent(state, agent.feature_id, {\n624:       pid: resolverResult.pid,\n625:     });\n626:     saveState(projectRoot, state);\n627: \n628:     // Wait for the resolver process to complete, then re-verify and retry merge.\n629:     // We intentionally do NOT add the resolver to the ProcessMonitor because\n630:     // the monitor's onComplete callback would trigger handleBuildVerification\n631:     // again, causing infinite recursion. Instead we await the process directly.\n632:     const resolverExitCode = await new Promise<number | null>((resolve) => {\n633:       resolverResult.process.on(\"exit\", (code) => resolve(code));\n634:       resolverResult.process.on(\"error\", () => resolve(null));\n635:     });\n636: \n637:     printAgentUpdate(\n638:       agent,\n639:       `conflict resolver exited (code ${resolverExitCode})${attemptLabel} — re-verifying build...`\n640:     );\n641: \n642:     // Re-verify build after conflict resolution\n643:     const rebuildResult = await runBuild(agent.worktree, config);\n644: \n645:     if (!rebuildResult.passed) {\n646:       if (attempt < maxResolverAttempts) {\n647:         printAgentUpdate(agent, `POST-CONFLICT BUILD FAILED${attemptLabel} — retrying resolver...`);\n648:         continue; // Try again with a fresh resolver\n649:       }\n650:       printAgentUpdate(agent, `POST-CONFLICT BUILD FAILED (all ${maxResolverAttempts} attempts exhausted)`);\n651:       updateAgent(state, agent.feature_id, {\n652:         status: \"failed\",\n653:         build_passed: false,\n654:         build_output: rebuildResult.errorSummary,\n655:         error: \"Build failed after conflict resolution\",\n656:         completed_at: new Date().toISOString(),\n657:       });\n658:       saveState(projectRoot, state);\n659:       cancelDownstream(state, agent.feature_id);\n660:       saveState(projectRoot, state);\n661:       return;\n662:     }\n663: \n664:     printAgentUpdate(agent, \"post-conflict build passed — retrying merge...\");\n665: \n666:     const retryMerge = await mergeBranch(\n667:       projectRoot,\n668:       agent.branch,\n669:       state.base_branch,\n670:       config\n671:     );\n672: \n673:     if (retryMerge.success) {\n674:       handleMergeSuccess(\n675:         projectRoot, state, agent, config,\n676:         retryMerge.commitHash, \"MERGED after conflict resolution\"\n677:       );\n678:       return;\n679:     }\n680: \n681:     // Merge still failed after resolver. If we have attempts left, re-merge\n682:     // base into feature to refresh conflict markers and try again.\n683:     if (attempt < maxResolverAttempts) {\n684:       printAgentUpdate(agent, `POST-CONFLICT MERGE FAILED${attemptLabel} — retrying resolver...`);\n685:       const refreshConflict = await mergeBaseIntoFeature(\n686:         agent.worktree,\n687:         state.base_branch,\n688:         config\n689:       );\n690:       conflictFiles = refreshConflict.conflicting\n691:         ? refreshConflict.files\n692:         : conflictFiles;\n693:       mergeError = retryMerge.error ?? mergeError;\n694:       continue;\n695:     }\n696: \n697:     // All attempts exhausted\n698:     printAgentUpdate(agent, `POST-CONFLICT MERGE FAILED (all ${maxResolverAttempts} attempts exhausted): ${retryMerge.error}`);\n699:     updateAgent(state, agent.feature_id, {\n700:       status: \"failed\",\n701:       error: `Merge still failed after ${maxResolverAttempts} conflict resolution attempt(s): ${retryMerge.error}`,\n702:       completed_at: new Date().toISOString(),\n703:     });\n704:     saveState(projectRoot, state);\n705:     cancelDownstream(state, agent.feature_id);\n706:     saveState(projectRoot, state);\n707:     return;\n708:   }\n709: }\n710: \n711: /**\n712:  * Handle retry of a failed agent (error-based, not build-based).\n713:  */\n714: export function handleRetry(\n715:   projectRoot: string,\n716:   state: WaveState,\n717:   agent: AgentState,\n718:   monitor: ProcessMonitor,\n719:   config: WomboConfig,\n720:   model?: string\n721: ): void {\n722:   if (!agent.session_id || !agent.error) return;\n723: \n724:   const retryResult = retryHeadless({\n725:     worktreePath: agent.worktree,\n726:     featureId: agent.feature_id,\n727:     sessionId: agent.session_id,\n728:     buildErrors: agent.error,\n729:     model,\n730:     config,\n731:   });\n732: \n733:   updateAgent(state, agent.feature_id, {\n734:     status: \"running\",\n735:     pid: retryResult.pid,\n736:   });\n737:   saveState(projectRoot, state);\n738: \n739:   monitor.addProcess(agent.feature_id, retryResult.process);\n740: }\n741: \n742: /**\n743:  * Launch the next queued agent if capacity allows.\n744:  * Dependency-aware: only launches agents whose dependencies are satisfied.\n745:  */\n746: export function launchNextQueued(\n747:   projectRoot: string,\n748:   state: WaveState,\n749:   featureMap: Map<string, Feature>,\n750:   monitor: ProcessMonitor,\n751:   config: WomboConfig,\n752:   model?: string,\n753:   agentResolutions?: Map<string, AgentResolution>\n754: ): void {\n755:   const active = activeAgents(state);\n756:   const ready = readyToLaunchAgents(state);\n757: \n758:   if (active.length < state.max_concurrent && ready.length > 0) {\n759:     const next = ready[0];\n760:     const feature = featureMap.get(next.feature_id);\n761:     if (feature) {\n762:       launchSingleHeadless(projectRoot, state, next, feature, monitor, config, model, agentResolutions);\n763:     }\n764:   }\n765: }\n766: \n767: /**\n768:  * Launch ALL ready agents up to capacity.\n769:  * After a dependency completes, multiple downstream agents may become unblocked.\n770:  * This launches as many as capacity allows, not just one.\n771:  *\n772:  * Also logs merge gate events when diamond-dependency features become unblocked.\n773:  */\n774: export function launchAllReady(\n775:   projectRoot: string,\n776:   state: WaveState,\n777:   featureMap: Map<string, Feature>,\n778:   monitor: ProcessMonitor,\n779:   config: WomboConfig,\n780:   model?: string,\n781:   agentResolutions?: Map<string, AgentResolution>\n782: ): void {\n783:   const active = activeAgents(state);\n784:   const ready = readyToLaunchAgents(state);\n785:   const available = state.max_concurrent - active.length;\n786: \n787:   if (available <= 0 || ready.length === 0) return;\n788: \n789:   const toLaunch = ready.slice(0, available);\n790:   for (const next of toLaunch) {\n791:     const feature = featureMap.get(next.feature_id);\n792:     if (!feature) continue;\n793: \n794:     // Log merge gate opening for diamond dependencies\n795:     if (next.depends_on.length > 1 && state.schedule_plan) {\n796:       const isMergeGate = state.schedule_plan.merge_gates.some(\n797:         (g) => g.feature_id === next.feature_id\n798:       );\n799:       if (isMergeGate) {\n800:         wtLog(\n801:           next.feature_id,\n802:           `merge gate opened — all ${next.depends_on.length} dependencies satisfied`\n803:         );\n804:       }\n805:     }\n806: \n807:     launchSingleHeadless(projectRoot, state, next, feature, monitor, config, model, agentResolutions);\n808:   }\n809: }\n810: \n811: // ---------------------------------------------------------------------------\n812: // Post-mortem: dump failed agent logs\n813: // ---------------------------------------------------------------------------\n814: \n815: /**\n816:  * Print full log contents for every failed agent so the user can diagnose\n817:  * issues after the wave finishes. Handles missing log files gracefully.\n818:  */\n819: export function dumpFailedAgentLogs(projectRoot: string, state: WaveState): void {\n820:   const failed = state.agents.filter((a) => a.status === \"failed\");\n821:   if (failed.length === 0) return;\n822: \n823:   const logDir = resolve(projectRoot, \".wombo-combo/logs\");\n824: \n825:   console.log(\n826:     `\\n${\"=\".repeat(72)}\\n` +\n827:     `  FAILED AGENT LOGS (${failed.length} agent${failed.length > 1 ? \"s\" : \"\"})\\n` +\n828:     `${\"=\".repeat(72)}`\n829:   );\n830: \n831:   for (const agent of failed) {\n832:     const logFile = resolve(logDir, `${agent.feature_id}.log`);\n833: \n834:     console.log(\n835:       `\\n${\"─\".repeat(72)}\\n` +\n836:       `  Feature: ${agent.feature_id}\\n` +\n837:       (agent.error ? `  Error:   ${agent.error}\\n` : \"\") +\n838:       `${\"─\".repeat(72)}`\n839:     );\n840: \n841:     if (!existsSync(logFile)) {\n842:       console.log(\"  (no log file found)\");\n843:       continue;\n844:     }\n845: \n846:     try {\n847:       const contents = readFileSync(logFile, \"utf-8\");\n848:       if (contents.trim().length === 0) {\n849:         console.log(\"  (log file is empty)\");\n850:       } else {\n851:         console.log(contents);\n852:       }\n853:     } catch (err: any) {\n854:       console.log(`  (error reading log: ${err.message})`);\n855:     }\n856:   }\n857: \n858:   console.log(`\\n${\"=\".repeat(72)}\\n`);\n859: }\n860: \n861: // ---------------------------------------------------------------------------\n862: // Headless Wave Launch\n863: // ---------------------------------------------------------------------------\n864: \n865: async function launchWaveHeadless(\n866:   projectRoot: string,\n867:   state: WaveState,\n868:   features: Feature[],\n869:   opts: LaunchCommandOptions,\n870:   agentResolutions?: Map<string, AgentResolution>\n871: ): Promise<void> {\n872:   const { config, model } = opts;\n873:   const featureMap = new Map(features.map((f) => [f.id, f]));\n874: \n875:   const monitor = new ProcessMonitor(projectRoot, {\n876:     onSessionId: (featureId, sessionId) => {\n877:       updateAgent(state, featureId, { session_id: sessionId });\n878:       saveState(projectRoot, state);\n879:     },\n880:     onComplete: (featureId) => {\n881:       updateAgent(state, featureId, {\n882:         status: \"completed\",\n883:         completed_at: new Date().toISOString(),\n884:       });\n885:       saveState(projectRoot, state);\n886: \n887:       // Run build verification — fire-and-forget\n888:       const agent = state.agents.find((a) => a.feature_id === featureId)!;\n889:       handleBuildVerification(projectRoot, state, agent, featureMap.get(featureId)!, config, model, monitor)\n890:         .then(() => {\n891:           // After verification/merge, try to launch dependency-ready agents\n892:           // Multiple queued agents may now be unblocked\n893:           launchAllReady(projectRoot, state, featureMap, monitor, config, model, agentResolutions);\n894:         })\n895:         .catch((err) => {\n896:           wtLog(featureId, `BUILD VERIFICATION UNHANDLED ERROR: ${err.message}`);\n897:           launchAllReady(projectRoot, state, featureMap, monitor, config, model, agentResolutions);\n898:         });\n899:     },\n900:     onError: (featureId, error) => {\n901:       const agent = state.agents.find((a) => a.feature_id === featureId)!;\n902:       if (agent.retries < agent.max_retries) {\n903:         updateAgent(state, featureId, {\n904:           status: \"retry\",\n905:           retries: agent.retries + 1,\n906:           error,\n907:         });\n908:         saveState(projectRoot, state);\n909: \n910:         // Retry\n911:         handleRetry(projectRoot, state, agent, monitor, config, model);\n912:       } else {\n913:         updateAgent(state, featureId, {\n914:           status: \"failed\",\n915:           error,\n916:           completed_at: new Date().toISOString(),\n917:         });\n918:         saveState(projectRoot, state);\n919: \n920:         // Cascade failure to downstream agents\n921:         const cancelled = cancelDownstream(state, featureId);\n922:         if (cancelled.length > 0) {\n923:           wtLog(featureId, `downstream cancelled: ${cancelled.join(\", \")}`);\n924:           saveState(projectRoot, state);\n925:         }\n926:       }\n927: \n928:       // Try to launch dependency-ready agents\n929:       launchAllReady(projectRoot, state, featureMap, monitor, config, model, agentResolutions);\n930:     },\n931:     onOutput: (_featureId, _data) => {\n932:       // Raw output — logged to file by ProcessMonitor\n933:     },\n934:     onActivity: (featureId, activity) => {\n935:       updateAgent(state, featureId, {\n936:         activity,\n937:         activity_updated_at: new Date().toISOString(),\n938:       });\n939:       // Don't save to disk on every activity — too frequent.\n940:     },\n941:   });\n942: \n943:   // Create the TUI — it will auto-refresh and show activity from the monitor\n944:   const tuiRef = { current: null as WomboTUI | null };\n945:   const startTUI = () => {\n946:     tuiRef.current = new WomboTUI({\n947:       state,\n948:       monitor,\n949:       projectRoot,\n950:       interactive: false,\n951:       config,\n952:       onQuit: () => {\n953:         // Same as SIGINT — save state and exit\n954:         for (const agent of state.agents) {\n955:           if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n956:             updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n957:           }\n958:         }\n959:         monitor.killAll();\n960:         saveState(projectRoot, state);\n961:         console.log(\"State saved. Use 'woco resume' to continue.\");\n962:         process.exit(0);\n963:       },\n964:     });\n965:     tuiRef.current.start();\n966:   };\n967: \n968:   // Handle graceful shutdown\n969:   process.on(\"SIGINT\", () => {\n970:     if (tuiRef.current) tuiRef.current.stop();\n971:     for (const agent of state.agents) {\n972:       if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n973:         updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n974:       }\n975:     }\n976:     monitor.killAll();\n977:     saveState(projectRoot, state);\n978:     console.log(\"\\nState saved. Use 'woco resume' to continue.\");\n979:     process.exit(0);\n980:   });\n981: \n982:   // Launch initial batch — only agents whose dependencies are already satisfied\n983:   const ready = readyToLaunchAgents(state);\n984:   const tolaunch = ready.slice(0, opts.maxConcurrent);\n985:   console.log(`Setting up ${tolaunch.length} agent(s) in parallel...\\n`);\n986: \n987:   await Promise.all(\n988:     tolaunch.map((agent) =>\n989:       launchSingleHeadless(\n990:         projectRoot,\n991:         state,\n992:         agent,\n993:         featureMap.get(agent.feature_id)!,\n994:         monitor,\n995:         config,\n996:         model,\n997:         agentResolutions\n998:       )\n999:     )\n1000:   );\n1001: \n1002:   const launched = state.agents.filter((a) => a.status === \"running\").length;\n1003: \n1004:   // Start the TUI dashboard (or skip if --no-tui)\n1005:   if (opts.noTui) {\n1006:     console.log(`${launched} agent(s) running. (--no-tui mode, dashboard prints every 15s)\\n`);\n1007:     printDashboard(state);\n1008:   } else {\n1009:     console.log(`${launched} agent(s) running. Launching TUI...\\n`);\n1010:     startTUI();\n1011:   }\n1012: \n1013:   // Background monitoring loop — checks for dead processes and launches queued\n1014:   const POLL_INTERVAL = 5000;\n1015:   let dashboardCounter = 0;\n1016:   while (!isWaveComplete(state)) {\n1017:     await new Promise((r) => setTimeout(r, POLL_INTERVAL));\n1018: \n1019:     // Check for completed processes that weren't caught by event handlers\n1020:     for (const agent of state.agents) {\n1021:       if (\n1022:         (agent.status === \"running\" || agent.status === \"resolving_conflict\") &&\n1023:         agent.pid &&\n1024:         !isProcessRunning(agent.pid) &&\n1025:         !monitor.isRunning(agent.feature_id)\n1026:       ) {\n1027:         if (agent.status === \"resolving_conflict\") {\n1028:           // Conflict resolver died — the await in handleBuildVerification\n1029:           // will resolve via the 'exit' event, so nothing to do here\n1030:           continue;\n1031:         }\n1032:         // Process exited but we didn't get a callback\n1033:         // Check if the agent actually made any commits\n1034:         if (!branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n1035:           // Agent died without producing any code — mark as failed, not completed\n1036:           updateAgent(state, agent.feature_id, {\n1037:             status: \"failed\",\n1038:             error: \"Agent process exited without making any commits\",\n1039:             activity: null,\n1040:             completed_at: new Date().toISOString(),\n1041:           });\n1042:           saveState(projectRoot, state);\n1043:           wtLog(agent.feature_id, \"process died with no code changes — marked failed\");\n1044: \n1045:           // Cascade failure to downstream agents\n1046:           const cancelled = cancelDownstream(state, agent.feature_id);\n1047:           if (cancelled.length > 0) {\n1048:             wtLog(agent.feature_id, `downstream cancelled: ${cancelled.join(\", \")}`);\n1049:             saveState(projectRoot, state);\n1050:           }\n1051:         } else {\n1052:           updateAgent(state, agent.feature_id, {\n1053:             status: \"completed\",\n1054:             completed_at: new Date().toISOString(),\n1055:             activity: \"done\",\n1056:           });\n1057:           saveState(projectRoot, state);\n1058:           try {\n1059:             await handleBuildVerification(projectRoot, state, agent, featureMap.get(agent.feature_id)!, config, model, monitor);\n1060:           } catch (err: any) {\n1061:             wtLog(agent.feature_id, `POLL VERIFY ERROR: ${err.message}`);\n1062:           }\n1063:         }\n1064:         launchAllReady(projectRoot, state, featureMap, monitor, config, model, agentResolutions);\n1065:       }\n1066:     }\n1067: \n1068:     // Persist state periodically\n1069:     saveState(projectRoot, state);\n1070: \n1071:     // Update TUI state reference (or print dashboard in --no-tui mode)\n1072:     if (tuiRef.current) {\n1073:       tuiRef.current.updateState(state);\n1074:     } else if (opts.noTui) {\n1075:       dashboardCounter++;\n1076:       if (dashboardCounter % 3 === 0) {\n1077:         printDashboard(state);\n1078: \n1079:         // Auto-push base branch if requested\n1080:         if (opts.autoPush) {\n1081:           const anyMerged = state.agents.some((a) => a.status === \"merged\");\n1082:           if (anyMerged) {\n1083:             await pushBaseBranch(projectRoot, state.base_branch, config);\n1084:           } else {\n1085:             console.log(\"No branches were merged — skipping push.\");\n1086:           }\n1087:         }\n1088:       }\n1089:     }\n1090:   }\n1091: \n1092:   // Wave complete — keep TUI open for post-mortem browsing\n1093:   if (tuiRef.current) {\n1094:     tuiRef.current.updateState(state);\n1095:     tuiRef.current.markWaveComplete();\n1096:     // Wait for the user to press q to exit the TUI\n1097:     await tuiRef.current.waitForQuit();\n1098:   }\n1099: \n1100:   // Print final dashboard after TUI is closed\n1101:   printDashboard(state);\n1102: \n1103:   // Dump full logs for failed agents (post-mortem)\n1104:   dumpFailedAgentLogs(projectRoot, state);\n1105: \n1106:   // Auto-export wave history\n1107:   try {\n1108:     const historyPath = exportWaveHistory(projectRoot, state);\n1109:     console.log(`Wave history exported to ${historyPath}`);\n1110:   } catch (err: any) {\n1111:     console.error(`Warning: failed to export wave history: ${err.message}`);\n1112:   }\n1113: \n1114:   // Auto-push base branch if requested\n1115:   if (opts.autoPush) {\n1116:     await pushBaseBranch(projectRoot, state.base_branch, config);\n1117:   }\n1118: \n1119:   console.log(\"Wave complete.\");\n1120: }\n1121: \n1122: // ---------------------------------------------------------------------------\n1123: // Interactive Wave Launch\n1124: // ---------------------------------------------------------------------------\n1125: \n1126: async function launchWaveInteractive(\n1127:   projectRoot: string,\n1128:   state: WaveState,\n1129:   features: Feature[],\n1130:   opts: LaunchCommandOptions,\n1131:   agentResolutions?: Map<string, AgentResolution>\n1132: ): Promise<void> {\n1133:   const { config, model } = opts;\n1134:   const featureMap = new Map(features.map((f) => [f.id, f]));\n1135: \n1136:   // Show dashboard immediately\n1137:   printDashboard(state);\n1138: \n1139:   // Launch initial batch — parallelize setup\n1140:   const tolaunch = queuedAgents(state).slice(0, opts.maxConcurrent);\n1141:   console.log(`Setting up ${tolaunch.length} agent(s) in parallel...\\n`);\n1142: \n1143:   await Promise.all(\n1144:     tolaunch.map(async (agent) => {\n1145:       updateAgent(state, agent.feature_id, {\n1146:         status: \"installing\",\n1147:         started_at: new Date().toISOString(),\n1148:         activity: \"setting up worktree...\",\n1149:       });\n1150:       saveState(projectRoot, state);\n1151: \n1152:       try {\n1153:         if (worktreeReady(agent.worktree)) {\n1154:           wtLog(agent.feature_id, \"worktree already exists, skipping setup\");\n1155:         } else {\n1156:           await createWorktree(projectRoot, agent.feature_id, state.base_branch, config);\n1157:           updateAgent(state, agent.feature_id, { activity: \"installing deps...\" });\n1158:           await installDeps(agent.worktree, agent.feature_id, config);\n1159:         }\n1160: \n1161:         const prompt = generatePrompt(\n1162:           featureMap.get(agent.feature_id)!,\n1163:           state.base_branch,\n1164:           config\n1165:         );\n1166: \n1167:         // Write specialized agent to worktree if applicable\n1168:         const resolution = agentResolutions?.get(agent.feature_id);\n1169:         const agentName = agent.agent_name ?? undefined;\n1170:         if (resolution && isSpecializedAgent(resolution)) {\n1171:           try {\n1172:             const patchedContent = patchImportedAgent(resolution.rawContent, config, projectRoot);\n1173:             writeAgentToWorktree(agent.worktree, resolution.name, patchedContent);\n1174:             wtLog(agent.feature_id, `wrote specialized agent: ${resolution.name}`);\n1175:           } catch (err: any) {\n1176:             wtLog(agent.feature_id, `WARN: failed to write specialized agent, using generalist: ${err.message}`);\n1177:           }\n1178:         }\n1179: \n1180:         wtLog(agent.feature_id, \"launching interactive session...\");\n1181:         const result = launchInteractive({\n1182:           worktreePath: agent.worktree,\n1183:           featureId: agent.feature_id,\n1184:           prompt,\n1185:           model,\n1186:           interactive: true,\n1187:           config,\n1188:           agentName,\n1189:         });\n1190: \n1191:         const muxName = getMultiplexerName(config);\n1192:         updateAgent(state, agent.feature_id, {\n1193:           status: \"running\",\n1194:           pid: result.pid,\n1195:           activity: `${muxName} session active`,\n1196:         });\n1197:         saveState(projectRoot, state);\n1198:         wtLog(agent.feature_id, `${muxName} session: ${config.agent.tmuxPrefix}-${agent.feature_id}`);\n1199:       } catch (err: any) {\n1200:         updateAgent(state, agent.feature_id, {\n1201:           status: \"failed\",\n1202:           error: err.message,\n1203:           activity: null,\n1204:           completed_at: new Date().toISOString(),\n1205:         });\n1206:         saveState(projectRoot, state);\n1207:         wtLog(agent.feature_id, `SETUP FAILED: ${err.message.split(\"\\n\")[0]}`);\n1208:       }\n1209:     })\n1210:   );\n1211: \n1212:   const mux = detectMultiplexer(config.agent.multiplexer);\n1213:   const muxName = getMultiplexerName(config);\n1214:   console.log(\"\\nInteractive sessions launched. Use these commands:\");\n1215:   console.log(`  ${muxAttachCommand(mux, `${config.agent.tmuxPrefix}-<feature-id>`)}   # attach to a session`);\n1216:   console.log(`  ${muxListCommand(mux)}${\" \".repeat(Math.max(1, 54 - muxListCommand(mux).length))}# list sessions`);\n1217:   console.log(\"  woco status                                             # check status\");\n1218:   console.log(\"  woco verify                                             # verify builds\");\n1219:   console.log(\"  woco merge                                              # merge verified\");\n1220:   console.log(\"  woco cleanup                                            # remove worktrees\");\n1221: \n1222:   printDashboard(state);\n1223: }\n1224: \n1225: // ---------------------------------------------------------------------------\n1226: // Main Command\n1227: // ---------------------------------------------------------------------------\n1228: \n1229: export async function cmdLaunch(opts: LaunchCommandOptions): Promise<void> {\n1230:   const { projectRoot, config } = opts;\n1231: \n1232:   console.log(\"\\n--- wombo-combo: Launch ---\\n\");\n1233: \n1234:   // Ensure agent definition exists — reinstall from template if missing\n1235:   ensureAgentDefinition(projectRoot, config);\n1236: \n1237:   // Ensure portless proxy is running (if enabled) to prevent port collisions\n1238:   if (config.portless.enabled) {\n1239:     if (isPortlessAvailable(config)) {\n1240:       const proxyOk = ensureProxyRunning(config);\n1241:       if (!proxyOk) {\n1242:         console.warn(\n1243:           \"\\x1b[33m[portless]\\x1b[0m proxy could not be started — agents may encounter port collisions\"\n1244:         );\n1245:       }\n1246:     } else {\n1247:       console.warn(\n1248:         \"\\x1b[33m[portless]\\x1b[0m enabled but not installed. Install with: npm install -g portless\"\n1249:       );\n1250:       console.warn(\n1251:         \"  Agents will run without portless — concurrent dev servers may have port collisions.\\n\"\n1252:       );\n1253:     }\n1254:   }\n1255: \n1256:   // -------------------------------------------------------------------------\n1257:   // Validate that the configured baseBranch exists as a local branch\n1258:   // -------------------------------------------------------------------------\n1259:   if (!branchExists(projectRoot, opts.baseBranch)) {\n1260:     const fmt = opts.outputFmt ?? \"text\";\n1261:     const msg = `Base branch \"${opts.baseBranch}\" does not exist as a local branch. ` +\n1262:       `Create it first (e.g. \"git checkout -b ${opts.baseBranch}\") or specify ` +\n1263:       `a different branch with --base-branch.`;\n1264:     outputError(fmt, msg);\n1265:   }\n1266: \n1267:   // -------------------------------------------------------------------------\n1268:   // Check for existing wave state — don't overwrite work in progress\n1269:   // -------------------------------------------------------------------------\n1270:   const existingState = loadState(projectRoot);\n1271:   if (existingState) {\n1272:     const merged = existingState.agents.filter((a) => a.status === \"merged\");\n1273:     const verified = existingState.agents.filter((a) => a.status === \"verified\");\n1274:     const completed = existingState.agents.filter((a) => a.status === \"completed\");\n1275:     const running = existingState.agents.filter((a) => a.status === \"running\");\n1276:     const queued = existingState.agents.filter((a) => a.status === \"queued\");\n1277:     const failed = existingState.agents.filter((a) => a.status === \"failed\");\n1278: \n1279:     const hasWork = merged.length > 0 || verified.length > 0 || completed.length > 0 || running.length > 0;\n1280: \n1281:     if (hasWork) {\n1282:       console.log(`Existing wave found: ${existingState.wave_id}`);\n1283:       console.log(`  ${merged.length} merged, ${verified.length} verified, ${completed.length} completed, ${running.length} running, ${queued.length} queued, ${failed.length} failed`);\n1284: \n1285:       // Finalize any merged agents by marking their features as done\n1286:       if (merged.length > 0) {\n1287:         console.log(\"\\nFinalizing merged tasks in tasks file...\");\n1288:         for (const agent of merged) {\n1289:           markFeatureDone(projectRoot, agent.feature_id, config, existingState.base_branch);\n1290:           // Clean up worktree and branch (already merged, safe to delete)\n1291:           try {\n1292:             removeWorktree(projectRoot, agent.worktree, true);\n1293:             console.log(`  ${agent.feature_id}: marked done, worktree removed`);\n1294:           } catch {\n1295:             console.log(`  ${agent.feature_id}: marked done (worktree already cleaned)`);\n1296:           }\n1297:         }\n1298:       }\n1299: \n1300:       // Verified agents: build passed but NOT merged — do NOT mark done.\n1301:       // Leave them for 'woco resume' to attempt the merge.\n1302:       if (verified.length > 0) {\n1303:         for (const agent of verified) {\n1304:           console.log(`  ${agent.feature_id}: verified (not yet merged) — use 'woco resume' to merge`);\n1305:         }\n1306:       }\n1307: \n1308:       const activeCount = running.length + completed.length + queued.length;\n1309:       if (activeCount > 0) {\n1310:         console.error(`\\nWave ${existingState.wave_id} has ${activeCount} unfinished agent(s).`);\n1311:       console.error(\"Use 'woco resume' to continue the existing wave,\");\n1312:       console.error(\"or 'woco cleanup' to clear it before starting a new one.\");\n1313:         process.exit(1);\n1314:       }\n1315: \n1316:       // All agents are in terminal states (merged/verified/failed) — safe to start fresh\n1317:       console.log(\"\\nAll agents in previous wave are finished. Starting fresh wave.\\n\");\n1318:     }\n1319:   }\n1320: \n1321:   // Load features\n1322:   const data = loadFeatures(projectRoot, config);\n1323: \n1324:   // Build selection options\n1325:   const selOpts: SelectionOptions = {};\n1326:   if (opts.topPriority) selOpts.topPriority = opts.topPriority;\n1327:   if (opts.quickestWins) selOpts.quickestWins = opts.quickestWins;\n1328:   if (opts.priority) selOpts.priority = opts.priority;\n1329:   if (opts.difficulty) selOpts.difficulty = opts.difficulty;\n1330:   if (opts.features) selOpts.taskIds = opts.features;\n1331:   if (opts.allReady) selOpts.allReady = true;\n1332: \n1333:   // Select features\n1334:   const selected = selectFeatures(data, selOpts);\n1335: \n1336:   if (selected.length === 0) {\n1337:     const fmt = opts.outputFmt ?? \"text\";\n1338:     // Build a context-aware message based on which flags were passed\n1339:     const activeFilters: string[] = [];\n1340:     if (opts.allReady) activeFilters.push(\"--all-ready\");\n1341:     if (opts.topPriority) activeFilters.push(`--top-priority ${opts.topPriority}`);\n1342:     if (opts.quickestWins) activeFilters.push(`--quickest-wins ${opts.quickestWins}`);\n1343:     if (opts.priority) activeFilters.push(`--priority ${opts.priority}`);\n1344:     if (opts.difficulty) activeFilters.push(`--difficulty ${opts.difficulty}`);\n1345:     if (opts.features?.length) activeFilters.push(`--tasks ${opts.features.join(\",\")}`);\n1346: \n1347:     let msg: string;\n1348:     if (opts.allReady && activeFilters.length === 1) {\n1349:       msg = \"No launchable tasks found (all tasks are done, cancelled, or have unmet dependencies).\";\n1350:     } else if (activeFilters.length > 0) {\n1351:       msg = `No tasks matched the current filters: ${activeFilters.join(\", \")}.`;\n1352:     } else {\n1353:       msg = \"No launchable tasks found.\";\n1354:     }\n1355: \n1356:     outputError(fmt, msg);\n1357:   }\n1358: \n1359:   // Show selection\n1360:   printFeatureSelection(\n1361:     selected.map((f) => ({\n1362:       id: f.id,\n1363:       title: f.title,\n1364:       priority: f.priority,\n1365:       difficulty: f.difficulty,\n1366:       effort: f.effort,\n1367:     }))\n1368:   );\n1369: \n1370:   // ---------------------------------------------------------------------------\n1371:   // Dependency graph analysis\n1372:   // ---------------------------------------------------------------------------\n1373:   const depGraph = buildDepGraph(selected, data.tasks);\n1374:   let schedulePlan: SchedulePlan | null = null;\n1375: \n1376:   // Check if any features actually have dependencies within the selected set\n1377:   const hasDeps = selected.some(\n1378:     (f) => f.depends_on.some((d) => selected.find((s) => s.id === d))\n1379:   );\n1380: \n1381:   if (hasDeps) {\n1382:     // Validate graph — throws on cycles or dangling deps\n1383:     try {\n1384:       validateDepGraph(depGraph);\n1385:     } catch (err: any) {\n1386:       console.error(`\\n${err.message}`);\n1387:       console.error(\"\\nFix dependency issues before launching.\");\n1388:       process.exit(1);\n1389:     }\n1390: \n1391:     // Build scheduling plan\n1392:     schedulePlan = buildSchedulePlan(depGraph);\n1393:     console.log(`\\n${formatSchedulePlan(schedulePlan)}\\n`);\n1394:   }\n1395: \n1396:   if (opts.dryRun) {\n1397:     const fmt = opts.outputFmt ?? \"text\";\n1398:     const dryRunResult = {\n1399:       dry_run: true,\n1400:       base_branch: opts.baseBranch,\n1401:       max_concurrent: opts.maxConcurrent,\n1402:       model: opts.model ?? null,\n1403:       interactive: opts.interactive,\n1404:       selected: selected.map((f) => ({\n1405:         id: f.id,\n1406:         title: f.title,\n1407:         priority: f.priority,\n1408:         difficulty: f.difficulty,\n1409:         effort: f.effort,\n1410:       })),\n1411:       schedule_plan: schedulePlan ? {\n1412:         streams: schedulePlan.streams.map((s) => s.featureIds),\n1413:         merge_gates: schedulePlan.mergeGates.map((g) => ({\n1414:           feature_id: g.featureId,\n1415:           wait_for: g.waitFor,\n1416:         })),\n1417:         topological_order: schedulePlan.topologicalOrder,\n1418:       } : null,\n1419:     };\n1420: \n1421:     output(fmt, dryRunResult, () => {\n1422:       console.log(\"Dry run — not launching agents.\");\n1423:     });\n1424:     return;\n1425:   }\n1426: \n1427:   // ---------------------------------------------------------------------------\n1428:   // Agent registry: resolve specialized agents for tasks with agent_type\n1429:   // ---------------------------------------------------------------------------\n1430:   let agentResolutions: Map<string, AgentResolution> | undefined;\n1431: \n1432:   if (config.agentRegistry.mode !== \"disabled\") {\n1433:     const tasksWithAgentType = selected.filter((t) => t.agent_type);\n1434:     if (tasksWithAgentType.length > 0) {\n1435:       console.log(`\\nResolving ${tasksWithAgentType.length} specialized agent(s) from registry...`);\n1436:       agentResolutions = await prepareAgentDefinitions(selected, config, projectRoot);\n1437: \n1438:       const specialized = [...agentResolutions.values()].filter(isSpecializedAgent);\n1439:       const cached = specialized.filter((r) => r.fromCache);\n1440:       console.log(\n1441:         `  ${specialized.length} specialized (${cached.length} cached, ${specialized.length - cached.length} fetched), ` +\n1442:         `${selected.length - specialized.length} generalist`\n1443:       );\n1444:     }\n1445:   }\n1446: \n1447:   // ---------------------------------------------------------------------------\n1448:   // Preflight confirmation\n1449:   // ---------------------------------------------------------------------------\n1450:   if (agentResolutions && agentResolutions.size > 0) {\n1451:     const isTTY = process.stdout.isTTY && process.stdin.isTTY;\n\n(Output capped at 50 KB. Showing lines 1-1451. Use offset=1452 to continue.)\n</content>","title":"src/commands/launch.ts","metadata":{"preview":"/**\n * launch.ts — Launch a wave of agents.\n *\n * Usage: woco launch [selection options] [launch options]\n *\n * This is the primary entry point for starting a new wave. It selects features\n * from the features file, creates a wave state, sets up worktrees, and launches\n * agent processes (either headless or interactive via dmux/tmux).\n *\n * IMPORTANT: This file also exports shared helper functions that are reused\n * by resume.ts and other commands:\n *   - launchSingleHeadless\n *   - handleBuildVerification\n *   - handleRetry\n *   - launchNextQueued\n */\n\nimport { execSync } from \"node:child_process\";\nimport { existsSync, readFileSync } from \"node:fs\";\nimport { resolve } from \"node:path\";","truncated":true,"loaded":[]},"time":{"start":1773436219429,"end":1773436219433}}}}
