{"type":"tool_use","timestamp":1773435859191,"sessionID":"ses_316fcb4c5ffehqcHU7q5TvsiXt","part":{"id":"prt_ce903ab9c001ihYKXdy2tFjTby","sessionID":"ses_316fcb4c5ffehqcHU7q5TvsiXt","messageID":"msg_ce903a2d6001MdRUT2GCZWlQVM","type":"tool","callID":"toolu_vrtx_019FuwPAaxGzaV2awcDnK47G","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-json-operational-commands/src/commands/launch.ts","offset":1445},"output":"<path>/home/fulgidus/Documents/wt-wombo-json-operational-commands/src/commands/launch.ts</path>\n<type>file</type>\n<content>1445:     // Apply user's changes (rejected agents, mode changes)\n1446:     agentResolutions = preflight.agents;\n1447:   }\n1448: \n1449:   // Create wave state\n1450:   const state = createWaveState({\n1451:     baseBranch: opts.baseBranch,\n1452:     maxConcurrent: opts.maxConcurrent,\n1453:     model: opts.model ?? null,\n1454:     interactive: opts.interactive,\n1455:   });\n1456: \n1457:   // Store serialized schedule plan in wave state\n1458:   if (schedulePlan) {\n1459:     state.schedule_plan = {\n1460:       streams: schedulePlan.streams.map((s) => s.featureIds),\n1461:       merge_gates: schedulePlan.mergeGates.map((g) => ({\n1462:         feature_id: g.featureId,\n1463:         wait_for: g.waitFor,\n1464:       })),\n1465:       topological_order: schedulePlan.topologicalOrder,\n1466:     };\n1467:   }\n1468: \n1469:   // Create agent entries for all selected features\n1470:   const selectedIds = new Set(selected.map((f) => f.id));\n1471: \n1472:   // Build a map from feature ID → shared worktree path for chain reuse.\n1473:   // All features in the same chain share the worktree of the chain's first feature.\n1474:   const chainWorktreeMap = new Map<string, string>();\n1475:   if (schedulePlan) {\n1476:     for (const stream of schedulePlan.streams) {\n1477:       if (stream.featureIds.length > 1) {\n1478:         // All features in this chain share the first feature's worktree\n1479:         const sharedWtPath = worktreePath(projectRoot, stream.featureIds[0], config);\n1480:         for (const featureId of stream.featureIds) {\n1481:           chainWorktreeMap.set(featureId, sharedWtPath);\n1482:         }\n1483:       }\n1484:     }\n1485:   }\n1486: \n1487:   for (const feature of selected) {\n1488:     const branch = featureBranchName(feature.id, config);\n1489:     // Use shared worktree path for chain members, or individual path otherwise\n1490:     const wtPath = chainWorktreeMap.get(feature.id) ?? worktreePath(projectRoot, feature.id, config);\n1491:     const agent = createAgentState(feature.id, branch, wtPath, opts.maxRetries);\n1492: \n1493:     // Set effort estimate from feature spec\n1494:     const effortMinutes = parseDurationMinutes(feature.effort);\n1495:     agent.effort_estimate_ms = effortMinutes === Infinity ? null : effortMinutes * 60 * 1000;\n1496: \n1497:     // Populate dependency fields from the graph\n1498:     const graphNode = depGraph.nodes.get(feature.id);\n1499:     if (graphNode) {\n1500:       // Only track internal deps (within the selected set)\n1501:       agent.depends_on = graphNode.dependsOn.filter((d) => selectedIds.has(d));\n1502:       agent.depended_on_by = graphNode.dependedOnBy.filter((d) => selectedIds.has(d));\n1503:     }\n1504: \n1505:     // Set stream index\n1506:     if (schedulePlan) {\n1507:       agent.stream_index = getStreamForFeature(schedulePlan, feature.id);\n1508:     }\n1509: \n1510:     // Set specialized agent info from resolution\n1511:     const resolution = agentResolutions?.get(feature.id);\n1512:     if (resolution && isSpecializedAgent(resolution)) {\n1513:       agent.agent_name = resolution.name;\n1514:       agent.agent_type = resolution.agentType;\n1515:     }\n1516: \n1517:     state.agents.push(agent);\n1518:   }\n1519: \n1520:   saveState(projectRoot, state);\n1521:   console.log(`Wave ${state.wave_id} created with ${selected.length} agents.`);\n1522: \n1523:   // Launch agents up to max_concurrent\n1524:   if (opts.interactive) {\n1525:     await launchWaveInteractive(projectRoot, state, selected, opts, agentResolutions);\n1526:   } else {\n1527:     await launchWaveHeadless(projectRoot, state, selected, opts, agentResolutions);\n1528:   }\n1529: }\n\n(End of file - total 1529 lines)\n</content>","title":"src/commands/launch.ts","metadata":{"preview":"    // Apply user's changes (rejected agents, mode changes)\n    agentResolutions = preflight.agents;\n  }\n\n  // Create wave state\n  const state = createWaveState({\n    baseBranch: opts.baseBranch,\n    maxConcurrent: opts.maxConcurrent,\n    model: opts.model ?? null,\n    interactive: opts.interactive,\n  });\n\n  // Store serialized schedule plan in wave state\n  if (schedulePlan) {\n    state.schedule_plan = {\n      streams: schedulePlan.streams.map((s) => s.featureIds),\n      merge_gates: schedulePlan.mergeGates.map((g) => ({\n        feature_id: g.featureId,\n        wait_for: g.waitFor,\n      })),","truncated":false,"loaded":[]},"time":{"start":1773435859186,"end":1773435859190}}}}
