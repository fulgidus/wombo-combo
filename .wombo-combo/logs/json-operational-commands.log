{"type":"tool_use","timestamp":1773435850555,"sessionID":"ses_316fcb4c5ffehqcHU7q5TvsiXt","part":{"id":"prt_ce9038c0c001t6uxSzDLeNds18","sessionID":"ses_316fcb4c5ffehqcHU7q5TvsiXt","messageID":"msg_ce9037e72001xG8a2vcig9bcxq","type":"tool","callID":"toolu_vrtx_017DagfuZbgjNvRx4QvdKkaJ","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-json-operational-commands/src/index.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-json-operational-commands/src/index.ts</path>\n<type>file</type>\n<content>1: #!/usr/bin/env bun\n2: /**\n3:  * index.ts — CLI entry point for the wombo-combo agent orchestration system.\n4:  *\n5:  * Every command has a short alias (e.g., woco i = woco init, woco t ls = woco tasks list).\n6:  *\n7:  * Usage:\n8:  *   woco init                                         (alias: i)\n9:  *   woco launch --top-priority 3                      (alias: l)\n10:  *   woco launch --quickest-wins 5\n11:  *   woco launch --priority high\n12:  *   woco launch --difficulty easy\n13:  *   woco launch --tasks \"feat-a,feat-b\"\n14:  *   woco launch --all-ready\n15:  *   woco launch ... --max-concurrent 3 --model \"anthropic/claude-sonnet-4-20250514\"\n16:  *   woco launch ... --interactive\n17:  *   woco resume                                       (alias: r)\n18:  *   woco status                                       (alias: s)\n19:  *   woco verify [feature-id]                          (alias: v)\n20:  *   woco merge [feature-id]                           (alias: m)\n21:  *   woco retry <feature-id>                           (alias: re)\n22:  *   woco abort <feature-id> [--requeue] [--output json]  (alias: a)\n23:  *   woco logs <feature-id> [--tail N] [--follow]      (alias: lo)\n24:  *   woco cleanup                                      (alias: c)\n25:  *   woco history [wave-id] [--output json]            (alias: h)\n26:  *   woco tasks list [--status <s>] [--priority <p>]   (alias: t ls)\n27:  *   woco tasks add <id> <title> [options]             (alias: t a)\n28:  *   woco tasks set-status <task-id> <status>          (alias: t ss)\n29:  *   woco tasks set-priority <task-id> <priority>      (alias: t sp)\n30:  *   woco tasks set-difficulty <task-id> <difficulty>   (alias: t sd)\n31:  *   woco tasks check                                  (alias: t ch)\n32:  *   woco tasks archive [task-id] [--dry-run]          (alias: t ar)\n33:  *   woco tasks show <task-id>                         (alias: t sh)\n34:  *   woco tasks graph [--ascii] [--mermaid]            (alias: t g)\n35:  *   woco completion <bash|zsh|fish>                   (alias: comp)\n36:  *   woco help\n37:  *   woco version\n38:  *   woco -v\n39:  */\n40: \n41: import { resolve } from \"node:path\";\n42: import { existsSync, readFileSync } from \"node:fs\";\n43: import { loadConfig, validateConfig } from \"./config.js\";\n44: import { loadState, saveState } from \"./lib/state.js\";\n45: \n46: // ---------------------------------------------------------------------------\n47: // Dev-mode guard: warn if running the global binary inside the wombo-combo repo\n48: // ---------------------------------------------------------------------------\n49: \n50: function checkDevModeGuard(): void {\n51:   const cwd = process.cwd();\n52:   const pkgPath = resolve(cwd, \"package.json\");\n53: \n54:   // Are we inside the wombo-combo repo?\n55:   if (!existsSync(pkgPath)) return;\n56: \n57:   let pkgName: string | undefined;\n58:   try {\n59:     const raw = readFileSync(pkgPath, \"utf-8\");\n60:     pkgName = JSON.parse(raw).name;\n61:   } catch {\n62:     return;\n63:   }\n64:   if (pkgName !== \"wombo-combo\") return;\n65: \n66:   // We're in the wombo-combo repo. Is the source being run from a different location?\n67:   // import.meta.dir = directory of THIS file (index.ts). If it's under cwd,\n68:   // we're running local source (bun dev). If it's elsewhere (e.g. ~/.bun/install),\n69:   // we're running the globally installed binary.\n70:   const sourceDir = resolve(import.meta.dir);\n71:   const projectSrc = resolve(cwd, \"src\");\n72: \n73:   if (!sourceDir.startsWith(projectSrc)) {\n74:     console.warn(\n75:       \"\\x1b[33m[WARNING]\\x1b[0m You are running the globally installed woco binary \" +\n76:       \"inside the wombo-combo repo.\\n\" +\n77:       \"  Use \\x1b[1mbun dev <command>\\x1b[0m instead to run from local source.\\n\" +\n78:       \"  See AGENTS.md for details.\\n\"\n79:     );\n80:   }\n81: }\n82: \n83: import { cmdInit } from \"./commands/init.js\";\n84: import { cmdLaunch } from \"./commands/launch.js\";\n85: import { cmdResume } from \"./commands/resume.js\";\n86: import { cmdStatus } from \"./commands/status.js\";\n87: import { cmdVerify } from \"./commands/verify.js\";\n88: import { cmdMerge } from \"./commands/merge.js\";\n89: import { cmdRetry } from \"./commands/retry.js\";\n90: import { cmdCleanup } from \"./commands/cleanup.js\";\n91: import { cmdAbort } from \"./commands/abort.js\";\n92: import { cmdLogs } from \"./commands/logs.js\";\n93: import { cmdUpgrade } from \"./commands/upgrade.js\";\n94: import { cmdHistory } from \"./commands/history.js\";\n95: import { cmdCompletion } from \"./commands/completion.js\";\n96: import { cmdTasksList } from \"./commands/tasks/list.js\";\n97: import { cmdTasksAdd } from \"./commands/tasks/add.js\";\n98: import { cmdTasksSetStatus } from \"./commands/tasks/set-status.js\";\n99: import { cmdTasksSetPriority } from \"./commands/tasks/set-priority.js\";\n100: import { cmdTasksSetDifficulty } from \"./commands/tasks/set-difficulty.js\";\n101: import { cmdTasksCheck } from \"./commands/tasks/check.js\";\n102: import { cmdTasksArchive } from \"./commands/tasks/archive.js\";\n103: import { cmdTasksShow } from \"./commands/tasks/show.js\";\n104: import { cmdTasksGraph } from \"./commands/tasks/graph.js\";\n105: \n106: import { ensureTasksFile } from \"./lib/tasks.js\";\n107: import type { Priority, Difficulty, FeatureStatus } from \"./lib/tasks.js\";\n108: import { resolveOutputFormat, type OutputFormat } from \"./lib/output.js\";\n109: import { validateId, validateText, validateBranchName, validateDuration, assertValid } from \"./lib/validate.js\";\n110: import { findCommandDef, commandToSchema, allCommandSchemas } from \"./lib/schema.js\";\n111: import { buildToonSpec, renderToonLegend } from \"./lib/toon-spec.js\";\n112: \n113: // ---------------------------------------------------------------------------\n114: // Types\n115: // ---------------------------------------------------------------------------\n116: \n117: export interface CLIArgs {\n118:   command: string;\n119:   subcommand?: string;\n120:   // Selection options (launch)\n121:   topPriority?: number;\n122:   quickestWins?: number;\n123:   priority?: Priority;\n124:   difficulty?: Difficulty;\n125:   tasks?: string[];\n126:   allReady?: boolean;\n127:   // Launch / runtime options\n128:   maxConcurrent?: number;\n129:   model?: string;\n130:   interactive: boolean;\n131:   dryRun: boolean;\n132:   baseBranch?: string;\n133:   maxRetries?: number;\n134:   noTui: boolean;\n135:   autoPush: boolean;\n136:   // Abort options\n137:   requeue: boolean;\n138:   // General\n139:   featureId?: string;\n140:   force: boolean;\n141:   // Output format\n142:   outputFmt: OutputFormat;\n143:   // Upgrade options\n144:   checkOnly: boolean;\n145:   tag?: string;\n146:   // Features subcommand extras\n147:   status?: string;\n148:   ready?: boolean;\n149:   includeArchive?: boolean;\n150:   title?: string;\n151:   description?: string;\n152:   effort?: string;\n153:   dependsOn?: string[];\n154:   // Logs options\n155:   tail?: number;\n156:   follow?: boolean;\n157:   // Compact output\n158:   fields?: string[];\n159:   // Graph options\n160:   ascii?: boolean;\n161:   mermaidRaw?: boolean;\n162:   graphSubtasks?: boolean;\n163:   // Browser verification\n164:   browser?: boolean;\n165: }\n166: \n167: // ---------------------------------------------------------------------------\n168: // Command & Subcommand Aliases\n169: // ---------------------------------------------------------------------------\n170: \n171: /** Map of short aliases → canonical top-level command names. */\n172: export const COMMAND_ALIASES: Record<string, string> = {\n173:   i: \"init\",\n174:   l: \"launch\",\n175:   r: \"resume\",\n176:   s: \"status\",\n177:   v: \"verify\",\n178:   m: \"merge\",\n179:   re: \"retry\",\n180:   a: \"abort\",\n181:   c: \"cleanup\",\n182:   h: \"history\",\n183:   lo: \"logs\",\n184:   t: \"tasks\",\n185:   features: \"tasks\", // backward-compat full-word alias\n186:   u: \"upgrade\",\n187:   d: \"describe\",\n188:   comp: \"completion\",\n189: };\n190: \n191: /** Map of short aliases → canonical tasks subcommand names. */\n192: export const SUBCOMMAND_ALIASES: Record<string, string> = {\n193:   ls: \"list\",\n194:   a: \"add\",\n195:   ss: \"set-status\",\n196:   sp: \"set-priority\",\n197:   sd: \"set-difficulty\",\n198:   ch: \"check\",\n199:   validate: \"check\", // backward-compat full-word alias\n200:   ar: \"archive\",\n201:   sh: \"show\",\n202:   g: \"graph\",\n203: };\n204: \n205: // ---------------------------------------------------------------------------\n206: // Arg Parsing\n207: // ---------------------------------------------------------------------------\n208: \n209: export function parseArgs(argv: string[]): CLIArgs {\n210:   const args = argv.slice(2); // skip 'bun' and script path\n211:   const result: CLIArgs = {\n212:     command: args[0] || \"help\",\n213:     interactive: false,\n214:     dryRun: false,\n215:     noTui: false,\n216:     autoPush: false,\n217:     requeue: false,\n218:     force: false,\n219:     checkOnly: false,\n220:     outputFmt: resolveOutputFormat(undefined), // auto-detect until --output overrides\n221:   };\n222: \n223:   // Resolve top-level command alias (e.g., \"i\" → \"init\", \"t\" → \"tasks\")\n224:   result.command = COMMAND_ALIASES[result.command] ?? result.command;\n225: \n226:   // If the command is \"tasks\", treat the second positional as the subcommand\n227:   let startIdx = 1;\n228:   if (result.command === \"tasks\") {\n229:     result.subcommand = args[1] || \"list\";\n230:     // Resolve subcommand alias (e.g., \"ls\" → \"list\", \"ss\" → \"set-status\")\n231:     result.subcommand = SUBCOMMAND_ALIASES[result.subcommand] ?? result.subcommand;\n232:     startIdx = 2;\n233:   }\n234: \n235:   for (let i = startIdx; i < args.length; i++) {\n236:     const arg = args[i];\n237: \n238:     // Helper: consume the next argument, or exit with a clear error\n239:     function requireValue(flag: string): string {\n240:       if (i + 1 >= args.length) {\n241:         console.error(`Flag ${flag} requires a value.`);\n242:         process.exit(1);\n243:       }\n244:       return args[++i];\n245:     }\n246: \n247:     switch (arg) {\n248:       // --- Selection options ---\n249:       case \"--top-priority\":\n250:         result.topPriority = parseInt(requireValue(arg), 10);\n251:         break;\n252:       case \"--quickest-wins\":\n253:         result.quickestWins = parseInt(requireValue(arg), 10);\n254:         break;\n255:       case \"--priority\":\n256:         result.priority = requireValue(arg) as Priority;\n257:         break;\n258:       case \"--difficulty\":\n259:         result.difficulty = requireValue(arg) as Difficulty;\n260:         break;\n261:       case \"--tasks\":\n262:       case \"--features\": // backward-compat alias\n263:         result.tasks = requireValue(arg).split(\",\").map((s) => s.trim());\n264:         break;\n265:       case \"--all-ready\":\n266:         result.allReady = true;\n267:         break;\n268: \n269:       // --- Launch / runtime options ---\n270:       case \"--max-concurrent\":\n271:         result.maxConcurrent = parseInt(requireValue(arg), 10);\n272:         break;\n273:       case \"--model\":\n274:       case \"-m\":\n275:         result.model = requireValue(arg);\n276:         break;\n277:       case \"--interactive\":\n278:         result.interactive = true;\n279:         break;\n280:       case \"--dry-run\":\n281:         result.dryRun = true;\n282:         break;\n283:       case \"--no-tui\":\n284:         result.noTui = true;\n285:         break;\n286:       case \"--auto-push\":\n287:         result.autoPush = true;\n288:         break;\n289:       case \"--requeue\":\n290:         result.requeue = true;\n291:         break;\n292:       case \"--base-branch\":\n293:         result.baseBranch = requireValue(arg);\n294:         break;\n295:       case \"--max-retries\":\n296:         result.maxRetries = parseInt(requireValue(arg), 10);\n297:         break;\n298: \n299:       // --- General flags ---\n300:       case \"--force\":\n301:         result.force = true;\n302:         break;\n303:       case \"--check\":\n304:         result.checkOnly = true;\n305:         break;\n306:       case \"--tag\":\n307:       case \"--release\":\n308:         result.tag = requireValue(arg);\n309:         break;\n310:       case \"--output\":\n311:       case \"-o\":\n312:         result.outputFmt = resolveOutputFormat(requireValue(arg));\n313:         break;\n314: \n315:       // --- Tasks subcommand options ---\n316:       case \"--status\":\n317:         result.status = requireValue(arg);\n318:         break;\n319:       case \"--ready\":\n320:         result.ready = true;\n321:         break;\n322:       case \"--include-archive\":\n323:         result.includeArchive = true;\n324:         break;\n325:       case \"--title\":\n326:         result.title = requireValue(arg);\n327:         break;\n328:       case \"--description\":\n329:       case \"--desc\":\n330:         result.description = requireValue(arg);\n331:         break;\n332:       case \"--effort\":\n333:         result.effort = requireValue(arg);\n334:         break;\n335:       case \"--depends-on\":\n336:         result.dependsOn = requireValue(arg).split(\",\").map((s) => s.trim());\n337:         break;\n338:       case \"--fields\":\n339:         result.fields = requireValue(arg).split(\",\").map((s) => s.trim());\n340:         break;\n341: \n342:       // --- Graph options ---\n343:       case \"--ascii\":\n344:         result.ascii = true;\n345:         break;\n346:       case \"--mermaid\":\n347:         result.mermaidRaw = true;\n348:         break;\n349:       case \"--subtasks\":\n350:         result.graphSubtasks = true;\n351:         break;\n352: \n353:       // --- Logs options ---\n354:       case \"--tail\":\n355:         result.tail = parseInt(requireValue(arg), 10);\n356:         break;\n357:       case \"--follow\":\n358:       case \"-f\":\n359:         result.follow = true;\n360:         break;\n361: \n362:       // --- Browser verification ---\n363:       case \"--browser\":\n364:         result.browser = true;\n365:         break;\n366: \n367:       // --- Positional (feature-id, title for add, etc.) ---\n368:       default:\n369:         if (!arg.startsWith(\"-\")) {\n370:           if (!result.featureId) {\n371:             result.featureId = arg;\n372:           } else if (!result.title) {\n373:             result.title = arg;\n374:           }\n375:         }\n376:         break;\n377:     }\n378:   }\n379: \n380:   return result;\n381: }\n382: \n383: // ---------------------------------------------------------------------------\n384: // Help\n385: // ---------------------------------------------------------------------------\n386: \n387: function cmdHelp(): void {\n388:   console.log(`\n389: wombo-combo — AI Agent Orchestration System\n390: \n391:   WOMBO COMBO! Parallel feature development with AI agents.\n392: \n393: Commands:                        (alias)\n394:   init                           (i)     Generate .wombo-combo/config.json in the current project\n395:   launch                         (l)     Launch a wave of agents to implement features\n396:   resume                         (r)     Resume a previously stopped wave\n397:   status                         (s)     Show the status of the current wave\n398:   verify                         (v)     Run build verification on completed agents\n399:   merge                          (m)     Merge verified branches into the base branch\n400:   retry                          (re)    Retry a failed agent\n401:   abort                          (a)     Kill a single running agent (--requeue to return to queue)\n402:   logs                           (lo)    Pretty-print agent logs for a feature\n403:   cleanup                        (c)     Remove all wave worktrees and multiplexer sessions\n404:   history                        (h)     List/view past wave results (stored in .wombo-combo/history/)\n405:   tasks                          (t)     Manage tasks file (see below; 'features' also accepted)\n406:   upgrade                        (u)     Check for updates and upgrade wombo-combo\n407:   describe                       (d)     Emit JSON schema of a command (for AI agents)\n408:   completion                     (comp)  Generate shell completions (bash, zsh, fish)\n409:   version                                Print version and exit\n410:   help                                   Show this help\n411: \n412: Tasks Subcommands:               (alias)\n413:   tasks list                     (ls)    List tasks (--status, --priority, --difficulty, --ready, --include-archive)\n414:   tasks add <id> <title>         (a)     Add a new task (--desc, --priority, --difficulty, --effort, --depends-on)\n415:   tasks set-status <id> <s>      (ss)    Change a task's status\n416:   tasks set-priority <id> <p>    (sp)    Change a task's priority (critical/high/medium/low/wishlist)\n417:   tasks set-difficulty <id> <d>  (sd)    Change a task's difficulty (trivial/easy/medium/hard/very_hard)\n418:   tasks check                    (ch)    Validate tasks file (schema, deps, duplicates, cycles)\n419:   tasks archive [id]             (ar)    Move done/cancelled to archive (--dry-run)\n420:   tasks show <id>                (sh)    Show task details\n421:   tasks graph                    (g)     Visualize dependency graph (--ascii, --mermaid, --subtasks)\n422: \n423: Selection Options (for launch):\n424:   --top-priority N         Select top N tasks by priority\n425:   --quickest-wins N        Select N tasks with lowest effort\n426:   --priority <level>       Filter by priority (critical/high/medium/low/wishlist)\n427:   --difficulty <level>     Filter by difficulty (trivial/easy/medium/hard/very_hard)\n428:   --tasks \"id1,id2\"        Select specific tasks by ID (--features also accepted)\n429:   --all-ready              Select all tasks whose dependencies are met\n430: \n431: Launch Options:\n432:   --max-concurrent N       Max agents running in parallel (default: from config)\n433:   --model <model>          Model to use (e.g., \"anthropic/claude-sonnet-4-20250514\")\n434:   --interactive            Use multiplexer (dmux/tmux) TUI mode instead of headless\n435:   --no-tui                 Headless mode without neo-blessed TUI (periodic console dashboard)\n436:   --auto-push              Push base branch to remote after all merges complete\n437:   --dry-run                Show what would be launched without launching\n438:   --base-branch <branch>   Base branch (default: from config)\n439:   --max-retries N          Max retries per agent (default: from config)\n440:   --browser                Enable browser-based verification (run after build passes)\n441: \n442: General:\n443:   --force                  Force overwrite (e.g., for init) / skip prompts (e.g., for upgrade)\n444:   --output <fmt>           Output format: text (default on TTY) or json (default when piped)\n445:   -o <fmt>                 Alias for --output\n446:   --dry-run                Show what would happen without performing the action\n447:   --fields <list>          Comma-separated fields to include (e.g., id,status,priority)\n448: \n449: Upgrade Options:\n450:   --check                  Only check for updates, don't install\n451:   --tag <tag>              Install a specific version (e.g., v0.1.0)\n452: \n453: Logs Options:\n454:   --tail N                 Show only the last N lines\n455:   --follow, -f             Stream new output as it arrives (like tail -f)\n456: \n457: Aliases (every command has a short form):\n458:   woco i                         woco init\n459:   woco l --all-ready             woco launch --all-ready\n460:   woco t ls                      woco tasks list\n461:   woco t a my-task \"Title\"       woco tasks add my-task \"Title\"\n462:   woco t ss my-task done         woco tasks set-status my-task done\n463: \n464: Shell Completion:\n465:   eval \"$(woco completion bash)\"    # Bash: add to ~/.bashrc\n466:   eval \"$(woco completion zsh)\"     # Zsh:  add to ~/.zshrc\n467:   woco completion fish | source     # Fish (or save to ~/.config/fish/completions/woco.fish)\n468: \n469: Examples:\n470:   woco init\n471:   woco launch --quickest-wins 3\n472:   woco launch --priority high --interactive\n473:   woco launch --tasks \"auth-flow,search-api\" --max-concurrent 2\n474:   woco resume\n475:   woco status\n476:   woco verify\n477:   woco merge\n478:   woco retry auth-flow\n479:   woco abort auth-flow\n480:   woco abort auth-flow --requeue\n481:   woco abort auth-flow --output json\n482:   woco logs auth-flow\n483:   woco logs auth-flow --tail 50\n484:   woco logs auth-flow --follow\n485:   woco logs auth-flow --output json\n486:   woco cleanup\n487:   woco tasks list --status ready --priority high\n488:   woco tasks list --fields id,status,priority --output json\n489:   woco tasks add my-task \"My Cool Task\" --priority high --difficulty easy\n490:   woco tasks set-status my-task in-progress\n491:   woco tasks check\n492:   woco tasks archive --dry-run\n493:   woco tasks show my-task\n494:   woco history\n495:   woco history wave-2026-03-12-420\n496:   woco history --output json\n497:   woco describe                           # list all commands as JSON\n498:   woco describe launch                    # describe a specific command\n499:   woco describe tasks add                 # describe a subcommand\n500: `);\n501: }\n502: \n503: // ---------------------------------------------------------------------------\n504: // Main\n505: // ---------------------------------------------------------------------------\n506: \n507: async function main(): Promise<void> {\n508:   checkDevModeGuard();\n509: \n510:   const PROJECT_ROOT = resolve(process.cwd());\n511:   const args = parseArgs(process.argv);\n512: \n513:   // -----------------------------------------------------------------------\n514:   // Input validation at the CLI boundary\n515:   // -----------------------------------------------------------------------\n516:   if (args.featureId) {\n517:     assertValid(validateId(args.featureId, \"feature ID\"));\n518:   }\n519:   if (args.title) {\n520:     assertValid(validateText(args.title, \"title\"));\n521:   }\n522:   if (args.description) {\n523:     assertValid(validateText(args.description, \"description\"));\n524:   }\n525:   if (args.baseBranch) {\n526:     assertValid(validateBranchName(args.baseBranch, \"base branch\"));\n527:   }\n528:   if (args.effort) {\n529:     assertValid(validateDuration(args.effort, \"effort\"));\n530:   }\n531:   if (args.tasks) {\n532:     for (const fid of args.tasks) {\n533:       assertValid(validateId(fid, \"task ID in --tasks\"));\n534:     }\n535:   }\n536:   if (args.dependsOn) {\n537:     for (const dep of args.dependsOn) {\n538:       assertValid(validateId(dep, \"dependency ID in --depends-on\"));\n539:     }\n540:   }\n541: \n542:   // Commands that don't need config loading\n543:   if (args.command === \"version\" || args.command === \"-v\" || args.command === \"-V\") {\n544:     const pkgPath = resolve(import.meta.dir, \"..\", \"package.json\");\n545:     const pkgFile = Bun.file(pkgPath);\n546:     try {\n547:       const pkg = await pkgFile.json();\n548:       console.log(`wombo-combo ${pkg.version ?? \"(unknown version)\"}`);\n549:     } catch {\n550:       console.log(\"wombo-combo (unknown version)\");\n551:     }\n552:     return;\n553:   }\n554: \n555:   if (args.command === \"help\" || args.command === \"--help\" || args.command === \"-h\") {\n556:     cmdHelp();\n557:     return;\n558:   }\n559: \n560:   if (args.command === \"describe\") {\n561:     // Schema introspection: `woco describe [command]`\n562:     if (args.outputFmt === \"toon\") {\n563:       // Emit TOON format legend — self-describing, cacheable by agents\n564:       const pkgPath = resolve(import.meta.dir, \"..\", \"package.json\");\n565:       let version = \"unknown\";\n566:       try {\n567:         const pkg = await Bun.file(pkgPath).json();\n568:         version = pkg.version ?? \"unknown\";\n569:       } catch {}\n570: \n571:       if (!args.featureId) {\n572:         // Full TOON spec (legend + all commands)\n573:         console.log(renderToonLegend(version));\n574:       } else {\n575:         // JSON structure for the full spec (--output toon with a specific command\n576:         // still emits JSON since TOON is a line-oriented data format, not a schema format)\n577:         const spec = buildToonSpec(version);\n578:         const cmdName = args.title\n579:           ? `${args.featureId} ${args.title}`\n580:           : args.featureId;\n581:         const cmdSpec = spec.commands.find((c) => c.command === cmdName);\n582:         if (!cmdSpec) {\n583:           console.error(`Unknown command: \"${cmdName}\"`);\n584:           console.error(\"Run 'woco describe --output toon' to see the full TOON spec.\");\n585:           process.exit(1);\n586:           return;\n587:         }\n588:         console.log(JSON.stringify(cmdSpec, null, 2));\n589:       }\n590:       return;\n591:     }\n592: \n593:     if (!args.featureId) {\n594:       // No command specified — list all commands\n595:       console.log(JSON.stringify(allCommandSchemas(), null, 2));\n596:     } else {\n597:       // Describe a specific command. Handle compound names: \"features list\"\n598:       const cmdName = args.title\n599:         ? `${args.featureId} ${args.title}`\n600:         : args.featureId;\n601:       const def = findCommandDef(cmdName);\n602:       if (!def) {\n603:         console.error(`Unknown command: \"${cmdName}\"`);\n604:         console.error(\"Run 'woco describe' to list all commands.\");\n605:         process.exit(1);\n606:         return;\n607:       }\n608:       console.log(JSON.stringify(commandToSchema(def), null, 2));\n609:     }\n610:     return;\n611:   }\n612: \n613:   if (args.command === \"init\") {\n614:     await cmdInit({ projectRoot: PROJECT_ROOT, force: args.force });\n615:     return;\n616:   }\n617: \n618:   if (args.command === \"upgrade\") {\n619:     await cmdUpgrade({\n620:       force: args.force,\n621:       tag: args.tag,\n622:       checkOnly: args.checkOnly,\n623:     });\n624:     return;\n625:   }\n626: \n627:   if (args.command === \"completion\") {\n628:     cmdCompletion({ shell: args.featureId }); // first positional = shell name\n629:     return;\n630:   }\n631: \n632:   if (args.command === \"logs\") {\n633:     if (!args.featureId) {\n634:       console.error(\"Usage: woco logs <feature-id> [--tail N] [--follow] [--output json]\");\n635:       process.exit(1);\n636:       return;\n637:     }\n638:     await cmdLogs({\n639:       projectRoot: PROJECT_ROOT,\n640:       featureId: args.featureId,\n641:       tail: args.tail,\n642:       follow: args.follow,\n643:       outputFmt: args.outputFmt,\n644:     });\n645:     return;\n646:   }\n647: \n648:   // Everything else requires config\n649:   const config = loadConfig(PROJECT_ROOT);\n650:   validateConfig(config);\n651: \n652:   // Commands that operate on the tasks file — ensure it exists first\n653:   const needsTasksFile = new Set([\"launch\", \"resume\", \"verify\", \"retry\", \"tasks\"]);\n654:   if (needsTasksFile.has(args.command)) {\n655:     await ensureTasksFile(PROJECT_ROOT, config);\n656:   }\n657: \n658:   switch (args.command) {\n659:     case \"launch\":\n660:       // Apply browser verification override if --browser flag was passed\n661:       if (args.browser !== undefined) {\n662:         config.browser.enabled = args.browser;\n663:       }\n664:       await cmdLaunch({\n665:         projectRoot: PROJECT_ROOT,\n666:         config,\n667:         topPriority: args.topPriority,\n668:         quickestWins: args.quickestWins,\n669:         priority: args.priority,\n670:         difficulty: args.difficulty,\n671:         features: args.tasks,\n672:         allReady: args.allReady,\n673:         maxConcurrent: args.maxConcurrent ?? config.defaults.maxConcurrent,\n674:         model: args.model,\n675:         interactive: args.interactive,\n676:         dryRun: args.dryRun,\n677:         baseBranch: args.baseBranch ?? config.baseBranch,\n678:         maxRetries: args.maxRetries ?? config.defaults.maxRetries,\n679:         noTui: args.noTui,\n680:         autoPush: args.autoPush,\n681:         outputFmt: args.outputFmt,\n682:       });\n683:       break;\n684: \n685:     case \"resume\":\n686:       await cmdResume({\n687:         projectRoot: PROJECT_ROOT,\n688:         config,\n689:         maxConcurrent: args.maxConcurrent,\n690:         model: args.model,\n691:         interactive: args.interactive,\n692:         noTui: args.noTui,\n693:         autoPush: args.autoPush,\n694:         baseBranch: args.baseBranch,\n695:         maxRetries: args.maxRetries,\n696:       });\n697:       break;\n698: \n699:     case \"status\":\n700:       await cmdStatus({ projectRoot: PROJECT_ROOT, config, outputFmt: args.outputFmt });\n701:       break;\n702: \n703:     case \"verify\":\n704:       await cmdVerify({\n705:         projectRoot: PROJECT_ROOT,\n706:         config,\n707:         featureId: args.featureId,\n708:         model: args.model,\n709:         maxRetries: args.maxRetries,\n710:         browserVerify: args.browser,\n711:       });\n712:       break;\n713: \n714:     case \"merge\":\n715:       await cmdMerge({\n716:         projectRoot: PROJECT_ROOT,\n717:         config,\n718:         featureId: args.featureId,\n719:         autoPush: args.autoPush,\n720:         dryRun: args.dryRun,\n721:         model: args.model,\n722:       });\n723:       break;\n724: \n725:     case \"retry\": {\n726:       if (!args.featureId) {\n727:         console.error(\"Usage: woco retry <feature-id>\");\n728:         process.exit(1);\n729:         return;\n730:       }\n731:       await cmdRetry({\n732:         projectRoot: PROJECT_ROOT,\n733:         config,\n734:         featureId: args.featureId,\n735:         model: args.model,\n736:         interactive: args.interactive,\n737:         dryRun: args.dryRun,\n738:       });\n739:       break;\n740:     }\n741: \n742:     case \"cleanup\":\n743:       await cmdCleanup({ projectRoot: PROJECT_ROOT, config, dryRun: args.dryRun });\n744:       break;\n745: \n746:     case \"history\":\n747:       await cmdHistory({\n748:         projectRoot: PROJECT_ROOT,\n749:         config,\n750:         waveId: args.featureId,\n751:         outputFmt: args.outputFmt,\n752:       });\n753:       break;\n754: \n755:     case \"abort\": {\n756:       if (!args.featureId) {\n757:         console.error(\"Usage: woco abort <feature-id> [--requeue] [--output json]\");\n758:         process.exit(1);\n759:         return;\n760:       }\n761:       await cmdAbort({\n762:         projectRoot: PROJECT_ROOT,\n763:         config,\n764:         featureId: args.featureId,\n765:         requeue: args.requeue,\n766:         outputFmt: args.outputFmt,\n767:       });\n768:       break;\n769:     }\n770: \n771:     case \"tasks\":\n772:       await handleTasksSubcommand(args, PROJECT_ROOT, config);\n773:       break;\n774: \n775:     default:\n776:       console.error(`Unknown command: ${args.command}`);\n777:       cmdHelp();\n778:       process.exit(1);\n779:       return;\n780:   }\n781: }\n782: \n783: // ---------------------------------------------------------------------------\n784: // Tasks Subcommand Router\n785: // ---------------------------------------------------------------------------\n786: \n787: async function handleTasksSubcommand(\n788:   args: CLIArgs,\n789:   projectRoot: string,\n790:   config: import(\"./config.js\").WomboConfig\n791: ): Promise<void> {\n792:   switch (args.subcommand) {\n793:     case \"list\":\n794:       await cmdTasksList({\n795:         projectRoot,\n796:         config,\n797:         status: args.status as FeatureStatus | undefined,\n798:         priority: args.priority,\n799:         difficulty: args.difficulty,\n800:         ready: args.ready,\n801:         includeArchive: args.includeArchive,\n802:         outputFmt: args.outputFmt,\n803:         fields: args.fields,\n804:       });\n805:       break;\n806: \n807:     case \"add\": {\n808:       if (!args.featureId || !args.title) {\n809:         console.error(\"Usage: woco tasks add <id> <title> [--desc <desc>] [--priority <p>] [--difficulty <d>] [--effort <e>] [--depends-on <ids>]\");\n810:         process.exit(1);\n811:         return;\n812:       }\n813:       await cmdTasksAdd({\n814:         projectRoot,\n815:         config,\n816:         id: args.featureId,\n817:         title: args.title,\n818:         description: args.description,\n819:         priority: args.priority,\n820:         difficulty: args.difficulty,\n821:         effort: args.effort,\n822:         dependsOn: args.dependsOn,\n823:         outputFmt: args.outputFmt,\n824:         dryRun: args.dryRun,\n825:       });\n826:       break;\n827:     }\n828: \n829:     case \"set-status\": {\n830:       if (!args.featureId || !args.title) {\n831:         // title holds the second positional arg (the status value)\n832:         // If not provided via positional, check --status flag\n833:         const newStatus = args.title || args.status;\n834:         if (!args.featureId || !newStatus) {\n835:           console.error(\"Usage: woco tasks set-status <task-id> <status>\");\n836:           process.exit(1);\n837:           return;\n838:         }\n839:         await cmdTasksSetStatus({\n840:           projectRoot,\n841:           config,\n842:           featureId: args.featureId,\n843:           newStatus,\n844:           outputFmt: args.outputFmt,\n845:           dryRun: args.dryRun,\n846:         });\n847:       } else {\n848:         await cmdTasksSetStatus({\n849:           projectRoot,\n850:           config,\n851:           featureId: args.featureId,\n852:           newStatus: args.title, // second positional = new status\n853:           outputFmt: args.outputFmt,\n854:           dryRun: args.dryRun,\n855:         });\n856:       }\n857:       break;\n858:     }\n859: \n860:     case \"set-priority\": {\n861:       if (!args.featureId || !args.title) {\n862:         // title holds the second positional arg (the priority value)\n863:         // If not provided via positional, check --priority flag\n864:         const newPriority = args.title || (args.priority as string | undefined);\n865:         if (!args.featureId || !newPriority) {\n866:           console.error(\"Usage: woco tasks set-priority <task-id> <priority>\");\n867:           process.exit(1);\n868:           return;\n869:         }\n870:         await cmdTasksSetPriority({\n871:           projectRoot,\n872:           config,\n873:           featureId: args.featureId,\n874:           newPriority,\n875:           outputFmt: args.outputFmt,\n876:           dryRun: args.dryRun,\n877:         });\n878:       } else {\n879:         await cmdTasksSetPriority({\n880:           projectRoot,\n881:           config,\n882:           featureId: args.featureId,\n883:           newPriority: args.title, // second positional = new priority\n884:           outputFmt: args.outputFmt,\n885:           dryRun: args.dryRun,\n886:         });\n887:       }\n888:       break;\n889:     }\n890: \n891:     case \"set-difficulty\": {\n892:       if (!args.featureId || !args.title) {\n893:         // title holds the second positional arg (the difficulty value)\n894:         // If not provided via positional, check --difficulty flag\n895:         const newDifficulty = args.title || (args.difficulty as string | undefined);\n896:         if (!args.featureId || !newDifficulty) {\n897:           console.error(\"Usage: woco tasks set-difficulty <task-id> <difficulty>\");\n898:           process.exit(1);\n899:           return;\n900:         }\n901:         await cmdTasksSetDifficulty({\n902:           projectRoot,\n903:           config,\n904:           featureId: args.featureId,\n905:           newDifficulty,\n906:           outputFmt: args.outputFmt,\n907:           dryRun: args.dryRun,\n908:         });\n909:       } else {\n910:         await cmdTasksSetDifficulty({\n911:           projectRoot,\n912:           config,\n913:           featureId: args.featureId,\n914:           newDifficulty: args.title, // second positional = new difficulty\n915:           outputFmt: args.outputFmt,\n916:           dryRun: args.dryRun,\n917:         });\n918:       }\n919:       break;\n920:     }\n921: \n922:     case \"check\":\n923:       await cmdTasksCheck({ projectRoot, config, outputFmt: args.outputFmt });\n924:       break;\n925: \n926:     case \"archive\":\n927:       await cmdTasksArchive({\n928:         projectRoot,\n929:         config,\n930:         featureId: args.featureId,\n931:         dryRun: args.dryRun,\n932:         outputFmt: args.outputFmt,\n933:       });\n934:       break;\n935: \n936:     case \"show\": {\n937:       if (!args.featureId) {\n938:         console.error(\"Usage: woco tasks show <task-id>\");\n939:         process.exit(1);\n940:         return;\n941:       }\n942:       await cmdTasksShow({\n943:         projectRoot,\n944:         config,\n945:         featureId: args.featureId,\n946:         outputFmt: args.outputFmt,\n947:         fields: args.fields,\n948:       });\n949:       break;\n950:     }\n951: \n952:     case \"graph\":\n953:       await cmdTasksGraph({\n954:         projectRoot,\n955:         config,\n956:         status: args.status as FeatureStatus | undefined,\n957:         ascii: args.ascii,\n958:         mermaid: args.mermaidRaw,\n959:         subtasks: args.graphSubtasks,\n960:         outputFmt: args.outputFmt,\n961:       });\n962:       break;\n963: \n964:     case \"help\":\n965:     case \"--help\":\n966:     case \"-h\":\n967:       cmdHelp();\n968:       break;\n969: \n970:     default:\n971:       console.error(`Unknown tasks subcommand: ${args.subcommand}`);\n972:       console.error(\"Run 'woco tasks help' or 'woco help' for usage.\");\n973:       process.exit(1);\n974:       return;\n975:   }\n976: }\n977: \n978: // ---------------------------------------------------------------------------\n979: // Error Handlers & Entry\n980: // ---------------------------------------------------------------------------\n981: \n982: // Global error handlers — prevent silent crashes\n983: process.on(\"uncaughtException\", (err) => {\n984:   console.error(`\\n[FATAL] Uncaught exception: ${err.message}`);\n985:   console.error(err.stack);\n986:   try {\n987:     const state = loadState(process.cwd());\n988:     if (state) saveState(process.cwd(), state);\n989:   } catch {}\n990:   process.exit(1);\n991: });\n992: \n993: process.on(\"unhandledRejection\", (reason: any) => {\n994:   console.error(`\\n[FATAL] Unhandled rejection: ${reason?.message || reason}`);\n995:   if (reason?.stack) console.error(reason.stack);\n996:   try {\n997:     const state = loadState(process.cwd());\n998:     if (state) saveState(process.cwd(), state);\n999:   } catch {}\n1000:   process.exit(1);\n1001: });\n1002: \n1003: main().catch((err) => {\n1004:   console.error(\"Fatal error:\", err.message);\n1005:   process.exit(1);\n1006: });\n\n(End of file - total 1006 lines)\n</content>","title":"src/index.ts","metadata":{"preview":"#!/usr/bin/env bun\n/**\n * index.ts — CLI entry point for the wombo-combo agent orchestration system.\n *\n * Every command has a short alias (e.g., woco i = woco init, woco t ls = woco tasks list).\n *\n * Usage:\n *   woco init                                         (alias: i)\n *   woco launch --top-priority 3                      (alias: l)\n *   woco launch --quickest-wins 5\n *   woco launch --priority high\n *   woco launch --difficulty easy\n *   woco launch --tasks \"feat-a,feat-b\"\n *   woco launch --all-ready\n *   woco launch ... --max-concurrent 3 --model \"anthropic/claude-sonnet-4-20250514\"\n *   woco launch ... --interactive\n *   woco resume                                       (alias: r)\n *   woco status                                       (alias: s)\n *   woco verify [feature-id]                          (alias: v)\n *   woco merge [feature-id]                           (alias: m)","truncated":false,"loaded":[]},"time":{"start":1773435850545,"end":1773435850552}}}}
