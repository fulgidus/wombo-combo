{"type":"tool_use","timestamp":1773435843006,"sessionID":"ses_316fcb4c5ffehqcHU7q5TvsiXt","part":{"id":"prt_ce9036d190011xo6EdURdjn2aP","sessionID":"ses_316fcb4c5ffehqcHU7q5TvsiXt","messageID":"msg_ce903644f001E9izFBREI9i5Ph","type":"tool","callID":"toolu_vrtx_01XSTn8vRxBYco1C2SLrufSY","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-json-operational-commands/src/commands/status.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-json-operational-commands/src/commands/status.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * status.ts — Show the status of the current wave.\n3:  *\n4:  * Usage:\n5:  *   woco status                  # human-readable dashboard\n6:  *   woco status --output json    # structured JSON for programmatic access\n7:  *\n8:  * Loads the wave state, checks for dead processes, and prints a dashboard\n9:  * or emits structured JSON with wave metadata, agent states, timing info,\n10:  * and summary statistics.\n11:  */\n12: \n13: import type { WomboConfig } from \"../config.js\";\n14: import { loadState, saveState, updateAgent, agentCounts, isWaveComplete } from \"../lib/state.js\";\n15: import type { WaveState, AgentState, AgentStatus } from \"../lib/state.js\";\n16: import { isProcessRunning } from \"../lib/launcher.js\";\n17: import { branchHasChanges } from \"../lib/worktree.js\";\n18: import { printDashboard } from \"../lib/ui.js\";\n19: import { output, outputMessage, type OutputFormat } from \"../lib/output.js\";\n20: \n21: export interface StatusOptions {\n22:   projectRoot: string;\n23:   config: WomboConfig;\n24:   outputFmt?: OutputFormat;\n25: }\n26: \n27: // ---------------------------------------------------------------------------\n28: // JSON Output Builder\n29: // ---------------------------------------------------------------------------\n30: \n31: /**\n32:  * Compute elapsed time in milliseconds from a start ISO timestamp to now.\n33:  */\n34: function elapsedMs(startedAt: string | null): number | null {\n35:   if (!startedAt) return null;\n36:   return Date.now() - new Date(startedAt).getTime();\n37: }\n38: \n39: /**\n40:  * Format milliseconds as a human-readable duration string (e.g. \"2h15m\", \"3m\").\n41:  */\n42: function formatElapsed(ms: number | null): string | null {\n43:   if (ms === null) return null;\n44:   const mins = Math.floor(ms / 60000);\n45:   if (mins < 60) return `${mins}m`;\n46:   const hours = Math.floor(mins / 60);\n47:   const remMins = mins % 60;\n48:   return `${hours}h${remMins}m`;\n49: }\n50: \n51: /**\n52:  * Build the structured JSON representation of an agent's state.\n53:  */\n54: function agentToJson(agent: AgentState): Record<string, unknown> {\n55:   const elapsed = elapsedMs(agent.started_at);\n56:   return {\n57:     feature_id: agent.feature_id,\n58:     branch: agent.branch,\n59:     worktree: agent.worktree,\n60:     status: agent.status,\n61:     pid: agent.pid,\n62:     retries: agent.retries,\n63:     max_retries: agent.max_retries,\n64:     started_at: agent.started_at,\n65:     completed_at: agent.completed_at,\n66:     elapsed_ms: elapsed,\n67:     elapsed_formatted: formatElapsed(elapsed),\n68:     build_passed: agent.build_passed,\n69:     error: agent.error,\n70:     activity: agent.activity,\n71:     activity_updated_at: agent.activity_updated_at,\n72:     effort_estimate_ms: agent.effort_estimate_ms,\n73:   };\n74: }\n75: \n76: /**\n77:  * Build the full structured JSON for the wave status.\n78:  * Schema:\n79:  *   {\n80:  *     wave_id: string,\n81:  *     base_branch: string,\n82:  *     started_at: string (ISO 8601),\n83:  *     updated_at: string (ISO 8601),\n84:  *     elapsed_ms: number,\n85:  *     elapsed_formatted: string,\n86:  *     max_concurrent: number,\n87:  *     model: string | null,\n88:  *     interactive: boolean,\n89:  *     is_complete: boolean,\n90:  *     agents: Agent[],\n91:  *     summary: { total, queued, installing, running, completed, verified, failed, merged, retry, resolving_conflict }\n92:  *   }\n93:  */\n94: function buildStatusJson(state: WaveState): Record<string, unknown> {\n95:   const counts = agentCounts(state);\n96:   const waveElapsed = elapsedMs(state.started_at);\n97: \n98:   return {\n99:     wave_id: state.wave_id,\n100:     base_branch: state.base_branch,\n101:     started_at: state.started_at,\n102:     updated_at: state.updated_at,\n103:     elapsed_ms: waveElapsed,\n104:     elapsed_formatted: formatElapsed(waveElapsed),\n105:     max_concurrent: state.max_concurrent,\n106:     model: state.model,\n107:     interactive: state.interactive,\n108:     is_complete: isWaveComplete(state),\n109:     agents: state.agents.map(agentToJson),\n110:     summary: {\n111:       total: state.agents.length,\n112:       ...counts,\n113:     },\n114:   };\n115: }\n116: \n117: // ---------------------------------------------------------------------------\n118: // Command\n119: // ---------------------------------------------------------------------------\n120: \n121: export async function cmdStatus(opts: StatusOptions): Promise<void> {\n122:   const fmt = opts.outputFmt ?? \"text\";\n123:   const state = loadState(opts.projectRoot);\n124: \n125:   if (!state) {\n126:     outputMessage(fmt, \"No active wave. Use 'woco launch' to start one.\", {\n127:       wave_id: null,\n128:       agents: [],\n129:       summary: { total: 0 },\n130:     });\n131:     return;\n132:   }\n133: \n134:   // Update running agent status from process state\n135:   for (const agent of state.agents) {\n136:     if (agent.status === \"running\" && agent.pid) {\n137:       if (!isProcessRunning(agent.pid)) {\n138:         // Check if the agent actually made any commits before marking completed\n139:         if (branchHasChanges(opts.projectRoot, agent.branch, state.base_branch)) {\n140:           updateAgent(state, agent.feature_id, {\n141:             status: \"completed\",\n142:             completed_at: new Date().toISOString(),\n143:           });\n144:         } else {\n145:           // Agent died without producing any code — mark as failed, not completed\n146:           updateAgent(state, agent.feature_id, {\n147:             status: \"failed\",\n148:             error: \"Agent process exited without making any commits\",\n149:             completed_at: new Date().toISOString(),\n150:           });\n151:         }\n152:       }\n153:     }\n154:   }\n155: \n156:   // Repair pass: re-check agents marked \"completed\" but never verified.\n157:   // Catches agents falsely promoted to completed by older versions of status.ts\n158:   // that didn't check branchHasChanges.\n159:   for (const agent of state.agents) {\n160:     if (agent.status === \"completed\" && agent.build_passed === null) {\n161:       if (!branchHasChanges(opts.projectRoot, agent.branch, state.base_branch)) {\n162:         updateAgent(state, agent.feature_id, {\n163:           status: \"failed\",\n164:           error: \"Agent process exited without making any commits\",\n165:         });\n166:       }\n167:     }\n168:   }\n169:   saveState(opts.projectRoot, state);\n170: \n171:   output(fmt, buildStatusJson(state), () => {\n172:     printDashboard(state);\n173:   });\n174: }\n\n(End of file - total 174 lines)\n</content>","title":"src/commands/status.ts","metadata":{"preview":"/**\n * status.ts — Show the status of the current wave.\n *\n * Usage:\n *   woco status                  # human-readable dashboard\n *   woco status --output json    # structured JSON for programmatic access\n *\n * Loads the wave state, checks for dead processes, and prints a dashboard\n * or emits structured JSON with wave metadata, agent states, timing info,\n * and summary statistics.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport { loadState, saveState, updateAgent, agentCounts, isWaveComplete } from \"../lib/state.js\";\nimport type { WaveState, AgentState, AgentStatus } from \"../lib/state.js\";\nimport { isProcessRunning } from \"../lib/launcher.js\";\nimport { branchHasChanges } from \"../lib/worktree.js\";\nimport { printDashboard } from \"../lib/ui.js\";\nimport { output, outputMessage, type OutputFormat } from \"../lib/output.js\";\n","truncated":false,"loaded":[]},"time":{"start":1773435843001,"end":1773435843005}}}}
{"type":"tool_use","timestamp":1773435843631,"sessionID":"ses_316fcb4c5ffehqcHU7q5TvsiXt","part":{"id":"prt_ce90371bb001vFLBhJojbQ4Mvr","sessionID":"ses_316fcb4c5ffehqcHU7q5TvsiXt","messageID":"msg_ce903644f001E9izFBREI9i5Ph","type":"tool","callID":"toolu_vrtx_01Vinz4Jzk1pyd8x5AZ2f5CM","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-json-operational-commands/src/commands/launch.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-json-operational-commands/src/commands/launch.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * launch.ts — Launch a wave of agents.\n3:  *\n4:  * Usage: woco launch [selection options] [launch options]\n5:  *\n6:  * This is the primary entry point for starting a new wave. It selects features\n7:  * from the features file, creates a wave state, sets up worktrees, and launches\n8:  * agent processes (either headless or interactive via dmux/tmux).\n9:  *\n10:  * IMPORTANT: This file also exports shared helper functions that are reused\n11:  * by resume.ts and other commands:\n12:  *   - launchSingleHeadless\n13:  *   - handleBuildVerification\n14:  *   - handleRetry\n15:  *   - launchNextQueued\n16:  */\n17: \n18: import { execSync } from \"node:child_process\";\n19: import { existsSync, readFileSync } from \"node:fs\";\n20: import { resolve } from \"node:path\";\n21: import type { WomboConfig } from \"../config.js\";\n22: import type { Feature, SelectionOptions, Priority, Difficulty } from \"../lib/tasks.js\";\n23: import { loadFeatures, selectFeatures, parseDurationMinutes, saveFeatures } from \"../lib/tasks.js\";\n24: import {\n25:   loadState,\n26:   saveState,\n27:   createWaveState,\n28:   createAgentState,\n29:   updateAgent,\n30:   activeAgents,\n31:   queuedAgents,\n32:   readyToLaunchAgents,\n33:   areAgentDepsReady,\n34:   cancelDownstream,\n35:   isWaveComplete,\n36:   type WaveState,\n37:   type AgentState,\n38:   type SerializedSchedulePlan,\n39: } from \"../lib/state.js\";\n40: import {\n41:   createWorktree,\n42:   installDeps,\n43:   featureBranchName,\n44:   worktreePath,\n45:   worktreeReady,\n46:   branchHasChanges,\n47:   branchExists,\n48:   removeWorktree,\n49:   log as wtLog,\n50: } from \"../lib/worktree.js\";\n51: import { generatePrompt, generateConflictResolutionPrompt } from \"../lib/prompt.js\";\n52: import {\n53:   launchHeadless,\n54:   retryHeadless,\n55:   launchInteractive,\n56:   retryInteractive,\n57:   launchConflictResolver,\n58:   isProcessRunning,\n59:   getMultiplexerName,\n60: } from \"../lib/launcher.js\";\n61: import { ProcessMonitor } from \"../lib/monitor.js\";\n62: import { runBuild, runFullVerification } from \"../lib/verifier.js\";\n63: import { mergeBranch, mergeBaseIntoFeature, pushBaseBranch, canMerge, enqueueMerge } from \"../lib/merger.js\";\n64: import {\n65:   printDashboard,\n66:   printFeatureSelection,\n67:   printAgentUpdate,\n68: } from \"../lib/ui.js\";\n69: import { WomboTUI } from \"../lib/tui.js\";\n70: import { ensureAgentDefinition } from \"../lib/templates.js\";\n71: import {\n72:   buildDepGraph,\n73:   validateDepGraph,\n74:   buildSchedulePlan,\n75:   formatSchedulePlan,\n76:   getStreamForFeature,\n77:   type DepGraph,\n78:   type SchedulePlan,\n79: } from \"../lib/dependency-graph.js\";\n80: import { ensureProxyRunning, isPortlessAvailable, portlessUrl } from \"../lib/portless.js\";\n81: import { outputError, type OutputFormat } from \"../lib/output.js\";\n82: import {\n83:   detectMultiplexer,\n84:   muxAttachCommand,\n85:   muxListCommand,\n86: } from \"../lib/multiplexer.js\";\n87: import { exportWaveHistory } from \"../lib/history.js\";\n88: import {\n89:   prepareAgentDefinitions,\n90:   isSpecializedAgent,\n91:   writeAgentToWorktree,\n92:   type AgentResolution,\n93: } from \"../lib/agent-registry.js\";\n94: import { patchImportedAgent } from \"../lib/templates.js\";\n95: import {\n96:   tuiPreflightConfirm,\n97:   consolePreflightConfirm,\n98: } from \"../lib/preflight.js\";\n99: \n100: // ---------------------------------------------------------------------------\n101: // Types\n102: // ---------------------------------------------------------------------------\n103: \n104: export interface LaunchCommandOptions {\n105:   projectRoot: string;\n106:   config: WomboConfig;\n107:   // Selection\n108:   topPriority?: number;\n109:   quickestWins?: number;\n110:   priority?: Priority;\n111:   difficulty?: Difficulty;\n112:   features?: string[];\n113:   allReady?: boolean;\n114:   // Launch\n115:   maxConcurrent: number;\n116:   model?: string;\n117:   interactive: boolean;\n118:   dryRun: boolean;\n119:   baseBranch: string;\n120:   maxRetries: number;\n121:   noTui: boolean;\n122:   autoPush: boolean;\n123:   // Output\n124:   outputFmt?: OutputFormat;\n125: }\n126: \n127: // ---------------------------------------------------------------------------\n128: // Shared Helpers (exported for resume.ts and others)\n129: // ---------------------------------------------------------------------------\n130: \n131: /**\n132:  * Mark a feature as done in the features file after a successful merge.\n133:  * Updates status to \"done\", completion to 100, and sets ended_at.\n134:  *\n135:  * GUARD: Verifies that the feature branch has actually been merged into\n136:  * baseBranch before allowing the status change. This prevents callers\n137:  * from accidentally marking verified-but-unmerged features as done.\n138:  */\n139: export function markFeatureDone(\n140:   projectRoot: string,\n141:   featureId: string,\n142:   config: WomboConfig,\n143:   baseBranch: string\n144: ): void {\n145:   try {\n146:     // Verify the feature branch was actually merged into base\n147:     const branch = featureBranchName(featureId, config);\n148:     try {\n149:       execSync(`git merge-base --is-ancestor \"${branch}\" \"${baseBranch}\"`, {\n150:         cwd: projectRoot,\n151:         stdio: \"pipe\",\n152:       });\n153:     } catch {\n154:       // git merge-base --is-ancestor exits non-zero if NOT an ancestor\n155:       console.error(\n156:         `Warning: ${featureId} branch \"${branch}\" is not merged into \"${baseBranch}\" — refusing to mark as done`\n157:       );\n158:       return;\n159:     }\n160: \n161:     const data = loadFeatures(projectRoot, config);\n162:     const feature = data.tasks.find((f: Feature) => f.id === featureId);\n163:     if (feature && feature.status !== \"done\") {\n164:       feature.status = \"done\";\n165:       feature.completion = 100;\n166:       feature.ended_at = new Date().toISOString();\n167:       saveFeatures(projectRoot, config, data);\n168:     }\n169:   } catch (err: any) {\n170:     // Non-fatal — log but don't crash the wave\n171:     console.error(`Warning: failed to update feature status for ${featureId}: ${err.message}`);\n172:   }\n173: }\n174: \n175: /**\n176:  * Launch a single agent in headless mode.\n177:  * Sets up worktree, installs deps, generates prompt, launches agent process.\n178:  * If agentResolutions is provided and contains a specialized agent for this\n179:  * feature, the patched agent definition is written into the worktree.\n180:  */\n181: export async function launchSingleHeadless(\n182:   projectRoot: string,\n183:   state: WaveState,\n184:   agent: AgentState,\n185:   feature: Feature,\n186:   monitor: ProcessMonitor,\n187:   config: WomboConfig,\n188:   model?: string,\n189:   agentResolutions?: Map<string, AgentResolution>\n190: ): Promise<void> {\n191:   updateAgent(state, agent.feature_id, {\n192:     status: \"installing\",\n193:     started_at: new Date().toISOString(),\n194:     activity: \"setting up worktree...\",\n195:   });\n196:   saveState(projectRoot, state);\n197: \n198:   try {\n199:     // Check if this agent is reusing a chain predecessor's worktree\n200:     const isChainReuse = agent.depends_on.some((depId) => {\n201:       const depAgent = state.agents.find((a) => a.feature_id === depId);\n202:       return depAgent && depAgent.worktree === agent.worktree;\n203:     });\n204: \n205:     if (isChainReuse && worktreeReady(agent.worktree)) {\n206:       // Chain worktree reuse: the worktree already exists from a predecessor.\n207:       // Create a new branch for this feature and switch the worktree to it.\n208:       wtLog(agent.feature_id, \"reusing chain worktree — switching branch...\");\n209:       updateAgent(state, agent.feature_id, { activity: \"switching branch (chain reuse)...\" });\n210: \n211:       try {\n212:         // Create the new feature branch from base (in the worktree)\n213:         execSync(`git checkout -B \"${agent.branch}\" \"${state.base_branch}\"`, {\n214:           cwd: agent.worktree,\n215:           stdio: \"pipe\",\n216:         });\n217:         wtLog(agent.feature_id, `switched to branch ${agent.branch}`);\n218:       } catch (branchErr: any) {\n219:         wtLog(agent.feature_id, `branch switch failed: ${branchErr.message}`);\n220:         // Fall through to normal worktree creation\n221:         await createWorktree(projectRoot, feature.id, state.base_branch, config);\n222:       }\n223:     } else if (worktreeReady(agent.worktree)) {\n224:       // Skip worktree setup if already ready (resume case)\n225:       wtLog(agent.feature_id, \"worktree already exists, skipping setup\");\n226:     } else {\n227:       // Create worktree (async — doesn't block other agents)\n228:       await createWorktree(projectRoot, feature.id, state.base_branch, config);\n229: \n230:       // Install dependencies (async)\n231:       updateAgent(state, agent.feature_id, { activity: \"installing deps...\" });\n232:       await installDeps(agent.worktree, feature.id, config);\n233:     }\n234: \n235:     // Generate prompt\n236:     const prompt = generatePrompt(feature, state.base_branch, config);\n237: \n238:     // Write specialized agent to worktree if applicable\n239:     const resolution = agentResolutions?.get(feature.id);\n240:     const agentName = agent.agent_name ?? undefined;\n241:     if (resolution && isSpecializedAgent(resolution)) {\n242:       try {\n243:         const patchedContent = patchImportedAgent(resolution.rawContent, config, projectRoot);\n244:         writeAgentToWorktree(agent.worktree, resolution.name, patchedContent);\n245:         wtLog(agent.feature_id, `wrote specialized agent: ${resolution.name}`);\n246:       } catch (err: any) {\n247:         wtLog(agent.feature_id, `WARN: failed to write specialized agent, using generalist: ${err.message}`);\n248:       }\n249:     }\n250: \n251:     // Launch agent\n252:     wtLog(agent.feature_id, \"launching agent...\");\n253:     const result = launchHeadless({\n254:       worktreePath: agent.worktree,\n255:       featureId: feature.id,\n256:       prompt,\n257:       model,\n258:       config,\n259:       agentName,\n260:     });\n261: \n262:     updateAgent(state, agent.feature_id, {\n263:       status: \"running\",\n264:       pid: result.pid,\n265:       activity: \"starting...\",\n266:     });\n267:     saveState(projectRoot, state);\n268: \n269:     monitor.addProcess(feature.id, result.process);\n270:     wtLog(agent.feature_id, `running (PID: ${result.pid})`);\n271:   } catch (err: any) {\n272:     updateAgent(state, agent.feature_id, {\n273:       status: \"failed\",\n274:       error: err.message,\n275:       activity: null,\n276:       completed_at: new Date().toISOString(),\n277:     });\n278:     saveState(projectRoot, state);\n279:     wtLog(agent.feature_id, `SETUP FAILED: ${err.message.split(\"\\n\")[0]}`);\n280:   }\n281: }\n282: \n283: /**\n284:  * Handle build verification after agent completion.\n285:  * Runs build, auto-merges on pass, retries on failure if retries remain.\n286:  *\n287:  * ASYNC — runs build and merge without blocking the event loop.\n288:  */\n289: export async function handleBuildVerification(\n290:   projectRoot: string,\n291:   state: WaveState,\n292:   agent: AgentState,\n293:   feature: Feature,\n294:   config: WomboConfig,\n295:   model?: string,\n296:   monitor?: ProcessMonitor\n297: ): Promise<void> {\n298:   try {\n299:     printAgentUpdate(agent, \"verifying build...\");\n300: \n301:     // Use full verification pipeline (build + optional browser tests)\n302:     const fullResult = await runFullVerification(agent.worktree, agent.feature_id, config);\n303:     const buildResult = fullResult.build;\n304: \n305:     // Report browser test status if they ran\n306:     if (fullResult.browser.ran && fullResult.browser.browserResult) {\n307:       const br = fullResult.browser.browserResult;\n308:       printAgentUpdate(\n309:         agent,\n310:         `BROWSER: ${br.summary} (${Math.round(br.totalDurationMs / 1000)}s)`\n311:       );\n312:     } else if (fullResult.browser.skipReason && config.browser.enabled) {\n313:       printAgentUpdate(agent, `BROWSER: skipped — ${fullResult.browser.skipReason}`);\n314:     }\n315: \n316:     if (fullResult.overallPassed) {\n317:       updateAgent(state, agent.feature_id, {\n318:         status: \"verified\",\n319:         build_passed: true,\n320:         build_output: null,\n321:       });\n322:       saveState(projectRoot, state);\n323:       printAgentUpdate(agent, `BUILD PASSED (${Math.round(buildResult.durationMs / 1000)}s)`);\n324: \n325:       // Auto-merge: attempt merge + conflict resolution\n326:       await attemptMerge(projectRoot, state, agent, feature, config, model);\n327:     } else {\n328:       const errorSummary = fullResult.combinedErrorSummary;\n329: \n330:       if (agent.retries < agent.max_retries) {\n331:         updateAgent(state, agent.feature_id, {\n332:           status: \"retry\",\n333:           retries: agent.retries + 1,\n334:           build_passed: false,\n335:           build_output: errorSummary,\n336:         });\n337:         saveState(projectRoot, state);\n338:         printAgentUpdate(\n339:           agent,\n340:           `VERIFICATION FAILED — retrying (${agent.retries}/${agent.max_retries})`\n341:         );\n342: \n343:         // Retry with error details\n344:         if (agent.session_id) {\n345:           const retryResult = retryHeadless({\n346:             worktreePath: agent.worktree,\n347:             featureId: agent.feature_id,\n348:             sessionId: agent.session_id,\n349:             buildErrors: errorSummary,\n350:             model,\n351:             config,\n352:           });\n353: \n354:           updateAgent(state, agent.feature_id, {\n355:             status: \"running\",\n356:             pid: retryResult.pid,\n357:           });\n358:           saveState(projectRoot, state);\n359: \n360:           // Add retry process to monitor so events are tracked\n361:           if (monitor) {\n362:             monitor.addProcess(agent.feature_id, retryResult.process);\n363:           }\n364:         }\n365:       } else {\n366:         updateAgent(state, agent.feature_id, {\n367:           status: \"failed\",\n368:           build_passed: false,\n369:           build_output: errorSummary,\n370:           error: `Verification failed after ${agent.max_retries} retries`,\n371:           completed_at: new Date().toISOString(),\n372:         });\n373:         saveState(projectRoot, state);\n374:         printAgentUpdate(agent, \"VERIFICATION FAILED — max retries reached\");\n375: \n376:         // Cascade failure to downstream agents\n377:         const cancelled = cancelDownstream(state, agent.feature_id);\n378:         if (cancelled.length > 0) {\n379:           printAgentUpdate(agent, `downstream cancelled: ${cancelled.join(\", \")}`);\n380:           saveState(projectRoot, state);\n381:         }\n382:       }\n383:     }\n384:   } catch (err: any) {\n385:     // Catch-all — never let build verification crash the process\n386:     printAgentUpdate(agent, `VERIFY ERROR: ${err.message?.slice(0, 100)}`);\n387:     updateAgent(state, agent.feature_id, {\n388:       status: \"failed\",\n389:       error: `Build verification error: ${err.message}`,\n390:       completed_at: new Date().toISOString(),\n391:     });\n392:     saveState(projectRoot, state);\n393:   }\n394: }\n395: \n396: /**\n397:  * Attempt to merge a verified agent's branch into the base branch.\n398:  *\n399:  * Handles conflict detection, base-into-feature merge, and resolver agent\n400:  * launch. Extracted from handleBuildVerification so it can be called\n401:  * independently (e.g., from resume's sequential merge phase).\n402:  *\n403:  * All merge operations are serialized via enqueueMerge() to prevent\n404:  * concurrent checkout races on the project root.\n405:  */\n406: export async function attemptMerge(\n407:   projectRoot: string,\n408:   state: WaveState,\n409:   agent: AgentState,\n410:   feature: Feature,\n411:   config: WomboConfig,\n412:   model?: string,\n413: ): Promise<void> {\n414:   return enqueueMerge(async () => {\n415:     printAgentUpdate(agent, \"auto-merging...\");\n416:     try {\n417:       // Pre-flight check: detect conflicts before attempting the real merge.\n418:       // This avoids the expensive merge-then-abort dance for known conflicts.\n419:       const preCheck = await canMerge(projectRoot, agent.branch, state.base_branch);\n420:       if (!preCheck.canMerge) {\n421:         printAgentUpdate(agent, `conflict detected (pre-flight) — attempting resolution...`);\n422:         await handleMergeConflict(\n423:           projectRoot, state, agent, feature, config, model,\n424:           preCheck.reason\n425:         );\n426:         return;\n427:       }\n428: \n429:       const mergeResult = await mergeBranch(projectRoot, agent.branch, state.base_branch, config);\n430: \n431:       if (mergeResult.success) {\n432:         handleMergeSuccess(projectRoot, state, agent, config, mergeResult.commitHash);\n433:         return;\n434:       }\n435: \n436:       // Merge failed despite clean pre-flight — race with another merge or\n437:       // a git state issue. Fall through to conflict resolution.\n438:       printAgentUpdate(agent, `MERGE CONFLICT — attempting resolution...`);\n439:       await handleMergeConflict(\n440:         projectRoot, state, agent, feature, config, model,\n441:         mergeResult.error ?? \"Unknown merge error\"\n442:       );\n443:     } catch (mergeErr: any) {\n444:       // Unexpected exception — stay in \"verified\" (retryable) but record the\n445:       // error so the user can see what went wrong instead of silent stalling.\n446:       printAgentUpdate(agent, `AUTO-MERGE ERROR: ${mergeErr.message?.slice(0, 100)}`);\n447:       updateAgent(state, agent.feature_id, {\n448:         error: `Auto-merge error: ${mergeErr.message}`,\n449:       });\n450:       saveState(projectRoot, state);\n451:     }\n452:   });\n453: }\n454: \n455: /**\n456:  * Handle a successful merge: update state, mark feature done, clean up.\n457:  */\n458: function handleMergeSuccess(\n459:   projectRoot: string,\n460:   state: WaveState,\n461:   agent: AgentState,\n462:   config: WomboConfig,\n463:   commitHash: string | null,\n464:   label = \"MERGED\",\n465: ): void {\n466:   updateAgent(state, agent.feature_id, {\n467:     status: \"merged\",\n468:     completed_at: new Date().toISOString(),\n469:   });\n470:   saveState(projectRoot, state);\n471:   printAgentUpdate(agent, `${label} (${commitHash?.slice(0, 7)})`);\n472: \n473:   markFeatureDone(projectRoot, agent.feature_id, config, state.base_branch);\n474: \n475:   // Clean up worktree — but preserve it if downstream agents in the same\n476:   // chain share this worktree.\n477:   const hasChainSuccessor = agent.depended_on_by.some((depId) => {\n478:     const depAgent = state.agents.find((a) => a.feature_id === depId);\n479:     return depAgent && depAgent.worktree === agent.worktree;\n480:   });\n481: \n482:   if (hasChainSuccessor) {\n483:     printAgentUpdate(agent, \"worktree preserved for chain successor\");\n484:   } else {\n485:     try {\n486:       removeWorktree(projectRoot, agent.worktree, true);\n487:       printAgentUpdate(agent, \"worktree and branch removed\");\n488:     } catch {\n489:       // Not critical — worktree cleanup is best-effort\n490:     }\n491:   }\n492: }\n493: \n494: /**\n495:  * Handle a merge conflict: merge base into feature, then either retry the\n496:  * direct merge (if base merged cleanly) or launch a resolver agent.\n497:  *\n498:  * All failure paths record the error on the agent (which stays \"verified\")\n499:  * so the merge can be retried without silently stalling.\n500:  */\n501: async function handleMergeConflict(\n502:   projectRoot: string,\n503:   state: WaveState,\n504:   agent: AgentState,\n505:   feature: Feature,\n506:   config: WomboConfig,\n507:   model: string | undefined,\n508:   mergeError: string,\n509: ): Promise<void> {\n510:   try {\n511:     // Merge base INTO the feature worktree to create conflict markers\n512:     const conflictResult = await mergeBaseIntoFeature(\n513:       agent.worktree,\n514:       state.base_branch,\n515:       config\n516:     );\n517: \n518:     if (conflictResult.error && !conflictResult.conflicting) {\n519:       // Setup itself failed — stay as \"verified\" (retryable) with error\n520:       printAgentUpdate(agent, `CONFLICT SETUP FAILED: ${conflictResult.error.slice(0, 100)}`);\n521:       updateAgent(state, agent.feature_id, {\n522:         error: `Conflict setup failed: ${conflictResult.error}`,\n523:       });\n524:       saveState(projectRoot, state);\n525:       return;\n526:     }\n527: \n528:     if (!conflictResult.conflicting) {\n529:       // Base merged cleanly into feature — retry merge into base.\n530:       printAgentUpdate(agent, \"base merged cleanly into feature — retrying merge...\");\n531:       const retryMerge = await mergeBranch(projectRoot, agent.branch, state.base_branch, config);\n532:       if (retryMerge.success) {\n533:         handleMergeSuccess(projectRoot, state, agent, config, retryMerge.commitHash, \"MERGED after rebase\");\n534:         return;\n535:       }\n536: \n537:       // Retry still failed — need conflict resolution.\n538:       // Merge base into feature again to get conflict files for the resolver.\n539:       printAgentUpdate(agent, `retry merge still failed — launching resolver agent...`);\n540:       const secondConflict = await mergeBaseIntoFeature(\n541:         agent.worktree,\n542:         state.base_branch,\n543:         config\n544:       );\n545: \n546:       const conflictFiles = secondConflict.conflicting\n547:         ? secondConflict.files\n548:         : [\"(unknown — merge direction mismatch)\"];\n549: \n550:       await launchResolverAndRetryMerge(\n551:         projectRoot, state, agent, feature, config, model,\n552:         retryMerge.error ?? mergeError, conflictFiles\n553:       );\n554:       return;\n555:     }\n556: \n557:     // There are real conflicts — launch a resolver agent\n558:     printAgentUpdate(\n559:       agent,\n560:       `${conflictResult.files.length} conflicting file(s): ${conflictResult.files.join(\", \")}`\n561:     );\n562: \n563:     await launchResolverAndRetryMerge(\n564:       projectRoot, state, agent, feature, config, model,\n565:       mergeError, conflictResult.files\n566:     );\n567:   } catch (conflictErr: any) {\n568:     // Unexpected error during conflict handling — stay \"verified\" with error\n569:     printAgentUpdate(agent, `CONFLICT RESOLUTION ERROR: ${conflictErr.message?.slice(0, 100)}`);\n570:     updateAgent(state, agent.feature_id, {\n571:       error: `Conflict resolution error: ${conflictErr.message}`,\n572:     });\n573:     saveState(projectRoot, state);\n574:   }\n575: }\n576: \n577: /**\n578:  * Launch a conflict resolver agent, wait for it to finish, re-verify build,\n579:  * and retry the merge. Supports configurable retry attempts (defaults to 1,\n580:  * up to config.defaults.maxRetries + 1).\n581:  *\n582:  * The resolver is re-launched with updated conflict state on each attempt,\n583:  * so it sees the current conflict markers, not stale ones.\n584:  */\n585: async function launchResolverAndRetryMerge(\n586:   projectRoot: string,\n587:   state: WaveState,\n588:   agent: AgentState,\n589:   feature: Feature,\n590:   config: WomboConfig,\n591:   model: string | undefined,\n592:   mergeError: string,\n593:   conflictFiles: string[]\n594: ): Promise<void> {\n595:   const maxResolverAttempts = Math.max(1, (config.defaults.maxRetries ?? 0) + 1);\n596: \n597:   for (let attempt = 1; attempt <= maxResolverAttempts; attempt++) {\n598:     const conflictPrompt = generateConflictResolutionPrompt(\n599:       feature,\n600:       state.base_branch,\n601:       mergeError,\n602:       config\n603:     );\n604: \n605:     const attemptLabel = maxResolverAttempts > 1\n606:       ? ` (attempt ${attempt}/${maxResolverAttempts})`\n607:       : \"\";\n608: \n609:     updateAgent(state, agent.feature_id, {\n610:       status: \"resolving_conflict\",\n611:       activity: `resolving ${conflictFiles.length} conflict(s)${attemptLabel}...`,\n612:     });\n613:     saveState(projectRoot, state);\n614: \n615:     const resolverResult = launchConflictResolver({\n616:       worktreePath: agent.worktree,\n617:       featureId: agent.feature_id,\n618:       prompt: conflictPrompt,\n619:       model,\n620:       config,\n621:     });\n622: \n623:     updateAgent(state, agent.feature_id, {\n624:       pid: resolverResult.pid,\n625:     });\n626:     saveState(projectRoot, state);\n627: \n628:     // Wait for the resolver process to complete, then re-verify and retry merge.\n629:     // We intentionally do NOT add the resolver to the ProcessMonitor because\n630:     // the monitor's onComplete callback would trigger handleBuildVerification\n631:     // again, causing infinite recursion. Instead we await the process directly.\n632:     const resolverExitCode = await new Promise<number | null>((resolve) => {\n633:       resolverResult.process.on(\"exit\", (code) => resolve(code));\n634:       resolverResult.process.on(\"error\", () => resolve(null));\n635:     });\n636: \n637:     printAgentUpdate(\n638:       agent,\n639:       `conflict resolver exited (code ${resolverExitCode})${attemptLabel} — re-verifying build...`\n640:     );\n641: \n642:     // Re-verify build after conflict resolution\n643:     const rebuildResult = await runBuild(agent.worktree, config);\n644: \n645:     if (!rebuildResult.passed) {\n646:       if (attempt < maxResolverAttempts) {\n647:         printAgentUpdate(agent, `POST-CONFLICT BUILD FAILED${attemptLabel} — retrying resolver...`);\n648:         continue; // Try again with a fresh resolver\n649:       }\n650:       printAgentUpdate(agent, `POST-CONFLICT BUILD FAILED (all ${maxResolverAttempts} attempts exhausted)`);\n651:       updateAgent(state, agent.feature_id, {\n652:         status: \"failed\",\n653:         build_passed: false,\n654:         build_output: rebuildResult.errorSummary,\n655:         error: \"Build failed after conflict resolution\",\n656:         completed_at: new Date().toISOString(),\n657:       });\n658:       saveState(projectRoot, state);\n659:       cancelDownstream(state, agent.feature_id);\n660:       saveState(projectRoot, state);\n661:       return;\n662:     }\n663: \n664:     printAgentUpdate(agent, \"post-conflict build passed — retrying merge...\");\n665: \n666:     const retryMerge = await mergeBranch(\n667:       projectRoot,\n668:       agent.branch,\n669:       state.base_branch,\n670:       config\n671:     );\n672: \n673:     if (retryMerge.success) {\n674:       handleMergeSuccess(\n675:         projectRoot, state, agent, config,\n676:         retryMerge.commitHash, \"MERGED after conflict resolution\"\n677:       );\n678:       return;\n679:     }\n680: \n681:     // Merge still failed after resolver. If we have attempts left, re-merge\n682:     // base into feature to refresh conflict markers and try again.\n683:     if (attempt < maxResolverAttempts) {\n684:       printAgentUpdate(agent, `POST-CONFLICT MERGE FAILED${attemptLabel} — retrying resolver...`);\n685:       const refreshConflict = await mergeBaseIntoFeature(\n686:         agent.worktree,\n687:         state.base_branch,\n688:         config\n689:       );\n690:       conflictFiles = refreshConflict.conflicting\n691:         ? refreshConflict.files\n692:         : conflictFiles;\n693:       mergeError = retryMerge.error ?? mergeError;\n694:       continue;\n695:     }\n696: \n697:     // All attempts exhausted\n698:     printAgentUpdate(agent, `POST-CONFLICT MERGE FAILED (all ${maxResolverAttempts} attempts exhausted): ${retryMerge.error}`);\n699:     updateAgent(state, agent.feature_id, {\n700:       status: \"failed\",\n701:       error: `Merge still failed after ${maxResolverAttempts} conflict resolution attempt(s): ${retryMerge.error}`,\n702:       completed_at: new Date().toISOString(),\n703:     });\n704:     saveState(projectRoot, state);\n705:     cancelDownstream(state, agent.feature_id);\n706:     saveState(projectRoot, state);\n707:     return;\n708:   }\n709: }\n710: \n711: /**\n712:  * Handle retry of a failed agent (error-based, not build-based).\n713:  */\n714: export function handleRetry(\n715:   projectRoot: string,\n716:   state: WaveState,\n717:   agent: AgentState,\n718:   monitor: ProcessMonitor,\n719:   config: WomboConfig,\n720:   model?: string\n721: ): void {\n722:   if (!agent.session_id || !agent.error) return;\n723: \n724:   const retryResult = retryHeadless({\n725:     worktreePath: agent.worktree,\n726:     featureId: agent.feature_id,\n727:     sessionId: agent.session_id,\n728:     buildErrors: agent.error,\n729:     model,\n730:     config,\n731:   });\n732: \n733:   updateAgent(state, agent.feature_id, {\n734:     status: \"running\",\n735:     pid: retryResult.pid,\n736:   });\n737:   saveState(projectRoot, state);\n738: \n739:   monitor.addProcess(agent.feature_id, retryResult.process);\n740: }\n741: \n742: /**\n743:  * Launch the next queued agent if capacity allows.\n744:  * Dependency-aware: only launches agents whose dependencies are satisfied.\n745:  */\n746: export function launchNextQueued(\n747:   projectRoot: string,\n748:   state: WaveState,\n749:   featureMap: Map<string, Feature>,\n750:   monitor: ProcessMonitor,\n751:   config: WomboConfig,\n752:   model?: string,\n753:   agentResolutions?: Map<string, AgentResolution>\n754: ): void {\n755:   const active = activeAgents(state);\n756:   const ready = readyToLaunchAgents(state);\n757: \n758:   if (active.length < state.max_concurrent && ready.length > 0) {\n759:     const next = ready[0];\n760:     const feature = featureMap.get(next.feature_id);\n761:     if (feature) {\n762:       launchSingleHeadless(projectRoot, state, next, feature, monitor, config, model, agentResolutions);\n763:     }\n764:   }\n765: }\n766: \n767: /**\n768:  * Launch ALL ready agents up to capacity.\n769:  * After a dependency completes, multiple downstream agents may become unblocked.\n770:  * This launches as many as capacity allows, not just one.\n771:  *\n772:  * Also logs merge gate events when diamond-dependency features become unblocked.\n773:  */\n774: export function launchAllReady(\n775:   projectRoot: string,\n776:   state: WaveState,\n777:   featureMap: Map<string, Feature>,\n778:   monitor: ProcessMonitor,\n779:   config: WomboConfig,\n780:   model?: string,\n781:   agentResolutions?: Map<string, AgentResolution>\n782: ): void {\n783:   const active = activeAgents(state);\n784:   const ready = readyToLaunchAgents(state);\n785:   const available = state.max_concurrent - active.length;\n786: \n787:   if (available <= 0 || ready.length === 0) return;\n788: \n789:   const toLaunch = ready.slice(0, available);\n790:   for (const next of toLaunch) {\n791:     const feature = featureMap.get(next.feature_id);\n792:     if (!feature) continue;\n793: \n794:     // Log merge gate opening for diamond dependencies\n795:     if (next.depends_on.length > 1 && state.schedule_plan) {\n796:       const isMergeGate = state.schedule_plan.merge_gates.some(\n797:         (g) => g.feature_id === next.feature_id\n798:       );\n799:       if (isMergeGate) {\n800:         wtLog(\n801:           next.feature_id,\n802:           `merge gate opened — all ${next.depends_on.length} dependencies satisfied`\n803:         );\n804:       }\n805:     }\n806: \n807:     launchSingleHeadless(projectRoot, state, next, feature, monitor, config, model, agentResolutions);\n808:   }\n809: }\n810: \n811: // ---------------------------------------------------------------------------\n812: // Post-mortem: dump failed agent logs\n813: // ---------------------------------------------------------------------------\n814: \n815: /**\n816:  * Print full log contents for every failed agent so the user can diagnose\n817:  * issues after the wave finishes. Handles missing log files gracefully.\n818:  */\n819: export function dumpFailedAgentLogs(projectRoot: string, state: WaveState): void {\n820:   const failed = state.agents.filter((a) => a.status === \"failed\");\n821:   if (failed.length === 0) return;\n822: \n823:   const logDir = resolve(projectRoot, \".wombo-combo/logs\");\n824: \n825:   console.log(\n826:     `\\n${\"=\".repeat(72)}\\n` +\n827:     `  FAILED AGENT LOGS (${failed.length} agent${failed.length > 1 ? \"s\" : \"\"})\\n` +\n828:     `${\"=\".repeat(72)}`\n829:   );\n830: \n831:   for (const agent of failed) {\n832:     const logFile = resolve(logDir, `${agent.feature_id}.log`);\n833: \n834:     console.log(\n835:       `\\n${\"─\".repeat(72)}\\n` +\n836:       `  Feature: ${agent.feature_id}\\n` +\n837:       (agent.error ? `  Error:   ${agent.error}\\n` : \"\") +\n838:       `${\"─\".repeat(72)}`\n839:     );\n840: \n841:     if (!existsSync(logFile)) {\n842:       console.log(\"  (no log file found)\");\n843:       continue;\n844:     }\n845: \n846:     try {\n847:       const contents = readFileSync(logFile, \"utf-8\");\n848:       if (contents.trim().length === 0) {\n849:         console.log(\"  (log file is empty)\");\n850:       } else {\n851:         console.log(contents);\n852:       }\n853:     } catch (err: any) {\n854:       console.log(`  (error reading log: ${err.message})`);\n855:     }\n856:   }\n857: \n858:   console.log(`\\n${\"=\".repeat(72)}\\n`);\n859: }\n860: \n861: // ---------------------------------------------------------------------------\n862: // Headless Wave Launch\n863: // ---------------------------------------------------------------------------\n864: \n865: async function launchWaveHeadless(\n866:   projectRoot: string,\n867:   state: WaveState,\n868:   features: Feature[],\n869:   opts: LaunchCommandOptions,\n870:   agentResolutions?: Map<string, AgentResolution>\n871: ): Promise<void> {\n872:   const { config, model } = opts;\n873:   const featureMap = new Map(features.map((f) => [f.id, f]));\n874: \n875:   const monitor = new ProcessMonitor(projectRoot, {\n876:     onSessionId: (featureId, sessionId) => {\n877:       updateAgent(state, featureId, { session_id: sessionId });\n878:       saveState(projectRoot, state);\n879:     },\n880:     onComplete: (featureId) => {\n881:       updateAgent(state, featureId, {\n882:         status: \"completed\",\n883:         completed_at: new Date().toISOString(),\n884:       });\n885:       saveState(projectRoot, state);\n886: \n887:       // Run build verification — fire-and-forget\n888:       const agent = state.agents.find((a) => a.feature_id === featureId)!;\n889:       handleBuildVerification(projectRoot, state, agent, featureMap.get(featureId)!, config, model, monitor)\n890:         .then(() => {\n891:           // After verification/merge, try to launch dependency-ready agents\n892:           // Multiple queued agents may now be unblocked\n893:           launchAllReady(projectRoot, state, featureMap, monitor, config, model, agentResolutions);\n894:         })\n895:         .catch((err) => {\n896:           wtLog(featureId, `BUILD VERIFICATION UNHANDLED ERROR: ${err.message}`);\n897:           launchAllReady(projectRoot, state, featureMap, monitor, config, model, agentResolutions);\n898:         });\n899:     },\n900:     onError: (featureId, error) => {\n901:       const agent = state.agents.find((a) => a.feature_id === featureId)!;\n902:       if (agent.retries < agent.max_retries) {\n903:         updateAgent(state, featureId, {\n904:           status: \"retry\",\n905:           retries: agent.retries + 1,\n906:           error,\n907:         });\n908:         saveState(projectRoot, state);\n909: \n910:         // Retry\n911:         handleRetry(projectRoot, state, agent, monitor, config, model);\n912:       } else {\n913:         updateAgent(state, featureId, {\n914:           status: \"failed\",\n915:           error,\n916:           completed_at: new Date().toISOString(),\n917:         });\n918:         saveState(projectRoot, state);\n919: \n920:         // Cascade failure to downstream agents\n921:         const cancelled = cancelDownstream(state, featureId);\n922:         if (cancelled.length > 0) {\n923:           wtLog(featureId, `downstream cancelled: ${cancelled.join(\", \")}`);\n924:           saveState(projectRoot, state);\n925:         }\n926:       }\n927: \n928:       // Try to launch dependency-ready agents\n929:       launchAllReady(projectRoot, state, featureMap, monitor, config, model, agentResolutions);\n930:     },\n931:     onOutput: (_featureId, _data) => {\n932:       // Raw output — logged to file by ProcessMonitor\n933:     },\n934:     onActivity: (featureId, activity) => {\n935:       updateAgent(state, featureId, {\n936:         activity,\n937:         activity_updated_at: new Date().toISOString(),\n938:       });\n939:       // Don't save to disk on every activity — too frequent.\n940:     },\n941:   });\n942: \n943:   // Create the TUI — it will auto-refresh and show activity from the monitor\n944:   const tuiRef = { current: null as WomboTUI | null };\n945:   const startTUI = () => {\n946:     tuiRef.current = new WomboTUI({\n947:       state,\n948:       monitor,\n949:       projectRoot,\n950:       interactive: false,\n951:       config,\n952:       onQuit: () => {\n953:         // Same as SIGINT — save state and exit\n954:         for (const agent of state.agents) {\n955:           if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n956:             updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n957:           }\n958:         }\n959:         monitor.killAll();\n960:         saveState(projectRoot, state);\n961:         console.log(\"State saved. Use 'woco resume' to continue.\");\n962:         process.exit(0);\n963:       },\n964:     });\n965:     tuiRef.current.start();\n966:   };\n967: \n968:   // Handle graceful shutdown\n969:   process.on(\"SIGINT\", () => {\n970:     if (tuiRef.current) tuiRef.current.stop();\n971:     for (const agent of state.agents) {\n972:       if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n973:         updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n974:       }\n975:     }\n976:     monitor.killAll();\n977:     saveState(projectRoot, state);\n978:     console.log(\"\\nState saved. Use 'woco resume' to continue.\");\n979:     process.exit(0);\n980:   });\n981: \n982:   // Launch initial batch — only agents whose dependencies are already satisfied\n983:   const ready = readyToLaunchAgents(state);\n984:   const tolaunch = ready.slice(0, opts.maxConcurrent);\n985:   console.log(`Setting up ${tolaunch.length} agent(s) in parallel...\\n`);\n986: \n987:   await Promise.all(\n988:     tolaunch.map((agent) =>\n989:       launchSingleHeadless(\n990:         projectRoot,\n991:         state,\n992:         agent,\n993:         featureMap.get(agent.feature_id)!,\n994:         monitor,\n995:         config,\n996:         model,\n997:         agentResolutions\n998:       )\n999:     )\n1000:   );\n1001: \n1002:   const launched = state.agents.filter((a) => a.status === \"running\").length;\n1003: \n1004:   // Start the TUI dashboard (or skip if --no-tui)\n1005:   if (opts.noTui) {\n1006:     console.log(`${launched} agent(s) running. (--no-tui mode, dashboard prints every 15s)\\n`);\n1007:     printDashboard(state);\n1008:   } else {\n1009:     console.log(`${launched} agent(s) running. Launching TUI...\\n`);\n1010:     startTUI();\n1011:   }\n1012: \n1013:   // Background monitoring loop — checks for dead processes and launches queued\n1014:   const POLL_INTERVAL = 5000;\n1015:   let dashboardCounter = 0;\n1016:   while (!isWaveComplete(state)) {\n1017:     await new Promise((r) => setTimeout(r, POLL_INTERVAL));\n1018: \n1019:     // Check for completed processes that weren't caught by event handlers\n1020:     for (const agent of state.agents) {\n1021:       if (\n1022:         (agent.status === \"running\" || agent.status === \"resolving_conflict\") &&\n1023:         agent.pid &&\n1024:         !isProcessRunning(agent.pid) &&\n1025:         !monitor.isRunning(agent.feature_id)\n1026:       ) {\n1027:         if (agent.status === \"resolving_conflict\") {\n1028:           // Conflict resolver died — the await in handleBuildVerification\n1029:           // will resolve via the 'exit' event, so nothing to do here\n1030:           continue;\n1031:         }\n1032:         // Process exited but we didn't get a callback\n1033:         // Check if the agent actually made any commits\n1034:         if (!branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n1035:           // Agent died without producing any code — mark as failed, not completed\n1036:           updateAgent(state, agent.feature_id, {\n1037:             status: \"failed\",\n1038:             error: \"Agent process exited without making any commits\",\n1039:             activity: null,\n1040:             completed_at: new Date().toISOString(),\n1041:           });\n1042:           saveState(projectRoot, state);\n1043:           wtLog(agent.feature_id, \"process died with no code changes — marked failed\");\n1044: \n1045:           // Cascade failure to downstream agents\n1046:           const cancelled = cancelDownstream(state, agent.feature_id);\n1047:           if (cancelled.length > 0) {\n1048:             wtLog(agent.feature_id, `downstream cancelled: ${cancelled.join(\", \")}`);\n1049:             saveState(projectRoot, state);\n1050:           }\n1051:         } else {\n1052:           updateAgent(state, agent.feature_id, {\n1053:             status: \"completed\",\n1054:             completed_at: new Date().toISOString(),\n1055:             activity: \"done\",\n1056:           });\n1057:           saveState(projectRoot, state);\n1058:           try {\n1059:             await handleBuildVerification(projectRoot, state, agent, featureMap.get(agent.feature_id)!, config, model, monitor);\n1060:           } catch (err: any) {\n1061:             wtLog(agent.feature_id, `POLL VERIFY ERROR: ${err.message}`);\n1062:           }\n1063:         }\n1064:         launchAllReady(projectRoot, state, featureMap, monitor, config, model, agentResolutions);\n1065:       }\n1066:     }\n1067: \n1068:     // Persist state periodically\n1069:     saveState(projectRoot, state);\n1070: \n1071:     // Update TUI state reference (or print dashboard in --no-tui mode)\n1072:     if (tuiRef.current) {\n1073:       tuiRef.current.updateState(state);\n1074:     } else if (opts.noTui) {\n1075:       dashboardCounter++;\n1076:       if (dashboardCounter % 3 === 0) {\n1077:         printDashboard(state);\n1078: \n1079:         // Auto-push base branch if requested\n1080:         if (opts.autoPush) {\n1081:           const anyMerged = state.agents.some((a) => a.status === \"merged\");\n1082:           if (anyMerged) {\n1083:             await pushBaseBranch(projectRoot, state.base_branch, config);\n1084:           } else {\n1085:             console.log(\"No branches were merged — skipping push.\");\n1086:           }\n1087:         }\n1088:       }\n1089:     }\n1090:   }\n1091: \n1092:   // Wave complete — keep TUI open for post-mortem browsing\n1093:   if (tuiRef.current) {\n1094:     tuiRef.current.updateState(state);\n1095:     tuiRef.current.markWaveComplete();\n1096:     // Wait for the user to press q to exit the TUI\n1097:     await tuiRef.current.waitForQuit();\n1098:   }\n1099: \n1100:   // Print final dashboard after TUI is closed\n1101:   printDashboard(state);\n1102: \n1103:   // Dump full logs for failed agents (post-mortem)\n1104:   dumpFailedAgentLogs(projectRoot, state);\n1105: \n1106:   // Auto-export wave history\n1107:   try {\n1108:     const historyPath = exportWaveHistory(projectRoot, state);\n1109:     console.log(`Wave history exported to ${historyPath}`);\n1110:   } catch (err: any) {\n1111:     console.error(`Warning: failed to export wave history: ${err.message}`);\n1112:   }\n1113: \n1114:   // Auto-push base branch if requested\n1115:   if (opts.autoPush) {\n1116:     await pushBaseBranch(projectRoot, state.base_branch, config);\n1117:   }\n1118: \n1119:   console.log(\"Wave complete.\");\n1120: }\n1121: \n1122: // ---------------------------------------------------------------------------\n1123: // Interactive Wave Launch\n1124: // ---------------------------------------------------------------------------\n1125: \n1126: async function launchWaveInteractive(\n1127:   projectRoot: string,\n1128:   state: WaveState,\n1129:   features: Feature[],\n1130:   opts: LaunchCommandOptions,\n1131:   agentResolutions?: Map<string, AgentResolution>\n1132: ): Promise<void> {\n1133:   const { config, model } = opts;\n1134:   const featureMap = new Map(features.map((f) => [f.id, f]));\n1135: \n1136:   // Show dashboard immediately\n1137:   printDashboard(state);\n1138: \n1139:   // Launch initial batch — parallelize setup\n1140:   const tolaunch = queuedAgents(state).slice(0, opts.maxConcurrent);\n1141:   console.log(`Setting up ${tolaunch.length} agent(s) in parallel...\\n`);\n1142: \n1143:   await Promise.all(\n1144:     tolaunch.map(async (agent) => {\n1145:       updateAgent(state, agent.feature_id, {\n1146:         status: \"installing\",\n1147:         started_at: new Date().toISOString(),\n1148:         activity: \"setting up worktree...\",\n1149:       });\n1150:       saveState(projectRoot, state);\n1151: \n1152:       try {\n1153:         if (worktreeReady(agent.worktree)) {\n1154:           wtLog(agent.feature_id, \"worktree already exists, skipping setup\");\n1155:         } else {\n1156:           await createWorktree(projectRoot, agent.feature_id, state.base_branch, config);\n1157:           updateAgent(state, agent.feature_id, { activity: \"installing deps...\" });\n1158:           await installDeps(agent.worktree, agent.feature_id, config);\n1159:         }\n1160: \n1161:         const prompt = generatePrompt(\n1162:           featureMap.get(agent.feature_id)!,\n1163:           state.base_branch,\n1164:           config\n1165:         );\n1166: \n1167:         // Write specialized agent to worktree if applicable\n1168:         const resolution = agentResolutions?.get(agent.feature_id);\n1169:         const agentName = agent.agent_name ?? undefined;\n1170:         if (resolution && isSpecializedAgent(resolution)) {\n1171:           try {\n1172:             const patchedContent = patchImportedAgent(resolution.rawContent, config, projectRoot);\n1173:             writeAgentToWorktree(agent.worktree, resolution.name, patchedContent);\n1174:             wtLog(agent.feature_id, `wrote specialized agent: ${resolution.name}`);\n1175:           } catch (err: any) {\n1176:             wtLog(agent.feature_id, `WARN: failed to write specialized agent, using generalist: ${err.message}`);\n1177:           }\n1178:         }\n1179: \n1180:         wtLog(agent.feature_id, \"launching interactive session...\");\n1181:         const result = launchInteractive({\n1182:           worktreePath: agent.worktree,\n1183:           featureId: agent.feature_id,\n1184:           prompt,\n1185:           model,\n1186:           interactive: true,\n1187:           config,\n1188:           agentName,\n1189:         });\n1190: \n1191:         const muxName = getMultiplexerName(config);\n1192:         updateAgent(state, agent.feature_id, {\n1193:           status: \"running\",\n1194:           pid: result.pid,\n1195:           activity: `${muxName} session active`,\n1196:         });\n1197:         saveState(projectRoot, state);\n1198:         wtLog(agent.feature_id, `${muxName} session: ${config.agent.tmuxPrefix}-${agent.feature_id}`);\n1199:       } catch (err: any) {\n1200:         updateAgent(state, agent.feature_id, {\n1201:           status: \"failed\",\n1202:           error: err.message,\n1203:           activity: null,\n1204:           completed_at: new Date().toISOString(),\n1205:         });\n1206:         saveState(projectRoot, state);\n1207:         wtLog(agent.feature_id, `SETUP FAILED: ${err.message.split(\"\\n\")[0]}`);\n1208:       }\n1209:     })\n1210:   );\n1211: \n1212:   const mux = detectMultiplexer(config.agent.multiplexer);\n1213:   const muxName = getMultiplexerName(config);\n1214:   console.log(\"\\nInteractive sessions launched. Use these commands:\");\n1215:   console.log(`  ${muxAttachCommand(mux, `${config.agent.tmuxPrefix}-<feature-id>`)}   # attach to a session`);\n1216:   console.log(`  ${muxListCommand(mux)}${\" \".repeat(Math.max(1, 54 - muxListCommand(mux).length))}# list sessions`);\n1217:   console.log(\"  woco status                                             # check status\");\n1218:   console.log(\"  woco verify                                             # verify builds\");\n1219:   console.log(\"  woco merge                                              # merge verified\");\n1220:   console.log(\"  woco cleanup                                            # remove worktrees\");\n1221: \n1222:   printDashboard(state);\n1223: }\n1224: \n1225: // ---------------------------------------------------------------------------\n1226: // Main Command\n1227: // ---------------------------------------------------------------------------\n1228: \n1229: export async function cmdLaunch(opts: LaunchCommandOptions): Promise<void> {\n1230:   const { projectRoot, config } = opts;\n1231: \n1232:   console.log(\"\\n--- wombo-combo: Launch ---\\n\");\n1233: \n1234:   // Ensure agent definition exists — reinstall from template if missing\n1235:   ensureAgentDefinition(projectRoot, config);\n1236: \n1237:   // Ensure portless proxy is running (if enabled) to prevent port collisions\n1238:   if (config.portless.enabled) {\n1239:     if (isPortlessAvailable(config)) {\n1240:       const proxyOk = ensureProxyRunning(config);\n1241:       if (!proxyOk) {\n1242:         console.warn(\n1243:           \"\\x1b[33m[portless]\\x1b[0m proxy could not be started — agents may encounter port collisions\"\n1244:         );\n1245:       }\n1246:     } else {\n1247:       console.warn(\n1248:         \"\\x1b[33m[portless]\\x1b[0m enabled but not installed. Install with: npm install -g portless\"\n1249:       );\n1250:       console.warn(\n1251:         \"  Agents will run without portless — concurrent dev servers may have port collisions.\\n\"\n1252:       );\n1253:     }\n1254:   }\n1255: \n1256:   // -------------------------------------------------------------------------\n1257:   // Validate that the configured baseBranch exists as a local branch\n1258:   // -------------------------------------------------------------------------\n1259:   if (!branchExists(projectRoot, opts.baseBranch)) {\n1260:     const fmt = opts.outputFmt ?? \"text\";\n1261:     const msg = `Base branch \"${opts.baseBranch}\" does not exist as a local branch. ` +\n1262:       `Create it first (e.g. \"git checkout -b ${opts.baseBranch}\") or specify ` +\n1263:       `a different branch with --base-branch.`;\n1264:     outputError(fmt, msg);\n1265:   }\n1266: \n1267:   // -------------------------------------------------------------------------\n1268:   // Check for existing wave state — don't overwrite work in progress\n1269:   // -------------------------------------------------------------------------\n1270:   const existingState = loadState(projectRoot);\n1271:   if (existingState) {\n1272:     const merged = existingState.agents.filter((a) => a.status === \"merged\");\n1273:     const verified = existingState.agents.filter((a) => a.status === \"verified\");\n1274:     const completed = existingState.agents.filter((a) => a.status === \"completed\");\n1275:     const running = existingState.agents.filter((a) => a.status === \"running\");\n1276:     const queued = existingState.agents.filter((a) => a.status === \"queued\");\n1277:     const failed = existingState.agents.filter((a) => a.status === \"failed\");\n1278: \n1279:     const hasWork = merged.length > 0 || verified.length > 0 || completed.length > 0 || running.length > 0;\n1280: \n1281:     if (hasWork) {\n1282:       console.log(`Existing wave found: ${existingState.wave_id}`);\n1283:       console.log(`  ${merged.length} merged, ${verified.length} verified, ${completed.length} completed, ${running.length} running, ${queued.length} queued, ${failed.length} failed`);\n1284: \n1285:       // Finalize any merged agents by marking their features as done\n1286:       if (merged.length > 0) {\n1287:         console.log(\"\\nFinalizing merged tasks in tasks file...\");\n1288:         for (const agent of merged) {\n1289:           markFeatureDone(projectRoot, agent.feature_id, config, existingState.base_branch);\n1290:           // Clean up worktree and branch (already merged, safe to delete)\n1291:           try {\n1292:             removeWorktree(projectRoot, agent.worktree, true);\n1293:             console.log(`  ${agent.feature_id}: marked done, worktree removed`);\n1294:           } catch {\n1295:             console.log(`  ${agent.feature_id}: marked done (worktree already cleaned)`);\n1296:           }\n1297:         }\n1298:       }\n1299: \n1300:       // Verified agents: build passed but NOT merged — do NOT mark done.\n1301:       // Leave them for 'woco resume' to attempt the merge.\n1302:       if (verified.length > 0) {\n1303:         for (const agent of verified) {\n1304:           console.log(`  ${agent.feature_id}: verified (not yet merged) — use 'woco resume' to merge`);\n1305:         }\n1306:       }\n1307: \n1308:       const activeCount = running.length + completed.length + queued.length;\n1309:       if (activeCount > 0) {\n1310:         console.error(`\\nWave ${existingState.wave_id} has ${activeCount} unfinished agent(s).`);\n1311:       console.error(\"Use 'woco resume' to continue the existing wave,\");\n1312:       console.error(\"or 'woco cleanup' to clear it before starting a new one.\");\n1313:         process.exit(1);\n1314:       }\n1315: \n1316:       // All agents are in terminal states (merged/verified/failed) — safe to start fresh\n1317:       console.log(\"\\nAll agents in previous wave are finished. Starting fresh wave.\\n\");\n1318:     }\n1319:   }\n1320: \n1321:   // Load features\n1322:   const data = loadFeatures(projectRoot, config);\n1323: \n1324:   // Build selection options\n1325:   const selOpts: SelectionOptions = {};\n1326:   if (opts.topPriority) selOpts.topPriority = opts.topPriority;\n1327:   if (opts.quickestWins) selOpts.quickestWins = opts.quickestWins;\n1328:   if (opts.priority) selOpts.priority = opts.priority;\n1329:   if (opts.difficulty) selOpts.difficulty = opts.difficulty;\n1330:   if (opts.features) selOpts.taskIds = opts.features;\n1331:   if (opts.allReady) selOpts.allReady = true;\n1332: \n1333:   // Select features\n1334:   const selected = selectFeatures(data, selOpts);\n1335: \n1336:   if (selected.length === 0) {\n1337:     // Build a context-aware message based on which flags were passed\n1338:     const activeFilters: string[] = [];\n1339:     if (opts.allReady) activeFilters.push(\"--all-ready\");\n1340:     if (opts.topPriority) activeFilters.push(`--top-priority ${opts.topPriority}`);\n1341:     if (opts.quickestWins) activeFilters.push(`--quickest-wins ${opts.quickestWins}`);\n1342:     if (opts.priority) activeFilters.push(`--priority ${opts.priority}`);\n1343:     if (opts.difficulty) activeFilters.push(`--difficulty ${opts.difficulty}`);\n1344:     if (opts.features?.length) activeFilters.push(`--tasks ${opts.features.join(\",\")}`);\n1345: \n1346:     if (opts.allReady && activeFilters.length === 1) {\n1347:       // Only --all-ready was passed, no additional filters\n1348:       console.error(\n1349:         \"No launchable tasks found (all tasks are done, cancelled, or have unmet dependencies).\\n\" +\n1350:         \"Run 'woco tasks list' to review task statuses.\"\n1351:       );\n1352:     } else if (activeFilters.length > 0) {\n1353:       // Specific filter flags were passed (with or without --all-ready)\n1354:       console.error(\n1355:         `No tasks matched the current filters: ${activeFilters.join(\", \")}.\\n` +\n1356:         \"Try broadening your criteria or run 'woco tasks list --ready' to see available tasks.\"\n1357:       );\n1358:     } else {\n1359:       // No selection flags at all — default selection found nothing\n1360:       console.error(\n1361:         \"No launchable tasks found.\\n\" +\n1362:         \"Use --all-ready to select all tasks whose dependencies are met,\\n\" +\n1363:         \"or run 'woco tasks list --ready' to see available tasks.\"\n1364:       );\n1365:     }\n1366:     process.exit(1);\n1367:   }\n1368: \n1369:   // Show selection\n1370:   printFeatureSelection(\n1371:     selected.map((f) => ({\n1372:       id: f.id,\n1373:       title: f.title,\n1374:       priority: f.priority,\n1375:       difficulty: f.difficulty,\n1376:       effort: f.effort,\n1377:     }))\n1378:   );\n1379: \n1380:   // ---------------------------------------------------------------------------\n1381:   // Dependency graph analysis\n1382:   // ---------------------------------------------------------------------------\n1383:   const depGraph = buildDepGraph(selected, data.tasks);\n1384:   let schedulePlan: SchedulePlan | null = null;\n1385: \n1386:   // Check if any features actually have dependencies within the selected set\n1387:   const hasDeps = selected.some(\n1388:     (f) => f.depends_on.some((d) => selected.find((s) => s.id === d))\n1389:   );\n1390: \n1391:   if (hasDeps) {\n1392:     // Validate graph — throws on cycles or dangling deps\n1393:     try {\n1394:       validateDepGraph(depGraph);\n1395:     } catch (err: any) {\n1396:       console.error(`\\n${err.message}`);\n1397:       console.error(\"\\nFix dependency issues before launching.\");\n1398:       process.exit(1);\n1399:     }\n1400: \n1401:     // Build scheduling plan\n1402:     schedulePlan = buildSchedulePlan(depGraph);\n1403:     console.log(`\\n${formatSchedulePlan(schedulePlan)}\\n`);\n1404:   }\n1405: \n1406:   if (opts.dryRun) {\n1407:     console.log(\"Dry run — not launching agents.\");\n1408:     return;\n1409:   }\n1410: \n1411:   // ---------------------------------------------------------------------------\n1412:   // Agent registry: resolve specialized agents for tasks with agent_type\n1413:   // ---------------------------------------------------------------------------\n1414:   let agentResolutions: Map<string, AgentResolution> | undefined;\n1415: \n1416:   if (config.agentRegistry.mode !== \"disabled\") {\n1417:     const tasksWithAgentType = selected.filter((t) => t.agent_type);\n1418:     if (tasksWithAgentType.length > 0) {\n1419:       console.log(`\\nResolving ${tasksWithAgentType.length} specialized agent(s) from registry...`);\n1420:       agentResolutions = await prepareAgentDefinitions(selected, config, projectRoot);\n1421: \n1422:       const specialized = [...agentResolutions.values()].filter(isSpecializedAgent);\n1423:       const cached = specialized.filter((r) => r.fromCache);\n1424:       console.log(\n1425:         `  ${specialized.length} specialized (${cached.length} cached, ${specialized.length - cached.length} fetched), ` +\n1426:         `${selected.length - specialized.length} generalist`\n1427:       );\n1428:     }\n1429:   }\n1430: \n1431:   // ---------------------------------------------------------------------------\n1432:   // Preflight confirmation\n1433:   // ---------------------------------------------------------------------------\n1434:   if (agentResolutions && agentResolutions.size > 0) {\n1435:     const isTTY = process.stdout.isTTY && process.stdin.isTTY;\n1436:     const preflight = isTTY && !opts.noTui\n1437:       ? await tuiPreflightConfirm(selected, agentResolutions, config)\n1438:       : await consolePreflightConfirm(selected, agentResolutions, config);\n1439: \n1440:     if (!preflight.proceed) {\n1441:       console.log(\"Launch cancelled.\\n\");\n1442:       return;\n1443:     }\n1444: \n\n(Output capped at 50 KB. Showing lines 1-1444. Use offset=1445 to continue.)\n</content>","title":"src/commands/launch.ts","metadata":{"preview":"/**\n * launch.ts — Launch a wave of agents.\n *\n * Usage: woco launch [selection options] [launch options]\n *\n * This is the primary entry point for starting a new wave. It selects features\n * from the features file, creates a wave state, sets up worktrees, and launches\n * agent processes (either headless or interactive via dmux/tmux).\n *\n * IMPORTANT: This file also exports shared helper functions that are reused\n * by resume.ts and other commands:\n *   - launchSingleHeadless\n *   - handleBuildVerification\n *   - handleRetry\n *   - launchNextQueued\n */\n\nimport { execSync } from \"node:child_process\";\nimport { existsSync, readFileSync } from \"node:fs\";\nimport { resolve } from \"node:path\";","truncated":true,"loaded":[]},"time":{"start":1773435843625,"end":1773435843629}}}}
{"type":"tool_use","timestamp":1773435843957,"sessionID":"ses_316fcb4c5ffehqcHU7q5TvsiXt","part":{"id":"prt_ce903742a001uJIthVAxbPWr0Q","sessionID":"ses_316fcb4c5ffehqcHU7q5TvsiXt","messageID":"msg_ce903644f001E9izFBREI9i5Ph","type":"tool","callID":"toolu_vrtx_0145KVMPEoHxrYQLBjqRcicD","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-json-operational-commands/src/commands/cleanup.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-json-operational-commands/src/commands/cleanup.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * cleanup.ts — Remove all wave-related resources.\n3:  *\n4:  * Usage: woco cleanup\n5:  *\n6:  * Kills multiplexer sessions (dmux/tmux), removes worktrees, removes state and log files.\n7:  *\n8:  * NOTE: .wombo-combo/history/ is intentionally NOT removed by cleanup.\n9:  * Wave history records are meant to survive cleanup for retrospective\n10:  * analysis. See src/lib/history.ts.\n11:  */\n12: \n13: import { existsSync, unlinkSync, rmSync } from \"node:fs\";\n14: import { execSync } from \"node:child_process\";\n15: import { resolve } from \"node:path\";\n16: import type { WomboConfig } from \"../config.js\";\n17: import { WOMBO_DIR } from \"../config.js\";\n18: import { killAllMuxSessions, getMultiplexerName } from \"../lib/launcher.js\";\n19: import { cleanupAllWorktrees, listWomboWorktrees } from \"../lib/worktree.js\";\n20: import {\n21:   detectMultiplexer,\n22:   muxListSessions,\n23: } from \"../lib/multiplexer.js\";\n24: \n25: export interface CleanupOptions {\n26:   projectRoot: string;\n27:   config: WomboConfig;\n28:   dryRun?: boolean;\n29: }\n30: \n31: export async function cmdCleanup(opts: CleanupOptions): Promise<void> {\n32:   const { projectRoot, config } = opts;\n33: \n34:   // Dry-run: show what would be cleaned up without doing it\n35:   if (opts.dryRun) {\n36:     console.log(\"\\n[dry-run] Would perform the following cleanup:\\n\");\n37: \n38:     // List multiplexer sessions that would be killed\n39:     const muxName = getMultiplexerName(config);\n40:     try {\n41:       const mux = detectMultiplexer(config.agent.multiplexer);\n42:       const sessions = muxListSessions(mux);\n43:       const prefix = config.agent.tmuxPrefix;\n44:       const matching = sessions.filter((s) => s.startsWith(prefix));\n45:       console.log(`  ${muxName} sessions to kill: ${matching.length}`);\n46:       for (const s of matching) {\n47:         console.log(`    ${s}`);\n48:       }\n49:     } catch {\n50:       console.log(`  ${muxName} sessions to kill: 0 (no ${muxName} server running)`);\n51:     }\n52: \n53:     // List worktrees that would be removed (using safe filtering)\n54:     try {\n55:       const matching = listWomboWorktrees(projectRoot, config);\n56:       console.log(`  worktrees to remove: ${matching.length}`);\n57:       for (const wt of matching) {\n58:         console.log(`    ${wt.path}`);\n59:       }\n60:     } catch {\n61:       console.log(\"  worktrees to remove: 0\");\n62:     }\n63: \n64:     const statePath = resolve(projectRoot, WOMBO_DIR, \"state.json\");\n65:     const logDir = resolve(projectRoot, WOMBO_DIR, \"logs\");\n66:     if (existsSync(statePath)) console.log(\"  Would remove: .wombo-combo/state.json\");\n67:     if (existsSync(logDir)) console.log(\"  Would remove: .wombo-combo/logs/\");\n68: \n69:     return;\n70:   }\n71: \n72:   console.log(\"\\n--- wombo-combo: Cleanup ---\\n\");\n73: \n74:   // Kill multiplexer sessions\n75:   const muxName = getMultiplexerName(config);\n76:   const killed = killAllMuxSessions(config);\n77:   console.log(`Killed ${killed} ${muxName} session(s)`);\n78: \n79:   // Remove worktrees\n80:   const removed = cleanupAllWorktrees(projectRoot, config);\n81:   console.log(`Removed ${removed} worktree(s)`);\n82: \n83:   // List remaining feature branches\n84:   try {\n85:     const branchPattern = `\"${config.git.branchPrefix}*\"`;\n86:     const branches = execSync(`git branch --list ${branchPattern}`, {\n87:       cwd: projectRoot,\n88:       encoding: \"utf-8\",\n89:     }).trim();\n90:     if (branches) {\n91:       console.log(`\\nRemaining feature branches:\\n${branches}`);\n92:       console.log('Use \"git branch -D <branch>\" to remove manually.');\n93:     }\n94:   } catch {}\n95: \n96:   // Remove state file\n97:   const statePath = resolve(projectRoot, WOMBO_DIR, \"state.json\");\n98:   if (existsSync(statePath)) {\n99:     unlinkSync(statePath);\n100:     console.log(\"Removed .wombo-combo/state.json\");\n101:   }\n102: \n103:   // Remove log directory\n104:   const logDir = resolve(projectRoot, WOMBO_DIR, \"logs\");\n105:   if (existsSync(logDir)) {\n106:     rmSync(logDir, { recursive: true, force: true });\n107:     console.log(\"Removed .wombo-combo/logs/\");\n108:   }\n109: \n110:   console.log(\"\\nCleanup complete.\");\n111: \n112:   // Inform the user that history is preserved\n113:   const historyDir = resolve(projectRoot, WOMBO_DIR, \"history\");\n114:   if (existsSync(historyDir)) {\n115:     console.log(\"Note: .wombo-combo/history/ is preserved. Use 'woco history' to view past waves.\");\n116:   }\n117: }\n\n(End of file - total 117 lines)\n</content>","title":"src/commands/cleanup.ts","metadata":{"preview":"/**\n * cleanup.ts — Remove all wave-related resources.\n *\n * Usage: woco cleanup\n *\n * Kills multiplexer sessions (dmux/tmux), removes worktrees, removes state and log files.\n *\n * NOTE: .wombo-combo/history/ is intentionally NOT removed by cleanup.\n * Wave history records are meant to survive cleanup for retrospective\n * analysis. See src/lib/history.ts.\n */\n\nimport { existsSync, unlinkSync, rmSync } from \"node:fs\";\nimport { execSync } from \"node:child_process\";\nimport { resolve } from \"node:path\";\nimport type { WomboConfig } from \"../config.js\";\nimport { WOMBO_DIR } from \"../config.js\";\nimport { killAllMuxSessions, getMultiplexerName } from \"../lib/launcher.js\";\nimport { cleanupAllWorktrees, listWomboWorktrees } from \"../lib/worktree.js\";\nimport {","truncated":false,"loaded":[]},"time":{"start":1773435843953,"end":1773435843956}}}}
{"type":"tool_use","timestamp":1773435844407,"sessionID":"ses_316fcb4c5ffehqcHU7q5TvsiXt","part":{"id":"prt_ce90375720015LVXeWvPqlMUP1","sessionID":"ses_316fcb4c5ffehqcHU7q5TvsiXt","messageID":"msg_ce903644f001E9izFBREI9i5Ph","type":"tool","callID":"toolu_vrtx_01RCFFDZFysHBzRKn531ykJV","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-json-operational-commands/src/commands/verify.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-json-operational-commands/src/commands/verify.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * verify.ts — Run build verification on completed agents.\n3:  *\n4:  * Usage: woco verify [feature-id] [--browser]\n5:  *\n6:  * Runs the build command in each completed agent's worktree. If a specific\n7:  * feature-id is given, verifies only that agent. Otherwise verifies all\n8:  * agents with status \"completed\".\n9:  *\n10:  * When --browser is passed (or browser.enabled is true in config), also\n11:  * runs browser-based verification after the build passes.\n12:  */\n13: \n14: import type { WomboConfig } from \"../config.js\";\n15: import { loadFeatures, type Feature } from \"../lib/tasks.js\";\n16: import { loadState, saveState } from \"../lib/state.js\";\n17: import { printDashboard } from \"../lib/ui.js\";\n18: import { handleBuildVerification } from \"./launch.js\";\n19: \n20: // ---------------------------------------------------------------------------\n21: // Types\n22: // ---------------------------------------------------------------------------\n23: \n24: export interface VerifyCommandOptions {\n25:   projectRoot: string;\n26:   config: WomboConfig;\n27:   featureId?: string;\n28:   model?: string;\n29:   maxRetries?: number;\n30:   /** Enable browser verification (overrides config.browser.enabled) */\n31:   browserVerify?: boolean;\n32: }\n33: \n34: // ---------------------------------------------------------------------------\n35: // Command\n36: // ---------------------------------------------------------------------------\n37: \n38: export async function cmdVerify(opts: VerifyCommandOptions): Promise<void> {\n39:   const { projectRoot, config } = opts;\n40: \n41:   // Apply browser verification override if --browser flag was passed\n42:   if (opts.browserVerify !== undefined) {\n43:     config.browser.enabled = opts.browserVerify;\n44:   }\n45: \n46:   const state = loadState(projectRoot);\n47:   if (!state) {\n48:     console.log(\"No active wave.\");\n49:     return;\n50:   }\n51: \n52:   const toVerify = opts.featureId\n53:     ? state.agents.filter((a) => a.feature_id === opts.featureId)\n54:     : state.agents.filter((a) => a.status === \"completed\");\n55: \n56:   if (toVerify.length === 0) {\n57:     console.log(\"No agents to verify.\");\n58:     return;\n59:   }\n60: \n61:   console.log(`\\nVerifying ${toVerify.length} agent(s)...\\n`);\n62: \n63:   const data = loadFeatures(projectRoot, config);\n64: \n65:   for (const agent of toVerify) {\n66:     const feature = data.tasks.find((f: Feature) => f.id === agent.feature_id);\n67:     if (!feature) continue;\n68: \n69:     await handleBuildVerification(projectRoot, state, agent, feature, config, opts.model);\n70:   }\n71: \n72:   printDashboard(state);\n73: }\n\n(End of file - total 73 lines)\n</content>","title":"src/commands/verify.ts","metadata":{"preview":"/**\n * verify.ts — Run build verification on completed agents.\n *\n * Usage: woco verify [feature-id] [--browser]\n *\n * Runs the build command in each completed agent's worktree. If a specific\n * feature-id is given, verifies only that agent. Otherwise verifies all\n * agents with status \"completed\".\n *\n * When --browser is passed (or browser.enabled is true in config), also\n * runs browser-based verification after the build passes.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport { loadFeatures, type Feature } from \"../lib/tasks.js\";\nimport { loadState, saveState } from \"../lib/state.js\";\nimport { printDashboard } from \"../lib/ui.js\";\nimport { handleBuildVerification } from \"./launch.js\";\n\n// ---------------------------------------------------------------------------","truncated":false,"loaded":[]},"time":{"start":1773435844402,"end":1773435844406}}}}
{"type":"tool_use","timestamp":1773435844887,"sessionID":"ses_316fcb4c5ffehqcHU7q5TvsiXt","part":{"id":"prt_ce9037734001wJDBbCbKULBytN","sessionID":"ses_316fcb4c5ffehqcHU7q5TvsiXt","messageID":"msg_ce903644f001E9izFBREI9i5Ph","type":"tool","callID":"toolu_vrtx_01MnUiX58truKk1PSWYeE6jX","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-json-operational-commands/src/commands/merge.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-json-operational-commands/src/commands/merge.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * merge.ts — Merge verified branches into the base branch.\n3:  *\n4:  * Usage: woco merge [feature-id]\n5:  *\n6:  * Merges all verified agents (or a specific one) into the base branch.\n7:  * Uses the full merge pipeline including pre-flight conflict detection,\n8:  * automatic conflict resolution, and configurable retry attempts.\n9:  */\n10: \n11: import type { WomboConfig } from \"../config.js\";\n12: import {\n13:   loadState,\n14: } from \"../lib/state.js\";\n15: import { pushBaseBranch } from \"../lib/merger.js\";\n16: import type { Feature } from \"../lib/tasks.js\";\n17: import { loadFeatures } from \"../lib/tasks.js\";\n18: import { printDashboard, printAgentUpdate } from \"../lib/ui.js\";\n19: import { attemptMerge } from \"./launch.js\";\n20: \n21: // ---------------------------------------------------------------------------\n22: // Types\n23: // ---------------------------------------------------------------------------\n24: \n25: export interface MergeCommandOptions {\n26:   projectRoot: string;\n27:   config: WomboConfig;\n28:   featureId?: string;\n29:   autoPush?: boolean;\n30:   dryRun?: boolean;\n31:   model?: string;\n32: }\n33: \n34: // ---------------------------------------------------------------------------\n35: // Command\n36: // ---------------------------------------------------------------------------\n37: \n38: export async function cmdMerge(opts: MergeCommandOptions): Promise<void> {\n39:   const { projectRoot, config } = opts;\n40: \n41:   const state = loadState(projectRoot);\n42:   if (!state) {\n43:     console.log(\"No active wave.\");\n44:     return;\n45:   }\n46: \n47:   const toMerge = opts.featureId\n48:     ? state.agents.filter(\n49:         (a) => a.feature_id === opts.featureId && a.status === \"verified\"\n50:       )\n51:     : state.agents.filter((a) => a.status === \"verified\");\n52: \n53:   if (toMerge.length === 0) {\n54:     console.log(\"No verified agents to merge.\");\n55:     return;\n56:   }\n57: \n58:   // Dry-run: show what would be merged without merging\n59:   if (opts.dryRun) {\n60:     console.log(`\\n[dry-run] Would merge ${toMerge.length} branch(es):\\n`);\n61:     for (const agent of toMerge) {\n62:       console.log(`  ${agent.feature_id} — branch: ${agent.branch}`);\n63:     }\n64:     if (opts.autoPush) {\n65:       console.log(`\\n  Would push ${state.base_branch} to remote after merge.`);\n66:     }\n67:     return;\n68:   }\n69: \n70:   // Load features for conflict resolution prompt generation.\n71:   // Build a flat map of all feature/subtask IDs so we can look up any agent.\n72:   const data = loadFeatures(projectRoot, config);\n73:   const featureMap = new Map<string, Feature>();\n74:   function indexFeatures(items: Feature[]) {\n75:     for (const f of items) {\n76:       featureMap.set(f.id, f);\n77:       if (f.subtasks) {\n78:         indexFeatures(f.subtasks as unknown as Feature[]);\n79:       }\n80:     }\n81:   }\n82:   indexFeatures(data.tasks);\n83:   indexFeatures(data.archive);\n84: \n85:   console.log(`\\nMerging ${toMerge.length} branch(es)...\\n`);\n86: \n87:   for (const agent of toMerge) {\n88:     const feature = featureMap.get(agent.feature_id);\n89:     if (!feature) {\n90:       printAgentUpdate(agent, `SKIP — feature \"${agent.feature_id}\" not found in features file`);\n91:       continue;\n92:     }\n93: \n94:     // Use the full merge pipeline (pre-flight, conflict resolution, retry)\n95:     await attemptMerge(projectRoot, state, agent, feature, config, opts.model);\n96:   }\n97: \n98:   // Auto-push if requested\n99:   if (opts.autoPush) {\n100:     const anyMerged = state.agents.some((a) => a.status === \"merged\");\n101:     if (anyMerged) {\n102:       await pushBaseBranch(projectRoot, state.base_branch, config);\n103:     }\n104:   }\n105: \n106:   printDashboard(state);\n107: }\n\n(End of file - total 107 lines)\n</content>","title":"src/commands/merge.ts","metadata":{"preview":"/**\n * merge.ts — Merge verified branches into the base branch.\n *\n * Usage: woco merge [feature-id]\n *\n * Merges all verified agents (or a specific one) into the base branch.\n * Uses the full merge pipeline including pre-flight conflict detection,\n * automatic conflict resolution, and configurable retry attempts.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport {\n  loadState,\n} from \"../lib/state.js\";\nimport { pushBaseBranch } from \"../lib/merger.js\";\nimport type { Feature } from \"../lib/tasks.js\";\nimport { loadFeatures } from \"../lib/tasks.js\";\nimport { printDashboard, printAgentUpdate } from \"../lib/ui.js\";\nimport { attemptMerge } from \"./launch.js\";\n","truncated":false,"loaded":[]},"time":{"start":1773435844848,"end":1773435844886}}}}
{"type":"tool_use","timestamp":1773435845460,"sessionID":"ses_316fcb4c5ffehqcHU7q5TvsiXt","part":{"id":"prt_ce90378f5001TCJ8QZNd1GMMQU","sessionID":"ses_316fcb4c5ffehqcHU7q5TvsiXt","messageID":"msg_ce903644f001E9izFBREI9i5Ph","type":"tool","callID":"toolu_vrtx_011tZKSdjPHf5HchGhGHwHyN","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-json-operational-commands/src/commands/resume.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-json-operational-commands/src/commands/resume.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * resume.ts — Resume a previously stopped wave.\n3:  *\n4:  * Usage: woco resume [options]\n5:  *\n6:  * Restores from .wombo-combo/state.json:\n7:  *   - Agents in \"running\"/\"installing\" whose PID is dead → re-check or re-launch\n8:  *   - Agents in \"queued\" → launch them\n9:  *   - Agents in terminal states (verified/failed/merged) → leave alone\n10:  */\n11: \n12: import type { WomboConfig } from \"../config.js\";\n13: import type { Feature } from \"../lib/tasks.js\";\n14: import { loadFeatures } from \"../lib/tasks.js\";\n15: import {\n16:   loadState,\n17:   saveState,\n18:   updateAgent,\n19:   queuedAgents,\n20:   readyToLaunchAgents,\n21:   cancelDownstream,\n22:   isWaveComplete,\n23:   type WaveState,\n24:   type AgentState,\n25: } from \"../lib/state.js\";\n26: import {\n27:   createWorktree,\n28:   installDeps,\n29:   worktreeReady,\n30:   worktreeExists,\n31:   branchHasChanges,\n32:   removeWorktree,\n33:   log as wtLog,\n34: } from \"../lib/worktree.js\";\n35: import { generatePrompt } from \"../lib/prompt.js\";\n36: import {\n37:   launchInteractive,\n38:   isProcessRunning,\n39:   getMultiplexerName,\n40: } from \"../lib/launcher.js\";\n41: import { ProcessMonitor } from \"../lib/monitor.js\";\n42: import { pushBaseBranch } from \"../lib/merger.js\";\n43: import { runBuild } from \"../lib/verifier.js\";\n44: import { printDashboard, printAgentUpdate } from \"../lib/ui.js\";\n45: import { WomboTUI } from \"../lib/tui.js\";\n46: import {\n47:   launchSingleHeadless,\n48:   handleBuildVerification,\n49:   handleRetry,\n50:   launchNextQueued,\n51:   launchAllReady,\n52:   markFeatureDone,\n53:   attemptMerge,\n54:   dumpFailedAgentLogs,\n55: } from \"./launch.js\";\n56: import {\n57:   detectMultiplexer,\n58:   muxAttachCommand,\n59: } from \"../lib/multiplexer.js\";\n60: import { exportWaveHistory } from \"../lib/history.js\";\n61: \n62: // ---------------------------------------------------------------------------\n63: // Types\n64: // ---------------------------------------------------------------------------\n65: \n66: export interface ResumeCommandOptions {\n67:   projectRoot: string;\n68:   config: WomboConfig;\n69:   maxConcurrent?: number;\n70:   model?: string;\n71:   interactive: boolean;\n72:   noTui: boolean;\n73:   autoPush: boolean;\n74:   baseBranch?: string;\n75:   maxRetries?: number;\n76: }\n77: \n78: // ---------------------------------------------------------------------------\n79: // Command\n80: // ---------------------------------------------------------------------------\n81: \n82: export async function cmdResume(opts: ResumeCommandOptions): Promise<void> {\n83:   const { projectRoot, config } = opts;\n84: \n85:   const state = loadState(projectRoot);\n86:   if (!state) {\n87:     console.error(\"No wave state found. Use 'woco launch' to start a new wave.\");\n88:     process.exit(1);\n89:     return; // unreachable — helps TypeScript narrow\n90:   }\n91: \n92:   console.log(`\\n--- wombo-combo: Resume ${state.wave_id} ---\\n`);\n93: \n94:   // Load feature data for prompt generation\n95:   const data = loadFeatures(projectRoot, config);\n96:   const featureMap = new Map(data.tasks.map((f: Feature) => [f.id, f]));\n97: \n98:   // Triage agents by current state\n99:   let toRelaunch: AgentState[] = [];\n100:   let toVerify: AgentState[] = [];\n101: \n102:   for (const agent of state.agents) {\n103:     switch (agent.status) {\n104:       case \"running\":\n105:       case \"installing\":\n106:       case \"retry\":\n107:       case \"resolving_conflict\":\n108:         // Was in-flight when we stopped — check if PID is still alive\n109:         if (agent.pid && isProcessRunning(agent.pid)) {\n110:           console.log(`  ${agent.feature_id}: still running (PID ${agent.pid}), leaving alone`);\n111:         } else {\n112:           // Process is dead — check if worktree exists with meaningful changes.\n113:           // Use worktreeExists (not worktreeReady) because node_modules may be\n114:           // missing — the worktree still has code that should be verified.\n115:           if (worktreeExists(agent.worktree) && branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n116:             // Worktree exists AND branch has commits — try build verification\n117:             console.log(`  ${agent.feature_id}: process dead, worktree has changes — will verify build`);\n118:             toVerify.push(agent);\n119:           } else {\n120:             // No worktree, or worktree exists but branch has no commits (agent did nothing)\n121:             const reason = worktreeExists(agent.worktree)\n122:               ? \"worktree exists but no code changes\"\n123:               : \"no worktree\";\n124:             console.log(`  ${agent.feature_id}: process dead, ${reason} — will re-launch`);\n125:             updateAgent(state, agent.feature_id, {\n126:               status: \"queued\",\n127:               pid: null,\n128:               activity: null,\n129:               session_id: null,\n130:             });\n131:             toRelaunch.push(agent);\n132:           }\n133:         }\n134:         break;\n135: \n136:       case \"queued\":\n137:         console.log(`  ${agent.feature_id}: queued — will launch`);\n138:         toRelaunch.push(agent);\n139:         break;\n140: \n141:       case \"completed\":\n142:         // Completed but not verified — verify\n143:         console.log(`  ${agent.feature_id}: completed — will verify build`);\n144:         toVerify.push(agent);\n145:         break;\n146: \n147:       case \"verified\":\n148:         // Build passed but NOT yet merged — need to attempt merge (+ conflict resolution)\n149:         console.log(`  ${agent.feature_id}: verified — will attempt merge`);\n150:         toVerify.push(agent);\n151:         break;\n152: \n153:       case \"merged\":\n154:         console.log(`  ${agent.feature_id}: merged — marking feature as done`);\n155:         markFeatureDone(projectRoot, agent.feature_id, config, state.base_branch);\n156:         try {\n157:           removeWorktree(projectRoot, agent.worktree, true);\n158:           console.log(`  ${agent.feature_id}: worktree and branch removed`);\n159:         } catch {\n160:           // Already cleaned — not critical\n161:         }\n162:         break;\n163: \n164:       case \"failed\":\n165:         // If the worktree exists with code changes and retries remain,\n166:         // attempt build verification rather than discarding the work.\n167:         if (agent.retries < agent.max_retries &&\n168:             worktreeExists(agent.worktree) &&\n169:             branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n170:           console.log(`  ${agent.feature_id}: failed but has work (retry ${agent.retries}/${agent.max_retries}) — will verify build`);\n171:           // Clear stale error and mark as completed so handleBuildVerification\n172:           // processes it correctly (it expects a non-failed agent)\n173:           updateAgent(state, agent.feature_id, {\n174:             status: \"completed\",\n175:             error: null,\n176:             build_passed: null,\n177:             build_output: null,\n178:             completed_at: new Date().toISOString(),\n179:           });\n180:           toVerify.push(agent);\n181:         } else if (agent.retries < agent.max_retries) {\n182:           // No worktree or no changes — re-launch from scratch\n183:           console.log(`  ${agent.feature_id}: failed, no salvageable work (retry ${agent.retries}/${agent.max_retries}) — will re-launch`);\n184:           updateAgent(state, agent.feature_id, {\n185:             status: \"queued\",\n186:             pid: null,\n187:             error: null,\n188:             build_passed: null,\n189:             build_output: null,\n190:             activity: null,\n191:             session_id: null,\n192:             completed_at: null,\n193:           });\n194:           toRelaunch.push(agent);\n195:         } else {\n196:           console.log(`  ${agent.feature_id}: failed — max retries reached (use 'woco retry' to reset)`);\n197:         }\n198:         break;\n199:     }\n200:   }\n201: \n202:   saveState(projectRoot, state);\n203: \n204:   // ---------------------------------------------------------------------------\n205:   // Phase 1: Parallel build verification\n206:   // Each agent's worktree is independent, so dep install + build can run\n207:   // concurrently. Merges must remain sequential (they mutate the project root).\n208:   // ---------------------------------------------------------------------------\n209:   if (toVerify.length > 0) {\n210:     console.log(`\\nVerifying ${toVerify.length} agent(s) in parallel...\\n`);\n211: \n212:     const verifyResults = await Promise.all(\n213:       toVerify.map(async (agent): Promise<{ agent: AgentState; needsMerge: boolean }> => {\n214:         const feature = featureMap.get(agent.feature_id);\n215:         if (!feature) return { agent, needsMerge: false };\n216: \n217:         // Already verified — skip build, go straight to merge\n218:         if (agent.status === \"verified\") {\n219:           printAgentUpdate(agent, \"already verified — queued for merge\");\n220:           return { agent, needsMerge: true };\n221:         }\n222: \n223:         printAgentUpdate(agent, \"verifying build...\");\n224: \n225:         // Ensure deps are installed — worktree may exist without node_modules\n226:         // (e.g., failed agents whose setup was interrupted)\n227:         if (!worktreeReady(agent.worktree) && worktreeExists(agent.worktree)) {\n228:           try {\n229:             printAgentUpdate(agent, \"installing deps...\");\n230:             await installDeps(agent.worktree, agent.feature_id, config);\n231:           } catch (depErr: any) {\n232:             printAgentUpdate(agent, `dep install failed: ${depErr.message}`);\n233:             updateAgent(state, agent.feature_id, {\n234:               status: \"failed\",\n235:               error: `Dependency install failed: ${depErr.message}`,\n236:               retries: agent.retries + 1,\n237:               completed_at: new Date().toISOString(),\n238:             });\n239:             saveState(projectRoot, state);\n240:             return { agent, needsMerge: false };\n241:           }\n242:         }\n243: \n244:         try {\n245:           const buildResult = await runBuild(agent.worktree, config);\n246:           if (buildResult.passed) {\n247:             updateAgent(state, agent.feature_id, {\n248:               status: \"verified\",\n249:               build_passed: true,\n250:               build_output: null,\n251:             });\n252:             saveState(projectRoot, state);\n253:             printAgentUpdate(agent, `BUILD PASSED (${Math.round(buildResult.durationMs / 1000)}s)`);\n254:             return { agent, needsMerge: true };\n255:           } else {\n256:             // Build failed\n257:             if (agent.retries < agent.max_retries) {\n258:               updateAgent(state, agent.feature_id, {\n259:                 status: \"retry\",\n260:                 retries: agent.retries + 1,\n261:                 build_passed: false,\n262:                 build_output: buildResult.errorSummary,\n263:               });\n264:               saveState(projectRoot, state);\n265:               printAgentUpdate(agent, `BUILD FAILED — will retry (${agent.retries + 1}/${agent.max_retries})`);\n266:             } else {\n267:               updateAgent(state, agent.feature_id, {\n268:                 status: \"failed\",\n269:                 build_passed: false,\n270:                 build_output: buildResult.errorSummary,\n271:                 error: `Build failed after ${agent.max_retries} retries`,\n272:                 completed_at: new Date().toISOString(),\n273:               });\n274:               saveState(projectRoot, state);\n275:               printAgentUpdate(agent, \"BUILD FAILED — max retries reached\");\n276:             }\n277:             return { agent, needsMerge: false };\n278:           }\n279:         } catch (err: any) {\n280:           printAgentUpdate(agent, `verify error: ${err.message}`);\n281:           updateAgent(state, agent.feature_id, {\n282:             status: \"failed\",\n283:             error: `Build verification error: ${err.message}`,\n284:             completed_at: new Date().toISOString(),\n285:           });\n286:           saveState(projectRoot, state);\n287:           return { agent, needsMerge: false };\n288:         }\n289:       })\n290:     );\n291: \n292:     saveState(projectRoot, state);\n293: \n294:     // -------------------------------------------------------------------------\n295:     // Phase 2: Sequential merge for verified agents\n296:     // Merges must be sequential because they operate on the project root.\n297:     // -------------------------------------------------------------------------\n298:     const toMerge = verifyResults.filter((r) => r.needsMerge);\n299:     if (toMerge.length > 0) {\n300:       console.log(`\\nMerging ${toMerge.length} verified agent(s)...\\n`);\n301:       for (const { agent } of toMerge) {\n302:         const feature = featureMap.get(agent.feature_id);\n303:         if (!feature) continue;\n304:         try {\n305:           await attemptMerge(projectRoot, state, agent, feature, config, opts.model);\n306:         } catch (err: any) {\n307:           printAgentUpdate(agent, `merge error: ${err.message}`);\n308:         }\n309:       }\n310:     }\n311: \n312:     // Collect agents that need re-launching from verify results\n313:     for (const { agent } of verifyResults) {\n314:       if (agent.status === \"retry\" || agent.status === \"running\") {\n315:         toRelaunch.push(agent);\n316:       }\n317:     }\n318:   }\n319: \n320:   // Re-launch agents\n321:   const maxConcurrent = opts.maxConcurrent ?? state.max_concurrent;\n322:   const toLaunchNow = toRelaunch.slice(0, maxConcurrent);\n323:   if (toLaunchNow.length === 0) {\n324:     console.log(\"\\nNo agents need (re)launching.\");\n325:     printDashboard(state);\n326:     return;\n327:   }\n328: \n329:   console.log(`\\nRe-launching ${toLaunchNow.length} agent(s)...\\n`);\n330:   printDashboard(state);\n331: \n332:   const model = opts.model ?? state.model ?? undefined;\n333: \n334:   if (opts.interactive) {\n335:     // Interactive resume\n336:     await Promise.all(\n337:       toLaunchNow.map(async (agent) => {\n338:         const feature = featureMap.get(agent.feature_id);\n339:         if (!feature) return;\n340: \n341:         updateAgent(state, agent.feature_id, {\n342:           status: \"installing\",\n343:           started_at: new Date().toISOString(),\n344:           activity: \"resuming...\",\n345:         });\n346:         saveState(projectRoot, state);\n347: \n348:         try {\n349:           if (!worktreeReady(agent.worktree)) {\n350:             await createWorktree(projectRoot, agent.feature_id, state.base_branch, config);\n351:             await installDeps(agent.worktree, agent.feature_id, config);\n352:           }\n353: \n354:           const prompt = generatePrompt(feature, state.base_branch, config);\n355:           const result = launchInteractive({\n356:             worktreePath: agent.worktree,\n357:             featureId: feature.id,\n358:             prompt,\n359:             model,\n360:             interactive: true,\n361:             config,\n362:           });\n363: \n364:           const muxName = getMultiplexerName(config);\n365:           updateAgent(state, agent.feature_id, {\n366:             status: \"running\",\n367:             pid: result.pid,\n368:             activity: `${muxName} session active`,\n369:           });\n370:           saveState(projectRoot, state);\n371:         } catch (err: any) {\n372:           updateAgent(state, agent.feature_id, {\n373:             status: \"failed\",\n374:             error: err.message,\n375:             activity: null,\n376:             completed_at: new Date().toISOString(),\n377:           });\n378:           saveState(projectRoot, state);\n379:         }\n380:       })\n381:     );\n382: \n383:     printDashboard(state);\n384:     const mux = detectMultiplexer(config.agent.multiplexer);\n385:     console.log(`\\nResume complete. Use '${muxAttachCommand(mux, `${config.agent.tmuxPrefix}-<id>`)}' to check sessions.`);\n386:   } else {\n387:     // Headless resume — re-enter monitoring loop\n388:     const monitor = new ProcessMonitor(projectRoot, {\n389:       onSessionId: (featureId, sessionId) => {\n390:         updateAgent(state, featureId, { session_id: sessionId });\n391:         saveState(projectRoot, state);\n392:       },\n393:       onComplete: (featureId) => {\n394:         updateAgent(state, featureId, {\n395:           status: \"completed\",\n396:           completed_at: new Date().toISOString(),\n397:           activity: \"done\",\n398:         });\n399:         saveState(projectRoot, state);\n400:         wtLog(featureId, \"agent completed — verifying build...\");\n401: \n402:         const agent = state.agents.find((a) => a.feature_id === featureId)!;\n403:         const feature = featureMap.get(featureId)!;\n404:         handleBuildVerification(projectRoot, state, agent, feature, config, model, monitor)\n405:           .then(() => launchAllReady(projectRoot, state, featureMap, monitor, config, model))\n406:           .catch((err) => {\n407:             wtLog(featureId, `BUILD VERIFICATION UNHANDLED ERROR: ${err.message}`);\n408:             launchAllReady(projectRoot, state, featureMap, monitor, config, model);\n409:           });\n410:       },\n411:       onError: (featureId, error) => {\n412:         const agent = state.agents.find((a) => a.feature_id === featureId)!;\n413:         if (agent.retries < agent.max_retries) {\n414:           updateAgent(state, featureId, {\n415:             status: \"retry\",\n416:             retries: agent.retries + 1,\n417:             error,\n418:             activity: \"retrying...\",\n419:           });\n420:           saveState(projectRoot, state);\n421:           handleRetry(projectRoot, state, agent, monitor, config, model);\n422:         } else {\n423:           updateAgent(state, featureId, {\n424:             status: \"failed\",\n425:             error,\n426:             activity: null,\n427:             completed_at: new Date().toISOString(),\n428:           });\n429:           saveState(projectRoot, state);\n430: \n431:           // Cascade failure to downstream agents\n432:           const cancelled = cancelDownstream(state, featureId);\n433:           if (cancelled.length > 0) {\n434:             wtLog(featureId, `downstream cancelled: ${cancelled.join(\", \")}`);\n435:             saveState(projectRoot, state);\n436:           }\n437:         }\n438:         launchAllReady(projectRoot, state, featureMap, monitor, config, model);\n439:       },\n440:       onActivity: (featureId, activity) => {\n441:         updateAgent(state, featureId, {\n442:           activity,\n443:           activity_updated_at: new Date().toISOString(),\n444:         });\n445:       },\n446:     });\n447: \n448:     // Handle graceful shutdown\n449:     const tuiRef = { current: null as WomboTUI | null };\n450:     process.on(\"SIGINT\", () => {\n451:       if (tuiRef.current) tuiRef.current.stop();\n452:       for (const agent of state.agents) {\n453:         if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n454:           updateAgent(state, agent.feature_id, {\n455:             activity: \"interrupted\",\n456:           });\n457:         }\n458:       }\n459:       monitor.killAll();\n460:       saveState(projectRoot, state);\n461:       console.log(\"\\nState saved. Use 'woco resume' to continue.\");\n462:       process.exit(0);\n463:     });\n464: \n465:     await Promise.all(\n466:       toLaunchNow.map((agent) => {\n467:         const feature = featureMap.get(agent.feature_id);\n468:         if (!feature) return Promise.resolve();\n469:         return launchSingleHeadless(projectRoot, state, agent, feature, monitor, config, model);\n470:       })\n471:     );\n472: \n473:     // Start TUI dashboard (or skip if --no-tui)\n474:     if (!opts.noTui) {\n475:       tuiRef.current = new WomboTUI({\n476:         state,\n477:         monitor,\n478:         projectRoot,\n479:         interactive: false,\n480:         config,\n481:         onQuit: () => {\n482:           for (const agent of state.agents) {\n483:             if (agent.status === \"running\") {\n484:               updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n485:             }\n486:           }\n487:           monitor.killAll();\n488:           saveState(projectRoot, state);\n489:           console.log(\"State saved. Use 'woco resume' to continue.\");\n490:           process.exit(0);\n491:         },\n492:       });\n493:       tuiRef.current.start();\n494:     } else {\n495:       console.log(\"(--no-tui mode, dashboard prints every 15s)\\n\");\n496:       printDashboard(state);\n497:     }\n498: \n499:     // Monitoring loop\n500:     const POLL_INTERVAL = 5000;\n501:     let dashboardCounter = 0;\n502:     while (!isWaveComplete(state)) {\n503:       await new Promise((r) => setTimeout(r, POLL_INTERVAL));\n504: \n505:       for (const agent of state.agents) {\n506:         if (\n507:           (agent.status === \"running\" || agent.status === \"resolving_conflict\") &&\n508:           agent.pid &&\n509:           !isProcessRunning(agent.pid) &&\n510:           !monitor.isRunning(agent.feature_id)\n511:         ) {\n512:           if (agent.status === \"resolving_conflict\") {\n513:             // Conflict resolver died unexpectedly — mark as failed\n514:             updateAgent(state, agent.feature_id, {\n515:               status: \"failed\",\n516:               error: \"Conflict resolver process died unexpectedly\",\n517:               activity: null,\n518:               completed_at: new Date().toISOString(),\n519:             });\n520:             saveState(projectRoot, state);\n521:             wtLog(agent.feature_id, \"conflict resolver died — marked failed\");\n522: \n523:             // Cascade failure to downstream agents\n524:             const cancelled = cancelDownstream(state, agent.feature_id);\n525:             if (cancelled.length > 0) {\n526:               wtLog(agent.feature_id, `downstream cancelled: ${cancelled.join(\", \")}`);\n527:               saveState(projectRoot, state);\n528:             }\n529: \n530:             launchAllReady(projectRoot, state, featureMap, monitor, config, model);\n531:             continue;\n532:           }\n533:           // Check if the agent actually made any commits\n534:           if (!branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n535:             // Agent died without producing any code — mark as failed\n536:             updateAgent(state, agent.feature_id, {\n537:               status: \"failed\",\n538:               error: \"Agent process exited without making any commits\",\n539:               activity: null,\n540:               completed_at: new Date().toISOString(),\n541:             });\n542:             saveState(projectRoot, state);\n543:             wtLog(agent.feature_id, \"process died with no code changes — marked failed\");\n544: \n545:             // Cascade failure to downstream agents\n546:             const cancelled = cancelDownstream(state, agent.feature_id);\n547:             if (cancelled.length > 0) {\n548:               wtLog(agent.feature_id, `downstream cancelled: ${cancelled.join(\", \")}`);\n549:               saveState(projectRoot, state);\n550:             }\n551:           } else {\n552:             updateAgent(state, agent.feature_id, {\n553:               status: \"completed\",\n554:               completed_at: new Date().toISOString(),\n555:               activity: \"done\",\n556:             });\n557:             saveState(projectRoot, state);\n558:             const feature = featureMap.get(agent.feature_id)!;\n559:             try {\n560:               await handleBuildVerification(projectRoot, state, agent, feature, config, model, monitor);\n561:             } catch (err: any) {\n562:               wtLog(agent.feature_id, `POLL VERIFY ERROR: ${err.message}`);\n563:             }\n564:           }\n565:           launchAllReady(projectRoot, state, featureMap, monitor, config, model);\n566:         }\n567:       }\n568: \n569:       saveState(projectRoot, state);\n570:       if (tuiRef.current) {\n571:         tuiRef.current.updateState(state);\n572:       } else if (opts.noTui) {\n573:         dashboardCounter++;\n574:         if (dashboardCounter % 3 === 0) {\n575:           printDashboard(state);\n576:         }\n577:       }\n578:     }\n579: \n580:     // Wave complete — keep TUI open for post-mortem browsing\n581:     if (tuiRef.current) {\n582:       tuiRef.current.updateState(state);\n583:       tuiRef.current.markWaveComplete();\n584:       await tuiRef.current.waitForQuit();\n585:     }\n586: \n587:     printDashboard(state);\n588: \n589:     // Dump full logs for failed agents (post-mortem)\n590:     dumpFailedAgentLogs(projectRoot, state);\n591: \n592:     // Auto-export wave history\n593:     try {\n594:       const historyPath = exportWaveHistory(projectRoot, state);\n595:       console.log(`Wave history exported to ${historyPath}`);\n596:     } catch (err: any) {\n597:       console.error(`Warning: failed to export wave history: ${err.message}`);\n598:     }\n599: \n600:     // Auto-push base branch if requested\n601:     if (opts.autoPush) {\n602:       await pushBaseBranch(projectRoot, state.base_branch, config);\n603:     }\n604: \n605:     console.log(\"Wave complete.\");\n606:   }\n607: }\n\n(End of file - total 607 lines)\n</content>","title":"src/commands/resume.ts","metadata":{"preview":"/**\n * resume.ts — Resume a previously stopped wave.\n *\n * Usage: woco resume [options]\n *\n * Restores from .wombo-combo/state.json:\n *   - Agents in \"running\"/\"installing\" whose PID is dead → re-check or re-launch\n *   - Agents in \"queued\" → launch them\n *   - Agents in terminal states (verified/failed/merged) → leave alone\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport type { Feature } from \"../lib/tasks.js\";\nimport { loadFeatures } from \"../lib/tasks.js\";\nimport {\n  loadState,\n  saveState,\n  updateAgent,\n  queuedAgents,\n  readyToLaunchAgents,","truncated":false,"loaded":[]},"time":{"start":1773435845288,"end":1773435845454}}}}
{"type":"text","timestamp":1773435845682,"sessionID":"ses_316fcb4c5ffehqcHU7q5TvsiXt","part":{"id":"prt_ce9036baf001bmgI7VCp586Six","sessionID":"ses_316fcb4c5ffehqcHU7q5TvsiXt","messageID":"msg_ce903644f001E9izFBREI9i5Ph","type":"text","text":"Now let me read all the operational command files that need to be retrofitted:","time":{"start":1773435845678,"end":1773435845678}}}
{"type":"tool_use","timestamp":1773435845788,"sessionID":"ses_316fcb4c5ffehqcHU7q5TvsiXt","part":{"id":"prt_ce9037abd001yQXwMJb6pFsGjy","sessionID":"ses_316fcb4c5ffehqcHU7q5TvsiXt","messageID":"msg_ce903644f001E9izFBREI9i5Ph","type":"tool","callID":"toolu_vrtx_01X5aWqDyCRpsjVQUfdbCNHu","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-json-operational-commands/src/commands/retry.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-json-operational-commands/src/commands/retry.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * retry.ts — Retry a specific failed agent.\n3:  *\n4:  * Usage: woco retry <feature-id> [--interactive] [--model <model>]\n5:  *\n6:  * Resets the agent's retry count and re-launches it. Can launch in either\n7:  * headless mode (default) or interactive (dmux/tmux) mode.\n8:  */\n9: \n10: import type { WomboConfig } from \"../config.js\";\n11: import { loadFeatures, type Feature } from \"../lib/tasks.js\";\n12: import {\n13:   loadState,\n14:   saveState,\n15:   updateAgent,\n16: } from \"../lib/state.js\";\n17: import { worktreeReady } from \"../lib/worktree.js\";\n18: import { generatePrompt } from \"../lib/prompt.js\";\n19: import { launchInteractive, getMultiplexerName } from \"../lib/launcher.js\";\n20: import { ProcessMonitor } from \"../lib/monitor.js\";\n21: import { launchSingleHeadless } from \"./launch.js\";\n22: \n23: // ---------------------------------------------------------------------------\n24: // Types\n25: // ---------------------------------------------------------------------------\n26: \n27: export interface RetryCommandOptions {\n28:   projectRoot: string;\n29:   config: WomboConfig;\n30:   featureId: string;\n31:   model?: string;\n32:   interactive: boolean;\n33:   dryRun?: boolean;\n34: }\n35: \n36: // ---------------------------------------------------------------------------\n37: // Command\n38: // ---------------------------------------------------------------------------\n39: \n40: export async function cmdRetry(opts: RetryCommandOptions): Promise<void> {\n41:   const { projectRoot, config } = opts;\n42: \n43:   if (!opts.featureId) {\n44:     console.error(\"Usage: woco retry <feature-id>\");\n45:     process.exit(1);\n46:     return; // unreachable — helps TypeScript narrow\n47:   }\n48: \n49:   const state = loadState(projectRoot);\n50:   if (!state) {\n51:     console.log(\"No active wave.\");\n52:     return;\n53:   }\n54: \n55:   const agent = state.agents.find((a) => a.feature_id === opts.featureId);\n56:   if (!agent) {\n57:     console.error(`Agent not found for feature: ${opts.featureId}`);\n58:     process.exit(1);\n59:     return; // unreachable — helps TypeScript narrow\n60:   }\n61: \n62:   if (agent.status !== \"failed\") {\n63:     console.error(\n64:       `Agent ${opts.featureId} is not in failed state (current: ${agent.status})`\n65:     );\n66:     process.exit(1);\n67:     return; // unreachable — helps TypeScript narrow\n68:   }\n69: \n70:   // Dry-run: show what would be retried without doing it\n71:   if (opts.dryRun) {\n72:     console.log(`\\n[dry-run] Would retry agent: ${opts.featureId}`);\n73:     console.log(`  Current status: ${agent.status}`);\n74:     console.log(`  Retries so far: ${agent.retries}`);\n75:     console.log(`  Worktree: ${agent.worktree}`);\n76:     console.log(`  Mode: ${opts.interactive ? \"interactive (multiplexer)\" : \"headless\"}`);\n77:     if (opts.model) console.log(`  Model: ${opts.model}`);\n78:     return;\n79:   }\n80: \n81:   // Reset retry count and re-run\n82:   updateAgent(state, agent.feature_id, {\n83:     status: \"queued\",\n84:     retries: 0,\n85:     error: null,\n86:     build_passed: null,\n87:     build_output: null,\n88:     completed_at: null,\n89:   });\n90:   saveState(projectRoot, state);\n91: \n92:   const data = loadFeatures(projectRoot, config);\n93:   const feature = data.tasks.find((f: Feature) => f.id === opts.featureId);\n94:   if (!feature) {\n95:     console.error(`Feature ${opts.featureId} not found in ${config.tasksFile}`);\n96:     process.exit(1);\n97:     return; // unreachable — helps TypeScript narrow\n98:   }\n99: \n100:   if (opts.interactive) {\n101:     const prompt = generatePrompt(feature, state.base_branch, config);\n102:     launchInteractive({\n103:       worktreePath: agent.worktree,\n104:       featureId: feature.id,\n105:       prompt,\n106:       model: opts.model,\n107:       interactive: true,\n108:       config,\n109:     });\n110: \n111:     updateAgent(state, agent.feature_id, {\n112:       status: \"running\",\n113:       started_at: new Date().toISOString(),\n114:     });\n115:     saveState(projectRoot, state);\n116:     const muxName = getMultiplexerName(config);\n117:     console.log(`Retrying ${opts.featureId} in ${muxName} session ${config.agent.tmuxPrefix}-${opts.featureId}`);\n118:   } else {\n119:     const monitor = new ProcessMonitor(projectRoot);\n120:     await launchSingleHeadless(projectRoot, state, agent, feature, monitor, config, opts.model);\n121:     console.log(`Retrying ${opts.featureId} in headless mode`);\n122:   }\n123: }\n\n(End of file - total 123 lines)\n</content>","title":"src/commands/retry.ts","metadata":{"preview":"/**\n * retry.ts — Retry a specific failed agent.\n *\n * Usage: woco retry <feature-id> [--interactive] [--model <model>]\n *\n * Resets the agent's retry count and re-launches it. Can launch in either\n * headless mode (default) or interactive (dmux/tmux) mode.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport { loadFeatures, type Feature } from \"../lib/tasks.js\";\nimport {\n  loadState,\n  saveState,\n  updateAgent,\n} from \"../lib/state.js\";\nimport { worktreeReady } from \"../lib/worktree.js\";\nimport { generatePrompt } from \"../lib/prompt.js\";\nimport { launchInteractive, getMultiplexerName } from \"../lib/launcher.js\";\nimport { ProcessMonitor } from \"../lib/monitor.js\";","truncated":false,"loaded":[]},"time":{"start":1773435845663,"end":1773435845786}}}}
