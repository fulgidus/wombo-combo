"},{"range":{"start":{"line":76,"character":7},"end":{"line":76,"character":15}},"message":"'DepGraph' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"},{"range":{"start":{"line":79,"character":50},"end":{"line":79,"character":61}},"message":"'portlessUrl' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"},{"range":{"start":{"line":1212,"character":8},"end":{"line":1212,"character":15}},"message":"'muxName' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"}],"/home/fulgidus/Documents/wt-wombo-json-operational-commands/src/commands/cleanup.ts":[{"range":{"start":{"line":23,"character":17},"end":{"line":23,"character":30}},"message":"'outputMessage' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"}],"/home/fulgidus/Documents/wt-wombo-json-operational-commands/src/commands/verify.ts":[{"range":{"start":{"line":15,"character":20},"end":{"line":15,"character":29}},"message":"'saveState' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"}],"/home/fulgidus/Documents/wt-wombo-json-operational-commands/src/commands/merge.ts":[],"/home/fulgidus/Documents/wt-wombo-json-operational-commands/src/commands/resume.ts":[{"range":{"start":{"line":18,"character":2},"end":{"line":18,"character":14}},"message":"'queuedAgents' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"},{"range":{"start":{"line":19,"character":2},"end":{"line":19,"character":21}},"message":"'readyToLaunchAgents' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"},{"range":{"start":{"line":22,"character":7},"end":{"line":22,"character":16}},"message":"'WaveState' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"},{"range":{"start":{"line":49,"character":2},"end":{"line":49,"character":18}},"message":"'launchN