{"type":"tool_use","timestamp":1773436226568,"sessionID":"ses_316fcb4c5ffehqcHU7q5TvsiXt","part":{"id":"prt_ce9094767001QNzFaMLhkgAIeF","sessionID":"ses_316fcb4c5ffehqcHU7q5TvsiXt","messageID":"msg_ce9093dec00140YxMpbOyMmtfS","type":"tool","callID":"toolu_vrtx_016jhoGAtF9LLJUKvBxTzzrg","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wt-wombo-json-operational-commands/src/commands/resume.ts"},"output":"<path>/home/fulgidus/Documents/wt-wombo-json-operational-commands/src/commands/resume.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * resume.ts — Resume a previously stopped wave.\n3:  *\n4:  * Usage: woco resume [options] [--output json]\n5:  *\n6:  * Restores from .wombo-combo/state.json:\n7:  *   - Agents in \"running\"/\"installing\" whose PID is dead → re-check or re-launch\n8:  *   - Agents in \"queued\" → launch them\n9:  *   - Agents in terminal states (verified/failed/merged) → leave alone\n10:  */\n11: \n12: import type { WomboConfig } from \"../config.js\";\n13: import type { Feature } from \"../lib/tasks.js\";\n14: import { loadFeatures } from \"../lib/tasks.js\";\n15: import {\n16:   loadState,\n17:   saveState,\n18:   updateAgent,\n19:   queuedAgents,\n20:   readyToLaunchAgents,\n21:   cancelDownstream,\n22:   isWaveComplete,\n23:   type WaveState,\n24:   type AgentState,\n25: } from \"../lib/state.js\";\n26: import {\n27:   createWorktree,\n28:   installDeps,\n29:   worktreeReady,\n30:   worktreeExists,\n31:   branchHasChanges,\n32:   removeWorktree,\n33:   log as wtLog,\n34: } from \"../lib/worktree.js\";\n35: import { generatePrompt } from \"../lib/prompt.js\";\n36: import {\n37:   launchInteractive,\n38:   isProcessRunning,\n39:   getMultiplexerName,\n40: } from \"../lib/launcher.js\";\n41: import { ProcessMonitor } from \"../lib/monitor.js\";\n42: import { pushBaseBranch } from \"../lib/merger.js\";\n43: import { runBuild } from \"../lib/verifier.js\";\n44: import { printDashboard, printAgentUpdate } from \"../lib/ui.js\";\n45: import { WomboTUI } from \"../lib/tui.js\";\n46: import {\n47:   launchSingleHeadless,\n48:   handleBuildVerification,\n49:   handleRetry,\n50:   launchNextQueued,\n51:   launchAllReady,\n52:   markFeatureDone,\n53:   attemptMerge,\n54:   dumpFailedAgentLogs,\n55: } from \"./launch.js\";\n56: import {\n57:   detectMultiplexer,\n58:   muxAttachCommand,\n59: } from \"../lib/multiplexer.js\";\n60: import { exportWaveHistory } from \"../lib/history.js\";\n61: import { outputError, outputMessage, type OutputFormat } from \"../lib/output.js\";\n62: \n63: // ---------------------------------------------------------------------------\n64: // Types\n65: // ---------------------------------------------------------------------------\n66: \n67: export interface ResumeCommandOptions {\n68:   projectRoot: string;\n69:   config: WomboConfig;\n70:   maxConcurrent?: number;\n71:   model?: string;\n72:   interactive: boolean;\n73:   noTui: boolean;\n74:   autoPush: boolean;\n75:   baseBranch?: string;\n76:   maxRetries?: number;\n77:   outputFmt?: OutputFormat;\n78: }\n79: \n80: // ---------------------------------------------------------------------------\n81: // Command\n82: // ---------------------------------------------------------------------------\n83: \n84: export async function cmdResume(opts: ResumeCommandOptions): Promise<void> {\n85:   const { projectRoot, config } = opts;\n86:   const fmt = opts.outputFmt ?? \"text\";\n87: \n88:   const state = loadState(projectRoot);\n89:   if (!state) {\n90:     outputError(fmt, \"No wave state found. Use 'woco launch' to start a new wave.\");\n91:     return; // unreachable — outputError calls process.exit\n92:   }\n93: \n94:   if (fmt === \"text\") {\n95:     console.log(`\\n--- wombo-combo: Resume ${state.wave_id} ---\\n`);\n96:   }\n97: \n98:   // Load feature data for prompt generation\n99:   const data = loadFeatures(projectRoot, config);\n100:   const featureMap = new Map(data.tasks.map((f: Feature) => [f.id, f]));\n101: \n102:   // Triage agents by current state\n103:   let toRelaunch: AgentState[] = [];\n104:   let toVerify: AgentState[] = [];\n105: \n106:   for (const agent of state.agents) {\n107:     switch (agent.status) {\n108:       case \"running\":\n109:       case \"installing\":\n110:       case \"retry\":\n111:       case \"resolving_conflict\":\n112:         // Was in-flight when we stopped — check if PID is still alive\n113:         if (agent.pid && isProcessRunning(agent.pid)) {\n114:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: still running (PID ${agent.pid}), leaving alone`);\n115:         } else {\n116:           // Process is dead — check if worktree exists with meaningful changes.\n117:           // Use worktreeExists (not worktreeReady) because node_modules may be\n118:           // missing — the worktree still has code that should be verified.\n119:           if (worktreeExists(agent.worktree) && branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n120:             // Worktree exists AND branch has commits — try build verification\n121:             if (fmt === \"text\") console.log(`  ${agent.feature_id}: process dead, worktree has changes — will verify build`);\n122:             toVerify.push(agent);\n123:           } else {\n124:             // No worktree, or worktree exists but branch has no commits (agent did nothing)\n125:             const reason = worktreeExists(agent.worktree)\n126:               ? \"worktree exists but no code changes\"\n127:               : \"no worktree\";\n128:             if (fmt === \"text\") console.log(`  ${agent.feature_id}: process dead, ${reason} — will re-launch`);\n129:             updateAgent(state, agent.feature_id, {\n130:               status: \"queued\",\n131:               pid: null,\n132:               activity: null,\n133:               session_id: null,\n134:             });\n135:             toRelaunch.push(agent);\n136:           }\n137:         }\n138:         break;\n139: \n140:       case \"queued\":\n141:         if (fmt === \"text\") console.log(`  ${agent.feature_id}: queued — will launch`);\n142:         toRelaunch.push(agent);\n143:         break;\n144: \n145:       case \"completed\":\n146:         // Completed but not verified — verify\n147:         if (fmt === \"text\") console.log(`  ${agent.feature_id}: completed — will verify build`);\n148:         toVerify.push(agent);\n149:         break;\n150: \n151:       case \"verified\":\n152:         // Build passed but NOT yet merged — need to attempt merge (+ conflict resolution)\n153:         if (fmt === \"text\") console.log(`  ${agent.feature_id}: verified — will attempt merge`);\n154:         toVerify.push(agent);\n155:         break;\n156: \n157:       case \"merged\":\n158:         if (fmt === \"text\") console.log(`  ${agent.feature_id}: merged — marking feature as done`);\n159:         markFeatureDone(projectRoot, agent.feature_id, config, state.base_branch);\n160:         try {\n161:           removeWorktree(projectRoot, agent.worktree, true);\n162:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: worktree and branch removed`);\n163:         } catch {\n164:           // Already cleaned — not critical\n165:         }\n166:         break;\n167: \n168:       case \"failed\":\n169:         // If the worktree exists with code changes and retries remain,\n170:         // attempt build verification rather than discarding the work.\n171:         if (agent.retries < agent.max_retries &&\n172:             worktreeExists(agent.worktree) &&\n173:             branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n174:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: failed but has work (retry ${agent.retries}/${agent.max_retries}) — will verify build`);\n175:           // Clear stale error and mark as completed so handleBuildVerification\n176:           // processes it correctly (it expects a non-failed agent)\n177:           updateAgent(state, agent.feature_id, {\n178:             status: \"completed\",\n179:             error: null,\n180:             build_passed: null,\n181:             build_output: null,\n182:             completed_at: new Date().toISOString(),\n183:           });\n184:           toVerify.push(agent);\n185:         } else if (agent.retries < agent.max_retries) {\n186:           // No worktree or no changes — re-launch from scratch\n187:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: failed, no salvageable work (retry ${agent.retries}/${agent.max_retries}) — will re-launch`);\n188:           updateAgent(state, agent.feature_id, {\n189:             status: \"queued\",\n190:             pid: null,\n191:             error: null,\n192:             build_passed: null,\n193:             build_output: null,\n194:             activity: null,\n195:             session_id: null,\n196:             completed_at: null,\n197:           });\n198:           toRelaunch.push(agent);\n199:         } else {\n200:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: failed — max retries reached (use 'woco retry' to reset)`);\n201:         }\n202:         break;\n203:     }\n204:   }\n205: \n206:   saveState(projectRoot, state);\n207: \n208:   // ---------------------------------------------------------------------------\n209:   // Phase 1: Parallel build verification\n210:   // Each agent's worktree is independent, so dep install + build can run\n211:   // concurrently. Merges must remain sequential (they mutate the project root).\n212:   // ---------------------------------------------------------------------------\n213:   if (toVerify.length > 0) {\n214:     if (fmt === \"text\") console.log(`\\nVerifying ${toVerify.length} agent(s) in parallel...\\n`);\n215: \n216:     const verifyResults = await Promise.all(\n217:       toVerify.map(async (agent): Promise<{ agent: AgentState; needsMerge: boolean }> => {\n218:         const feature = featureMap.get(agent.feature_id);\n219:         if (!feature) return { agent, needsMerge: false };\n220: \n221:         // Already verified — skip build, go straight to merge\n222:         if (agent.status === \"verified\") {\n223:           printAgentUpdate(agent, \"already verified — queued for merge\");\n224:           return { agent, needsMerge: true };\n225:         }\n226: \n227:         printAgentUpdate(agent, \"verifying build...\");\n228: \n229:         // Ensure deps are installed — worktree may exist without node_modules\n230:         // (e.g., failed agents whose setup was interrupted)\n231:         if (!worktreeReady(agent.worktree) && worktreeExists(agent.worktree)) {\n232:           try {\n233:             printAgentUpdate(agent, \"installing deps...\");\n234:             await installDeps(agent.worktree, agent.feature_id, config);\n235:           } catch (depErr: any) {\n236:             printAgentUpdate(agent, `dep install failed: ${depErr.message}`);\n237:             updateAgent(state, agent.feature_id, {\n238:               status: \"failed\",\n239:               error: `Dependency install failed: ${depErr.message}`,\n240:               retries: agent.retries + 1,\n241:               completed_at: new Date().toISOString(),\n242:             });\n243:             saveState(projectRoot, state);\n244:             return { agent, needsMerge: false };\n245:           }\n246:         }\n247: \n248:         try {\n249:           const buildResult = await runBuild(agent.worktree, config);\n250:           if (buildResult.passed) {\n251:             updateAgent(state, agent.feature_id, {\n252:               status: \"verified\",\n253:               build_passed: true,\n254:               build_output: null,\n255:             });\n256:             saveState(projectRoot, state);\n257:             printAgentUpdate(agent, `BUILD PASSED (${Math.round(buildResult.durationMs / 1000)}s)`);\n258:             return { agent, needsMerge: true };\n259:           } else {\n260:             // Build failed\n261:             if (agent.retries < agent.max_retries) {\n262:               updateAgent(state, agent.feature_id, {\n263:                 status: \"retry\",\n264:                 retries: agent.retries + 1,\n265:                 build_passed: false,\n266:                 build_output: buildResult.errorSummary,\n267:               });\n268:               saveState(projectRoot, state);\n269:               printAgentUpdate(agent, `BUILD FAILED — will retry (${agent.retries + 1}/${agent.max_retries})`);\n270:             } else {\n271:               updateAgent(state, agent.feature_id, {\n272:                 status: \"failed\",\n273:                 build_passed: false,\n274:                 build_output: buildResult.errorSummary,\n275:                 error: `Build failed after ${agent.max_retries} retries`,\n276:                 completed_at: new Date().toISOString(),\n277:               });\n278:               saveState(projectRoot, state);\n279:               printAgentUpdate(agent, \"BUILD FAILED — max retries reached\");\n280:             }\n281:             return { agent, needsMerge: false };\n282:           }\n283:         } catch (err: any) {\n284:           printAgentUpdate(agent, `verify error: ${err.message}`);\n285:           updateAgent(state, agent.feature_id, {\n286:             status: \"failed\",\n287:             error: `Build verification error: ${err.message}`,\n288:             completed_at: new Date().toISOString(),\n289:           });\n290:           saveState(projectRoot, state);\n291:           return { agent, needsMerge: false };\n292:         }\n293:       })\n294:     );\n295: \n296:     saveState(projectRoot, state);\n297: \n298:     // -------------------------------------------------------------------------\n299:     // Phase 2: Sequential merge for verified agents\n300:     // Merges must be sequential because they operate on the project root.\n301:     // -------------------------------------------------------------------------\n302:     const toMerge = verifyResults.filter((r) => r.needsMerge);\n303:     if (toMerge.length > 0) {\n304:       if (fmt === \"text\") console.log(`\\nMerging ${toMerge.length} verified agent(s)...\\n`);\n305:       for (const { agent } of toMerge) {\n306:         const feature = featureMap.get(agent.feature_id);\n307:         if (!feature) continue;\n308:         try {\n309:           await attemptMerge(projectRoot, state, agent, feature, config, opts.model);\n310:         } catch (err: any) {\n311:           printAgentUpdate(agent, `merge error: ${err.message}`);\n312:         }\n313:       }\n314:     }\n315: \n316:     // Collect agents that need re-launching from verify results\n317:     for (const { agent } of verifyResults) {\n318:       if (agent.status === \"retry\" || agent.status === \"running\") {\n319:         toRelaunch.push(agent);\n320:       }\n321:     }\n322:   }\n323: \n324:   // Re-launch agents\n325:   const maxConcurrent = opts.maxConcurrent ?? state.max_concurrent;\n326:   const toLaunchNow = toRelaunch.slice(0, maxConcurrent);\n327:   if (toLaunchNow.length === 0) {\n328:     outputMessage(fmt, \"No agents need (re)launching.\", {\n329:       wave_id: state.wave_id,\n330:       triage: {\n331:         to_verify: toVerify.length,\n332:         to_relaunch: 0,\n333:       },\n334:       agents: state.agents.map((a) => ({\n335:         feature_id: a.feature_id,\n336:         status: a.status,\n337:         build_passed: a.build_passed,\n338:         error: a.error,\n339:       })),\n340:     });\n341:     if (fmt === \"text\") printDashboard(state);\n342:     return;\n343:   }\n344: \n345:   if (fmt === \"text\") {\n346:     console.log(`\\nRe-launching ${toLaunchNow.length} agent(s)...\\n`);\n347:     printDashboard(state);\n348:   }\n349: \n350:   const model = opts.model ?? state.model ?? undefined;\n351: \n352:   if (opts.interactive) {\n353:     // Interactive resume\n354:     await Promise.all(\n355:       toLaunchNow.map(async (agent) => {\n356:         const feature = featureMap.get(agent.feature_id);\n357:         if (!feature) return;\n358: \n359:         updateAgent(state, agent.feature_id, {\n360:           status: \"installing\",\n361:           started_at: new Date().toISOString(),\n362:           activity: \"resuming...\",\n363:         });\n364:         saveState(projectRoot, state);\n365: \n366:         try {\n367:           if (!worktreeReady(agent.worktree)) {\n368:             await createWorktree(projectRoot, agent.feature_id, state.base_branch, config);\n369:             await installDeps(agent.worktree, agent.feature_id, config);\n370:           }\n371: \n372:           const prompt = generatePrompt(feature, state.base_branch, config);\n373:           const result = launchInteractive({\n374:             worktreePath: agent.worktree,\n375:             featureId: feature.id,\n376:             prompt,\n377:             model,\n378:             interactive: true,\n379:             config,\n380:           });\n381: \n382:           const muxName = getMultiplexerName(config);\n383:           updateAgent(state, agent.feature_id, {\n384:             status: \"running\",\n385:             pid: result.pid,\n386:             activity: `${muxName} session active`,\n387:           });\n388:           saveState(projectRoot, state);\n389:         } catch (err: any) {\n390:           updateAgent(state, agent.feature_id, {\n391:             status: \"failed\",\n392:             error: err.message,\n393:             activity: null,\n394:             completed_at: new Date().toISOString(),\n395:           });\n396:           saveState(projectRoot, state);\n397:         }\n398:       })\n399:     );\n400: \n401:     printDashboard(state);\n402:     const mux = detectMultiplexer(config.agent.multiplexer);\n403:     console.log(`\\nResume complete. Use '${muxAttachCommand(mux, `${config.agent.tmuxPrefix}-<id>`)}' to check sessions.`);\n404:   } else {\n405:     // Headless resume — re-enter monitoring loop\n406:     const monitor = new ProcessMonitor(projectRoot, {\n407:       onSessionId: (featureId, sessionId) => {\n408:         updateAgent(state, featureId, { session_id: sessionId });\n409:         saveState(projectRoot, state);\n410:       },\n411:       onComplete: (featureId) => {\n412:         updateAgent(state, featureId, {\n413:           status: \"completed\",\n414:           completed_at: new Date().toISOString(),\n415:           activity: \"done\",\n416:         });\n417:         saveState(projectRoot, state);\n418:         wtLog(featureId, \"agent completed — verifying build...\");\n419: \n420:         const agent = state.agents.find((a) => a.feature_id === featureId)!;\n421:         const feature = featureMap.get(featureId)!;\n422:         handleBuildVerification(projectRoot, state, agent, feature, config, model, monitor)\n423:           .then(() => launchAllReady(projectRoot, state, featureMap, monitor, config, model))\n424:           .catch((err) => {\n425:             wtLog(featureId, `BUILD VERIFICATION UNHANDLED ERROR: ${err.message}`);\n426:             launchAllReady(projectRoot, state, featureMap, monitor, config, model);\n427:           });\n428:       },\n429:       onError: (featureId, error) => {\n430:         const agent = state.agents.find((a) => a.feature_id === featureId)!;\n431:         if (agent.retries < agent.max_retries) {\n432:           updateAgent(state, featureId, {\n433:             status: \"retry\",\n434:             retries: agent.retries + 1,\n435:             error,\n436:             activity: \"retrying...\",\n437:           });\n438:           saveState(projectRoot, state);\n439:           handleRetry(projectRoot, state, agent, monitor, config, model);\n440:         } else {\n441:           updateAgent(state, featureId, {\n442:             status: \"failed\",\n443:             error,\n444:             activity: null,\n445:             completed_at: new Date().toISOString(),\n446:           });\n447:           saveState(projectRoot, state);\n448: \n449:           // Cascade failure to downstream agents\n450:           const cancelled = cancelDownstream(state, featureId);\n451:           if (cancelled.length > 0) {\n452:             wtLog(featureId, `downstream cancelled: ${cancelled.join(\", \")}`);\n453:             saveState(projectRoot, state);\n454:           }\n455:         }\n456:         launchAllReady(projectRoot, state, featureMap, monitor, config, model);\n457:       },\n458:       onActivity: (featureId, activity) => {\n459:         updateAgent(state, featureId, {\n460:           activity,\n461:           activity_updated_at: new Date().toISOString(),\n462:         });\n463:       },\n464:     });\n465: \n466:     // Handle graceful shutdown\n467:     const tuiRef = { current: null as WomboTUI | null };\n468:     process.on(\"SIGINT\", () => {\n469:       if (tuiRef.current) tuiRef.current.stop();\n470:       for (const agent of state.agents) {\n471:         if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n472:           updateAgent(state, agent.feature_id, {\n473:             activity: \"interrupted\",\n474:           });\n475:         }\n476:       }\n477:       monitor.killAll();\n478:       saveState(projectRoot, state);\n479:       console.log(\"\\nState saved. Use 'woco resume' to continue.\");\n480:       process.exit(0);\n481:     });\n482: \n483:     await Promise.all(\n484:       toLaunchNow.map((agent) => {\n485:         const feature = featureMap.get(agent.feature_id);\n486:         if (!feature) return Promise.resolve();\n487:         return launchSingleHeadless(projectRoot, state, agent, feature, monitor, config, model);\n488:       })\n489:     );\n490: \n491:     // Start TUI dashboard (or skip if --no-tui)\n492:     if (!opts.noTui) {\n493:       tuiRef.current = new WomboTUI({\n494:         state,\n495:         monitor,\n496:         projectRoot,\n497:         interactive: false,\n498:         config,\n499:         onQuit: () => {\n500:           for (const agent of state.agents) {\n501:             if (agent.status === \"running\") {\n502:               updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n503:             }\n504:           }\n505:           monitor.killAll();\n506:           saveState(projectRoot, state);\n507:           console.log(\"State saved. Use 'woco resume' to continue.\");\n508:           process.exit(0);\n509:         },\n510:       });\n511:       tuiRef.current.start();\n512:     } else {\n513:       console.log(\"(--no-tui mode, dashboard prints every 15s)\\n\");\n514:       printDashboard(state);\n515:     }\n516: \n517:     // Monitoring loop\n518:     const POLL_INTERVAL = 5000;\n519:     let dashboardCounter = 0;\n520:     while (!isWaveComplete(state)) {\n521:       await new Promise((r) => setTimeout(r, POLL_INTERVAL));\n522: \n523:       for (const agent of state.agents) {\n524:         if (\n525:           (agent.status === \"running\" || agent.status === \"resolving_conflict\") &&\n526:           agent.pid &&\n527:           !isProcessRunning(agent.pid) &&\n528:           !monitor.isRunning(agent.feature_id)\n529:         ) {\n530:           if (agent.status === \"resolving_conflict\") {\n531:             // Conflict resolver died unexpectedly — mark as failed\n532:             updateAgent(state, agent.feature_id, {\n533:               status: \"failed\",\n534:               error: \"Conflict resolver process died unexpectedly\",\n535:               activity: null,\n536:               completed_at: new Date().toISOString(),\n537:             });\n538:             saveState(projectRoot, state);\n539:             wtLog(agent.feature_id, \"conflict resolver died — marked failed\");\n540: \n541:             // Cascade failure to downstream agents\n542:             const cancelled = cancelDownstream(state, agent.feature_id);\n543:             if (cancelled.length > 0) {\n544:               wtLog(agent.feature_id, `downstream cancelled: ${cancelled.join(\", \")}`);\n545:               saveState(projectRoot, state);\n546:             }\n547: \n548:             launchAllReady(projectRoot, state, featureMap, monitor, config, model);\n549:             continue;\n550:           }\n551:           // Check if the agent actually made any commits\n552:           if (!branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n553:             // Agent died without producing any code — mark as failed\n554:             updateAgent(state, agent.feature_id, {\n555:               status: \"failed\",\n556:               error: \"Agent process exited without making any commits\",\n557:               activity: null,\n558:               completed_at: new Date().toISOString(),\n559:             });\n560:             saveState(projectRoot, state);\n561:             wtLog(agent.feature_id, \"process died with no code changes — marked failed\");\n562: \n563:             // Cascade failure to downstream agents\n564:             const cancelled = cancelDownstream(state, agent.feature_id);\n565:             if (cancelled.length > 0) {\n566:               wtLog(agent.feature_id, `downstream cancelled: ${cancelled.join(\", \")}`);\n567:               saveState(projectRoot, state);\n568:             }\n569:           } else {\n570:             updateAgent(state, agent.feature_id, {\n571:               status: \"completed\",\n572:               completed_at: new Date().toISOString(),\n573:               activity: \"done\",\n574:             });\n575:             saveState(projectRoot, state);\n576:             const feature = featureMap.get(agent.feature_id)!;\n577:             try {\n578:               await handleBuildVerification(projectRoot, state, agent, feature, config, model, monitor);\n579:             } catch (err: any) {\n580:               wtLog(agent.feature_id, `POLL VERIFY ERROR: ${err.message}`);\n581:             }\n582:           }\n583:           launchAllReady(projectRoot, state, featureMap, monitor, config, model);\n584:         }\n585:       }\n586: \n587:       saveState(projectRoot, state);\n588:       if (tuiRef.current) {\n589:         tuiRef.current.updateState(state);\n590:       } else if (opts.noTui) {\n591:         dashboardCounter++;\n592:         if (dashboardCounter % 3 === 0) {\n593:           printDashboard(state);\n594:         }\n595:       }\n596:     }\n597: \n598:     // Wave complete — keep TUI open for post-mortem browsing\n599:     if (tuiRef.current) {\n600:       tuiRef.current.updateState(state);\n601:       tuiRef.current.markWaveComplete();\n602:       await tuiRef.current.waitForQuit();\n603:     }\n604: \n605:     printDashboard(state);\n606: \n607:     // Dump full logs for failed agents (post-mortem)\n608:     dumpFailedAgentLogs(projectRoot, state);\n609: \n610:     // Auto-export wave history\n611:     try {\n612:       const historyPath = exportWaveHistory(projectRoot, state);\n613:       console.log(`Wave history exported to ${historyPath}`);\n614:     } catch (err: any) {\n615:       console.error(`Warning: failed to export wave history: ${err.message}`);\n616:     }\n617: \n618:     // Auto-push base branch if requested\n619:     if (opts.autoPush) {\n620:       await pushBaseBranch(projectRoot, state.base_branch, config);\n621:     }\n622: \n623:     console.log(\"Wave complete.\");\n624:   }\n625: }\n\n(End of file - total 625 lines)\n</content>","title":"src/commands/resume.ts","metadata":{"preview":"/**\n * resume.ts — Resume a previously stopped wave.\n *\n * Usage: woco resume [options] [--output json]\n *\n * Restores from .wombo-combo/state.json:\n *   - Agents in \"running\"/\"installing\" whose PID is dead → re-check or re-launch\n *   - Agents in \"queued\" → launch them\n *   - Agents in terminal states (verified/failed/merged) → leave alone\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport type { Feature } from \"../lib/tasks.js\";\nimport { loadFeatures 