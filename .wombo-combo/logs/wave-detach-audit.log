{"type":"tool_use","timestamp":1773481727904,"sessionID":"ses_3144093abffe4EFLXWMouX7qVB","part":{"id":"prt_cebbf9326001dFyOw0DEW5B11a","sessionID":"ses_3144093abffe4EFLXWMouX7qVB","messageID":"msg_cebbf8607001sykyV79AAm5jeN","type":"tool","callID":"toolu_vrtx_01LT9SqwEKDfAFhcMpsvizHh","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/wave-detach-audit/src/commands/launch.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/wave-detach-audit/src/commands/launch.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * launch.ts — Launch a wave of agents.\n3:  *\n4:  * Usage: woco launch [selection options] [launch options]\n5:  *\n6:  * This is the primary entry point for starting a new wave. It selects features\n7:  * from the features file, creates a wave state, sets up worktrees, and launches\n8:  * agent processes (either headless or interactive via dmux/tmux).\n9:  *\n10:  * IMPORTANT: This file also exports shared helper functions that are reused\n11:  * by resume.ts and other commands:\n12:  *   - launchSingleHeadless\n13:  *   - handleBuildVerification\n14:  *   - handleRetry\n15:  *   - launchNextQueued\n16:  */\n17: \n18: import { execSync } from \"node:child_process\";\n19: import { existsSync, readFileSync } from \"node:fs\";\n20: import { resolve } from \"node:path\";\n21: import type { WomboConfig } from \"../config.js\";\n22: import type { Feature, SelectionOptions, Priority, Difficulty } from \"../lib/tasks.js\";\n23: import { loadFeatures, selectFeatures, parseDurationMinutes, saveFeatures } from \"../lib/tasks.js\";\n24: import {\n25:   loadState,\n26:   saveState,\n27:   createWaveState,\n28:   createAgentState,\n29:   updateAgent,\n30:   activeAgents,\n31:   queuedAgents,\n32:   readyToLaunchAgents,\n33:   areAgentDepsReady,\n34:   cancelDownstream,\n35:   isWaveComplete,\n36:   type WaveState,\n37:   type AgentState,\n38:   type SerializedSchedulePlan,\n39: } from \"../lib/state.js\";\n40: import {\n41:   createWorktree,\n42:   installDeps,\n43:   featureBranchName,\n44:   worktreePath,\n45:   worktreeReady,\n46:   branchHasChanges,\n47:   isWorktreesDirEmpty,\n48:   branchExists,\n49:   removeWorktree,\n50:   log as wtLog,\n51: } from \"../lib/worktree.js\";\n52: import { generatePrompt, generateConflictResolutionPrompt, type QuestPromptContext } from \"../lib/prompt.js\";\n53: import {\n54:   launchHeadless,\n55:   retryHeadless,\n56:   launchInteractive,\n57:   retryInteractive,\n58:   launchConflictResolver,\n59:   isProcessRunning,\n60:   getMultiplexerName,\n61: } from \"../lib/launcher.js\";\n62: import { ProcessMonitor } from \"../lib/monitor.js\";\n63: import { runBuild, runFullVerification, type FullVerificationOptions } from \"../lib/verifier.js\";\n64: import { mergeBranch, mergeBaseIntoFeature, pushBaseBranch, canMerge, enqueueMerge, tieredMergeBaseIntoFeature } from \"../lib/merger.js\";\n65: import {\n66:   printDashboard,\n67:   printFeatureSelection,\n68:   printAgentUpdate,\n69: } from \"../lib/ui.js\";\n70: import { WomboTUI } from \"../lib/tui.js\";\n71: import { ensureAgentDefinition } from \"../lib/templates.js\";\n72: import {\n73:   buildDepGraph,\n74:   validateDepGraph,\n75:   buildSchedulePlan,\n76:   formatSchedulePlan,\n77:   getStreamForFeature,\n78:   type DepGraph,\n79:   type SchedulePlan,\n80: } from \"../lib/dependency-graph.js\";\n81: import { ensureProxyRunning, isPortlessAvailable, portlessUrl } from \"../lib/portless.js\";\n82: import { output, outputError, outputMessage, type OutputFormat } from \"../lib/output.js\";\n83: import { renderLaunchDryRun } from \"../lib/toon.js\";\n84: import {\n85:   detectMultiplexer,\n86:   muxAttachCommand,\n87:   muxListCommand,\n88: } from \"../lib/multiplexer.js\";\n89: import { exportWaveHistory } from \"../lib/history.js\";\n90: import {\n91:   prepareAgentDefinitions,\n92:   isSpecializedAgent,\n93:   writeAgentToWorktree,\n94:   type AgentResolution,\n95: } from \"../lib/agent-registry.js\";\n96: import { patchImportedAgent } from \"../lib/templates.js\";\n97: import {\n98:   tuiPreflightConfirm,\n99:   consolePreflightConfirm,\n100: } from \"../lib/preflight.js\";\n101: import { loadQuest, loadQuestKnowledge } from \"../lib/quest-store.js\";\n102: import { resolveQuestConfig, applyQuestConstraintsToTask, type QuestHitlMode } from \"../lib/quest.js\";\n103: import { questBranchExists, createQuestBranch } from \"../lib/worktree.js\";\n104: import { getPendingQuestions, cleanupAll as cleanupHitl, submitAnswer, type HitlQuestion } from \"../lib/hitl-channel.js\";\n105: \n106: // ---------------------------------------------------------------------------\n107: // Constants\n108: // ---------------------------------------------------------------------------\n109: \n110: /**\n111:  * Build a QuestPromptContext from a wave's quest_id.\n112:  * Returns undefined if the wave is not quest-scoped.\n113:  * Used by internal functions that can't receive questContext from their caller.\n114:  */\n115: function buildQuestContext(\n116:   projectRoot: string,\n117:   questId: string | null\n118: ): QuestPromptContext | undefined {\n119:   if (!questId) return undefined;\n120: \n121:   const quest = loadQuest(projectRoot, questId);\n122:   if (!quest) return undefined;\n123: \n124:   const knowledge = loadQuestKnowledge(projectRoot, questId);\n125:   return {\n126:     questId: quest.id,\n127:     goal: quest.goal,\n128:     addedConstraints: quest.constraints.add ?? [],\n129:     addedForbidden: quest.constraints.ban ?? [],\n130:     knowledge,\n131:   };\n132: }\n133: \n134: /**\n135:  * Delay (ms) between sequential agent launches to avoid SQLite race conditions.\n136:  * Each agent spawns its own process which runs DB migrations on startup.\n137:  * Launching them simultaneously causes `CREATE TABLE` collisions.\n138:  */\n139: const LAUNCH_STAGGER_MS = 500;\n140: \n141: // ---------------------------------------------------------------------------\n142: // Types\n143: // ---------------------------------------------------------------------------\n144: \n145: export interface LaunchCommandOptions {\n146:   projectRoot: string;\n147:   config: WomboConfig;\n148:   // Selection\n149:   topPriority?: number;\n150:   quickestWins?: number;\n151:   priority?: Priority;\n152:   difficulty?: Difficulty;\n153:   features?: string[];\n154:   allReady?: boolean;\n155:   // Launch\n156:   maxConcurrent: number;\n157:   model?: string;\n158:   interactive: boolean;\n159:   dryRun: boolean;\n160:   baseBranch: string;\n161:   maxRetries: number;\n162:   noTui: boolean;\n163:   autoPush: boolean;\n164:   // Agent selection\n165:   /** CLI override: use this local agent definition for all launched tasks */\n166:   agent?: string;\n167:   // Quest scoping\n168:   /** Quest ID to scope this launch to (uses quest branch as base) */\n169:   questId?: string;\n170:   // Output\n171:   outputFmt?: OutputFormat;\n172: }\n173: \n174: // ---------------------------------------------------------------------------\n175: // Shared Helpers (exported for resume.ts and others)\n176: // ---------------------------------------------------------------------------\n177: \n178: /**\n179:  * Mark a feature as done in the features file after a successful merge.\n180:  * Updates status to \"done\", completion to 100, and sets ended_at.\n181:  *\n182:  * GUARD: Verifies that the feature branch has actually been merged into\n183:  * baseBranch before allowing the status change. This prevents callers\n184:  * from accidentally marking verified-but-unmerged features as done.\n185:  *\n186:  * @param fmt - Output format. When \"json\" or \"toon\", suppresses console warnings.\n187:  */\n188: export function markFeatureDone(\n189:   projectRoot: string,\n190:   featureId: string,\n191:   config: WomboConfig,\n192:   baseBranch: string,\n193:   fmt: OutputFormat = \"text\"\n194: ): void {\n195:   try {\n196:     // Verify the feature branch was actually merged into base\n197:     const branch = featureBranchName(featureId, config);\n198:     try {\n199:       execSync(`git merge-base --is-ancestor \"${branch}\" \"${baseBranch}\"`, {\n200:         cwd: projectRoot,\n201:         stdio: \"pipe\",\n202:       });\n203:     } catch {\n204:       // git merge-base --is-ancestor exits non-zero if NOT an ancestor\n205:       if (fmt === \"text\") {\n206:         console.error(\n207:           `Warning: ${featureId} branch \"${branch}\" is not merged into \"${baseBranch}\" — refusing to mark as done`\n208:         );\n209:       }\n210:       return;\n211:     }\n212: \n213:     const data = loadFeatures(projectRoot, config);\n214:     const feature = data.tasks.find((f: Feature) => f.id === featureId);\n215:     if (feature && feature.status !== \"done\") {\n216:       feature.status = \"done\";\n217:       feature.completion = 100;\n218:       feature.ended_at = new Date().toISOString();\n219:       saveFeatures(projectRoot, config, data);\n220:     }\n221:   } catch (err: any) {\n222:     // Non-fatal — log but don't crash the wave\n223:     if (fmt === \"text\") {\n224:       console.error(`Warning: failed to update feature status for ${featureId}: ${err.message}`);\n225:     }\n226:   }\n227: }\n228: \n229: /**\n230:  * Launch a single agent in headless mode.\n231:  * Sets up worktree, installs deps, generates prompt, launches agent process.\n232:  * If agentResolutions is provided and contains a specialized agent for this\n233:  * feature, the patched agent definition is written into the worktree.\n234:  */\n235: export async function launchSingleHeadless(\n236:   projectRoot: string,\n237:   state: WaveState,\n238:   agent: AgentState,\n239:   feature: Feature,\n240:   monitor: ProcessMonitor,\n241:   config: WomboConfig,\n242:   model?: string,\n243:   agentResolutions?: Map<string, AgentResolution>,\n244:   questContext?: QuestPromptContext,\n245:   hitlMode?: string\n246: ): Promise<void> {\n247:   updateAgent(state, agent.feature_id, {\n248:     status: \"installing\",\n249:     started_at: new Date().toISOString(),\n250:     activity: \"setting up worktree...\",\n251:   });\n252:   saveState(projectRoot, state);\n253: \n254:   try {\n255:     // Check if this agent is reusing a chain predecessor's worktree\n256:     const isChainReuse = agent.depends_on.some((depId) => {\n257:       const depAgent = state.agents.find((a) => a.feature_id === depId);\n258:       return depAgent && depAgent.worktree === agent.worktree;\n259:     });\n260: \n261:     if (isChainReuse && worktreeReady(agent.worktree)) {\n262:       // Chain worktree reuse: the worktree already exists from a predecessor.\n263:       // Create a new branch for this feature and switch the worktree to it.\n264:       wtLog(agent.feature_id, \"reusing chain worktree — switching branch...\");\n265:       updateAgent(state, agent.feature_id, { activity: \"switching branch (chain reuse)...\" });\n266: \n267:       try {\n268:         // Create the new feature branch from base (in the worktree)\n269:         execSync(`git checkout -B \"${agent.branch}\" \"${state.base_branch}\"`, {\n270:           cwd: agent.worktree,\n271:           stdio: \"pipe\",\n272:         });\n273:         wtLog(agent.feature_id, `switched to branch ${agent.branch}`);\n274:       } catch (branchErr: any) {\n275:         wtLog(agent.feature_id, `branch switch failed: ${branchErr.message}`);\n276:         // Fall through to normal worktree creation\n277:         await createWorktree(projectRoot, feature.id, state.base_branch, config);\n278:       }\n279:     } else if (worktreeReady(agent.worktree)) {\n280:       // Skip worktree setup if already ready (resume case)\n281:       wtLog(agent.feature_id, \"worktree already exists, skipping setup\");\n282:     } else {\n283:       // Create worktree (async — doesn't block other agents)\n284:       await createWorktree(projectRoot, feature.id, state.base_branch, config);\n285: \n286:       // Install dependencies (async)\n287:       updateAgent(state, agent.feature_id, { activity: \"installing deps...\" });\n288:       await installDeps(agent.worktree, feature.id, config);\n289:     }\n290: \n291:     // Generate prompt\n292:     const prompt = generatePrompt(feature, state.base_branch, config, questContext, hitlMode as QuestHitlMode | undefined);\n293: \n294:     // Write specialized agent to worktree if applicable\n295:     const resolution = agentResolutions?.get(feature.id);\n296:     const agentName = agent.agent_name ?? undefined;\n297:     if (resolution && isSpecializedAgent(resolution)) {\n298:       try {\n299:         const patchedContent = patchImportedAgent(resolution.rawContent, config, projectRoot);\n300:         writeAgentToWorktree(agent.worktree, resolution.name, patchedContent);\n301:         wtLog(agent.feature_id, `wrote specialized agent: ${resolution.name}`);\n302:       } catch (err: any) {\n303:         wtLog(agent.feature_id, `WARN: failed to write specialized agent, using generalist: ${err.message}`);\n304:       }\n305:     }\n306: \n307:     // Launch agent\n308:     wtLog(agent.feature_id, \"launching agent...\");\n309:     const result = launchHeadless({\n310:       worktreePath: agent.worktree,\n311:       featureId: feature.id,\n312:       prompt,\n313:       model,\n314:       config,\n315:       agentName,\n316:       hitlMode,\n317:       projectRoot,\n318:     });\n319: \n320:     updateAgent(state, agent.feature_id, {\n321:       status: \"running\",\n322:       pid: result.pid,\n323:       activity: \"starting...\",\n324:     });\n325:     saveState(projectRoot, state);\n326: \n327:     monitor.addProcess(feature.id, result.process);\n328:     wtLog(agent.feature_id, `running (PID: ${result.pid})`);\n329:   } catch (err: any) {\n330:     updateAgent(state, agent.feature_id, {\n331:       status: \"failed\",\n332:       error: err.message,\n333:       activity: null,\n334:       completed_at: new Date().toISOString(),\n335:     });\n336:     saveState(projectRoot, state);\n337:     wtLog(agent.feature_id, `SETUP FAILED: ${err.message.split(\"\\n\")[0]}`);\n338:   }\n339: }\n340: \n341: /**\n342:  * Handle build verification after agent completion.\n343:  * Runs build, auto-merges on pass, retries on failure if retries remain.\n344:  *\n345:  * ASYNC — runs build and merge without blocking the event loop.\n346:  */\n347: export async function handleBuildVerification(\n348:   projectRoot: string,\n349:   state: WaveState,\n350:   agent: AgentState,\n351:   feature: Feature,\n352:   config: WomboConfig,\n353:   model?: string,\n354:   monitor?: ProcessMonitor,\n355:   tddOpts?: FullVerificationOptions,\n356:   hitlMode?: string\n357: ): Promise<void> {\n358:   try {\n359:     printAgentUpdate(agent, \"verifying build...\");\n360: \n361:     // Use full verification pipeline (build + optional browser tests + optional TDD)\n362:     const fullResult = await runFullVerification(agent.worktree, agent.feature_id, config, tddOpts);\n363:     const buildResult = fullResult.build;\n364: \n365:     // Report browser test status if they ran\n366:     if (fullResult.browser.ran && fullResult.browser.browserResult) {\n367:       const br = fullResult.browser.browserResult;\n368:       printAgentUpdate(\n369:         agent,\n370:         `BROWSER: ${br.summary} (${Math.round(br.totalDurationMs / 1000)}s)`\n371:       );\n372:     } else if (fullResult.browser.skipReason && config.browser.enabled) {\n373:       printAgentUpdate(agent, `BROWSER: skipped — ${fullResult.browser.skipReason}`);\n374:     }\n375: \n376:     // Report TDD verification status if it ran\n377:     if (fullResult.tdd.ran) {\n378:       const tdd = fullResult.tdd;\n379:       const tddIcon = tdd.passed ? \"✓\" : \"✗\";\n380:       printAgentUpdate(agent, `TDD: ${tddIcon} ${tdd.summary}`);\n381:       if (tdd.hasWarnings) {\n382:         printAgentUpdate(agent, `TDD: ⚠ Missing tests detected (non-blocking)`);\n383:       }\n384:     } else if (fullResult.tdd.skipReason && config.tdd?.enabled) {\n385:       printAgentUpdate(agent, `TDD: skipped — ${fullResult.tdd.skipReason}`);\n386:     }\n387: \n388:     if (fullResult.overallPassed) {\n389:       updateAgent(state, agent.feature_id, {\n390:         status: \"verified\",\n391:         build_passed: true,\n392:         build_output: null,\n393:       });\n394:       saveState(projectRoot, state);\n395:       printAgentUpdate(agent, `BUILD PASSED (${Math.round(buildResult.durationMs / 1000)}s)`);\n396: \n397:       // Auto-merge: attempt merge + conflict resolution\n398:       await attemptMerge(projectRoot, state, agent, feature, config, model);\n399:     } else {\n400:       const errorSummary = fullResult.combinedErrorSummary;\n401: \n402:       if (agent.retries < agent.max_retries) {\n403:         updateAgent(state, agent.feature_id, {\n404:           status: \"retry\",\n405:           retries: agent.retries + 1,\n406:           build_passed: false,\n407:           build_output: errorSummary,\n408:         });\n409:         saveState(projectRoot, state);\n410:         printAgentUpdate(\n411:           agent,\n412:           `VERIFICATION FAILED — retrying (${agent.retries}/${agent.max_retries})`\n413:         );\n414: \n415:         // Retry with error details\n416:         if (agent.session_id) {\n417:           const retryResult = retryHeadless({\n418:             worktreePath: agent.worktree,\n419:             featureId: agent.feature_id,\n420:             sessionId: agent.session_id,\n421:             buildErrors: errorSummary,\n422:             model,\n423:             config,\n424:             hitlMode,\n425:             projectRoot,\n426:           });\n427: \n428:           updateAgent(state, agent.feature_id, {\n429:             status: \"running\",\n430:             pid: retryResult.pid,\n431:           });\n432:           saveState(projectRoot, state);\n433: \n434:           // Add retry process to monitor so events are tracked\n435:           if (monitor) {\n436:             monitor.addProcess(agent.feature_id, retryResult.process);\n437:           }\n438:         } else {\n439:           // Agent has no session — reset to queued for a fresh launch\n440:           wtLog(agent.feature_id, `no session — resetting to queued for fresh launch (retry ${agent.retries}/${agent.max_retries})`);\n441:           updateAgent(state, agent.feature_id, {\n442:             status: \"queued\",\n443:             error: null,\n444:             activity: \"waiting for relaunch...\",\n445:           });\n446:           saveState(projectRoot, state);\n447:         }\n448:       } else {\n449:         updateAgent(state, agent.feature_id, {\n450:           status: \"failed\",\n451:           build_passed: false,\n452:           build_output: errorSummary,\n453:           error: `Verification failed after ${agent.max_retries} retries`,\n454:           completed_at: new Date().toISOString(),\n455:         });\n456:         saveState(projectRoot, state);\n457:         printAgentUpdate(agent, \"VERIFICATION FAILED — max retries reached\");\n458: \n459:         // Cascade failure to downstream agents\n460:         const cancelled = cancelDownstream(state, agent.feature_id);\n461:         if (cancelled.length > 0) {\n462:           printAgentUpdate(agent, `downstream cancelled: ${cancelled.join(\", \")}`);\n463:           saveState(projectRoot, state);\n464:         }\n465:       }\n466:     }\n467:   } catch (err: any) {\n468:     // Catch-all — never let build verification crash the process\n469:     printAgentUpdate(agent, `VERIFY ERROR: ${err.message?.slice(0, 100)}`);\n470:     updateAgent(state, agent.feature_id, {\n471:       status: \"failed\",\n472:       error: `Build verification error: ${err.message}`,\n473:       completed_at: new Date().toISOString(),\n474:     });\n475:     saveState(projectRoot, state);\n476:   }\n477: }\n478: \n479: /**\n480:  * Attempt to merge a verified agent's branch into the base branch.\n481:  *\n482:  * Handles conflict detection, base-into-feature merge, and resolver agent\n483:  * launch. Extracted from handleBuildVerification so it can be called\n484:  * independently (e.g., from resume's sequential merge phase).\n485:  *\n486:  * All merge operations are serialized via enqueueMerge() to prevent\n487:  * concurrent checkout races on the project root.\n488:  */\n489: export async function attemptMerge(\n490:   projectRoot: string,\n491:   state: WaveState,\n492:   agent: AgentState,\n493:   feature: Feature,\n494:   config: WomboConfig,\n495:   model?: string,\n496: ): Promise<void> {\n497:   return enqueueMerge(async () => {\n498:     printAgentUpdate(agent, \"auto-merging...\");\n499:     try {\n500:       // Pre-flight check: detect conflicts before attempting the real merge.\n501:       // This avoids the expensive merge-then-abort dance for known conflicts.\n502:       const preCheck = await canMerge(projectRoot, agent.branch, state.base_branch);\n503:       if (!preCheck.canMerge) {\n504:         printAgentUpdate(agent, `conflict detected (pre-flight) — attempting resolution...`);\n505:         await handleMergeConflict(\n506:           projectRoot, state, agent, feature, config, model,\n507:           preCheck.reason\n508:         );\n509:         return;\n510:       }\n511: \n512:       const mergeResult = await mergeBranch(projectRoot, agent.branch, state.base_branch, config);\n513: \n514:       if (mergeResult.success) {\n515:         handleMergeSuccess(projectRoot, state, agent, config, mergeResult.commitHash);\n516:         return;\n517:       }\n518: \n519:       // Merge failed despite clean pre-flight — race with another merge or\n520:       // a git state issue. Fall through to conflict resolution.\n521:       printAgentUpdate(agent, `MERGE CONFLICT — attempting resolution...`);\n522:       await handleMergeConflict(\n523:         projectRoot, state, agent, feature, config, model,\n524:         mergeResult.error ?? \"Unknown merge error\"\n525:       );\n526:     } catch (mergeErr: any) {\n527:       // Unexpected exception — stay in \"verified\" (retryable) but record the\n528:       // error so the user can see what went wrong instead of silent stalling.\n529:       printAgentUpdate(agent, `AUTO-MERGE ERROR: ${mergeErr.message?.slice(0, 100)}`);\n530:       updateAgent(state, agent.feature_id, {\n531:         error: `Auto-merge error: ${mergeErr.message}`,\n532:       });\n533:       saveState(projectRoot, state);\n534:     }\n535:   });\n536: }\n537: \n538: /**\n539:  * Handle a successful merge: update state, mark feature done, clean up.\n540:  */\n541: function handleMergeSuccess(\n542:   projectRoot: string,\n543:   state: WaveState,\n544:   agent: AgentState,\n545:   config: WomboConfig,\n546:   commitHash: string | null,\n547:   label = \"MERGED\",\n548: ): void {\n549:   updateAgent(state, agent.feature_id, {\n550:     status: \"merged\",\n551:     completed_at: new Date().toISOString(),\n552:   });\n553:   saveState(projectRoot, state);\n554:   printAgentUpdate(agent, `${label} (${commitHash?.slice(0, 7)})`);\n555: \n556:   markFeatureDone(projectRoot, agent.feature_id, config, state.base_branch);\n557: \n558:   // Clean up worktree — but preserve it if downstream agents in the same\n559:   // chain share this worktree.\n560:   const hasChainSuccessor = agent.depended_on_by.some((depId) => {\n561:     const depAgent = state.agents.find((a) => a.feature_id === depId);\n562:     return depAgent && depAgent.worktree === agent.worktree;\n563:   });\n564: \n565:   if (hasChainSuccessor) {\n566:     printAgentUpdate(agent, \"worktree preserved for chain successor\");\n567:   } else {\n568:     try {\n569:       removeWorktree(projectRoot, agent.worktree, true);\n570:       printAgentUpdate(agent, \"worktree and branch removed\");\n571:     } catch (err: any) {\n572:       // Log the failure so it's visible — stale worktrees waste disk space\n573:       printAgentUpdate(agent, `WARN: worktree cleanup failed: ${err.message?.split(\"\\n\")[0]}`);\n574:     }\n575:   }\n576: }\n577: \n578: /**\n579:  * Handle a merge conflict: use tiered merge strategy.\n580:  *\n581:  * Tier 1: Already failed (we got here because the direct merge failed).\n582:  * Tier 2: Merge base into feature, then auto-resolve trivial conflicts.\n583:  * Tier 3: Real conflicts remain — launch a resolver agent.\n584:  *\n585:  * If tier 3 also fails after max attempts, mark as needs_manual_merge.\n586:  *\n587:  * All failure paths record the error on the agent (which stays \"verified\")\n588:  * so the merge can be retried without silently stalling.\n589:  */\n590: async function handleMergeConflict(\n591:   projectRoot: string,\n592:   state: WaveState,\n593:   agent: AgentState,\n594:   feature: Feature,\n595:   config: WomboConfig,\n596:   model: string | undefined,\n597:   mergeError: string,\n598: ): Promise<void> {\n599:   try {\n600:     // Tiered merge: attempts tier 1 (clean merge) and tier 2 (trivial auto-resolve)\n601:     const tieredResult = await tieredMergeBaseIntoFeature(\n602:       agent.worktree,\n603:       state.base_branch,\n604:       config\n605:     );\n606: \n607:     if (tieredResult.success && tieredResult.tier === 1) {\n608:       // Clean merge of base into feature — retry merge into base\n609:       printAgentUpdate(agent, \"base merged cleanly into feature — retrying merge...\");\n610:       const retryMerge = await mergeBranch(projectRoot, agent.branch, state.base_branch, config);\n611:       if (retryMerge.success) {\n612:         handleMergeSuccess(projectRoot, state, agent, config, retryMerge.commitHash, \"MERGED after rebase\");\n613:         return;\n614:       }\n615: \n616:       // Retry still failed — need conflict resolution. Re-merge base into\n617:       // feature to get conflict files for the resolver.\n618:       printAgentUpdate(agent, `retry merge still failed — launching resolver agent...`);\n619:       const secondConflict = await mergeBaseIntoFeature(\n620:         agent.worktree,\n621:         state.base_branch,\n622:         config\n623:       );\n624: \n625:       const conflictFiles = secondConflict.conflicting\n626:         ? secondConflict.files\n627:         : [\"(unknown — merge direction mismatch)\"];\n628: \n629:       await launchResolverAndRetryMerge(\n630:         projectRoot, state, agent, feature, config, model,\n631:         retryMerge.error ?? mergeError, conflictFiles\n632:       );\n633:       return;\n634:     }\n635: \n636:     if (tieredResult.success && tieredResult.tier === 2) {\n637:       // Trivial conflicts auto-resolved — retry merge into base\n638:       printAgentUpdate(agent, \"trivial conflicts auto-resolved (whitespace only) — retrying merge...\");\n639:       const retryMerge = await mergeBranch(projectRoot, agent.branch, state.base_branch, config);\n640:       if (retryMerge.success) {\n641:         handleMergeSuccess(projectRoot, state, agent, config, retryMerge.commitHash, \"MERGED after trivial auto-resolve\");\n642:         return;\n643:       }\n644: \n645:       // Still failed after auto-resolve — fall through to agent resolver\n646:       printAgentUpdate(agent, `merge still failed after auto-resolve — launching resolver agent...`);\n647:       const postAutoConflict = await mergeBaseIntoFeature(\n648:         agent.worktree,\n649:         state.base_branch,\n650:         config\n651:       );\n652:       const conflictFiles = postAutoConflict.conflicting\n653:         ? postAutoConflict.files\n654:         : [\"(unknown — merge direction mismatch)\"];\n655: \n656:       await launchResolverAndRetryMerge(\n657:         projectRoot, state, agent, feature, config, model,\n658:         retryMerge.error ?? mergeError, conflictFiles\n659:       );\n660:       return;\n661:     }\n662: \n663:     if (tieredResult.tier === null && tieredResult.error) {\n664:       // Setup itself failed — stay as \"verified\" (retryable) with error\n665:       printAgentUpdate(agent, `CONFLICT SETUP FAILED: ${tieredResult.error.slice(0, 100)}`);\n666:       updateAgent(state, agent.feature_id, {\n667:         error: `Conflict setup failed: ${tieredResult.error}`,\n668:       });\n669:       saveState(projectRoot, state);\n670:       return;\n671:     }\n672: \n673:     // Tier 3: Real conflicts remain — launch resolver agent\n674:     printAgentUpdate(\n675:       agent,\n676:       `${tieredResult.conflictFiles.length} non-trivial conflict(s): ${tieredResult.conflictFiles.join(\", \")}`\n677:     );\n678: \n679:     await launchResolverAndRetryMerge(\n680:       projectRoot, state, agent, feature, config, model,\n681:       mergeError, tieredResult.conflictFiles\n682:     );\n683:   } catch (conflictErr: any) {\n684:     // Unexpected error during conflict handling — stay \"verified\" with error\n685:     printAgentUpdate(agent, `CONFLICT RESOLUTION ERROR: ${conflictErr.message?.slice(0, 100)}`);\n686:     updateAgent(state, agent.feature_id, {\n687:       error: `Conflict resolution error: ${conflictErr.message}`,\n688:     });\n689:     saveState(projectRoot, state);\n690:   }\n691: }\n692: \n693: /**\n694:  * Launch a conflict resolver agent, wait for it to finish, re-verify build,\n695:  * and retry the merge. Supports configurable retry attempts (defaults to 1,\n696:  * up to config.defaults.maxRetries + 1).\n697:  *\n698:  * The resolver is re-launched with updated conflict state on each attempt,\n699:  * so it sees the current conflict markers, not stale ones.\n700:  */\n701: async function launchResolverAndRetryMerge(\n702:   projectRoot: string,\n703:   state: WaveState,\n704:   agent: AgentState,\n705:   feature: Feature,\n706:   config: WomboConfig,\n707:   model: string | undefined,\n708:   mergeError: string,\n709:   conflictFiles: string[]\n710: ): Promise<void> {\n711:   const maxResolverAttempts = Math.max(1, (config.defaults.maxRetries ?? 0) + 1);\n712: \n713:   for (let attempt = 1; attempt <= maxResolverAttempts; attempt++) {\n714:     const conflictPrompt = generateConflictResolutionPrompt(\n715:       feature,\n716:       state.base_branch,\n717:       mergeError,\n718:       config,\n719:       buildQuestContext(projectRoot, state.quest_id)\n720:     );\n721: \n722:     const attemptLabel = maxResolverAttempts > 1\n723:       ? ` (attempt ${attempt}/${maxResolverAttempts})`\n724:       : \"\";\n725: \n726:     updateAgent(state, agent.feature_id, {\n727:       status: \"resolving_conflict\",\n728:       activity: `resolving ${conflictFiles.length} conflict(s)${attemptLabel}...`,\n729:     });\n730:     saveState(projectRoot, state);\n731: \n732:     const resolverResult = launchConflictResolver({\n733:       worktreePath: agent.worktree,\n734:       featureId: agent.feature_id,\n735:       prompt: conflictPrompt,\n736:       model,\n737:       config,\n738:     });\n739: \n740:     updateAgent(state, agent.feature_id, {\n741:       pid: resolverResult.pid,\n742:     });\n743:     saveState(projectRoot, state);\n744: \n745:     // Wait for the resolver process to complete, then re-verify and retry merge.\n746:     // We intentionally do NOT add the resolver to the ProcessMonitor because\n747:     // the monitor's onComplete callback would trigger handleBuildVerification\n748:     // again, causing infinite recursion. Instead we await the process directly.\n749:     const resolverExitCode = await new Promise<number | null>((resolve) => {\n750:       resolverResult.process.on(\"exit\", (code) => resolve(code));\n751:       resolverResult.process.on(\"error\", () => resolve(null));\n752:     });\n753: \n754:     printAgentUpdate(\n755:       agent,\n756:       `conflict resolver exited (code ${resolverExitCode})${attemptLabel} — re-verifying build...`\n757:     );\n758: \n759:     // Re-verify build after conflict resolution\n760:     const rebuildResult = await runBuild(agent.worktree, config);\n761: \n762:     if (!rebuildResult.passed) {\n763:       if (attempt < maxResolverAttempts) {\n764:         printAgentUpdate(agent, `POST-CONFLICT BUILD FAILED${attemptLabel} — retrying resolver...`);\n765:         continue; // Try again with a fresh resolver\n766:       }\n767:       printAgentUpdate(agent, `POST-CONFLICT BUILD FAILED (all ${maxResolverAttempts} attempts exhausted)`);\n768:       updateAgent(state, agent.feature_id, {\n769:         status: \"failed\",\n770:         build_passed: false,\n771:         build_output: rebuildResult.errorSummary,\n772:         error: \"Build failed after conflict resolution\",\n773:         completed_at: new Date().toISOString(),\n774:       });\n775:       saveState(projectRoot, state);\n776:       cancelDownstream(state, agent.feature_id);\n777:       saveState(projectRoot, state);\n778:       return;\n779:     }\n780: \n781:     printAgentUpdate(agent, \"post-conflict build passed — retrying merge...\");\n782: \n783:     const retryMerge = await mergeBranch(\n784:       projectRoot,\n785:       agent.branch,\n786:       state.base_branch,\n787:       config\n788:     );\n789: \n790:     if (retryMerge.success) {\n791:       handleMergeSuccess(\n792:         projectRoot, state, agent, config,\n793:         retryMerge.commitHash, \"MERGED after conflict resolution\"\n794:       );\n795:       return;\n796:     }\n797: \n798:     // Merge still failed after resolver. If we have attempts left, re-merge\n799:     // base into feature to refresh conflict markers and try again.\n800:     if (attempt < maxResolverAttempts) {\n801:       printAgentUpdate(agent, `POST-CONFLICT MERGE FAILED${attemptLabel} — retrying resolver...`);\n802:       const refreshConflict = await mergeBaseIntoFeature(\n803:         agent.worktree,\n804:         state.base_branch,\n805:         config\n806:       );\n807:       conflictFiles = refreshConflict.conflicting\n808:         ? refreshConflict.files\n809:         : conflictFiles;\n810:       mergeError = retryMerge.error ?? mergeError;\n811:       continue;\n812:     }\n813: \n814:     // All attempts exhausted\n815:     printAgentUpdate(agent, `POST-CONFLICT MERGE FAILED (all ${maxResolverAttempts} attempts exhausted): ${retryMerge.error}`);\n816:     updateAgent(state, agent.feature_id, {\n817:       status: \"failed\",\n818:       error: `Merge still failed after ${maxResolverAttempts} conflict resolution attempt(s): ${retryMerge.error}`,\n819:       completed_at: new Date().toISOString(),\n820:     });\n821:     saveState(projectRoot, state);\n822:     cancelDownstream(state, agent.feature_id);\n823:     saveState(projectRoot, state);\n824:     return;\n825:   }\n826: }\n827: \n828: /**\n829:  * Handle retry of a failed agent (error-based, not build-based).\n830:  *\n831:  * If the agent has a session_id, resumes the existing session with error context.\n832:  * If the agent crashed before establishing a session (session_id is null),\n833:  * resets it to \"queued\" so it gets relaunched from scratch on the next\n834:  * launchAllReady() cycle. This prevents the \"stuck retry\" state where an\n835:  * agent sits in \"retry\" forever with no process running.\n836:  */\n837: export function handleRetry(\n838:   projectRoot: string,\n839:   state: WaveState,\n840:   agent: AgentState,\n841:   monitor: ProcessMonitor,\n842:   config: WomboConfig,\n843:   model?: string,\n844:   hitlMode?: string\n845: ): void {\n846:   if (!agent.session_id) {\n847:     // Agent crashed before establishing a session (e.g. SQLite race condition).\n848:     // Reset to queued so it gets a fresh launch on the next cycle.\n849:     wtLog(agent.feature_id, `no session — resetting to queued for fresh launch (retry ${agent.retries}/${agent.max_retries})`);\n850:     updateAgent(state, agent.feature_id, {\n851:       status: \"queued\",\n852:       error: null,\n853:       activity: \"waiting for relaunch...\",\n854:     });\n855:     saveState(projectRoot, state);\n856:     return;\n857:   }\n858: \n859:   if (!agent.error) return;\n860: \n861:   const retryResult = retryHeadless({\n862:     worktreePath: agent.worktree,\n863:     featureId: agent.feature_id,\n864:     sessionId: agent.session_id,\n865:     buildErrors: agent.error,\n866:     model,\n867:     config,\n868:     hitlMode,\n869:     projectRoot,\n870:   });\n871: \n872:   updateAgent(state, agent.feature_id, {\n873:     status: \"running\",\n874:     pid: retryResult.pid,\n875:   });\n876:   saveState(projectRoot, state);\n877: \n878:   monitor.addProcess(agent.feature_id, retryResult.process);\n879: }\n880: \n881: /**\n882:  * Launch the next queued agent if capacity allows.\n883:  * Dependency-aware: only launches agents whose dependencies are satisfied.\n884:  */\n885: export async function launchNextQueued(\n886:   projectRoot: string,\n887:   state: WaveState,\n888:   featureMap: Map<string, Feature>,\n889:   monitor: ProcessMonitor,\n890:   config: WomboConfig,\n891:   model?: string,\n892:   agentResolutions?: Map<string, AgentResolution>,\n893:   questContext?: QuestPromptContext,\n894:   hitlMode?: string\n895: ): Promise<void> {\n896:   const active = activeAgents(state);\n897:   const ready = readyToLaunchAgents(state);\n898: \n899:   if (active.length < state.max_concurrent && ready.length > 0) {\n900:     const next = ready[0];\n901:     const feature = featureMap.get(next.feature_id);\n902:     if (feature) {\n903:       await launchSingleHeadless(projectRoot, state, next, feature, monitor, config, model, agentResolutions, questContext, hitlMode);\n904:     }\n905:   }\n906: }\n907: \n908: /**\n909:  * Launch ALL ready agents up to capacity.\n910:  * After a dependency completes, multiple downstream agents may become unblocked.\n911:  * This launches as many as capacity allows, not just one.\n912:  *\n913:  * Launches are staggered to avoid SQLite race conditions.\n914:  *\n915:  * Also logs merge gate events when diamond-dependency features become unblocked.\n916:  */\n917: export async function launchAllReady(\n918:   projectRoot: string,\n919:   state: WaveState,\n920:   featureMap: Map<string, Feature>,\n921:   monitor: ProcessMonitor,\n922:   config: WomboConfig,\n923:   model?: string,\n924:   agentResolutions?: Map<string, AgentResolution>,\n925:   questContext?: QuestPromptContext,\n926:   hitlMode?: string\n927: ): Promise<void> {\n928:   const active = activeAgents(state);\n929:   const ready = readyToLaunchAgents(state);\n930:   const available = state.max_concurrent - active.length;\n931: \n932:   if (available <= 0 || ready.length === 0) return;\n933: \n934:   const toLaunch = ready.slice(0, available);\n935:   for (let i = 0; i < toLaunch.length; i++) {\n936:     const next = toLaunch[i];\n937:     const feature = featureMap.get(next.feature_id);\n938:     if (!feature) continue;\n939: \n940:     // Log merge gate opening for diamond dependencies\n941:     if (next.depends_on.length > 1 && state.schedule_plan) {\n942:       const isMergeGate = state.schedule_plan.merge_gates.some(\n943:         (g) => g.feature_id === next.feature_id\n944:       );\n945:       if (isMergeGate) {\n946:         wtLog(\n947:           next.feature_id,\n948:           `merge gate opened — all ${next.depends_on.length} dependencies satisfied`\n949:         );\n950:       }\n951:     }\n952: \n953:     await launchSingleHeadless(projectRoot, state, next, feature, monitor, config, model, agentResolutions, questContext, hitlMode);\n954:     // Stagger between launches to avoid SQLite race conditions\n955:     if (i < toLaunch.length - 1) {\n956:       await new Promise((r) => setTimeout(r, LAUNCH_STAGGER_MS));\n957:     }\n958:   }\n959: }\n960: \n961: // ---------------------------------------------------------------------------\n962: // Post-mortem: dump failed agent logs\n963: // ---------------------------------------------------------------------------\n964: \n965: /**\n966:  * Print full log contents for every failed agent so the user can diagnose\n967:  * issues after the wave finishes. Handles missing log files gracefully.\n968:  *\n969:  * In JSON/TOON mode, this function is a no-op — callers should emit\n970:  * structured failure data through the output() helper instead.\n971:  *\n972:  * @param fmt - Output format. Only prints when \"text\".\n973:  */\n974: export function dumpFailedAgentLogs(projectRoot: string, state: WaveState, fmt: OutputFormat = \"text\"): void {\n975:   if (fmt !== \"text\") return; // suppress in JSON/TOON mode\n976: \n977:   const failed = state.agents.filter((a) => a.status === \"failed\");\n978:   if (failed.length === 0) return;\n979: \n980:   const logDir = resolve(projectRoot, \".wombo-combo/logs\");\n981: \n982:   console.log(\n983:     `\\n${\"=\".repeat(72)}\\n` +\n984:     `  FAILED AGENT LOGS (${failed.length} agent${failed.length > 1 ? \"s\" : \"\"})\\n` +\n985:     `${\"=\".repeat(72)}`\n986:   );\n987: \n988:   for (const agent of failed) {\n989:     const logFile = resolve(logDir, `${agent.feature_id}.log`);\n990: \n991:     console.log(\n992:       `\\n${\"─\".repeat(72)}\\n` +\n993:       `  Feature: ${agent.feature_id}\\n` +\n994:       (agent.error ? `  Error:   ${agent.error}\\n` : \"\") +\n995:       `${\"─\".repeat(72)}`\n996:     );\n997: \n998:     if (!existsSync(logFile)) {\n999:       console.log(\"  (no log file found)\");\n1000:       continue;\n1001:     }\n1002: \n1003:     try {\n1004:       const contents = readFileSync(logFile, \"utf-8\");\n1005:       if (contents.trim().length === 0) {\n1006:         console.log(\"  (log file is empty)\");\n1007:       } else {\n1008:         console.log(contents);\n1009:       }\n1010:     } catch (err: any) {\n1011:       console.log(`  (error reading log: ${err.message})`);\n1012:     }\n1013:   }\n1014: \n1015:   console.log(`\\n${\"=\".repeat(72)}\\n`);\n1016: }\n1017: \n1018: // ---------------------------------------------------------------------------\n1019: // Headless Wave Launch\n1020: // ---------------------------------------------------------------------------\n1021: \n1022: async function launchWaveHeadless(\n1023:   projectRoot: string,\n1024:   state: WaveState,\n1025:   features: Feature[],\n1026:   opts: LaunchCommandOptions,\n1027:   agentResolutions?: Map<string, AgentResolution>,\n1028:   questContext?: QuestPromptContext,\n1029:   hitlMode?: string\n1030: ): Promise<void> {\n1031:   const { config, model } = opts;\n1032:   const fmt = opts.outputFmt ?? \"text\";\n1033:   const featureMap = new Map(features.map((f) => [f.id, f]));\n1034: \n1035:   const monitor = new ProcessMonitor(projectRoot, {\n1036:     onSessionId: (featureId, sessionId) => {\n1037:       updateAgent(state, featureId, { session_id: sessionId });\n1038:       saveState(projectRoot, state);\n1039:     },\n1040:     onComplete: (featureId) => {\n1041:       updateAgent(state, featureId, {\n1042:         status: \"completed\",\n1043:         completed_at: new Date().toISOString(),\n1044:       });\n1045:       saveState(projectRoot, state);\n1046: \n1047:       // Run build verification — fire-and-forget\n1048:       const agent = state.agents.find((a) => a.feature_id === featureId)!;\n1049:       handleBuildVerification(projectRoot, state, agent, featureMap.get(featureId)!, config, model, monitor, undefined, hitlMode)\n1050:         .then(() => {\n1051:           // After verification/merge, try to launch dependency-ready agents\n1052:           // Multiple queued agents may now be unblocked\n1053:           launchAllReady(projectRoot, state, featureMap, monitor, config, model, agentResolutions, questContext, hitlMode)\n1054:             .catch((err) => wtLog(featureId, `LAUNCH ERROR: ${err.message}`));\n1055:         })\n1056:         .catch((err) => {\n1057:           wtLog(featureId, `BUILD VERIFICATION UNHANDLED ERROR: ${err.message}`);\n1058:           launchAllReady(projectRoot, state, featureMap, monitor, config, model, agentResolutions, questContext, hitlMode)\n1059:             .catch((err2) => wtLog(featureId, `LAUNCH ERROR: ${err2.message}`));\n1060:         });\n1061:     },\n1062:     onError: (featureId, error) => {\n1063:       const agent = state.agents.find((a) => a.feature_id === featureId)!;\n1064:       if (agent.retries < agent.max_retries) {\n1065:         updateAgent(state, featureId, {\n1066:           status: \"retry\",\n1067:           retries: agent.retries + 1,\n1068:           error,\n1069:         });\n1070:         saveState(projectRoot, state);\n1071: \n1072:         // Retry\n1073:         handleRetry(projectRoot, state, agent, monitor, config, model, hitlMode);\n1074:       } else {\n1075:         updateAgent(state, featureId, {\n1076:           status: \"failed\",\n1077:           error,\n1078:           completed_at: new Date().toISOString(),\n1079:         });\n1080:         saveState(projectRoot, state);\n1081: \n1082:         // Cascade failure to downstream agents\n1083:         const cancelled = cancelDownstream(state, featureId);\n1084:         if (cancelled.length > 0) {\n1085:           wtLog(featureId, `downstream cancelled: ${cancelled.join(\", \")}`);\n1086:           saveState(projectRoot, state);\n1087:         }\n1088:       }\n1089: \n1090:       // Try to launch dependency-ready agents\n1091:       launchAllReady(projectRoot, state, featureMap, monitor, config, model, agentResolutions, questContext, hitlMode)\n1092:         .catch((err) => wtLog(featureId, `LAUNCH ERROR: ${err.message}`));\n1093:     },\n1094:     onOutput: (_featureId, _data) => {\n1095:       // Raw output — logged to file by ProcessMonitor\n1096:     },\n1097:     onActivity: (featureId, activity) => {\n1098:       updateAgent(state, featureId, {\n1099:         activity,\n1100:         activity_updated_at: new Date().toISOString(),\n1101:       });\n1102:       // Don't save to disk on every activity — too frequent.\n1103:     },\n1104:   });\n1105: \n1106:   // Create the TUI — it will auto-refresh and show activity from the monitor\n1107:   const tuiRef = { current: null as WomboTUI | null };\n1108:   const startTUI = () => {\n1109:     tuiRef.current = new WomboTUI({\n1110:       state,\n1111:       monitor,\n1112:       projectRoot,\n1113:       interactive: false,\n1114:       config,\n1115:       onQuit: () => {\n1116:         // Same as SIGINT — save state and exit\n1117:         for (const agent of state.agents) {\n1118:           if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n1119:             updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n1120:           }\n1121:         }\n1122:         monitor.killAll();\n1123:         saveState(projectRoot, state);\n1124:         if (fmt === \"text\") console.log(\"State saved. Use 'woco resume' to continue.\");\n1125:         process.exit(0);\n1126:       },\n1127:       onRetry: (featureId: string) => {\n1128:         const agent = state.agents.find((a) => a.feature_id === featureId);\n1129:         if (!agent) return;\n1130:         if (agent.status !== \"failed\" && agent.status !== \"retry\") return;\n1131: \n1132:         // Reset retries if exhausted, give it one more shot\n1133:         if (agent.retries >= agent.max_retries) {\n1134:           updateAgent(state, featureId, { max_retries: agent.retries + 1 });\n1135:         }\n1136: \n1137:         wtLog(featureId, `manual retry requested from TUI — resetting to queued`);\n1138:         updateAgent(state, featureId, {\n1139:           status: \"queued\",\n1140:           error: null,\n1141:           activity: \"waiting for relaunch (manual retry)...\",\n1142:         });\n1143:         saveState(projectRoot, state);\n1144:         // The polling loop will call launchAllReady() and pick this up\n1145:       },\n1146:       onAnswer: (agentId: string, questionId: string, answerText: string) => {\n1147:         try {\n1148:           submitAnswer(projectRoot, agentId, questionId, answerText);\n1149:           wtLog(agentId, `HITL answer submitted: \"${answerText.slice(0, 80)}${answerText.length > 80 ? \"...\" : \"\"}\"`);\n1150:         } catch (err: any) {\n1151:           wtLog(agentId, `HITL answer error: ${err.message}`);\n1152:         }\n1153:       },\n1154:     });\n1155:     tuiRef.current.start();\n1156:   };\n1157: \n1158:   // Handle graceful shutdown\n1159:   process.on(\"SIGINT\", () => {\n1160:     if (tuiRef.current) tuiRef.current.stop();\n1161:     for (const agent of state.agents) {\n1162:       if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n1163:         updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n1164:       }\n1165:     }\n1166:     monitor.killAll();\n1167:     saveState(projectRoot, state);\n1168:     if (fmt === \"text\") console.log(\"\\nState saved. Use 'woco resume' to continue.\");\n1169:     process.exit(0);\n1170:   });\n1171: \n1172:   // Launch initial batch — only agents whose dependencies are already satisfied\n1173:   // Stagger launches to avoid SQLite race conditions in agent processes:\n1174:   // each agent spawns its own DB, and simultaneous CREATE TABLE calls collide.\n1175:   const ready = readyToLaunchAgents(state);\n1176:   const tolaunch = ready.slice(0, opts.maxConcurrent);\n1177:   if (fmt === \"text\") console.log(`Setting up ${tolaunch.length} agent(s) (staggered)...\\n`);\n1178: \n1179:   for (let i = 0; i < tolaunch.length; i++) {\n1180:     await launchSingleHeadless(\n1181:       projectRoot,\n1182:       state,\n1183:       tolaunch[i],\n1184:       featureMap.get(tolaunch[i].feature_id)!,\n1185:       monitor,\n1186:       config,\n1187:       model,\n1188:       agentResolutions,\n1189:       questContext,\n1190:       hitlMode\n1191:     );\n1192:     // Brief delay between spawns so each agent's DB migration settles\n1193:     if (i < tolaunch.length - 1) {\n1194:       await new Promise((r) => setTimeout(r, LAUNCH_STAGGER_MS));\n1195:     }\n1196:   }\n1197: \n1198:   const launched = state.agents.filter((a) => a.status === \"running\").length;\n1199: \n1200:   // Start the TUI dashboard (or skip if --no-tui)\n1201:   if (opts.noTui) {\n1202:     if (fmt === \"text\") {\n1203:       console.log(`${launched} agent(s) running. (--no-tui mode, dashboard prints every 15s)\\n`);\n1204:       printDashboard(state);\n1205:     }\n1206:   } else {\n1207:     if (fmt === \"text\") console.log(`${launched} agent(s) running. Launching TUI...\\n`);\n1208:     startTUI();\n1209:   }\n1210: \n1211:   // Background monitoring loop — checks for dead processes and launches queued\n1212:   const POLL_INTERVAL = 5000;\n1213:   let dashboardCounter = 0;\n1214:   while (!isWaveComplete(state)) {\n1215:     await new Promise((r) => setTimeout(r, POLL_INTERVAL));\n1216: \n1217:     // Check for completed processes that weren't caught by event handlers\n1218:     for (const agent of state.agents) {\n1219:       if (\n1220:         (agent.status === \"running\" || agent.status === \"resolving_conflict\") &&\n1221:         agent.pid &&\n1222:         !isProcessRunning(agent.pid) &&\n1223:         !monitor.isRunning(agent.feature_id)\n1224:       ) {\n1225:         if (agent.status === \"resolving_conflict\") {\n1226:           // Conflict resolver died — the await in handleBuildVerification\n1227:           // will resolve via the 'exit' event, so nothing to do here\n1228:           continue;\n1229:         }\n1230:         // Process exited but we didn't get a callback\n1231:         // Check if the agent actually made any commits\n1232:         if (!branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n1233:           // Agent died without producing any code — mark as failed, not completed\n1234:           updateAgent(state, agent.feature_id, {\n1235:             status: \"failed\",\n1236:             error: \"Agent process exited without making any commits\",\n1237:             activity: null,\n1238:             completed_at: new Date().toISOString(),\n1239:           });\n1240:           saveState(projectRoot, state);\n1241:           wtLog(agent.feature_id, \"process died with no code changes — marked failed\");\n1242: \n1243:           // Cascade failure to downstream agents\n1244:           const cancelled = cancelDownstream(state, agent.feature_id);\n1245:           if (cancelled.length > 0) {\n1246:             wtLog(agent.feature_id, `downstream cancelled: ${cancelled.join(\", \")}`);\n1247:             saveState(projectRoot, state);\n1248:           }\n1249:         } else {\n1250:           updateAgent(state, agent.feature_id, {\n1251:             status: \"completed\",\n1252:             completed_at: new Date().toISOString(),\n1253:             activity: \"done\",\n1254:           });\n1255:           saveState(projectRoot, state);\n1256:           try {\n1257:             await handleBuildVerification(projectRoot, state, agent, featureMap.get(agent.feature_id)!, config, model, monitor, undefined, hitlMode);\n1258:           } catch (err: any) {\n1259:             wtLog(agent.feature_id, `POLL VERIFY ERROR: ${err.message}`);\n1260:           }\n1261:         }\n1262:         await launchAllReady(projectRoot, state, featureMap, monitor, config, model, agentResolutions, questContext, hitlMode);\n1263:       }\n1264:     }\n1265: \n1266:     // Safety net: detect agents stuck in \"retry\" with no running process.\n1267:     // This catches edge cases where handleRetry() wasn't called or failed\n1268:     // to reset the agent (e.g. race between onError callback and poll loop).\n1269:     for (const agent of state.agents) {\n1270:       if (\n1271:         agent.status === \"retry\" &&\n1272:         (!agent.pid || !isProcessRunning(agent.pid)) &&\n1273:         !monitor.isRunning(agent.feature_id)\n1274:       ) {\n1275:         if (agent.retries >= agent.max_retries) {\n1276:           // Out of retries — mark as failed and cascade\n1277:           wtLog(agent.feature_id, `stuck in retry with no process and retries exhausted (${agent.retries}/${agent.max_retries}) — marking failed`);\n1278:           updateAgent(state, agent.feature_id, {\n1279:             status: \"failed\",\n1280:             error: agent.error ?? \"Agent stuck in retry state with no running process\",\n1281:             activity: null,\n1282:             completed_at: new Date().toISOString(),\n1283:           });\n1284:           saveState(projectRoot, state);\n1285:           const cancelled = cancelDownstream(state, agent.feature_id);\n1286:           if (cancelled.length > 0) {\n1287:             wtLog(agent.feature_id, `downstream cancelled: ${cancelled.join(\", \")}`);\n1288:             saveState(projectRoot, state);\n1289:           }\n1290:         } else {\n1291:           // Has retries left — reset to queued for a fresh launch\n1292:           wtLog(agent.feature_id, `stuck in retry with no process — resetting to queued (retry ${agent.retries}/${agent.max_retries})`);\n1293:           updateAgent(state, agent.feature_id, {\n1294:             status: \"queued\",\n1295:             error: null,\n1296:             activity: \"waiting for relaunch...\",\n1297:           });\n1298:           saveState(projectRoot, state);\n1299:         }\n1300:       }\n1301:     }\n1302: \n1303:     // After recovering stuck agents, try launching any that are now ready\n1304:     await launchAllReady(projectRoot, state, featureMap, monitor, config, model, agentResolutions, questContext, hitlMode);\n1305: \n1306:     // Persist state periodically\n1307:     saveState(projectRoot, state);\n1308: \n1309:     // Poll for HITL questions from agents and forward to TUI\n1310:     if (hitlMode && hitlMode !== \"yolo\") {\n1311:       try {\n1312:         const pendingQuestions = getPendingQuestions(projectRoot);\n1313:         if (tuiRef.current && pendingQuestions.length > 0) {\n1314:           tuiRef.current.setPendingQuestions(pendingQuestions);\n1315:         }\n1316:       } catch {\n1317:         // Non-fatal — HITL dir may not exist yet\n1318:       }\n1319:     }\n1320: \n1321:     // Update TUI state reference (or print dashboard in --no-tui mode)\n1322:     if (tuiRef.current) {\n1323:       tuiRef.current.updateState(state);\n1324:     } else if (opts.noTui && fmt === \"text\") {\n1325:       dashboardCounter++;\n1326:       if (dashboardCounter % 3 === 0) {\n1327:         printDashboard(state);\n1328: \n1329:         // Auto-push base branch if requested\n1330:         if (opts.autoPush) {\n1331:           const anyMerged = state.agents.some((a) => a.status === \"merged\");\n1332:           if (anyMerged) {\n1333:             await pushBaseBranch(projectRoot, state.base_branch, config);\n1334:           } else {\n1335:             console.log(\"No branches were merged — skipping push.\");\n1336:           }\n1337:         }\n1338:       }\n1339:     }\n1340:   }\n1341: \n1342:   // Wave complete — keep TUI open for post-mortem browsing\n1343:   if (tuiRef.current) {\n1344:     tuiRef.current.updateState(state);\n1345:     tuiRef.current.markWaveComplete();\n1346:     // Wait for the user to press q to exit the TUI\n1347:     await tuiRef.current.waitForQuit();\n1348:   }\n1349: \n1350:   // Print final dashboard after TUI is closed\n1351:   if (fmt === \"text\") printDashboard(state);\n1352: \n1353:   // Clean up HITL files\n1354:   try {\n1355:     cleanupHitl(projectRoot);\n1356:   } catch {\n1357:     // Non-fatal\n1358:   }\n1359: \n1360:   // Dump full logs for failed agents (post-mortem)\n1361:   dumpFailedAgentLogs(projectRoot, state, fmt);\n1362: \n1363:   // Auto-export wave history\n1364:   try {\n1365:     const historyPath = exportWaveHistory(projectRoot, state);\n1366:     if (fmt === \"text\") console.log(`Wave history exported to ${historyPath}`);\n1367:   } catch (err: any) {\n1368:     if (fmt === \"text\") console.error(`Warning: failed to export wave history: ${err.message}`);\n1369:   }\n1370: \n1371:   // Auto-push base branch if requested\n1372:   if (opts.autoPush) {\n1373:     await pushBaseBranch(projectRoot, state.base_branch, config);\n1374:   }\n1375: \n1376:   // Completion double-check: verify worktrees directory is empty\n1377:   if (fmt === \"text\") {\n1378:     if (isWorktreesDirEmpty(projectRoot)) {\n1379:       console.log(\"All worktrees cleaned up — worktrees directory is empty.\");\n1380:     } else {\n1381:       console.log(\"\\x1b[33mNote:\\x1b[0m worktrees directory still has contents. Run 'woco cleanup' to clean up.\");\n1382:     }\n1383: \n1384:     console.log(\"Wave complete.\");\n1385:   }\n1386: }\n1387: \n1388: // ---------------------------------------------------------------------------\n1389: // Interactive Wave Launch\n1390: // ---------------------------------------------------------------------------\n1391: \n1392: async function launchWaveInteractive(\n1393:   projectRoot: string,\n1394:   state: WaveState,\n1395:   features: Feature[],\n1396:   opts: LaunchCommandOptions,\n1397:   agentResolutions?: Map<string, AgentResolution>,\n1398:   questContext?: QuestPromptContext,\n1399:   hitlMode?: string\n1400: ): Promise<void> {\n1401:   const { config, model } = opts;\n1402:   const fmt = opts.outputFmt ?? \"text\";\n1403:   const featureMap = new Map(features.map((f) => [f.id, f]));\n1404: \n1405:   // Show dashboard immediately\n1406:   if (fmt === \"text\") printDashboard(state);\n1407: \n1408:   // Launch initial batch — parallelize setup\n1409:   const tolaunch = queuedAgents(state).slice(0, opts.maxConcurrent);\n1410:   if (fmt === \"text\") console.log(`Setting up ${tolaunch.length} agent(s) in parallel...\\n`);\n1411: \n1412:   await Promise.all(\n1413:     tolaunch.map(async (agent) => {\n1414:       updateAgent(state, agent.feature_id, {\n1415:         status: \"installing\",\n1416:         started_at: new Date().toISOString(),\n1417:         activity: \"setting up worktree...\",\n1418:       });\n1419:       saveState(projectRoot, state);\n1420: \n1421:       try {\n1422:         if (worktreeReady(agent.worktree)) {\n1423:           wtLog(agent.feature_id, \"worktree already exists, skipping setup\");\n1424:         } else {\n1425:           await createWorktree(projectRoot, agent.feature_id, state.base_branch, config);\n1426:           updateAgent(state, agent.feature_id, { activity: \"installing deps...\" });\n1427:           await installDeps(agent.worktree, agent.feature_id, config);\n1428:         }\n1429: \n1430:         const prompt = generatePrompt(\n1431:           featureMap.get(agent.feature_id)!,\n1432:           state.base_branch,\n1433:           config,\n1434:           questContext,\n1435:           hitlMode as QuestHitlMode | undefined\n1436:         );\n1437: \n1438:         // Write specialized agent to worktree if applicable\n1439:         const resolution = agentResolutions?.get(agent.feature_id);\n1440:         const agentName = agent.agent_name ?? undefined;\n1441:         if (resolution && isSpecializedAgent(resolution)) {\n\n(Output capped at 50 KB. Showing lines 1-1441. Use offset=1442 to continue.)\n</content>","title":"src/commands/launch.ts","metadata":{"preview":"/**\n * launch.ts — Launch a wave of agents.\n *\n * Usage: woco launch [selection options] [launch options]\n *\n * This is the primary entry point for starting a new wave. It selects features\n * from the features file, creates a wave state, sets up worktrees, and launches\n * agent processes (either headless or interactive via dmux/tmux).\n *\n * IMPORTANT: This file also exports shared helper functions that are reused\n * by resume.ts and other commands:\n *   - launchSingleHeadless\n *   - handleBuildVerification\n *   - handleRetry\n *   - launchNextQueued\n */\n\nimport { execSync } from \"node:child_process\";\nimport { existsSync, readFileSync } from \"node:fs\";\nimport { resolve } from \"node:path\";","truncated":true,"loaded":[]},"time":{"start":1773481727895,"end":1773481727902}}}}
