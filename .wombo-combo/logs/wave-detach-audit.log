{"type":"tool_use","timestamp":1773481740989,"sessionID":"ses_3144093abffe4EFLXWMouX7qVB","part":{"id":"prt_cebbfc8b2001Pj9d3Pri2dAmH4","sessionID":"ses_3144093abffe4EFLXWMouX7qVB","messageID":"msg_cebbfb751001HPxGiWxXAwyuhE","type":"tool","callID":"toolu_vrtx_01L9sU6fMnZcyD4fi8Ry4Pzb","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/wave-detach-audit/src/commands/cleanup.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/wave-detach-audit/src/commands/cleanup.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * cleanup.ts — Remove all wave-related resources.\n3:  *\n4:  * Usage: woco cleanup\n5:  *\n6:  * Kills multiplexer sessions (dmux/tmux), removes worktrees, removes state and log files.\n7:  *\n8:  * NOTE: .wombo-combo/history/ is intentionally NOT removed by cleanup.\n9:  * Wave history records are meant to survive cleanup for retrospective\n10:  * analysis. See src/lib/history.ts.\n11:  */\n12: \n13: import { existsSync, unlinkSync, rmSync } from \"node:fs\";\n14: import { execSync } from \"node:child_process\";\n15: import { resolve } from \"node:path\";\n16: import type { WomboConfig } from \"../config.js\";\n17: import { WOMBO_DIR } from \"../config.js\";\n18: import { killAllMuxSessions, getMultiplexerName } from \"../lib/launcher.js\";\n19: import { cleanupAllWorktrees, listWomboWorktrees, worktreesDir, isWorktreesDirEmpty } from \"../lib/worktree.js\";\n20: import {\n21:   detectMultiplexer,\n22:   muxListSessions,\n23: } from \"../lib/multiplexer.js\";\n24: import { output, outputMessage, type OutputFormat } from \"../lib/output.js\";\n25: import { renderCleanup } from \"../lib/toon.js\";\n26: \n27: export interface CleanupOptions {\n28:   projectRoot: string;\n29:   config: WomboConfig;\n30:   dryRun?: boolean;\n31:   outputFmt?: OutputFormat;\n32: }\n33: \n34: export async function cmdCleanup(opts: CleanupOptions): Promise<void> {\n35:   const { projectRoot, config } = opts;\n36:   const fmt = opts.outputFmt ?? \"text\";\n37: \n38:   // Dry-run: show what would be cleaned up without doing it\n39:   if (opts.dryRun) {\n40:     // List multiplexer sessions that would be killed\n41:     const muxName = getMultiplexerName(config);\n42:     let matchingSessions: string[] = [];\n43:     try {\n44:       const mux = detectMultiplexer(config.agent.multiplexer);\n45:       const sessions = muxListSessions(mux);\n46:       const prefix = config.agent.tmuxPrefix;\n47:       matchingSessions = sessions.filter((s) => s.startsWith(prefix));\n48:     } catch {\n49:       // no mux server running\n50:     }\n51: \n52:     // List worktrees that would be removed (using safe filtering)\n53:     let matchingWorktrees: { path: string }[] = [];\n54:     try {\n55:       matchingWorktrees = listWomboWorktrees(projectRoot, config);\n56:     } catch {\n57:       // no worktrees\n58:     }\n59: \n60:     const statePath = resolve(projectRoot, WOMBO_DIR, \"state.json\");\n61:     const logDir = resolve(projectRoot, WOMBO_DIR, \"logs\");\n62:     const filesToRemove: string[] = [];\n63:     if (existsSync(statePath)) filesToRemove.push(\".wombo-combo/state.json\");\n64:     if (existsSync(logDir)) filesToRemove.push(\".wombo-combo/logs/\");\n65: \n66:     const dryRunResult = {\n67:       dry_run: true,\n68:       mux_sessions: matchingSessions,\n69:       mux_sessions_count: matchingSessions.length,\n70:       worktrees: matchingWorktrees.map((wt) => wt.path),\n71:       worktrees_count: matchingWorktrees.length,\n72:       worktrees_dir: worktreesDir(projectRoot),\n73:       files_to_remove: filesToRemove,\n74:     };\n75: \n76:     output(fmt, dryRunResult, () => {\n77:       console.log(\"\\n[dry-run] Would perform the following cleanup:\\n\");\n78:       console.log(`  ${muxName} sessions to kill: ${matchingSessions.length}`);\n79:       for (const s of matchingSessions) {\n80:         console.log(`    ${s}`);\n81:       }\n82:       console.log(`  worktrees to remove: ${matchingWorktrees.length}`);\n83:       for (const wt of matchingWorktrees) {\n84:         console.log(`    ${wt.path}`);\n85:       }\n86:       console.log(`  worktrees dir: ${worktreesDir(projectRoot)}`);\n87:       for (const f of filesToRemove) {\n88:         console.log(`  Would remove: ${f}`);\n89:       }\n90:     }, () => {\n91:       console.log(renderCleanup(dryRunResult));\n92:     });\n93: \n94:     return;\n95:   }\n96: \n97:   // Kill multiplexer sessions\n98:   const muxName = getMultiplexerName(config);\n99:   const killed = killAllMuxSessions(config);\n100: \n101:   // Remove worktrees\n102:   const removed = cleanupAllWorktrees(projectRoot, config);\n103: \n104:   // List remaining feature branches\n105:   let remainingBranches: string[] = [];\n106:   try {\n107:     const branchPattern = `\"${config.git.branchPrefix}*\"`;\n108:     const branchesRaw = execSync(`git branch --list ${branchPattern}`, {\n109:       cwd: projectRoot,\n110:       encoding: \"utf-8\",\n111:     }).trim();\n112:     if (branchesRaw) {\n113:       remainingBranches = branchesRaw.split(\"\\n\").map((b) => b.trim());\n114:     }\n115:   } catch {}\n116: \n117:   // Remove state file\n118:   const statePath = resolve(projectRoot, WOMBO_DIR, \"state.json\");\n119:   const stateRemoved = existsSync(statePath);\n120:   if (stateRemoved) {\n121:     unlinkSync(statePath);\n122:   }\n123: \n124:   // Remove log directory\n125:   const logDir = resolve(projectRoot, WOMBO_DIR, \"logs\");\n126:   const logsRemoved = existsSync(logDir);\n127:   if (logsRemoved) {\n128:     rmSync(logDir, { recursive: true, force: true });\n129:   }\n130: \n131:   // Check if history is preserved\n132:   const historyDir = resolve(projectRoot, WOMBO_DIR, \"history\");\n133:   const historyPreserved = existsSync(historyDir);\n134: \n135:   // Check if the worktrees directory is now empty (completion double-check)\n136:   const wtDirEmpty = isWorktreesDirEmpty(projectRoot);\n137:   const wtDirPath = worktreesDir(projectRoot);\n138: \n139:   const result = {\n140:     mux_sessions_killed: killed,\n141:     worktrees_removed: removed,\n142:     worktrees_dir: wtDirPath,\n143:     worktrees_dir_empty: wtDirEmpty,\n144:     state_removed: stateRemoved,\n145:     logs_removed: logsRemoved,\n146:     remaining_branches: remainingBranches,\n147:     history_preserved: historyPreserved,\n148:   };\n149: \n150:   output(fmt, result, () => {\n151:     console.log(\"\\n--- wombo-combo: Cleanup ---\\n\");\n152:     console.log(`Killed ${killed} ${muxName} session(s)`);\n153:     console.log(`Removed ${removed} worktree(s)`);\n154: \n155:     if (wtDirEmpty) {\n156:       console.log(`Worktrees directory is clean: ${wtDirPath}`);\n157:     } else {\n158:       console.log(`\\x1b[33mWorktrees directory still has contents:\\x1b[0m ${wtDirPath}`);\n159:     }\n160: \n161:     if (remainingBranches.length > 0) {\n162:       console.log(`\\nRemaining feature branches:\\n${remainingBranches.map((b) => `  ${b}`).join(\"\\n\")}`);\n163:       console.log('Use \"git branch -D <branch>\" to remove manually.');\n164:     }\n165: \n166:     if (stateRemoved) console.log(\"Removed .wombo-combo/state.json\");\n167:     if (logsRemoved) console.log(\"Removed .wombo-combo/logs/\");\n168: \n169:     console.log(\"\\nCleanup complete.\");\n170: \n171:     if (historyPreserved) {\n172:       console.log(\"Note: .wombo-combo/history/ is preserved. Use 'woco history' to view past waves.\");\n173:     }\n174:   }, () => {\n175:     console.log(renderCleanup(result));\n176:   });\n177: }\n\n(End of file - total 177 lines)\n</content>","title":"src/commands/cleanup.ts","metadata":{"preview":"/**\n * cleanup.ts — Remove all wave-related resources.\n *\n * Usage: woco cleanup\n *\n * Kills multiplexer sessions (dmux/tmux), removes worktrees, removes state and log files.\n *\n * NOTE: .wombo-combo/history/ is intentionally NOT removed by cleanup.\n * Wave history records are meant to survive cleanup for retrospective\n * analysis. See src/lib/history.ts.\n */\n\nimport { existsSync, unlinkSync, rmSync } from \"node:fs\";\nimport { execSync } from \"node:child_process\";\nimport { resolve } from \"node:path\";\nimport type { WomboConfig } from \"../config.js\";\nimport { WOMBO_DIR } from \"../config.js\";\nimport { killAllMuxSessions, getMultiplexerName } from \"../lib/launcher.js\";\nimport { cleanupAllWorktrees, listWomboWorktrees, worktreesDir, isWorktreesDirEmpty } from \"../lib/worktree.js\";\nimport {","truncated":false,"loaded":[]},"time":{"start":1773481740986,"end":1773481740988}}}}
