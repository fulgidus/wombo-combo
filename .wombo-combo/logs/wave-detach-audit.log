{"type":"tool_use","timestamp":1773483367855,"sessionID":"ses_31427856effefwaC38OEq6YCmn","part":{"id":"prt_cebd89a14001KVwcZpk81H42zz","sessionID":"ses_31427856effefwaC38OEq6YCmn","messageID":"msg_cebd8906f001zEOTbtSrmRjWDQ","type":"tool","callID":"toolu_vrtx_01V8SYBTo2vZgAtg8ysa7URc","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/wave-detach-audit/src/lib/launcher.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/wave-detach-audit/src/lib/launcher.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * launcher.ts — Process spawning and terminal multiplexer session management.\n3:  *\n4:  * Responsibilities:\n5:  *   - Launch agent in headless mode (agent run --format json)\n6:  *   - Launch agent in interactive mode (dmux/tmux session with TUI)\n7:  *   - Resume sessions for auto-retry\n8:  *   - Manage multiplexer sessions (create, list, kill)\n9:  *\n10:  * Supports both dmux (preferred) and tmux (fallback) via the multiplexer\n11:  * abstraction layer. The active backend is determined by config.agent.multiplexer.\n12:  *\n13:  * ## Agent Process Lifecycle (audit: wave-detach-audit)\n14:  *\n15:  * **Headless mode** (`launchHeadless`, `retryHeadless`, `launchConflictResolver`):\n16:  *   - Agents are spawned with `detached: false` — they are child processes of\n17:  *     the wombo parent and will be terminated when the parent exits.\n18:  *   - `unref()` is NOT called — the child holds the parent's event loop alive,\n19:  *     which is required for the ProcessMonitor to receive stdout/stderr events.\n20:  *   - `stdio` is `[\"pipe\", \"pipe\", \"pipe\"]` — stdout is piped for JSON event\n21:  *     parsing by ProcessMonitor. This further ties the child to the parent.\n22:  *   - **Consequence**: If the parent is killed (SIGKILL, crash, OOM), headless\n23:  *     agents die immediately with no state saved. The SIGINT/SIGTERM handlers\n24:  *     in launch.ts and resume.ts mitigate this for graceful shutdowns by\n25:  *     calling `monitor.killAll()` and `saveState()` before exiting.\n26:  *   - **Recovery**: `woco resume` detects dead-but-productive agents (worktree\n27:  *     exists with commits) and runs build verification on their output, or\n28:  *     re-launches agents that died without producing code.\n29:  *\n30:  * **Interactive mode** (`launchInteractive`):\n31:  *   - Agents run inside dmux/tmux sessions, which are independent of the\n32:  *     parent process. They survive parent death naturally.\n33:  *   - The `process` field in LaunchResult is `null as any` — no direct\n34:  *     ChildProcess handle exists. PID is obtained via `muxGetPanePid()`.\n35:  *\n36:  * **Design rationale for `detached: false`**:\n37:  *   Headless agents MUST have their stdout piped to the parent for real-time\n38:  *   JSON event parsing (session ID extraction, completion detection, activity\n39:  *   tracking). Using `detached: true` + `unref()` would allow agents to\n40:  *   outlive the parent, but the piped stdio streams would break when the\n41:  *   parent exits, potentially causing agent crashes or lost output. The\n42:  *   current design trades survivability for reliable monitoring. If agent\n43:  *   persistence across parent restarts is needed, the interactive (mux)\n44:  *   mode should be used instead.\n45:  */\n46: \n47: import { spawn, execSync, type ChildProcess } from \"node:child_process\";\n48: import { writeFileSync, unlinkSync } from \"node:fs\";\n49: import type { WomboConfig } from \"../config.js\";\n50: import { resolveAgentBin } from \"../config.js\";\n51: import {\n52:   detectMultiplexer,\n53:   muxNewSession,\n54:   muxHasSession,\n55:   muxKillSession,\n56:   muxListSessions,\n57:   muxGetPanePid,\n58:   muxLoadBuffer,\n59:   muxPasteBuffer,\n60:   muxSendKeys,\n61:   muxDisplayName,\n62:   type MultiplexerInfo,\n63: } from \"./multiplexer.js\";\n64: import { portlessEnv } from \"./portless.js\";\n65: import { hitlDir } from \"./hitl-channel.js\";\n66: import { resolve, dirname } from \"node:path\";\n67: \n68: // ---------------------------------------------------------------------------\n69: // Types\n70: // ---------------------------------------------------------------------------\n71: \n72: export interface LaunchResult {\n73:   pid: number;\n74:   process: ChildProcess;\n75:   sessionId?: string;\n76: }\n77: \n78: export interface LaunchOptions {\n79:   worktreePath: string;\n80:   featureId: string;\n81:   prompt: string;\n82:   model?: string;\n83:   interactive?: boolean;\n84:   config: WomboConfig;\n85:   /** Override the agent name (for specialized agents from the registry) */\n86:   agentName?: string;\n87:   /** HITL mode for this agent (from quest or config) */\n88:   hitlMode?: string;\n89:   /** Project root (for HITL directory path) */\n90:   projectRoot?: string;\n91: }\n92: \n93: export interface RetryOptions {\n94:   worktreePath: string;\n95:   featureId: string;\n96:   sessionId: string;\n97:   buildErrors: string;\n98:   model?: string;\n99:   interactive?: boolean;\n100:   config: WomboConfig;\n101:   /** HITL mode for this agent (from quest or config) */\n102:   hitlMode?: string;\n103:   /** Project root (for HITL directory path) */\n104:   projectRoot?: string;\n105: }\n106: \n107: // ---------------------------------------------------------------------------\n108: // Helpers\n109: // ---------------------------------------------------------------------------\n110: \n111: function muxSessionName(featureId: string, config: WomboConfig): string {\n112:   return `${config.agent.tmuxPrefix}-${featureId}`;\n113: }\n114: \n115: /**\n116:  * Get the multiplexer info for this config.\n117:  * Caches detection per-process.\n118:  */\n119: function getMux(config: WomboConfig): MultiplexerInfo {\n120:   return detectMultiplexer(config.agent.multiplexer);\n121: }\n122: \n123: function runSilent(cmd: string): string {\n124:   try {\n125:     return execSync(cmd, { encoding: \"utf-8\", stdio: \"pipe\" }).trim();\n126:   } catch {\n127:     return \"\";\n128:   }\n129: }\n130: \n131: /**\n132:  * Build environment variables for an agent process.\n133:  * Merges process.env with OPENCODE_DIR, portless env vars, and HITL env vars.\n134:  */\n135: function agentEnv(\n136:   worktreePath: string,\n137:   featureId: string,\n138:   config: WomboConfig,\n139:   hitlMode?: string,\n140:   projectRoot?: string\n141: ): Record<string, string | undefined> {\n142:   const env: Record<string, string | undefined> = {\n143:     ...process.env,\n144:     OPENCODE_DIR: worktreePath,\n145:     ...portlessEnv(featureId, config),\n146:   };\n147: \n148:   // HITL environment — always set so the hitl-ask script is available,\n149:   // but the prompt controls whether the agent actually uses it.\n150:   if (projectRoot) {\n151:     env.WOMBO_HITL_DIR = hitlDir(projectRoot);\n152:     env.WOMBO_AGENT_ID = featureId;\n153:     env.WOMBO_HITL_MODE = hitlMode ?? \"yolo\";\n154:     // Path to the hitl-ask script (relative to this module)\n155:     // In development: src/lib/hitl-ask.ts\n156:     // In production (bundled): same dir as this file\n157:     const hitlAskPath = resolve(import.meta.dir, \"hitl-ask.ts\");\n158:     env.WOMBO_HITL_ASK = hitlAskPath;\n159:   }\n160: \n161:   return env;\n162: }\n163: \n164: // ---------------------------------------------------------------------------\n165: // Headless Launch\n166: // ---------------------------------------------------------------------------\n167: \n168: /**\n169:  * Launch agent in headless mode with JSON output.\n170:  *\n171:  * The child process is spawned with `detached: false` — it is tied to the\n172:  * parent process and will die when the parent exits. This is intentional:\n173:  * stdout must be piped for ProcessMonitor to parse JSON events in real-time.\n174:  * See module-level documentation for the full lifecycle analysis.\n175:  */\n176: export function launchHeadless(opts: LaunchOptions): LaunchResult {\n177:   const agentBin = resolveAgentBin(opts.config);\n178: \n179:   const args = [\n180:     \"run\",\n181:     \"--format\", \"json\",\n182:     \"--agent\", opts.agentName ?? opts.config.agent.name,\n183:     \"--dir\", opts.worktreePath,\n184:     \"--title\", `woco: ${opts.featureId}`,\n185:   ];\n186: \n187:   if (opts.model) {\n188:     args.push(\"--model\", opts.model);\n189:   }\n190: \n191:   args.push(opts.prompt);\n192: \n193:   const child = spawn(agentBin, args, {\n194:     stdio: [\"pipe\", \"pipe\", \"pipe\"],\n195:     detached: false,\n196:     env: agentEnv(opts.worktreePath, opts.featureId, opts.config, opts.hitlMode, opts.projectRoot),\n197:   });\n198: \n199:   // Close stdin so agent starts processing immediately\n200:   child.stdin?.end();\n201: \n202:   return {\n203:     pid: child.pid!,\n204:     process: child,\n205:   };\n206: }\n207: \n208: /**\n209:  * Resume a headless session with a retry message (build errors).\n210:  *\n211:  * Same lifecycle as `launchHeadless` — spawned with `detached: false`,\n212:  * piped stdio, no `unref()`. The child is tied to the parent process.\n213:  */\n214: export function retryHeadless(opts: RetryOptions): LaunchResult {\n215:   const agentBin = resolveAgentBin(opts.config);\n216: \n217:   const retryMessage = `The build failed. Please fix the following errors and run \\`${opts.config.build.command}\\` again:\\n\\n\\`\\`\\`\\n${opts.buildErrors}\\n\\`\\`\\`\\n\\nFix all errors, then verify the build passes.`;\n218: \n219:   const args = [\n220:     \"run\",\n221:     \"--format\", \"json\",\n222:     \"--session\", opts.sessionId,\n223:     \"--continue\",\n224:     \"--dir\", opts.worktreePath,\n225:   ];\n226: \n227:   if (opts.model) {\n228:     args.push(\"--model\", opts.model);\n229:   }\n230: \n231:   args.push(retryMessage);\n232: \n233:   const child = spawn(agentBin, args, {\n234:     stdio: [\"pipe\", \"pipe\", \"pipe\"],\n235:     detached: false,\n236:     env: agentEnv(opts.worktreePath, opts.featureId, opts.config, opts.hitlMode, opts.projectRoot),\n237:   });\n238: \n239:   child.stdin?.end();\n240: \n241:   return {\n242:     pid: child.pid!,\n243:     process: child,\n244:   };\n245: }\n246: \n247: // ---------------------------------------------------------------------------\n248: // Conflict Resolution Launch\n249: // ---------------------------------------------------------------------------\n250: \n251: export interface ConflictResolverOptions {\n252:   worktreePath: string;\n253:   featureId: string;\n254:   prompt: string;\n255:   model?: string;\n256:   config: WomboConfig;\n257:   /** Override the agent name for conflict resolution (default: merge-resolver-agent) */\n258:   agentName?: string;\n259: }\n260: \n261: /**\n262:  * Launch a headless agent to resolve merge conflicts.\n263:  *\n264:  * This is similar to `launchHeadless`, but the prompt is a conflict-resolution\n265:  * prompt generated by `generateConflictResolutionPrompt()`. The agent runs in\n266:  * the feature worktree where `git merge <baseBranch>` has already been run,\n267:  * leaving conflict markers in the working tree.\n268:  *\n269:  * By default uses the specialized \"merge-resolver-agent\" definition, which\n270:  * has minimal context and is focused solely on conflict resolution. Falls back\n271:  * to the generalist agent if no merge-resolver-agent is available.\n272:  *\n273:  * Same lifecycle as `launchHeadless` — spawned with `detached: false`,\n274:  * piped stdio, no `unref()`. Note: conflict resolver processes are NOT\n275:  * added to the ProcessMonitor (to avoid infinite recursion with\n276:  * handleBuildVerification). They are awaited directly via process.on('exit').\n277:  */\n278: export function launchConflictResolver(opts: ConflictResolverOptions): LaunchResult {\n279:   const agentBin = resolveAgentBin(opts.config);\n280: \n281:   // Use the specialized merge-resolver agent by default\n282:   const agentName = opts.agentName ?? \"merge-resolver-agent\";\n283: \n284:   const args = [\n285:     \"run\",\n286:     \"--format\", \"json\",\n287:     \"--agent\", agentName,\n288:     \"--dir\", opts.worktreePath,\n289:     \"--title\", `woco: conflict-resolve ${opts.featureId}`,\n290:   ];\n291: \n292:   if (opts.model) {\n293:     args.push(\"--model\", opts.model);\n294:   }\n295: \n296:   args.push(opts.prompt);\n297: \n298:   const child = spawn(agentBin, args, {\n299:     stdio: [\"pipe\", \"pipe\", \"pipe\"],\n300:     detached: false,\n301:     env: agentEnv(opts.worktreePath, opts.featureId, opts.config),\n302:   });\n303: \n304:   child.stdin?.end();\n305: \n306:   return {\n307:     pid: child.pid!,\n308:     process: child,\n309:   };\n310: }\n311: \n312: // ---------------------------------------------------------------------------\n313: // Interactive (multiplexer) Launch\n314: // ---------------------------------------------------------------------------\n315: \n316: /**\n317:  * Launch agent in a terminal multiplexer session (dmux or tmux) for interactive use.\n318:  *\n319:  * Unlike headless mode, the agent runs inside a multiplexer session that is\n320:  * fully independent of the parent process. The session survives parent death,\n321:  * SIGINT, and crashes. The trade-off is that there is no direct ChildProcess\n322:  * handle — monitoring is limited to checking the pane PID and session existence.\n323:  *\n324:  * The returned `process` field is `null as any` because the agent is managed\n325:  * by the multiplexer, not by Node's child_process module.\n326:  */\n327: export function launchInteractive(opts: LaunchOptions): LaunchResult {\n328:   const agentBin = resolveAgentBin(opts.config);\n329:   const mux = getMux(opts.config);\n330:   const sessionName = muxSessionName(opts.featureId, opts.config);\n331: \n332:   // Kill existing session if any\n333:   killMuxSession(opts.featureId, opts.config);\n334: \n335:   // Build the agent command to run inside the multiplexer\n336:   // Include portless env vars so any server started in the session\n337:   // is routed through the portless proxy\n338:   const pEnv = portlessEnv(opts.featureId, opts.config);\n339:   const envPrefix = Object.entries(pEnv)\n340:     .map(([k, v]) => `${k}=${JSON.stringify(v)}`)\n341:     .join(\" \");\n342: \n343:   const ocArgs = [\n344:     agentBin,\n345:     \"--dir\", JSON.stringify(opts.worktreePath),\n346:   ];\n347: \n348:   // Pass agent name if specified (specialized agent from registry or per-task override)\n349:   if (opts.agentName) {\n350:     ocArgs.push(\"--agent\", JSON.stringify(opts.agentName));\n351:   }\n352: \n353:   if (opts.model) {\n354:     ocArgs.push(\"--model\", JSON.stringify(opts.model));\n355:   }\n356: \n357:   const muxCmd = envPrefix ? `${envPrefix} ${ocArgs.join(\" \")}` : ocArgs.join(\" \");\n358: \n359:   // Create a detached session running the agent\n360:   muxNewSession(mux, sessionName, opts.worktreePath, muxCmd);\n361: \n362:   // Send the prompt as initial message after a brief delay\n363:   setTimeout(() => {\n364:     try {\n365:       const tmpFile = `/tmp/woco-prompt-${opts.featureId}.txt`;\n366:       writeFileSync(tmpFile, opts.prompt);\n367:       muxLoadBuffer(mux, tmpFile);\n368:       muxPasteBuffer(mux, sessionName);\n369:       muxSendKeys(mux, sessionName, \"Enter\");\n370:       try { unlinkSync(tmpFile); } catch {}\n371:     } catch {\n372:       // If prompt sending fails, user can type manually\n373:     }\n374:   }, 3000);\n375: \n376:   // Get the PID of the pane process\n377:   const panePid = muxGetPanePid(mux, sessionName);\n378: \n379:   return {\n380:     pid: panePid,\n381:     process: null as any, // No direct process handle in multiplexer mode\n382:   };\n383: }\n384: \n385: /**\n386:  * Resume an interactive session with retry message.\n387:  */\n388: export function retryInteractive(opts: RetryOptions): LaunchResult {\n389:   const mux = getMux(opts.config);\n390:   const sessionName = muxSessionName(opts.featureId, opts.config);\n391: \n392:   const exists = muxSessionExists(opts.featureId, opts.config);\n393: \n394:   if (exists) {\n395:     const retryMsg = `The build failed. Fix these errors:\\n${opts.buildErrors}`;\n396:     const tmpFile = `/tmp/woco-retry-${opts.featureId}.txt`;\n397:     writeFileSync(tmpFile, retryMsg);\n398:     muxLoadBuffer(mux, tmpFile);\n399:     muxPasteBuffer(mux, sessionName);\n400:     muxSendKeys(mux, sessionName, \"Enter\");\n401:     try { unlinkSync(tmpFile); } catch {}\n402: \n403:     const panePid = muxGetPanePid(mux, sessionName);\n404: \n405:     return {\n406:       pid: panePid,\n407:       process: null as any,\n408:     };\n409:   }\n410: \n411:   // Session doesn't exist — launch a new interactive session\n412:   return launchInteractive({\n413:     worktreePath: opts.worktreePath,\n414:     featureId: opts.featureId,\n415:     prompt: `Continue from session ${opts.sessionId}. The build failed:\\n${opts.buildErrors}\\n\\nFix all errors and verify the build passes.`,\n416:     model: opts.model,\n417:     interactive: true,\n418:     config: opts.config,\n419:   });\n420: }\n421: \n422: // ---------------------------------------------------------------------------\n423: // Multiplexer Session Management\n424: // ---------------------------------------------------------------------------\n425: \n426: /**\n427:  * Check if a multiplexer session exists for a feature.\n428:  */\n429: export function muxSessionExists(\n430:   featureId: string,\n431:   config: WomboConfig\n432: ): boolean {\n433:   const mux = getMux(config);\n434:   const sessionName = muxSessionName(featureId, config);\n435:   return muxHasSession(mux, sessionName);\n436: }\n437: \n438: /**\n439:  * Kill a multiplexer session for a feature.\n440:  */\n441: export function killMuxSession(\n442:   featureId: string,\n443:   config: WomboConfig\n444: ): void {\n445:   const mux = getMux(config);\n446:   const sessionName = muxSessionName(featureId, config);\n447:   muxKillSession(mux, sessionName);\n448: }\n449: \n450: /**\n451:  * List all woco-related multiplexer sessions.\n452:  */\n453: export function listMuxSessions(config: WomboConfig): string[] {\n454:   const mux = getMux(config);\n455:   const sessions = muxListSessions(mux);\n456:   return sessions.filter((s) => s.startsWith(config.agent.tmuxPrefix + \"-\"));\n457: }\n458: \n459: /**\n460:  * Kill all woco-related multiplexer sessions.\n461:  */\n462: export function killAllMuxSessions(config: WomboConfig): number {\n463:   const mux = getMux(config);\n464:   const sessions = listMuxSessions(config);\n465:   for (const s of sessions) {\n466:     muxKillSession(mux, s);\n467:   }\n468:   return sessions.length;\n469: }\n470: \n471: /**\n472:  * Get the display name of the active multiplexer backend.\n473:  */\n474: export function getMultiplexerName(config: WomboConfig): string {\n475:   try {\n476:     const mux = getMux(config);\n477:     return muxDisplayName(mux);\n478:   } catch {\n479:     return \"tmux/dmux\";\n480:   }\n481: }\n482: \n483: // ---------------------------------------------------------------------------\n484: // Backward Compatibility Aliases\n485: // ---------------------------------------------------------------------------\n486: \n487: /** @deprecated Use muxSessionExists instead */\n488: export const tmuxSessionExists = muxSessionExists;\n489: /** @deprecated Use killMuxSession instead */\n490: export const killTmuxSession = killMuxSession;\n491: /** @deprecated Use listMuxSessions instead */\n492: export const listTmuxSessions = listMuxSessions;\n493: /** @deprecated Use killAllMuxSessions instead */\n494: export const killAllTmuxSessions = killAllMuxSessions;\n495: \n496: /**\n497:  * Check if a process is still running by PID.\n498:  */\n499: export function isProcessRunning(pid: number): boolean {\n500:   if (!pid || pid <= 0) return false;\n501:   try {\n502:     process.kill(pid, 0);\n503:     return true;\n504:   } catch {\n505:     return false;\n506:   }\n507: }\n\n(End of file - total 507 lines)\n</content>","title":"src/lib/launcher.ts","metadata":{"preview":"/**\n * launcher.ts — Process spawning and terminal multiplexer session management.\n *\n * Responsibilities:\n *   - Launch agent in headless mode (agent run --format json)\n *   - Launch agent in interactive mode (dmux/tmux session with TUI)\n *   - Resume sessions for auto-retry\n *   - Manage multiplexer sessions (create, list, kill)\n *\n * Supports both dmux (preferred) and tmux (fallback) via the multiplexer\n * abstraction layer. The active backend is determined by config.agent.multiplexer.\n *\n * ## Agent Process Lifecycle (audit: wave-detach-audit)\n *\n * **Headless mode** (`launchHeadless`, `retryHeadless`, `launchConflictResolver`):\n *   - Agents are spawned with `detached: false` — they are child processes of\n *     the wombo parent and will be terminated when the parent exits.\n *   - `unref()` is NOT called — the child holds the parent's event loop alive,\n *     which is required for the ProcessMonitor to receive stdout/stderr events.\n *   - `stdio` is `[\"pipe\", \"pipe\", \"pipe\"]` — stdout is piped for JSON event","truncated":false,"loaded":[]},"time":{"start":1773483367851,"end":1773483367854}}}}
{"type":"tool_use","timestamp":1773483368471,"sessionID":"ses_31427856effefwaC38OEq6YCmn","part":{"id":"prt_cebd89dac0017AkteYesB12MFg","sessionID":"ses_31427856effefwaC38OEq6YCmn","messageID":"msg_cebd8906f001zEOTbtSrmRjWDQ","type":"tool","callID":"toolu_vrtx_0146UXkVQgc2hToEaxjRWhdh","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/wave-detach-audit/src/lib/monitor.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/wave-detach-audit/src/lib/monitor.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * monitor.ts — Parse JSON events from agent and detect completion/failure.\n3:  *\n4:  * Responsibilities:\n5:  *   - Parse newline-delimited JSON events from agent stdout\n6:  *   - Detect session completion (agent finished)\n7:  *   - Detect session ID from events\n8:  *   - Detect errors and failures\n9:  *   - Write per-agent raw log files for diagnostics\n10:  *   - Maintain per-agent parsed activity log for TUI preview\n11:  *\n12:  * ## Process Lifecycle (audit: wave-detach-audit)\n13:  *\n14:  * ProcessMonitor manages the lifecycle of headless agent child processes:\n15:  *\n16:  * **Normal flow**: Agent stdout → JSON event parsing → callbacks → completion\n17:  *   1. `addProcess()` registers a ChildProcess and attaches stdout/stderr listeners\n18:  *   2. Stdout data is parsed line-by-line as JSON events\n19:  *   3. Callbacks fire: `onSessionId`, `onActivity`, `onComplete`, `onError`\n20:  *   4. On process exit (code 0 or sawFinalStop), `onComplete` is called\n21:  *   5. On process exit (non-zero, no final stop), `onError` is called\n22:  *\n23:  * **Teardown flow**: Parent quit → `killAll()` → SIGTERM to each child\n24:  *   1. TUI `onQuit` or SIGINT handler calls `monitor.killAll()`\n25:  *   2. `killAll()` iterates all processes and calls `remove(featureId)`\n26:  *   3. `remove()` sends SIGTERM to the child process (if still running)\n27:  *   4. The process map entry is deleted — no further events are tracked\n28:  *\n29:  * **Key behavior**: `remove()` and `killAll()` intentionally kill child\n30:  * processes. This is correct because headless agents are spawned with\n31:  * `detached: false` — they are tied to the parent and would die anyway\n32:  * when the parent exits. Explicitly killing them ensures a clean shutdown\n33:  * with proper state saving before the parent terminates.\n34:  *\n35:  * **Edge case**: If the parent is killed with SIGKILL (not catchable),\n36:  * child processes die with no cleanup. `woco resume` handles this by\n37:  * detecting orphaned worktrees with commits and re-verifying/re-launching.\n38:  */\n39: \n40: import type { ChildProcess } from \"node:child_process\";\n41: import { isProcessRunning } from \"./launcher.js\";\n42: import { mkdirSync, appendFileSync, existsSync, readFileSync } from \"node:fs\";\n43: import { resolve } from \"node:path\";\n44: import { TokenCollector, type UsageRecord } from \"./token-collector.js\";\n45: import { UsageStore } from \"./token-usage.js\";\n46: \n47: // ---------------------------------------------------------------------------\n48: // Log directory name (configurable would be overkill here)\n49: // ---------------------------------------------------------------------------\n50: \n51: const LOG_DIR_NAME = \".wombo-combo/logs\";\n52: \n53: // ---------------------------------------------------------------------------\n54: // Types — OpenCode JSON Events\n55: // ---------------------------------------------------------------------------\n56: \n57: export interface OpenCodeEvent {\n58:   type: string;\n59:   sessionID?: string;\n60:   timestamp?: number;\n61:   part?: {\n62:     type?: string;\n63:     tool?: string;\n64:     callID?: string;\n65:     text?: string;\n66:     reason?: string;\n67:     cost?: number;\n68:     tokens?: {\n69:       total: number;\n70:       input: number;\n71:       output: number;\n72:       reasoning: number;\n73:       cache?: {\n74:         read: number;\n75:         write: number;\n76:       };\n77:     };\n78:     state?: {\n79:       status?: string;\n80:       input?: Record<string, any>;\n81:       output?: string;\n82:       error?: string;\n83:     };\n84:   };\n85:   [key: string]: any;\n86: }\n87: \n88: // ---------------------------------------------------------------------------\n89: // Event Parser\n90: // ---------------------------------------------------------------------------\n91: \n92: export interface ParsedOutput {\n93:   sessionId: string | null;\n94:   completed: boolean;\n95:   errored: boolean;\n96:   lastError: string | null;\n97:   events: OpenCodeEvent[];\n98: }\n99: \n100: export function parseEvents(rawOutput: string): ParsedOutput {\n101:   const result: ParsedOutput = {\n102:     sessionId: null,\n103:     completed: false,\n104:     errored: false,\n105:     lastError: null,\n106:     events: [],\n107:   };\n108: \n109:   const lines = rawOutput.split(\"\\n\").filter((l) => l.trim());\n110: \n111:   for (const line of lines) {\n112:     try {\n113:       const event = JSON.parse(line) as OpenCodeEvent;\n114:       result.events.push(event);\n115: \n116:       if (event.sessionID && !result.sessionId) {\n117:         result.sessionId = event.sessionID;\n118:       }\n119: \n120:       if (\n121:         event.type === \"step_finish\" &&\n122:         event.part?.reason === \"stop\"\n123:       ) {\n124:         result.completed = true;\n125:       }\n126: \n127:       if (\n128:         event.type === \"tool_use\" &&\n129:         event.part?.state?.status === \"error\"\n130:       ) {\n131:         result.errored = true;\n132:         result.lastError = event.part.state.error ?? \"unknown tool error\";\n133:       }\n134:     } catch {\n135:       // Not valid JSON — skip\n136:     }\n137:   }\n138: \n139:   return result;\n140: }\n141: \n142: // ---------------------------------------------------------------------------\n143: // Activity Extraction\n144: // ---------------------------------------------------------------------------\n145: \n146: function shortPath(fullPath: string | undefined, maxLen: number = 30): string {\n147:   if (!fullPath) return \"\";\n148:   const parts = fullPath.replace(/^\\/+/, \"\").split(\"/\");\n149:   const short =\n150:     parts.length > 1\n151:       ? parts.slice(-2).join(\"/\")\n152:       : parts[parts.length - 1];\n153:   if (short.length <= maxLen) return short;\n154:   const fname = parts[parts.length - 1];\n155:   return fname.length <= maxLen ? fname : fname.slice(0, maxLen - 1) + \"\\u2026\";\n156: }\n157: \n158: function shortCmd(cmd: string | undefined, maxLen: number = 30): string {\n159:   if (!cmd) return \"\";\n160:   const first = cmd.split(\"\\n\")[0].trim();\n161:   if (first.length <= maxLen) return first;\n162:   return first.slice(0, maxLen - 1) + \"\\u2026\";\n163: }\n164: \n165: /**\n166:  * Map an event to a human-readable activity string.\n167:  */\n168: export function extractActivity(event: OpenCodeEvent): string | null {\n169:   switch (event.type) {\n170:     case \"step_start\":\n171:       return \"thinking\\u2026\";\n172: \n173:     case \"tool_use\": {\n174:       const toolName = (event.part?.tool ?? \"\").toLowerCase();\n175:       const input = event.part?.state?.input ?? {};\n176:       const status = event.part?.state?.status ?? \"\";\n177: \n178:       if (status === \"error\") {\n179:         return `${toolName}: error`;\n180:       }\n181: \n182:       switch (toolName) {\n183:         case \"read\":\n184:           return `reading ${shortPath(input.filePath ?? input.path)}`;\n185:         case \"write\":\n186:           return `writing ${shortPath(input.filePath ?? input.path)}`;\n187:         case \"edit\":\n188:           return `editing ${shortPath(input.filePath ?? input.path)}`;\n189:         case \"bash\":\n190:         case \"command\":\n191:         case \"terminal\": {\n192:           const cmd = input.command ?? input.cmd ?? \"\";\n193:           // Detect HITL ask script invocation\n194:           if (cmd.includes(\"hitl-ask\")) {\n195:             return \"waiting for human…\";\n196:           }\n197:           return `$ ${shortCmd(cmd)}`;\n198:         }\n199:         case \"glob\":\n200:           return `finding: ${shortPath(input.pattern)}`;\n201:         case \"grep\":\n202:         case \"search\":\n203:           return `searching: ${(input.pattern ?? \"\").slice(0, 25)}`;\n204:         case \"task\":\n205:           return \"delegating task\\u2026\";\n206:         case \"webfetch\":\n207:         case \"web_fetch\":\n208:           return \"fetching URL\\u2026\";\n209:         case \"todowrite\":\n210:         case \"todo_write\":\n211:           return \"planning\\u2026\";\n212:         case \"question\":\n213:           return \"asking question\\u2026\";\n214:         case \"jcodemunch_index_folder\":\n215:         case \"jcodemunch_index_repo\":\n216:           return \"indexing code\\u2026\";\n217:         case \"jcodemunch_search_symbols\":\n218:         case \"jcodemunch_search_text\":\n219:           return \"searching symbols\\u2026\";\n220:         case \"jcodemunch_get_file_outline\":\n221:           return `outlining ${shortPath(input.file_path)}`;\n222:         case \"jcodemunch_get_symbol\":\n223:         case \"jcodemunch_get_symbols\":\n224:           return \"reading symbol\\u2026\";\n225:         default:\n226:           return `tool: ${toolName}`;\n227:       }\n228:     }\n229: \n230:     case \"text\":\n231:       return \"responding\\u2026\";\n232: \n233:     case \"step_finish\":\n234:       if (event.part?.reason === \"stop\") return \"done\";\n235:       if (event.part?.reason === \"tool-calls\") return null;\n236:       return null;\n237: \n238:     default:\n239:       return null;\n240:   }\n241: }\n242: \n243: /**\n244:  * Format an event into a human-readable log line for the activity stream.\n245:  */\n246: export function formatEventForLog(event: OpenCodeEvent): string | null {\n247:   switch (event.type) {\n248:     case \"step_start\":\n249:       return \"-- step started\";\n250: \n251:     case \"tool_use\": {\n252:       const toolName = event.part?.tool ?? \"unknown\";\n253:       const input = event.part?.state?.input ?? {};\n254:       const status = event.part?.state?.status ?? \"\";\n255:       const output = event.part?.state?.output ?? \"\";\n256:       const error = event.part?.state?.error ?? \"\";\n257: \n258:       let line = `>> ${toolName}`;\n259:       switch (toolName.toLowerCase()) {\n260:         case \"read\":\n261:           line = `>> read ${shortPath(input.filePath ?? input.path, 50)}`;\n262:           break;\n263:         case \"write\":\n264:           line = `>> write ${shortPath(input.filePath ?? input.path, 50)}`;\n265:           break;\n266:         case \"edit\":\n267:           line = `>> edit ${shortPath(input.filePath ?? input.path, 50)}`;\n268:           break;\n269:         case \"bash\":\n270:         case \"command\":\n271:           line = `>> $ ${shortCmd(input.command ?? input.cmd, 60)}`;\n272:           break;\n273:         case \"glob\":\n274:           line = `>> glob ${input.pattern ?? \"\"}`;\n275:           break;\n276:         case \"grep\":\n277:           line = `>> grep \"${(input.pattern ?? \"\").slice(0, 30)}\"`;\n278:           break;\n279:         case \"task\":\n280:           line = `>> task: ${(input.description ?? input.prompt ?? \"\").slice(0, 50)}`;\n281:           break;\n282:       }\n283: \n284:       if (status === \"completed\" && output) {\n285:         const preview = output.split(\"\\n\")[0].slice(0, 80);\n286:         return `${line}\\n   ${preview}${output.length > 80 ? \"\\u2026\" : \"\"}`;\n287:       }\n288:       if (status === \"error\" && error) {\n289:         return `${line}\\n!! ${error.slice(0, 100)}`;\n290:       }\n291:       return line;\n292:     }\n293: \n294:     case \"text\": {\n295:       const text = event.part?.text ?? \"\";\n296:       if (!text.trim()) return null;\n297:       const firstLine = text.split(\"\\n\").find((l: string) => l.trim())?.trim() ?? \"\";\n298:       if (firstLine.length === 0) return null;\n299:       return `   ${firstLine.slice(0, 120)}${firstLine.length > 120 ? \"\\u2026\" : \"\"}`;\n300:     }\n301: \n302:     case \"step_finish\": {\n303:       const reason = event.part?.reason ?? \"\";\n304:       const tokens = event.part?.tokens;\n305:       if (reason === \"stop\") {\n306:         let tokStr = \"\";\n307:         if (tokens) {\n308:           const parts = [`${tokens.input}in`, `${tokens.output}out`];\n309:           if (tokens.cache?.read) parts.push(`${tokens.cache.read}cache`);\n310:           tokStr = ` (${parts.join(\"/\")})`;\n311:         }\n312:         return `-- done${tokStr}`;\n313:       }\n314:       return null;\n315:     }\n316: \n317:     default:\n318:       return null;\n319:   }\n320: }\n321: \n322: // ---------------------------------------------------------------------------\n323: // Per-agent Activity Log (in-memory ring buffer for TUI)\n324: // ---------------------------------------------------------------------------\n325: \n326: export interface ActivityEntry {\n327:   timestamp: string;\n328:   text: string;\n329: }\n330: \n331: const MAX_ACTIVITY_LINES = 500;\n332: \n333: // ---------------------------------------------------------------------------\n334: // Process Monitor\n335: // ---------------------------------------------------------------------------\n336: \n337: export interface MonitorCallbacks {\n338:   onSessionId?: (featureId: string, sessionId: string) => void;\n339:   onComplete?: (featureId: string) => void;\n340:   onError?: (featureId: string, error: string) => void;\n341:   onOutput?: (featureId: string, data: string) => void;\n342:   onActivity?: (featureId: string, activity: string) => void;\n343:   /** Called when an agent asks a human question via HITL */\n344:   onQuestion?: (featureId: string, questionText: string) => void;\n345:   /** Called when token usage data is parsed from a step_finish event */\n346:   onUsage?: (featureId: string, record: UsageRecord) => void;\n347: }\n348: \n349: interface MonitoredProcess {\n350:   featureId: string;\n351:   process: ChildProcess | null;\n352:   /** Explicit PID — used for reconnected processes where no ChildProcess handle exists */\n353:   pid: number;\n354:   stdout: string;\n355:   stderr: string;\n356:   sessionId: string | null;\n357:   done: boolean;\n358:   lineBuffer: string;\n359:   sawFinalStop: boolean;\n360:   /** True when this entry was created by reconnectProcess() (PID-only, no ChildProcess) */\n361:   reconnected: boolean;\n362: }\n363: \n364: /**\n365:  * Monitor a set of headless agent processes.\n366:  * Collects stdout, parses events, and calls callbacks on state changes.\n367:  */\n368: export class ProcessMonitor {\n369:   private processes: Map<string, MonitoredProcess> = new Map();\n370:   private callbacks: MonitorCallbacks;\n371:   private logDir: string;\n372:   /** Per-agent activity log for TUI preview pane */\n373:   public activityLogs: Map<string, ActivityEntry[]> = new Map();\n374:   /** Token usage collector — parses and accumulates usage from step_finish events */\n375:   public tokenCollector: TokenCollector;\n376:   /** Token usage store — persists records to .wombo-combo/usage.jsonl */\n377:   public usageStore: UsageStore;\n378: \n379:   constructor(projectRoot: string, callbacks: MonitorCallbacks = {}) {\n380:     this.callbacks = callbacks;\n381:     this.logDir = resolve(projectRoot, LOG_DIR_NAME);\n382:     if (!existsSync(this.logDir)) {\n383:       mkdirSync(this.logDir, { recursive: true });\n384:     }\n385:     this.usageStore = new UsageStore(projectRoot);\n386:     this.tokenCollector = new TokenCollector((record) => {\n387:       // Persist to JSONL file for historical tracking\n388:       try {\n389:         this.usageStore.append(record);\n390:       } catch {\n391:         // Non-critical — don't break agent monitoring if write fails\n392:       }\n393:       this.callbacks.onUsage?.(record.task_id, record);\n394:     });\n395:   }\n396: \n397:   private pushActivity(featureId: string, text: string): void {\n398:     if (!this.activityLogs.has(featureId)) {\n399:       this.activityLogs.set(featureId, []);\n400:     }\n401:     const log = this.activityLogs.get(featureId)!;\n402:     for (const line of text.split(\"\\n\")) {\n403:       log.push({ timestamp: new Date().toISOString().slice(11, 19), text: line });\n404:     }\n405:     if (log.length > MAX_ACTIVITY_LINES) {\n406:       log.splice(0, log.length - MAX_ACTIVITY_LINES);\n407:     }\n408:   }\n409: \n410:   private writeLog(featureId: string, data: string): void {\n411:     try {\n412:       const logFile = resolve(this.logDir, `${featureId}.log`);\n413:       appendFileSync(logFile, data);\n414:     } catch {\n415:       // Non-critical\n416:     }\n417:   }\n418: \n419:   getActivityLog(featureId: string): ActivityEntry[] {\n420:     return this.activityLogs.get(featureId) ?? [];\n421:   }\n422: \n423:   addProcess(featureId: string, child: ChildProcess): void {\n424:     const monitored: MonitoredProcess = {\n425:       featureId,\n426:       process: child,\n427:       pid: child.pid!,\n428:       stdout: \"\",\n429:       stderr: \"\",\n430:       sessionId: null,\n431:       done: false,\n432:       lineBuffer: \"\",\n433:       sawFinalStop: false,\n434:       reconnected: false,\n435:     };\n436: \n437:     this.pushActivity(featureId, \"-- agent process started\");\n438:     this.writeLog(featureId, `[wombo] Process started at ${new Date().toISOString()}\\n`);\n439: \n440:     child.stdout?.on(\"data\", (data: Buffer) => {\n441:       const chunk = data.toString();\n442:       monitored.stdout += chunk;\n443:       this.callbacks.onOutput?.(featureId, chunk);\n444:       this.writeLog(featureId, chunk);\n445: \n446:       monitored.lineBuffer += chunk;\n447:       const lines = monitored.lineBuffer.split(\"\\n\");\n448:       monitored.lineBuffer = lines.pop() ?? \"\";\n449: \n450:       for (const line of lines) {\n451:         const trimmed = line.trim();\n452:         if (!trimmed) continue;\n453:         try {\n454:           const event = JSON.parse(trimmed) as OpenCodeEvent;\n455: \n456:           if (!monitored.sessionId && event.sessionID) {\n457:             monitored.sessionId = event.sessionID;\n458:             this.callbacks.onSessionId?.(featureId, event.sessionID);\n459:             this.pushActivity(featureId, `-- session: ${event.sessionID}`);\n460:           }\n461: \n462:           const activity = extractActivity(event);\n463:           if (activity) {\n464:             this.callbacks.onActivity?.(featureId, activity);\n465:           }\n466: \n467:           const logLine = formatEventForLog(event);\n468:           if (logLine) {\n469:             this.pushActivity(featureId, logLine);\n470:           }\n471: \n472:           // Extract token usage from step_finish events\n473:           this.tokenCollector.ingestEvent(featureId, event);\n474: \n475:           if (\n476:             event.type === \"step_finish\" &&\n477:             event.part?.reason === \"stop\"\n478:           ) {\n479:             monitored.sawFinalStop = true;\n480:           }\n481:         } catch {\n482:           if (trimmed.length > 0 && trimmed.length < 500) {\n483:             this.pushActivity(featureId, `[raw] ${trimmed.slice(0, 120)}`);\n484:           }\n485:         }\n486:       }\n487:     });\n488: \n489:     child.stderr?.on(\"data\", (data: Buffer) => {\n490:       const chunk = data.toString();\n491:       monitored.stderr += chunk;\n492:       this.writeLog(featureId, `[stderr] ${chunk}`);\n493:       const lines = chunk.split(\"\\n\").filter((l) => l.trim());\n494:       for (const line of lines) {\n495:         this.pushActivity(featureId, `[stderr] ${line.trim().slice(0, 120)}`);\n496:       }\n497:     });\n498: \n499:     child.on(\"exit\", (code) => {\n500:       monitored.done = true;\n501:       this.pushActivity(featureId, `-- process exited (code ${code})`);\n502:       this.writeLog(featureId, `\\n[wombo] Process exited with code ${code} at ${new Date().toISOString()}\\n`);\n503: \n504:       if (code === 0 || monitored.sawFinalStop) {\n505:         this.callbacks.onComplete?.(featureId);\n506:       } else {\n507:         const error =\n508:           monitored.stderr.slice(-2000) ||\n509:           `Process exited with code ${code}`;\n510:         this.callbacks.onError?.(featureId, error);\n511:       }\n512:     });\n513: \n514:     child.on(\"error\", (err) => {\n515:       monitored.done = true;\n516:       this.pushActivity(featureId, `!! process error: ${err.message}`);\n517:       this.writeLog(featureId, `\\n[wombo] Process error: ${err.message}\\n`);\n518:       this.callbacks.onError?.(featureId, err.message);\n519:     });\n520: \n521:     this.processes.set(featureId, monitored);\n522:   }\n523: \n524:   /**\n525:    * Reconnect to a running agent process by PID.\n526:    *\n527:    * Creates a \"virtual\" MonitoredProcess entry with no ChildProcess handle.\n528:    * This is used when resuming a wave where agents (typically interactive\n529:    * mux-based agents) are still alive but the parent monitor was stopped.\n530:    *\n531:    * Since there are no stdio pipes to read from, this method:\n532:    *   - Loads historical activity from the existing log file (last N lines)\n533:    *   - Starts a PID polling interval to detect process death\n534:    *   - When the PID dies, fires onComplete or onError callbacks based on\n535:    *     whether the agent's worktree has commits (determined by the caller)\n536:    *\n537:    * The polling loop detects PID death and marks the entry as done, which\n538:    * allows the resume.ts polling loop to handle verification/re-launch.\n539:    */\n540:   reconnectProcess(featureId: string, pid: number, sessionId?: string | null): void {\n541:     const monitored: MonitoredProcess = {\n542:       featureId,\n543:       process: null,\n544:       pid,\n545:       stdout: \"\",\n546:       stderr: \"\",\n547:       sessionId: sessionId ?? null,\n548:       done: false,\n549:       lineBuffer: \"\",\n550:       sawFinalStop: false,\n551:       reconnected: true,\n552:     };\n553: \n554:     this.pushActivity(featureId, `-- reconnected to running process (PID ${pid})`);\n555:     this.writeLog(featureId, `\\n[wombo] Reconnected to PID ${pid} at ${new Date().toISOString()}\\n`);\n556: \n557:     // Load historical activity from the log file so the TUI has context\n558:     this._loadHistoricalActivity(featureId);\n559: \n560:     // Start a polling interval to detect PID death.\n561:     // When the PID dies, mark as done and fire the appropriate callback.\n562:     // The resume.ts polling loop will handle verification/re-launch.\n563:     const pollInterval = setInterval(() => {\n564:       if (!isProcessRunning(pid)) {\n565:         clearInterval(pollInterval);\n566:         monitored.done = true;\n567:         this.pushActivity(featureId, `-- reconnected process exited (PID ${pid})`);\n568:         this.writeLog(featureId, `\\n[wombo] Reconnected process PID ${pid} exited at ${new Date().toISOString()}\\n`);\n569:         // Fire onComplete — the resume.ts polling loop checks branchHasChanges\n570:         // and will downgrade to onError/failed if no commits were made.\n571:         this.callbacks.onComplete?.(featureId);\n572:       }\n573:     }, 2000);\n574: \n575:     // Ensure the interval doesn't hold the process alive if everything else is done\n576:     if (pollInterval.unref) {\n577:       pollInterval.unref();\n578:     }\n579: \n580:     this.processes.set(featureId, monitored);\n581:   }\n582: \n583:   /**\n584:    * Load recent lines from the log file into the activity buffer.\n585:    * Gives the TUI context about what the agent was doing before the monitor\n586:    * was stopped.\n587:    */\n588:   private _loadHistoricalActivity(featureId: string): void {\n589:     const logFile = resolve(this.logDir, `${featureId}.log`);\n590:     if (!existsSync(logFile)) return;\n591: \n592:     try {\n593:       const content = readFileSync(logFile, \"utf-8\");\n594:       const lines = content.split(\"\\n\").filter((l) => l.trim());\n595:       // Take last N lines to avoid flooding the activity buffer\n596:       const recentLines = lines.slice(-50);\n597: \n598:       for (const line of recentLines) {\n599:         const trimmed = line.trim();\n600:         if (!trimmed) continue;\n601: \n602:         // Try parsing as JSON event to extract structured activity\n603:         try {\n604:           const event = JSON.parse(trimmed) as OpenCodeEvent;\n605:           const logLine = formatEventForLog(event);\n606:           if (logLine) {\n607:             this.pushActivity(featureId, logLine);\n608:           }\n609:         } catch {\n610:           // Not JSON — add as raw log line (skip [wombo] meta lines)\n611:           if (!trimmed.startsWith(\"[wombo]\")) {\n612:             this.pushActivity(featureId, `[log] ${trimmed.slice(0, 120)}`);\n613:           }\n614:         }\n615:       }\n616:     } catch {\n617:       // Non-critical — log file may be unreadable\n618:     }\n619:   }\n620: \n621:   getSessionId(featureId: string): string | null {\n622:     return this.processes.get(featureId)?.sessionId ?? null;\n623:   }\n624: \n625:   getOutput(featureId: string): string {\n626:     return this.processes.get(featureId)?.stdout ?? \"\";\n627:   }\n628: \n629:   isRunning(featureId: string): boolean {\n630:     const m = this.processes.get(featureId);\n631:     if (!m) return false;\n632:     if (m.done) return false;\n633:     return isProcessRunning(m.pid);\n634:   }\n635: \n636:   allDone(): boolean {\n637:     for (const m of this.processes.values()) {\n638:       if (!m.done) return false;\n639:     }\n640:     return true;\n641:   }\n642: \n643:   activeCount(): number {\n644:     let count = 0;\n645:     for (const m of this.processes.values()) {\n646:       if (!m.done) count++;\n647:     }\n648:     return count;\n649:   }\n650: \n651:   /**\n652:    * Remove a process from monitoring and kill it if still running.\n653:    *\n654:    * Sends SIGTERM (not SIGKILL) to allow the agent to handle shutdown\n655:    * gracefully (e.g., save partial work, close files). The process map\n656:    * entry is deleted immediately — any subsequent events from the dying\n657:    * process are ignored.\n658:    *\n659:    * For reconnected processes (no ChildProcess handle), uses\n660:    * `process.kill(pid, 'SIGTERM')` directly.\n661:    */\n662:   remove(featureId: string): void {\n663:     const m = this.processes.get(featureId);\n664:     if (m && !m.done) {\n665:       try {\n666:         if (m.process) {\n667:           m.process.kill(\"SIGTERM\");\n668:         } else {\n669:           // Reconnected process — no ChildProcess handle, use PID directly\n670:           process.kill(m.pid, \"SIGTERM\");\n671:         }\n672:       } catch {}\n673:     }\n674:     this.processes.delete(featureId);\n675:   }\n676: \n677:   /**\n678:    * Kill all monitored processes. Called during graceful shutdown\n679:    * (SIGINT, TUI quit) to ensure no orphaned agent processes remain.\n680:    *\n681:    * This is the primary teardown path. After killAll(), the parent\n682:    * process saves wave state and exits. Agents can be re-launched\n683:    * later via `woco resume`.\n684:    *\n685:    * Reconnected processes are NOT killed — they are independent agents\n686:    * (typically in mux sessions) that should survive the parent's exit.\n687:    * They are simply removed from the monitor map so polling stops.\n688:    */\n689:   killAll(): void {\n690:     for (const [id, m] of this.processes.entries()) {\n691:       if (m.reconnected) {\n692:         // Don't kill reconnected processes — just stop monitoring\n693:         this.processes.delete(id);\n694:       } else {\n695:         this.remove(id);\n696:       }\n697:     }\n698:   }\n699: \n700:   waitAll(pollIntervalMs: number = 1000): Promise<void> {\n701:     return new Promise((resolve) => {\n702:       const check = () => {\n703:         if (this.allDone()) {\n704:           resolve();\n705:         } else {\n706:           setTimeout(check, pollIntervalMs);\n707:         }\n708:       };\n709:       check();\n710:     });\n711:   }\n712: }\n713: \n714: // ---------------------------------------------------------------------------\n715: // Re-exports from token-collector for convenience\n716: // ---------------------------------------------------------------------------\n717: \n718: export { TokenCollector, type UsageRecord } from \"./token-collector.js\";\n719: export type { UsageSummary, UsageCallback } from \"./token-collector.js\";\n720: \n721: // ---------------------------------------------------------------------------\n722: // Re-exports from token-usage for convenience\n723: // ---------------------------------------------------------------------------\n724: \n725: export { UsageStore, appendUsageRecord, loadUsageRecords, totalUsage, filterByDateRange, groupBy } from \"./token-usage.js\";\n726: export type { UsageTotals, GroupableField } from \"./token-usage.js\";\n\n(End of file - total 726 lines)\n</content>","title":"src/lib/monitor.ts","metadata":{"preview":"/**\n * monitor.ts — Parse JSON events from agent and detect completion/failure.\n *\n * Responsibilities:\n *   - Parse newline-delimited JSON events from agent stdout\n *   - Detect session completion (agent finished)\n *   - Detect session ID from events\n *   - Detect errors and failures\n *   - Write per-agent raw log files for diagnostics\n *   - Maintain per-agent parsed activity log for TUI preview\n *\n * ## Process Lifecycle (audit: wave-detach-audit)\n *\n * ProcessMonitor manages the lifecycle of headless agent child processes:\n *\n * **Normal flow**: Agent stdout → JSON event parsing → callbacks → completion\n *   1. `addProcess()` registers a ChildProcess and attaches stdout/stderr listeners\n *   2. Stdout data is parsed line-by-line as JSON events\n *   3. Callbacks fire: `onSessionId`, `onActivity`, `onComplete`, `onError`\n *   4. On process exit (code 0 or sawFinalStop), `onComplete` is called","truncated":false,"loaded":[]},"time":{"start":1773483368467,"end":1773483368470}}}}
{"type":"text","timestamp":1773483368897,"sessionID":"ses_31427856effefwaC38OEq6YCmn","part":{"id":"prt_cebd8987d001p5y0XgxK9kDc8D","sessionID":"ses_31427856effefwaC38OEq6YCmn","messageID":"msg_cebd8906f001zEOTbtSrmRjWDQ","type":"text","text":"Now let me read the three key files mentioned in the task:","time":{"start":1773483368896,"end":1773483368896}}}
{"type":"tool_use","timestamp":1773483368913,"sessionID":"ses_31427856effefwaC38OEq6YCmn","part":{"id":"prt_cebd8a07e0013vtgMLugZDsWWl","sessionID":"ses_31427856effefwaC38OEq6YCmn","messageID":"msg_cebd8906f001zEOTbtSrmRjWDQ","type":"tool","callID":"toolu_vrtx_01VYZZo4yqmDFwz7pV9i3D5J","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/wave-detach-audit/src/lib/tui.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/wave-detach-audit/src/lib/tui.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tui.ts — Blessed-based TUI dashboard for wombo-combo.\n3:  *\n4:  * Layout:\n5:  *   ┌─────────────────────────────────────────────┐\n6:  *   │ Header: Wave ID, base branch, mode, model   │\n7:  *   ├──────────────────────────┬──────────────────┤\n8:  *   │ Agent Table              │ Preview Pane     │\n9:  *   │ (selectable rows with    │ (parsed activity │\n10:  *   │  status, activity,       │  stream for the  │\n11:  *   │  progress bars, elapsed) │  selected agent) │\n12:  *   ├──────────────────────────┴──────────────────┤\n13:  *   │ Status bar: keybinds + summary counts       │\n14:  *   └─────────────────────────────────────────────┘\n15:  *\n16:  * Keybinds:\n17:  *   Up/Down   — navigate agent list\n18:  *   Enter     — attach to selected agent's multiplexer session (interactive mode)\n19:  *   r         — retry a failed/stuck agent\n20:  *   b         — show build log for selected agent\n21:  *   p         — toggle auto-scroll (pause/resume)\n22:  *   q / C-c   — quit\n23:  */\n24: \n25: import blessed from \"neo-blessed\";\n26: import type { Widgets } from \"neo-blessed\";\n27: import type { WaveState, AgentState, AgentStatus } from \"./state.js\";\n28: import { agentCounts } from \"./state.js\";\n29: import type { ProcessMonitor, ActivityEntry } from \"./monitor.js\";\n30: import { execSync } from \"node:child_process\";\n31: import { readFileSync } from \"node:fs\";\n32: import { resolve } from \"node:path\";\n33: import type { WomboConfig } from \"../config.js\";\n34: import {\n35:   detectMultiplexer,\n36:   muxHasSession,\n37:   muxAttach,\n38:   muxDisplayName,\n39: } from \"./multiplexer.js\";\n40: import { QuestionPopup } from \"./tui-question-popup.js\";\n41: import type { HitlQuestion } from \"./hitl-channel.js\";\n42: \n43: // ---------------------------------------------------------------------------\n44: // Types\n45: // ---------------------------------------------------------------------------\n46: \n47: export interface TUIOptions {\n48:   state: WaveState;\n49:   monitor: ProcessMonitor;\n50:   onQuit: () => void;\n51:   /** Whether the wave is running in interactive (multiplexer) mode. */\n52:   interactive?: boolean;\n53:   /** Project root path (for locating log files). */\n54:   projectRoot: string;\n55:   /** Config (for multiplexer session prefix, log dir, etc.) */\n56:   config: WomboConfig;\n57:   /** Callback to retry a failed/stuck agent from the TUI. */\n58:   onRetry?: (featureId: string) => void;\n59:   /** Callback when the user answers an HITL question. */\n60:   onAnswer?: (agentId: string, questionId: string, answerText: string) => void;\n61:   /**\n62:    * Callback invoked during stop() BEFORE the blessed screen is destroyed.\n63:    * Use this to flush pending state writes to disk while the process is\n64:    * still alive and I/O is still functional. This ensures state.json\n65:    * integrity even if the process exits immediately after screen.destroy().\n66:    */\n67:   onBeforeDestroy?: () => void;\n68: }\n69: \n70: // ---------------------------------------------------------------------------\n71: // Color Map\n72: // ---------------------------------------------------------------------------\n73: \n74: const STATUS_COLORS: Record<AgentStatus, string> = {\n75:   queued: \"gray\",\n76:   installing: \"cyan\",\n77:   running: \"blue\",\n78:   completed: \"yellow\",\n79:   verified: \"green\",\n80:   failed: \"red\",\n81:   merged: \"magenta\",\n82:   retry: \"yellow\",\n83:   resolving_conflict: \"cyan\",\n84: };\n85: \n86: const STATUS_ICONS: Record<AgentStatus, string> = {\n87:   queued: \"·\",\n88:   installing: \"⟳\",\n89:   running: \"●\",\n90:   completed: \"○\",\n91:   verified: \"✓\",\n92:   failed: \"✗\",\n93:   merged: \"◆\",\n94:   retry: \"↻\",\n95:   resolving_conflict: \"⚡\",\n96: };\n97: \n98: // ---------------------------------------------------------------------------\n99: // Helpers\n100: // ---------------------------------------------------------------------------\n101: \n102: /**\n103:  * Escape curly braces so blessed doesn't interpret them as formatting tags.\n104:  * Blessed uses {color-fg}...{/color-fg} syntax; unmatched or malformed braces\n105:  * in user-provided text (JSON, Python dicts, shell commands, etc.) crash the\n106:  * renderer. We replace { and } with the Unicode fullwidth equivalents which\n107:  * render visually similar but are not parsed by blessed.\n108:  */\n109: function escapeBlessedTags(text: string): string {\n110:   return text.replace(/\\{/g, \"｛\").replace(/\\}/g, \"｝\");\n111: }\n112: \n113: function elapsed(startedAt: string | null): string {\n114:   if (!startedAt) return \"-\";\n115:   const start = new Date(startedAt).getTime();\n116:   const diffMs = Date.now() - start;\n117:   const secs = Math.floor(diffMs / 1000);\n118:   if (secs < 60) return `${secs}s`;\n119:   const mins = Math.floor(secs / 60);\n120:   if (mins < 60) return `${mins}m`;\n121:   const hours = Math.floor(mins / 60);\n122:   return `${hours}h${mins % 60}m`;\n123: }\n124: \n125: function progressBar(\n126:   elapsedMs: number,\n127:   estimateMs: number,\n128:   width: number = 10\n129: ): string {\n130:   if (estimateMs <= 0) return \"░\".repeat(width);\n131:   const ratio = Math.min(elapsedMs / estimateMs, 1);\n132:   const filled = Math.round(ratio * width);\n133:   return \"█\".repeat(filled) + \"░\".repeat(width - filled);\n134: }\n135: \n136: // ---------------------------------------------------------------------------\n137: // TUI Dashboard Class\n138: // ---------------------------------------------------------------------------\n139: \n140: export class WomboTUI {\n141:   private screen: Widgets.Screen;\n142:   private headerBox: Widgets.BoxElement;\n143:   private agentList: Widgets.ListElement;\n144:   private previewBox: Widgets.Log;\n145:   private statusBar: Widgets.BoxElement;\n146:   private buildLogBox: Widgets.Log;\n147: \n148:   private state: WaveState;\n149:   private monitor: ProcessMonitor;\n150:   private onQuit: () => void;\n151:   private onRetry?: (featureId: string) => void;\n152:   private onAnswer?: (agentId: string, questionId: string, answerText: string) => void;\n153:   private onBeforeDestroy?: () => void;\n154:   private interactive: boolean;\n155:   private projectRoot: string;\n156:   private config: WomboConfig;\n157: \n158:   private selectedIndex: number = 0;\n159:   private autoScroll: boolean = true;\n160:   private showingBuildLog: boolean = false;\n161:   private showingLogFile: boolean = false;\n162:   private logFileBox: Widgets.Log | null = null;\n163:   private refreshTimer: ReturnType<typeof setInterval> | null = null;\n164:   private waveComplete: boolean = false;\n165:   private waveCompleteResolve: (() => void) | null = null;\n166: \n167:   /** Pending HITL questions from agents */\n168:   private pendingQuestions: HitlQuestion[] = [];\n169:   /** Active question popup (null when closed) */\n170:   private questionPopup: QuestionPopup | null = null;\n171: \n172:   /** Saved originals for console interception */\n173:   private origConsoleLog: typeof console.log = console.log;\n174:   private origConsoleError: typeof console.error = console.error;\n175:   private origConsoleWarn: typeof console.warn = console.warn;\n176:   /** System messages captured while TUI is active */\n177:   private systemMessages: ActivityEntry[] = [];\n178: \n179:   constructor(opts: TUIOptions) {\n180:     this.state = opts.state;\n181:     this.monitor = opts.monitor;\n182:     this.onQuit = opts.onQuit;\n183:     this.onRetry = opts.onRetry;\n184:     this.onAnswer = opts.onAnswer;\n185:     this.onBeforeDestroy = opts.onBeforeDestroy;\n186:     this.interactive = opts.interactive ?? false;\n187:     this.projectRoot = opts.projectRoot;\n188:     this.config = opts.config;\n189: \n190:     // Create screen\n191:     this.screen = blessed.screen({\n192:       smartCSR: true,\n193:       title: `wombo-combo — ${opts.state.wave_id}`,\n194:       fullUnicode: true,\n195:     });\n196: \n197:     // Header\n198:     this.headerBox = blessed.box({\n199:       top: 0,\n200:       left: 0,\n201:       width: \"100%\",\n202:       height: 3,\n203:       tags: true,\n204:       style: {\n205:         fg: \"white\",\n206:         bg: \"black\",\n207:       },\n208:     });\n209: \n210:     // Agent list (left pane)\n211:     this.agentList = blessed.list({\n212:       top: 3,\n213:       left: 0,\n214:       width: \"55%\",\n215:       height: \"100%-6\",\n216:       tags: true,\n217:       scrollable: true,\n218:       mouse: true,\n219:       keys: true,\n220:       vi: true,\n221:       border: {\n222:         type: \"line\",\n223:       },\n224:       style: {\n225:         border: { fg: \"gray\" },\n226:         selected: {\n227:           bg: \"blue\",\n228:           fg: \"white\",\n229:           bold: true,\n230:         },\n231:         item: {\n232:           fg: \"white\",\n233:         },\n234:       },\n235:       label: \" Agents \",\n236:     });\n237: \n238:     // Preview pane (right pane)\n239:     this.previewBox = blessed.log({\n240:       top: 3,\n241:       left: \"55%\",\n242:       width: \"45%\",\n243:       height: \"100%-6\",\n244:       tags: true,\n245:       scrollable: true,\n246:       mouse: true,\n247:       keys: false,\n248:       scrollbar: {\n249:         ch: \"│\",\n250:         style: { fg: \"cyan\" },\n251:       },\n252:       border: {\n253:         type: \"line\",\n254:       },\n255:       style: {\n256:         border: { fg: \"gray\" },\n257:         fg: \"white\",\n258:       },\n259:       label: \" Activity \",\n260:     });\n261: \n262:     // Build log overlay (hidden by default)\n263:     this.buildLogBox = blessed.log({\n264:       top: 3,\n265:       left: \"10%\",\n266:       width: \"80%\",\n267:       height: \"100%-6\",\n268:       tags: true,\n269:       scrollable: true,\n270:       mouse: true,\n271:       keys: true,\n272:       scrollbar: {\n273:         ch: \"│\",\n274:         style: { fg: \"yellow\" },\n275:       },\n276:       border: {\n277:         type: \"line\",\n278:       },\n279:       style: {\n280:         border: { fg: \"yellow\" },\n281:         fg: \"white\",\n282:       },\n283:       label: \" Build Log \",\n284:       hidden: true,\n285:     });\n286: \n287:     // Status bar\n288:     this.statusBar = blessed.box({\n289:       bottom: 0,\n290:       left: 0,\n291:       width: \"100%\",\n292:       height: 3,\n293:       tags: true,\n294:       style: {\n295:         fg: \"white\",\n296:         bg: \"black\",\n297:       },\n298:     });\n299: \n300:     // Assemble\n301:     this.screen.append(this.headerBox);\n302:     this.screen.append(this.agentList);\n303:     this.screen.append(this.previewBox);\n304:     this.screen.append(this.buildLogBox);\n305:     this.screen.append(this.statusBar);\n306: \n307:     // Focus the agent list\n308:     this.agentList.focus();\n309: \n310:     // Bind keys\n311:     this.bindKeys();\n312:   }\n313: \n314:   // -------------------------------------------------------------------------\n315:   // Key Bindings\n316:   // -------------------------------------------------------------------------\n317: \n318:   private bindKeys(): void {\n319:     // Quit\n320:     this.screen.key([\"q\", \"C-c\"], () => {\n321:       this.stop();\n322:       if (this.waveComplete && this.waveCompleteResolve) {\n323:         // Wave is done — just close TUI and resolve the wait promise\n324:         this.waveCompleteResolve();\n325:       } else {\n326:         // Wave still running — trigger the abort/interrupt handler\n327:         this.onQuit();\n328:       }\n329:     });\n330: \n331:     // Navigate agent list\n332:     this.agentList.on(\"select item\", (_item: any, index: number) => {\n333:       this.selectedIndex = index;\n334:       this.refreshPreview();\n335:     });\n336: \n337:     // Enter — multiplexer attach\n338:     this.screen.key([\"enter\"], () => {\n339:       this.muxAttach();\n340:     });\n341: \n342:     // b — toggle build log\n343:     this.screen.key([\"b\"], () => {\n344:       this.toggleBuildLog();\n345:     });\n346: \n347:     // p — toggle auto-scroll\n348:     this.screen.key([\"p\"], () => {\n349:       this.autoScroll = !this.autoScroll;\n350:       this.refreshStatusBar();\n351:     });\n352: \n353:     // r — retry failed/stuck agent\n354:     this.screen.key([\"r\"], () => {\n355:       this.retrySelected();\n356:     });\n357: \n358:     // h — open HITL question popup\n359:     this.screen.key([\"h\"], () => {\n360:       this.openQuestionPopup();\n361:     });\n362: \n363:     // Escape — close build log, log file overlay, or question popup\n364:     this.screen.key([\"escape\"], () => {\n365:       if (this.questionPopup && !this.questionPopup.isDestroyed()) {\n366:         this.questionPopup.close();\n367:         this.questionPopup = null;\n368:         this.agentList.focus();\n369:         this.screen.render();\n370:       } else if (this.showingBuildLog) {\n371:         this.showingBuildLog = false;\n372:         this.buildLogBox.hide();\n373:         this.agentList.focus();\n374:         this.screen.render();\n375:       } else if (this.showingLogFile && this.logFileBox) {\n376:         this.showingLogFile = false;\n377:         this.logFileBox.destroy();\n378:         this.logFileBox = null;\n379:         this.agentList.focus();\n380:         this.screen.render();\n381:       }\n382:     });\n383:   }\n384: \n385:   // -------------------------------------------------------------------------\n386:   // Start / Stop\n387:   //\n388:   // ## TUI Lifecycle and Agent Processes (audit: wave-detach-audit)\n389:   //\n390:   // `stop()` only tears down the TUI — it clears the refresh timer and\n391:   // destroys the blessed screen. It does NOT kill agent processes.\n392:   //\n393:   // Agent process termination is handled by the `onQuit` callback, which\n394:   // is set by launch.ts/resume.ts to call `monitor.killAll()` + state save.\n395:   //\n396:   // The separation is intentional:\n397:   //   - `stop()` is also called before mux attach (muxAttach method) where\n398:   //     the TUI is temporarily destroyed and recreated after detach.\n399:   //   - `onQuit()` is only called when the user intends to exit the entire\n400:   //     wave, triggering agent cleanup and process exit.\n401:   //\n402:   // `screen.destroy()` does NOT affect child processes because agents are\n403:   // spawned by the ProcessMonitor (in the launch command), not by the TUI.\n404:   // The TUI only reads from the monitor — it never owns agent processes.\n405:   // -------------------------------------------------------------------------\n406: \n407:   start(): void {\n408:     this.interceptConsole();\n409:     this.refresh();\n410:     this.screen.render();\n411: \n412:     // Auto-refresh every 2 seconds\n413:     this.refreshTimer = setInterval(() => {\n414:       this.refresh();\n415:     }, 2000);\n416:   }\n417: \n418:   stop(): void {\n419:     this.restoreConsole();\n420:     if (this.refreshTimer) {\n421:       clearInterval(this.refreshTimer);\n422:       this.refreshTimer = null;\n423:     }\n424:     // Flush pending state writes before destroying the screen.\n425:     // This ensures state.json integrity even if process.exit() follows.\n426:     if (this.onBeforeDestroy) {\n427:       try {\n428:         this.onBeforeDestroy();\n429:       } catch {\n430:         // Best-effort — don't let flush errors prevent screen cleanup\n431:       }\n432:     }\n433:     this.screen.destroy();\n434:   }\n435: \n436:   /**\n437:    * Intercept console.log/error/warn so they don't corrupt the TUI.\n438:    * Messages are captured into systemMessages and shown in the preview\n439:    * when no specific agent is producing activity.\n440:    */\n441:   private interceptConsole(): void {\n442:     this.origConsoleLog = console.log;\n443:     this.origConsoleError = console.error;\n444:     this.origConsoleWarn = console.warn;\n445: \n446:     const capture = (...args: any[]) => {\n447:       const text = args\n448:         .map((a) => (typeof a === \"string\" ? a : JSON.stringify(a)))\n449:         .join(\" \");\n450:       // Strip ANSI codes for clean TUI display\n451:       const clean = text.replace(/\\x1b\\[[0-9;]*m/g, \"\");\n452:       if (!clean.trim()) return;\n453:       this.systemMessages.push({\n454:         timestamp: new Date().toISOString().slice(11, 19),\n455:         text: clean,\n456:       });\n457:       // Keep bounded\n458:       if (this.systemMessages.length > 200) {\n459:         this.systemMessages.splice(0, this.systemMessages.length - 200);\n460:       }\n461:     };\n462: \n463:     console.log = capture;\n464:     console.error = capture;\n465:     console.warn = capture;\n466:   }\n467: \n468:   /**\n469:    * Restore original console methods.\n470:    */\n471:   private restoreConsole(): void {\n472:     console.log = this.origConsoleLog;\n473:     console.error = this.origConsoleError;\n474:     console.warn = this.origConsoleWarn;\n475:   }\n476: \n477:   /**\n478:    * Update the state reference (called from the monitoring loop).\n479:    */\n480:   updateState(state: WaveState): void {\n481:     this.state = state;\n482:   }\n483: \n484:   /**\n485:    * Mark the wave as complete. The TUI stays open so the user can browse\n486:    * agent logs, build output, etc. The header shows a WAVE COMPLETE banner\n487:    * and the status bar tells the user to press q to exit.\n488:    */\n489:   markWaveComplete(): void {\n490:     this.waveComplete = true;\n491:     this.refresh();\n492:   }\n493: \n494:   /**\n495:    * Returns a Promise that resolves when the user presses q to quit.\n496:    * Used after wave completion so the TUI stays open for post-mortem browsing.\n497:    */\n498:   waitForQuit(): Promise<void> {\n499:     return new Promise<void>((resolve) => {\n500:       this.waveCompleteResolve = resolve;\n501:     });\n502:   }\n503: \n504:   /**\n505:    * Update pending HITL questions. Called from the monitoring loop.\n506:    * If the question popup is open, it gets live-updated too.\n507:    */\n508:   setPendingQuestions(questions: HitlQuestion[]): void {\n509:     this.pendingQuestions = questions;\n510:     if (this.questionPopup && !this.questionPopup.isDestroyed()) {\n511:       this.questionPopup.updateQuestions(questions);\n512:     }\n513:     // Status bar will pick up the badge on next refresh cycle\n514:   }\n515: \n516:   /**\n517:    * Open the HITL question popup modal.\n518:    */\n519:   private openQuestionPopup(): void {\n520:     // Don't open if already open\n521:     if (this.questionPopup && !this.questionPopup.isDestroyed()) return;\n522: \n523:     // Don't open if there are no pending questions\n524:     if (this.pendingQuestions.length === 0) {\n525:       // Flash a message in the preview\n526:       const agent = this.state.agents[this.selectedIndex];\n527:       if (agent) {\n528:         const logs = this.monitor.activityLogs.get(agent.feature_id);\n529:         if (logs) {\n530:           logs.push({\n531:             timestamp: new Date().toISOString().slice(11, 19),\n532:             text: `-- No pending HITL questions`,\n533:           });\n534:         }\n535:         this.refreshPreview();\n536:         this.screen.render();\n537:       }\n538:       return;\n539:     }\n540: \n541:     this.questionPopup = new QuestionPopup(\n542:       this.screen,\n543:       [...this.pendingQuestions], // copy so popup can mutate internally\n544:       {\n545:         onAnswer: (agentId, questionId, answerText) => {\n546:           // Forward to the external callback (which calls submitAnswer)\n547:           if (this.onAnswer) {\n548:             this.onAnswer(agentId, questionId, answerText);\n549:           }\n550:           // Remove from our pending list\n551:           this.pendingQuestions = this.pendingQuestions.filter(\n552:             (q) => !(q.agentId === agentId && q.id === questionId)\n553:           );\n554:         },\n555:         onClose: () => {\n556:           this.questionPopup = null;\n557:           this.agentList.focus();\n558:           this.refreshStatusBar();\n559:           this.screen.render();\n560:         },\n561:       }\n562:     );\n563:   }\n564: \n565:   // -------------------------------------------------------------------------\n566:   // Refresh Logic\n567:   // -------------------------------------------------------------------------\n568: \n569:   private refresh(): void {\n570:     this.refreshHeader();\n571:     this.refreshAgentList();\n572:     this.refreshPreview();\n573:     this.refreshStatusBar();\n574:     this.screen.render();\n575:   }\n576: \n577:   private refreshHeader(): void {\n578:     const s = this.state;\n579:     const counts = agentCounts(s);\n580:     const total = s.agents.length;\n581:     const done = counts.verified + counts.merged;\n582: \n583:     let line1 = ` {bold}wombo-combo{/bold} {gray-fg}${s.wave_id}{/gray-fg}`;\n584:     if (this.waveComplete) {\n585:       line1 += `  {gray-fg}│{/gray-fg}  {bold}{green-fg}WAVE COMPLETE{/green-fg}{/bold}`;\n586:     }\n587:     line1 += `  {gray-fg}│{/gray-fg}  Base: {cyan-fg}${s.base_branch}{/cyan-fg}`;\n588:     line1 += `  {gray-fg}│{/gray-fg}  Mode: ${s.interactive ? \"{green-fg}interactive{/green-fg}\" : \"{blue-fg}headless{/blue-fg}\"}`;\n589:     if (s.model) {\n590:       line1 += `  {gray-fg}│{/gray-fg}  Model: {yellow-fg}${s.model}{/yellow-fg}`;\n591:     }\n592: \n593:     let line2 = ` Progress: {green-fg}${done}{/green-fg}/{white-fg}${total}{/white-fg}`;\n594:     if (counts.running > 0)\n595:       line2 += `  {blue-fg}${counts.running} running{/blue-fg}`;\n596:     if (counts.failed > 0)\n597:       line2 += `  {red-fg}${counts.failed} failed{/red-fg}`;\n598:     if (counts.queued > 0)\n599:       line2 += `  {gray-fg}${counts.queued} queued{/gray-fg}`;\n600:     if (counts.retry > 0)\n601:       line2 += `  {yellow-fg}${counts.retry} retrying{/yellow-fg}`;\n602:     if (counts.resolving_conflict > 0)\n603:       line2 += `  {cyan-fg}${counts.resolving_conflict} resolving{/cyan-fg}`;\n604: \n605:     this.headerBox.setContent(`${line1}\\n${line2}`);\n606:   }\n607: \n608:   private refreshAgentList(): void {\n609:     const items: string[] = [];\n610: \n611:     for (let i = 0; i < this.state.agents.length; i++) {\n612:       const a = this.state.agents[i];\n613:       const color = STATUS_COLORS[a.status];\n614:       const icon = STATUS_ICONS[a.status];\n615: \n616:       // Feature ID (padded)\n617:       const fid =\n618:         a.feature_id.length > 24\n619:           ? a.feature_id.slice(0, 23) + \"…\"\n620:           : a.feature_id.padEnd(24);\n621: \n622:       // Status\n623:       const st = `{${color}-fg}${icon} ${a.status.padEnd(10)}{/${color}-fg}`;\n624: \n625:       // Progress bar\n626:       let pbar = \"\";\n627:       if ((a.status === \"running\" || a.status === \"resolving_conflict\") && a.started_at) {\n628:         const elapsedMs = Date.now() - new Date(a.started_at).getTime();\n629:         // Use actual effort estimate from feature data, fallback to 1h\n630:         const estimateMs = a.effort_estimate_ms ?? 60 * 60 * 1000;\n631:         pbar = ` {cyan-fg}${progressBar(elapsedMs, estimateMs, 8)}{/cyan-fg}`;\n632:       } else if (a.status === \"verified\" || a.status === \"merged\") {\n633:         pbar = ` {green-fg}${\"█\".repeat(8)}{/green-fg}`;\n634:       } else if (a.status === \"failed\") {\n635:         pbar = ` {red-fg}${\"█\".repeat(8)}{/red-fg}`;\n636:       }\n637: \n638:       // Activity (for running/resolving agents)\n639:       let act = \"\";\n640:       if ((a.status === \"running\" || a.status === \"resolving_conflict\") && a.activity) {\n641:         const rawAct =\n642:           a.activity.length > 25 ? a.activity.slice(0, 24) + \"…\" : a.activity;\n643:         const actText = escapeBlessedTags(rawAct);\n644:         act = ` {cyan-fg}${actText}{/cyan-fg}`;\n645:       } else if (a.status === \"installing\") {\n646:         act = \" {cyan-fg}setting up…{/cyan-fg}\";\n647:       }\n648: \n649:       // Elapsed\n650:       const el = elapsed(a.started_at);\n651: \n652:       // Retries\n653:       const retries =\n654:         a.retries > 0 ? ` {yellow-fg}↻${a.retries}{/yellow-fg}` : \"\";\n655: \n656:       items.push(\n657:         ` ${fid} ${st}${pbar}${act}${retries} {gray-fg}${el}{/gray-fg}`\n658:       );\n659:     }\n660: \n661:     // Preserve selection\n662:     const prevSelected = this.selectedIndex;\n663:     this.agentList.setItems(items as any);\n664:     if (prevSelected < items.length) {\n665:       this.agentList.select(prevSelected);\n666:     }\n667:   }\n668: \n669:   private refreshPreview(): void {\n670:     const agent = this.state.agents[this.selectedIndex];\n671:     if (!agent) {\n672:       this.previewBox.setContent(\"{gray-fg}No agent selected{/gray-fg}\");\n673:       return;\n674:     }\n675: \n676:     // Update label\n677:     this.previewBox.setLabel(` ${agent.feature_id} — Activity `);\n678: \n679:     // Get activity log from monitor\n680:     const log = this.monitor.getActivityLog(agent.feature_id);\n681: \n682:     // Also include system messages (build verification, etc.)\n683:     // that mention this agent's feature_id\n684:     const relevantSys = this.systemMessages.filter((m) =>\n685:       m.text.includes(agent.feature_id)\n686:     );\n687: \n688:     if (log.length === 0 && relevantSys.length === 0) {\n689:       this.previewBox.setContent(\n690:         \"{gray-fg}No activity yet. Waiting for agent output…{/gray-fg}\"\n691:       );\n692:       return;\n693:     }\n694: \n695:     // Format log entries\n696:     const lines: string[] = [];\n697:     for (const entry of log) {\n698:       lines.push(this.formatActivityLine(entry));\n699:     }\n700: \n701:     // Append relevant system messages\n702:     if (relevantSys.length > 0) {\n703:       lines.push(\"\");\n704:       lines.push(\"{yellow-fg}-- system --{/yellow-fg}\");\n705:       for (const entry of relevantSys) {\n706:         const ts = `{gray-fg}${entry.timestamp}{/gray-fg}`;\n707:         lines.push(`${ts} {yellow-fg}${escapeBlessedTags(entry.text)}{/yellow-fg}`);\n708:       }\n709:     }\n710: \n711:     this.previewBox.setContent(lines.join(\"\\n\"));\n712: \n713:     // Auto-scroll to bottom\n714:     if (this.autoScroll) {\n715:       this.previewBox.setScrollPerc(100);\n716:     }\n717:   }\n718: \n719:   private formatActivityLine(entry: ActivityEntry): string {\n720:     const ts = `{gray-fg}${entry.timestamp}{/gray-fg}`;\n721:     let text = escapeBlessedTags(entry.text);\n722: \n723:     // Color-code different line types\n724:     if (text.startsWith(\">>\")) {\n725:       text = `{cyan-fg}${text}{/cyan-fg}`;\n726:     } else if (text.startsWith(\"!!\")) {\n727:       text = `{red-fg}${text}{/red-fg}`;\n728:     } else if (text.startsWith(\"--\")) {\n729:       text = `{green-fg}${text}{/green-fg}`;\n730:     } else if (text.startsWith(\"[stderr]\")) {\n731:       text = `{red-fg}${text}{/red-fg}`;\n732:     } else if (text.startsWith(\"[raw]\")) {\n733:       text = `{gray-fg}${text}{/gray-fg}`;\n734:     } else if (text.startsWith(\"   \")) {\n735:       text = `{white-fg}${text}{/white-fg}`;\n736:     }\n737: \n738:     return `${ts} ${text}`;\n739:   }\n740: \n741:   private refreshStatusBar(): void {\n742:     const scrollStatus = this.autoScroll\n743:       ? \"{green-fg}auto-scroll{/green-fg}\"\n744:       : \"{yellow-fg}paused{/yellow-fg}\";\n745: \n746:     const agent = this.state.agents[this.selectedIndex];\n747:     const agentInfo = agent\n748:       ? `{gray-fg}Selected: {white-fg}${agent.feature_id}{/white-fg}{/gray-fg}`\n749:       : \"\";\n750: \n751:     const enterHint = this.interactive\n752:       ? \"{gray-fg}Enter{/gray-fg} attach session\"\n753:       : \"{gray-fg}Enter{/gray-fg} view log\";\n754: \n755:     // HITL badge — show only when there are pending questions\n756:     const hitlBadge =\n757:       this.pendingQuestions.length > 0\n758:         ? `  {bold}{yellow-fg}? ${this.pendingQuestions.length} pending{/yellow-fg}{/bold}  {gray-fg}H{/gray-fg} answer`\n759:         : \"\";\n760: \n761:     let line1: string;\n762:     if (this.waveComplete) {\n763:       line1 = ` {bold}{green-fg}Wave complete.{/green-fg}{/bold}  ${enterHint}  {gray-fg}R{/gray-fg} retry  {gray-fg}B{/gray-fg} build log  {gray-fg}P{/gray-fg} ${scrollStatus}${hitlBadge}  {bold}{yellow-fg}Q{/yellow-fg} exit{/bold}`;\n764:     } else {\n765:       line1 = ` {bold}Keys:{/bold} {gray-fg}\\u2191\\u2193{/gray-fg} navigate  ${enterHint}  {gray-fg}R{/gray-fg} retry  {gray-fg}B{/gray-fg} build log  {gray-fg}P{/gray-fg} ${scrollStatus}${hitlBadge}  {gray-fg}Q{/gray-fg} quit`;\n766:     }\n767:     const line2 = ` ${agentInfo}`;\n768: \n769:     this.statusBar.setContent(`${line1}\\n${line2}`);\n770:   }\n771: \n772:   // -------------------------------------------------------------------------\n773:   // Actions\n774:   // -------------------------------------------------------------------------\n775: \n776:   private muxAttach(): void {\n777:     const agent = this.state.agents[this.selectedIndex];\n778:     if (!agent) return;\n779: \n780:     if (!this.interactive) {\n781:       // Headless mode — show the raw log file in an overlay\n782:       this.showLogFile(agent);\n783:       return;\n784:     }\n785: \n786:     const mux = detectMultiplexer(this.config.agent.multiplexer);\n787:     const sessionName = `${this.config.agent.tmuxPrefix}-${agent.feature_id}`;\n788: \n789:     // Check if multiplexer session exists\n790:     if (!muxHasSession(mux, sessionName)) {\n791:       // No session — show message in preview\n792:       this.monitor.activityLogs.get(agent.feature_id)?.push({\n793:         timestamp: new Date().toISOString().slice(11, 19),\n794:         text: `!! No ${muxDisplayName(mux)} session '${sessionName}' found`,\n795:       });\n796:       this.refreshPreview();\n797:       this.screen.render();\n798:       return;\n799:     }\n800: \n801:     // Detach from blessed, attach to multiplexer session\n802:     this.restoreConsole();\n803:     this.screen.destroy();\n804:     try {\n805:       muxAttach(mux, sessionName);\n806:     } catch {\n807:       // User detached from session — resume TUI\n808:     }\n809: \n810:     // Re-create screen after returning from multiplexer\n811:     this.recreateScreen();\n812:   }\n813: \n814:   /**\n815:    * Retry the selected agent (only if failed or stuck in retry).\n816:    * Resets it to \"queued\" so the polling loop picks it up for a fresh launch.\n817:    */\n818:   private retrySelected(): void {\n819:     const agent = this.state.agents[this.selectedIndex];\n820:     if (!agent) return;\n821: \n822:     const retryableStatuses: AgentStatus[] = [\"failed\", \"retry\"];\n823:     if (!retryableStatuses.includes(agent.status)) {\n824:       // Flash a message in the preview — agent isn't in a retryable state\n825:       const logs = this.monitor.activityLogs.get(agent.feature_id);\n826:       if (logs) {\n827:         logs.push({\n828:           timestamp: new Date().toISOString().slice(11, 19),\n829:           text: `!! Cannot retry — agent status is \"${agent.status}\" (must be failed or retry)`,\n830:         });\n831:       }\n832:       this.refreshPreview();\n833:       this.screen.render();\n834:       return;\n835:     }\n836: \n837:     if (this.onRetry) {\n838:       this.onRetry(agent.feature_id);\n839: \n840:       // Show feedback in preview\n841:       const logs = this.monitor.activityLogs.get(agent.feature_id);\n842:       if (logs) {\n843:         logs.push({\n844:           timestamp: new Date().toISOString().slice(11, 19),\n845:           text: `>> Retry requested — agent will be relaunched`,\n846:         });\n847:       }\n848:       this.refresh();\n849:       this.screen.render();\n850:     }\n851:   }\n852: \n853:   /**\n854:    * Show the raw log file for an agent in an overlay (headless mode).\n855:    */\n856:   private showLogFile(agent: AgentState): void {\n857:     if (this.showingLogFile) {\n858:       // Toggle off\n859:       this.showingLogFile = false;\n860:       if (this.logFileBox) {\n861:         this.logFileBox.destroy();\n862:         this.logFileBox = null;\n863:       }\n864:       this.agentList.focus();\n865:       this.screen.render();\n866:       return;\n867:     }\n868: \n869:     const logPath = resolve(\n870:       this.projectRoot,\n871:       \".wombo-combo\",\n872:       \"logs\",\n873:       `${agent.feature_id}.log`\n874:     );\n875:     let content: string;\n876:     try {\n877:       content = readFileSync(logPath, \"utf-8\");\n878:       if (!content.trim()) {\n879:         content =\n880:           \"{gray-fg}Log file is empty. Agent may not have started producing output yet.{/gray-fg}\";\n881:       }\n882:     } catch {\n883:       content = \"{gray-fg}No log file found at \" + logPath + \"{/gray-fg}\";\n884:     }\n885: \n886:     // Create overlay\n887:     this.logFileBox = blessed.log({\n888:       top: 3,\n889:       left: \"5%\",\n890:       width: \"90%\",\n891:       height: \"100%-6\",\n892:       tags: true,\n893:       scrollable: true,\n894:       mouse: true,\n895:       keys: true,\n896:       scrollbar: {\n897:         ch: \"│\",\n898:         style: { fg: \"cyan\" },\n899:       },\n900:       border: {\n901:         type: \"line\",\n902:       },\n903:       style: {\n904:         border: { fg: \"cyan\" },\n905:         fg: \"white\",\n906:       },\n907:       label: ` Log — ${agent.feature_id} (Esc to close) `,\n908:     });\n909: \n910:     this.screen.append(this.logFileBox);\n911: \n912:     // Truncate to last 200 lines to keep TUI responsive\n913:     const lines = content.split(\"\\n\");\n914:     const truncated =\n915:       lines.length > 200 ? lines.slice(-200).join(\"\\n\") : content;\n916:     this.logFileBox.setContent(escapeBlessedTags(truncated));\n917:     this.logFileBox.setScrollPerc(100);\n918:     this.logFileBox.focus();\n919:     this.showingLogFile = true;\n920:     this.screen.render();\n921:   }\n922: \n923:   private toggleBuildLog(): void {\n924:     const agent = this.state.agents[this.selectedIndex];\n925:     if (!agent) return;\n926: \n927:     if (this.showingBuildLog) {\n928:       this.showingBuildLog = false;\n929:       this.buildLogBox.hide();\n930:       this.agentList.focus();\n931:     } else {\n932:       this.showingBuildLog = true;\n933:       this.buildLogBox.setLabel(` Build Log — ${agent.feature_id} `);\n934: \n935:       if (agent.build_output) {\n936:         this.buildLogBox.setContent(escapeBlessedTags(agent.build_output));\n937:       } else if (agent.build_passed === true) {\n938:         this.buildLogBox.setContent(\n939:           \"{green-fg}Build passed — no errors.{/green-fg}\"\n940:         );\n941:       } else if (agent.build_passed === false) {\n942:         this.buildLogBox.setContent(\n943:           \"{red-fg}Build failed — no output captured.{/red-fg}\"\n944:         );\n945:       } else {\n946:         this.buildLogBox.setContent(\n947:           \"{gray-fg}No build has been run yet.{/gray-fg}\"\n948:         );\n949:       }\n950: \n951:       this.buildLogBox.show();\n952:       this.buildLogBox.focus();\n953:     }\n954:     this.screen.render();\n955:   }\n956: \n957:   /**\n958:    * Re-create the screen after returning from multiplexer attach.\n959:    * Blessed can't resume after destroy, so we rebuild everything.\n960:    */\n961:   private recreateScreen(): void {\n962:     // Re-create screen\n963:     this.screen = blessed.screen({\n964:       smartCSR: true,\n965:       title: `wombo-combo — ${this.state.wave_id}`,\n966:       fullUnicode: true,\n967:     });\n968: \n969:     // Re-create all widgets\n970:     this.headerBox = blessed.box({\n971:       top: 0,\n972:       left: 0,\n973:       width: \"100%\",\n974:       height: 3,\n975:       tags: true,\n976:       style: { fg: \"white\", bg: \"black\" },\n977:     });\n978: \n979:     this.agentList = blessed.list({\n980:       top: 3,\n981:       left: 0,\n982:       width: \"55%\",\n983:       height: \"100%-6\",\n984:       tags: true,\n985:       scrollable: true,\n986:       mouse: true,\n987:       keys: true,\n988:       vi: true,\n989:       border: { type: \"line\" },\n990:       style: {\n991:         border: { fg: \"gray\" },\n992:         selected: { bg: \"blue\", fg: \"white\", bold: true },\n993:         item: { fg: \"white\" },\n994:       },\n995:       label: \" Agents \",\n996:     });\n997: \n998:     this.previewBox = blessed.log({\n999:       top: 3,\n1000:       left: \"55%\",\n1001:       width: \"45%\",\n1002:       height: \"100%-6\",\n1003:       tags: true,\n1004:       scrollable: true,\n1005:       mouse: true,\n1006:       keys: false,\n1007:       scrollbar: { ch: \"│\", style: { fg: \"cyan\" } },\n1008:       border: { type: \"line\" },\n1009:       style: { border: { fg: \"gray\" }, fg: \"white\" },\n1010:       label: \" Activity \",\n1011:     });\n1012: \n1013:     this.buildLogBox = blessed.log({\n1014:       top: 3,\n1015:       left: \"10%\",\n1016:       width: \"80%\",\n1017:       height: \"100%-6\",\n1018:       tags: true,\n1019:       scrollable: true,\n1020:       mouse: true,\n1021:       keys: true,\n1022:       scrollbar: { ch: \"│\", style: { fg: \"yellow\" } },\n1023:       border: { type: \"line\" },\n1024:       style: { border: { fg: \"yellow\" }, fg: \"white\" },\n1025:       label: \" Build Log \",\n1026:       hidden: true,\n1027:     });\n1028: \n1029:     this.statusBar = blessed.box({\n1030:       bottom: 0,\n1031:       left: 0,\n1032:       width: \"100%\",\n1033:       height: 3,\n1034:       tags: true,\n1035:       style: { fg: \"white\", bg: \"black\" },\n1036:     });\n1037: \n1038:     this.screen.append(this.headerBox);\n1039:     this.screen.append(this.agentList);\n1040:     this.screen.append(this.previewBox);\n1041:     this.screen.append(this.buildLogBox);\n1042:     this.screen.append(this.statusBar);\n1043: \n1044:     this.agentList.focus();\n1045:     this.showingBuildLog = false;\n1046:     this.showingLogFile = false;\n1047:     this.logFileBox = null;\n1048:     this.questionPopup = null;\n1049:     this.interceptConsole();\n1050:     this.bindKeys();\n1051:     this.refresh();\n1052:   }\n1053: }\n\n(End of file - total 1053 lines)\n</content>","title":"src/lib/tui.ts","metadata":{"preview":"/**\n * tui.ts — Blessed-based TUI dashboard for wombo-combo.\n *\n * Layout:\n *   ┌─────────────────────────────────────────────┐\n *   │ Header: Wave ID, base branch, mode, model   │\n *   ├──────────────────────────┬──────────────────┤\n *   │ Agent Table              │ Preview Pane     │\n *   │ (selectable rows with    │ (parsed activity │\n *   │  status, activity,       │  stream for the  │\n *   │  progress bars, elapsed) │  selected agent) │\n *   ├──────────────────────────┴──────────────────┤\n *   │ Status bar: keybinds + summary counts       │\n *   └─────────────────────────────────────────────┘\n *\n * Keybinds:\n *   Up/Down   — navigate agent list\n *   Enter     — attach to selected agent's multiplexer session (interactive mode)\n *   r         — retry a failed/stuck agent\n *   b         — show build log for selected agent","truncated":false,"loaded":[]},"time":{"start":1773483368894,"end":1773483368911}}}}
