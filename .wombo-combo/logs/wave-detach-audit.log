{"type":"tool_use","timestamp":1773481740479,"sessionID":"ses_3144093abffe4EFLXWMouX7qVB","part":{"id":"prt_cebbfc3980014tL80lyM9hzsE3","sessionID":"ses_3144093abffe4EFLXWMouX7qVB","messageID":"msg_cebbfb751001HPxGiWxXAwyuhE","type":"tool","callID":"toolu_vrtx_012t9UQjF27cHXsUVmutZBuh","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/wave-detach-audit/src/lib/multiplexer.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/wave-detach-audit/src/lib/multiplexer.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * multiplexer.ts — Abstraction layer for terminal multiplexers (dmux/tmux).\n3:  *\n4:  * Provides a unified API for session management that works with either\n5:  * dmux (preferred, Rust-based) or tmux (fallback). Auto-detects which\n6:  * multiplexer is available, preferring dmux when both are present.\n7:  *\n8:  * Configurable via .wombo-combo/config.json `agent.multiplexer` field:\n9:  *   - \"auto\"  — prefer dmux, fall back to tmux (default)\n10:  *   - \"dmux\"  — use dmux only (error if not available)\n11:  *   - \"tmux\"  — use tmux only (error if not available)\n12:  */\n13: \n14: import { execSync } from \"node:child_process\";\n15: \n16: // ---------------------------------------------------------------------------\n17: // Types\n18: // ---------------------------------------------------------------------------\n19: \n20: export type MultiplexerBackend = \"dmux\" | \"tmux\";\n21: export type MultiplexerPreference = \"auto\" | \"dmux\" | \"tmux\";\n22: \n23: export interface MultiplexerInfo {\n24:   /** Which backend is active */\n25:   backend: MultiplexerBackend;\n26:   /** The binary name (e.g., \"dmux\" or \"tmux\") */\n27:   bin: string;\n28: }\n29: \n30: // ---------------------------------------------------------------------------\n31: // Detection\n32: // ---------------------------------------------------------------------------\n33: \n34: /** Cache the detection result so we only check once per process. */\n35: let cachedDetection: MultiplexerInfo | null = null;\n36: let cachedPreference: MultiplexerPreference | null = null;\n37: \n38: function isAvailable(bin: string): boolean {\n39:   try {\n40:     execSync(`which ${bin}`, { encoding: \"utf-8\", stdio: \"pipe\" });\n41:     return true;\n42:   } catch {\n43:     return false;\n44:   }\n45: }\n46: \n47: /**\n48:  * Detect which multiplexer is available. Results are cached.\n49:  *\n50:  * @param preference - User preference from config (\"auto\", \"dmux\", \"tmux\")\n51:  * @returns MultiplexerInfo with the selected backend\n52:  * @throws Error if the preferred multiplexer is not available\n53:  */\n54: export function detectMultiplexer(\n55:   preference: MultiplexerPreference = \"auto\"\n56: ): MultiplexerInfo {\n57:   // Return cached result if preference hasn't changed\n58:   if (cachedDetection && cachedPreference === preference) {\n59:     return cachedDetection;\n60:   }\n61: \n62:   let result: MultiplexerInfo;\n63: \n64:   switch (preference) {\n65:     case \"dmux\":\n66:       if (!isAvailable(\"dmux\")) {\n67:         throw new Error(\n68:           \"dmux is configured as the multiplexer but is not installed. \" +\n69:             \"Install dmux or set agent.multiplexer to 'auto' or 'tmux' in .wombo-combo/config.json.\"\n70:         );\n71:       }\n72:       result = { backend: \"dmux\", bin: \"dmux\" };\n73:       break;\n74: \n75:     case \"tmux\":\n76:       if (!isAvailable(\"tmux\")) {\n77:         throw new Error(\n78:           \"tmux is configured as the multiplexer but is not installed. \" +\n79:             \"Install tmux or set agent.multiplexer to 'auto' or 'dmux' in .wombo-combo/config.json.\"\n80:         );\n81:       }\n82:       result = { backend: \"tmux\", bin: \"tmux\" };\n83:       break;\n84: \n85:     case \"auto\":\n86:     default:\n87:       if (isAvailable(\"dmux\")) {\n88:         result = { backend: \"dmux\", bin: \"dmux\" };\n89:       } else if (isAvailable(\"tmux\")) {\n90:         result = { backend: \"tmux\", bin: \"tmux\" };\n91:       } else {\n92:         throw new Error(\n93:           \"No terminal multiplexer found. Install dmux (preferred) or tmux.\\n\" +\n94:             \"  dmux: https://github.com/nicholasgasior/dmux\\n\" +\n95:             \"  tmux: https://github.com/tmux/tmux\"\n96:         );\n97:       }\n98:       break;\n99:   }\n100: \n101:   cachedDetection = result;\n102:   cachedPreference = preference;\n103:   return result;\n104: }\n105: \n106: /**\n107:  * Reset the cached detection (useful for testing or config changes).\n108:  */\n109: export function resetMultiplexerCache(): void {\n110:   cachedDetection = null;\n111:   cachedPreference = null;\n112: }\n113: \n114: // ---------------------------------------------------------------------------\n115: // Helpers\n116: // ---------------------------------------------------------------------------\n117: \n118: function runSilent(cmd: string): string {\n119:   try {\n120:     return execSync(cmd, { encoding: \"utf-8\", stdio: \"pipe\" }).trim();\n121:   } catch {\n122:     return \"\";\n123:   }\n124: }\n125: \n126: // ---------------------------------------------------------------------------\n127: // Unified Session Management API\n128: // ---------------------------------------------------------------------------\n129: \n130: /**\n131:  * Create a new detached session running a command.\n132:  */\n133: export function muxNewSession(\n134:   mux: MultiplexerInfo,\n135:   sessionName: string,\n136:   workDir: string,\n137:   command: string\n138: ): void {\n139:   switch (mux.backend) {\n140:     case \"dmux\":\n141:       execSync(\n142:         `dmux new-session -d -s \"${sessionName}\" -c \"${workDir}\" \"${command}\"`,\n143:         { stdio: \"pipe\" }\n144:       );\n145:       break;\n146:     case \"tmux\":\n147:       execSync(\n148:         `tmux new-session -d -s \"${sessionName}\" -c \"${workDir}\" \"${command}\"`,\n149:         { stdio: \"pipe\" }\n150:       );\n151:       break;\n152:   }\n153: }\n154: \n155: /**\n156:  * Check if a session with the given name exists.\n157:  */\n158: export function muxHasSession(\n159:   mux: MultiplexerInfo,\n160:   sessionName: string\n161: ): boolean {\n162:   switch (mux.backend) {\n163:     case \"dmux\":\n164:       return (\n165:         runSilent(\n166:           `dmux has-session -t \"${sessionName}\" 2>/dev/null && echo yes`\n167:         ) === \"yes\"\n168:       );\n169:     case \"tmux\":\n170:       return (\n171:         runSilent(\n172:           `tmux has-session -t \"${sessionName}\" 2>/dev/null && echo yes`\n173:         ) === \"yes\"\n174:       );\n175:   }\n176: }\n177: \n178: /**\n179:  * Kill a specific session.\n180:  */\n181: export function muxKillSession(\n182:   mux: MultiplexerInfo,\n183:   sessionName: string\n184: ): void {\n185:   switch (mux.backend) {\n186:     case \"dmux\":\n187:       runSilent(`dmux kill-session -t \"${sessionName}\" 2>/dev/null`);\n188:       break;\n189:     case \"tmux\":\n190:       runSilent(`tmux kill-session -t \"${sessionName}\" 2>/dev/null`);\n191:       break;\n192:   }\n193: }\n194: \n195: /**\n196:  * List all session names.\n197:  */\n198: export function muxListSessions(mux: MultiplexerInfo): string[] {\n199:   let output: string;\n200:   switch (mux.backend) {\n201:     case \"dmux\":\n202:       output = runSilent(\n203:         `dmux list-sessions -F \"#{session_name}\" 2>/dev/null`\n204:       );\n205:       break;\n206:     case \"tmux\":\n207:       output = runSilent(\n208:         `tmux list-sessions -F \"#{session_name}\" 2>/dev/null`\n209:       );\n210:       break;\n211:   }\n212:   if (!output) return [];\n213:   return output.split(\"\\n\").filter(Boolean);\n214: }\n215: \n216: /**\n217:  * Get the PID of the main pane in a session.\n218:  */\n219: export function muxGetPanePid(\n220:   mux: MultiplexerInfo,\n221:   sessionName: string\n222: ): number {\n223:   let output: string;\n224:   switch (mux.backend) {\n225:     case \"dmux\":\n226:       output = runSilent(\n227:         `dmux list-panes -t \"${sessionName}\" -F \"#{pane_pid}\"`\n228:       );\n229:       break;\n230:     case \"tmux\":\n231:       output = runSilent(\n232:         `tmux list-panes -t \"${sessionName}\" -F \"#{pane_pid}\"`\n233:       );\n234:       break;\n235:   }\n236:   return parseInt(output) || 0;\n237: }\n238: \n239: /**\n240:  * Load text into the paste buffer.\n241:  */\n242: export function muxLoadBuffer(\n243:   mux: MultiplexerInfo,\n244:   filePath: string\n245: ): void {\n246:   switch (mux.backend) {\n247:     case \"dmux\":\n248:       execSync(`dmux load-buffer \"${filePath}\"`, { stdio: \"pipe\" });\n249:       break;\n250:     case \"tmux\":\n251:       execSync(`tmux load-buffer \"${filePath}\"`, { stdio: \"pipe\" });\n252:       break;\n253:   }\n254: }\n255: \n256: /**\n257:  * Paste the buffer into a session.\n258:  */\n259: export function muxPasteBuffer(\n260:   mux: MultiplexerInfo,\n261:   sessionName: string\n262: ): void {\n263:   switch (mux.backend) {\n264:     case \"dmux\":\n265:       execSync(`dmux paste-buffer -t \"${sessionName}\"`, { stdio: \"pipe\" });\n266:       break;\n267:     case \"tmux\":\n268:       execSync(`tmux paste-buffer -t \"${sessionName}\"`, { stdio: \"pipe\" });\n269:       break;\n270:   }\n271: }\n272: \n273: /**\n274:  * Send keys (e.g., Enter) to a session.\n275:  */\n276: export function muxSendKeys(\n277:   mux: MultiplexerInfo,\n278:   sessionName: string,\n279:   keys: string\n280: ): void {\n281:   switch (mux.backend) {\n282:     case \"dmux\":\n283:       execSync(`dmux send-keys -t \"${sessionName}\" ${keys}`, {\n284:         stdio: \"pipe\",\n285:       });\n286:       break;\n287:     case \"tmux\":\n288:       execSync(`tmux send-keys -t \"${sessionName}\" ${keys}`, {\n289:         stdio: \"pipe\",\n290:       });\n291:       break;\n292:   }\n293: }\n294: \n295: /**\n296:  * Attach to a session (blocks until user detaches).\n297:  */\n298: export function muxAttach(\n299:   mux: MultiplexerInfo,\n300:   sessionName: string\n301: ): void {\n302:   switch (mux.backend) {\n303:     case \"dmux\":\n304:       execSync(`dmux attach -t \"${sessionName}\"`, { stdio: \"inherit\" });\n305:       break;\n306:     case \"tmux\":\n307:       execSync(`tmux attach -t \"${sessionName}\"`, { stdio: \"inherit\" });\n308:       break;\n309:   }\n310: }\n311: \n312: /**\n313:  * Get the multiplexer name for display purposes.\n314:  * Returns \"dmux\" or \"tmux\".\n315:  */\n316: export function muxDisplayName(mux: MultiplexerInfo): string {\n317:   return mux.backend;\n318: }\n319: \n320: /**\n321:  * Build the attach command string (for display to user).\n322:  */\n323: export function muxAttachCommand(\n324:   mux: MultiplexerInfo,\n325:   sessionName: string\n326: ): string {\n327:   return `${mux.bin} attach -t ${sessionName}`;\n328: }\n329: \n330: /**\n331:  * Build the list-sessions command string (for display to user).\n332:  */\n333: export function muxListCommand(mux: MultiplexerInfo): string {\n334:   return `${mux.bin} ls`;\n335: }\n\n(End of file - total 335 lines)\n</content>","title":"src/lib/multiplexer.ts","metadata":{"preview":"/**\n * multiplexer.ts — Abstraction layer for terminal multiplexers (dmux/tmux).\n *\n * Provides a unified API for session management that works with either\n * dmux (preferred, Rust-based) or tmux (fallback). Auto-detects which\n * multiplexer is available, preferring dmux when both are present.\n *\n * Configurable via .wombo-combo/config.json `agent.multiplexer` field:\n *   - \"auto\"  — prefer dmux, fall back to tmux (default)\n *   - \"dmux\"  — use dmux only (error if not available)\n *   - \"tmux\"  — use tmux only (error if not available)\n */\n\nimport { execSync } from \"node:child_process\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type MultiplexerBackend = \"dmux\" | \"tmux\";","truncated":false,"loaded":[]},"time":{"start":1773481740465,"end":1773481740468}}}}
