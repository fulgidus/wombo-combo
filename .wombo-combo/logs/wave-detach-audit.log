{"type":"tool_use","timestamp":1773483373523,"sessionID":"ses_31427856effefwaC38OEq6YCmn","part":{"id":"prt_cebd8aff5001xX6z26E6ikqrZA","sessionID":"ses_31427856effefwaC38OEq6YCmn","messageID":"msg_cebd8a245001cWpvKxkO5YPSfc","type":"tool","callID":"toolu_vrtx_01SYY1u41A8NyjMaBu8MDNPy","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/wave-detach-audit/src/commands/launch.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/wave-detach-audit/src/commands/launch.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * launch.ts — Launch a wave of agents.\n3:  *\n4:  * Usage: woco launch [selection options] [launch options]\n5:  *\n6:  * This is the primary entry point for starting a new wave. It selects features\n7:  * from the features file, creates a wave state, sets up worktrees, and launches\n8:  * agent processes (either headless or interactive via dmux/tmux).\n9:  *\n10:  * IMPORTANT: This file also exports shared helper functions that are reused\n11:  * by resume.ts and other commands:\n12:  *   - launchSingleHeadless\n13:  *   - handleBuildVerification\n14:  *   - handleRetry\n15:  *   - launchNextQueued\n16:  */\n17: \n18: import { execSync } from \"node:child_process\";\n19: import { existsSync, readFileSync } from \"node:fs\";\n20: import { resolve } from \"node:path\";\n21: import type { WomboConfig } from \"../config.js\";\n22: import type { Feature, SelectionOptions, Priority, Difficulty } from \"../lib/tasks.js\";\n23: import { loadFeatures, selectFeatures, parseDurationMinutes, saveFeatures } from \"../lib/tasks.js\";\n24: import {\n25:   loadState,\n26:   saveState,\n27:   flushState,\n28:   createWaveState,\n29:   createAgentState,\n30:   updateAgent,\n31:   activeAgents,\n32:   queuedAgents,\n33:   readyToLaunchAgents,\n34:   areAgentDepsReady,\n35:   cancelDownstream,\n36:   isWaveComplete,\n37:   type WaveState,\n38:   type AgentState,\n39:   type SerializedSchedulePlan,\n40: } from \"../lib/state.js\";\n41: import {\n42:   createWorktree,\n43:   installDeps,\n44:   featureBranchName,\n45:   worktreePath,\n46:   worktreeReady,\n47:   branchHasChanges,\n48:   isWorktreesDirEmpty,\n49:   branchExists,\n50:   removeWorktree,\n51:   log as wtLog,\n52: } from \"../lib/worktree.js\";\n53: import { generatePrompt, generateConflictResolutionPrompt, type QuestPromptContext } from \"../lib/prompt.js\";\n54: import {\n55:   launchHeadless,\n56:   retryHeadless,\n57:   launchInteractive,\n58:   retryInteractive,\n59:   launchConflictResolver,\n60:   isProcessRunning,\n61:   getMultiplexerName,\n62: } from \"../lib/launcher.js\";\n63: import { ProcessMonitor } from \"../lib/monitor.js\";\n64: import { runBuild, runFullVerification, type FullVerificationOptions } from \"../lib/verifier.js\";\n65: import { mergeBranch, mergeBaseIntoFeature, pushBaseBranch, canMerge, enqueueMerge, tieredMergeBaseIntoFeature } from \"../lib/merger.js\";\n66: import {\n67:   printDashboard,\n68:   printFeatureSelection,\n69:   printAgentUpdate,\n70: } from \"../lib/ui.js\";\n71: import { WomboTUI } from \"../lib/tui.js\";\n72: import { ensureAgentDefinition } from \"../lib/templates.js\";\n73: import {\n74:   buildDepGraph,\n75:   validateDepGraph,\n76:   buildSchedulePlan,\n77:   formatSchedulePlan,\n78:   getStreamForFeature,\n79:   type DepGraph,\n80:   type SchedulePlan,\n81: } from \"../lib/dependency-graph.js\";\n82: import { ensureProxyRunning, isPortlessAvailable, portlessUrl } from \"../lib/portless.js\";\n83: import { output, outputError, outputMessage, type OutputFormat } from \"../lib/output.js\";\n84: import { renderLaunchDryRun } from \"../lib/toon.js\";\n85: import {\n86:   detectMultiplexer,\n87:   muxAttachCommand,\n88:   muxListCommand,\n89: } from \"../lib/multiplexer.js\";\n90: import { exportWaveHistory } from \"../lib/history.js\";\n91: import {\n92:   prepareAgentDefinitions,\n93:   isSpecializedAgent,\n94:   writeAgentToWorktree,\n95:   type AgentResolution,\n96: } from \"../lib/agent-registry.js\";\n97: import { patchImportedAgent } from \"../lib/templates.js\";\n98: import {\n99:   tuiPreflightConfirm,\n100:   consolePreflightConfirm,\n101: } from \"../lib/preflight.js\";\n102: import { loadQuest, loadQuestKnowledge } from \"../lib/quest-store.js\";\n103: import { resolveQuestConfig, applyQuestConstraintsToTask, type QuestHitlMode } from \"../lib/quest.js\";\n104: import { questBranchExists, createQuestBranch } from \"../lib/worktree.js\";\n105: import { getPendingQuestions, cleanupAll as cleanupHitl, submitAnswer, type HitlQuestion } from \"../lib/hitl-channel.js\";\n106: \n107: // ---------------------------------------------------------------------------\n108: // Constants\n109: // ---------------------------------------------------------------------------\n110: \n111: /**\n112:  * Build a QuestPromptContext from a wave's quest_id.\n113:  * Returns undefined if the wave is not quest-scoped.\n114:  * Used by internal functions that can't receive questContext from their caller.\n115:  */\n116: function buildQuestContext(\n117:   projectRoot: string,\n118:   questId: string | null\n119: ): QuestPromptContext | undefined {\n120:   if (!questId) return undefined;\n121: \n122:   const quest = loadQuest(projectRoot, questId);\n123:   if (!quest) return undefined;\n124: \n125:   const knowledge = loadQuestKnowledge(projectRoot, questId);\n126:   return {\n127:     questId: quest.id,\n128:     goal: quest.goal,\n129:     addedConstraints: quest.constraints.add ?? [],\n130:     addedForbidden: quest.constraints.ban ?? [],\n131:     knowledge,\n132:   };\n133: }\n134: \n135: /**\n136:  * Delay (ms) between sequential agent launches to avoid SQLite race conditions.\n137:  * Each agent spawns its own process which runs DB migrations on startup.\n138:  * Launching them simultaneously causes `CREATE TABLE` collisions.\n139:  */\n140: const LAUNCH_STAGGER_MS = 500;\n141: \n142: // ---------------------------------------------------------------------------\n143: // Types\n144: // ---------------------------------------------------------------------------\n145: \n146: export interface LaunchCommandOptions {\n147:   projectRoot: string;\n148:   config: WomboConfig;\n149:   // Selection\n150:   topPriority?: number;\n151:   quickestWins?: number;\n152:   priority?: Priority;\n153:   difficulty?: Difficulty;\n154:   features?: string[];\n155:   allReady?: boolean;\n156:   // Launch\n157:   maxConcurrent: number;\n158:   model?: string;\n159:   interactive: boolean;\n160:   dryRun: boolean;\n161:   baseBranch: string;\n162:   maxRetries: number;\n163:   noTui: boolean;\n164:   autoPush: boolean;\n165:   // Agent selection\n166:   /** CLI override: use this local agent definition for all launched tasks */\n167:   agent?: string;\n168:   // Quest scoping\n169:   /** Quest ID to scope this launch to (uses quest branch as base) */\n170:   questId?: string;\n171:   // Output\n172:   outputFmt?: OutputFormat;\n173: }\n174: \n175: // ---------------------------------------------------------------------------\n176: // Shared Helpers (exported for resume.ts and others)\n177: // ---------------------------------------------------------------------------\n178: \n179: /**\n180:  * Mark a feature as done in the features file after a successful merge.\n181:  * Updates status to \"done\", completion to 100, and sets ended_at.\n182:  *\n183:  * GUARD: Verifies that the feature branch has actually been merged into\n184:  * baseBranch before allowing the status change. This prevents callers\n185:  * from accidentally marking verified-but-unmerged features as done.\n186:  *\n187:  * @param fmt - Output format. When \"json\" or \"toon\", suppresses console warnings.\n188:  */\n189: export function markFeatureDone(\n190:   projectRoot: string,\n191:   featureId: string,\n192:   config: WomboConfig,\n193:   baseBranch: string,\n194:   fmt: OutputFormat = \"text\"\n195: ): void {\n196:   try {\n197:     // Verify the feature branch was actually merged into base\n198:     const branch = featureBranchName(featureId, config);\n199:     try {\n200:       execSync(`git merge-base --is-ancestor \"${branch}\" \"${baseBranch}\"`, {\n201:         cwd: projectRoot,\n202:         stdio: \"pipe\",\n203:       });\n204:     } catch {\n205:       // git merge-base --is-ancestor exits non-zero if NOT an ancestor\n206:       if (fmt === \"text\") {\n207:         console.error(\n208:           `Warning: ${featureId} branch \"${branch}\" is not merged into \"${baseBranch}\" — refusing to mark as done`\n209:         );\n210:       }\n211:       return;\n212:     }\n213: \n214:     const data = loadFeatures(projectRoot, config);\n215:     const feature = data.tasks.find((f: Feature) => f.id === featureId);\n216:     if (feature && feature.status !== \"done\") {\n217:       feature.status = \"done\";\n218:       feature.completion = 100;\n219:       feature.ended_at = new Date().toISOString();\n220:       saveFeatures(projectRoot, config, data);\n221:     }\n222:   } catch (err: any) {\n223:     // Non-fatal — log but don't crash the wave\n224:     if (fmt === \"text\") {\n225:       console.error(`Warning: failed to update feature status for ${featureId}: ${err.message}`);\n226:     }\n227:   }\n228: }\n229: \n230: /**\n231:  * Launch a single agent in headless mode.\n232:  * Sets up worktree, installs deps, generates prompt, launches agent process.\n233:  * If agentResolutions is provided and contains a specialized agent for this\n234:  * feature, the patched agent definition is written into the worktree.\n235:  */\n236: export async function launchSingleHeadless(\n237:   projectRoot: string,\n238:   state: WaveState,\n239:   agent: AgentState,\n240:   feature: Feature,\n241:   monitor: ProcessMonitor,\n242:   config: WomboConfig,\n243:   model?: string,\n244:   agentResolutions?: Map<string, AgentResolution>,\n245:   questContext?: QuestPromptContext,\n246:   hitlMode?: string\n247: ): Promise<void> {\n248:   updateAgent(state, agent.feature_id, {\n249:     status: \"installing\",\n250:     started_at: new Date().toISOString(),\n251:     activity: \"setting up worktree...\",\n252:   });\n253:   saveState(projectRoot, state);\n254: \n255:   try {\n256:     // Check if this agent is reusing a chain predecessor's worktree\n257:     const isChainReuse = agent.depends_on.some((depId) => {\n258:       const depAgent = state.agents.find((a) => a.feature_id === depId);\n259:       return depAgent && depAgent.worktree === agent.worktree;\n260:     });\n261: \n262:     if (isChainReuse && worktreeReady(agent.worktree)) {\n263:       // Chain worktree reuse: the worktree already exists from a predecessor.\n264:       // Create a new branch for this feature and switch the worktree to it.\n265:       wtLog(agent.feature_id, \"reusing chain worktree — switching branch...\");\n266:       updateAgent(state, agent.feature_id, { activity: \"switching branch (chain reuse)...\" });\n267: \n268:       try {\n269:         // Create the new feature branch from base (in the worktree)\n270:         execSync(`git checkout -B \"${agent.branch}\" \"${state.base_branch}\"`, {\n271:           cwd: agent.worktree,\n272:           stdio: \"pipe\",\n273:         });\n274:         wtLog(agent.feature_id, `switched to branch ${agent.branch}`);\n275:       } catch (branchErr: any) {\n276:         wtLog(agent.feature_id, `branch switch failed: ${branchErr.message}`);\n277:         // Fall through to normal worktree creation\n278:         await createWorktree(projectRoot, feature.id, state.base_branch, config);\n279:       }\n280:     } else if (worktreeReady(agent.worktree)) {\n281:       // Skip worktree setup if already ready (resume case)\n282:       wtLog(agent.feature_id, \"worktree already exists, skipping setup\");\n283:     } else {\n284:       // Create worktree (async — doesn't block other agents)\n285:       await createWorktree(projectRoot, feature.id, state.base_branch, config);\n286: \n287:       // Install dependencies (async)\n288:       updateAgent(state, agent.feature_id, { activity: \"installing deps...\" });\n289:       await installDeps(agent.worktree, feature.id, config);\n290:     }\n291: \n292:     // Generate prompt\n293:     const prompt = generatePrompt(feature, state.base_branch, config, questContext, hitlMode as QuestHitlMode | undefined);\n294: \n295:     // Write specialized agent to worktree if applicable\n296:     const resolution = agentResolutions?.get(feature.id);\n297:     const agentName = agent.agent_name ?? undefined;\n298:     if (resolution && isSpecializedAgent(resolution)) {\n299:       try {\n300:         const patchedContent = patchImportedAgent(resolution.rawContent, config, projectRoot);\n301:         writeAgentToWorktree(agent.worktree, resolution.name, patchedContent);\n302:         wtLog(agent.feature_id, `wrote specialized agent: ${resolution.name}`);\n303:       } catch (err: any) {\n304:         wtLog(agent.feature_id, `WARN: failed to write specialized agent, using generalist: ${err.message}`);\n305:       }\n306:     }\n307: \n308:     // Launch agent\n309:     wtLog(agent.feature_id, \"launching agent...\");\n310:     const result = launchHeadless({\n311:       worktreePath: agent.worktree,\n312:       featureId: feature.id,\n313:       prompt,\n314:       model,\n315:       config,\n316:       agentName,\n317:       hitlMode,\n318:       projectRoot,\n319:     });\n320: \n321:     updateAgent(state, agent.feature_id, {\n322:       status: \"running\",\n323:       pid: result.pid,\n324:       activity: \"starting...\",\n325:     });\n326:     saveState(projectRoot, state);\n327: \n328:     monitor.addProcess(feature.id, result.process);\n329:     wtLog(agent.feature_id, `running (PID: ${result.pid})`);\n330:   } catch (err: any) {\n331:     updateAgent(state, agent.feature_id, {\n332:       status: \"failed\",\n333:       error: err.message,\n334:       activity: null,\n335:       completed_at: new Date().toISOString(),\n336:     });\n337:     saveState(projectRoot, state);\n338:     wtLog(agent.feature_id, `SETUP FAILED: ${err.message.split(\"\\n\")[0]}`);\n339:   }\n340: }\n341: \n342: /**\n343:  * Handle build verification after agent completion.\n344:  * Runs build, auto-merges on pass, retries on failure if retries remain.\n345:  *\n346:  * ASYNC — runs build and merge without blocking the event loop.\n347:  */\n348: export async function handleBuildVerification(\n349:   projectRoot: string,\n350:   state: WaveState,\n351:   agent: AgentState,\n352:   feature: Feature,\n353:   config: WomboConfig,\n354:   model?: string,\n355:   monitor?: ProcessMonitor,\n356:   tddOpts?: FullVerificationOptions,\n357:   hitlMode?: string\n358: ): Promise<void> {\n359:   try {\n360:     printAgentUpdate(agent, \"verifying build...\");\n361: \n362:     // Use full verification pipeline (build + optional browser tests + optional TDD)\n363:     const fullResult = await runFullVerification(agent.worktree, agent.feature_id, config, tddOpts);\n364:     const buildResult = fullResult.build;\n365: \n366:     // Report browser test status if they ran\n367:     if (fullResult.browser.ran && fullResult.browser.browserResult) {\n368:       const br = fullResult.browser.browserResult;\n369:       printAgentUpdate(\n370:         agent,\n371:         `BROWSER: ${br.summary} (${Math.round(br.totalDurationMs / 1000)}s)`\n372:       );\n373:     } else if (fullResult.browser.skipReason && config.browser.enabled) {\n374:       printAgentUpdate(agent, `BROWSER: skipped — ${fullResult.browser.skipReason}`);\n375:     }\n376: \n377:     // Report TDD verification status if it ran\n378:     if (fullResult.tdd.ran) {\n379:       const tdd = fullResult.tdd;\n380:       const tddIcon = tdd.passed ? \"✓\" : \"✗\";\n381:       printAgentUpdate(agent, `TDD: ${tddIcon} ${tdd.summary}`);\n382:       if (tdd.hasWarnings) {\n383:         printAgentUpdate(agent, `TDD: ⚠ Missing tests detected (non-blocking)`);\n384:       }\n385:     } else if (fullResult.tdd.skipReason && config.tdd?.enabled) {\n386:       printAgentUpdate(agent, `TDD: skipped — ${fullResult.tdd.skipReason}`);\n387:     }\n388: \n389:     if (fullResult.overallPassed) {\n390:       updateAgent(state, agent.feature_id, {\n391:         status: \"verified\",\n392:         build_passed: true,\n393:         build_output: null,\n394:       });\n395:       saveState(projectRoot, state);\n396:       printAgentUpdate(agent, `BUILD PASSED (${Math.round(buildResult.durationMs / 1000)}s)`);\n397: \n398:       // Auto-merge: attempt merge + conflict resolution\n399:       await attemptMerge(projectRoot, state, agent, feature, config, model);\n400:     } else {\n401:       const errorSummary = fullResult.combinedErrorSummary;\n402: \n403:       if (agent.retries < agent.max_retries) {\n404:         updateAgent(state, agent.feature_id, {\n405:           status: \"retry\",\n406:           retries: agent.retries + 1,\n407:           build_passed: false,\n408:           build_output: errorSummary,\n409:         });\n410:         saveState(projectRoot, state);\n411:         printAgentUpdate(\n412:           agent,\n413:           `VERIFICATION FAILED — retrying (${agent.retries}/${agent.max_retries})`\n414:         );\n415: \n416:         // Retry with error details\n417:         if (agent.session_id) {\n418:           const retryResult = retryHeadless({\n419:             worktreePath: agent.worktree,\n420:             featureId: agent.feature_id,\n421:             sessionId: agent.session_id,\n422:             buildErrors: errorSummary,\n423:             model,\n424:             config,\n425:             hitlMode,\n426:             projectRoot,\n427:           });\n428: \n429:           updateAgent(state, agent.feature_id, {\n430:             status: \"running\",\n431:             pid: retryResult.pid,\n432:           });\n433:           saveState(projectRoot, state);\n434: \n435:           // Add retry process to monitor so events are tracked\n436:           if (monitor) {\n437:             monitor.addProcess(agent.feature_id, retryResult.process);\n438:           }\n439:         } else {\n440:           // Agent has no session — reset to queued for a fresh launch\n441:           wtLog(agent.feature_id, `no session — resetting to queued for fresh launch (retry ${agent.retries}/${agent.max_retries})`);\n442:           updateAgent(state, agent.feature_id, {\n443:             status: \"queued\",\n444:             error: null,\n445:             activity: \"waiting for relaunch...\",\n446:           });\n447:           saveState(projectRoot, state);\n448:         }\n449:       } else {\n450:         updateAgent(state, agent.feature_id, {\n451:           status: \"failed\",\n452:           build_passed: false,\n453:           build_output: errorSummary,\n454:           error: `Verification failed after ${agent.max_retries} retries`,\n455:           completed_at: new Date().toISOString(),\n456:         });\n457:         saveState(projectRoot, state);\n458:         printAgentUpdate(agent, \"VERIFICATION FAILED — max retries reached\");\n459: \n460:         // Cascade failure to downstream agents\n461:         const cancelled = cancelDownstream(state, agent.feature_id);\n462:         if (cancelled.length > 0) {\n463:           printAgentUpdate(agent, `downstream cancelled: ${cancelled.join(\", \")}`);\n464:           saveState(projectRoot, state);\n465:         }\n466:       }\n467:     }\n468:   } catch (err: any) {\n469:     // Catch-all — never let build verification crash the process\n470:     printAgentUpdate(agent, `VERIFY ERROR: ${err.message?.slice(0, 100)}`);\n471:     updateAgent(state, agent.feature_id, {\n472:       status: \"failed\",\n473:       error: `Build verification error: ${err.message}`,\n474:       completed_at: new Date().toISOString(),\n475:     });\n476:     saveState(projectRoot, state);\n477:   }\n478: }\n479: \n480: /**\n481:  * Attempt to merge a verified agent's branch into the base branch.\n482:  *\n483:  * Handles conflict detection, base-into-feature merge, and resolver agent\n484:  * launch. Extracted from handleBuildVerification so it can be called\n485:  * independently (e.g., from resume's sequential merge phase).\n486:  *\n487:  * All merge operations are serialized via enqueueMerge() to prevent\n488:  * concurrent checkout races on the project root.\n489:  */\n490: export async function attemptMerge(\n491:   projectRoot: string,\n492:   state: WaveState,\n493:   agent: AgentState,\n494:   feature: Feature,\n495:   config: WomboConfig,\n496:   model?: string,\n497: ): Promise<void> {\n498:   return enqueueMerge(async () => {\n499:     printAgentUpdate(agent, \"auto-merging...\");\n500:     try {\n501:       // Pre-flight check: detect conflicts before attempting the real merge.\n502:       // This avoids the expensive merge-then-abort dance for known conflicts.\n503:       const preCheck = await canMerge(projectRoot, agent.branch, state.base_branch);\n504:       if (!preCheck.canMerge) {\n505:         printAgentUpdate(agent, `conflict detected (pre-flight) — attempting resolution...`);\n506:         await handleMergeConflict(\n507:           projectRoot, state, agent, feature, config, model,\n508:           preCheck.reason\n509:         );\n510:         return;\n511:       }\n512: \n513:       const mergeResult = await mergeBranch(projectRoot, agent.branch, state.base_branch, config);\n514: \n515:       if (mergeResult.success) {\n516:         handleMergeSuccess(projectRoot, state, agent, config, mergeResult.commitHash);\n517:         return;\n518:       }\n519: \n520:       // Merge failed despite clean pre-flight — race with another merge or\n521:       // a git state issue. Fall through to conflict resolution.\n522:       printAgentUpdate(agent, `MERGE CONFLICT — attempting resolution...`);\n523:       await handleMergeConflict(\n524:         projectRoot, state, agent, feature, config, model,\n525:         mergeResult.error ?? \"Unknown merge error\"\n526:       );\n527:     } catch (mergeErr: any) {\n528:       // Unexpected exception — stay in \"verified\" (retryable) but record the\n529:       // error so the user can see what went wrong instead of silent stalling.\n530:       printAgentUpdate(agent, `AUTO-MERGE ERROR: ${mergeErr.message?.slice(0, 100)}`);\n531:       updateAgent(state, agent.feature_id, {\n532:         error: `Auto-merge error: ${mergeErr.message}`,\n533:       });\n534:       saveState(projectRoot, state);\n535:     }\n536:   });\n537: }\n538: \n539: /**\n540:  * Handle a successful merge: update state, mark feature done, clean up.\n541:  */\n542: function handleMergeSuccess(\n543:   projectRoot: string,\n544:   state: WaveState,\n545:   agent: AgentState,\n546:   config: WomboConfig,\n547:   commitHash: string | null,\n548:   label = \"MERGED\",\n549: ): void {\n550:   updateAgent(state, agent.feature_id, {\n551:     status: \"merged\",\n552:     completed_at: new Date().toISOString(),\n553:   });\n554:   saveState(projectRoot, state);\n555:   printAgentUpdate(agent, `${label} (${commitHash?.slice(0, 7)})`);\n556: \n557:   markFeatureDone(projectRoot, agent.feature_id, config, state.base_branch);\n558: \n559:   // Clean up worktree — but preserve it if downstream agents in the same\n560:   // chain share this worktree.\n561:   const hasChainSuccessor = agent.depended_on_by.some((depId) => {\n562:     const depAgent = state.agents.find((a) => a.feature_id === depId);\n563:     return depAgent && depAgent.worktree === agent.worktree;\n564:   });\n565: \n566:   if (hasChainSuccessor) {\n567:     printAgentUpdate(agent, \"worktree preserved for chain successor\");\n568:   } else {\n569:     try {\n570:       removeWorktree(projectRoot, agent.worktree, true);\n571:       printAgentUpdate(agent, \"worktree and branch removed\");\n572:     } catch (err: any) {\n573:       // Log the failure so it's visible — stale worktrees waste disk space\n574:       printAgentUpdate(agent, `WARN: worktree cleanup failed: ${err.message?.split(\"\\n\")[0]}`);\n575:     }\n576:   }\n577: }\n578: \n579: /**\n580:  * Handle a merge conflict: use tiered merge strategy.\n581:  *\n582:  * Tier 1: Already failed (we got here because the direct merge failed).\n583:  * Tier 2: Merge base into feature, then auto-resolve trivial conflicts.\n584:  * Tier 3: Real conflicts remain — launch a resolver agent.\n585:  *\n586:  * If tier 3 also fails after max attempts, mark as needs_manual_merge.\n587:  *\n588:  * All failure paths record the error on the agent (which stays \"verified\")\n589:  * so the merge can be retried without silently stalling.\n590:  */\n591: async function handleMergeConflict(\n592:   projectRoot: string,\n593:   state: WaveState,\n594:   agent: AgentState,\n595:   feature: Feature,\n596:   config: WomboConfig,\n597:   model: string | undefined,\n598:   mergeError: string,\n599: ): Promise<void> {\n600:   try {\n601:     // Tiered merge: attempts tier 1 (clean merge) and tier 2 (trivial auto-resolve)\n602:     const tieredResult = await tieredMergeBaseIntoFeature(\n603:       agent.worktree,\n604:       state.base_branch,\n605:       config\n606:     );\n607: \n608:     if (tieredResult.success && tieredResult.tier === 1) {\n609:       // Clean merge of base into feature — retry merge into base\n610:       printAgentUpdate(agent, \"base merged cleanly into feature — retrying merge...\");\n611:       const retryMerge = await mergeBranch(projectRoot, agent.branch, state.base_branch, config);\n612:       if (retryMerge.success) {\n613:         handleMergeSuccess(projectRoot, state, agent, config, retryMerge.commitHash, \"MERGED after rebase\");\n614:         return;\n615:       }\n616: \n617:       // Retry still failed — need conflict resolution. Re-merge base into\n618:       // feature to get conflict files for the resolver.\n619:       printAgentUpdate(agent, `retry merge still failed — launching resolver agent...`);\n620:       const secondConflict = await mergeBaseIntoFeature(\n621:         agent.worktree,\n622:         state.base_branch,\n623:         config\n624:       );\n625: \n626:       const conflictFiles = secondConflict.conflicting\n627:         ? secondConflict.files\n628:         : [\"(unknown — merge direction mismatch)\"];\n629: \n630:       await launchResolverAndRetryMerge(\n631:         projectRoot, state, agent, feature, config, model,\n632:         retryMerge.error ?? mergeError, conflictFiles\n633:       );\n634:       return;\n635:     }\n636: \n637:     if (tieredResult.success && tieredResult.tier === 2) {\n638:       // Trivial conflicts auto-resolved — retry merge into base\n639:       printAgentUpdate(agent, \"trivial conflicts auto-resolved (whitespace only) — retrying merge...\");\n640:       const retryMerge = await mergeBranch(projectRoot, agent.branch, state.base_branch, config);\n641:       if (retryMerge.success) {\n642:         handleMergeSuccess(projectRoot, state, agent, config, retryMerge.commitHash, \"MERGED after trivial auto-resolve\");\n643:         return;\n644:       }\n645: \n646:       // Still failed after auto-resolve — fall through to agent resolver\n647:       printAgentUpdate(agent, `merge still failed after auto-resolve — launching resolver agent...`);\n648:       const postAutoConflict = await mergeBaseIntoFeature(\n649:         agent.worktree,\n650:         state.base_branch,\n651:         config\n652:       );\n653:       const conflictFiles = postAutoConflict.conflicting\n654:         ? postAutoConflict.files\n655:         : [\"(unknown — merge direction mismatch)\"];\n656: \n657:       await launchResolverAndRetryMerge(\n658:         projectRoot, state, agent, feature, config, model,\n659:         retryMerge.error ?? mergeError, conflictFiles\n660:       );\n661:       return;\n662:     }\n663: \n664:     if (tieredResult.tier === null && tieredResult.error) {\n665:       // Setup itself failed — stay as \"verified\" (retryable) with error\n666:       printAgentUpdate(agent, `CONFLICT SETUP FAILED: ${tieredResult.error.slice(0, 100)}`);\n667:       updateAgent(state, agent.feature_id, {\n668:         error: `Conflict setup failed: ${tieredResult.error}`,\n669:       });\n670:       saveState(projectRoot, state);\n671:       return;\n672:     }\n673: \n674:     // Tier 3: Real conflicts remain — launch resolver agent\n675:     printAgentUpdate(\n676:       agent,\n677:       `${tieredResult.conflictFiles.length} non-trivial conflict(s): ${tieredResult.conflictFiles.join(\", \")}`\n678:     );\n679: \n680:     await launchResolverAndRetryMerge(\n681:       projectRoot, state, agent, feature, config, model,\n682:       mergeError, tieredResult.conflictFiles\n683:     );\n684:   } catch (conflictErr: any) {\n685:     // Unexpected error during conflict handling — stay \"verified\" with error\n686:     printAgentUpdate(agent, `CONFLICT RESOLUTION ERROR: ${conflictErr.message?.slice(0, 100)}`);\n687:     updateAgent(state, agent.feature_id, {\n688:       error: `Conflict resolution error: ${conflictErr.message}`,\n689:     });\n690:     saveState(projectRoot, state);\n691:   }\n692: }\n693: \n694: /**\n695:  * Launch a conflict resolver agent, wait for it to finish, re-verify build,\n696:  * and retry the merge. Supports configurable retry attempts (defaults to 1,\n697:  * up to config.defaults.maxRetries + 1).\n698:  *\n699:  * The resolver is re-launched with updated conflict state on each attempt,\n700:  * so it sees the current conflict markers, not stale ones.\n701:  */\n702: async function launchResolverAndRetryMerge(\n703:   projectRoot: string,\n704:   state: WaveState,\n705:   agent: AgentState,\n706:   feature: Feature,\n707:   config: WomboConfig,\n708:   model: string | undefined,\n709:   mergeError: string,\n710:   conflictFiles: string[]\n711: ): Promise<void> {\n712:   const maxResolverAttempts = Math.max(1, (config.defaults.maxRetries ?? 0) + 1);\n713: \n714:   for (let attempt = 1; attempt <= maxResolverAttempts; attempt++) {\n715:     const conflictPrompt = generateConflictResolutionPrompt(\n716:       feature,\n717:       state.base_branch,\n718:       mergeError,\n719:       config,\n720:       buildQuestContext(projectRoot, state.quest_id)\n721:     );\n722: \n723:     const attemptLabel = maxResolverAttempts > 1\n724:       ? ` (attempt ${attempt}/${maxResolverAttempts})`\n725:       : \"\";\n726: \n727:     updateAgent(state, agent.feature_id, {\n728:       status: \"resolving_conflict\",\n729:       activity: `resolving ${conflictFiles.length} conflict(s)${attemptLabel}...`,\n730:     });\n731:     saveState(projectRoot, state);\n732: \n733:     const resolverResult = launchConflictResolver({\n734:       worktreePath: agent.worktree,\n735:       featureId: agent.feature_id,\n736:       prompt: conflictPrompt,\n737:       model,\n738:       config,\n739:     });\n740: \n741:     updateAgent(state, agent.feature_id, {\n742:       pid: resolverResult.pid,\n743:     });\n744:     saveState(projectRoot, state);\n745: \n746:     // Wait for the resolver process to complete, then re-verify and retry merge.\n747:     // We intentionally do NOT add the resolver to the ProcessMonitor because\n748:     // the monitor's onComplete callback would trigger handleBuildVerification\n749:     // again, causing infinite recursion. Instead we await the process directly.\n750:     const resolverExitCode = await new Promise<number | null>((resolve) => {\n751:       resolverResult.process.on(\"exit\", (code) => resolve(code));\n752:       resolverResult.process.on(\"error\", () => resolve(null));\n753:     });\n754: \n755:     printAgentUpdate(\n756:       agent,\n757:       `conflict resolver exited (code ${resolverExitCode})${attemptLabel} — re-verifying build...`\n758:     );\n759: \n760:     // Re-verify build after conflict resolution\n761:     const rebuildResult = await runBuild(agent.worktree, config);\n762: \n763:     if (!rebuildResult.passed) {\n764:       if (attempt < maxResolverAttempts) {\n765:         printAgentUpdate(agent, `POST-CONFLICT BUILD FAILED${attemptLabel} — retrying resolver...`);\n766:         continue; // Try again with a fresh resolver\n767:       }\n768:       printAgentUpdate(agent, `POST-CONFLICT BUILD FAILED (all ${maxResolverAttempts} attempts exhausted)`);\n769:       updateAgent(state, agent.feature_id, {\n770:         status: \"failed\",\n771:         build_passed: false,\n772:         build_output: rebuildResult.errorSummary,\n773:         error: \"Build failed after conflict resolution\",\n774:         completed_at: new Date().toISOString(),\n775:       });\n776:       saveState(projectRoot, state);\n777:       cancelDownstream(state, agent.feature_id);\n778:       saveState(projectRoot, state);\n779:       return;\n780:     }\n781: \n782:     printAgentUpdate(agent, \"post-conflict build passed — retrying merge...\");\n783: \n784:     const retryMerge = await mergeBranch(\n785:       projectRoot,\n786:       agent.branch,\n787:       state.base_branch,\n788:       config\n789:     );\n790: \n791:     if (retryMerge.success) {\n792:       handleMergeSuccess(\n793:         projectRoot, state, agent, config,\n794:         retryMerge.commitHash, \"MERGED after conflict resolution\"\n795:       );\n796:       return;\n797:     }\n798: \n799:     // Merge still failed after resolver. If we have attempts left, re-merge\n800:     // base into feature to refresh conflict markers and try again.\n801:     if (attempt < maxResolverAttempts) {\n802:       printAgentUpdate(agent, `POST-CONFLICT MERGE FAILED${attemptLabel} — retrying resolver...`);\n803:       const refreshConflict = await mergeBaseIntoFeature(\n804:         agent.worktree,\n805:         state.base_branch,\n806:         config\n807:       );\n808:       conflictFiles = refreshConflict.conflicting\n809:         ? refreshConflict.files\n810:         : conflictFiles;\n811:       mergeError = retryMerge.error ?? mergeError;\n812:       continue;\n813:     }\n814: \n815:     // All attempts exhausted\n816:     printAgentUpdate(agent, `POST-CONFLICT MERGE FAILED (all ${maxResolverAttempts} attempts exhausted): ${retryMerge.error}`);\n817:     updateAgent(state, agent.feature_id, {\n818:       status: \"failed\",\n819:       error: `Merge still failed after ${maxResolverAttempts} conflict resolution attempt(s): ${retryMerge.error}`,\n820:       completed_at: new Date().toISOString(),\n821:     });\n822:     saveState(projectRoot, state);\n823:     cancelDownstream(state, agent.feature_id);\n824:     saveState(projectRoot, state);\n825:     return;\n826:   }\n827: }\n828: \n829: /**\n830:  * Handle retry of a failed agent (error-based, not build-based).\n831:  *\n832:  * If the agent has a session_id, resumes the existing session with error context.\n833:  * If the agent crashed before establishing a session (session_id is null),\n834:  * resets it to \"queued\" so it gets relaunched from scratch on the next\n835:  * launchAllReady() cycle. This prevents the \"stuck retry\" state where an\n836:  * agent sits in \"retry\" forever with no process running.\n837:  */\n838: export function handleRetry(\n839:   projectRoot: string,\n840:   state: WaveState,\n841:   agent: AgentState,\n842:   monitor: ProcessMonitor,\n843:   config: WomboConfig,\n844:   model?: string,\n845:   hitlMode?: string\n846: ): void {\n847:   if (!agent.session_id) {\n848:     // Agent crashed before establishing a session (e.g. SQLite race condition).\n849:     // Reset to queued so it gets a fresh launch on the next cycle.\n850:     wtLog(agent.feature_id, `no session — resetting to queued for fresh launch (retry ${agent.retries}/${agent.max_retries})`);\n851:     updateAgent(state, agent.feature_id, {\n852:       status: \"queued\",\n853:       error: null,\n854:       activity: \"waiting for relaunch...\",\n855:     });\n856:     saveState(projectRoot, state);\n857:     return;\n858:   }\n859: \n860:   if (!agent.error) return;\n861: \n862:   const retryResult = retryHeadless({\n863:     worktreePath: agent.worktree,\n864:     featureId: agent.feature_id,\n865:     sessionId: agent.session_id,\n866:     buildErrors: agent.error,\n867:     model,\n868:     config,\n869:     hitlMode,\n870:     projectRoot,\n871:   });\n872: \n873:   updateAgent(state, agent.feature_id, {\n874:     status: \"running\",\n875:     pid: retryResult.pid,\n876:   });\n877:   saveState(projectRoot, state);\n878: \n879:   monitor.addProcess(agent.feature_id, retryResult.process);\n880: }\n881: \n882: /**\n883:  * Launch the next queued agent if capacity allows.\n884:  * Dependency-aware: only launches agents whose dependencies are satisfied.\n885:  */\n886: export async function launchNextQueued(\n887:   projectRoot: string,\n888:   state: WaveState,\n889:   featureMap: Map<string, Feature>,\n890:   monitor: ProcessMonitor,\n891:   config: WomboConfig,\n892:   model?: string,\n893:   agentResolutions?: Map<string, AgentResolution>,\n894:   questContext?: QuestPromptContext,\n895:   hitlMode?: string\n896: ): Promise<void> {\n897:   const active = activeAgents(state);\n898:   const ready = readyToLaunchAgents(state);\n899: \n900:   if (active.length < state.max_concurrent && ready.length > 0) {\n901:     const next = ready[0];\n902:     const feature = featureMap.get(next.feature_id);\n903:     if (feature) {\n904:       await launchSingleHeadless(projectRoot, state, next, feature, monitor, config, model, agentResolutions, questContext, hitlMode);\n905:     }\n906:   }\n907: }\n908: \n909: /**\n910:  * Launch ALL ready agents up to capacity.\n911:  * After a dependency completes, multiple downstream agents may become unblocked.\n912:  * This launches as many as capacity allows, not just one.\n913:  *\n914:  * Launches are staggered to avoid SQLite race conditions.\n915:  *\n916:  * Also logs merge gate events when diamond-dependency features become unblocked.\n917:  */\n918: export async function launchAllReady(\n919:   projectRoot: string,\n920:   state: WaveState,\n921:   featureMap: Map<string, Feature>,\n922:   monitor: ProcessMonitor,\n923:   config: WomboConfig,\n924:   model?: string,\n925:   agentResolutions?: Map<string, AgentResolution>,\n926:   questContext?: QuestPromptContext,\n927:   hitlMode?: string\n928: ): Promise<void> {\n929:   const active = activeAgents(state);\n930:   const ready = readyToLaunchAgents(state);\n931:   const available = state.max_concurrent - active.length;\n932: \n933:   if (available <= 0 || ready.length === 0) return;\n934: \n935:   const toLaunch = ready.slice(0, available);\n936:   for (let i = 0; i < toLaunch.length; i++) {\n937:     const next = toLaunch[i];\n938:     const feature = featureMap.get(next.feature_id);\n939:     if (!feature) continue;\n940: \n941:     // Log merge gate opening for diamond dependencies\n942:     if (next.depends_on.length > 1 && state.schedule_plan) {\n943:       const isMergeGate = state.schedule_plan.merge_gates.some(\n944:         (g) => g.feature_id === next.feature_id\n945:       );\n946:       if (isMergeGate) {\n947:         wtLog(\n948:           next.feature_id,\n949:           `merge gate opened — all ${next.depends_on.length} dependencies satisfied`\n950:         );\n951:       }\n952:     }\n953: \n954:     await launchSingleHeadless(projectRoot, state, next, feature, monitor, config, model, agentResolutions, questContext, hitlMode);\n955:     // Stagger between launches to avoid SQLite race conditions\n956:     if (i < toLaunch.length - 1) {\n957:       await new Promise((r) => setTimeout(r, LAUNCH_STAGGER_MS));\n958:     }\n959:   }\n960: }\n961: \n962: // ---------------------------------------------------------------------------\n963: // Post-mortem: dump failed agent logs\n964: // ---------------------------------------------------------------------------\n965: \n966: /**\n967:  * Print full log contents for every failed agent so the user can diagnose\n968:  * issues after the wave finishes. Handles missing log files gracefully.\n969:  *\n970:  * In JSON/TOON mode, this function is a no-op — callers should emit\n971:  * structured failure data through the output() helper instead.\n972:  *\n973:  * @param fmt - Output format. Only prints when \"text\".\n974:  */\n975: export function dumpFailedAgentLogs(projectRoot: string, state: WaveState, fmt: OutputFormat = \"text\"): void {\n976:   if (fmt !== \"text\") return; // suppress in JSON/TOON mode\n977: \n978:   const failed = state.agents.filter((a) => a.status === \"failed\");\n979:   if (failed.length === 0) return;\n980: \n981:   const logDir = resolve(projectRoot, \".wombo-combo/logs\");\n982: \n983:   console.log(\n984:     `\\n${\"=\".repeat(72)}\\n` +\n985:     `  FAILED AGENT LOGS (${failed.length} agent${failed.length > 1 ? \"s\" : \"\"})\\n` +\n986:     `${\"=\".repeat(72)}`\n987:   );\n988: \n989:   for (const agent of failed) {\n990:     const logFile = resolve(logDir, `${agent.feature_id}.log`);\n991: \n992:     console.log(\n993:       `\\n${\"─\".repeat(72)}\\n` +\n994:       `  Feature: ${agent.feature_id}\\n` +\n995:       (agent.error ? `  Error:   ${agent.error}\\n` : \"\") +\n996:       `${\"─\".repeat(72)}`\n997:     );\n998: \n999:     if (!existsSync(logFile)) {\n1000:       console.log(\"  (no log file found)\");\n1001:       continue;\n1002:     }\n1003: \n1004:     try {\n1005:       const contents = readFileSync(logFile, \"utf-8\");\n1006:       if (contents.trim().length === 0) {\n1007:         console.log(\"  (log file is empty)\");\n1008:       } else {\n1009:         console.log(contents);\n1010:       }\n1011:     } catch (err: any) {\n1012:       console.log(`  (error reading log: ${err.message})`);\n1013:     }\n1014:   }\n1015: \n1016:   console.log(`\\n${\"=\".repeat(72)}\\n`);\n1017: }\n1018: \n1019: // ---------------------------------------------------------------------------\n1020: // Headless Wave Launch\n1021: // ---------------------------------------------------------------------------\n1022: \n1023: async function launchWaveHeadless(\n1024:   projectRoot: string,\n1025:   state: WaveState,\n1026:   features: Feature[],\n1027:   opts: LaunchCommandOptions,\n1028:   agentResolutions?: Map<string, AgentResolution>,\n1029:   questContext?: QuestPromptContext,\n1030:   hitlMode?: string\n1031: ): Promise<void> {\n1032:   const { config, model } = opts;\n1033:   const fmt = opts.outputFmt ?? \"text\";\n1034:   const featureMap = new Map(features.map((f) => [f.id, f]));\n1035: \n1036:   const monitor = new ProcessMonitor(projectRoot, {\n1037:     onSessionId: (featureId, sessionId) => {\n1038:       updateAgent(state, featureId, { session_id: sessionId });\n1039:       saveState(projectRoot, state);\n1040:     },\n1041:     onComplete: (featureId) => {\n1042:       updateAgent(state, featureId, {\n1043:         status: \"completed\",\n1044:         completed_at: new Date().toISOString(),\n1045:       });\n1046:       saveState(projectRoot, state);\n1047: \n1048:       // Run build verification — fire-and-forget\n1049:       const agent = state.agents.find((a) => a.feature_id === featureId)!;\n1050:       handleBuildVerification(projectRoot, state, agent, featureMap.get(featureId)!, config, model, monitor, undefined, hitlMode)\n1051:         .then(() => {\n1052:           // After verification/merge, try to launch dependency-ready agents\n1053:           // Multiple queued agents may now be unblocked\n1054:           launchAllReady(projectRoot, state, featureMap, monitor, config, model, agentResolutions, questContext, hitlMode)\n1055:             .catch((err) => wtLog(featureId, `LAUNCH ERROR: ${err.message}`));\n1056:         })\n1057:         .catch((err) => {\n1058:           wtLog(featureId, `BUILD VERIFICATION UNHANDLED ERROR: ${err.message}`);\n1059:           launchAllReady(projectRoot, state, featureMap, monitor, config, model, agentResolutions, questContext, hitlMode)\n1060:             .catch((err2) => wtLog(featureId, `LAUNCH ERROR: ${err2.message}`));\n1061:         });\n1062:     },\n1063:     onError: (featureId, error) => {\n1064:       const agent = state.agents.find((a) => a.feature_id === featureId)!;\n1065:       if (agent.retries < agent.max_retries) {\n1066:         updateAgent(state, featureId, {\n1067:           status: \"retry\",\n1068:           retries: agent.retries + 1,\n1069:           error,\n1070:         });\n1071:         saveState(projectRoot, state);\n1072: \n1073:         // Retry\n1074:         handleRetry(projectRoot, state, agent, monitor, config, model, hitlMode);\n1075:       } else {\n1076:         updateAgent(state, featureId, {\n1077:           status: \"failed\",\n1078:           error,\n1079:           completed_at: new Date().toISOString(),\n1080:         });\n1081:         saveState(projectRoot, state);\n1082: \n1083:         // Cascade failure to downstream agents\n1084:         const cancelled = cancelDownstream(state, featureId);\n1085:         if (cancelled.length > 0) {\n1086:           wtLog(featureId, `downstream cancelled: ${cancelled.join(\", \")}`);\n1087:           saveState(projectRoot, state);\n1088:         }\n1089:       }\n1090: \n1091:       // Try to launch dependency-ready agents\n1092:       launchAllReady(projectRoot, state, featureMap, monitor, config, model, agentResolutions, questContext, hitlMode)\n1093:         .catch((err) => wtLog(featureId, `LAUNCH ERROR: ${err.message}`));\n1094:     },\n1095:     onOutput: (_featureId, _data) => {\n1096:       // Raw output — logged to file by ProcessMonitor\n1097:     },\n1098:     onActivity: (featureId, activity) => {\n1099:       updateAgent(state, featureId, {\n1100:         activity,\n1101:         activity_updated_at: new Date().toISOString(),\n1102:       });\n1103:       // Don't save to disk on every activity — too frequent.\n1104:     },\n1105:   });\n1106: \n1107:   // Create the TUI — it will auto-refresh and show activity from the monitor\n1108:   const tuiRef = { current: null as WomboTUI | null };\n1109:   const startTUI = () => {\n1110:     tuiRef.current = new WomboTUI({\n1111:       state,\n1112:       monitor,\n1113:       projectRoot,\n1114:       interactive: false,\n1115:       config,\n1116:       onQuit: () => {\n1117:           // Audit (wave-detach-audit): This is the TUI quit path — equivalent\n1118:           // to the SIGINT handler. Kills all agents, saves state, and exits.\n1119:           // Agents are non-detached children, so they die when we exit anyway,\n1120:           // but explicit killAll() gives them SIGTERM for graceful shutdown.\n1121:           for (const agent of state.agents) {\n1122:             if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n1123:             updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n1124:           }\n1125:         }\n1126:         monitor.killAll();\n1127:         flushState(projectRoot, state);\n1128:         if (fmt === \"text\") console.log(\"State saved. Use 'woco resume' to continue.\");\n1129:         process.exit(0);\n1130:       },\n1131:       onBeforeDestroy: () => {\n1132:         // Flush state to disk before the blessed screen is destroyed.\n1133:         // This is called from TUI.stop() which runs before screen.destroy(),\n1134:         // ensuring state.json is complete even if process.exit() follows.\n1135:         flushState(projectRoot, state);\n1136:       },\n1137:       onRetry: (featureId: string) => {\n1138:         const agent = state.agents.find((a) => a.feature_id === featureId);\n1139:         if (!agent) return;\n1140:         if (agent.status !== \"failed\" && agent.status !== \"retry\") return;\n1141: \n1142:         // Reset retries if exhausted, give it one more shot\n1143:         if (agent.retries >= agent.max_retries) {\n1144:           updateAgent(state, featureId, { max_retries: agent.retries + 1 });\n1145:         }\n1146: \n1147:         wtLog(featureId, `manual retry requested from TUI — resetting to queued`);\n1148:         updateAgent(state, featureId, {\n1149:           status: \"queued\",\n1150:           error: null,\n1151:           activity: \"waiting for relaunch (manual retry)...\",\n1152:         });\n1153:         saveState(projectRoot, state);\n1154:         // The polling loop will call launchAllReady() and pick this up\n1155:       },\n1156:       onAnswer: (agentId: string, questionId: string, answerText: string) => {\n1157:         try {\n1158:           submitAnswer(projectRoot, agentId, questionId, answerText);\n1159:           wtLog(agentId, `HITL answer submitted: \"${answerText.slice(0, 80)}${answerText.length > 80 ? \"...\" : \"\"}\"`);\n1160:         } catch (err: any) {\n1161:           wtLog(agentId, `HITL answer error: ${err.message}`);\n1162:         }\n1163:       },\n1164:     });\n1165:     tuiRef.current.start();\n1166:   };\n1167: \n1168:   // Handle graceful shutdown\n1169:   //\n1170:   // Audit (wave-detach-audit): This is the critical shutdown path for headless\n1171:   // agents. Because agents are spawned with `detached: false` (see launcher.ts),\n1172:   // they would be killed by the OS when the parent exits anyway. However, calling\n1173:   // `monitor.killAll()` explicitly before `process.exit(0)` ensures:\n1174:   //   1. Each agent gets SIGTERM (not SIGKILL), allowing graceful shutdown\n1175:   //   2. Wave state is saved BEFORE agents die, preserving progress\n1176:   //   3. The TUI is cleanly destroyed before terminal restoration\n1177:   //\n1178:   // If the parent is killed with SIGKILL (uncatchable), agents die immediately\n1179:   // with no state save. `woco resume` recovers from this by detecting orphaned\n1180:   // worktrees with commits and re-verifying or re-launching as appropriate.\n1181:   const gracefulShutdown = (signal: string) => {\n1182:     if (tuiRef.current) tuiRef.current.stop();\n1183:     for (const agent of state.agents) {\n1184:       if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n1185:         updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n1186:       }\n1187:     }\n1188:     monitor.killAll();\n1189:     flushState(projectRoot, state);\n1190:     if (fmt === \"text\") console.log(`\\nState saved (${signal}). Use 'woco resume' to continue.`);\n1191:     process.exit(0);\n1192:   };\n1193:   process.on(\"SIGINT\", () => gracefulShutdown(\"SIGINT\"));\n1194:   process.on(\"SIGTERM\", () => gracefulShutdown(\"SIGTERM\"));\n1195:   process.on(\"SIGHUP\", () => gracefulShutdown(\"SIGHUP\"));\n1196: \n1197:   // Launch initial batch — only agents whose dependencies are already satisfied\n1198:   // Stagger launches to avoid SQLite race conditions in agent processes:\n1199:   // each agent spawns its own DB, and simultaneous CREATE TABLE calls collide.\n1200:   const ready = readyToLaunchAgents(state);\n1201:   const tolaunch = ready.slice(0, opts.maxConcurrent);\n1202:   if (fmt === \"text\") console.log(`Setting up ${tolaunch.length} agent(s) (staggered)...\\n`);\n1203: \n1204:   for (let i = 0; i < tolaunch.length; i++) {\n1205:     await launchSingleHeadless(\n1206:       projectRoot,\n1207:       state,\n1208:       tolaunch[i],\n1209:       featureMap.get(tolaunch[i].feature_id)!,\n1210:       monitor,\n1211:       config,\n1212:       model,\n1213:       agentResolutions,\n1214:       questContext,\n1215:       hitlMode\n1216:     );\n1217:     // Brief delay between spawns so each agent's DB migration settles\n1218:     if (i < tolaunch.length - 1) {\n1219:       await new Promise((r) => setTimeout(r, LAUNCH_STAGGER_MS));\n1220:     }\n1221:   }\n1222: \n1223:   const launched = state.agents.filter((a) => a.status === \"running\").length;\n1224: \n1225:   // Start the TUI dashboard (or skip if --no-tui)\n1226:   if (opts.noTui) {\n1227:     if (fmt === \"text\") {\n1228:       console.log(`${launched} agent(s) running. (--no-tui mode, dashboard prints every 15s)\\n`);\n1229:       printDashboard(state);\n1230:     }\n1231:   } else {\n1232:     if (fmt === \"text\") console.log(`${launched} agent(s) running. Launching TUI...\\n`);\n1233:     startTUI();\n1234:   }\n1235: \n1236:   // Background monitoring loop — checks for dead processes and launches queued\n1237:   const POLL_INTERVAL = 5000;\n1238:   let dashboardCounter = 0;\n1239:   while (!isWaveComplete(state)) {\n1240:     await new Promise((r) => setTimeout(r, POLL_INTERVAL));\n1241: \n1242:     // Check for completed processes that weren't caught by event handlers\n1243:     for (const agent of state.agents) {\n1244:       if (\n1245:         (agent.status === \"running\" || agent.status === \"resolving_conflict\") &&\n1246:         agent.pid &&\n1247:         !isProcessRunning(agent.pid) &&\n1248:         !monitor.isRunning(agent.feature_id)\n1249:       ) {\n1250:         if (agent.status === \"resolving_conflict\") {\n1251:           // Conflict resolver died — the await in handleBuildVerification\n1252:           // will resolve via the 'exit' event, so nothing to do here\n1253:           continue;\n1254:         }\n1255:         // Process exited but we didn't get a callback\n1256:         // Check if the agent actually made any commits\n1257:         if (!branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n1258:           // Agent died without producing any code — mark as failed, not completed\n1259:           updateAgent(state, agent.feature_id, {\n1260:             status: \"failed\",\n1261:             error: \"Agent process exited without making any commits\",\n1262:             activity: null,\n1263:             completed_at: new Date().toISOString(),\n1264:           });\n1265:           saveState(projectRoot, state);\n1266:           wtLog(agent.feature_id, \"process died with no code changes — marked failed\");\n1267: \n1268:           // Cascade failure to downstream agents\n1269:           const cancelled = cancelDownstream(state, agent.feature_id);\n1270:           if (cancelled.length > 0) {\n1271:             wtLog(agent.feature_id, `downstream cancelled: ${cancelled.join(\", \")}`);\n1272:             saveState(projectRoot, state);\n1273:           }\n1274:         } else {\n1275:           updateAgent(state, agent.feature_id, {\n1276:             status: \"completed\",\n1277:             completed_at: new Date().toISOString(),\n1278:             activity: \"done\",\n1279:           });\n1280:           saveState(projectRoot, state);\n1281:           try {\n1282:             await handleBuildVerification(projectRoot, state, agent, featureMap.get(agent.feature_id)!, config, model, monitor, undefined, hitlMode);\n1283:           } catch (err: any) {\n1284:             wtLog(agent.feature_id, `POLL VERIFY ERROR: ${err.message}`);\n1285:           }\n1286:         }\n1287:         await launchAllReady(projectRoot, state, featureMap, monitor, config, model, agentResolutions, questContext, hitlMode);\n1288:       }\n1289:     }\n1290: \n1291:     // Safety net: detect agents stuck in \"retry\" with no running process.\n1292:     // This catches edge cases where handleRetry() wasn't called or failed\n1293:     // to reset the agent (e.g. race between onError callback and poll loop).\n1294:     for (const agent of state.agents) {\n1295:       if (\n1296:         agent.status === \"retry\" &&\n1297:         (!agent.pid || !isProcessRunning(agent.pid)) &&\n1298:         !monitor.isRunning(agent.feature_id)\n1299:       ) {\n1300:         if (agent.retries >= agent.max_retries) {\n1301:           // Out of retries — mark as failed and cascade\n1302:           wtLog(agent.feature_id, `stuck in retry with no process and retries exhausted (${agent.retries}/${agent.max_retries}) — marking failed`);\n1303:           updateAgent(state, agent.feature_id, {\n1304:             status: \"failed\",\n1305:             error: agent.error ?? \"Agent stuck in retry state with no running process\",\n1306:             activity: null,\n1307:             completed_at: new Date().toISOString(),\n1308:           });\n1309:           saveState(projectRoot, state);\n1310:           const cancelled = cancelDownstream(state, agent.feature_id);\n1311:           if (cancelled.length > 0) {\n1312:             wtLog(agent.feature_id, `downstream cancelled: ${cancelled.join(\", \")}`);\n1313:             saveState(projectRoot, state);\n1314:           }\n1315:         } else {\n1316:           // Has retries left — reset to queued for a fresh launch\n1317:           wtLog(agent.feature_id, `stuck in retry with no process — resetting to queued (retry ${agent.retries}/${agent.max_retries})`);\n1318:           updateAgent(state, agent.feature_id, {\n1319:             status: \"queued\",\n1320:             error: null,\n1321:             activity: \"waiting for relaunch...\",\n1322:           });\n1323:           saveState(projectRoot, state);\n1324:         }\n1325:       }\n1326:     }\n1327: \n1328:     // After recovering stuck agents, try launching any that are now ready\n1329:     await launchAllReady(projectRoot, state, featureMap, monitor, config, model, agentResolutions, questContext, hitlMode);\n1330: \n1331:     // Persist state periodically\n1332:     saveState(projectRoot, state);\n1333: \n1334:     // Poll for HITL questions from agents and forward to TUI\n1335:     if (hitlMode && hitlMode !== \"yolo\") {\n1336:       try {\n1337:         const pendingQuestions = getPendingQuestions(projectRoot);\n1338:         if (tuiRef.current && pendingQuestions.length > 0) {\n1339:           tuiRef.current.setPendingQuestions(pendingQuestions);\n1340:         }\n1341:       } catch {\n1342:         // Non-fatal — HITL dir may not exist yet\n1343:       }\n1344:     }\n1345: \n1346:     // Update TUI state reference (or print dashboard in --no-tui mode)\n1347:     if (tuiRef.current) {\n1348:       tuiRef.current.updateState(state);\n1349:     } else if (opts.noTui && fmt === \"text\") {\n1350:       dashboardCounter++;\n1351:       if (dashboardCounter % 3 === 0) {\n1352:         printDashboard(state);\n1353: \n1354:         // Auto-push base branch if requested\n1355:         if (opts.autoPush) {\n1356:           const anyMerged = state.agents.some((a) => a.status === \"merged\");\n1357:           if (anyMerged) {\n1358:             await pushBaseBranch(projectRoot, state.base_branch, config);\n1359:           } else {\n1360:             console.log(\"No branches were merged — skipping push.\");\n1361:           }\n1362:         }\n1363:       }\n1364:     }\n1365:   }\n1366: \n1367:   // Wave complete — keep TUI open for post-mortem browsing\n1368:   if (tuiRef.current) {\n1369:     tuiRef.current.updateState(state);\n1370:     tuiRef.current.markWaveComplete();\n1371:     // Wait for the user to press q to exit the TUI\n1372:     await tuiRef.current.waitForQuit();\n1373:   }\n1374: \n1375:   // Print final dashboard after TUI is closed\n1376:   if (fmt === \"text\") printDashboard(state);\n1377: \n1378:   // Clean up HITL files\n1379:   try {\n1380:     cleanupHitl(projectRoot);\n1381:   } catch {\n1382:     // Non-fatal\n1383:   }\n1384: \n1385:   // Dump full logs for failed agents (post-mortem)\n1386:   dumpFailedAgentLogs(projectRoot, state, fmt);\n1387: \n1388:   // Auto-export wave history\n1389:   try {\n1390:     const historyPath = exportWaveHistory(projectRoot, state);\n1391:     if (fmt === \"text\") console.log(`Wave history exported to ${historyPath}`);\n1392:   } catch (err: any) {\n1393:     if (fmt === \"text\") console.error(`Warning: failed to export wave history: ${err.message}`);\n1394:   }\n1395: \n1396:   // Auto-push base branch if requested\n1397:   if (opts.autoPush) {\n1398:     await pushBaseBranch(projectRoot, state.base_branch, config);\n1399:   }\n1400: \n1401:   // Completion double-check: verify worktrees directory is empty\n1402:   if (fmt === \"text\") {\n1403:     if (isWorktreesDirEmpty(projectRoot)) {\n1404:       console.log(\"All worktrees cleaned up — worktrees directory is empty.\");\n1405:     } else {\n1406:       console.log(\"\\x1b[33mNote:\\x1b[0m worktrees directory still has contents. Run 'woco cleanup' to clean up.\");\n1407:     }\n1408: \n1409:     console.log(\"Wave complete.\");\n1410:   }\n1411: }\n1412: \n1413: // ---------------------------------------------------------------------------\n1414: // Interactive Wave Launch\n1415: // ---------------------------------------------------------------------------\n1416: \n1417: async function launchWaveInteractive(\n1418:   projectRoot: string,\n1419:   state: WaveState,\n1420:   features: Feature[],\n1421:   opts: LaunchCommandOptions,\n1422:   agentResolutions?: Map<string, AgentResolution>,\n1423:   questContext?: QuestPromptContext,\n1424:   hitlMode?: string\n1425: ): Promise<void> {\n\n(Output capped at 50 KB. Showing lines 1-1425. Use offset=1426 to continue.)\n</content>","title":"src/commands/launch.ts","metadata":{"preview":"/**\n * launch.ts — Launch a wave of agents.\n *\n * Usage: woco launch [selection options] [launch options]\n *\n * This is the primary entry point for starting a new wave. It selects features\n * from the features file, creates a wave state, sets up worktrees, and launches\n * agent processes (either headless or interactive via dmux/tmux).\n *\n * IMPORTANT: This file also exports shared helper functions that are reused\n * by resume.ts and other commands:\n *   - launchSingleHeadless\n *   - handleBuildVerification\n *   - handleRetry\n *   - launchNextQueued\n */\n\nimport { execSync } from \"node:child_process\";\nimport { existsSync, readFileSync } from \"node:fs\";\nimport { resolve } from \"node:path\";","truncated":true,"loaded":[]},"time":{"start":1773483373516,"end":1773483373521}}}}
{"type":"text","timestamp":1773483373876,"sessionID":"ses_31427856effefwaC38OEq6YCmn","part":{"id":"prt_cebd8aaea001Zw0m12F72TsChN","sessionID":"ses_31427856effefwaC38OEq6YCmn","messageID":"msg_cebd8a245001cWpvKxkO5YPSfc","type":"text","text":"Now let me also look at the launch.ts and resume.ts commands to see how the onQuit callback is wired up, and the signal handling:","time":{"start":1773483373875,"end":1773483373875}}}
{"type":"tool_use","timestamp":1773483373910,"sessionID":"ses_31427856effefwaC38OEq6YCmn","part":{"id":"prt_cebd8b3cd001nwrfKp6qlhvRHi","sessionID":"ses_31427856effefwaC38OEq6YCmn","messageID":"msg_cebd8a245001cWpvKxkO5YPSfc","type":"tool","callID":"toolu_vrtx_0117XeVjzMA8e2AM41Cctw8p","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/wave-detach-audit/src/commands/resume.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/wave-detach-audit/src/commands/resume.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * resume.ts — Resume a previously stopped wave.\n3:  *\n4:  * Usage: woco resume [options] [--output json]\n5:  *\n6:  * Restores from .wombo-combo/state.json:\n7:  *   - Agents in \"running\"/\"installing\" whose PID is dead → re-check or re-launch\n8:  *   - Agents in \"queued\" → launch them\n9:  *   - Agents in terminal states (verified/failed/merged) → leave alone\n10:  *\n11:  * ## Agent Recovery (audit: wave-detach-audit)\n12:  *\n13:  * This is the primary recovery mechanism for agents that died when the parent\n14:  * process was terminated (gracefully via SIGINT, or ungracefully via SIGKILL/crash).\n15:  *\n16:  * Recovery triage for each agent:\n17:  *   - PID still alive → leave it running (another wombo instance may still be active)\n18:  *   - PID dead + worktree has commits → run build verification on existing work\n19:  *   - PID dead + no commits → reset to \"queued\" for a fresh re-launch\n20:  *   - \"completed\" → verify build\n21:  *   - \"verified\" → attempt merge\n22:  *   - \"failed\" with retries remaining + worktree has commits → re-verify\n23:  *   - \"failed\" with retries remaining + no commits → re-launch\n24:  *   - \"failed\" with retries exhausted → leave alone (user can `woco retry`)\n25:  *\n26:  * This design means no agent work is permanently lost unless the worktree\n27:  * itself is destroyed (e.g., by `woco cleanup`).\n28:  */\n29: \n30: import type { WomboConfig } from \"../config.js\";\n31: import type { Feature } from \"../lib/tasks.js\";\n32: import { loadFeatures } from \"../lib/tasks.js\";\n33: import {\n34:   loadState,\n35:   saveState,\n36:   flushState,\n37:   updateAgent,\n38:   queuedAgents,\n39:   readyToLaunchAgents,\n40:   cancelDownstream,\n41:   isWaveComplete,\n42:   type WaveState,\n43:   type AgentState,\n44: } from \"../lib/state.js\";\n45: import {\n46:   createWorktree,\n47:   installDeps,\n48:   worktreeReady,\n49:   worktreeExists,\n50:   branchHasChanges,\n51:   removeWorktree,\n52:   log as wtLog,\n53: } from \"../lib/worktree.js\";\n54: import { generatePrompt, type QuestPromptContext } from \"../lib/prompt.js\";\n55: import {\n56:   launchInteractive,\n57:   isProcessRunning,\n58:   getMultiplexerName,\n59: } from \"../lib/launcher.js\";\n60: import { ProcessMonitor } from \"../lib/monitor.js\";\n61: import { pushBaseBranch } from \"../lib/merger.js\";\n62: import { runBuild } from \"../lib/verifier.js\";\n63: import { printDashboard, printAgentUpdate } from \"../lib/ui.js\";\n64: import { WomboTUI } from \"../lib/tui.js\";\n65: import {\n66:   launchSingleHeadless,\n67:   handleBuildVerification,\n68:   handleRetry,\n69:   launchNextQueued,\n70:   launchAllReady,\n71:   markFeatureDone,\n72:   attemptMerge,\n73:   dumpFailedAgentLogs,\n74: } from \"./launch.js\";\n75: import {\n76:   detectMultiplexer,\n77:   muxAttachCommand,\n78: } from \"../lib/multiplexer.js\";\n79: import { exportWaveHistory } from \"../lib/history.js\";\n80: import { outputError, outputMessage, type OutputFormat } from \"../lib/output.js\";\n81: import {\n82:   prepareAgentDefinitions,\n83:   isSpecializedAgent,\n84:   type AgentResolution,\n85: } from \"../lib/agent-registry.js\";\n86: import { patchImportedAgent } from \"../lib/templates.js\";\n87: import { writeAgentToWorktree } from \"../lib/agent-registry.js\";\n88: import { loadQuest, loadQuestKnowledge } from \"../lib/quest-store.js\";\n89: import { resolveQuestConfig, type QuestHitlMode } from \"../lib/quest.js\";\n90: import { getPendingQuestions, cleanupAll as cleanupHitl, submitAnswer, type HitlQuestion } from \"../lib/hitl-channel.js\";\n91: \n92: // ---------------------------------------------------------------------------\n93: // Types\n94: // ---------------------------------------------------------------------------\n95: \n96: export interface ResumeCommandOptions {\n97:   projectRoot: string;\n98:   config: WomboConfig;\n99:   maxConcurrent?: number;\n100:   model?: string;\n101:   interactive: boolean;\n102:   noTui: boolean;\n103:   autoPush: boolean;\n104:   baseBranch?: string;\n105:   maxRetries?: number;\n106:   outputFmt?: OutputFormat;\n107: }\n108: \n109: // ---------------------------------------------------------------------------\n110: // Command\n111: // ---------------------------------------------------------------------------\n112: \n113: export async function cmdResume(opts: ResumeCommandOptions): Promise<void> {\n114:   const { projectRoot } = opts;\n115:   let { config } = opts;\n116:   const fmt = opts.outputFmt ?? \"text\";\n117: \n118:   const state = loadState(projectRoot);\n119:   if (!state) {\n120:     outputError(fmt, \"No wave state found. Use 'woco launch' to start a new wave.\");\n121:     return; // unreachable — outputError calls process.exit\n122:   }\n123: \n124:   if (fmt === \"text\") {\n125:     console.log(`\\n--- wombo-combo: Resume ${state.wave_id} ---\\n`);\n126:   }\n127: \n128:   // Reconstruct quest context from wave state (if quest-scoped)\n129:   let questContext: QuestPromptContext | undefined;\n130:   let hitlMode: string | undefined;\n131:   if (state.quest_id) {\n132:     const quest = loadQuest(projectRoot, state.quest_id);\n133:     if (quest) {\n134:       config = resolveQuestConfig(config, quest);\n135:       hitlMode = quest.hitlMode;\n136:       const knowledge = loadQuestKnowledge(projectRoot, state.quest_id);\n137:       questContext = {\n138:         questId: quest.id,\n139:         goal: quest.goal,\n140:         addedConstraints: quest.constraints.add ?? [],\n141:         addedForbidden: quest.constraints.ban ?? [],\n142:         knowledge,\n143:       };\n144:       if (fmt === \"text\") {\n145:         console.log(`Quest: ${quest.title} (${quest.id})\\n`);\n146:       }\n147:     } else if (fmt === \"text\") {\n148:       console.warn(`Warning: wave references quest \"${state.quest_id}\" but it was not found.\\n`);\n149:     }\n150:   }\n151: \n152:   // Load feature data for prompt generation\n153:   const data = loadFeatures(projectRoot, config);\n154:   const featureMap = new Map(data.tasks.map((f: Feature) => [f.id, f]));\n155: \n156:   // Triage agents by current state\n157:   let toRelaunch: AgentState[] = [];\n158:   let toVerify: AgentState[] = [];\n159:   let stillAlive: AgentState[] = [];\n160: \n161:   for (const agent of state.agents) {\n162:     switch (agent.status) {\n163:       case \"running\":\n164:       case \"installing\":\n165:       case \"retry\":\n166:       case \"resolving_conflict\":\n167:         // Was in-flight when we stopped — check if PID is still alive\n168:         if (agent.pid && isProcessRunning(agent.pid)) {\n169:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: still running (PID ${agent.pid})`);\n170:           stillAlive.push(agent);\n171:         } else {\n172:           // Process is dead — check if worktree exists with meaningful changes.\n173:           // Use worktreeExists (not worktreeReady) because node_modules may be\n174:           // missing — the worktree still has code that should be verified.\n175:           if (worktreeExists(agent.worktree) && branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n176:             // Worktree exists AND branch has commits — try build verification\n177:             if (fmt === \"text\") console.log(`  ${agent.feature_id}: process dead, worktree has changes — will verify build`);\n178:             toVerify.push(agent);\n179:           } else {\n180:             // No worktree, or worktree exists but branch has no commits (agent did nothing)\n181:             const reason = worktreeExists(agent.worktree)\n182:               ? \"worktree exists but no code changes\"\n183:               : \"no worktree\";\n184:             if (fmt === \"text\") console.log(`  ${agent.feature_id}: process dead, ${reason} — will re-launch`);\n185:             updateAgent(state, agent.feature_id, {\n186:               status: \"queued\",\n187:               pid: null,\n188:               activity: null,\n189:               session_id: null,\n190:             });\n191:             toRelaunch.push(agent);\n192:           }\n193:         }\n194:         break;\n195: \n196:       case \"queued\":\n197:         if (fmt === \"text\") console.log(`  ${agent.feature_id}: queued — will launch`);\n198:         toRelaunch.push(agent);\n199:         break;\n200: \n201:       case \"completed\":\n202:         // Completed but not verified — verify\n203:         if (fmt === \"text\") console.log(`  ${agent.feature_id}: completed — will verify build`);\n204:         toVerify.push(agent);\n205:         break;\n206: \n207:       case \"verified\":\n208:         // Build passed but NOT yet merged — need to attempt merge (+ conflict resolution)\n209:         if (fmt === \"text\") console.log(`  ${agent.feature_id}: verified — will attempt merge`);\n210:         toVerify.push(agent);\n211:         break;\n212: \n213:       case \"merged\":\n214:         if (fmt === \"text\") console.log(`  ${agent.feature_id}: merged — marking feature as done`);\n215:         markFeatureDone(projectRoot, agent.feature_id, config, state.base_branch, fmt);\n216:         try {\n217:           removeWorktree(projectRoot, agent.worktree, true);\n218:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: worktree and branch removed`);\n219:         } catch {\n220:           // Already cleaned — not critical\n221:         }\n222:         break;\n223: \n224:       case \"failed\":\n225:         // If the worktree exists with code changes and retries remain,\n226:         // attempt build verification rather than discarding the work.\n227:         if (agent.retries < agent.max_retries &&\n228:             worktreeExists(agent.worktree) &&\n229:             branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n230:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: failed but has work (retry ${agent.retries}/${agent.max_retries}) — will verify build`);\n231:           // Clear stale error and mark as completed so handleBuildVerification\n232:           // processes it correctly (it expects a non-failed agent)\n233:           updateAgent(state, agent.feature_id, {\n234:             status: \"completed\",\n235:             error: null,\n236:             build_passed: null,\n237:             build_output: null,\n238:             completed_at: new Date().toISOString(),\n239:           });\n240:           toVerify.push(agent);\n241:         } else if (agent.retries < agent.max_retries) {\n242:           // No worktree or no changes — re-launch from scratch\n243:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: failed, no salvageable work (retry ${agent.retries}/${agent.max_retries}) — will re-launch`);\n244:           updateAgent(state, agent.feature_id, {\n245:             status: \"queued\",\n246:             pid: null,\n247:             error: null,\n248:             build_passed: null,\n249:             build_output: null,\n250:             activity: null,\n251:             session_id: null,\n252:             completed_at: null,\n253:           });\n254:           toRelaunch.push(agent);\n255:         } else {\n256:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: failed — max retries reached (use 'woco retry' to reset)`);\n257:         }\n258:         break;\n259:     }\n260:   }\n261: \n262:   saveState(projectRoot, state);\n263: \n264:   // ---------------------------------------------------------------------------\n265:   // Phase 1: Parallel build verification\n266:   // Each agent's worktree is independent, so dep install + build can run\n267:   // concurrently. Merges must remain sequential (they mutate the project root).\n268:   // ---------------------------------------------------------------------------\n269:   if (toVerify.length > 0) {\n270:     if (fmt === \"text\") console.log(`\\nVerifying ${toVerify.length} agent(s) in parallel...\\n`);\n271: \n272:     const verifyResults = await Promise.all(\n273:       toVerify.map(async (agent): Promise<{ agent: AgentState; needsMerge: boolean }> => {\n274:         const feature = featureMap.get(agent.feature_id);\n275:         if (!feature) return { agent, needsMerge: false };\n276: \n277:         // Already verified — skip build, go straight to merge\n278:         if (agent.status === \"verified\") {\n279:           printAgentUpdate(agent, \"already verified — queued for merge\");\n280:           return { agent, needsMerge: true };\n281:         }\n282: \n283:         printAgentUpdate(agent, \"verifying build...\");\n284: \n285:         // Ensure deps are installed — worktree may exist without node_modules\n286:         // (e.g., failed agents whose setup was interrupted)\n287:         if (!worktreeReady(agent.worktree) && worktreeExists(agent.worktree)) {\n288:           try {\n289:             printAgentUpdate(agent, \"installing deps...\");\n290:             await installDeps(agent.worktree, agent.feature_id, config);\n291:           } catch (depErr: any) {\n292:             printAgentUpdate(agent, `dep install failed: ${depErr.message}`);\n293:             updateAgent(state, agent.feature_id, {\n294:               status: \"failed\",\n295:               error: `Dependency install failed: ${depErr.message}`,\n296:               retries: agent.retries + 1,\n297:               completed_at: new Date().toISOString(),\n298:             });\n299:             saveState(projectRoot, state);\n300:             return { agent, needsMerge: false };\n301:           }\n302:         }\n303: \n304:         try {\n305:           const buildResult = await runBuild(agent.worktree, config);\n306:           if (buildResult.passed) {\n307:             updateAgent(state, agent.feature_id, {\n308:               status: \"verified\",\n309:               build_passed: true,\n310:               build_output: null,\n311:             });\n312:             saveState(projectRoot, state);\n313:             printAgentUpdate(agent, `BUILD PASSED (${Math.round(buildResult.durationMs / 1000)}s)`);\n314:             return { agent, needsMerge: true };\n315:           } else {\n316:             // Build failed\n317:             if (agent.retries < agent.max_retries) {\n318:               updateAgent(state, agent.feature_id, {\n319:                 status: \"retry\",\n320:                 retries: agent.retries + 1,\n321:                 build_passed: false,\n322:                 build_output: buildResult.errorSummary,\n323:               });\n324:               saveState(projectRoot, state);\n325:               printAgentUpdate(agent, `BUILD FAILED — will retry (${agent.retries + 1}/${agent.max_retries})`);\n326:             } else {\n327:               updateAgent(state, agent.feature_id, {\n328:                 status: \"failed\",\n329:                 build_passed: false,\n330:                 build_output: buildResult.errorSummary,\n331:                 error: `Build failed after ${agent.max_retries} retries`,\n332:                 completed_at: new Date().toISOString(),\n333:               });\n334:               saveState(projectRoot, state);\n335:               printAgentUpdate(agent, \"BUILD FAILED — max retries reached\");\n336:             }\n337:             return { agent, needsMerge: false };\n338:           }\n339:         } catch (err: any) {\n340:           printAgentUpdate(agent, `verify error: ${err.message}`);\n341:           updateAgent(state, agent.feature_id, {\n342:             status: \"failed\",\n343:             error: `Build verification error: ${err.message}`,\n344:             completed_at: new Date().toISOString(),\n345:           });\n346:           saveState(projectRoot, state);\n347:           return { agent, needsMerge: false };\n348:         }\n349:       })\n350:     );\n351: \n352:     saveState(projectRoot, state);\n353: \n354:     // -------------------------------------------------------------------------\n355:     // Phase 2: Sequential merge for verified agents\n356:     // Merges must be sequential because they operate on the project root.\n357:     // -------------------------------------------------------------------------\n358:     const toMerge = verifyResults.filter((r) => r.needsMerge);\n359:     if (toMerge.length > 0) {\n360:       if (fmt === \"text\") console.log(`\\nMerging ${toMerge.length} verified agent(s)...\\n`);\n361:       for (const { agent } of toMerge) {\n362:         const feature = featureMap.get(agent.feature_id);\n363:         if (!feature) continue;\n364:         try {\n365:           await attemptMerge(projectRoot, state, agent, feature, config, opts.model);\n366:         } catch (err: any) {\n367:           printAgentUpdate(agent, `merge error: ${err.message}`);\n368:         }\n369:       }\n370:     }\n371: \n372:     // Collect agents that need re-launching from verify results\n373:     for (const { agent } of verifyResults) {\n374:       if (agent.status === \"retry\" || agent.status === \"running\") {\n375:         toRelaunch.push(agent);\n376:       }\n377:     }\n378:   }\n379: \n380:   // Re-launch agents\n381:   const maxConcurrent = opts.maxConcurrent ?? state.max_concurrent;\n382:   const toLaunchNow = toRelaunch.slice(0, maxConcurrent);\n383:   if (toLaunchNow.length === 0 && stillAlive.length === 0) {\n384:     outputMessage(fmt, \"No agents need (re)launching.\", {\n385:       wave_id: state.wave_id,\n386:       triage: {\n387:         to_verify: toVerify.length,\n388:         to_relaunch: 0,\n389:       },\n390:       agents: state.agents.map((a) => ({\n391:         feature_id: a.feature_id,\n392:         status: a.status,\n393:         build_passed: a.build_passed,\n394:         error: a.error,\n395:       })),\n396:     });\n397:     if (fmt === \"text\") printDashboard(state);\n398:     return;\n399:   }\n400: \n401:   // ---------------------------------------------------------------------------\n402:   // Re-resolve specialized agents for relaunched tasks that have agent_type\n403:   // ---------------------------------------------------------------------------\n404:   let agentResolutions: Map<string, AgentResolution> | undefined;\n405: \n406:   if (config.agentRegistry.mode !== \"disabled\") {\n407:     const agentsWithType = toLaunchNow.filter((a) => a.agent_type);\n408:     if (agentsWithType.length > 0) {\n409:       // Build feature list for tasks being relaunched\n410:       const featuresToResolve = agentsWithType\n411:         .map((a) => featureMap.get(a.feature_id))\n412:         .filter((f): f is Feature => !!f);\n413:       if (featuresToResolve.length > 0) {\n414:         if (fmt === \"text\") console.log(`\\nRe-resolving ${featuresToResolve.length} specialized agent(s) from registry...`);\n415:         try {\n416:           agentResolutions = await prepareAgentDefinitions(featuresToResolve, config, projectRoot);\n417:         } catch (err: any) {\n418:           if (fmt === \"text\") console.log(`  WARN: agent resolution failed, using cached agent names: ${err.message}`);\n419:         }\n420:       }\n421:     }\n422:   }\n423: \n424:   if (fmt === \"text\") {\n425:     const parts: string[] = [];\n426:     if (toLaunchNow.length > 0) parts.push(`re-launching ${toLaunchNow.length}`);\n427:     if (stillAlive.length > 0) parts.push(`reconnecting ${stillAlive.length}`);\n428:     console.log(`\\n${parts.join(\", \")} agent(s)...\\n`);\n429:     printDashboard(state);\n430:   }\n431:   const model = opts.model ?? state.model ?? undefined;\n432: \n433:   if (opts.interactive) {\n434:     // Interactive resume\n435:     await Promise.all(\n436:       toLaunchNow.map(async (agent) => {\n437:         const feature = featureMap.get(agent.feature_id);\n438:         if (!feature) return;\n439: \n440:         updateAgent(state, agent.feature_id, {\n441:           status: \"installing\",\n442:           started_at: new Date().toISOString(),\n443:           activity: \"resuming...\",\n444:         });\n445:         saveState(projectRoot, state);\n446: \n447:         try {\n448:           if (!worktreeReady(agent.worktree)) {\n449:             await createWorktree(projectRoot, agent.feature_id, state.base_branch, config);\n450:             await installDeps(agent.worktree, agent.feature_id, config);\n451:           }\n452: \n453:           // Write specialized agent to worktree if applicable\n454:           const resolution = agentResolutions?.get(agent.feature_id);\n455:           const agentName = agent.agent_name ?? undefined;\n456:           if (resolution && isSpecializedAgent(resolution)) {\n457:             try {\n458:               const patchedContent = patchImportedAgent(resolution.rawContent, config, projectRoot);\n459:               writeAgentToWorktree(agent.worktree, resolution.name, patchedContent);\n460:               wtLog(agent.feature_id, `wrote specialized agent: ${resolution.name}`);\n461:             } catch (err: any) {\n462:               wtLog(agent.feature_id, `WARN: failed to write specialized agent: ${err.message}`);\n463:             }\n464:           }\n465: \n466:           const prompt = generatePrompt(feature, state.base_branch, config, questContext, hitlMode as QuestHitlMode | undefined);\n467:           const result = launchInteractive({\n468:             worktreePath: agent.worktree,\n469:             featureId: feature.id,\n470:             prompt,\n471:             model,\n472:             interactive: true,\n473:             config,\n474:             agentName,\n475:           });\n476: \n477:           const muxName = getMultiplexerName(config);\n478:           updateAgent(state, agent.feature_id, {\n479:             status: \"running\",\n480:             pid: result.pid,\n481:             activity: `${muxName} session active`,\n482:           });\n483:           saveState(projectRoot, state);\n484:         } catch (err: any) {\n485:           updateAgent(state, agent.feature_id, {\n486:             status: \"failed\",\n487:             error: err.message,\n488:             activity: null,\n489:             completed_at: new Date().toISOString(),\n490:           });\n491:           saveState(projectRoot, state);\n492:         }\n493:       })\n494:     );\n495: \n496:     if (fmt === \"text\") {\n497:       printDashboard(state);\n498:       const mux = detectMultiplexer(config.agent.multiplexer);\n499:       console.log(`\\nResume complete. Use '${muxAttachCommand(mux, `${config.agent.tmuxPrefix}-<id>`)}' to check sessions.`);\n500:     }\n501:   } else {\n502:     // Headless resume — re-enter monitoring loop\n503:     const monitor = new ProcessMonitor(projectRoot, {\n504:       onSessionId: (featureId, sessionId) => {\n505:         updateAgent(state, featureId, { session_id: sessionId });\n506:         saveState(projectRoot, state);\n507:       },\n508:       onComplete: (featureId) => {\n509:         updateAgent(state, featureId, {\n510:           status: \"completed\",\n511:           completed_at: new Date().toISOString(),\n512:           activity: \"done\",\n513:         });\n514:         saveState(projectRoot, state);\n515:         wtLog(featureId, \"agent completed — verifying build...\");\n516: \n517:         const agent = state.agents.find((a) => a.feature_id === featureId)!;\n518:         const feature = featureMap.get(featureId)!;\n519:         handleBuildVerification(projectRoot, state, agent, feature, config, model, monitor, undefined, hitlMode)\n520:           .then(() => launchAllReady(projectRoot, state, featureMap, monitor, config, model, undefined, questContext, hitlMode))\n521:           .catch((err) => {\n522:             wtLog(featureId, `BUILD VERIFICATION UNHANDLED ERROR: ${err.message}`);\n523:             launchAllReady(projectRoot, state, featureMap, monitor, config, model, undefined, questContext, hitlMode);\n524:           });\n525:       },\n526:       onError: (featureId, error) => {\n527:         const agent = state.agents.find((a) => a.feature_id === featureId)!;\n528:         if (agent.retries < agent.max_retries) {\n529:           updateAgent(state, featureId, {\n530:             status: \"retry\",\n531:             retries: agent.retries + 1,\n532:             error,\n533:             activity: \"retrying...\",\n534:           });\n535:           saveState(projectRoot, state);\n536:           handleRetry(projectRoot, state, agent, monitor, config, model, hitlMode);\n537:         } else {\n538:           updateAgent(state, featureId, {\n539:             status: \"failed\",\n540:             error,\n541:             activity: null,\n542:             completed_at: new Date().toISOString(),\n543:           });\n544:           saveState(projectRoot, state);\n545: \n546:           // Cascade failure to downstream agents\n547:           const cancelled = cancelDownstream(state, featureId);\n548:           if (cancelled.length > 0) {\n549:             wtLog(featureId, `downstream cancelled: ${cancelled.join(\", \")}`);\n550:             saveState(projectRoot, state);\n551:           }\n552:         }\n553:         launchAllReady(projectRoot, state, featureMap, monitor, config, model, undefined, questContext, hitlMode);\n554:       },\n555:       onActivity: (featureId, activity) => {\n556:         updateAgent(state, featureId, {\n557:           activity,\n558:           activity_updated_at: new Date().toISOString(),\n559:         });\n560:       },\n561:     });\n562: \n563:     // Handle graceful shutdown\n564:     // Audit (wave-detach-audit): Same pattern as launch.ts — see launch.ts\n565:     // SIGINT handler for detailed lifecycle documentation. Agents are\n566:     // non-detached children; killAll() gives them SIGTERM before exit.\n567:     const tuiRef = { current: null as WomboTUI | null };\n568:     const gracefulShutdown = (signal: string) => {\n569:       if (tuiRef.current) tuiRef.current.stop();\n570:       for (const agent of state.agents) {\n571:         if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n572:           updateAgent(state, agent.feature_id, {\n573:             activity: \"interrupted\",\n574:           });\n575:         }\n576:       }\n577:       monitor.killAll();\n578:       flushState(projectRoot, state);\n579:       if (fmt === \"text\") console.log(`\\nState saved (${signal}). Use 'woco resume' to continue.`);\n580:       process.exit(0);\n581:     };\n582:     process.on(\"SIGINT\", () => gracefulShutdown(\"SIGINT\"));\n583:     process.on(\"SIGTERM\", () => gracefulShutdown(\"SIGTERM\"));\n584:     process.on(\"SIGHUP\", () => gracefulShutdown(\"SIGHUP\"));\n585: \n586:     // Reconnect to agents that are still alive — register them in the monitor\n587:     // so the TUI shows their activity and the polling loop detects their death.\n588:     for (const agent of stillAlive) {\n589:       monitor.reconnectProcess(agent.feature_id, agent.pid!, agent.session_id);\n590:       if (fmt === \"text\") console.log(`  ${agent.feature_id}: reconnected to PID ${agent.pid}`);\n591:     }\n592: \n593:     await Promise.all(\n594:       toLaunchNow.map((agent) => {\n595:         const feature = featureMap.get(agent.feature_id);\n596:         if (!feature) return Promise.resolve();\n597:         return launchSingleHeadless(projectRoot, state, agent, feature, monitor, config, model, agentResolutions, questContext, hitlMode);\n598:       })\n599:     );\n600: \n601:     // Start TUI dashboard (or skip if --no-tui)\n602:     if (!opts.noTui) {\n603:       tuiRef.current = new WomboTUI({\n604:         state,\n605:         monitor,\n606:         projectRoot,\n607:         interactive: false,\n608:         config,\n609:         onQuit: () => {\n610:           // Audit (wave-detach-audit): Same killAll() + flushState pattern as\n611:           // launch.ts onQuit. See launch.ts for full lifecycle documentation.\n612:           for (const agent of state.agents) {\n613:             if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n614:               updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n615:             }\n616:           }\n617:           monitor.killAll();\n618:           flushState(projectRoot, state);\n619:           if (fmt === \"text\") console.log(\"State saved. Use 'woco resume' to continue.\");\n620:           process.exit(0);\n621:         },\n622:         onBeforeDestroy: () => {\n623:           // Flush state to disk before the blessed screen is destroyed.\n624:           flushState(projectRoot, state);\n625:         },\n626:         onRetry: (featureId: string) => {\n627:           const agent = state.agents.find((a) => a.feature_id === featureId);\n628:           if (!agent) return;\n629:           if (agent.status !== \"failed\" && agent.status !== \"retry\") return;\n630: \n631:           // Reset retries if exhausted, give it one more shot\n632:           if (agent.retries >= agent.max_retries) {\n633:             updateAgent(state, featureId, { max_retries: agent.retries + 1 });\n634:           }\n635: \n636:           wtLog(featureId, `manual retry requested from TUI — resetting to queued`);\n637:           updateAgent(state, featureId, {\n638:             status: \"queued\",\n639:             error: null,\n640:             activity: \"waiting for relaunch (manual retry)...\",\n641:           });\n642:           saveState(projectRoot, state);\n643:         },\n644:         onAnswer: (agentId: string, questionId: string, answerText: string) => {\n645:           try {\n646:             submitAnswer(projectRoot, agentId, questionId, answerText);\n647:             wtLog(agentId, `HITL answer submitted: \"${answerText.slice(0, 80)}${answerText.length > 80 ? \"...\" : \"\"}\"`);\n648:           } catch (err: any) {\n649:             wtLog(agentId, `HITL answer error: ${err.message}`);\n650:           }\n651:         },\n652:       });\n653:       tuiRef.current.start();\n654:     } else {\n655:       if (fmt === \"text\") console.log(\"(--no-tui mode, dashboard prints every 15s)\\n\");\n656:       printDashboard(state);\n657:     }\n658: \n659:     // Monitoring loop\n660:     const POLL_INTERVAL = 5000;\n661:     let dashboardCounter = 0;\n662:     while (!isWaveComplete(state)) {\n663:       await new Promise((r) => setTimeout(r, POLL_INTERVAL));\n664: \n665:       for (const agent of state.agents) {\n666:         if (\n667:           (agent.status === \"running\" || agent.status === \"resolving_conflict\") &&\n668:           agent.pid &&\n669:           !isProcessRunning(agent.pid) &&\n670:           !monitor.isRunning(agent.feature_id)\n671:         ) {\n672:           if (agent.status === \"resolving_conflict\") {\n673:             // Conflict resolver died unexpectedly — mark as failed\n674:             updateAgent(state, agent.feature_id, {\n675:               status: \"failed\",\n676:               error: \"Conflict resolver process died unexpectedly\",\n677:               activity: null,\n678:               completed_at: new Date().toISOString(),\n679:             });\n680:             saveState(projectRoot, state);\n681:             wtLog(agent.feature_id, \"conflict resolver died — marked failed\");\n682: \n683:             // Cascade failure to downstream agents\n684:             const cancelled = cancelDownstream(state, agent.feature_id);\n685:             if (cancelled.length > 0) {\n686:               wtLog(agent.feature_id, `downstream cancelled: ${cancelled.join(\", \")}`);\n687:               saveState(projectRoot, state);\n688:             }\n689: \n690:             launchAllReady(projectRoot, state, featureMap, monitor, config, model, undefined, questContext, hitlMode);\n691:             continue;\n692:           }\n693:           // Check if the agent actually made any commits\n694:           if (!branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n695:             // Agent died without producing any code — mark as failed\n696:             updateAgent(state, agent.feature_id, {\n697:               status: \"failed\",\n698:               error: \"Agent process exited without making any commits\",\n699:               activity: null,\n700:               completed_at: new Date().toISOString(),\n701:             });\n702:             saveState(projectRoot, state);\n703:             wtLog(agent.feature_id, \"process died with no code changes — marked failed\");\n704: \n705:             // Cascade failure to downstream agents\n706:             const cancelled = cancelDownstream(state, agent.feature_id);\n707:             if (cancelled.length > 0) {\n708:               wtLog(agent.feature_id, `downstream cancelled: ${cancelled.join(\", \")}`);\n709:               saveState(projectRoot, state);\n710:             }\n711:           } else {\n712:             updateAgent(state, agent.feature_id, {\n713:               status: \"completed\",\n714:               completed_at: new Date().toISOString(),\n715:               activity: \"done\",\n716:             });\n717:             saveState(projectRoot, state);\n718:             const feature = featureMap.get(agent.feature_id)!;\n719:             try {\n720:               await handleBuildVerification(projectRoot, state, agent, feature, config, model, monitor, undefined, hitlMode);\n721:             } catch (err: any) {\n722:               wtLog(agent.feature_id, `POLL VERIFY ERROR: ${err.message}`);\n723:             }\n724:           }\n725:           launchAllReady(projectRoot, state, featureMap, monitor, config, model, undefined, questContext, hitlMode);\n726:         }\n727:       }\n728: \n729:       saveState(projectRoot, state);\n730: \n731:       // Poll for HITL questions from agents and forward to TUI\n732:       if (hitlMode && hitlMode !== \"yolo\") {\n733:         try {\n734:           const pendingQuestions = getPendingQuestions(projectRoot);\n735:           if (tuiRef.current && pendingQuestions.length > 0) {\n736:             tuiRef.current.setPendingQuestions(pendingQuestions);\n737:           }\n738:         } catch {\n739:           // Non-fatal — HITL dir may not exist yet\n740:         }\n741:       }\n742: \n743:       if (tuiRef.current) {\n744:         tuiRef.current.updateState(state);\n745:       } else if (opts.noTui) {\n746:         dashboardCounter++;\n747:         if (dashboardCounter % 3 === 0) {\n748:           printDashboard(state);\n749:         }\n750:       }\n751:     }\n752: \n753:     // Wave complete — keep TUI open for post-mortem browsing\n754:     if (tuiRef.current) {\n755:       tuiRef.current.updateState(state);\n756:       tuiRef.current.markWaveComplete();\n757:       await tuiRef.current.waitForQuit();\n758:     }\n759: \n760:     if (fmt === \"text\") {\n761:       printDashboard(state);\n762: \n763:       // Dump full logs for failed agents (post-mortem)\n764:       dumpFailedAgentLogs(projectRoot, state, fmt);\n765:     }\n766: \n767:     // Clean up HITL files\n768:     try {\n769:       cleanupHitl(projectRoot);\n770:     } catch {\n771:       // Non-fatal\n772:     }\n773: \n774:     // Auto-export wave history\n775:     try {\n776:       const historyPath = exportWaveHistory(projectRoot, state);\n777:       if (fmt === \"text\") console.log(`Wave history exported to ${historyPath}`);\n778:     } catch (err: any) {\n779:       if (fmt === \"text\") console.error(`Warning: failed to export wave history: ${err.message}`);\n780:     }\n781: \n782:     // Auto-push base branch if requested\n783:     if (opts.autoPush) {\n784:       await pushBaseBranch(projectRoot, state.base_branch, config);\n785:     }\n786: \n787:     if (fmt === \"text\") console.log(\"Wave complete.\");\n788:   }\n789: }\n\n(End of file - total 789 lines)\n</content>","title":"src/commands/resume.ts","metadata":{"preview":"/**\n * resume.ts — Resume a previously stopped wave.\n *\n * Usage: woco resume [options] [--output json]\n *\n * Restores from .wombo-combo/state.json:\n *   - Agents in \"running\"/\"installing\" whose PID is dead → re-check or re-launch\n *   - Agents in \"queued\" → launch them\n *   - Agents in terminal states (verified/failed/merged) → leave alone\n *\n * ## Agent Recovery (audit: wave-detach-audit)\n *\n * This is the primary recovery mechanism for agents that died when the parent\n * process was terminated (gracefully via SIGINT, or ungracefully via SIGKILL/crash).\n *\n * Recovery triage for each agent:\n *   - PID still alive → leave it running (another wombo instance may still be active)\n *   - PID dead + worktree has commits → run build verification on existing work\n *   - PID dead + no commits → reset to \"queued\" for a fresh re-launch\n *   - \"completed\" → verify build","truncated":false,"loaded":[]},"time":{"start":1773483373871,"end":1773483373908}}}}
