{"type":"tool_use","timestamp":1773481728166,"sessionID":"ses_3144093abffe4EFLXWMouX7qVB","part":{"id":"prt_cebbf979b001KgIRef8OEFQOXs","sessionID":"ses_3144093abffe4EFLXWMouX7qVB","messageID":"msg_cebbf8607001sykyV79AAm5jeN","type":"tool","callID":"toolu_vrtx_01K9iTkFRDhzjfSKEEVyxsmY","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/wave-detach-audit/src/commands/resume.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/wave-detach-audit/src/commands/resume.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * resume.ts — Resume a previously stopped wave.\n3:  *\n4:  * Usage: woco resume [options] [--output json]\n5:  *\n6:  * Restores from .wombo-combo/state.json:\n7:  *   - Agents in \"running\"/\"installing\" whose PID is dead → re-check or re-launch\n8:  *   - Agents in \"queued\" → launch them\n9:  *   - Agents in terminal states (verified/failed/merged) → leave alone\n10:  */\n11: \n12: import type { WomboConfig } from \"../config.js\";\n13: import type { Feature } from \"../lib/tasks.js\";\n14: import { loadFeatures } from \"../lib/tasks.js\";\n15: import {\n16:   loadState,\n17:   saveState,\n18:   updateAgent,\n19:   queuedAgents,\n20:   readyToLaunchAgents,\n21:   cancelDownstream,\n22:   isWaveComplete,\n23:   type WaveState,\n24:   type AgentState,\n25: } from \"../lib/state.js\";\n26: import {\n27:   createWorktree,\n28:   installDeps,\n29:   worktreeReady,\n30:   worktreeExists,\n31:   branchHasChanges,\n32:   removeWorktree,\n33:   log as wtLog,\n34: } from \"../lib/worktree.js\";\n35: import { generatePrompt, type QuestPromptContext } from \"../lib/prompt.js\";\n36: import {\n37:   launchInteractive,\n38:   isProcessRunning,\n39:   getMultiplexerName,\n40: } from \"../lib/launcher.js\";\n41: import { ProcessMonitor } from \"../lib/monitor.js\";\n42: import { pushBaseBranch } from \"../lib/merger.js\";\n43: import { runBuild } from \"../lib/verifier.js\";\n44: import { printDashboard, printAgentUpdate } from \"../lib/ui.js\";\n45: import { WomboTUI } from \"../lib/tui.js\";\n46: import {\n47:   launchSingleHeadless,\n48:   handleBuildVerification,\n49:   handleRetry,\n50:   launchNextQueued,\n51:   launchAllReady,\n52:   markFeatureDone,\n53:   attemptMerge,\n54:   dumpFailedAgentLogs,\n55: } from \"./launch.js\";\n56: import {\n57:   detectMultiplexer,\n58:   muxAttachCommand,\n59: } from \"../lib/multiplexer.js\";\n60: import { exportWaveHistory } from \"../lib/history.js\";\n61: import { outputError, outputMessage, type OutputFormat } from \"../lib/output.js\";\n62: import {\n63:   prepareAgentDefinitions,\n64:   isSpecializedAgent,\n65:   type AgentResolution,\n66: } from \"../lib/agent-registry.js\";\n67: import { patchImportedAgent } from \"../lib/templates.js\";\n68: import { writeAgentToWorktree } from \"../lib/agent-registry.js\";\n69: import { loadQuest, loadQuestKnowledge } from \"../lib/quest-store.js\";\n70: import { resolveQuestConfig, type QuestHitlMode } from \"../lib/quest.js\";\n71: import { getPendingQuestions, cleanupAll as cleanupHitl, submitAnswer, type HitlQuestion } from \"../lib/hitl-channel.js\";\n72: \n73: // ---------------------------------------------------------------------------\n74: // Types\n75: // ---------------------------------------------------------------------------\n76: \n77: export interface ResumeCommandOptions {\n78:   projectRoot: string;\n79:   config: WomboConfig;\n80:   maxConcurrent?: number;\n81:   model?: string;\n82:   interactive: boolean;\n83:   noTui: boolean;\n84:   autoPush: boolean;\n85:   baseBranch?: string;\n86:   maxRetries?: number;\n87:   outputFmt?: OutputFormat;\n88: }\n89: \n90: // ---------------------------------------------------------------------------\n91: // Command\n92: // ---------------------------------------------------------------------------\n93: \n94: export async function cmdResume(opts: ResumeCommandOptions): Promise<void> {\n95:   const { projectRoot } = opts;\n96:   let { config } = opts;\n97:   const fmt = opts.outputFmt ?? \"text\";\n98: \n99:   const state = loadState(projectRoot);\n100:   if (!state) {\n101:     outputError(fmt, \"No wave state found. Use 'woco launch' to start a new wave.\");\n102:     return; // unreachable — outputError calls process.exit\n103:   }\n104: \n105:   if (fmt === \"text\") {\n106:     console.log(`\\n--- wombo-combo: Resume ${state.wave_id} ---\\n`);\n107:   }\n108: \n109:   // Reconstruct quest context from wave state (if quest-scoped)\n110:   let questContext: QuestPromptContext | undefined;\n111:   let hitlMode: string | undefined;\n112:   if (state.quest_id) {\n113:     const quest = loadQuest(projectRoot, state.quest_id);\n114:     if (quest) {\n115:       config = resolveQuestConfig(config, quest);\n116:       hitlMode = quest.hitlMode;\n117:       const knowledge = loadQuestKnowledge(projectRoot, state.quest_id);\n118:       questContext = {\n119:         questId: quest.id,\n120:         goal: quest.goal,\n121:         addedConstraints: quest.constraints.add ?? [],\n122:         addedForbidden: quest.constraints.ban ?? [],\n123:         knowledge,\n124:       };\n125:       if (fmt === \"text\") {\n126:         console.log(`Quest: ${quest.title} (${quest.id})\\n`);\n127:       }\n128:     } else if (fmt === \"text\") {\n129:       console.warn(`Warning: wave references quest \"${state.quest_id}\" but it was not found.\\n`);\n130:     }\n131:   }\n132: \n133:   // Load feature data for prompt generation\n134:   const data = loadFeatures(projectRoot, config);\n135:   const featureMap = new Map(data.tasks.map((f: Feature) => [f.id, f]));\n136: \n137:   // Triage agents by current state\n138:   let toRelaunch: AgentState[] = [];\n139:   let toVerify: AgentState[] = [];\n140: \n141:   for (const agent of state.agents) {\n142:     switch (agent.status) {\n143:       case \"running\":\n144:       case \"installing\":\n145:       case \"retry\":\n146:       case \"resolving_conflict\":\n147:         // Was in-flight when we stopped — check if PID is still alive\n148:         if (agent.pid && isProcessRunning(agent.pid)) {\n149:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: still running (PID ${agent.pid}), leaving alone`);\n150:         } else {\n151:           // Process is dead — check if worktree exists with meaningful changes.\n152:           // Use worktreeExists (not worktreeReady) because node_modules may be\n153:           // missing — the worktree still has code that should be verified.\n154:           if (worktreeExists(agent.worktree) && branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n155:             // Worktree exists AND branch has commits — try build verification\n156:             if (fmt === \"text\") console.log(`  ${agent.feature_id}: process dead, worktree has changes — will verify build`);\n157:             toVerify.push(agent);\n158:           } else {\n159:             // No worktree, or worktree exists but branch has no commits (agent did nothing)\n160:             const reason = worktreeExists(agent.worktree)\n161:               ? \"worktree exists but no code changes\"\n162:               : \"no worktree\";\n163:             if (fmt === \"text\") console.log(`  ${agent.feature_id}: process dead, ${reason} — will re-launch`);\n164:             updateAgent(state, agent.feature_id, {\n165:               status: \"queued\",\n166:               pid: null,\n167:               activity: null,\n168:               session_id: null,\n169:             });\n170:             toRelaunch.push(agent);\n171:           }\n172:         }\n173:         break;\n174: \n175:       case \"queued\":\n176:         if (fmt === \"text\") console.log(`  ${agent.feature_id}: queued — will launch`);\n177:         toRelaunch.push(agent);\n178:         break;\n179: \n180:       case \"completed\":\n181:         // Completed but not verified — verify\n182:         if (fmt === \"text\") console.log(`  ${agent.feature_id}: completed — will verify build`);\n183:         toVerify.push(agent);\n184:         break;\n185: \n186:       case \"verified\":\n187:         // Build passed but NOT yet merged — need to attempt merge (+ conflict resolution)\n188:         if (fmt === \"text\") console.log(`  ${agent.feature_id}: verified — will attempt merge`);\n189:         toVerify.push(agent);\n190:         break;\n191: \n192:       case \"merged\":\n193:         if (fmt === \"text\") console.log(`  ${agent.feature_id}: merged — marking feature as done`);\n194:         markFeatureDone(projectRoot, agent.feature_id, config, state.base_branch, fmt);\n195:         try {\n196:           removeWorktree(projectRoot, agent.worktree, true);\n197:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: worktree and branch removed`);\n198:         } catch {\n199:           // Already cleaned — not critical\n200:         }\n201:         break;\n202: \n203:       case \"failed\":\n204:         // If the worktree exists with code changes and retries remain,\n205:         // attempt build verification rather than discarding the work.\n206:         if (agent.retries < agent.max_retries &&\n207:             worktreeExists(agent.worktree) &&\n208:             branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n209:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: failed but has work (retry ${agent.retries}/${agent.max_retries}) — will verify build`);\n210:           // Clear stale error and mark as completed so handleBuildVerification\n211:           // processes it correctly (it expects a non-failed agent)\n212:           updateAgent(state, agent.feature_id, {\n213:             status: \"completed\",\n214:             error: null,\n215:             build_passed: null,\n216:             build_output: null,\n217:             completed_at: new Date().toISOString(),\n218:           });\n219:           toVerify.push(agent);\n220:         } else if (agent.retries < agent.max_retries) {\n221:           // No worktree or no changes — re-launch from scratch\n222:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: failed, no salvageable work (retry ${agent.retries}/${agent.max_retries}) — will re-launch`);\n223:           updateAgent(state, agent.feature_id, {\n224:             status: \"queued\",\n225:             pid: null,\n226:             error: null,\n227:             build_passed: null,\n228:             build_output: null,\n229:             activity: null,\n230:             session_id: null,\n231:             completed_at: null,\n232:           });\n233:           toRelaunch.push(agent);\n234:         } else {\n235:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: failed — max retries reached (use 'woco retry' to reset)`);\n236:         }\n237:         break;\n238:     }\n239:   }\n240: \n241:   saveState(projectRoot, state);\n242: \n243:   // ---------------------------------------------------------------------------\n244:   // Phase 1: Parallel build verification\n245:   // Each agent's worktree is independent, so dep install + build can run\n246:   // concurrently. Merges must remain sequential (they mutate the project root).\n247:   // ---------------------------------------------------------------------------\n248:   if (toVerify.length > 0) {\n249:     if (fmt === \"text\") console.log(`\\nVerifying ${toVerify.length} agent(s) in parallel...\\n`);\n250: \n251:     const verifyResults = await Promise.all(\n252:       toVerify.map(async (agent): Promise<{ agent: AgentState; needsMerge: boolean }> => {\n253:         const feature = featureMap.get(agent.feature_id);\n254:         if (!feature) return { agent, needsMerge: false };\n255: \n256:         // Already verified — skip build, go straight to merge\n257:         if (agent.status === \"verified\") {\n258:           printAgentUpdate(agent, \"already verified — queued for merge\");\n259:           return { agent, needsMerge: true };\n260:         }\n261: \n262:         printAgentUpdate(agent, \"verifying build...\");\n263: \n264:         // Ensure deps are installed — worktree may exist without node_modules\n265:         // (e.g., failed agents whose setup was interrupted)\n266:         if (!worktreeReady(agent.worktree) && worktreeExists(agent.worktree)) {\n267:           try {\n268:             printAgentUpdate(agent, \"installing deps...\");\n269:             await installDeps(agent.worktree, agent.feature_id, config);\n270:           } catch (depErr: any) {\n271:             printAgentUpdate(agent, `dep install failed: ${depErr.message}`);\n272:             updateAgent(state, agent.feature_id, {\n273:               status: \"failed\",\n274:               error: `Dependency install failed: ${depErr.message}`,\n275:               retries: agent.retries + 1,\n276:               completed_at: new Date().toISOString(),\n277:             });\n278:             saveState(projectRoot, state);\n279:             return { agent, needsMerge: false };\n280:           }\n281:         }\n282: \n283:         try {\n284:           const buildResult = await runBuild(agent.worktree, config);\n285:           if (buildResult.passed) {\n286:             updateAgent(state, agent.feature_id, {\n287:               status: \"verified\",\n288:               build_passed: true,\n289:               build_output: null,\n290:             });\n291:             saveState(projectRoot, state);\n292:             printAgentUpdate(agent, `BUILD PASSED (${Math.round(buildResult.durationMs / 1000)}s)`);\n293:             return { agent, needsMerge: true };\n294:           } else {\n295:             // Build failed\n296:             if (agent.retries < agent.max_retries) {\n297:               updateAgent(state, agent.feature_id, {\n298:                 status: \"retry\",\n299:                 retries: agent.retries + 1,\n300:                 build_passed: false,\n301:                 build_output: buildResult.errorSummary,\n302:               });\n303:               saveState(projectRoot, state);\n304:               printAgentUpdate(agent, `BUILD FAILED — will retry (${agent.retries + 1}/${agent.max_retries})`);\n305:             } else {\n306:               updateAgent(state, agent.feature_id, {\n307:                 status: \"failed\",\n308:                 build_passed: false,\n309:                 build_output: buildResult.errorSummary,\n310:                 error: `Build failed after ${agent.max_retries} retries`,\n311:                 completed_at: new Date().toISOString(),\n312:               });\n313:               saveState(projectRoot, state);\n314:               printAgentUpdate(agent, \"BUILD FAILED — max retries reached\");\n315:             }\n316:             return { agent, needsMerge: false };\n317:           }\n318:         } catch (err: any) {\n319:           printAgentUpdate(agent, `verify error: ${err.message}`);\n320:           updateAgent(state, agent.feature_id, {\n321:             status: \"failed\",\n322:             error: `Build verification error: ${err.message}`,\n323:             completed_at: new Date().toISOString(),\n324:           });\n325:           saveState(projectRoot, state);\n326:           return { agent, needsMerge: false };\n327:         }\n328:       })\n329:     );\n330: \n331:     saveState(projectRoot, state);\n332: \n333:     // -------------------------------------------------------------------------\n334:     // Phase 2: Sequential merge for verified agents\n335:     // Merges must be sequential because they operate on the project root.\n336:     // -------------------------------------------------------------------------\n337:     const toMerge = verifyResults.filter((r) => r.needsMerge);\n338:     if (toMerge.length > 0) {\n339:       if (fmt === \"text\") console.log(`\\nMerging ${toMerge.length} verified agent(s)...\\n`);\n340:       for (const { agent } of toMerge) {\n341:         const feature = featureMap.get(agent.feature_id);\n342:         if (!feature) continue;\n343:         try {\n344:           await attemptMerge(projectRoot, state, agent, feature, config, opts.model);\n345:         } catch (err: any) {\n346:           printAgentUpdate(agent, `merge error: ${err.message}`);\n347:         }\n348:       }\n349:     }\n350: \n351:     // Collect agents that need re-launching from verify results\n352:     for (const { agent } of verifyResults) {\n353:       if (agent.status === \"retry\" || agent.status === \"running\") {\n354:         toRelaunch.push(agent);\n355:       }\n356:     }\n357:   }\n358: \n359:   // Re-launch agents\n360:   const maxConcurrent = opts.maxConcurrent ?? state.max_concurrent;\n361:   const toLaunchNow = toRelaunch.slice(0, maxConcurrent);\n362:   if (toLaunchNow.length === 0) {\n363:     outputMessage(fmt, \"No agents need (re)launching.\", {\n364:       wave_id: state.wave_id,\n365:       triage: {\n366:         to_verify: toVerify.length,\n367:         to_relaunch: 0,\n368:       },\n369:       agents: state.agents.map((a) => ({\n370:         feature_id: a.feature_id,\n371:         status: a.status,\n372:         build_passed: a.build_passed,\n373:         error: a.error,\n374:       })),\n375:     });\n376:     if (fmt === \"text\") printDashboard(state);\n377:     return;\n378:   }\n379: \n380:   // ---------------------------------------------------------------------------\n381:   // Re-resolve specialized agents for relaunched tasks that have agent_type\n382:   // ---------------------------------------------------------------------------\n383:   let agentResolutions: Map<string, AgentResolution> | undefined;\n384: \n385:   if (config.agentRegistry.mode !== \"disabled\") {\n386:     const agentsWithType = toLaunchNow.filter((a) => a.agent_type);\n387:     if (agentsWithType.length > 0) {\n388:       // Build feature list for tasks being relaunched\n389:       const featuresToResolve = agentsWithType\n390:         .map((a) => featureMap.get(a.feature_id))\n391:         .filter((f): f is Feature => !!f);\n392:       if (featuresToResolve.length > 0) {\n393:         if (fmt === \"text\") console.log(`\\nRe-resolving ${featuresToResolve.length} specialized agent(s) from registry...`);\n394:         try {\n395:           agentResolutions = await prepareAgentDefinitions(featuresToResolve, config, projectRoot);\n396:         } catch (err: any) {\n397:           if (fmt === \"text\") console.log(`  WARN: agent resolution failed, using cached agent names: ${err.message}`);\n398:         }\n399:       }\n400:     }\n401:   }\n402: \n403:   if (fmt === \"text\") {\n404:     console.log(`\\nRe-launching ${toLaunchNow.length} agent(s)...\\n`);\n405:     printDashboard(state);\n406:   }\n407:   const model = opts.model ?? state.model ?? undefined;\n408: \n409:   if (opts.interactive) {\n410:     // Interactive resume\n411:     await Promise.all(\n412:       toLaunchNow.map(async (agent) => {\n413:         const feature = featureMap.get(agent.feature_id);\n414:         if (!feature) return;\n415: \n416:         updateAgent(state, agent.feature_id, {\n417:           status: \"installing\",\n418:           started_at: new Date().toISOString(),\n419:           activity: \"resuming...\",\n420:         });\n421:         saveState(projectRoot, state);\n422: \n423:         try {\n424:           if (!worktreeReady(agent.worktree)) {\n425:             await createWorktree(projectRoot, agent.feature_id, state.base_branch, config);\n426:             await installDeps(agent.worktree, agent.feature_id, config);\n427:           }\n428: \n429:           // Write specialized agent to worktree if applicable\n430:           const resolution = agentResolutions?.get(agent.feature_id);\n431:           const agentName = agent.agent_name ?? undefined;\n432:           if (resolution && isSpecializedAgent(resolution)) {\n433:             try {\n434:               const patchedContent = patchImportedAgent(resolution.rawContent, config, projectRoot);\n435:               writeAgentToWorktree(agent.worktree, resolution.name, patchedContent);\n436:               wtLog(agent.feature_id, `wrote specialized agent: ${resolution.name}`);\n437:             } catch (err: any) {\n438:               wtLog(agent.feature_id, `WARN: failed to write specialized agent: ${err.message}`);\n439:             }\n440:           }\n441: \n442:           const prompt = generatePrompt(feature, state.base_branch, config, questContext, hitlMode as QuestHitlMode | undefined);\n443:           const result = launchInteractive({\n444:             worktreePath: agent.worktree,\n445:             featureId: feature.id,\n446:             prompt,\n447:             model,\n448:             interactive: true,\n449:             config,\n450:             agentName,\n451:           });\n452: \n453:           const muxName = getMultiplexerName(config);\n454:           updateAgent(state, agent.feature_id, {\n455:             status: \"running\",\n456:             pid: result.pid,\n457:             activity: `${muxName} session active`,\n458:           });\n459:           saveState(projectRoot, state);\n460:         } catch (err: any) {\n461:           updateAgent(state, agent.feature_id, {\n462:             status: \"failed\",\n463:             error: err.message,\n464:             activity: null,\n465:             completed_at: new Date().toISOString(),\n466:           });\n467:           saveState(projectRoot, state);\n468:         }\n469:       })\n470:     );\n471: \n472:     if (fmt === \"text\") {\n473:       printDashboard(state);\n474:       const mux = detectMultiplexer(config.agent.multiplexer);\n475:       console.log(`\\nResume complete. Use '${muxAttachCommand(mux, `${config.agent.tmuxPrefix}-<id>`)}' to check sessions.`);\n476:     }\n477:   } else {\n478:     // Headless resume — re-enter monitoring loop\n479:     const monitor = new ProcessMonitor(projectRoot, {\n480:       onSessionId: (featureId, sessionId) => {\n481:         updateAgent(state, featureId, { session_id: sessionId });\n482:         saveState(projectRoot, state);\n483:       },\n484:       onComplete: (featureId) => {\n485:         updateAgent(state, featureId, {\n486:           status: \"completed\",\n487:           completed_at: new Date().toISOString(),\n488:           activity: \"done\",\n489:         });\n490:         saveState(projectRoot, state);\n491:         wtLog(featureId, \"agent completed — verifying build...\");\n492: \n493:         const agent = state.agents.find((a) => a.feature_id === featureId)!;\n494:         const feature = featureMap.get(featureId)!;\n495:         handleBuildVerification(projectRoot, state, agent, feature, config, model, monitor, undefined, hitlMode)\n496:           .then(() => launchAllReady(projectRoot, state, featureMap, monitor, config, model, undefined, questContext, hitlMode))\n497:           .catch((err) => {\n498:             wtLog(featureId, `BUILD VERIFICATION UNHANDLED ERROR: ${err.message}`);\n499:             launchAllReady(projectRoot, state, featureMap, monitor, config, model, undefined, questContext, hitlMode);\n500:           });\n501:       },\n502:       onError: (featureId, error) => {\n503:         const agent = state.agents.find((a) => a.feature_id === featureId)!;\n504:         if (agent.retries < agent.max_retries) {\n505:           updateAgent(state, featureId, {\n506:             status: \"retry\",\n507:             retries: agent.retries + 1,\n508:             error,\n509:             activity: \"retrying...\",\n510:           });\n511:           saveState(projectRoot, state);\n512:           handleRetry(projectRoot, state, agent, monitor, config, model, hitlMode);\n513:         } else {\n514:           updateAgent(state, featureId, {\n515:             status: \"failed\",\n516:             error,\n517:             activity: null,\n518:             completed_at: new Date().toISOString(),\n519:           });\n520:           saveState(projectRoot, state);\n521: \n522:           // Cascade failure to downstream agents\n523:           const cancelled = cancelDownstream(state, featureId);\n524:           if (cancelled.length > 0) {\n525:             wtLog(featureId, `downstream cancelled: ${cancelled.join(\", \")}`);\n526:             saveState(projectRoot, state);\n527:           }\n528:         }\n529:         launchAllReady(projectRoot, state, featureMap, monitor, config, model, undefined, questContext, hitlMode);\n530:       },\n531:       onActivity: (featureId, activity) => {\n532:         updateAgent(state, featureId, {\n533:           activity,\n534:           activity_updated_at: new Date().toISOString(),\n535:         });\n536:       },\n537:     });\n538: \n539:     // Handle graceful shutdown\n540:     const tuiRef = { current: null as WomboTUI | null };\n541:     process.on(\"SIGINT\", () => {\n542:       if (tuiRef.current) tuiRef.current.stop();\n543:       for (const agent of state.agents) {\n544:         if (agent.status === \"running\" || agent.status === \"resolving_conflict\") {\n545:           updateAgent(state, agent.feature_id, {\n546:             activity: \"interrupted\",\n547:           });\n548:         }\n549:       }\n550:       monitor.killAll();\n551:       saveState(projectRoot, state);\n552:       if (fmt === \"text\") console.log(\"\\nState saved. Use 'woco resume' to continue.\");\n553:       process.exit(0);\n554:     });\n555: \n556:     await Promise.all(\n557:       toLaunchNow.map((agent) => {\n558:         const feature = featureMap.get(agent.feature_id);\n559:         if (!feature) return Promise.resolve();\n560:         return launchSingleHeadless(projectRoot, state, agent, feature, monitor, config, model, agentResolutions, questContext, hitlMode);\n561:       })\n562:     );\n563: \n564:     // Start TUI dashboard (or skip if --no-tui)\n565:     if (!opts.noTui) {\n566:       tuiRef.current = new WomboTUI({\n567:         state,\n568:         monitor,\n569:         projectRoot,\n570:         interactive: false,\n571:         config,\n572:         onQuit: () => {\n573:           for (const agent of state.agents) {\n574:             if (agent.status === \"running\") {\n575:               updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n576:             }\n577:           }\n578:           monitor.killAll();\n579:           saveState(projectRoot, state);\n580:           if (fmt === \"text\") console.log(\"State saved. Use 'woco resume' to continue.\");\n581:           process.exit(0);\n582:         },\n583:         onRetry: (featureId: string) => {\n584:           const agent = state.agents.find((a) => a.feature_id === featureId);\n585:           if (!agent) return;\n586:           if (agent.status !== \"failed\" && agent.status !== \"retry\") return;\n587: \n588:           // Reset retries if exhausted, give it one more shot\n589:           if (agent.retries >= agent.max_retries) {\n590:             updateAgent(state, featureId, { max_retries: agent.retries + 1 });\n591:           }\n592: \n593:           wtLog(featureId, `manual retry requested from TUI — resetting to queued`);\n594:           updateAgent(state, featureId, {\n595:             status: \"queued\",\n596:             error: null,\n597:             activity: \"waiting for relaunch (manual retry)...\",\n598:           });\n599:           saveState(projectRoot, state);\n600:         },\n601:         onAnswer: (agentId: string, questionId: string, answerText: string) => {\n602:           try {\n603:             submitAnswer(projectRoot, agentId, questionId, answerText);\n604:             wtLog(agentId, `HITL answer submitted: \"${answerText.slice(0, 80)}${answerText.length > 80 ? \"...\" : \"\"}\"`);\n605:           } catch (err: any) {\n606:             wtLog(agentId, `HITL answer error: ${err.message}`);\n607:           }\n608:         },\n609:       });\n610:       tuiRef.current.start();\n611:     } else {\n612:       if (fmt === \"text\") console.log(\"(--no-tui mode, dashboard prints every 15s)\\n\");\n613:       printDashboard(state);\n614:     }\n615: \n616:     // Monitoring loop\n617:     const POLL_INTERVAL = 5000;\n618:     let dashboardCounter = 0;\n619:     while (!isWaveComplete(state)) {\n620:       await new Promise((r) => setTimeout(r, POLL_INTERVAL));\n621: \n622:       for (const agent of state.agents) {\n623:         if (\n624:           (agent.status === \"running\" || agent.status === \"resolving_conflict\") &&\n625:           agent.pid &&\n626:           !isProcessRunning(agent.pid) &&\n627:           !monitor.isRunning(agent.feature_id)\n628:         ) {\n629:           if (agent.status === \"resolving_conflict\") {\n630:             // Conflict resolver died unexpectedly — mark as failed\n631:             updateAgent(state, agent.feature_id, {\n632:               status: \"failed\",\n633:               error: \"Conflict resolver process died unexpectedly\",\n634:               activity: null,\n635:               completed_at: new Date().toISOString(),\n636:             });\n637:             saveState(projectRoot, state);\n638:             wtLog(agent.feature_id, \"conflict resolver died — marked failed\");\n639: \n640:             // Cascade failure to downstream agents\n641:             const cancelled = cancelDownstream(state, agent.feature_id);\n642:             if (cancelled.length > 0) {\n643:               wtLog(agent.feature_id, `downstream cancelled: ${cancelled.join(\", \")}`);\n644:               saveState(projectRoot, state);\n645:             }\n646: \n647:             launchAllReady(projectRoot, state, featureMap, monitor, config, model, undefined, questContext, hitlMode);\n648:             continue;\n649:           }\n650:           // Check if the agent actually made any commits\n651:           if (!branchHasChanges(projectRoot, agent.branch, state.base_branch)) {\n652:             // Agent died without producing any code — mark as failed\n653:             updateAgent(state, agent.feature_id, {\n654:               status: \"failed\",\n655:               error: \"Agent process exited without making any commits\",\n656:               activity: null,\n657:               completed_at: new Date().toISOString(),\n658:             });\n659:             saveState(projectRoot, state);\n660:             wtLog(agent.feature_id, \"process died with no code changes — marked failed\");\n661: \n662:             // Cascade failure to downstream agents\n663:             const cancelled = cancelDownstream(state, agent.feature_id);\n664:             if (cancelled.length > 0) {\n665:               wtLog(agent.feature_id, `downstream cancelled: ${cancelled.join(\", \")}`);\n666:               saveState(projectRoot, state);\n667:             }\n668:           } else {\n669:             updateAgent(state, agent.feature_id, {\n670:               status: \"completed\",\n671:               completed_at: new Date().toISOString(),\n672:               activity: \"done\",\n673:             });\n674:             saveState(projectRoot, state);\n675:             const feature = featureMap.get(agent.feature_id)!;\n676:             try {\n677:               await handleBuildVerification(projectRoot, state, agent, feature, config, model, monitor, undefined, hitlMode);\n678:             } catch (err: any) {\n679:               wtLog(agent.feature_id, `POLL VERIFY ERROR: ${err.message}`);\n680:             }\n681:           }\n682:           launchAllReady(projectRoot, state, featureMap, monitor, config, model, undefined, questContext, hitlMode);\n683:         }\n684:       }\n685: \n686:       saveState(projectRoot, state);\n687: \n688:       // Poll for HITL questions from agents and forward to TUI\n689:       if (hitlMode && hitlMode !== \"yolo\") {\n690:         try {\n691:           const pendingQuestions = getPendingQuestions(projectRoot);\n692:           if (tuiRef.current && pendingQuestions.length > 0) {\n693:             tuiRef.current.setPendingQuestions(pendingQuestions);\n694:           }\n695:         } catch {\n696:           // Non-fatal — HITL dir may not exist yet\n697:         }\n698:       }\n699: \n700:       if (tuiRef.current) {\n701:         tuiRef.current.updateState(state);\n702:       } else if (opts.noTui) {\n703:         dashboardCounter++;\n704:         if (dashboardCounter % 3 === 0) {\n705:           printDashboard(state);\n706:         }\n707:       }\n708:     }\n709: \n710:     // Wave complete — keep TUI open for post-mortem browsing\n711:     if (tuiRef.current) {\n712:       tuiRef.current.updateState(state);\n713:       tuiRef.current.markWaveComplete();\n714:       await tuiRef.current.waitForQuit();\n715:     }\n716: \n717:     if (fmt === \"text\") {\n718:       printDashboard(state);\n719: \n720:       // Dump full logs for failed agents (post-mortem)\n721:       dumpFailedAgentLogs(projectRoot, state, fmt);\n722:     }\n723: \n724:     // Clean up HITL files\n725:     try {\n726:       cleanupHitl(projectRoot);\n727:     } catch {\n728:       // Non-fatal\n729:     }\n730: \n731:     // Auto-export wave history\n732:     try {\n733:       const historyPath = exportWaveHistory(projectRoot, state);\n734:       if (fmt === \"text\") console.log(`Wave history exported to ${historyPath}`);\n735:     } catch (err: any) {\n736:       if (fmt === \"text\") console.error(`Warning: failed to export wave history: ${err.message}`);\n737:     }\n738: \n739:     // Auto-push base branch if requested\n740:     if (opts.autoPush) {\n741:       await pushBaseBranch(projectRoot, state.base_branch, config);\n742:     }\n743: \n744:     if (fmt === \"text\") console.log(\"Wave complete.\");\n745:   }\n746: }\n\n(End of file - total 746 lines)\n</content>","title":"src/commands/resume.ts","metadata":{"preview":"/**\n * resume.ts — Resume a previously stopped wave.\n *\n * Usage: woco resume [options] [--output json]\n *\n * Restores from .wombo-combo/state.json:\n *   - Agents in \"running\"/\"installing\" whose PID is dead → re-check or re-launch\n *   - Agents in \"queued\" → launch them\n *   - Agents in terminal states (verified/failed/merged) → leave alone\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport type { Feature } from \"../lib/tasks.js\";\nimport { loadFeatures } from \"../lib/tasks.js\";\nimport {\n  loadState,\n  saveState,\n  updateAgent,\n  queuedAgents,\n  readyToLaunchAgents,","truncated":false,"loaded":[]},"time":{"start":1773481728159,"end":1773481728164}}}}
