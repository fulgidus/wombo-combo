{"type":"tool_use","timestamp":1773482650635,"sessionID":"ses_3143289ffffebE5N0evuhJd5Hx","part":{"id":"prt_cebcdaaa1001KaPOCrelS7mNY9","sessionID":"ses_3143289ffffebE5N0evuhJd5Hx","messageID":"msg_cebcd9b33001NJoWhwE33k9Xz8","type":"tool","callID":"toolu_vrtx_01W2K8WFHnpHJrUqvYxMyENo","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/wave-reconnect/src/commands/tui.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/wave-reconnect/src/commands/tui.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * tui.ts -- Unified TUI command entry point for wombo-combo.\n3:  *\n4:  * Orchestrates multiple views in a persistent loop:\n5:  *   1. Quest Picker (tui-quest-picker.ts) -- select a quest or \"All Tasks\"\n6:  *   2. Task Browser (tui-browser.ts) -- select tasks, change priorities, launch\n7:  *   3. Wave Monitor (tui.ts) -- watch running wave, view logs, retry agents\n8:  *   4. Plan Review (tui-plan-review.ts) -- review/edit/approve planner output\n9:  *   5. Genesis Review (tui-genesis-review.ts) -- review/edit/approve genesis plan\n10:  *\n11:  * Flow:\n12:  *   `woco` -> Quest Picker (if quests exist) -> Task Browser -> L -> launches\n13:  *   wave -> wave completes -> Q in monitor -> back to Quest Picker -> ...\n14:  *\n15:  *   Quest Picker -> P (plan) -> spinner -> Plan Review -> approve/cancel ->\n16:  *   back to Quest Picker\n17:  *\n18:  *   Quest Picker -> G (genesis) -> vision prompt -> spinner -> Genesis Review\n19:  *   -> approve/cancel -> back to Quest Picker\n20:  *\n21:  *   Quest Picker/Browser -> E (errand) -> description prompt -> spinner ->\n22:  *   Plan Review -> approve/cancel -> creates quest-less tasks -> back\n23:  *\n24:  * If no quests exist, the Quest Picker is skipped entirely and the flow goes\n25:  * straight to the Task Browser (backward compatible).\n26:  *\n27:  * Exit behavior:\n28:  *   - Q from Quest Picker: exits the process\n29:  *   - Q/Esc from Task Browser: back to Quest Picker (or exits if no quests)\n30:  *   - Q from Wave Monitor: back to Quest Picker\n31:  *   - Q/Esc from Plan Review: discard plan, back to Quest Picker\n32:  *\n33:  * Session state is persisted to .wombo-combo/tui-session.json so the user can\n34:  * close and reopen the TUI without losing their task selections.\n35:  */\n36: \n37: import type { WomboConfig } from \"../config.js\";\n38: import { ensureTasksFile } from \"../lib/tasks.js\";\n39: import { loadState } from \"../lib/state.js\";\n40: import { loadTUISession, saveTUISession } from \"../lib/tui-session.js\";\n41: import type { TUISession } from \"../lib/tui-session.js\";\n42: import { TaskBrowser } from \"../lib/tui-browser.js\";\n43: import { QuestPicker } from \"../lib/tui-quest-picker.js\";\n44: import type { QuestPickerAction } from \"../lib/tui-quest-picker.js\";\n45: import { PlanReview } from \"../lib/tui-plan-review.js\";\n46: import type { ProposedTask } from \"../lib/quest-planner.js\";\n47: import { runQuestPlanner, applyPlanToQuest } from \"../lib/quest-planner.js\";\n48: import type { PlanResult } from \"../lib/quest-planner.js\";\n49: import { loadAllQuests, loadQuest, saveQuest, listQuestIds, saveQuestKnowledge } from \"../lib/quest-store.js\";\n50: import { GenesisReview } from \"../lib/tui-genesis-review.js\";\n51: import type { GenesisReviewAction } from \"../lib/tui-genesis-review.js\";\n52: import { runGenesisPlanner } from \"../lib/genesis-planner.js\";\n53: import type { GenesisResult, ProposedQuest } from \"../lib/genesis-planner.js\";\n54: import { createBlankQuest } from \"../lib/quest.js\";\n55: import { runErrandPlanner, applyErrandPlan } from \"../lib/errand-planner.js\";\n56: import { cmdLaunch } from \"./launch.js\";\n57: import type { LaunchCommandOptions } from \"./launch.js\";\n58: import { cmdResume } from \"./resume.js\";\n59: \n60: // ---------------------------------------------------------------------------\n61: // Types\n62: // ---------------------------------------------------------------------------\n63: \n64: export interface TUICommandOptions {\n65:   projectRoot: string;\n66:   config: WomboConfig;\n67:   /** Max concurrent agents (override, or null to use session/config default) */\n68:   maxConcurrent?: number;\n69:   /** Model override */\n70:   model?: string;\n71:   /** Base branch override */\n72:   baseBranch?: string;\n73:   /** Max retries override */\n74:   maxRetries?: number;\n75:   /** Auto-push after merge */\n76:   autoPush?: boolean;\n77:   /** Skip TDD tests */\n78:   skipTests?: boolean;\n79:   /** Strict TDD mode */\n80:   strictTdd?: boolean;\n81:   /** Agent definition override */\n82:   agent?: string;\n83: }\n84: \n85: type BrowserAction =\n86:   | { type: \"launch\"; ids: string[] }\n87:   | { type: \"errand\" }\n88:   | { type: \"back\" }\n89:   | { type: \"quit\" };\n90: \n91: type PlanReviewResult =\n92:   | { type: \"approve\"; tasks: ProposedTask[]; knowledge: string | null }\n93:   | { type: \"cancel\" };\n94: \n95: // ---------------------------------------------------------------------------\n96: // Command -- Main Loop\n97: // ---------------------------------------------------------------------------\n98: \n99: export async function cmdTui(opts: TUICommandOptions): Promise<void> {\n100:   const { projectRoot, config } = opts;\n101: \n102:   // Ensure tasks file exists\n103:   await ensureTasksFile(projectRoot, config);\n104: \n105:   // Load session state (persisted selections, sort, concurrency)\n106:   const session = loadTUISession(projectRoot);\n107: \n108:   // Apply concurrency override from CLI if provided\n109:   if (opts.maxConcurrent !== undefined) {\n110:     session.maxConcurrent = opts.maxConcurrent;\n111:   }\n112: \n113:   // Main TUI loop:\n114:   //   Quest Picker -> Task Browser -> Launch -> Monitor -> back to Quest Picker\n115:   // Only exits when the user presses Q from the Quest Picker (or browser if no quests).\n116:   while (true) {\n117:     // Check for an active wave on each iteration\n118:     const existingState = loadState(projectRoot);\n119:     const hasRunningWave =\n120:       existingState !== null &&\n121:       existingState.agents.some(\n122:         (a) =>\n123:           a.status === \"running\" ||\n124:           a.status === \"queued\" ||\n125:           a.status === \"installing\" ||\n126:           a.status === \"resolving_conflict\" ||\n127:           a.status === \"retry\"\n128:       );\n129: \n130:     if (hasRunningWave) {\n131:       // A wave is already running -- resume it (wave monitor TUI).\n132:       // When the wave completes and the user presses Q, cmdResume returns\n133:       // and we loop back to the quest picker / browser.\n134:       console.log(\n135:         `Active wave detected: ${existingState!.wave_id}. Resuming...`\n136:       );\n137:       try {\n138:         await cmdResume({\n139:           projectRoot,\n140:           config,\n141:           maxConcurrent: opts.maxConcurrent,\n142:           model: opts.model,\n143:           interactive: false,\n144:           noTui: false,\n145:           autoPush: opts.autoPush ?? false,\n146:           baseBranch: opts.baseBranch,\n147:           maxRetries: opts.maxRetries,\n148:         });\n149:       } catch (err: any) {\n150:         // Don't crash -- show error and loop back\n151:         console.error(`\\nResume error: ${err.message}\\n`);\n152:         await sleep(2000);\n153:       }\n154:       // Clear terminal before showing picker/browser again\n155:       process.stdout.write(\"\\x1B[2J\\x1B[H\");\n156:       continue;\n157:     }\n158: \n159:     // -----------------------------------------------------------------------\n160:     // Quest Picker (skip if no quests exist)\n161:     // -----------------------------------------------------------------------\n162:     const quests = loadAllQuests(projectRoot);\n163:     const hasQuests = quests.length > 0;\n164: \n165:     let selectedQuestId: string | null = null;\n166: \n167:     if (hasQuests) {\n168:       const questAction = await showQuestPicker(projectRoot, config, opts);\n169: \n170:       if (questAction.type === \"quit\") {\n171:         // User pressed Q in quest picker -- exit cleanly\n172:         session.lastView = \"browser\";\n173:         saveTUISession(projectRoot, session);\n174:         break;\n175:       }\n176: \n177:       if (questAction.type === \"plan\") {\n178:         // User pressed P to plan a quest -- run planner + review\n179:         await handlePlanFlow(projectRoot, config, opts, questAction.questId);\n180:         // After planning (approve or cancel), loop back to quest picker\n181:         process.stdout.write(\"\\x1B[2J\\x1B[H\");\n182:         continue;\n183:       }\n184: \n185:       if (questAction.type === \"genesis\") {\n186:         // User pressed G to run genesis -- run genesis planner + review\n187:         await handleGenesisFlow(projectRoot, config, opts);\n188:         // After genesis (approve or cancel), loop back to quest picker\n189:         process.stdout.write(\"\\x1B[2J\\x1B[H\");\n190:         continue;\n191:       }\n192: \n193:       if (questAction.type === \"errand\") {\n194:         // User pressed E to create an errand (quest-less assisted task)\n195:         await handleErrandFlow(projectRoot, config, opts);\n196:         // After errand (approve or cancel), loop back to quest picker\n197:         process.stdout.write(\"\\x1B[2J\\x1B[H\");\n198:         continue;\n199:       }\n200: \n201:       selectedQuestId = questAction.questId;\n202:     }\n203: \n204:     // -----------------------------------------------------------------------\n205:     // Task Browser (filtered by quest if one was selected)\n206:     // -----------------------------------------------------------------------\n207:     const action = await showBrowser(\n208:       projectRoot,\n209:       config,\n210:       session,\n211:       opts,\n212:       selectedQuestId,\n213:       hasQuests\n214:     );\n215: \n216:     if (action.type === \"quit\") {\n217:       // User pressed Q in browser with no quest context -- exit cleanly\n218:       session.lastView = \"browser\";\n219:       saveTUISession(projectRoot, session);\n220:       break;\n221:     }\n222: \n223:     if (action.type === \"back\") {\n224:       // User pressed Q/Esc in quest-filtered browser -- back to quest picker\n225:       process.stdout.write(\"\\x1B[2J\\x1B[H\");\n226:       continue;\n227:     }\n228: \n229:     if (action.type === \"errand\") {\n230:       // User pressed E in browser to create an errand\n231:       await handleErrandFlow(projectRoot, config, opts);\n232:       process.stdout.write(\"\\x1B[2J\\x1B[H\");\n233:       continue;\n234:     }\n235: \n236:     if (action.type === \"launch\") {\n237:       // Save session before launching\n238:       session.selected = action.ids;\n239:       session.lastView = \"monitor\";\n240:       saveTUISession(projectRoot, session);\n241: \n242:       // Build launch options\n243:       const launchOpts: LaunchCommandOptions = {\n244:         projectRoot,\n245:         config,\n246:         features: action.ids,\n247:         maxConcurrent: session.maxConcurrent,\n248:         model: opts.model,\n249:         interactive: false,\n250:         dryRun: false,\n251:         baseBranch: opts.baseBranch ?? config.baseBranch,\n252:         maxRetries: opts.maxRetries ?? config.defaults.maxRetries,\n253:         noTui: false,\n254:         autoPush: opts.autoPush ?? false,\n255:         agent: opts.agent,\n256:         outputFmt: \"text\",\n257:         // Pass quest ID so launch uses quest branch and constraints\n258:         questId: selectedQuestId ?? undefined,\n259:       };\n260: \n261:       try {\n262:         await cmdLaunch(launchOpts);\n263:       } catch (err: any) {\n264:         // Don't crash -- show error and loop back\n265:         console.error(`\\nLaunch error: ${err.message}\\n`);\n266:         await sleep(2000);\n267:       }\n268: \n269:       // Clear terminal before showing picker/browser again\n270:       process.stdout.write(\"\\x1B[2J\\x1B[H\");\n271:       continue;\n272:     }\n273:   }\n274: }\n275: \n276: // ---------------------------------------------------------------------------\n277: // Quest Picker View -- Promise-based\n278: // ---------------------------------------------------------------------------\n279: \n280: /**\n281:  * Show the Quest Picker and return a Promise that resolves when the user\n282:  * takes an action (select quest, plan quest, or quit).\n283:  */\n284: function showQuestPicker(\n285:   projectRoot: string,\n286:   config: WomboConfig,\n287:   opts: TUICommandOptions\n288: ): Promise<QuestPickerAction> {\n289:   return new Promise<QuestPickerAction>((resolve) => {\n290:     const picker = new QuestPicker({\n291:       projectRoot,\n292:       config,\n293: \n294:       onSelect: (questId: string | null) => {\n295:         resolve({ type: \"select\", questId });\n296:       },\n297: \n298:       onPlan: (questId: string) => {\n299:         resolve({ type: \"plan\", questId });\n300:       },\n301: \n302:       onGenesis: () => {\n303:         resolve({ type: \"genesis\" });\n304:       },\n305: \n306:       onErrand: () => {\n307:         resolve({ type: \"errand\" });\n308:       },\n309: \n310:       onQuit: () => {\n311:         resolve({ type: \"quit\" });\n312:       },\n313:     });\n314: \n315:     picker.start();\n316:   });\n317: }\n318: \n319: // ---------------------------------------------------------------------------\n320: // Plan Flow -- Planner + Review\n321: // ---------------------------------------------------------------------------\n322: \n323: /**\n324:  * Run the quest planner agent, then show the plan review TUI.\n325:  * Handles the full flow: spinner → planner → review → approve/cancel.\n326:  */\n327: async function handlePlanFlow(\n328:   projectRoot: string,\n329:   config: WomboConfig,\n330:   opts: TUICommandOptions,\n331:   questId: string\n332: ): Promise<void> {\n333:   const quest = loadQuest(projectRoot, questId);\n334:   if (!quest) {\n335:     console.error(`\\nQuest \"${questId}\" not found.\\n`);\n336:     await sleep(2000);\n337:     return;\n338:   }\n339: \n340:   // Set quest to planning status\n341:   const prevStatus = quest.status;\n342:   quest.status = \"planning\";\n343:   saveQuest(projectRoot, quest);\n344: \n345:   // Show a planning spinner on the terminal (no blessed screen here)\n346:   console.log(`\\n  Planning quest: ${quest.title} (${quest.id})`);\n347:   console.log(`  Running quest planner agent...\\n`);\n348: \n349:   const spinChars = [\"\\u2802\", \"\\u2806\", \"\\u2807\", \"\\u2803\", \"\\u2809\", \"\\u280C\", \"\\u280E\", \"\\u280B\"];\n350:   let spinIdx = 0;\n351:   let lastProgress = \"\";\n352:   const spinTimer = setInterval(() => {\n353:     const ch = spinChars[spinIdx % spinChars.length];\n354:     spinIdx++;\n355:     process.stdout.write(`\\r  ${ch} ${lastProgress}`);\n356:   }, 120);\n357: \n358:   let planResult: PlanResult;\n359: \n360:   try {\n361:     planResult = await runQuestPlanner(quest, projectRoot, config, {\n362:       model: opts.model,\n363:       onProgress: (msg) => {\n364:         lastProgress = msg;\n365:       },\n366:     });\n367:   } catch (err: any) {\n368:     clearInterval(spinTimer);\n369:     process.stdout.write(\"\\r\" + \" \".repeat(80) + \"\\r\");\n370:     console.error(`\\n  Planner error: ${err.message}\\n`);\n371:     // Revert quest status\n372:     quest.status = prevStatus;\n373:     saveQuest(projectRoot, quest);\n374:     await sleep(3000);\n375:     return;\n376:   }\n377: \n378:   clearInterval(spinTimer);\n379:   process.stdout.write(\"\\r\" + \" \".repeat(80) + \"\\r\");\n380: \n381:   if (!planResult.success && planResult.tasks.length === 0) {\n382:     // Total failure — no tasks produced\n383:     console.error(`\\n  Planner failed: ${planResult.error ?? \"No tasks produced\"}\\n`);\n384:     quest.status = prevStatus;\n385:     saveQuest(projectRoot, quest);\n386:     await sleep(3000);\n387:     return;\n388:   }\n389: \n390:   console.log(`  Planner produced ${planResult.tasks.length} tasks.`);\n391:   if (planResult.issues.length > 0) {\n392:     const errors = planResult.issues.filter((i) => i.level === \"error\").length;\n393:     const warnings = planResult.issues.filter((i) => i.level === \"warning\").length;\n394:     if (errors > 0) console.log(`  ${errors} validation error(s).`);\n395:     if (warnings > 0) console.log(`  ${warnings} validation warning(s).`);\n396:   }\n397:   console.log(`  Opening plan review...\\n`);\n398:   await sleep(1000);\n399: \n400:   // Clear terminal before showing the plan review TUI\n401:   process.stdout.write(\"\\x1B[2J\\x1B[H\");\n402: \n403:   // Show the plan review TUI\n404:   const reviewAction = await showPlanReview(\n405:     questId,\n406:     quest.title,\n407:     planResult\n408:   );\n409: \n410:   if (reviewAction.type === \"cancel\") {\n411:     // User cancelled — revert quest status\n412:     quest.status = prevStatus;\n413:     saveQuest(projectRoot, quest);\n414:     console.log(`\\n  Plan discarded. Quest \"${questId}\" reverted to \"${prevStatus}\".\\n`);\n415:     await sleep(1500);\n416:     return;\n417:   }\n418: \n419:   // User approved — apply the plan\n420:   try {\n421:     // Update planResult with only the accepted tasks\n422:     const approvedResult: PlanResult = {\n423:       ...planResult,\n424:       tasks: reviewAction.tasks,\n425:       knowledge: reviewAction.knowledge,\n426:     };\n427: \n428:     const tasks = applyPlanToQuest(approvedResult, quest, projectRoot, config);\n429:     console.log(`\\n  Plan approved! Created ${tasks.length} tasks.`);\n430:     console.log(`  Quest \"${questId}\" is now active.`);\n431:     if (reviewAction.knowledge) {\n432:       console.log(`  Saved knowledge file (${reviewAction.knowledge.length} chars).`);\n433:     }\n434:     console.log();\n435:     await sleep(2000);\n436:   } catch (err: any) {\n437:     console.error(`\\n  Failed to apply plan: ${err.message}\\n`);\n438:     quest.status = prevStatus;\n439:     saveQuest(projectRoot, quest);\n440:     await sleep(3000);\n441:   }\n442: }\n443: \n444: // ---------------------------------------------------------------------------\n445: // Genesis Flow -- Vision Prompt + Planner + Review\n446: // ---------------------------------------------------------------------------\n447: \n448: /**\n449:  * Run the genesis planner: prompt user for a vision, run the genesis planner\n450:  * agent, then show the genesis review TUI.\n451:  * Handles the full flow: readline prompt → spinner → planner → review → create quests.\n452:  */\n453: async function handleGenesisFlow(\n454:   projectRoot: string,\n455:   config: WomboConfig,\n456:   opts: TUICommandOptions\n457: ): Promise<void> {\n458:   // Prompt the user for a project vision via readline (no blessed screen is active)\n459:   const readline = await import(\"node:readline\");\n460:   const rl = readline.createInterface({\n461:     input: process.stdin,\n462:     output: process.stdout,\n463:   });\n464: \n465:   const vision = await new Promise<string>((resolve) => {\n466:     console.log();\n467:     console.log(\"  ╔══════════════════════════════════════╗\");\n468:     console.log(\"  ║         GENESIS PLANNER              ║\");\n469:     console.log(\"  ╚══════════════════════════════════════╝\");\n470:     console.log();\n471:     console.log(\"  Describe your project vision. The genesis planner will\");\n472:     console.log(\"  decompose it into a set of quests.\");\n473:     console.log();\n474:     rl.question(\"  Vision: \", (answer) => {\n475:       rl.close();\n476:       resolve(answer.trim());\n477:     });\n478:   });\n479: \n480:   if (!vision) {\n481:     console.log(\"\\n  No vision provided. Returning to quest picker.\\n\");\n482:     await sleep(1500);\n483:     return;\n484:   }\n485: \n486:   // Gather existing quest IDs so the planner can avoid duplicates\n487:   const existingQuestIds = listQuestIds(projectRoot);\n488: \n489:   // Show a planning spinner on the terminal\n490:   console.log();\n491:   console.log(`  Running genesis planner agent...`);\n492:   console.log();\n493: \n494:   const spinChars = [\"\\u2802\", \"\\u2806\", \"\\u2807\", \"\\u2803\", \"\\u2809\", \"\\u280C\", \"\\u280E\", \"\\u280B\"];\n495:   let spinIdx = 0;\n496:   let lastProgress = \"\";\n497:   const spinTimer = setInterval(() => {\n498:     const ch = spinChars[spinIdx % spinChars.length];\n499:     spinIdx++;\n500:     process.stdout.write(`\\r  ${ch} ${lastProgress}`);\n501:   }, 120);\n502: \n503:   let genesisResult: GenesisResult;\n504: \n505:   try {\n506:     genesisResult = await runGenesisPlanner(vision, projectRoot, config, {\n507:       existingQuestIds,\n508:       model: opts.model,\n509:       onProgress: (msg) => {\n510:         lastProgress = msg;\n511:       },\n512:     });\n513:   } catch (err: any) {\n514:     clearInterval(spinTimer);\n515:     process.stdout.write(\"\\r\" + \" \".repeat(80) + \"\\r\");\n516:     console.error(`\\n  Genesis planner error: ${err.message}\\n`);\n517:     await sleep(3000);\n518:     return;\n519:   }\n520: \n521:   clearInterval(spinTimer);\n522:   process.stdout.write(\"\\r\" + \" \".repeat(80) + \"\\r\");\n523: \n524:   if (!genesisResult.success && genesisResult.quests.length === 0) {\n525:     // Total failure — no quests produced\n526:     console.error(`\\n  Genesis planner failed: ${genesisResult.error ?? \"No quests produced\"}\\n`);\n527:     await sleep(3000);\n528:     return;\n529:   }\n530: \n531:   console.log(`  Genesis planner produced ${genesisResult.quests.length} quests.`);\n532:   if (genesisResult.issues.length > 0) {\n533:     const errors = genesisResult.issues.filter((i) => i.level === \"error\").length;\n534:     const warnings = genesisResult.issues.filter((i) => i.level === \"warning\").length;\n535:     if (errors > 0) console.log(`  ${errors} validation error(s).`);\n536:     if (warnings > 0) console.log(`  ${warnings} validation warning(s).`);\n537:   }\n538:   console.log(`  Opening genesis review...\\n`);\n539:   await sleep(1000);\n540: \n541:   // Clear terminal before showing the genesis review TUI\n542:   process.stdout.write(\"\\x1B[2J\\x1B[H\");\n543: \n544:   // Show the genesis review TUI\n545:   const reviewAction = await showGenesisReview(genesisResult);\n546: \n547:   if (reviewAction.type === \"cancel\") {\n548:     console.log(`\\n  Genesis plan discarded.\\n`);\n549:     await sleep(1500);\n550:     return;\n551:   }\n552: \n553:   // User approved — create quests from accepted proposals\n554:   const baseBranch = opts.baseBranch ?? config.baseBranch;\n555:   const created: string[] = [];\n556: \n557:   for (const proposed of reviewAction.quests) {\n558:     const quest = createBlankQuest(proposed.id, proposed.title, proposed.goal, baseBranch, {\n559:       priority: proposed.priority,\n560:       difficulty: proposed.difficulty,\n561:       hitlMode: proposed.hitl_mode,\n562:     });\n563: \n564:     // Apply constraints from the genesis planner\n565:     quest.constraints.add = proposed.constraints.add ?? [];\n566:     quest.constraints.ban = proposed.constraints.ban ?? [];\n567:     quest.depends_on = proposed.depends_on ?? [];\n568:     quest.notes = proposed.notes ?? [];\n569: \n570:     saveQuest(projectRoot, quest);\n571:     created.push(quest.id);\n572:   }\n573: \n574:   console.log(`\\n  Genesis plan approved! Created ${created.length} quests:`);\n575:   for (const id of created) {\n576:     console.log(`    - ${id}`);\n577:   }\n578: \n579:   // Save knowledge if the planner produced any (attach to the first quest)\n580:   const knowledge = reviewAction.knowledge;\n581:   if (knowledge && created.length > 0) {\n582:     saveQuestKnowledge(projectRoot, created[0], knowledge);\n583:     console.log(`  Saved knowledge file (${knowledge.length} chars) to quest \"${created[0]}\".`);\n584:   }\n585: \n586:   console.log();\n587:   await sleep(2000);\n588: }\n589: \n590: // ---------------------------------------------------------------------------\n591: // Errand Flow -- Quick Task Generation (quest-less)\n592: // ---------------------------------------------------------------------------\n593: \n594: /**\n595:  * Run the errand planner: prompt user for a brief description, run the quest\n596:  * planner agent with an errand-specific prompt, then show plan review to let\n597:  * the user accept/reject/edit the proposed tasks.\n598:  *\n599:  * Created tasks go directly into the task store without any quest association.\n600:  */\n601: async function handleErrandFlow(\n602:   projectRoot: string,\n603:   config: WomboConfig,\n604:   opts: TUICommandOptions\n605: ): Promise<void> {\n606:   // Prompt the user for a description via readline (no blessed screen is active)\n607:   const readline = await import(\"node:readline\");\n608:   const rl = readline.createInterface({\n609:     input: process.stdin,\n610:     output: process.stdout,\n611:   });\n612: \n613:   const description = await new Promise<string>((resolve) => {\n614:     console.log();\n615:     console.log(\"  ╔══════════════════════════════════════╗\");\n616:     console.log(\"  ║           ERRAND PLANNER             ║\");\n617:     console.log(\"  ╚══════════════════════════════════════╝\");\n618:     console.log();\n619:     console.log(\"  Describe the errand. The planner will explore the\");\n620:     console.log(\"  codebase and generate tasks for you.\");\n621:     console.log();\n622:     rl.question(\"  Errand: \", (answer) => {\n623:       rl.close();\n624:       resolve(answer.trim());\n625:     });\n626:   });\n627: \n628:   if (!description) {\n629:     console.log(\"\\n  No description provided. Returning.\\n\");\n630:     await sleep(1500);\n631:     return;\n632:   }\n633: \n634:   // Show a planning spinner on the terminal\n635:   console.log();\n636:   console.log(`  Running errand planner...`);\n637:   console.log();\n638: \n639:   const spinChars = [\"\\u2802\", \"\\u2806\", \"\\u2807\", \"\\u2803\", \"\\u2809\", \"\\u280C\", \"\\u280E\", \"\\u280B\"];\n640:   let spinIdx = 0;\n641:   let lastProgress = \"\";\n642:   const spinTimer = setInterval(() => {\n643:     const ch = spinChars[spinIdx % spinChars.length];\n644:     spinIdx++;\n645:     process.stdout.write(`\\r  ${ch} ${lastProgress}`);\n646:   }, 120);\n647: \n648:   let planResult: PlanResult;\n649: \n650:   try {\n651:     planResult = await runErrandPlanner(description, projectRoot, config, {\n652:       model: opts.model,\n653:       onProgress: (msg) => {\n654:         lastProgress = msg;\n655:       },\n656:     });\n657:   } catch (err: any) {\n658:     clearInterval(spinTimer);\n659:     process.stdout.write(\"\\r\" + \" \".repeat(80) + \"\\r\");\n660:     console.error(`\\n  Errand planner error: ${err.message}\\n`);\n661:     await sleep(3000);\n662:     return;\n663:   }\n664: \n665:   clearInterval(spinTimer);\n666:   process.stdout.write(\"\\r\" + \" \".repeat(80) + \"\\r\");\n667: \n668:   if (!planResult.success && planResult.tasks.length === 0) {\n669:     console.error(`\\n  Errand planner failed: ${planResult.error ?? \"No tasks produced\"}\\n`);\n670:     await sleep(3000);\n671:     return;\n672:   }\n673: \n674:   console.log(`  Errand planner produced ${planResult.tasks.length} task(s).`);\n675:   if (planResult.issues.length > 0) {\n676:     const errors = planResult.issues.filter((i) => i.level === \"error\").length;\n677:     const warnings = planResult.issues.filter((i) => i.level === \"warning\").length;\n678:     if (errors > 0) console.log(`  ${errors} validation error(s).`);\n679:     if (warnings > 0) console.log(`  ${warnings} validation warning(s).`);\n680:   }\n681:   console.log(`  Opening plan review...\\n`);\n682:   await sleep(1000);\n683: \n684:   // Clear terminal before showing the plan review TUI\n685:   process.stdout.write(\"\\x1B[2J\\x1B[H\");\n686: \n687:   // Reuse the plan review TUI (it works for any set of proposed tasks)\n688:   const reviewAction = await showPlanReview(\n689:     \"(errand)\",\n690:     description.length > 50 ? description.slice(0, 47) + \"...\" : description,\n691:     planResult\n692:   );\n693: \n694:   if (reviewAction.type === \"cancel\") {\n695:     console.log(`\\n  Errand plan discarded.\\n`);\n696:     await sleep(1500);\n697:     return;\n698:   }\n699: \n700:   // User approved -- create tasks directly (no quest)\n701:   try {\n702:     const approvedResult: PlanResult = {\n703:       ...planResult,\n704:       tasks: reviewAction.tasks,\n705:       knowledge: reviewAction.knowledge,\n706:     };\n707: \n708:     const tasks = applyErrandPlan(approvedResult, projectRoot, config);\n709:     console.log(`\\n  Errand approved! Created ${tasks.length} task(s):`);\n710:     for (const t of tasks) {\n711:       console.log(`    - ${t.id}: ${t.title}`);\n712:     }\n713:     console.log();\n714:     await sleep(2000);\n715:   } catch (err: any) {\n716:     console.error(`\\n  Failed to create errand tasks: ${err.message}\\n`);\n717:     await sleep(3000);\n718:   }\n719: }\n720: \n721: // ---------------------------------------------------------------------------\n722: // Genesis Review View -- Promise-based\n723: // ---------------------------------------------------------------------------\n724: \n725: /**\n726:  * Show the Genesis Review TUI and return a Promise that resolves when the\n727:  * user approves or cancels.\n728:  */\n729: function showGenesisReview(\n730:   genesisResult: GenesisResult\n731: ): Promise<GenesisReviewAction> {\n732:   return new Promise<GenesisReviewAction>((resolve) => {\n733:     const review = new GenesisReview({\n734:       genesisResult,\n735: \n736:       onApprove: (quests, knowledge) => {\n737:         resolve({ type: \"approve\", quests, knowledge });\n738:       },\n739: \n740:       onCancel: () => {\n741:         resolve({ type: \"cancel\" });\n742:       },\n743:     });\n744: \n745:     review.start();\n746:   });\n747: }\n748: \n749: // ---------------------------------------------------------------------------\n750: // Plan Review View -- Promise-based\n751: // ---------------------------------------------------------------------------\n752: \n753: /**\n754:  * Show the Plan Review TUI and return a Promise that resolves when the user\n755:  * approves or cancels.\n756:  */\n757: function showPlanReview(\n758:   questId: string,\n759:   questTitle: string,\n760:   planResult: PlanResult\n761: ): Promise<PlanReviewResult> {\n762:   return new Promise<PlanReviewResult>((resolve) => {\n763:     const review = new PlanReview({\n764:       questId,\n765:       questTitle,\n766:       planResult,\n767: \n768:       onApprove: (tasks, knowledge) => {\n769:         resolve({ type: \"approve\", tasks, knowledge });\n770:       },\n771: \n772:       onCancel: () => {\n773:         resolve({ type: \"cancel\" });\n774:       },\n775:     });\n776: \n777:     review.start();\n778:   });\n779: }\n780: \n781: // ---------------------------------------------------------------------------\n782: // Browser View -- Promise-based\n783: // ---------------------------------------------------------------------------\n784: \n785: /**\n786:  * Show the Task Browser and return a Promise that resolves when the user\n787:  * takes an action (launch, back, or quit).\n788:  */\n789: function showBrowser(\n790:   projectRoot: string,\n791:   config: WomboConfig,\n792:   session: TUISession,\n793:   opts: TUICommandOptions,\n794:   questId: string | null,\n795:   hasQuestPicker: boolean\n796: ): Promise<BrowserAction> {\n797:   // Reload session from disk in case state changed after a wave\n798:   const freshSession = loadTUISession(projectRoot);\n799:   // Merge any runtime overrides\n800:   if (opts.maxConcurrent !== undefined) {\n801:     freshSession.maxConcurrent = opts.maxConcurrent;\n802:   }\n803:   // Copy fresh values back into the shared session object\n804:   Object.assign(session, freshSession);\n805: \n806:   // Load quest details for filtering if a quest was selected\n807:   let questTitle: string | undefined;\n808:   let questTaskIds: string[] | undefined;\n809:   if (questId) {\n810:     const quest = loadQuest(projectRoot, questId);\n811:     if (quest) {\n812:       questTitle = quest.title;\n813:       questTaskIds = quest.taskIds;\n814:     }\n815:   }\n816: \n817:   return new Promise<BrowserAction>((resolve) => {\n818:     const browser = new TaskBrowser({\n819:       projectRoot,\n820:       config,\n821:       session,\n822:       questId,\n823:       questTitle,\n824:       questTaskIds,\n825: \n826:       onLaunch: (selectedIds: string[]) => {\n827:         if (selectedIds.length === 0) return;\n828:         // The browser has already shown a transition message on-screen.\n829:         // Destroy the blessed screen and clear the terminal.\n830:         browser.destroy();\n831:         resolve({ type: \"launch\", ids: selectedIds });\n832:       },\n833: \n834:       onQuit: () => {\n835:         browser.stop();\n836:         resolve({ type: \"quit\" });\n837:       },\n838: \n839:       onBack: hasQuestPicker\n840:         ? () => {\n841:             resolve({ type: \"back\" });\n842:           }\n843:         : undefined,\n844: \n845:       // Errand is available when not in quest-filtered mode\n846:       onErrand: !questId\n847:         ? () => {\n848:             resolve({ type: \"errand\" });\n849:           }\n850:         : undefined,\n851: \n852:       onSwitchToMonitor: undefined,\n853:     });\n854: \n855:     browser.start();\n856:   });\n857: }\n858: \n859: // ---------------------------------------------------------------------------\n860: // Helpers\n861: // ---------------------------------------------------------------------------\n862: \n863: function sleep(ms: number): Promise<void> {\n864:   return new Promise((r) => setTimeout(r, ms));\n865: }\n\n(End of file - total 865 lines)\n</content>","title":"src/commands/tui.ts","metadata":{"preview":"/**\n * tui.ts -- Unified TUI command entry point for wombo-combo.\n *\n * Orchestrates multiple views in a persistent loop:\n *   1. Quest Picker (tui-quest-picker.ts) -- select a quest or \"All Tasks\"\n *   2. Task Browser (tui-browser.ts) -- select tasks, change priorities, launch\n *   3. Wave Monitor (tui.ts) -- watch running wave, view logs, retry agents\n *   4. Plan Review (tui-plan-review.ts) -- review/edit/approve planner output\n *   5. Genesis Review (tui-genesis-review.ts) -- review/edit/approve genesis plan\n *\n * Flow:\n *   `woco` -> Quest Picker (if quests exist) -> Task Browser -> L -> launches\n *   wave -> wave completes -> Q in monitor -> back to Quest Picker -> ...\n *\n *   Quest Picker -> P (plan) -> spinner -> Plan Review -> approve/cancel ->\n *   back to Quest Picker\n *\n *   Quest Picker -> G (genesis) -> vision prompt -> spinner -> Genesis Review\n *   -> approve/cancel -> back to Quest Picker\n *","truncated":false,"loaded":[]},"time":{"start":1773482650631,"end":1773482650634}}}}
