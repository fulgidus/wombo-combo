&&\n1288:         !monitor.isRunning(agent.feature_id)\n1289:       ) {\n1290:         if (agent.retries >= agent.max_retries) {\n1291:           // Out of retries — mark as failed and cascade\n1292:           wtLog(agent.feature_id, `stuck in retry with no process and retries exhausted (${agent.retries}/${agent.max_retries}) — marking failed`);\n1293:           updateAgent(state, agent.feature_id, {\n1294:             status: \"failed\",\n1295:             error: agent.error ?? \"Agent stuck in retry state with no running process\",\n1296:             activity: null,\n1297:             completed_at: new Date().toISOString(),\n1298:           });\n1299:           saveState(projectRoot, state);\n1300:           const cancelled = cancelDownstream(state, agent.feature_id);\n1301:           if (cancelled.length > 0) {\n1302:             wtLog(agent.feature_id, `downstream cancelled: ${cancelled.join(\", \")}`);\n1303:             saveState(projectRoot, state);\n1304:           }\n1305:         } else {\n1306:           // Has retries left — reset to queued for a fresh launch\n1307:           wtLog(agent.feature_id, `stuck in retry with no process — resetting to queued (retry ${agent.retries}/${agent.max_retries})`);\n1308:           updateAgent(state, agent.feature_id, {\n1309:             status: \"queued\",\n1310:             error: null,\n1311:             activity: \"waiting for relaunch...\",\n1312:           });\n1313:           saveState(projectRoot, state);\n1314:         }\n1315:       }\n1316:     }\n1317: \n1318:     // After recovering stuck agents, try launching any that are now ready\n1319:     await launchAllReady(projectRoot, state, featureMap, monitor, config, model, agentResolutions, questContext, hitlMode);\n\n(Showing lines 1220-1319 of 1934. Use offset=1320 to continue.)\n</content>","title":"src/commands/launch.ts","metadata":{"preview":"    }\n  } else {\n    if (fmt === \"text\") console.log(`${launched} agent(s) running. Launching TUI...\\n`);\n