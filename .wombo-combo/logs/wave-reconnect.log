{"type":"tool_use","timestamp":1773482662372,"sessionID":"ses_3143289ffffebE5N0evuhJd5Hx","part":{"id":"prt_cebcdd522001mgUfGoqfTR5kiD","sessionID":"ses_3143289ffffebE5N0evuhJd5Hx","messageID":"msg_cebcdcb58001aOwRIp2P9sWubn","type":"tool","callID":"toolu_vrtx_01AKVgmn2HCJ387ThDi4DiE4","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/wave-reconnect/src/lib/token-collector.ts"},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/wave-reconnect/src/lib/token-collector.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * token-collector.ts — Parse and collect token usage data from agent events.\n3:  *\n4:  * Responsibilities:\n5:  *   - Define the UsageRecord type for structured token usage data\n6:  *   - Parse step_finish events to extract per-step token counts\n7:  *   - Accumulate usage records per agent (task_id)\n8:  *   - Emit parsed records via callback (storage is handled elsewhere)\n9:  *\n10:  * OpenCode emits step_finish events with this token structure:\n11:  *   {\n12:  *     type: \"step_finish\",\n13:  *     part: {\n14:  *       reason: \"tool-calls\" | \"stop\",\n15:  *       cost: number,\n16:  *       tokens: {\n17:  *         total: number,\n18:  *         input: number,\n19:  *         output: number,\n20:  *         reasoning: number,\n21:  *         cache: { read: number, write: number }\n22:  *       }\n23:  *     }\n24:  *   }\n25:  */\n26: \n27: import type { OpenCodeEvent } from \"./monitor.js\";\n28: \n29: // ---------------------------------------------------------------------------\n30: // Types\n31: // ---------------------------------------------------------------------------\n32: \n33: /**\n34:  * A single token usage record extracted from an agent's step_finish event.\n35:  *\n36:  * Each record represents one step's token consumption. Multiple records\n37:  * are emitted per agent session (one per step_finish event).\n38:  */\n39: export interface UsageRecord {\n40:   /** The task/feature ID this usage belongs to */\n41:   task_id: string;\n42:   /** Optional quest ID if the agent is working within a quest */\n43:   quest_id: string | null;\n44:   /** Model identifier (e.g. \"claude-sonnet-4-20250514\") — from launch context */\n45:   model: string | null;\n46:   /** Provider name (e.g. \"anthropic\", \"openai\") — from launch context */\n47:   provider: string | null;\n48:   /** Agent harness name (e.g. \"opencode\") — from launch context */\n49:   harness: string | null;\n50:   /** Input tokens consumed in this step */\n51:   input_tokens: number;\n52:   /** Output tokens generated in this step */\n53:   output_tokens: number;\n54:   /** Tokens read from cache in this step */\n55:   cache_read: number;\n56:   /** Tokens written to cache in this step */\n57:   cache_write: number;\n58:   /** Reasoning tokens used in this step (e.g. for o1-style models) */\n59:   reasoning_tokens: number;\n60:   /** Total tokens for this step (input + output + reasoning) */\n61:   total_tokens: number;\n62:   /** Cost reported by the agent harness (may be 0 if not available) */\n63:   cost: number;\n64:   /** Whether this was the final step (reason === \"stop\") */\n65:   is_final_step: boolean;\n66:   /** ISO 8601 timestamp when this usage was recorded */\n67:   timestamp: string;\n68: }\n69: \n70: /**\n71:  * Aggregated usage summary for a single agent session.\n72:  */\n73: export interface UsageSummary {\n74:   /** The task/feature ID */\n75:   task_id: string;\n76:   /** Total input tokens across all steps */\n77:   total_input: number;\n78:   /** Total output tokens across all steps */\n79:   total_output: number;\n80:   /** Total cache read tokens across all steps */\n81:   total_cache_read: number;\n82:   /** Total cache write tokens across all steps */\n83:   total_cache_write: number;\n84:   /** Total reasoning tokens across all steps */\n85:   total_reasoning: number;\n86:   /** Grand total tokens across all steps */\n87:   total_tokens: number;\n88:   /** Total cost across all steps */\n89:   total_cost: number;\n90:   /** Number of steps recorded */\n91:   step_count: number;\n92: }\n93: \n94: // ---------------------------------------------------------------------------\n95: // Parsing\n96: // ---------------------------------------------------------------------------\n97: \n98: /**\n99:  * Check if an OpenCode event is a step_finish with token data.\n100:  */\n101: export function isTokenEvent(event: OpenCodeEvent): boolean {\n102:   return (\n103:     event.type === \"step_finish\" &&\n104:     event.part?.tokens != null &&\n105:     typeof event.part.tokens.input === \"number\"\n106:   );\n107: }\n108: \n109: /**\n110:  * Extract a UsageRecord from a step_finish event.\n111:  *\n112:  * Returns null if the event doesn't contain valid token data.\n113:  *\n114:  * @param event     The OpenCode JSON event (must be type \"step_finish\")\n115:  * @param taskId    The task/feature ID this agent is working on\n116:  * @param context   Optional context from the launch environment\n117:  */\n118: export function parseUsageFromEvent(\n119:   event: OpenCodeEvent,\n120:   taskId: string,\n121:   context?: {\n122:     quest_id?: string | null;\n123:     model?: string | null;\n124:     provider?: string | null;\n125:     harness?: string | null;\n126:   }\n127: ): UsageRecord | null {\n128:   if (!isTokenEvent(event)) return null;\n129: \n130:   const tokens = event.part!.tokens!;\n131:   const cache = tokens.cache ?? { read: 0, write: 0 };\n132: \n133:   return {\n134:     task_id: taskId,\n135:     quest_id: context?.quest_id ?? null,\n136:     model: context?.model ?? null,\n137:     provider: context?.provider ?? null,\n138:     harness: context?.harness ?? \"opencode\",\n139:     input_tokens: tokens.input,\n140:     output_tokens: tokens.output,\n141:     cache_read: cache.read,\n142:     cache_write: cache.write,\n143:     reasoning_tokens: tokens.reasoning ?? 0,\n144:     total_tokens: tokens.total,\n145:     cost: event.part?.cost ?? 0,\n146:     is_final_step: event.part?.reason === \"stop\",\n147:     timestamp: new Date(event.timestamp ?? Date.now()).toISOString(),\n148:   };\n149: }\n150: \n151: // ---------------------------------------------------------------------------\n152: // Collector\n153: // ---------------------------------------------------------------------------\n154: \n155: /** Callback invoked when a new usage record is parsed */\n156: export type UsageCallback = (record: UsageRecord) => void;\n157: \n158: /**\n159:  * TokenCollector accumulates usage records for multiple agents.\n160:  *\n161:  * Usage:\n162:  *   const collector = new TokenCollector((record) => {\n163:  *     console.log(\"Usage:\", record);\n164:  *   });\n165:  *\n166:  *   // Register context for an agent before it starts\n167:  *   collector.registerAgent(\"my-feature\", {\n168:  *     quest_id: \"quest-1\",\n169:  *     model: \"claude-sonnet-4-20250514\",\n170:  *   });\n171:  *\n172:  *   // Feed events as they arrive\n173:  *   collector.ingestEvent(\"my-feature\", event);\n174:  *\n175:  *   // Get aggregated summary\n176:  *   const summary = collector.getSummary(\"my-feature\");\n177:  */\n178: export class TokenCollector {\n179:   /** Per-agent usage records */\n180:   private records: Map<string, UsageRecord[]> = new Map();\n181: \n182:   /** Per-agent context (model, provider, quest, etc.) */\n183:   private contexts: Map<\n184:     string,\n185:     {\n186:       quest_id?: string | null;\n187:       model?: string | null;\n188:       provider?: string | null;\n189:       harness?: string | null;\n190:     }\n191:   > = new Map();\n192: \n193:   /** Callback invoked for each new usage record */\n194:   private onUsage: UsageCallback | null;\n195: \n196:   constructor(onUsage?: UsageCallback) {\n197:     this.onUsage = onUsage ?? null;\n198:   }\n199: \n200:   /**\n201:    * Register context for an agent before events start flowing.\n202:    * This context (model, provider, quest_id) is attached to every\n203:    * UsageRecord emitted for this agent.\n204:    */\n205:   registerAgent(\n206:     taskId: string,\n207:     context?: {\n208:       quest_id?: string | null;\n209:       model?: string | null;\n210:       provider?: string | null;\n211:       harness?: string | null;\n212:     }\n213:   ): void {\n214:     this.contexts.set(taskId, context ?? {});\n215:     if (!this.records.has(taskId)) {\n216:       this.records.set(taskId, []);\n217:     }\n218:   }\n219: \n220:   /**\n221:    * Feed an OpenCode event for a specific agent.\n222:    * If the event is a step_finish with token data, a UsageRecord\n223:    * is created and the onUsage callback is invoked.\n224:    *\n225:    * @returns The parsed UsageRecord, or null if the event had no token data\n226:    */\n227:   ingestEvent(taskId: string, event: OpenCodeEvent): UsageRecord | null {\n228:     if (!isTokenEvent(event)) return null;\n229: \n230:     const context = this.contexts.get(taskId);\n231:     const record = parseUsageFromEvent(event, taskId, context);\n232:     if (!record) return null;\n233: \n234:     if (!this.records.has(taskId)) {\n235:       this.records.set(taskId, []);\n236:     }\n237:     this.records.get(taskId)!.push(record);\n238: \n239:     this.onUsage?.(record);\n240: \n241:     return record;\n242:   }\n243: \n244:   /**\n245:    * Get all usage records for an agent.\n246:    */\n247:   getRecords(taskId: string): UsageRecord[] {\n248:     return this.records.get(taskId) ?? [];\n249:   }\n250: \n251:   /**\n252:    * Get all usage records across all agents.\n253:    */\n254:   getAllRecords(): UsageRecord[] {\n255:     const all: UsageRecord[] = [];\n256:     for (const records of this.records.values()) {\n257:       all.push(...records);\n258:     }\n259:     return all;\n260:   }\n261: \n262:   /**\n263:    * Get an aggregated usage summary for an agent.\n264:    * Returns null if no records exist for the agent.\n265:    */\n266:   getSummary(taskId: string): UsageSummary | null {\n267:     const records = this.records.get(taskId);\n268:     if (!records || records.length === 0) return null;\n269: \n270:     return {\n271:       task_id: taskId,\n272:       total_input: records.reduce((sum, r) => sum + r.input_tokens, 0),\n273:       total_output: records.reduce((sum, r) => sum + r.output_tokens, 0),\n274:       total_cache_read: records.reduce((sum, r) => sum + r.cache_read, 0),\n275:       total_cache_write: records.reduce((sum, r) => sum + r.cache_write, 0),\n276:       total_reasoning: records.reduce((sum, r) => sum + r.reasoning_tokens, 0),\n277:       total_tokens: records.reduce((sum, r) => sum + r.total_tokens, 0),\n278:       total_cost: records.reduce((sum, r) => sum + r.cost, 0),\n279:       step_count: records.length,\n280:     };\n281:   }\n282: \n283:   /**\n284:    * Get aggregated summaries for all tracked agents.\n285:    */\n286:   getAllSummaries(): UsageSummary[] {\n287:     const summaries: UsageSummary[] = [];\n288:     for (const taskId of this.records.keys()) {\n289:       const summary = this.getSummary(taskId);\n290:       if (summary) summaries.push(summary);\n291:     }\n292:     return summaries;\n293:   }\n294: \n295:   /**\n296:    * Remove all records for an agent (e.g. after archiving).\n297:    */\n298:   clear(taskId: string): void {\n299:     this.records.delete(taskId);\n300:     this.contexts.delete(taskId);\n301:   }\n302: \n303:   /**\n304:    * Remove all records for all agents.\n305:    */\n306:   clearAll(): void {\n307:     this.records.clear();\n308:     this.contexts.clear();\n309:   }\n310: }\n\n(End of file - total 310 lines)\n</content>","title":"src/lib/token-collector.ts","metadata":{"preview":"/**\n * token-collector.ts — Parse and collect token usage data from agent events.\n *\n * Responsibilities:\n *   - Define the UsageRecord type for structured token usage data\n *   - Parse step_finish events to extract per-step token counts\n *   - Accumulate usage records per agent (task_id)\n *   - Emit parsed records via callback (storage is handled elsewhere)\n *\n * OpenCode emits step_finish events with this token structure:\n *   {\n *     type: \"step_finish\",\n *     part: {\n *       reason: \"tool-calls\" | \"stop\",\n *       cost: number,\n *       tokens: {\n *         total: number,\n *         input: number,\n *         output: number,\n *         reasoning: number,","truncated":false,"loaded":[]},"time":{"start":1773482662370,"end":1773482662372}}}}
{"type":"tool_use","timestamp":1773482664366,"sessionID":"ses_3143289ffffebE5N0evuhJd5Hx","part":{"id":"prt_cebcdd9e20012WVDADVc03AWVj","sessionID":"ses_3143289ffffebE5N0evuhJd5Hx","messageID":"msg_cebcdcb58001aOwRIp2P9sWubn","type":"tool","callID":"toolu_vrtx_019CpCwBv2ibaVhpfCkHb8CH","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-combo-worktrees/wave-reconnect/src/config.ts","limit":100},"output":"<path>/home/fulgidus/Documents/wombo-combo-worktrees/wave-reconnect/src/config.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * config.ts — Load .wombo-combo/config.json, merge with defaults, validate, expose typed config.\n3:  *\n4:  * The config file lives at .wombo-combo/config.json inside the target project root.\n5:  * All values have sensible defaults so minimal config works out of the box.\n6:  */\n7: \n8: import { readFileSync, existsSync } from \"node:fs\";\n9: import { resolve } from \"node:path\";\n10: import type { MultiplexerPreference } from \"./lib/multiplexer.js\";\n11: \n12: // ---------------------------------------------------------------------------\n13: // .wombo-combo directory constant\n14: // ---------------------------------------------------------------------------\n15: \n16: /** Name of the directory that holds all wombo-combo files */\n17: export const WOMBO_DIR = \".wombo-combo\";\n18: \n19: // ---------------------------------------------------------------------------\n20: // Types\n21: // ---------------------------------------------------------------------------\n22: \n23: /** Agent registry download mode */\n24: export type AgentRegistryMode = \"auto\" | \"monitored\" | \"disabled\";\n25: \n26: export interface WomboConfig {\n27:   /** Directory name for task files relative to .wombo-combo/ (folder-based storage) */\n28:   tasksDir: string;\n29:   /** Directory name for archived task files relative to .wombo-combo/ */\n30:   archiveDir: string;\n31:   /** @deprecated Use tasksDir. Legacy single-file path relative to .wombo-combo/ */\n32:   tasksFile?: string;\n33:   /** @deprecated Use archiveDir. Legacy single-file path relative to .wombo-combo/ */\n34:   archiveFile?: string;\n35:   /** Base branch to create feature branches from */\n36:   baseBranch: string;\n37:   /** Build configuration */\n38:   build: {\n39:     /** Build command to run in worktrees */\n40:     command: string;\n41:     /** Build timeout in milliseconds */\n42:     timeout: number;\n43:     /** Build artifact directory (for quick \"did it build?\" checks) */\n44:     artifactDir: string;\n45:   };\n46:   /** Install configuration */\n47:   install: {\n48:     /** Install command to run in worktrees */\n49:     command: string;\n50:     /** Install timeout in milliseconds */\n51:     timeout: number;\n52:   };\n53:   /** Git configuration */\n54:   git: {\n55:     /** Branch name prefix for feature branches */\n56:     branchPrefix: string;\n57:     /** Git remote name */\n58:     remote: string;\n59:     /** Merge strategy flag */\n60:     mergeStrategy: string;\n61:   };\n62:   /** Agent configuration */\n63:   agent: {\n64:     /** Path to agent binary (null = auto-detect) */\n65:     bin: string | null;\n66:     /** Agent name to pass via --agent flag */\n67:     name: string;\n68:     /** Config files/dirs to copy into worktrees */\n69:     configFiles: string[];\n70:     /** Session name prefix for terminal multiplexer */\n71:     tmuxPrefix: string;\n72:     /** Terminal multiplexer preference: \"auto\" (prefer dmux), \"dmux\", or \"tmux\" */\n73:     multiplexer: MultiplexerPreference;\n74:   };\n75:   /** Portless integration for localhost server testing */\n76:   portless: {\n77:     /** Whether portless is enabled for agent worktrees */\n78:     enabled: boolean;\n79:     /** Path to portless binary (null = auto-detect via PATH) */\n80:     bin: string | null;\n81:     /** Proxy port (portless default is 1355) */\n82:     proxyPort: number;\n83:     /** Whether to use HTTPS mode */\n84:     https: boolean;\n85:   };\n86:   /** Backup configuration for tasks file */\n87:   backup: {\n88:     /** Maximum number of timestamped backups to keep */\n89:     maxBackups: number;\n90:   };\n91:   /** Default runtime values */\n92:   defaults: {\n93:     /** Max concurrent agents */\n94:     maxConcurrent: number;\n95:     /** Max retries per agent */\n96:     maxRetries: number;\n97:   };\n98:   /** Browser testing configuration */\n99:   browser: BrowserConfig;\n100:   /** Agent registry configuration for specialized agent downloads */\n\n(Showing lines 1-100 of 356. Use offset=101 to continue.)\n</content>","title":"src/config.ts","metadata":{"preview":"/**\n * config.ts — Load .wombo-combo/config.json, merge with defaults, validate, expose typed config.\n *\n * The config file lives at .wombo-combo/config.json inside the target project root.\n * All values have sensible defaults so minimal config works out of the box.\n */\n\nimport { readFileSync, existsSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\nimport type { MultiplexerPreference } from \"./lib/multiplexer.js\";\n\n// ---------------------------------------------------------------------------\n// .wombo-combo directory constant\n// ---------------------------------------------------------------------------\n\n/** Name of the directory that holds all wombo-combo files */\nexport const WOMBO_DIR = \".wombo-combo\";\n\n// ---------------------------------------------------------------------------\n// Types","truncated":true,"loaded":[]},"time":{"start":1773482664363,"end":1773482664365}}}}
